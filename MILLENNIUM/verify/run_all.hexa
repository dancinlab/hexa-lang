#!hexa strict
// hexa-millennium/verify/run_all.hexa — aggregator (.hexa primary).
//
// Single CLI entry that runs all verify/*.hexa scripts and aggregates
// pass/fail. Sister of hexa-matter/rtsc/ufo/cern/fusion's run_all.hexa
// pattern, scaled to spec-first Clay-Millennium scope.
//
// Closure shape for hexa-millennium (spec-first, 7-verb):
//   1. spec_presence         — 7/7 Clay-verb candidate-spec docs present
//   2. lattice_arithmetic    — n=6 self-consistency (aux per LATTICE_POLICY §1.3)
//   3. real_limits_anchor    — LIMIT_BREAKTHROUGH.md anchors (Gödel HARD_WALL,
//                              ZFC, Clay 2-yr review, Perelman 2003, etc.)
//   4. closure_consistency   — scoreboard cross-check (CLI · toml · README · AGENTS)
//
//   PASS means the 7 verbs ship CANDIDATE SPECS — it does NOT claim that
//   any Clay Millennium Problem has been solved by this repo. Poincaré is
//   Perelman 2003; the other six remain OPEN. Acceptance would require
//   formal Lean4/Coq proofs + Clay-mandated 2-yr community review.
//
// Run:
//     hexa run verify/run_all.hexa     # exit 0 = all subscripts PASS

let HOME = env("HOME")
let HEXA_MILLENNIUM_ROOT_ENV = env("HEXA_MILLENNIUM_ROOT")

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_root() -> str {
    if HEXA_MILLENNIUM_ROOT_ENV.len() > 0 { return HEXA_MILLENNIUM_ROOT_ENV }
    let oldpwd = env("OLDPWD")
    if oldpwd.len() > 0 {
        let t = exec("[ -f " + shq(oldpwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return oldpwd }
    }
    let pwd = env("PWD")
    if pwd.len() > 0 {
        let t = exec("[ -f " + shq(pwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return pwd }
    }
    return HOME + "/core/hexa-millennium"
}

let SCRIPTS: [str] = [
    "verify/spec_presence.hexa",
    "verify/lattice_arithmetic.hexa",
    "verify/real_limits_anchor.hexa",
    "verify/closure_consistency.hexa",
]

fn main() {
    let root = _resolve_root()
    println("========================================================================")
    println("  hexa-millennium verify/run_all — aggregate sweep (Clay 7-verb candidate)")
    println("  root: " + root)
    println("========================================================================")
    let mut passed = 0
    let mut failed = 0
    for s in SCRIPTS {
        println("")
        println("---- " + s + " ----")
        let abs_script = root + "/" + s
        let cmd = "cd " + shq(root) + " && hexa run " + shq(abs_script) + " >/tmp/_hexa_millennium_v.out 2>&1; echo $?"
        let rc_str = exec(cmd).trim()
        let parts = rc_str.split("\n")
        let last = parts[parts.len() - 1].trim()
        let rc = int(last)
        let out = exec("cat /tmp/_hexa_millennium_v.out 2>/dev/null")
        // Print last 6 lines for compactness.
        let lines = out.split("\n")
        let n = lines.len()
        let mut start = 0
        if n > 6 { start = n - 6 }
        let mut k = start
        while k < n {
            println(lines[k])
            k = k + 1
        }
        let marker_pass = out.contains("__HEXA_MILLENNIUM_") && out.contains("__ PASS")
        let marker_fail = out.contains("__HEXA_MILLENNIUM_") && out.contains("__ FAIL")
        let script_pass = (rc == 0 && marker_pass) || (rc == 0 && marker_fail == false && out.len() > 0)
        let script_fail = rc != 0 || marker_fail
        if script_fail {
            failed = failed + 1
            println("  → " + s + " FAIL (rc=" + str(rc) + ")")
        } else if script_pass {
            passed = passed + 1
            println("  → " + s + " PASS")
        } else {
            failed = failed + 1
            println("  → " + s + " FAIL (no PASS marker, rc=" + str(rc) + ")")
        }
    }
    println("")
    println("========================================================================")
    let total = passed + failed
    println("  " + str(passed) + "/" + str(total) + " scripts passed")
    if failed > 0 {
        println("  verify sweep FAILED — see per-script output above.")
        exit(1)
    }
    println("  PASS — all hexa-millennium closure invariants hold (CANDIDATE specs, NOT proofs).")
}
