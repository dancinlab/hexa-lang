// HEXA Native Compiler — Discovery staging writer (RFC-017 §5: ε self-proof)
//
// @version 0.1.0
// @capabilities [pure, fs_write]
//
// Writes a list of DiscoveryProposal records to a single
//   atlas.proposed.{date}.n6
// staging file. This is the FIRST step of atlas auto-discovery — the file
// is *not* live atlas: a future promote_to_atlas() driver folds approved
// entries into the real atlas.append.*.n6 stream.
//
// Format (line-oriented, atlas-compatible header but ".proposed." namespace):
//
//   # auto-generated by hexa discover staging — do not edit
//   # generated_at: <ISO-8601>
//   # verifier_version: hexa-prover-v0
//   L[<fn_name>] @ <proof_hash>
//     defined_at: <span.file>:<span.line>
//     normalized_form: <s-expr>
//     params: <sorted,types>
//
// The leading sigil tracks the discovered atlas kind: "L[…]" for laws,
// "P[…]" / "C[…]" / "E[…]" likewise (matches the embed/parser P/C/L/E
// vocabulary). Comment lines start with `#` so the existing
// compiler/atlas/parser.hexa skips them harmlessly when this file is later
// re-ingested by promote_to_atlas() — that promotion is deferred.
//
// pub fn write_staging(proposals: [DiscoveryProposal], path: string) -> i64
//   returns 0 on success.

import "./discover.hexa"

// -- ISO-8601 UTC stamp ----------------------------------------
// Uses `date -u`; falls back to the empty string if exec is unavailable.
fn _iso_utc_now() -> string {
    // TODO(L2): replace with iso_utc_now intrinsic (compiler/intrinsics/intrinsics.hexa, task 56)
    let s = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()  // @allow-bare-exec
    return s
}

// -- Emit one proposal block ----------------------------------

fn _emit_proposal(p: DiscoveryProposal, parts: array) {
    parts.push(p.kind)
    parts.push("[")
    parts.push(p.fn_name)
    parts.push("] @ ")
    parts.push(p.proof_hash)
    parts.push("\n  defined_at: ")
    parts.push(p.span.file)
    parts.push(":")
    parts.push(to_string(p.span.line))
    parts.push("\n  normalized_form: ")
    parts.push(p.normalized_form)
    parts.push("\n  params: ")
    parts.push(p.sorted_param_types)
    parts.push("\n  verifier: ")
    parts.push(p.verifier_version)
    parts.push("\n")
}

// -- Public API ------------------------------------------------

pub fn write_staging(proposals: [DiscoveryProposal], path: string) -> i64 {
    let parts = []
    parts.push("# auto-generated by hexa discover staging — do not edit\n")
    parts.push("# generated_at: ")
    parts.push(_iso_utc_now())
    parts.push("\n")
    parts.push("# verifier_version: ")
    parts.push(DISCOVER_VERIFIER_VERSION)
    parts.push("\n")
    parts.push("# proposal_count: ")
    parts.push(to_string(len(proposals)))
    parts.push("\n\n")

    let mut i = 0
    while i < len(proposals) {
        _emit_proposal(proposals[i], parts)
        i = i + 1
    }

    let body = parts.join("")
    write_file(path, body)
    return 0
}
