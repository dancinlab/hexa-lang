// HEXA Native Compiler — Discovery tombstone (RFC-017 §5e: invalidation) — Step 3
//
// @version 0.1.0
// @capabilities [pure, fs_read, fs_write]
//
// Third step of atlas auto-discovery (RFC-017 decision 5e —
// `tombstone_plus_retroactive_sweep`). Records the obsolescence of an L node
// on a dedicated history file `atlas.tombstones.n6` under `atlas_root`. The
// merger keeps the original L node bytes intact (history is append-only); the
// tombstone file is the single source of truth for "this L is no longer
// citable". Citation pass (compiler/check/citation.hexa) consults the
// tombstone set and emits HX1099 for any @implements(L[id]) whose id matches.
//
// SCOPE
//   This module covers ONLY the manual-tombstone half of decision 5e. The
//   automatic-sweep companion (compiler/discover/retroactive_sweep.hexa)
//   layers on top by calling tombstone_node() with reason="auto-sweep …".
//
// FORMAT (atlas.tombstones.n6, line-oriented, ENGLISH ONLY)
//   # auto-generated by hexa atlas tombstone — append-only history
//   tombstone L[<node_id>]
//       reason: "<reason>"
//       discovered_at: <ISO-8601>
//       discovered_by: "<user-handle or auto-sweep>"
//       replacement: L[<replacement>]   (optional, omit if none)
//       prev_proof_hash: <hash>
//       prev_verifier_version: <ver>
//
// PUBLIC SURFACE
//   pub struct Tombstone { ... }
//   pub fn tombstone_node(atlas_root, node_id, reason, replacement) -> i64
//   pub fn is_tombstoned(atlas_root, node_id) -> bool
//   pub fn list_tombstones(atlas_root) -> [Tombstone]
//
// Catalog/diagnostic strings: ENGLISH ONLY (RFC-019 §6 + repo policy).

import "../atlas/parser.hexa"
import "../atlas/merger.hexa"

// -- Tombstone record ---------------------------------------------

pub struct Tombstone {
    node_id: string,
    reason: string,
    discovered_at: string,
    discovered_by: string,
    replacement: string,
    prev_proof_hash: string,
    prev_verifier_version: string
}

fn _empty_tombstone() -> Tombstone {
    return Tombstone {
        node_id: "",
        reason: "",
        discovered_at: "",
        discovered_by: "",
        replacement: "",
        prev_proof_hash: "",
        prev_verifier_version: ""
    }
}

// -- ISO-8601 (date+time) -----------------------------------------

fn _iso_utc_now() -> string {
    // TODO(L2): replace with intrinsic iso_utc_now() from compiler/intrinsics/intrinsics.hexa (task #56)
    let s = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()  // @allow-bare-exec
    return s
}

// -- Tiny string utilities ----------------------------------------

fn _is_ws_char(c: string) -> bool {
    return c == " " || c == "\t"
}

fn _ltrim(s: string) -> string {
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if !_is_ws_char(c) { break }
        i = i + 1
    }
    return s.substring(i, n)
}

fn _rtrim(s: string) -> string {
    let n = len(s)
    let mut i = n
    while i > 0 {
        let c = s.substring(i - 1, i)
        if !_is_ws_char(c) && c != "\n" && c != "\r" { break }
        i = i - 1
    }
    return s.substring(0, i)
}

fn _starts_with(s: string, prefix: string) -> bool {
    let m = len(prefix)
    if len(s) < m { return false }
    return s.substring(0, m) == prefix
}

// Extract the id between the FIRST '[' and the matching ']' (so a line of the
// form "tombstone L[my-id]" yields "my-id"). Returns "" if either bracket is
// absent.
fn _bracketed_id(s: string) -> string {
    let n = len(s)
    let mut i = 0
    while i < n && s.substring(i, i + 1) != "[" { i = i + 1 }
    if i >= n { return "" }
    let mut j = i + 1
    while j < n && s.substring(j, j + 1) != "]" { j = j + 1 }
    if j >= n { return "" }
    return s.substring(i + 1, j)
}

// Strip an optional leading-and-trailing pair of double quotes ("foo" → foo).
fn _unquote(s: string) -> string {
    let n = len(s)
    if n < 2 { return s }
    if s.substring(0, 1) != "\"" { return s }
    if s.substring(n - 1, n) != "\"" { return s }
    return s.substring(1, n - 1)
}

// -- File paths ----------------------------------------------------

fn _tombstones_path(atlas_root: string) -> string {
    return atlas_root + "/atlas.tombstones.n6"
}

fn _file_exists_or_empty(path: string) -> string {
    if !file_exists(path) { return "" }
    return read_file(path)
}

// -- Atlas L lookup helpers ----------------------------------------

// Pull the proof_hash continuation line from an L node's raw text.
// Mirror of compiler/discover/promote.hexa::_extract_existing_proof_hash kept
// inline here so the tombstone module stays standalone.
fn _extract_proof_hash(raw: string) -> string {
    let lines = raw.split("\n")
    let mut i = 0
    while i < len(lines) {
        let s = _ltrim(lines[i])
        if _starts_with(s, "proof_hash:") {
            return _ltrim(s.substring(len("proof_hash:"), len(s)))
        }
        i = i + 1
    }
    return ""
}

// Pull the verifier_version continuation line from an L node's raw text.
fn _extract_verifier_version(raw: string) -> string {
    let lines = raw.split("\n")
    let mut i = 0
    while i < len(lines) {
        let s = _ltrim(lines[i])
        if _starts_with(s, "verifier_version:") {
            return _ltrim(s.substring(len("verifier_version:"), len(s)))
        }
        i = i + 1
    }
    return ""
}

// Locate an AtlasNode by (kind="L", id) in the index. Returns a sentinel with
// kind="" when missing — mirrors merger::lookup behaviour.
fn _find_l_node(idx: AtlasIndex, id: string) -> AtlasNode {
    let mut i = 0
    while i < len(idx.l_nodes) {
        let n = idx.l_nodes[i]
        if n.id == id { return n }
        i = i + 1
    }
    return AtlasNode {
        kind: "",
        id: id,
        raw: "",
        source_file: "",
        source_line: 0
    }
}

// File-level @L block extractor. Reads atlas.n6 (and every
// atlas.append.*.n6 in alpha order) line-by-line, returns the contiguous
// "@L <id>" block bytes for the requested id (or "" when absent). We
// bypass compiler/atlas/parser.hexa here because the Stage0 hexa
// interp's array push semantics drop every-other continuation line out
// of node.raw; reading the file ourselves keeps the bytes intact.
fn _extract_l_block_from_file(atlas_root: string, id: string) -> string {
    // Try the main atlas.n6 first; if not found, scan append shards.
    let candidates = []
    candidates.push(atlas_root + "/atlas.n6")
    let entries = list_dir(atlas_root)
    if type_of(entries) == "array" {
        let mut k = 0
        while k < len(entries) {
            let name = to_string(entries[k])
            if len(name) >= 16 && name.substring(0, 13) == "atlas.append." {
                let tail = name.substring(len(name) - 3, len(name))
                if tail == ".n6" {
                    candidates.push(atlas_root + "/" + name)
                }
            }
            k = k + 1
        }
    }
    let mut ci = 0
    while ci < len(candidates) {
        let path = candidates[ci]
        if !file_exists(path) { ci = ci + 1; continue }
        let text = read_file(path)
        if len(text) == 0 { ci = ci + 1; continue }
        let lines = text.split("\n")
        let n_lines = len(lines)
        let header_prefix = "@L " + id
        let mut in_block = false
        let parts = []
        let mut i = 0
        while i < n_lines {
            let line = lines[i]
            if len(line) == 0 { i = i + 1; continue }
            let c0 = line.substring(0, 1)
            if c0 == "@" {
                if in_block {
                    // Hit next @-header → block ended.
                    return parts.join("\n")
                }
                if _starts_with(line, header_prefix) {
                    let next_after = len(header_prefix)
                    if next_after >= len(line) {
                        in_block = true
                        parts.push(line)
                    } else {
                        let nc = line.substring(next_after, next_after + 1)
                        if _is_ws_char(nc) || nc == "\r" {
                            in_block = true
                            parts.push(line)
                        }
                    }
                }
                i = i + 1
                continue
            }
            if in_block {
                parts.push(line)
            }
            i = i + 1
        }
        if in_block { return parts.join("\n") }
        ci = ci + 1
    }
    return ""
}

// -- Tombstone parser ----------------------------------------------
// Walks atlas.tombstones.n6 line-by-line, splitting on the literal header
// prefix "tombstone L[". Each tombstone block ends at the next header line
// or EOF; continuation lines must be indented (leading whitespace).
fn _parse_tombstones_text(text: string) -> array {
    let out = []
    if len(text) == 0 { return out }
    let lines = text.split("\n")
    let n_lines = len(lines)
    let mut have_cur = false
    let mut cur = _empty_tombstone()
    let mut i = 0
    while i < n_lines {
        let line = lines[i]
        if len(line) == 0 { i = i + 1; continue }
        let c0 = line.substring(0, 1)
        if c0 == "#" { i = i + 1; continue }
        if _starts_with(line, "tombstone L[") {
            if have_cur { out.push(cur) }
            cur = _empty_tombstone()
            cur.node_id = _bracketed_id(line)
            have_cur = true
            i = i + 1
            continue
        }
        if have_cur {
            let stripped = _ltrim(line)
            if _starts_with(stripped, "reason:") {
                cur.reason = _unquote(_ltrim(stripped.substring(len("reason:"), len(stripped))))
            } else if _starts_with(stripped, "discovered_at:") {
                cur.discovered_at = _ltrim(stripped.substring(len("discovered_at:"), len(stripped)))
            } else if _starts_with(stripped, "discovered_by:") {
                cur.discovered_by = _unquote(_ltrim(stripped.substring(len("discovered_by:"), len(stripped))))
            } else if _starts_with(stripped, "replacement:") {
                let rest = _ltrim(stripped.substring(len("replacement:"), len(stripped)))
                cur.replacement = _bracketed_id(rest)
            } else if _starts_with(stripped, "prev_proof_hash:") {
                cur.prev_proof_hash = _ltrim(stripped.substring(len("prev_proof_hash:"), len(stripped)))
            } else if _starts_with(stripped, "prev_verifier_version:") {
                cur.prev_verifier_version = _ltrim(stripped.substring(len("prev_verifier_version:"), len(stripped)))
            }
        }
        i = i + 1
    }
    if have_cur { out.push(cur) }
    return out
}

// -- Tombstone block emitter ---------------------------------------

fn _render_tombstone_block(t: Tombstone, parts: array) {
    parts.push("tombstone L[")
    parts.push(t.node_id)
    parts.push("]\n    reason: \"")
    parts.push(t.reason)
    parts.push("\"\n    discovered_at: ")
    parts.push(t.discovered_at)
    parts.push("\n    discovered_by: \"")
    parts.push(t.discovered_by)
    parts.push("\"\n")
    if len(t.replacement) > 0 {
        parts.push("    replacement: L[")
        parts.push(t.replacement)
        parts.push("]\n")
    }
    parts.push("    prev_proof_hash: ")
    parts.push(t.prev_proof_hash)
    parts.push("\n    prev_verifier_version: ")
    parts.push(t.prev_verifier_version)
    parts.push("\n")
}

// -- Public API ----------------------------------------------------

// list_tombstones — read atlas.tombstones.n6 (if present) and return every
// Tombstone record parsed from it. Returns an empty array when the file is
// missing or empty.
pub fn list_tombstones(atlas_root: string) -> array {
    let path = _tombstones_path(atlas_root)
    let text = _file_exists_or_empty(path)
    return _parse_tombstones_text(text)
}

// is_tombstoned — true iff atlas.tombstones.n6 contains a `tombstone L[id]`
// header for the given node_id. The check is a fast string scan; a full parse
// is unnecessary for the hot path used by the citation pass.
pub fn is_tombstoned(atlas_root: string, node_id: string) -> bool {
    let path = _tombstones_path(atlas_root)
    let text = _file_exists_or_empty(path)
    if len(text) == 0 { return false }
    let needle = "tombstone L[" + node_id + "]"
    let lines = text.split("\n")
    let mut i = 0
    while i < len(lines) {
        let s = lines[i]
        if _starts_with(s, needle) {
            // Must be exactly "tombstone L[id]" (next char is end-of-line or
            // ws); guards against L[id-extended] aliasing.
            let m = len(needle)
            if len(s) == m { return true }
            let c = s.substring(m, m + 1)
            if _is_ws_char(c) || c == "\r" { return true }
        }
        i = i + 1
    }
    return false
}

// tombstone_node — append a Tombstone record for `node_id` to
// atlas.tombstones.n6. Looks up the L node in the live atlas first to
// capture its proof_hash + verifier_version (so future audits can tell which
// canonical record was retired).
//
// Returns:
//   0  on success
//   2  when the atlas index has no L node with that id
//   3  when the file system write fails (best-effort detection — write_file
//      itself doesn't return a status; we re-read and probe)
//
// Does NOT modify atlas.n6 or any append shard. The original L node bytes
// remain intact so promote/merge operations don't reshuffle history.
pub fn tombstone_node(atlas_root: string, node_id: string, reason: string,
                      replacement: string) -> i64 {
    // Read the L block bytes directly from the atlas file -- the merger's
    // node.raw is unreliable under Stage0 interp (drops continuation lines).
    let block = _extract_l_block_from_file(atlas_root, node_id)
    if len(block) == 0 {
        println("tombstone_node: no atlas L node `" + node_id + "` under " + atlas_root)
        return 2
    }

    let prev_hash = _extract_proof_hash(block)
    let prev_ver = _extract_verifier_version(block)

    let t = Tombstone {
        node_id: node_id,
        reason: reason,
        discovered_at: _iso_utc_now(),
        discovered_by: "manual",
        replacement: replacement,
        prev_proof_hash: prev_hash,
        prev_verifier_version: prev_ver
    }

    let path = _tombstones_path(atlas_root)
    let mut existing = _file_exists_or_empty(path)
    let parts = []
    if len(existing) == 0 {
        parts.push("# auto-generated by hexa atlas tombstone — append-only history\n")
        parts.push("# generated_at: ")
        parts.push(_iso_utc_now())
        parts.push("\n# format: tombstone L[id] + indented continuation lines\n\n")
    } else {
        parts.push(existing)
        // Ensure a separating newline between the prior block and the new one.
        let n = len(existing)
        if n > 0 && existing.substring(n - 1, n) != "\n" {
            parts.push("\n")
        }
    }
    _render_tombstone_block(t, parts)
    write_file(path, parts.join(""))

    // Sanity probe: re-read and confirm the header landed.
    if !is_tombstoned(atlas_root, node_id) {
        println("tombstone_node: write_file appears to have failed for " + path)
        return 3
    }

    println("tombstone_node: L[" + node_id + "] tombstoned (reason=\"" + reason + "\")")
    return 0
}

// tombstone_node_with_actor — same as tombstone_node but lets the caller
// override discovered_by (used by the auto-sweep driver to record
// "auto-sweep <verifier_version>" instead of "manual"). Kept as a sibling
// rather than a default-arg overload to stay portable across Stage0 hexa
// runtimes that lack default-args / overloading.
pub fn tombstone_node_with_actor(atlas_root: string, node_id: string,
                                 reason: string, replacement: string,
                                 discovered_by: string) -> i64 {
    let block = _extract_l_block_from_file(atlas_root, node_id)
    if len(block) == 0 {
        println("tombstone_node_with_actor: no atlas L node `" + node_id + "` under " + atlas_root)
        return 2
    }

    let prev_hash = _extract_proof_hash(block)
    let prev_ver = _extract_verifier_version(block)

    let t = Tombstone {
        node_id: node_id,
        reason: reason,
        discovered_at: _iso_utc_now(),
        discovered_by: discovered_by,
        replacement: replacement,
        prev_proof_hash: prev_hash,
        prev_verifier_version: prev_ver
    }

    let path = _tombstones_path(atlas_root)
    let mut existing = _file_exists_or_empty(path)
    let parts = []
    if len(existing) == 0 {
        parts.push("# auto-generated by hexa atlas tombstone — append-only history\n")
        parts.push("# generated_at: ")
        parts.push(_iso_utc_now())
        parts.push("\n# format: tombstone L[id] + indented continuation lines\n\n")
    } else {
        parts.push(existing)
        let n = len(existing)
        if n > 0 && existing.substring(n - 1, n) != "\n" {
            parts.push("\n")
        }
    }
    _render_tombstone_block(t, parts)
    write_file(path, parts.join(""))

    if !is_tombstoned(atlas_root, node_id) {
        println("tombstone_node_with_actor: write_file appears to have failed for " + path)
        return 3
    }
    return 0
}
