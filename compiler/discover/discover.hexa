// HEXA Native Compiler — Discovery (RFC-017 §5: ε self-proof) — Step 1
//
// @version 0.1.0
// @capabilities [pure]
//
// First step of atlas auto-discovery (RFC-017 decision 5b — fully_automatic).
// SCOPE OF THIS STEP: STAGING ONLY. We do NOT register live atlas nodes here.
//
// Walks Item.annotations across a Module. For every Item that carries BOTH
//   @discover(kind="L"|"P"|"C"|"E")  AND
//   @verify
// we:
//   (a) compute a canonical normalized_form of the body's main `==` BinOp
//       (mirrors compiler/check/equational.hexa _normalize, kept inline here
//        so we don't perturb the verifier module),
//   (b) compute a 32-char proof_hash = first 32 hex chars of
//       sha256(normalized_form || "|" || verifier_version || "|" || sorted_param_types),
//   (c) emit a DiscoveryProposal record.
//
// Items lacking `@discover` are skipped — even if `@verify` proves them — so
// authors retain explicit opt-in until promote_to_atlas() lands.
//
// Items lacking `@verify` are skipped — RFC-017 §5 requires the prover signal
// before staging.
//
// Items whose body has no `==` BinOp are skipped — there is nothing to
// canonicalise.
//
// Public surface:
//   pub struct DiscoveryProposal { ... }
//   pub fn discover_check(module: Module) -> [DiscoveryProposal]
//
// Catalog/diagnostic strings: ENGLISH ONLY (RFC-019 §6 + repo policy).

import "../parse/ast.hexa"
import "../lex/tokens.hexa"
import "../../stdlib/hash/sha256.hexa"

// -- verifier version pin ---------------------------------------
// Matches SPEC.yaml prover_engine.initial_capabilities surface; bumped
// whenever the canonicalisation rule set changes (retroactive sweep
// trigger per RFC-017 §5e).
pub let DISCOVER_VERIFIER_VERSION: string = "hexa-prover-v0"

// -- Public record ---------------------------------------------

pub struct DiscoveryProposal {
    fn_name: string,
    kind: string,                 // "P" | "C" | "L" | "E"
    proof_hash: string,           // 32 hex chars (sha256 prefix)
    verifier_version: string,     // pinned to DISCOVER_VERIFIER_VERSION
    normalized_form: string,      // canonical s-expression of LHS == RHS
    sorted_param_types: string,   // comma-joined sorted Param.typ.name list
    span: Span                    // span of the `==` BinOp (or item if absent)
}

// -- ExprKind / ItemKind probes (mirror equational.hexa) -------

fn _is_lit_int_kind(k: ExprKind) -> bool {
    return match k {
        ExprKind::LiteralInt -> true,
        ExprKind::LiteralFloat -> false,
        ExprKind::LiteralString -> false,
        ExprKind::LiteralBool -> false,
        ExprKind::LiteralChar -> false,
        ExprKind::Ident -> false,
        ExprKind::AtlasRef -> false,
        ExprKind::Call -> false,
        ExprKind::BinOp -> false,
        ExprKind::UnOp -> false,
        ExprKind::Block -> false,
        ExprKind::If -> false,
        ExprKind::While -> false,
        ExprKind::For -> false,
        ExprKind::Match -> false,
        ExprKind::Return -> false,
        ExprKind::Break -> false,
        ExprKind::Continue -> false,
        ExprKind::Let -> false,
        ExprKind::Assign -> false,
        ExprKind::Field -> false,
        ExprKind::Index -> false,
        ExprKind::ArrayLit -> false,
        ExprKind::StructLit -> false,
        ExprKind::EnumPath -> false,
        ExprKind::Wildcard -> false
    }
}

