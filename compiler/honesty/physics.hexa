// HEXA Native Compiler — Phase 2 absorption: A3 physics-domain verifier
//
// @version 0.1.0
// @capabilities [pure]
//
// Source: ~/core/nexus/tool/check_physics.hexa.
//
// Ports the portable subset of the physics verifier:
//   - dimensional analysis (SI 7-axis) — 6 invariants (E=mc², F=ma, p=mv,
//     KE=½mv², P=F·v, plus one negative test ¬(E=mv)).
//   - conservation laws (scaled int 10^6, 0.1% / 1000 ppm tolerance) —
//     4 invariants (ΔE elastic, Δp elastic, ΔL no-torque, plus one
//     negative test).
//
// Deferred (require external bridges):
//   - anchor (sim_bridge/anu_time/empirical_anchor.hexa)
//   - codata (tool/codata_bridge.hexa)
//   - planck (tool/cmb_planck_bridge.hexa)
//   - lorentz (sim_bridge/anu_time/lorentz_metric.hexa)
// All four call out to network-dependent helpers; the upstream router
// already gates them on explicit `--all` / per-domain flags. Phase 2
// keeps the in-process dim/cons subset; the bridges are Phase 3 work
// once the IO-capability boundary lands.
//
//   pub fn physics_check() -> PhysicsVerdict

pub struct PhysicsVerdict {
    overall: string,   // "PASS" | "FAIL"
    dim_pass: i64,
    dim_total: i64,
    cons_pass: i64,
    cons_total: i64
}

// --- dimensional analysis -------------------------------------------------
// axes = [M, L, T, I, Theta, N, J]; only the first three carry signal in
// the upstream test set so we leave I/Theta/N/J at zero.

fn _dim_make(m: i64, l: i64, t: i64) -> array {
    let r = []
    r.push(m); r.push(l); r.push(t)
    r.push(0); r.push(0); r.push(0); r.push(0)
    return r
}

fn _dim_add(a: array, b: array) -> array {
    let r = []
    let mut i = 0
    while i < 7 {
        r.push(to_int(a[i]) + to_int(b[i]))
        i = i + 1
    }
    return r
}

fn _dim_scale(a: array, k: i64) -> array {
    let r = []
    let mut i = 0
    while i < 7 {
        r.push(to_int(a[i]) * k)
        i = i + 1
    }
    return r
}

fn _dim_eq(a: array, b: array) -> bool {
    let mut i = 0
    while i < 7 {
        if to_int(a[i]) != to_int(b[i]) { return false }
        i = i + 1
    }
    return true
}

fn _run_dimensional() -> array {
    let dM   = _dim_make(1, 0, 0)
    let dL   = _dim_make(0, 1, 0)
    let dT   = _dim_make(0, 0, 1)
    let dVel = _dim_make(0, 1, -1)    // L/T
    let dAcc = _dim_make(0, 1, -2)    // L/T²
    let dF   = _dim_make(1, 1, -2)    // M·L/T²
    let dMom = _dim_make(1, 1, -1)    // M·L/T
    let dE   = _dim_make(1, 2, -2)    // M·L²/T²
    let dP   = _dim_make(1, 2, -3)    // M·L²/T³

    let mut p: i64 = 0
    let mut t: i64 = 0

    // 1. E = mc²
    if _dim_eq(dE, _dim_add(dM, _dim_scale(dVel, 2))) { p = p + 1 }
    t = t + 1
    // 2. F = ma
    if _dim_eq(dF, _dim_add(dM, dAcc)) { p = p + 1 }
    t = t + 1
    // 3. p = mv
    if _dim_eq(dMom, _dim_add(dM, dVel)) { p = p + 1 }
    t = t + 1
    // 4. KE = ½mv²
    if _dim_eq(dE, _dim_add(dM, _dim_scale(dVel, 2))) { p = p + 1 }
    t = t + 1
    // 5. P = F·v
    if _dim_eq(dP, _dim_add(dF, dVel)) { p = p + 1 }
    t = t + 1
    // 6. negative test — E = mv 는 틀려야 함
    if !_dim_eq(dE, _dim_add(dM, dVel)) { p = p + 1 }
    t = t + 1

    let out = []
    out.push(p); out.push(t)
    return out
}

// --- conservation laws (scaled int 10^6) ---------------------------------

fn _abs_i(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn _within_ppm(before: i64, after: i64, ppm: i64) -> bool {
    let d = _abs_i(before - after)
    let a = _abs_i(before)
    if a == 0 { return d <= ppm }
    return d * 1000000 <= ppm * a
}

fn _run_conservation() -> array {
    let mut p: i64 = 0
    let mut t: i64 = 0
    let tol: i64 = 1000   // 0.1% = 1000 ppm

    // 1D elastic m1=2 m2=1 v1=3 v2=-1 → analytic: E,p,L conserved
    // E = 0.5·2·9 + 0.5·1·1 = 9.5  → 9_500_000
    if _within_ppm(9500000, 9500000, tol) { p = p + 1 }
    t = t + 1
    // p = 2·3 + 1·(-1) = 5 → 5_000_000
    if _within_ppm(5000000, 5000000, tol) { p = p + 1 }
    t = t + 1
    // angular L (no torque) constant
    if _within_ppm(10000000, 10000000, tol) { p = p + 1 }
    t = t + 1
    // negative test — 1% violation must trip 0.1% tol
    if !_within_ppm(10000000, 10100000, tol) { p = p + 1 }
    t = t + 1

    let out = []
    out.push(p); out.push(t)
    return out
}

// --- public ---------------------------------------------------------------

pub fn physics_check() -> PhysicsVerdict {
    let d = _run_dimensional()
    let c = _run_conservation()
    let dp = to_int(d[0])
    let dt = to_int(d[1])
    let cp = to_int(c[0])
    let ct = to_int(c[1])
    let mut verdict: string = "PASS"
    if dp != dt { verdict = "FAIL" }
    if cp != ct { verdict = "FAIL" }
    return PhysicsVerdict {
        overall: verdict,
        dim_pass: dp,
        dim_total: dt,
        cons_pass: cp,
        cons_total: ct
    }
}
