// HEXA Native Compiler — Phase B3 / S3+S4: type & domain smoke test
//
// @version 0.1.0
// @capabilities [pure]
//
// Hand-builds five small Modules and exercises the type pass:
//
//   (a) PASS — fn add(x:Int,y:Int)->Int { return x+y } fn main(){ add(1,2) }
//       expect 0 diagnostics
//
//   (b) FAIL HX3002 — fn add(x:Int,y:Int)->Int{...} fn main(){ add(1) }
//       expect 1 HX3002 (wrong arity)
//
//   (c) FAIL HX3003 — fn add(x:Int,y:Int)->Int{...} fn main(){ add(1,"hi") }
//       expect 1 HX3003 (arg #2 type mismatch)
//
//   (d) FAIL HX3001 — fn main(){ let _ = 1 + true }
//       expect 1 HX3001 (binop operand mismatch)
//
//   (e) FAIL HX3004 — fn pick()->Int { return "no" }
//       expect 1 HX3004 (return type mismatch)
//
// Run:
//   hexa run compiler/check/types_test.hexa

import "../parse/ast.hexa"
import "../diag/catalog.hexa"
import "../lex/tokens.hexa"
import "../ir/hir.hexa"
import "./types.hexa"

// ── AST construction helpers ─────────────────────────────────

fn _span(file: string, line: i64, col: i64, length: i64) -> Span {
    return Span { file: file, line: line, col: col, len: length }
}

fn _empty_span() -> Span {
    return _span("", 0, 0, 0)
}

fn _empty_atlas_ref() -> AtlasRef {
    return AtlasRef { kind: "", id: "", span: _empty_span() }
}

fn _empty_type_ref() -> TypeRef {
    return TypeRef { kind: "", name: "", args: [], span: _empty_span() }
}

fn _named_type_ref(name: string) -> TypeRef {
    return TypeRef { kind: "named", name: name, args: [], span: _empty_span() }
}

fn _ident_expr(name: string, file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::Ident,
        span: _span(file, line, col, len(name)),
        text: name,
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
}

fn _int_expr(text: string, file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::LiteralInt,
        span: _span(file, line, col, len(text)),
        text: text,
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
}

fn _string_expr(text: string, file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::LiteralString,
        span: _span(file, line, col, len(text)),
        text: text,
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
}

fn _bool_expr(text: string, file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::LiteralBool,
        span: _span(file, line, col, len(text)),
        text: text,
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
}

fn _bin_expr(op: string, lhs: Expr, rhs: Expr, file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(lhs)
    kids.push(rhs)
    return Expr {
        kind: ExprKind::BinOp,
        span: _span(file, line, col, len(op)),
        text: op,
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _call_expr(callee: Expr, args: [Expr], file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(callee)
    let mut i = 0
    while i < len(args) {
        kids.push(args[i])
        i = i + 1
    }
    return Expr {
        kind: ExprKind::Call,
        span: _span(file, line, col, 1),
        text: "",
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _return_expr(value: Expr, file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(value)
    return Expr {
        kind: ExprKind::Return,
        span: _span(file, line, col, 6),
        text: "",
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _let_expr(name: string, rhs: Expr, file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(rhs)
    return Expr {
        kind: ExprKind::Let,
        span: _span(file, line, col, 3),
        text: name,
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _block(children: [Expr], file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::Block,
        span: _span(file, line, col, 1),
        text: "",
        children: children,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _fn_item(name: string, params: [Param], ret: TypeRef, body: Expr, file: string, line: i64) -> Item {
    return Item {
        kind: ItemKind::Fn,
        name: name,
        span: _span(file, line, 1, len(name)),
        annotations: [],
        params: params,
        return_type: ret,
        body: body,
        is_pub: false
    }
}

fn _param(name: string, typ_name: string, file: string, line: i64, col: i64) -> Param {
    return Param {
        name: name,
        typ: _named_type_ref(typ_name),
        span: _span(file, line, col, len(name))
    }
}

// ── Pretty-print ─────────────────────────────────────────────

fn _sev_str(s: Severity) -> string {
    return match s {
        Severity::Error -> "error",
        Severity::Warning -> "warning",
        Severity::Note -> "note"
    }
}

fn _print_diag(idx: i64, d: Diagnostic) {
    let sp = d.span
    let loc = sp.file + ":" + to_string(sp.line) + ":" + to_string(sp.col)
    println("    [" + to_string(idx) + "] " + d.code + " (" + _sev_str(d.severity) + " " + d.stage + ") @ " + loc)
    println("          msg:     " + d.message)
}

// ── Cases ────────────────────────────────────────────────────

// (a) PASS: fn add(x:Int,y:Int)->Int { return x+y } fn main(){ add(1,2) }
fn _build_case_a() -> Module {
    let f = "case_a.hexa"

    let mut params_add = []
    params_add.push(_param("x", "Int", f, 1, 8))
    params_add.push(_param("y", "Int", f, 1, 16))
    let x_ref = _ident_expr("x", f, 1, 35)
    let y_ref = _ident_expr("y", f, 1, 39)
    let body_expr = _bin_expr("+", x_ref, y_ref, f, 1, 37)
    let ret = _return_expr(body_expr, f, 1, 28)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 26)
    let item_add = _fn_item("add", params_add, _named_type_ref("Int"), body, f, 1)

    let add_callee = _ident_expr("add", f, 2, 14)
    let lit1 = _int_expr("1", f, 2, 18)
    let lit2 = _int_expr("2", f, 2, 21)
    let mut args = []
    args.push(lit1)
    args.push(lit2)
    let call = _call_expr(add_callee, args, f, 2, 17)
    let mut main_kids = []
    main_kids.push(call)
    let main_body = _block(main_kids, f, 2, 12)
    let item_main = _fn_item("main", [], _empty_type_ref(), main_body, f, 2)

    let mut items = []
    items.push(item_add)
    items.push(item_main)
    return Module { file: f, items: items, imports: [] }
}

// (b) FAIL HX3002: add(1) — wrong arity
fn _build_case_b() -> Module {
    let f = "case_b.hexa"

    let mut params_add = []
    params_add.push(_param("x", "Int", f, 1, 8))
    params_add.push(_param("y", "Int", f, 1, 16))
    let x_ref = _ident_expr("x", f, 1, 35)
    let y_ref = _ident_expr("y", f, 1, 39)
    let body_expr = _bin_expr("+", x_ref, y_ref, f, 1, 37)
    let ret = _return_expr(body_expr, f, 1, 28)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 26)
    let item_add = _fn_item("add", params_add, _named_type_ref("Int"), body, f, 1)

    let add_callee = _ident_expr("add", f, 2, 14)
    let lit1 = _int_expr("1", f, 2, 18)
    let mut args = []
    args.push(lit1)
    let call = _call_expr(add_callee, args, f, 2, 17)
    let mut main_kids = []
    main_kids.push(call)
    let main_body = _block(main_kids, f, 2, 12)
    let item_main = _fn_item("main", [], _empty_type_ref(), main_body, f, 2)

    let mut items = []
    items.push(item_add)
    items.push(item_main)
    return Module { file: f, items: items, imports: [] }
}

// (c) FAIL HX3003: add(1, "hi") — second arg type mismatch
fn _build_case_c() -> Module {
    let f = "case_c.hexa"

    let mut params_add = []
    params_add.push(_param("x", "Int", f, 1, 8))
    params_add.push(_param("y", "Int", f, 1, 16))
    let x_ref = _ident_expr("x", f, 1, 35)
    let y_ref = _ident_expr("y", f, 1, 39)
    let body_expr = _bin_expr("+", x_ref, y_ref, f, 1, 37)
    let ret = _return_expr(body_expr, f, 1, 28)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 26)
    let item_add = _fn_item("add", params_add, _named_type_ref("Int"), body, f, 1)

    let add_callee = _ident_expr("add", f, 2, 14)
    let lit1 = _int_expr("1", f, 2, 18)
    let lit_str = _string_expr("hi", f, 2, 21)
    let mut args = []
    args.push(lit1)
    args.push(lit_str)
    let call = _call_expr(add_callee, args, f, 2, 17)
    let mut main_kids = []
    main_kids.push(call)
    let main_body = _block(main_kids, f, 2, 12)
    let item_main = _fn_item("main", [], _empty_type_ref(), main_body, f, 2)

    let mut items = []
    items.push(item_add)
    items.push(item_main)
    return Module { file: f, items: items, imports: [] }
}

// (d) FAIL HX3001: 1 + true — binop operand mismatch
fn _build_case_d() -> Module {
    let f = "case_d.hexa"

    let lit1 = _int_expr("1", f, 1, 14)
    let lit_t = _bool_expr("true", f, 1, 18)
    let bin = _bin_expr("+", lit1, lit_t, f, 1, 16)
    let let_e = _let_expr("z", bin, f, 1, 5)
    let mut block_kids = []
    block_kids.push(let_e)
    let main_body = _block(block_kids, f, 1, 12)
    let item_main = _fn_item("main", [], _empty_type_ref(), main_body, f, 1)

    let mut items = []
    items.push(item_main)
    return Module { file: f, items: items, imports: [] }
}

// (e) FAIL HX3004: fn pick() -> Int { return "no" }
fn _build_case_e() -> Module {
    let f = "case_e.hexa"

    let lit_str = _string_expr("no", f, 1, 27)
    let ret = _return_expr(lit_str, f, 1, 20)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 18)
    let item_pick = _fn_item("pick", [], _named_type_ref("Int"), body, f, 1)

    let mut items = []
    items.push(item_pick)
    return Module { file: f, items: items, imports: [] }
}

// ── Driver ───────────────────────────────────────────────────

fn _run_case(label: string, m: Module) -> array {
    println("")
    println("── " + label + " ──")
    println("  module: " + m.file + " (items=" + to_string(len(m.items)) + ")")
    let diags = type_check(m)
    println("  diagnostics: " + to_string(len(diags)))
    let mut i = 0
    while i < len(diags) {
        _print_diag(i, diags[i])
        i = i + 1
    }
    return diags
}

fn _has_code(diags: array, code: string) -> bool {
    let mut i = 0
    while i < len(diags) {
        let d = diags[i]
        if d.code == code { return true }
        i = i + 1
    }
    return false
}

fn _count_code(diags: array, code: string) -> i64 {
    let mut i = 0
    let mut n = 0
    while i < len(diags) {
        let d = diags[i]
        if d.code == code { n = n + 1 }
        i = i + 1
    }
    return n
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  HEXA Compiler — Type/Domain Smoke Test (B3/S3+S4)")
    println("══════════════════════════════════════════════")

    let mut ok = true

    // (a) PASS
    let diags_a = _run_case("(a) PASS — add(1,2) signature matches", _build_case_a())
    if len(diags_a) != 0 {
        println("  FAIL: case (a) expected 0 diagnostics, got " + to_string(len(diags_a)))
        ok = false
    } else {
        println("  ok: 0 diagnostics")
    }

    // (b) HX3002
    let diags_b = _run_case("(b) FAIL HX3002 — add(1) wrong arity", _build_case_b())
    let nb = _count_code(diags_b, "HX3002")
    if nb != 1 {
        println("  FAIL: case (b) expected 1 HX3002, got " + to_string(nb) + " (total=" + to_string(len(diags_b)) + ")")
        ok = false
    } else {
        println("  ok: 1 HX3002 emitted")
    }

    // (c) HX3003
    let diags_c = _run_case("(c) FAIL HX3003 — add(1,\"hi\") arg type", _build_case_c())
    let nc = _count_code(diags_c, "HX3003")
    if nc != 1 {
        println("  FAIL: case (c) expected 1 HX3003, got " + to_string(nc) + " (total=" + to_string(len(diags_c)) + ")")
        ok = false
    } else {
        println("  ok: 1 HX3003 emitted")
    }

    // (d) HX3001
    let diags_d = _run_case("(d) FAIL HX3001 — 1 + true binop mismatch", _build_case_d())
    if !_has_code(diags_d, "HX3001") {
        println("  FAIL: case (d) expected at least one HX3001, got total=" + to_string(len(diags_d)))
        ok = false
    } else {
        println("  ok: HX3001 emitted")
    }

    // (e) HX3004
    let diags_e = _run_case("(e) FAIL HX3004 — fn pick()->Int returns string", _build_case_e())
    if !_has_code(diags_e, "HX3004") {
        println("  FAIL: case (e) expected at least one HX3004, got total=" + to_string(len(diags_e)))
        ok = false
    } else {
        println("  ok: HX3004 emitted")
    }

    println("")
    println("══════════════════════════════════════════════")
    if ok {
        println("PASS: all type-check cases match contract.")
    } else {
        println("FAIL: type-check contract not satisfied.")
    }
    println("══════════════════════════════════════════════")
    if !ok { exit(1) }
}
