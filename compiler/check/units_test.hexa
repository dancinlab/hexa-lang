// HEXA Native Compiler — Phase B3+ / S5: units smoke test
//
// @version 0.1.0
// @capabilities [pure]
//
// Hand-builds four small Modules exercising the units pass:
//
//   (a) PASS — @units("kg","m/s","J") fn energy(m,c) { return m*c*c }
//       with v=m/s squared = m²/s²; energy = kg·m²/s² = J. expect 0 diagnostics.
//
//   (b) FAIL HX5001 — let f = m + a where m: kg, a: m/s²
//       expect 1 HX5001 (unit mismatch in `+`)
//
//   (c) FAIL HX5002 — fn declared @units("J") but body returns m * v
//       (m: kg, v: m/s → product is kg·m/s which is not J).
//       expect 1 HX5002 (return unit mismatch)
//
//   (d) PASS — chain with no annotations → 0 diagnostics
//       (lenient v1 — untyped fns produce no S5 diagnostics).
//
// Run:
//   hexa run compiler/check/units_test.hexa

import "../parse/ast.hexa"
import "../diag/catalog.hexa"
import "../lex/tokens.hexa"
import "../ir/hir.hexa"
import "./units.hexa"

// ── AST construction helpers ─────────────────────────────────

fn _span(file: string, line: i64, col: i64, length: i64) -> Span {
    return Span { file: file, line: line, col: col, len: length }
}

fn _empty_span() -> Span {
    return _span("", 0, 0, 0)
}

fn _empty_atlas_ref() -> AtlasRef {
    return AtlasRef { kind: "", id: "", span: _empty_span() }
}

fn _empty_type_ref() -> TypeRef {
    return TypeRef { kind: "", name: "", args: [], span: _empty_span() }
}

fn _named_type_ref(name: string) -> TypeRef {
    return TypeRef { kind: "named", name: name, args: [], span: _empty_span() }
}

fn _ident_expr(name: string, file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::Ident,
        span: _span(file, line, col, len(name)),
        text: name,
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
}

fn _string_expr(text: string, file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::LiteralString,
        span: _span(file, line, col, len(text)),
        text: text,
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
}

fn _bin_expr(op: string, lhs: Expr, rhs: Expr, file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(lhs)
    kids.push(rhs)
    return Expr {
        kind: ExprKind::BinOp,
        span: _span(file, line, col, len(op)),
        text: op,
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _return_expr(value: Expr, file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(value)
    return Expr {
        kind: ExprKind::Return,
        span: _span(file, line, col, 6),
        text: "",
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _let_expr(name: string, rhs: Expr, file: string, line: i64, col: i64) -> Expr {
    let mut kids = []
    kids.push(rhs)
    return Expr {
        kind: ExprKind::Let,
        span: _span(file, line, col, 3),
        text: name,
        children: kids,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _block(children: [Expr], file: string, line: i64, col: i64) -> Expr {
    return Expr {
        kind: ExprKind::Block,
        span: _span(file, line, col, 1),
        text: "",
        children: children,
        atlas_ref: _empty_atlas_ref()
    }
}

fn _param(name: string, typ_name: string, file: string, line: i64, col: i64) -> Param {
    return Param {
        name: name,
        typ: _named_type_ref(typ_name),
        span: _span(file, line, col, len(name))
    }
}

fn _units_annotation(units: [string], file: string, line: i64) -> Annotation {
    let mut args: [Expr] = []
    let mut i = 0
    while i < len(units) {
        args.push(_string_expr(units[i], file, line, 1))
        i = i + 1
    }
    return Annotation { name: "units", args: args, span: _span(file, line, 1, 6) }
}

fn _fn_item_ann(name: string, anns: [Annotation], params: [Param], ret: TypeRef, body: Expr, file: string, line: i64) -> Item {
    return Item {
        kind: ItemKind::Fn,
        name: name,
        span: _span(file, line, 1, len(name)),
        annotations: anns,
        params: params,
        return_type: ret,
        body: body,
        is_pub: false
    }
}

// ── Pretty-print ─────────────────────────────────────────────

fn _sev_str(s: Severity) -> string {
    return match s {
        Severity::Error -> "error",
        Severity::Warning -> "warning",
        Severity::Note -> "note"
    }
}

fn _print_diag(idx: i64, d: Diagnostic) {
    let sp = d.span
    let loc = sp.file + ":" + to_string(sp.line) + ":" + to_string(sp.col)
    println("    [" + to_string(idx) + "] " + d.code + " (" + _sev_str(d.severity) + " " + d.stage + ") @ " + loc)
    println("          msg:     " + d.message)
}

// ── parse_unit smoke ─────────────────────────────────────────

fn _check_parse_unit(spec: string, expected: string) -> bool {
    let u = parse_unit(spec)
    let got = unit_to_string(u)
    let ok = got == expected
    let mark = if ok { "ok" } else { "FAIL" }
    println("  " + mark + " parse_unit(" + spec + ") = " + got + " (expected " + expected + ")")
    return ok
}

// ── Cases ────────────────────────────────────────────────────

// (a) PASS:
//   @units("kg", "m/s", "J")
//   fn energy(m: f64, c: f64) -> f64 { return m * c * c }
//
// units of body:
//   m * c     → kg * (m/s) = kg.m/s
//   m * c * c → kg.m/s * (m/s) = kg.m.m / (s.s) = kg.m^2/s^2  ≡ J
fn _build_case_a() -> Module {
    let f = "case_a.hexa"

    let m_ref = _ident_expr("m", f, 1, 30)
    let c_ref1 = _ident_expr("c", f, 1, 34)
    let c_ref2 = _ident_expr("c", f, 1, 38)
    let mc = _bin_expr("*", m_ref, c_ref1, f, 1, 32)
    let mcc = _bin_expr("*", mc, c_ref2, f, 1, 36)
    let ret = _return_expr(mcc, f, 1, 24)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 22)

    let mut params = []
    params.push(_param("m", "f64", f, 1, 11))
    params.push(_param("c", "f64", f, 1, 18))

    let mut units = []
    units.push("kg")
    units.push("m/s")
    units.push("J")
    let mut anns = []
    anns.push(_units_annotation(units, f, 1))

    let energy = _fn_item_ann("energy", anns, params, _named_type_ref("f64"), body, f, 1)
    let mut items = []
    items.push(energy)
    return Module { file: f, items: items, imports: [] }
}

// (b) FAIL HX5001:
//   @units("kg", "m/s^2", "kg")
//   fn add_force(m: f64, a: f64) -> f64 { return m + a }
//
// `m + a` has lhs unit kg, rhs unit m/s^2 → HX5001.
// (We pick a return unit of "kg" so the result of `m+a` itself doesn't
// trigger HX5002 too — but addition still emits exactly one HX5001.)
fn _build_case_b() -> Module {
    let f = "case_b.hexa"

    let m_ref = _ident_expr("m", f, 1, 30)
    let a_ref = _ident_expr("a", f, 1, 34)
    let sum = _bin_expr("+", m_ref, a_ref, f, 1, 32)
    let ret = _return_expr(sum, f, 1, 24)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 22)

    let mut params = []
    params.push(_param("m", "f64", f, 1, 11))
    params.push(_param("a", "f64", f, 1, 18))

    let mut units = []
    units.push("kg")
    units.push("m/s^2")
    units.push("kg")
    let mut anns = []
    anns.push(_units_annotation(units, f, 1))

    let it = _fn_item_ann("add_force", anns, params, _named_type_ref("f64"), body, f, 1)
    let mut items = []
    items.push(it)
    return Module { file: f, items: items, imports: [] }
}

// (c) FAIL HX5002:
//   @units("kg", "m/s", "J")
//   fn bad(m: f64, v: f64) -> f64 { return m * v }
//
// body produces kg * m/s = kg.m/s; declared J = kg.m^2/s^2 → HX5002.
// Note: `m * v` itself is dimensionally fine (no HX5001), so only the
// return mismatch fires.
fn _build_case_c() -> Module {
    let f = "case_c.hexa"

    let m_ref = _ident_expr("m", f, 1, 30)
    let v_ref = _ident_expr("v", f, 1, 34)
    let prod = _bin_expr("*", m_ref, v_ref, f, 1, 32)
    let ret = _return_expr(prod, f, 1, 24)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 22)

    let mut params = []
    params.push(_param("m", "f64", f, 1, 11))
    params.push(_param("v", "f64", f, 1, 18))

    let mut units = []
    units.push("kg")
    units.push("m/s")
    units.push("J")
    let mut anns = []
    anns.push(_units_annotation(units, f, 1))

    let it = _fn_item_ann("bad", anns, params, _named_type_ref("f64"), body, f, 1)
    let mut items = []
    items.push(it)
    return Module { file: f, items: items, imports: [] }
}

// (d) PASS — fn add(x,y) { let z = x + y; return z } with no annotations.
// Lenient v1: no @units → 0 diagnostics from S5.
fn _build_case_d() -> Module {
    let f = "case_d.hexa"

    let x_ref = _ident_expr("x", f, 1, 30)
    let y_ref = _ident_expr("y", f, 1, 34)
    let sum = _bin_expr("+", x_ref, y_ref, f, 1, 32)
    let let_e = _let_expr("z", sum, f, 1, 26)
    let z_ref = _ident_expr("z", f, 1, 50)
    let ret = _return_expr(z_ref, f, 1, 44)
    let mut block_kids = []
    block_kids.push(let_e)
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 22)

    let mut params = []
    params.push(_param("x", "f64", f, 1, 11))
    params.push(_param("y", "f64", f, 1, 18))

    let it = _fn_item_ann("add", [], params, _named_type_ref("f64"), body, f, 1)
    let mut items = []
    items.push(it)
    return Module { file: f, items: items, imports: [] }
}

// ── Driver ───────────────────────────────────────────────────

fn _run_case(label: string, m: Module) -> array {
    println("")
    println("── " + label + " ──")
    println("  module: " + m.file + " (items=" + to_string(len(m.items)) + ")")
    let diags = unit_check(m)
    println("  diagnostics: " + to_string(len(diags)))
    let mut i = 0
    while i < len(diags) {
        _print_diag(i, diags[i])
        i = i + 1
    }
    return diags
}

fn _count_code(diags: array, code: string) -> i64 {
    let mut i = 0
    let mut n = 0
    while i < len(diags) {
        let d = diags[i]
        if d.code == code { n = n + 1 }
        i = i + 1
    }
    return n
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  HEXA Compiler — Units Smoke Test (B3+/S5)")
    println("══════════════════════════════════════════════")

    let mut ok = true

    // ── parse_unit / unit_to_string round trips ──
    println("")
    println("── parse_unit / unit_to_string ──")
    if !_check_parse_unit("",         "1")         { ok = false }
    if !_check_parse_unit("kg",       "kg")        { ok = false }
    if !_check_parse_unit("m/s",      "m/s")       { ok = false }
    if !_check_parse_unit("kg.m/s^2", "kg.m/s.s")  { ok = false }
    if !_check_parse_unit("s^-2",     "1/s.s")     { ok = false }
    if !_check_parse_unit("m^2/s",    "m.m/s")     { ok = false }

    // ── unit_eq sanity (J vs kg.m^2/s^2 are not user-equal — they're
    // separate symbols in the lenient v1; equality is by canonical form) ──
    let j  = parse_unit("J")
    let nm = parse_unit("kg.m.m/s.s")
    if unit_eq(j, nm) {
        println("  FAIL: J should not canonical-equal kg.m.m/s.s in v1 (no SI table)")
        ok = false
    } else {
        println("  ok: J and kg.m.m/s.s are distinct under v1 canonicalisation")
    }

    // (a) PASS — energy()
    // Note: under v1 canonicalisation, declared `J` and computed `kg.m.m/s.s`
    // are different symbol bags, so we expect HX5002 here. To make this case
    // a clean PASS we declare the return unit as the canonical product
    // `kg.m^2/s^2` instead of the J alias. We rebuild the case body so the
    // computed and declared units canonicalise identically.
    let diags_a = _run_case("(a) PASS — energy = m*c*c with kg, m/s, kg.m^2/s^2",
                            _build_case_a_canonical())
    if len(diags_a) != 0 {
        println("  FAIL: case (a) expected 0 diagnostics, got " + to_string(len(diags_a)))
        ok = false
    } else {
        println("  ok: 0 diagnostics")
    }

    // (b) HX5001
    let diags_b = _run_case("(b) FAIL HX5001 — m + a with kg, m/s^2",
                            _build_case_b())
    let nb = _count_code(diags_b, "HX5001")
    if nb != 1 {
        println("  FAIL: case (b) expected 1 HX5001, got " + to_string(nb) + " (total=" + to_string(len(diags_b)) + ")")
        ok = false
    } else {
        println("  ok: 1 HX5001 emitted")
    }

    // (c) HX5002
    let diags_c = _run_case("(c) FAIL HX5002 — fn @units(\"J\") body returns kg.m/s",
                            _build_case_c())
    let nc = _count_code(diags_c, "HX5002")
    if nc < 1 {
        println("  FAIL: case (c) expected ≥1 HX5002, got " + to_string(nc) + " (total=" + to_string(len(diags_c)) + ")")
        ok = false
    } else {
        println("  ok: " + to_string(nc) + " HX5002 emitted")
    }

    // (d) PASS — no annotations
    let diags_d = _run_case("(d) PASS — chain with no @units (lenient v1)",
                            _build_case_d())
    if len(diags_d) != 0 {
        println("  FAIL: case (d) expected 0 diagnostics, got " + to_string(len(diags_d)))
        ok = false
    } else {
        println("  ok: 0 diagnostics")
    }

    println("")
    println("══════════════════════════════════════════════")
    if ok {
        println("PASS: all units cases match contract.")
    } else {
        println("FAIL: units contract not satisfied.")
    }
    println("══════════════════════════════════════════════")
    if !ok { exit(1) }
}

// (a) PASS — canonical unit form of return slot:
//   declared kg.m^2/s^2  ⇔ computed kg.m.m/s.s — identical canonical bag.
fn _build_case_a_canonical() -> Module {
    let f = "case_a.hexa"

    let m_ref = _ident_expr("m", f, 1, 30)
    let c_ref1 = _ident_expr("c", f, 1, 34)
    let c_ref2 = _ident_expr("c", f, 1, 38)
    let mc = _bin_expr("*", m_ref, c_ref1, f, 1, 32)
    let mcc = _bin_expr("*", mc, c_ref2, f, 1, 36)
    let ret = _return_expr(mcc, f, 1, 24)
    let mut block_kids = []
    block_kids.push(ret)
    let body = _block(block_kids, f, 1, 22)

    let mut params = []
    params.push(_param("m", "f64", f, 1, 11))
    params.push(_param("c", "f64", f, 1, 18))

    let mut units = []
    units.push("kg")
    units.push("m/s")
    units.push("kg.m^2/s^2")
    let mut anns = []
    anns.push(_units_annotation(units, f, 1))

    let energy = _fn_item_ann("energy", anns, params, _named_type_ref("f64"), body, f, 1)
    let mut items = []
    items.push(energy)
    return Module { file: f, items: items, imports: [] }
}
