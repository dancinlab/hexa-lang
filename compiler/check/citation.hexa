// HEXA Native Compiler — Phase B4 / S8: citation pass
//
// @version 0.1.0
// @capabilities [pure]
//
// Walks a parsed Module and validates every `@implements(L[*])` annotation
// against an in-memory AtlasIndex (Phase A2 — compiler/atlas/merger.hexa).
// Per RFC-017 §3.1 (S8) citation is fatal: missing or wrong-kind citations
// abort compilation. Per RFC-019 §6 multi-error policy: we collect every
// miss and return all diagnostics (no early-stop).
//
// Diagnostic codes (catalog: compiler/diag/catalog.hexa):
//   HX8001  @implements(L[id]) — atlas has no such L node
//   HX8002  @implements(K[id]) where K != L — wrong-kind citation
//   HX8003  fn body uses atlas L refs but no @implements citation (Warn)
//           DEPRECATED — superseded by HX8004 per SPEC.yaml
//           atlas_citation_strict (Decision 2026-05-09). Kept transitionally
//           so downstream tooling can migrate; will be retired in the next
//           citation pass refresh.
//   HX8004  formula-bearing item (carries @verify/@law, OR body references
//           L[*]) has no atlas binding — neither @implements(L[*]) nor
//           @discover(kind="L"). Error severity, fatal at S8 (SPEC.yaml
//           atlas_citation_strict.on_missing_binding).
//   HX1099  @implements(L[id]) where the id is tombstoned (Decision 5e).
//           Two detection paths: (1) the legacy `[TOMBSTONED]` raw-marker
//           on an existing AtlasNode, (2) a record in atlas.tombstones.n6
//           consulted via citation_check_with_root(.., atlas_root). The
//           tombstones-file path WINS over HX8001 — a tombstoned id is
//           fatal even if the L body has been physically removed.
//
// `@law(...)` annotations carry only string literals (formula + units) and
// require no atlas binding here — deeper verification is RFC-017 S6/S7
// prover territory. However the PRESENCE of `@law` (or `@verify`) on an
// item triggers the HX8004 atlas-binding check below.
//
// pub fn citation_check(module: Module, atlas: AtlasIndex) -> [Diagnostic]
// pub fn citation_check_with_root(module, atlas, atlas_root) -> [Diagnostic]
//
// 100% enum match on ItemKind / ExprKind (no string compares against tags).

import "../parse/ast.hexa"
import "../diag/catalog.hexa"
import "../diag/builder.hexa"
import "../atlas/merger.hexa"
import "../atlas/parser.hexa"
import "../lex/tokens.hexa"
import "../discover/tombstone.hexa"

// ── Helpers ──────────────────────────────────────────────────

fn _citation_empty_fixit() -> FixIt {
    return FixIt {
        kind: FixItKind::None,
        span: Span { file: "", line: 0, col: 0, len: 0 },
        new_text: ""
    }
}

// Render the HX8001 message inline (template lives in catalog as
// "atlas {atlas_hash} has no L node `{node_id}` cited by @implements").
fn _render_hx8001(atlas_hash: string, node_id: string) -> string {
    return "atlas " + atlas_hash + " has no L node `" + node_id + "` cited by @implements"
}

// Render HX8002 — wrong-kind target ("@implements points at a {K} node;
// only L nodes may be implemented").
fn _render_hx8002(node_kind: string, node_id: string) -> string {
    return "@implements(" + node_kind + "[" + node_id + "]) points at a " + node_kind + " node; only L nodes may be implemented"
}

// Render HX8003 — fn uses L refs but no @implements citation.
fn _render_hx8003(fn_name: string, node_id: string) -> string {
    return "function `" + fn_name + "` references atlas L node `" + node_id + "` in its body but has no @implements citation"
}

// Render HX1099 — citing a tombstoned L node (RFC-017 §5e, SPEC.md §6.5).
// Reason text comes from atlas.tombstones.n6 when available; falls back to a
// generic message when the legacy [TOMBSTONED] raw-marker triggered the
// detection (no separate reason recorded).
fn _render_hx1099(node_id: string, reason: string) -> string {
    if len(reason) > 0 {
        return "atlas L node `" + node_id + "` is tombstoned: " + reason
    }
    return "atlas L node `" + node_id + "` is tombstoned; @implements citation rejected"
}

// Look up a tombstone reason for `node_id` in the supplied tombstone list
// (parsed from atlas.tombstones.n6 by the caller). Returns "" when no record
// matches — caller falls back to the legacy generic message.
fn _tombstone_reason(tombstones: array, node_id: string) -> string {
    let mut i = 0
    while i < len(tombstones) {
        let t = tombstones[i]
        if t.node_id == node_id { return t.reason }
        i = i + 1
    }
    return ""
}

// True iff `tombstones` contains a record for `node_id`.
fn _id_in_tombstones(tombstones: array, node_id: string) -> bool {
    let mut i = 0
    while i < len(tombstones) {
        let t = tombstones[i]
        if t.node_id == node_id { return true }
        i = i + 1
    }
    return false
}

// Tombstone detection — Decision 5e tombstones are recorded in
// atlas.tombstones.n6 and surface in AtlasNode.raw via a literal
// "[TOMBSTONED]" marker (mirrors the gate convention). Atlas merger
// keeps the node but flags raw — citation pass refuses to bind to it.
fn _is_tombstoned(node: AtlasNode) -> bool {
    let raw = node.raw
    let n = len(raw)
    if n < 12 { return false }
    let mut i = 0
    while i + 12 <= n {
        if raw.substring(i, i + 12) == "[TOMBSTONED]" { return true }
        i = i + 1
    }
    return false
}

// ── ExprKind / ItemKind probes ────────────────────────────────
// Stage0 cannot derive Eq for enums; mirror parser.hexa tag_of pattern.

fn _citation_is_atlas_ref_kind(k: ExprKind) -> bool {
    return match k {
        ExprKind::AtlasRef -> true,
        ExprKind::LiteralInt -> false,
        ExprKind::LiteralFloat -> false,
        ExprKind::LiteralString -> false,
        ExprKind::LiteralBool -> false,
        ExprKind::LiteralChar -> false,
        ExprKind::Ident -> false,
        ExprKind::Call -> false,
        ExprKind::BinOp -> false,
        ExprKind::UnOp -> false,
        ExprKind::Block -> false,
        ExprKind::If -> false,
        ExprKind::While -> false,
        ExprKind::For -> false,
        ExprKind::Match -> false,
        ExprKind::Return -> false,
        ExprKind::Let -> false,
        ExprKind::Assign -> false,
        ExprKind::Field -> false,
        ExprKind::Index -> false,
        ExprKind::ArrayLit -> false,
        ExprKind::StructLit -> false,
        ExprKind::EnumPath -> false,
        ExprKind::Wildcard -> false
    }
}

fn _citation_is_fn_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Fn -> true,
        ItemKind::Let -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false,
        ItemKind::Import -> false
    }
}

// ── L-ref collection over an Expr tree ───────────────────────
// Emits an array of AtlasRef payloads (kind="L") from the body so the
// citation hint pass (HX8003) can compare against @implements targets.

fn _collect_l_refs(e: Expr, out: array) {
    if _citation_is_atlas_ref_kind(e.kind) {
        let aref = e.atlas_ref
        if aref.kind == "L" { out.push(aref) }
    } else {
        // Defensive: Some Exprs may carry a populated atlas_ref even when
        // their kind isn't AtlasRef (matches resolve.hexa behaviour).
        let aref = e.atlas_ref
        if aref.kind == "L" { out.push(aref) }
    }
    let mut i = 0
    while i < len(e.children) {
        _collect_l_refs(e.children[i], out)
        i = i + 1
    }
}

// ── Annotation classification ────────────────────────────────
// `@implements` should hold exactly one AtlasRef arg. We check each arg
// independently (so multi-arg impls are validated arm-by-arm) and emit
// per-arg diagnostics.

fn _is_implements_ann(name: string) -> bool {
    return name == "implements"
}

fn _is_law_ann(name: string) -> bool {
    return name == "law"
}

fn _is_verify_ann(name: string) -> bool {
    return name == "verify"
}

fn _is_discover_ann(name: string) -> bool {
    return name == "discover"
}

fn _is_assign_kind(k: ExprKind) -> bool {
    return match k {
        ExprKind::Assign -> true,
        ExprKind::LiteralInt -> false,
        ExprKind::LiteralFloat -> false,
        ExprKind::LiteralString -> false,
        ExprKind::LiteralBool -> false,
        ExprKind::LiteralChar -> false,
        ExprKind::Ident -> false,
        ExprKind::AtlasRef -> false,
        ExprKind::Call -> false,
        ExprKind::BinOp -> false,
        ExprKind::UnOp -> false,
        ExprKind::Block -> false,
        ExprKind::If -> false,
        ExprKind::While -> false,
        ExprKind::For -> false,
        ExprKind::Match -> false,
        ExprKind::Return -> false,
        ExprKind::Let -> false,
        ExprKind::Field -> false,
        ExprKind::Index -> false,
        ExprKind::ArrayLit -> false,
        ExprKind::StructLit -> false,
        ExprKind::EnumPath -> false,
        ExprKind::Wildcard -> false
    }
}

fn _citation_is_ident_kind(k: ExprKind) -> bool {
    return match k {
        ExprKind::Ident -> true,
        ExprKind::LiteralInt -> false,
        ExprKind::LiteralFloat -> false,
        ExprKind::LiteralString -> false,
        ExprKind::LiteralBool -> false,
        ExprKind::LiteralChar -> false,
        ExprKind::AtlasRef -> false,
        ExprKind::Call -> false,
        ExprKind::BinOp -> false,
        ExprKind::UnOp -> false,
        ExprKind::Block -> false,
        ExprKind::If -> false,
        ExprKind::While -> false,
        ExprKind::For -> false,
        ExprKind::Match -> false,
        ExprKind::Return -> false,
        ExprKind::Let -> false,
        ExprKind::Assign -> false,
        ExprKind::Field -> false,
        ExprKind::Index -> false,
        ExprKind::ArrayLit -> false,
        ExprKind::StructLit -> false,
        ExprKind::EnumPath -> false,
        ExprKind::Wildcard -> false
    }
}

fn _is_string_lit_kind(k: ExprKind) -> bool {
    return match k {
        ExprKind::LiteralString -> true,
        ExprKind::LiteralInt -> false,
        ExprKind::LiteralFloat -> false,
        ExprKind::LiteralBool -> false,
        ExprKind::LiteralChar -> false,
        ExprKind::Ident -> false,
        ExprKind::AtlasRef -> false,
        ExprKind::Call -> false,
        ExprKind::BinOp -> false,
        ExprKind::UnOp -> false,
        ExprKind::Block -> false,
        ExprKind::If -> false,
        ExprKind::While -> false,
        ExprKind::For -> false,
        ExprKind::Match -> false,
        ExprKind::Return -> false,
        ExprKind::Let -> false,
        ExprKind::Assign -> false,
        ExprKind::Field -> false,
        ExprKind::Index -> false,
        ExprKind::ArrayLit -> false,
        ExprKind::StructLit -> false,
        ExprKind::EnumPath -> false,
        ExprKind::Wildcard -> false
    }
}

fn _check_one_discover_arg(arg: Expr) -> bool {
    if !_is_assign_kind(arg.kind) { return false }
    if len(arg.children) < 2 { return false }
    let lhs = arg.children[0]
    let rhs = arg.children[1]
    if !_citation_is_ident_kind(lhs.kind) { return false }
    if lhs.text != "kind" { return false }
    if !_is_string_lit_kind(rhs.kind) { return false }
    return rhs.text == "L"
}

fn _discover_kind_is_law(a: Annotation) -> bool {
    let mut i = 0
    while i < len(a.args) {
        if _check_one_discover_arg(a.args[i]) { return true }
        i = i + 1
    }
    return false
}

// Validate one @implements arg expression. Returns the cited L id when
// the arg is a well-formed L[*] (so the caller can record it for the
// HX8003 gap check); returns "" otherwise.
//
// `tombstones` is the parsed atlas.tombstones.n6 list (may be empty). When
// non-empty, an `@implements(L[id])` whose id is tombstoned emits HX1099
// EVEN IF the L node has been physically removed from atlas.n6 — the
// retroactive-sweep contract (RFC-017 §5e) requires the tombstone signal
// to win over the generic HX8001 "missing" path so authors get a precise
// "this was retired, see atlas.tombstones.n6" message.
fn _check_implements_arg(arg: Expr, atlas: AtlasIndex,
                         tombstones: array, out: array) -> string {
    // Only AtlasRef-shaped args matter — anything else (string lit, ident,
    // etc.) is silently ignored at S8 (S0/S2 already covers shape errors).
    let aref = arg.atlas_ref
    if len(aref.kind) == 0 { return "" }

    if aref.kind != "L" {
        // Wrong kind — HX8002.
        let mut b = diag_new("HX8002")
        b = diag_span(b, aref.span)
        b = diag_arg(b, "kind", aref.kind)
        b = diag_arg(b, "node_id", aref.id)
        out.push(diag_emit(b))
        return ""
    }

    // ── HX1099 — atlas.tombstones.n6 wins over HX8001 ────────────
    // Decision 5e: a tombstoned id is fatal regardless of whether the L
    // body still lives in atlas.n6 (manual tombstone leaves the body
    // intact; sweep-driven tombstones likewise — the body is preserved
    // for provenance, the tombstones file is the single source of truth).
    if _id_in_tombstones(tombstones, aref.id) {
        let reason = _tombstone_reason(tombstones, aref.id)
        let mut b = diag_new("HX1099")
        b = diag_span(b, aref.span)
        b = diag_arg(b, "node_id", aref.id)
        b = diag_arg(b, "reason", reason)
        out.push(diag_emit(b))
        return ""
    }

    let hit = lookup(atlas, "L", aref.id)
    if len(hit.kind) == 0 {
        // Missing — HX8001. Note: S1 (resolve) already emits HX1042 for
        // the same span, but S8 is its own pass and emits the citation-
        // specific code so downstream tooling (LSP, gate) can route.
        let mut b = diag_new("HX8001")
        b = diag_span(b, aref.span)
        b = diag_arg(b, "atlas_hash", atlas.hash)
        b = diag_arg(b, "node_id", aref.id)
        out.push(diag_emit(b))
        return ""
    }

    if _is_tombstoned(hit) {
        // Legacy [TOMBSTONED] raw-marker path — preserved so existing
        // fixtures using the marker continue to fail closed.
        let msg = _render_hx1099(aref.id, "")
        let d = Diagnostic {
            code: "HX1099",
            severity: Severity::Error,
            stage: "S8",
            span: aref.span,
            message: msg,
            note: "",
            suggest: "",
            fixit: _citation_empty_fixit(),
            related: []
        }
        out.push(d)
        return ""
    }

    // Valid citation — record the id for the HX8003 gap check.
    return aref.id
}

// ── Per-item walk ────────────────────────────────────────────

fn _citation_walk_item(it: Item, atlas: AtlasIndex, tombstones: array, out: array) {
    // Collect every @implements target id into `cited` so we can compare
    // against the body's L-refs after annotation validation. Also track
    // formula-bearing markers (@verify, @law) and @discover(kind="L")
    // for the HX8004 atlas-binding check (SPEC.yaml atlas_citation_strict).
    let mut cited = []
    let mut has_verify = false
    let mut has_law = false
    let mut has_implements_l = false
    let mut has_discover_l = false
    let mut i = 0
    while i < len(it.annotations) {
        let a = it.annotations[i]
        if _is_implements_ann(a.name) {
            let mut j = 0
            while j < len(a.args) {
                let id = _check_implements_arg(a.args[j], atlas, tombstones, out)
                if len(id) > 0 {
                    cited.push(id)
                    has_implements_l = true
                }
                j = j + 1
            }
        } else if _is_verify_ann(a.name) {
            has_verify = true
        } else if _is_law_ann(a.name) {
            has_law = true
        } else if _is_discover_ann(a.name) {
            if _discover_kind_is_law(a) { has_discover_l = true }
        }
        // @law args are documentation strings — no atlas binding here.
        i = i + 1
    }

    // HX8003 hint: fn bodies that USE L[*] refs but cite none are flagged.
    // Only fn items have meaningful bodies — let/struct/enum/import bodies
    // are the empty placeholder (kind=Ident, no atlas refs).
    if !_citation_is_fn_item(it.kind) { return }

    let mut body_refs = []
    _collect_l_refs(it.body, body_refs)
    let body_uses_l = len(body_refs) > 0

    // ── HX8004: atlas-binding required for formula-bearing items ─────
    // SPEC.yaml atlas_citation_strict.required_when:
    //   (a) @verify present, OR (b) @law present, OR (c) body L[*] refs.
    // Legal bindings: @implements(L[*]) OR @discover(kind="L").
    // Severity: Error. Multi-error collection — one HX8004 per item.
    let formula_bearing = has_verify || has_law || body_uses_l
    let has_binding = has_implements_l || has_discover_l
    if formula_bearing {
        if !has_binding {
            let mut b = diag_new("HX8004")
            b = diag_span(b, it.span)
            b = diag_arg(b, "name", it.name)
            out.push(diag_emit(b))
        }
    }

    // ── HX8003 (DEPRECATED, transitional) ─────────────────────────────
    // Superseded by HX8004 above per SPEC.yaml atlas_citation_strict.
    // Kept emitting so downstream tooling (LSP, gate) can migrate; will
    // be retired in the next citation pass refresh. Only fires when the
    // body uses L[*] refs at all (the original HX8003 trigger).
    //
    // For each L-ref in the body, check whether some @implements cites
    // it. We emit at most one HX8003 per item (covers the first uncited
    // ref) — multi-error collection across items is preserved.
    if !body_uses_l { return }
    let mut k = 0
    while k < len(body_refs) {
        let r = body_refs[k]
        let mut covered = false
        let mut c = 0
        while c < len(cited) {
            if cited[c] == r.id { covered = true; break }
            c = c + 1
        }
        if !covered {
            let mut b = diag_new("HX8003")
            b = diag_span(b, r.span)
            b = diag_arg(b, "name", it.name)
            b = diag_arg(b, "node_id", r.id)
            out.push(diag_emit(b))
            return
        }
        k = k + 1
    }
}

// ── Public entry ─────────────────────────────────────────────

pub fn citation_check(module: Module, atlas: AtlasIndex) -> array {
    // Backward-compatible entrypoint — no tombstone file consulted.
    let empty_tombs = []
    return _citation_check_inner(module, atlas, empty_tombs)
}

// citation_check_with_root — Decision 5e entrypoint. Loads the tombstone
// list from `atlas_root + "/atlas.tombstones.n6"` (via list_tombstones) and
// emits HX1099 for any @implements(L[id]) whose id is tombstoned. Falls
// back to plain `citation_check` semantics when atlas_root is empty.
pub fn citation_check_with_root(module: Module, atlas: AtlasIndex,
                                atlas_root: string) -> array {
    let mut tombstones = []
    if len(atlas_root) > 0 {
        tombstones = list_tombstones(atlas_root)
    }
    return _citation_check_inner(module, atlas, tombstones)
}

fn _citation_check_inner(module: Module, atlas: AtlasIndex,
                         tombstones: array) -> array {
    let mut out = []
    let mut i = 0
    while i < len(module.items) {
        _citation_walk_item(module.items[i], atlas, tombstones, out)
        i = i + 1
    }
    return out
}
