}

fn _is_let_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Let -> true,
        ItemKind::Fn -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false,
        ItemKind::Import -> false
    }
}

// ── TypeRef → Type lowering (small) ─────────────────────────
// AST TypeRef is untyped; map common primitive names + user-defined
// nominal types onto a Type. Unrecognised names become a "named"
// Type carrying just the name through `kind` so the diagnostic
// pretty-printer can still show something.

fn _lower_type_ref(tr: TypeRef) -> Type {
    if len(tr.kind) == 0 { return _empty_type() }
    if tr.kind == "named" {
        let n = tr.name
        if n == "i64" || n == "Int" || n == "int" { return _t_i64() }
        if n == "f64" || n == "Float" || n == "float" || n == "Real" { return _t_f64() }
        if n == "bool" || n == "Bool" { return _t_bool() }
        if n == "string" || n == "String" { return _t_string() }
        if n == "char" || n == "Char" { return _t_char() }
        if n == "unit" || n == "Unit" || n == "()" || len(n) == 0 { return _t_unit() }
        return Type {
            kind: "named:" + n,
            def: _miss_def_id(),
            args: [],
            ret: [],
            domain: "",
            unit: ""
        }
    }
    // generic / fn / tuple / atlas_kind — degrade gracefully
    return Type {
        kind: tr.kind + ":" + tr.name,
        def: _miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// ── TypeEnv ops ──────────────────────────────────────────────

fn _env_define(env: TypeEnv, name: string, def: DefId, t: Type) -> TypeEnv {
    let mut entries = env.entries
    entries.push(TypeBinding { def: def, name: name, typ: t })
    return TypeEnv { entries: entries }
}

fn _env_lookup(env: TypeEnv, name: string) -> Type {
    let mut i = 0
    while i < len(env.entries) {
        let b = env.entries[i]
        if b.name == name { return b.typ }
        i = i + 1
    }
    return _empty_type()
}

// Standalone fallback used by the test when bind has not run — scan a
// Module's items for a top-level definition with the given name and
// synthesise its Type. Mirrors the pre-pass that `type_check` performs
// on a real module, just inlined for callers that hand-build envs.
pub fn _resolve_ident_to_type(env: TypeEnv, name: string) -> Type {
    return _env_lookup(env, name)
}

// ── Diagnostic emit helpers ──────────────────────────────────

fn _emit(code: string, sev: Severity, stage: string, msg: string, sp: Span, out: array) {
    let d = Diagnostic {
        code: code,
        severity: sev,
        stage: stage,
        span: sp,
        message: msg,
        note: "",
        suggest: "",
        fixit: _empty_fixit(),
        related: []
    }
    out.push(d)
}

fn _emit_hx3001(expected: Type, actual: Type, sp: Span, out: array) {
    let msg = "type mismatch: expected `" + _type_display(expected) + "`, got `" + _type_display(actual) + "`"
    _emit("HX3001", Severity::Error, "S3", msg, sp, out)
}

fn _emit_hx3002(name: string, expected: i64, actual: i64, sp: Span, out: array) {
    let msg = "wrong number of arguments to `" + name + "`: expected " + to_string(expected) + ", got " + to_string(actual)
    _emit("HX3002", Severity::Error, "S3", msg, sp, out)
}

fn _emit_hx3003(name: string, pos: i64, expected: Type, actual: Type, sp: Span, out: array) {
    let msg = "argument " + to_string(pos) + " of `" + name + "`: expected `" + _type_display(expected) + "`, got `" + _type_display(actual) + "`"
    _emit("HX3003", Severity::Error, "S3", msg, sp, out)
}

fn _emit_hx3004(name: string, expected: Type, actual: Type, sp: Span, out: array) {
    let msg = "return type mismatch: function `" + name + "` returns `" + _type_display(expected) + "`, got `" + _type_display(actual) + "`"
    _emit("HX3004", Severity::Error, "S3", msg, sp, out)
}

fn _emit_hx3005(pos: i64, expected: Type, actual: Type, sp: Span, out: array) {
    let msg = "match arms have different types: expected `" + _type_display(expected) + "`, got `" + _type_display(actual) + "` on arm " + to_string(pos)
    _emit("HX3005", Severity::Error, "S3", msg, sp, out)
}

fn _emit_hx4001(sp: Span, out: array) {
    let msg = "integer division narrows the real domain to integers; use `//` (floor) or cast to f64 to silence"
    _emit("HX4001", Severity::Warning, "S4", msg, sp, out)
}

// ── Type equivalence (nominal, structural for primitives) ────

fn _types_equal(a: Type, b: Type) -> bool {
    // Either side unknown → tolerate (don't double-report).
    if len(a.kind) == 0 || len(b.kind) == 0 { return true }
    return a.kind == b.kind
}

fn _is_numeric(t: Type) -> bool {
    if len(t.kind) == 0 { return false }
    if t.kind == "i64" { return true }
    if t.kind == "f64" { return true }
    if t.kind == "i32" { return true }
    if t.kind == "f32" { return true }
    return false
}

fn _is_integer_kind(t: Type) -> bool {
    if t.kind == "i64" { return true }
    if t.kind == "i32" { return true }
    return false
}

// ── Context for the walker ───────────────────────────────────
// Threaded through recursive checks: the enclosing fn name + return Type
// (for HX3004) and the module name (currently informational).

pub struct CheckCtx {
    fn_name: string,
    fn_return: Type,
    module: string
}

fn _new_ctx(module: string) -> CheckCtx {
    return CheckCtx { fn_name: "", fn_return: _empty_type(), module: module }
}

fn _ctx_with_fn(ctx: CheckCtx, name: string, ret: Type) -> CheckCtx {
    return CheckCtx { fn_name: name, fn_return: ret, module: ctx.module }
}

// ── Expression type inference + checks ───────────────────────
// Returns the inferred Type of `e`. Diagnostics for sub-expressions push
// into `out` along the way (multi-error policy).

fn _infer_expr(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    if _is_lit_int(e.kind)    { return _t_i64() }
    if _is_lit_float(e.kind)  { return _t_f64() }
    if _is_lit_string(e.kind) { return _t_string() }
    if _is_lit_bool(e.kind)   { return _t_bool() }
    if _is_lit_char(e.kind)   { return _t_char() }

    if _is_ident(e.kind) {
        let t = _env_lookup(env, e.text)
        return t
    }

    if _is_atlas(e.kind) {
        // Atlas refs inhabit a kind-specific opaque type; S5/S8 will refine.
        let k = e.atlas_ref.kind
        if len(k) == 0 { return _empty_type() }
        return Type {
            kind: "atlas_" + k,
            def: _miss_def_id(),
            args: [],
            ret: [],
            domain: "",
            unit: ""
        }
    }

    if _is_unop(e.kind) {
        if len(e.children) == 0 { return _empty_type() }
        let inner = _infer_expr(e.children[0], env, ctx, out)
        // Unary `-` keeps the operand's numeric type; otherwise pass through.
        if e.text == "-" && _is_numeric(inner) {
            return inner
        }
        return inner
    }

    if _is_binop(e.kind) {
        return _check_binop(e, env, ctx, out)
    }

    if _is_call(e.kind) {
        return _check_call(e, env, ctx, out)
    }

    if _is_block(e.kind) {
        let mut last = _t_unit()
        let mut i = 0
        while i < len(e.children) {
            last = _infer_expr(e.children[i], env, ctx, out)
            i = i + 1
        }
        return last
    }

    if _is_if(e.kind) {
        // children: [cond, then, (else)]
        if len(e.children) >= 1 {
            let cond_t = _infer_expr(e.children[0], env, ctx, out)
            if !_types_equal(cond_t, _t_bool()) {
                _emit_hx3001(_t_bool(), cond_t, e.children[0].span, out)
            }
        }
        let mut then_t = _t_unit()
        let mut else_t = _t_unit()
        if len(e.children) >= 2 {
            then_t = _infer_expr(e.children[1], env, ctx, out)
        }
        if len(e.children) >= 3 {
            else_t = _infer_expr(e.children[2], env, ctx, out)
            if !_types_equal(then_t, else_t) {
                _emit_hx3001(then_t, else_t, e.span, out)
            }
        }
        return then_t
    }

    if _is_while(e.kind) {
        if len(e.children) >= 1 {
            let cond_t = _infer_expr(e.children[0], env, ctx, out)
            if !_types_equal(cond_t, _t_bool()) {
                _emit_hx3001(_t_bool(), cond_t, e.children[0].span, out)
            }
        }
        if len(e.children) >= 2 {
            // body's type discarded — while is always unit.
            let _b = _infer_expr(e.children[1], env, ctx, out)
        }
        return _t_unit()
    }

    if _is_return(e.kind) {
        let mut val_t = _t_unit()
        if len(e.children) > 0 {
            val_t = _infer_expr(e.children[0], env, ctx, out)
        }
        // Validate against enclosing fn return type.
        if len(ctx.fn_return.kind) > 0 {
            if !_types_equal(ctx.fn_return, val_t) {
                _emit_hx3004(ctx.fn_name, ctx.fn_return, val_t, e.span, out)
            }
        }
        return _t_unit()
    }

    if _is_let(e.kind) {
        // Walk RHS so any inner type errors surface.
        let mut i = 0
        while i < len(e.children) {
            let _t = _infer_expr(e.children[i], env, ctx, out)
            i = i + 1
        }
        return _t_unit()
    }

    if _is_assign(e.kind) {
        if len(e.children) >= 2 {
            let lhs_t = _infer_expr(e.children[0], env, ctx, out)
            let rhs_t = _infer_expr(e.children[1], env, ctx, out)
            if !_types_equal(lhs_t, rhs_t) {
                _emit_hx3001(lhs_t, rhs_t, e.span, out)
            }
        }
        return _t_unit()
    }

    if _is_match_expr(e.kind) {
        return _check_match(e, env, ctx, out)
    }

    // Field / Index / StructLit / EnumPath / Wildcard — STUB v1.
    // Walk children for inner errors; return unknown so outer sites that
    // gate on equality tolerate (per _types_equal).
    let mut i = 0
    while i < len(e.children) {
        let _t = _infer_expr(e.children[i], env, ctx, out)
        i = i + 1
    }
    return _empty_type()
}

// ── BinOp checker ────────────────────────────────────────────

fn _is_arith_op(op: string) -> bool {
    if op == "+" { return true }
    if op == "-" { return true }
    if op == "*" { return true }
    if op == "/" { return true }
    if op == "%" { return true }
    return false
}

fn _is_compare_op(op: string) -> bool {
    if op == "==" { return true }
    if op == "!=" { return true }
    if op == "<"  { return true }
    if op == "<=" { return true }
    if op == ">"  { return true }
    if op == ">=" { return true }
    return false
}

fn _check_binop(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    if len(e.children) < 2 { return _empty_type() }
    let lt = _infer_expr(e.children[0], env, ctx, out)
    let rt = _infer_expr(e.children[1], env, ctx, out)
    let op = e.text

    if _is_arith_op(op) {
        // Both sides must be numeric AND of the same kind.
        if _is_numeric(lt) && _is_numeric(rt) {
            if !_types_equal(lt, rt) {
                _emit_hx3001(lt, rt, e.span, out)
            }
            // S4: integer / integer narrows the ℝ domain → HX4001 (Warning).
            if op == "/" && _is_integer_kind(lt) && _is_integer_kind(rt) {
                _emit_hx4001(e.span, out)
            }
            return lt
        }
        // Mismatch (one or both non-numeric) — treat as type-mismatch with
        // the LHS as the reference shape; emit once.
        _emit_hx3001(lt, rt, e.span, out)
        return lt
    }

    if _is_compare_op(op) {
        if !_types_equal(lt, rt) {
            _emit_hx3001(lt, rt, e.span, out)
        }
        return _t_bool()
    }

    // Unknown operator — fall back to LHS type.
    return lt
}

// ── Call checker ─────────────────────────────────────────────

fn _check_call(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    if len(e.children) == 0 { return _empty_type() }
    let callee = e.children[0]
    let callee_t = _infer_expr(callee, env, ctx, out)
    let arg_count = len(e.children) - 1

    // Best-effort callee name for diagnostics.
    let mut name = "<callee>"
    if _is_ident(callee.kind) && len(callee.text) > 0 { name = callee.text }

    // Walk args first so inner errors surface even when callee resolution fails.
    let mut arg_types: [Type] = []
    let mut i = 0
    while i < arg_count {
        let at = _infer_expr(e.children[1 + i], env, ctx, out)
        arg_types.push(at)
        i = i + 1
    }

    // Callee must be a fn type.
    if callee_t.kind != "fn" {
        // Callee not resolved as fn — skip arity/argument checks; return value
        // type unknown.
        return _empty_type()
    }

    let expected_count = len(callee_t.args)
    if arg_count != expected_count {
        _emit_hx3002(name, expected_count, arg_count, e.span, out)
    } else {
        let mut k = 0
        while k < arg_count {
            let want = callee_t.args[k]
            let got = arg_types[k]
            if !_types_equal(want, got) {
                _emit_hx3003(name, k + 1, want, got, e.children[1 + k].span, out)
            }
            k = k + 1
        }
    }

    if len(callee_t.ret) > 0 { return callee_t.ret[0] }
    return _t_unit()
}

// ── Match checker ────────────────────────────────────────────

fn _check_match(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    // children: [scrut, pat0, body0, pat1, body1, ...]
    if len(e.children) == 0 { return _empty_type() }
    let _scrut_t = _infer_expr(e.children[0], env, ctx, out)
    let mut first_t = _empty_type()
    let mut have_first = false
    let mut arm_idx = 0
    let mut i = 1
    while i + 1 < len(e.children) {
        // Pattern children may include ident binders (S2 handles binding) —
        // walk them so any type-bearing pattern still gets inspected, but
        // discard the inferred pattern type (no equality check at v1).
        let _pt = _infer_expr(e.children[i], env, ctx, out)
        let bt = _infer_expr(e.children[i + 1], env, ctx, out)
        if !have_first {
            first_t = bt
            have_first = true
        } else {
            if !_types_equal(first_t, bt) {
                _emit_hx3005(arm_idx, first_t, bt, e.children[i + 1].span, out)
            }
        }
        arm_idx = arm_idx + 1
        i = i + 2
    }
    return first_t
}

// ── Pre-pass: collect Item types into TypeEnv ────────────────

fn _signature_type(it: Item) -> Type {
    let mut params: [Type] = []
    let mut i = 0
    while i < len(it.params) {
        params.push(_lower_type_ref(it.params[i].typ))
        i = i + 1
    }
    let mut ret: [Type] = []
    let r = _lower_type_ref(it.return_type)
    if len(r.kind) > 0 {
        ret.push(r)
    } else {
        ret.push(_t_unit())
    }
    return Type {
        kind: "fn",
        def: _miss_def_id(),
        args: params,
        ret: ret,
        domain: "",
        unit: ""
    }
}

fn _struct_type(it: Item, def: DefId) -> Type {
    let mut fields: [Type] = []
    let mut i = 0
    while i < len(it.params) {
        fields.push(_lower_type_ref(it.params[i].typ))
        i = i + 1
    }
    return Type {
        kind: "struct",
        def: def,
        args: fields,
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _enum_type(def: DefId) -> Type {
    return Type {
        kind: "enum",
        def: def,
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _collect_item_types(module: Module) -> TypeEnv {
    let mut env = TypeEnv { entries: [] }
    let mut idx = 0
    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        let def = DefId { module: module.file, index: idx }
        if _is_fn_item(it.kind) {
            env = _env_define(env, it.name, def, _signature_type(it))
            idx = idx + 1
        } else if _is_struct_item(it.kind) {
            env = _env_define(env, it.name, def, _struct_type(it, def))
            idx = idx + 1
        } else if _is_enum_item(it.kind) {
            env = _env_define(env, it.name, def, _enum_type(def))
            idx = idx + 1
        } else if _is_let_item(it.kind) {
            env = _env_define(env, it.name, def, _lower_type_ref(it.return_type))
            idx = idx + 1
        }
        i = i + 1
    }
    return env
}

// ── Per-fn local env (params bind on top of module env) ──────

fn _bind_params(env: TypeEnv, it: Item) -> TypeEnv {
    let mut e = env
    let mut i = 0
    while i < len(it.params) {
        let p = it.params[i]
        let pt = _lower_type_ref(p.typ)
        e = _env_define(e, p.name, _miss_def_id(), pt)
        i = i + 1
    }
    return e
}

// ── Public entry ─────────────────────────────────────────────

pub fn type_check(module: Module) -> array {
    let mut out = []
    let env = _collect_item_types(module)
    let ctx0 = _new_ctx(module.file)

    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        if _is_fn_item(it.kind) {
            let local = _bind_params(env, it)
            let r = _lower_type_ref(it.return_type)
            let mut ret = r
            if len(ret.kind) == 0 { ret = _t_unit() }
            let ctx = _ctx_with_fn(ctx0, it.name, ret)
            // Walk body — inner Returns validate against ctx.fn_return.
            let body_t = _infer_expr(it.body, local, ctx, out)
            // Trailing block expression must also satisfy the return type
            // (when fn was annotated and body produced a value).
            if len(r.kind) > 0 && !_types_equal(r, body_t) {
                // Only report if body actually produced something (non-unknown);
                // unannotated/early-return-only fns still pass cleanly.
                if len(body_t.kind) > 0 && body_t.kind != "unit" {
                    _emit_hx3004(it.name, r, body_t, it.body.span, out)
                }
            }
        } else if _is_let_item(it.kind) {
            // RHS type vs declared type.
            let declared = _lower_type_ref(it.return_type)
            let rhs_t = _infer_expr(it.body, env, ctx0, out)
            if len(declared.kind) > 0 && len(rhs_t.kind) > 0 {
                if !_types_equal(declared, rhs_t) {
                    _emit_hx3001(declared, rhs_t, it.body.span, out)
                }
            }
        }
        // Struct / Enum / Import: no body to walk.
        i = i + 1
    }

    return out
}
