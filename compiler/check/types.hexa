// ── TypeRef → Type lowering (small) ─────────────────────────
// AST TypeRef is untyped; map common primitive names + user-defined
// nominal types onto a Type. Unrecognised names become a "named"
// Type carrying just the name through `kind` so the diagnostic
// pretty-printer can still show something.

fn _types_lower_type_ref(tr: TypeRef) -> Type {
    if len(tr.kind) == 0 { return _types_empty_type() }
    if tr.kind == "named" {
        let n = tr.name
        // Gap 3 (stage1 punch list): kind="named" with empty `name` is a stale
        // TypeRef shape — degrade to the unknown sentinel so the let-RHS /
        // return checker tolerates instead of falsely mapping to `unit`.
        // Without this, an unannotated let RHS spuriously raised HX3001
        // "expected unit, got <rhs>".
        if len(n) == 0 { return _types_empty_type() }
        if n == "i8"  { return _types_t_i8() }
        if n == "i16" { return _types_t_i16() }
        if n == "i32" { return _types_t_i32() }
        if n == "i64" || n == "Int" || n == "int" { return _types_t_i64() }
        if n == "f32" { return _types_t_f32() }
        if n == "f64" || n == "Float" || n == "float" || n == "Real" { return _types_t_f64() }
        if n == "bool" || n == "Bool" { return _types_t_bool() }
        if n == "string" || n == "String" { return _types_t_string() }
        if n == "char" || n == "Char" { return _types_t_char() }
        if n == "unit" || n == "Unit" || n == "()" { return _types_t_unit() }
        // u8/u16/u32/u64 — deferred: stage0 backend has no unsigned
        // representation. Fall through to the `named:<n>` sentinel so
        // downstream layers see the user's spelling without a silent
        // i64 alias (which would mis-typecheck signed/unsigned mixes).
        return Type {
            kind: "named:" + n,
            def: _types_miss_def_id(),
            args: [],
            ret: [],
            domain: "",
            unit: ""
        }
    }
    // generic / fn / tuple / atlas_kind — degrade gracefully
    return Type {
        kind: tr.kind + ":" + tr.name,
        def: _types_miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// ── TypeEnv ops ──────────────────────────────────────────────

// Define a binding with explicit visibility + owning-module attribution.
// Stage1 punch list Gap 2 — pub items live in the global namespace; non-pub
// items are file-private and visible only when the caller's module.file
// matches `module_file`. Local bindings (fn params, lets) are recorded as
// pub=false / module_file=current to keep them invisible across files.
fn _types_env_define_attr(env: TypeEnv, name: string, def: DefId, t: Type,
    is_pub: bool, module_file: string) -> TypeEnv {
    let mut entries = env.entries
    entries.push(TypeBinding {
        def: def,
        name: name,
        typ: t,
        is_pub: is_pub,
        module_file: module_file
    })
    return TypeEnv { entries: entries }
}

// Backwards-compatible shim. Pre-Gap-2 callers expected a single-namespace
// define with no visibility/attribution — we record those as pub=false /
// module_file="" so cross-file lookups never see them. The pre-pass uses
// `_types_env_define_attr` directly with the real values.
fn _types_env_define(env: TypeEnv, name: string, def: DefId, t: Type) -> TypeEnv {
    return _types_env_define_attr(env, name, def, t, false, "")
}

// Status of a name lookup. Stage1 Gap 2:
//   found=true                          → typ is the visible binding
//   found=false, private_other_module=true
//                                       → name exists privately in another
//                                         module — caller emits HX2002
//   found=false, private_other_module=false
//                                       → name simply does not exist
pub struct LookupResult {
    found: bool,
    typ: Type,
    private_other_module: bool,
    other_module_file: string
}

fn _types_lookup_def(env: TypeEnv, name: string, caller_file: string) -> LookupResult {
    // Pass 1: pub global hit takes priority (pubs are global names).
    let mut i = 0
    while i < len(env.entries) {
        let b = env.entries[i]
        if b.name == name && b.is_pub {
            return LookupResult {
                found: true,
                typ: b.typ,
                private_other_module: false,
                other_module_file: ""
            }
        }
        i = i + 1
    }
    // Pass 2: private hit in caller's own module.
    let mut j = 0
    while j < len(env.entries) {
        let b = env.entries[j]
        if b.name == name && !b.is_pub && b.module_file == caller_file {
            return LookupResult {
                found: true,
                typ: b.typ,
                private_other_module: false,
                other_module_file: ""
            }
        }
        j = j + 1
    }
    // Pass 3: name exists privately, but in a foreign module — surface
    // the privacy violation (caller emits HX2002).
    let mut k = 0
    while k < len(env.entries) {
        let b = env.entries[k]
        if b.name == name && !b.is_pub {
            return LookupResult {
                found: false,
                typ: _types_empty_type(),
                private_other_module: true,
                other_module_file: b.module_file
            }
        }
        k = k + 1
    }
    return LookupResult {
        found: false,
        typ: _types_empty_type(),
        private_other_module: false,
        other_module_file: ""
    }
}

// Legacy lookup. Caller-file is taken from the env's first private binding
// when present (test harnesses build flat envs with no module attribution).
// Production code paths now use `_types_lookup_def` directly with the real
// CheckCtx.module attribution.
fn _types_env_lookup(env: TypeEnv, name: string) -> Type {
    let mut i = 0
    while i < len(env.entries) {
        let b = env.entries[i]
        if b.name == name { return b.typ }
        i = i + 1
    }
    return _types_empty_type()
}

// Standalone fallback used by the test when bind has not run — scan a
// Module's items for a top-level definition with the given name and
// synthesise its Type. Mirrors the pre-pass that `type_check` performs
// on a real module, just inlined for callers that hand-build envs.
pub fn _resolve_ident_to_type(env: TypeEnv, name: string) -> Type {
    return _types_env_lookup(env, name)
}

// ── Diagnostic emit helpers ──────────────────────────────────

fn _emit_hx3001(expected: Type, actual: Type, sp: Span, out: array) {
    let mut b = diag_new("HX3001")
    b = diag_span(b, sp)
    b = diag_arg(b, "expected", _type_display(expected))
    b = diag_arg(b, "actual", _type_display(actual))
    out.push(diag_emit(b))
}

fn _emit_hx3002(name: string, expected: i64, actual: i64, sp: Span, out: array) {
    let mut b = diag_new("HX3002")
    b = diag_span(b, sp)
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "expected", to_string(expected))
    b = diag_arg(b, "actual", to_string(actual))
    out.push(diag_emit(b))
}

fn _emit_hx3003(name: string, pos: i64, expected: Type, actual: Type, sp: Span, out: array) {
    let mut b = diag_new("HX3003")
    b = diag_span(b, sp)
    b = diag_arg(b, "pos", to_string(pos))
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "expected", _type_display(expected))
    b = diag_arg(b, "actual", _type_display(actual))
    out.push(diag_emit(b))
}

fn _emit_hx3004(name: string, expected: Type, actual: Type, sp: Span, out: array) {
    let mut b = diag_new("HX3004")
    b = diag_span(b, sp)
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "expected", _type_display(expected))
    b = diag_arg(b, "actual", _type_display(actual))
    out.push(diag_emit(b))
}

fn _emit_hx3005(pos: i64, expected: Type, actual: Type, sp: Span, out: array) {
    let mut b = diag_new("HX3005")
    b = diag_span(b, sp)
    b = diag_arg(b, "expected", _type_display(expected))
    b = diag_arg(b, "actual", _type_display(actual))
    b = diag_arg(b, "pos", to_string(pos))
    out.push(diag_emit(b))
}

fn _emit_hx4001(sp: Span, out: array) {
    let mut b = diag_new("HX4001")
    b = diag_span(b, sp)
    out.push(diag_emit(b))
}

// Stage1 Gap 2 — duplicate pub symbol across files.
fn _emit_hx3010(name: string, first_file: string, second_file: string, sp: Span, out: array) {
    let mut b = diag_new("HX3010")
    b = diag_span(b, sp)
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "first_file", first_file)
    b = diag_arg(b, "second_file", second_file)
    out.push(diag_emit(b))
}

// Stage1 Gap 2 — private symbol referenced from a foreign module.
fn _emit_hx2002(name: string, defining_file: string, caller_file: string, sp: Span, out: array) {
    let mut b = diag_new("HX2002")
    b = diag_span(b, sp)
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "defining_file", defining_file)
    b = diag_arg(b, "caller_file", caller_file)
    out.push(diag_emit(b))
}

// ── Type equivalence (nominal, structural for primitives) ────

fn _types_equal(a: Type, b: Type) -> bool {
    // Either side unknown → tolerate (don't double-report).
    if len(a.kind) == 0 || len(b.kind) == 0 { return true }
    return a.kind == b.kind
}

fn _types_is_numeric(t: Type) -> bool {
    if len(t.kind) == 0 { return false }
    if t.kind == "i8"  { return true }
    if t.kind == "i16" { return true }
    if t.kind == "i32" { return true }
    if t.kind == "i64" { return true }
    if t.kind == "f32" { return true }
    if t.kind == "f64" { return true }
    return false
}

fn _is_integer_kind(t: Type) -> bool {
    if t.kind == "i8"  { return true }
    if t.kind == "i16" { return true }
    if t.kind == "i32" { return true }
    if t.kind == "i64" { return true }
    return false
}

fn _is_float_kind(t: Type) -> bool {
    if t.kind == "f32" { return true }
    if t.kind == "f64" { return true }
    return false
}

// Literal-coercion-aware compatibility check.
//
// `_types_equal` is structural on `kind`, which is too strict for the
// universal-int-literal ergonomics every mainstream language ships:
// `let x: i32 = 0` should type-check even though `0` is inferred as i64.
// This helper layers a narrow exception on top:
//
//   - if either side is unknown → tolerate (preserves _types_equal policy)
//   - if both kinds are equal → ok
//   - if `actual` came from an integer literal AND both kinds are integer
//     kinds (any of i8/i16/i32/i64) → ok
//   - if `actual` came from a float literal AND both kinds are float
//     kinds (f32/f64) → ok
//
// Range-fit checking (does the literal value fit in i8?) is deferred to
// a later pass; v0 trusts the programmer the way Rust's untyped-int
// literal inference does. Out-of-range fits surface as codegen overflow.
fn _types_assignable(expected: Type, actual: Type, src: Expr) -> bool {
    if _types_equal(expected, actual) { return true }
    if _types_is_lit_int(src.kind) && _is_integer_kind(expected) && _is_integer_kind(actual) {
        return true
    }
    if _types_is_lit_float(src.kind) && _is_float_kind(expected) && _is_float_kind(actual) {
        return true
    }
    return false
}

// ── Context for the walker ───────────────────────────────────
// Threaded through recursive checks: the enclosing fn name + return Type
// (for HX3004) and the module name (currently informational).

pub struct CheckCtx {
    fn_name: string,
    fn_return: Type,
    module: string
}

fn _types_new_ctx(module: string) -> CheckCtx {
    return CheckCtx { fn_name: "", fn_return: _types_empty_type(), module: module }
}

fn _ctx_with_fn(ctx: CheckCtx, name: string, ret: Type) -> CheckCtx {
    return CheckCtx { fn_name: name, fn_return: ret, module: ctx.module }
}

// ── Expression type inference + checks ───────────────────────
// Returns the inferred Type of `e`. Diagnostics for sub-expressions push
// into `out` along the way (multi-error policy).

fn _infer_expr(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    if _types_is_lit_int(e.kind)    { return _types_t_i64() }
    if _types_is_lit_float(e.kind)  { return _types_t_f64() }
    if _types_is_lit_string(e.kind) { return _types_t_string() }
    if _is_lit_bool(e.kind)   { return _types_t_bool() }
    if _is_lit_char(e.kind)   { return _types_t_char() }

    if _types_is_ident(e.kind) {
        // Stage1 Gap 2 — caller-module-aware lookup. Pub items are global;
        // privates are only visible inside their owning module. A foreign
        // private surface as HX2002 (private name not accessible).
        let r = _types_lookup_def(env, e.text, ctx.module)
        if r.found { return r.typ }
        if r.private_other_module {
            _emit_hx2002(e.text, r.other_module_file, ctx.module, e.span, out)
        }
        // Fall back to legacy single-namespace scan for hand-built test envs
        // that pre-date the visibility split (resolve_test / bind_test build
        // their TypeEnv directly without module attribution).
        return _types_env_lookup(env, e.text)
    }

    if _is_atlas(e.kind) {
        // Atlas refs inhabit a kind-specific opaque type; S5/S8 will refine.
        let k = e.atlas_ref.kind
        if len(k) == 0 { return _types_empty_type() }
        return Type {
            kind: "atlas_" + k,
            def: _types_miss_def_id(),
            args: [],
            ret: [],
            domain: "",
            unit: ""
        }
    }

    if _types_is_unop(e.kind) {
        if len(e.children) == 0 { return _types_empty_type() }
        let inner = _infer_expr(e.children[0], env, ctx, out)
        // Unary `-` keeps the operand's numeric type; otherwise pass through.
        if e.text == "-" && _types_is_numeric(inner) {
            return inner
        }
        return inner
    }

    if _types_is_binop(e.kind) {
        return _types_check_binop(e, env, ctx, out)
    }

    if _types_is_call(e.kind) {
        return _types_check_call(e, env, ctx, out)
    }

    if _types_is_block(e.kind) {
        let mut last = _types_t_unit()
        let mut i = 0
        while i < len(e.children) {
            last = _infer_expr(e.children[i], env, ctx, out)
            i = i + 1
        }
        return last
    }

    if _types_is_if(e.kind) {
        // children: [cond, then, (else)]
        if len(e.children) >= 1 {
            let cond_t = _infer_expr(e.children[0], env, ctx, out)
            if !_types_equal(cond_t, _types_t_bool()) {
                _emit_hx3001(_types_t_bool(), cond_t, e.children[0].span, out)
            }
        }
        let mut then_t = _types_t_unit()
        let mut else_t = _types_t_unit()
        if len(e.children) >= 2 {
            then_t = _infer_expr(e.children[1], env, ctx, out)
        }
        if len(e.children) >= 3 {
            else_t = _infer_expr(e.children[2], env, ctx, out)
            if !_types_equal(then_t, else_t) {
                _emit_hx3001(then_t, else_t, e.span, out)
            }
        }
        return then_t
    }

    if _types_is_while(e.kind) {
        if len(e.children) >= 1 {
            let cond_t = _infer_expr(e.children[0], env, ctx, out)
            if !_types_equal(cond_t, _types_t_bool()) {
                _emit_hx3001(_types_t_bool(), cond_t, e.children[0].span, out)
            }
        }
        if len(e.children) >= 2 {
            // body's type discarded — while is always unit.
            let _b = _infer_expr(e.children[1], env, ctx, out)
        }
        return _types_t_unit()
    }

    if _types_is_return(e.kind) {
        let mut val_t = _types_t_unit()
        let mut val_src = e
        if len(e.children) > 0 {
            val_t = _infer_expr(e.children[0], env, ctx, out)
            val_src = e.children[0]
        }
        // Validate against enclosing fn return type. _types_assignable
        // permits the standard integer-literal coercion (e.g. `return 0`
        // for an `-> i32` fn) so the M0 baseline type-checks.
        if len(ctx.fn_return.kind) > 0 {
            if !_types_assignable(ctx.fn_return, val_t, val_src) {
                _emit_hx3004(ctx.fn_name, ctx.fn_return, val_t, e.span, out)
            }
        }
        return _types_t_unit()
    }

    if _types_is_let(e.kind) {
        // Walk RHS so any inner type errors surface.
        let mut i = 0
        while i < len(e.children) {
            let _t = _infer_expr(e.children[i], env, ctx, out)
            i = i + 1
        }
        return _types_t_unit()
    }

    if _types_is_assign(e.kind) {
        if len(e.children) >= 2 {
            let lhs_t = _infer_expr(e.children[0], env, ctx, out)
            let rhs_t = _infer_expr(e.children[1], env, ctx, out)
            if !_types_equal(lhs_t, rhs_t) {
                _emit_hx3001(lhs_t, rhs_t, e.span, out)
            }
        }
        return _types_t_unit()
    }

    if _is_match_expr(e.kind) {
        return _check_match(e, env, ctx, out)
    }

    // Field / Index / StructLit / EnumPath / Wildcard — STUB v1.
    // Walk children for inner errors; return unknown so outer sites that
    // gate on equality tolerate (per _types_equal).
    let mut i = 0
    while i < len(e.children) {
        let _t = _infer_expr(e.children[i], env, ctx, out)
        i = i + 1
    }
    return _types_empty_type()
}

// ── BinOp checker ────────────────────────────────────────────

fn _is_arith_op(op: string) -> bool {
    if op == "+" { return true }
    if op == "-" { return true }
    if op == "*" { return true }
    if op == "/" { return true }
    if op == "%" { return true }
    return false
}

fn _types_is_compare_op(op: string) -> bool {
    if op == "==" { return true }
    if op == "!=" { return true }
    if op == "<"  { return true }
    if op == "<=" { return true }
    if op == ">"  { return true }
    if op == ">=" { return true }
    return false
}

fn _types_check_binop(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    if len(e.children) < 2 { return _types_empty_type() }
    let lt = _infer_expr(e.children[0], env, ctx, out)
    let rt = _infer_expr(e.children[1], env, ctx, out)
    let op = e.text

    if _is_arith_op(op) {
        // Both sides must be numeric AND of the same kind.
        if _types_is_numeric(lt) && _types_is_numeric(rt) {
            if !_types_equal(lt, rt) {
                _emit_hx3001(lt, rt, e.span, out)
            }
            // S4: integer / integer narrows the ℝ domain → HX4001 (Warning).
            if op == "/" && _is_integer_kind(lt) && _is_integer_kind(rt) {
                _emit_hx4001(e.span, out)
            }
            return lt
        }
        // Mismatch (one or both non-numeric) — treat as type-mismatch with
        // the LHS as the reference shape; emit once.
        _emit_hx3001(lt, rt, e.span, out)
        return lt
    }

    if _types_is_compare_op(op) {
        if !_types_equal(lt, rt) {
            _emit_hx3001(lt, rt, e.span, out)
        }
        return _types_t_bool()
    }

    // Unknown operator — fall back to LHS type.
    return lt
}

// ── Call checker ─────────────────────────────────────────────

fn _types_check_call(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    if len(e.children) == 0 { return _types_empty_type() }
    let callee = e.children[0]
    let callee_t = _infer_expr(callee, env, ctx, out)
    let arg_count = len(e.children) - 1

    // Best-effort callee name for diagnostics.
    let mut name = "<callee>"
    if _types_is_ident(callee.kind) && len(callee.text) > 0 { name = callee.text }

    // Walk args first so inner errors surface even when callee resolution fails.
    let mut arg_types: [Type] = []
    let mut i = 0
    while i < arg_count {
        let at = _infer_expr(e.children[1 + i], env, ctx, out)
        arg_types.push(at)
        i = i + 1
    }

    // Callee must be a fn type.
    if callee_t.kind != "fn" {
        // Callee not resolved as fn — skip arity/argument checks; return value
        // type unknown.
        return _types_empty_type()
    }

    let expected_count = len(callee_t.args)
    if arg_count != expected_count {
        _emit_hx3002(name, expected_count, arg_count, e.span, out)
    } else {
        let mut k = 0
        while k < arg_count {
            let want = callee_t.args[k]
            let got = arg_types[k]
            if !_types_equal(want, got) {
                _emit_hx3003(name, k + 1, want, got, e.children[1 + k].span, out)
            }
            k = k + 1
        }
    }

    if len(callee_t.ret) > 0 { return callee_t.ret[0] }
    return _types_t_unit()
}

// ── Match checker ────────────────────────────────────────────

fn _check_match(e: Expr, env: TypeEnv, ctx: CheckCtx, out: array) -> Type {
    // children: [scrut, pat0, body0, pat1, body1, ...]
    if len(e.children) == 0 { return _types_empty_type() }
    let _scrut_t = _infer_expr(e.children[0], env, ctx, out)
    let mut first_t = _types_empty_type()
    let mut have_first = false
    let mut arm_idx = 0
    let mut i = 1
    while i + 1 < len(e.children) {
        // Pattern children may include ident binders (S2 handles binding) —
        // walk them so any type-bearing pattern still gets inspected, but
        // discard the inferred pattern type (no equality check at v1).
        let _pt = _infer_expr(e.children[i], env, ctx, out)
        let bt = _infer_expr(e.children[i + 1], env, ctx, out)
        if !have_first {
            first_t = bt
            have_first = true
        } else {
            if !_types_equal(first_t, bt) {
                _emit_hx3005(arm_idx, first_t, bt, e.children[i + 1].span, out)
            }
        }
        arm_idx = arm_idx + 1
        i = i + 2
    }
    return first_t
}

// ── Pre-pass: collect Item types into TypeEnv ────────────────

fn _types_signature_type(it: Item) -> Type {
    let mut params: [Type] = []
    let mut i = 0
    while i < len(it.params) {
        params.push(_types_lower_type_ref(it.params[i].typ))
        i = i + 1
    }
    let mut ret: [Type] = []
    let r = _types_lower_type_ref(it.return_type)
    if len(r.kind) > 0 {
        ret.push(r)
    } else {
        ret.push(_types_t_unit())
    }
    return Type {
        kind: "fn",
        def: _types_miss_def_id(),
        args: params,
        ret: ret,
        domain: "",
        unit: ""
    }
}

fn _types_struct_type(it: Item, def: DefId) -> Type {
    let mut fields: [Type] = []
    let mut i = 0
    while i < len(it.params) {
        fields.push(_types_lower_type_ref(it.params[i].typ))
        i = i + 1
    }
    return Type {
        kind: "struct",
        def: def,
        args: fields,
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _types_enum_type(def: DefId) -> Type {
    return Type {
        kind: "enum",
        def: def,
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// Look up an existing binding by (name, owning_file) — used by the pre-pass
// for idempotent re-registration detection (Item appears twice in
// module.items because the same fn was spliced from another file).
fn _types_find_binding(env: TypeEnv, name: string, owning_file: string) -> bool {
    let mut i = 0
    while i < len(env.entries) {
        let b = env.entries[i]
        if b.name == name && b.module_file == owning_file {
            return true
        }
        i = i + 1
    }
    return false
}

// Find the file that owns the existing pub binding for `name`, or "" when
// no pub binding is present. Used by HX3010 emission to identify the prior
// owner during a duplicate-pub-symbol-across-files report.
fn _types_pub_owner_file(env: TypeEnv, name: string) -> string {
    let mut i = 0
    while i < len(env.entries) {
        let b = env.entries[i]
        if b.name == name && b.is_pub {
            return b.module_file
        }
        i = i + 1
    }
    return ""
}

// Stage1 Gap 2 — pre-pass that respects pub visibility AND dedupes across
// files. Walks module.items (which after Gap 1 may carry items spliced
// from imported files) and:
//   - Skips an Item whose (name, owning_file) is already in env (idempotent
//     re-registration; the same fn arrived twice via the splice path — no
//     diagnostic, this is by design).
//   - For pub items, treats `name` as a global key. A second pub binding
//     for the same name from a DIFFERENT file emits HX3010 (Error, S3) and
//     skips the duplicate so downstream lookups see only the first.
//   - For non-pub items, treats `<file>::<name>` as the key — multiple
//     files may each declare a private `helper` without conflict.
//
// The `out` array collects HX3010 diagnostics; non-collision cases push
// nothing so existing single-file callers see an empty diag list.
fn _collect_item_types(module: Module, out: array) -> TypeEnv {
    let mut env = TypeEnv { entries: [] }
    let mut idx = 0
    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        // Each item carries an owning file via item.span.file (parser sets
        // span.file on every constructed AST node). Fall back to the top-
        // level module.file when span.file is empty (hand-built tests).
        let mut owning = it.span.file
        if len(owning) == 0 { owning = module.file }
        let def = DefId { module: owning, index: idx }

        // Skip non-definition items up front.
        let is_def = _types_is_fn_item(it.kind)
            || _types_is_struct_item(it.kind)
            || _types_is_enum_item(it.kind)
            || _types_is_let_item(it.kind)
        if !is_def {
            i = i + 1
            continue
        }

        // Idempotent re-registration: same item from same file already in
        // env — silently skip (the parser's import splice may surface the
        // same fn twice when a file is reachable from multiple paths).
        if _types_find_binding(env, it.name, owning) {
            i = i + 1
            continue
        }

        // Pub-vs-pub collision across files → HX3010, skip the second.
        if it.is_pub {
            let prior_owner = _types_pub_owner_file(env, it.name)
            if len(prior_owner) > 0 && prior_owner != owning {
                _emit_hx3010(it.name, prior_owner, owning, it.span, out)
                i = i + 1
                continue
            }
        }

        if _types_is_fn_item(it.kind) {
            env = _types_env_define_attr(env, it.name, def,
                _types_signature_type(it), it.is_pub, owning)
        } else if _types_is_struct_item(it.kind) {
            env = _types_env_define_attr(env, it.name, def,
                _types_struct_type(it, def), it.is_pub, owning)
        } else if _types_is_enum_item(it.kind) {
            env = _types_env_define_attr(env, it.name, def,
                _types_enum_type(def), it.is_pub, owning)
        } else {
            // _types_is_let_item
            env = _types_env_define_attr(env, it.name, def,
                _types_lower_type_ref(it.return_type), it.is_pub, owning)
        }
        idx = idx + 1
        i = i + 1
    }
    return env
}

// ── Per-fn local env (params bind on top of module env) ──────

fn _types_bind_params(env: TypeEnv, it: Item, caller_file: string) -> TypeEnv {
    let mut e = env
    // Resolve the file that "owns" these params — falls back to caller_file
    // when the item has no span attribution (hand-built tests).
    let mut owning = it.span.file
    if len(owning) == 0 { owning = caller_file }
    let mut i = 0
    while i < len(it.params) {
        let p = it.params[i]
        let pt = _types_lower_type_ref(p.typ)
        // Params are file-private (visible only within the enclosing fn /
        // module). Record them with is_pub=false and the resolved owning
        // file so `_types_lookup_def` can match them under the caller's
        // module attribution.
        e = _types_env_define_attr(e, p.name, _types_miss_def_id(), pt,
            false, owning)
        i = i + 1
    }
    return e
}

// ── Public entry ─────────────────────────────────────────────

pub fn type_check(module: Module) -> array {
    let mut out = []
    // Pre-pass collects item types and emits HX3010 for duplicate pub
    // symbols across files (Stage1 punch list Gap 2).
    let env = _collect_item_types(module, out)
    let ctx0 = _types_new_ctx(module.file)

    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        if _types_is_fn_item(it.kind) {
            // The fn's enclosing file becomes the caller's module for
            // visibility checks. Fall back to module.file when the item
            // span has no attribution (hand-built tests).
            let mut fn_file = it.span.file
            if len(fn_file) == 0 { fn_file = module.file }
            let local = _types_bind_params(env, it, fn_file)
            let r = _types_lower_type_ref(it.return_type)
            let mut ret = r
            if len(ret.kind) == 0 { ret = _types_t_unit() }
            // Per-fn ctx uses the fn's owning file so `_types_lookup_def`
            // applies the right caller-module to private visibility.
            let ctx_for_fn = _types_new_ctx(fn_file)
            let ctx = _ctx_with_fn(ctx_for_fn, it.name, ret)
            // Walk body — inner Returns validate against ctx.fn_return.
            let body_t = _infer_expr(it.body, local, ctx, out)
            // Trailing block expression must also satisfy the return type
            // (when fn was annotated and body produced a value).
            // Use the block's last child as the literal-coercion source so
            // `fn f() -> i32 { 0 }` type-checks via _types_assignable.
            let mut tail_src = it.body
            if len(it.body.children) > 0 {
                tail_src = it.body.children[len(it.body.children) - 1]
            }
            if len(r.kind) > 0 && !_types_assignable(r, body_t, tail_src) {
                // Only report if body actually produced something (non-unknown);
                // unannotated/early-return-only fns still pass cleanly.
                if len(body_t.kind) > 0 && body_t.kind != "unit" {
                    _emit_hx3004(it.name, r, body_t, it.body.span, out)
                }
            }
        } else if _types_is_let_item(it.kind) {
            // RHS type vs declared type. _types_assignable lets
            // `let x: i32 = 0` type-check (literal-int coercion).
            let declared = _types_lower_type_ref(it.return_type)
            let rhs_t = _infer_expr(it.body, env, ctx0, out)
            if len(declared.kind) > 0 && len(rhs_t.kind) > 0 {
                if !_types_assignable(declared, rhs_t, it.body) {
                    _emit_hx3001(declared, rhs_t, it.body.span, out)
                }
            }
        }
        // Struct / Enum / Import: no body to walk.
        i = i + 1
    }

    return out
}
