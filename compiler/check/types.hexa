// ── ItemKind probes ──────────────────────────────────────────

fn _is_fn_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Fn -> true,
        ItemKind::Let -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false,
        ItemKind::Import -> false
    }
}

fn _is_struct_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Struct -> true,
        ItemKind::Fn -> false,
        ItemKind::Let -> false,
        ItemKind::Enum -> false,
