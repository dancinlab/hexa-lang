// HEXA Native Compiler — Phase B3 / S3+S4: type & domain check
//
// @version 0.1.0
// @capabilities [pure]
//
// Walks a parsed Module and:
//   S3: infers expression types, validates assignments / calls / binops /
//       returns / match arms. Multi-error per RFC-019 §6 — every site is
//       reported.
//   S4: light domain check — emits HX4001 (Warning) when integer / integer
//       division narrows the ℝ domain. Real / Natural / Complex propagation
//       is stubbed at the literal layer (LiteralInt → "integer", LiteralFloat
//       → "real") so units (S5) and prover (S7) can refine later.
//
// Per RFC-017 §3.1 S3 is fatal — type mismatches abort compilation. HX4001
// is Warning only (domain hint), so it doesn't gate codegen on its own.
//
// Stage0 caveats:
//   - HIR.Type is the typed shape (compiler/ir/hir.hexa). We synthesise it
//     here without lowering the AST — that lives in a future Phase B4.
//   - Field access / struct literal validation is a v1 stub (records the
//     receiver type but doesn't look up declared field types yet).
//   - If compiler/check/bind.hexa is absent at this code-base SHA, the
//     `_resolve_ident_to_type` fallback covers the sole identifier case
//     used by the test (function call lookup) by scanning module items.

import "../parse/ast.hexa"
import "../diag/catalog.hexa"
import "../ir/hir.hexa"
import "../lex/tokens.hexa"

// ── TypeEnv ──────────────────────────────────────────────────
// Flat module-level binding table. Each item (fn / struct / enum / let)
// maps a DefId-shaped key to a Type, where the Type kind encodes the role:
//   fn      → Type{kind="fn", args=[param types], ret=[return type]}
//   struct  → Type{kind="struct", def, args=[field types]}
//   enum    → Type{kind="enum",   def}
//   let     → declared type (or Type{kind=""} when unannotated)

pub struct TypeBinding {
    def: DefId,
    name: string,        // mirror of name for did-you-mean / lookup convenience
    typ: Type
}

pub struct TypeEnv {
    entries: [TypeBinding]
}

// ── Helpers ──────────────────────────────────────────────────

fn _empty_fixit() -> FixIt {
    return FixIt {
        kind: FixItKind::None,
        span: Span { file: "", line: 0, col: 0, len: 0 },
        new_text: ""
    }
}

fn _miss_def_id() -> DefId {
    return DefId { module: "", index: -1 }
}

fn _empty_type() -> Type {
    return Type {
        kind: "",
        def: _miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _prim(kind: string, domain: string) -> Type {
    return Type {
        kind: kind,
        def: _miss_def_id(),
        args: [],
        ret: [],
        domain: domain,
        unit: ""
    }
}

fn _t_i64()    -> Type { return _prim("i64",    "integer") }
fn _t_f64()    -> Type { return _prim("f64",    "real") }
fn _t_bool()   -> Type { return _prim("bool",   "") }
fn _t_string() -> Type { return _prim("string", "") }
fn _t_char()   -> Type { return _prim("char",   "") }
fn _t_unit()   -> Type { return _prim("unit",   "") }

// Render a Type for diagnostic messages. Stage0 has no Display impl, so we
// hand-roll a minimal pretty-printer that resolves the most common cases.
fn _type_display(t: Type) -> string {
    if len(t.kind) == 0 { return "<unknown>" }
    if t.kind == "fn" {
        let mut s = "fn("
        let mut i = 0
        while i < len(t.args) {
            if i > 0 { s = s + ", " }
            s = s + _type_display(t.args[i])
            i = i + 1
        }
        s = s + ")"
        if len(t.ret) > 0 {
            s = s + " -> " + _type_display(t.ret[0])
        }
        return s
    }
    if t.kind == "struct" || t.kind == "enum" {
        if len(t.def.module) > 0 || t.def.index >= 0 {
            // We don't record the bare name on Type, so fall back to kind.
            return t.kind
        }
        return t.kind
    }
    return t.kind
}

