// ── Annotation extraction ────────────────────────────────────
// `@units(...)` per-fn: positional string-literal args.
//   1  arg  → ret unit only.
//   n+1 args (n = fn param count) → param units, last = ret unit.
//   else   → discard (silent — robust against malformed annotations).

pub struct UnitsAnn {
    has: bool,
    params: [Unit],   // one Unit per fn param (in order)
    ret: Unit
}

fn _empty_units_ann(param_count: i64) -> UnitsAnn {
    let mut params: [Unit] = []
    let mut i = 0
    while i < param_count {
        params.push(unit_empty())
        i = i + 1
    }
    return UnitsAnn { has: false, params: params, ret: unit_empty() }
}

fn _extract_units_ann(it: Item) -> UnitsAnn {
    let pc = len(it.params)
    let mut ann = _empty_units_ann(pc)
    // Stage1 punch list C13: early-out before any unit-string parsing.
    // Most compiler/ fns are unannotated; skipping the loop saves a hot
    // pass over `it.annotations` (zero-iteration `while` still allocates
    // its scratch slot in stage0).
    if len(it.annotations) == 0 { return ann }
    let mut i = 0
    while i < len(it.annotations) {
        let a = it.annotations[i]
        if a.name == "units" {
            // Collect all string-literal args.
            let mut strs: [string] = []
            let mut j = 0
            while j < len(a.args) {
                let arg = a.args[j]
                if _units_is_lit_string(arg.kind) {
                    strs.push(arg.text)
                }
                j = j + 1
            }
            let total = len(strs)
            if total == 1 {
                ann.has = true
                ann.ret = parse_unit(strs[0])
            } else if total == pc + 1 {
                ann.has = true
                let mut k = 0
                let mut new_params: [Unit] = []
                while k < pc {
                    new_params.push(parse_unit(strs[k]))
                    k = k + 1
                }
                ann.params = new_params
                ann.ret = parse_unit(strs[pc])
            }
            // Other shapes → leave unitless.
        }
        i = i + 1
    }
    return ann
}

// ── UnitEnv: param name → Unit ───────────────────────────────

pub struct UnitBinding {
    name: string,
    u: Unit
}

pub struct UnitEnv {
    entries: [UnitBinding]
}

fn _env_empty() -> UnitEnv {
    return UnitEnv { entries: [] }
}

fn _units_env_define(env: UnitEnv, name: string, u: Unit) -> UnitEnv {
    let mut e = env.entries
    e.push(UnitBinding { name: name, u: u })
    return UnitEnv { entries: e }
}

fn _units_env_lookup(env: UnitEnv, name: string) -> Unit {
    let mut i = 0
    while i < len(env.entries) {
        if env.entries[i].name == name { return env.entries[i].u }
        i = i + 1
    }
    return unit_empty()
}

// Module-level fn signature table for call checking.
pub struct FnSig {
    name: string,
    params: [Unit],
    ret: Unit,
    has: bool
}

pub struct SigTable {
    sigs: [FnSig]
}

fn _collect_sigs(module: Module) -> SigTable {
    let mut sigs: [FnSig] = []
    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        if _units_is_fn_item(it.kind) {
            let ann = _extract_units_ann(it)
            sigs.push(FnSig {
                name: it.name,
                params: ann.params,
                ret: ann.ret,
                has: ann.has
            })
        }
        i = i + 1
    }
    return SigTable { sigs: sigs }
}

fn _lookup_sig(table: SigTable, name: string) -> FnSig {
    let mut i = 0
    while i < len(table.sigs) {
        if table.sigs[i].name == name { return table.sigs[i] }
        i = i + 1
    }
    return FnSig { name: "", params: [], ret: unit_empty(), has: false }
}

// ── Diagnostic emit helpers ──────────────────────────────────

fn _units_empty_fixit() -> FixIt {
    return FixIt {
        kind: FixItKind::None,
        span: Span { file: "", line: 0, col: 0, len: 0 },
        new_text: ""
    }
}

fn _emit_hx5001(op: string, lu: Unit, ru: Unit, sp: Span, out: array) {
    let mut b = diag_new("HX5001")
    b = diag_span(b, sp)
    b = diag_arg(b, "op", op)
    b = diag_arg(b, "lhs", unit_to_string(lu))
    b = diag_arg(b, "rhs", unit_to_string(ru))
    out.push(diag_emit(b))
}

fn _emit_hx5002(name: string, expected: Unit, actual: Unit, sp: Span, out: array) {
    let mut b = diag_new("HX5002")
    b = diag_span(b, sp)
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "expected", unit_to_string(expected))
    b = diag_arg(b, "actual", unit_to_string(actual))
    out.push(diag_emit(b))
}

fn _emit_hx5003(name: string, pos: i64, expected: Unit, actual: Unit, sp: Span, out: array) {
    let mut b = diag_new("HX5003")
    b = diag_span(b, sp)
    b = diag_arg(b, "pos", to_string(pos))
    b = diag_arg(b, "name", name)
    b = diag_arg(b, "expected", unit_to_string(expected))
    b = diag_arg(b, "actual", unit_to_string(actual))
    out.push(diag_emit(b))
}

// ── Walker context ──────────────────────────────────────────
// Stage1 punch list Gap 12 — VERIFIED, no code change. All UnitCtx fields
// are populated at the SOLE construction site (`unit_check`, see ~line
// 1109) where `sigs` receives `_collect_sigs(module)`, which always
// returns `SigTable { sigs: [] }` even on an empty module (see
// `_collect_sigs` ~line 832). `_lookup_sig(ctx.sigs, name)` therefore
// never reads a missing field.

pub struct UnitCtx {
    fn_name: string,
    fn_ret: Unit,
    has_ret: bool,
    sigs: SigTable
}

// Return true iff `a` and `b` are both non-unitless and incompatible.
// Lenient v1 — empty unit is compatible with anything.
fn _incompatible(a: Unit, b: Unit) -> bool {
    if unit_is_empty(a) { return false }
    if unit_is_empty(b) { return false }
    if unit_eq(a, b) { return false }
    return true
}

// ── Expression unit inference ────────────────────────────────

fn _infer(e: Expr, env: UnitEnv, ctx: UnitCtx, out: array) -> Unit {
    if _units_is_lit_int(e.kind)    { return unit_empty() }
    if _units_is_lit_float(e.kind)  { return unit_empty() }
    if _units_is_lit_string(e.kind) { return unit_empty() }

    if _units_is_ident(e.kind) {
        return _units_env_lookup(env, e.text)
    }

    if _units_is_unop(e.kind) {
        if len(e.children) == 0 { return unit_empty() }
        return _infer(e.children[0], env, ctx, out)
    }

    if _units_is_binop(e.kind) {
        return _units_check_binop(e, env, ctx, out)
    }

    if _units_is_call(e.kind) {
        return _units_check_call(e, env, ctx, out)
    }

    if _units_is_block(e.kind) {
        let mut last = unit_empty()
        let mut i = 0
        while i < len(e.children) {
            last = _infer(e.children[i], env, ctx, out)
            i = i + 1
        }
        return last
    }

    if _units_is_if(e.kind) {
        let mut i = 0
        while i < len(e.children) {
            let _u = _infer(e.children[i], env, ctx, out)
            i = i + 1
        }
        // Use then-branch unit if present.
        if len(e.children) >= 2 {
            return _infer(e.children[1], env, ctx, out)
        }
        return unit_empty()
    }

    if _units_is_while(e.kind) {
        let mut i = 0
        while i < len(e.children) {
            let _u = _infer(e.children[i], env, ctx, out)
            i = i + 1
        }
        return unit_empty()
    }

    if _units_is_return(e.kind) {
        let mut val_u = unit_empty()
        if len(e.children) > 0 {
            val_u = _infer(e.children[0], env, ctx, out)
        }
        if ctx.has_ret {
            if _incompatible(ctx.fn_ret, val_u) {
                _emit_hx5002(ctx.fn_name, ctx.fn_ret, val_u, e.span, out)
            }
        }
        return unit_empty()
    }

    if _units_is_let(e.kind) {
        // Walk children; let bindings don't propagate units in v1.
        let mut i = 0
        while i < len(e.children) {
            let _u = _infer(e.children[i], env, ctx, out)
            i = i + 1
        }
        return unit_empty()
    }

    // Other kinds — walk for sub-effects, return unitless.
    let mut i = 0
    while i < len(e.children) {
        let _u = _infer(e.children[i], env, ctx, out)
        i = i + 1
    }
    return unit_empty()
}

fn _is_addsub(op: string) -> bool {
    if op == "+" { return true }
    if op == "-" { return true }
    return false
}

fn _is_mul(op: string) -> bool { return op == "*" }
fn _is_div(op: string) -> bool { return op == "/" }

fn _is_compare(op: string) -> bool {
    if op == "==" { return true }
    if op == "!=" { return true }
    if op == "<"  { return true }
    if op == "<=" { return true }
    if op == ">"  { return true }
    if op == ">=" { return true }
    return false
}

fn _units_check_binop(e: Expr, env: UnitEnv, ctx: UnitCtx, out: array) -> Unit {
    if len(e.children) < 2 { return unit_empty() }
    let lu = _infer(e.children[0], env, ctx, out)
    let ru = _infer(e.children[1], env, ctx, out)
    let op = e.text

    if _is_addsub(op) {
        if _incompatible(lu, ru) {
            _emit_hx5001(op, lu, ru, e.span, out)
        }
        // Result unit = lhs unit (or rhs if lhs unitless).
        if !unit_is_empty(lu) { return lu }
        return ru
    }

    if _is_compare(op) {
        if _incompatible(lu, ru) {
            _emit_hx5001(op, lu, ru, e.span, out)
        }
        return unit_empty()
    }

    if _is_mul(op) {
        return unit_mul(lu, ru)
    }

    if _is_div(op) {
        return unit_div(lu, ru)
    }

    // Unknown op — fall back to lhs unit.
    return lu
}

fn _units_check_call(e: Expr, env: UnitEnv, ctx: UnitCtx, out: array) -> Unit {
    if len(e.children) == 0 { return unit_empty() }
    let callee = e.children[0]
    let arg_count = len(e.children) - 1

    // Infer arg units (always — sub-expr diagnostics still flow).
    let mut arg_us: [Unit] = []
    let mut i = 0
    while i < arg_count {
        let au = _infer(e.children[1 + i], env, ctx, out)
        arg_us.push(au)
        i = i + 1
    }

    if !_units_is_ident(callee.kind) {
        let _cu = _infer(callee, env, ctx, out)
        return unit_empty()
    }
    let name = callee.text
    let sig = _lookup_sig(ctx.sigs, name)
    if !sig.has {
        // Untyped callee — no constraint.
        return unit_empty()
    }
    if arg_count == len(sig.params) {
        let mut k = 0
        while k < arg_count {
            let want = sig.params[k]
            let got = arg_us[k]
            if _incompatible(want, got) {
                _emit_hx5003(name, k + 1, want, got, e.children[1 + k].span, out)
            }
            k = k + 1
        }
    }
    return sig.ret
}

// ── Per-fn binding ──────────────────────────────────────────

fn _units_bind_params(env: UnitEnv, it: Item, ann: UnitsAnn) -> UnitEnv {
    let mut e = env
    let mut i = 0
    while i < len(it.params) {
        let p = it.params[i]
        let mut u = unit_empty()
        if i < len(ann.params) {
            u = ann.params[i]
        }
        e = _units_env_define(e, p.name, u)
        i = i + 1
    }
    return e
}

// ── Public entry ────────────────────────────────────────────

pub fn unit_check(module: Module) -> array {
    let mut out = []
    let sigs = _collect_sigs(module)
    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        if _units_is_fn_item(it.kind) {
            let ann = _extract_units_ann(it)
            // Skip fns without @units annotation entirely (lenient v1 gate).
            if ann.has {
                let env = _units_bind_params(_env_empty(), it, ann)
                let ctx = UnitCtx {
                    fn_name: it.name,
                    fn_ret: ann.ret,
                    has_ret: true,
                    sigs: sigs
                }
                let body_u = _infer(it.body, env, ctx, out)
                // Trailing block unit must satisfy ret (when body produced one).
                if !unit_is_empty(body_u) && _incompatible(ann.ret, body_u) {
                    _emit_hx5002(it.name, ann.ret, body_u, it.body.span, out)
                }
            }
        }
        i = i + 1
    }
    return out
}
