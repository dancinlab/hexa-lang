// HEXA Native Compiler — Phase B3+ / S5: dimensional analysis (units check)
//
// @version 0.1.0
// @capabilities [pure]
//
// Walks a parsed Module and validates dimensional consistency in any
// fn that carries an `@units(...)` annotation. RFC-017 §3.1 lists S5
// as default-fatal; §3.5 specifies the annotation syntax.
//
// Annotation convention (lenient v1, given stage0 parser has no kwarg
// support): arguments to `@units` are positional string literals.
//   * 1 arg                                → return unit only
//   * n+1 args (n = fn param count)        → param units + return unit
//
//   @units("J")                            // ret = J, params unitless
//   @units("kg", "m/s", "J")               // m: kg, v: m/s, ret: J
//
// Diagnostics:
//   HX5001 — binop arithmetic unit mismatch (+, -, comparisons)
//   HX5002 — fn return unit mismatch
//   HX5003 — call argument unit mismatch
//
// Lenient v1 (per task spec): an unknown / empty unit is treated as
// "unitless and compatible with anything." S5 only fires when both
// sides carry concrete units. A future strict v2 will reject mixing.
//
// Stage0 caveats:
//   - Hexa stage0 lacks rich string ops; parse_unit splits on "." and
//     "/" only. Power notation (`s^2`) is expanded by repeating the
//     factor (s^2 → ["s","s"]).
//   - Negative exponents (`s^-2`) are allowed in the denominator slot:
//     `s^-2` parses as den=["s","s"].

import "../parse/ast.hexa"
import "../diag/catalog.hexa"
import "../diag/builder.hexa"
import "../ir/hir.hexa"
import "../lex/tokens.hexa"

// ── Unit canonical form ──────────────────────────────────────
// Numerator / denominator are sorted string lists. Sorting makes
// `unit_eq` a simple per-index comparison.

pub struct Unit {
    num: [string],
    den: [string]
}

pub fn unit_empty() -> Unit {
    return Unit { num: [], den: [] }
}

pub fn unit_is_empty(u: Unit) -> bool {
    return len(u.num) == 0 && len(u.den) == 0
}

// ── String helpers (stage0 has no built-in trim / parseint) ──

fn _is_digit_ch(c: string) -> bool {
    if c == "0" { return true }
    if c == "1" { return true }
    if c == "2" { return true }
    if c == "3" { return true }
    if c == "4" { return true }
    if c == "5" { return true }
    if c == "6" { return true }
    if c == "7" { return true }
    if c == "8" { return true }
    if c == "9" { return true }
    return false
}

fn _units_digit_val(c: string) -> i64 {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return 0
}

// Trim ASCII whitespace from both ends.
fn _trim_units(s: string) -> string {
    let n = len(s)
    if n == 0 { return s }
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c != " " && c != "\t" { break }
        i = i + 1
    }
    let mut j = n
    while j > i {
        let c = s.substring(j - 1, j)
        if c != " " && c != "\t" { break }
        j = j - 1
    }
    return s.substring(i, j)
}

// Append `count` copies of `factor` to `dst`.
fn _push_n(dst: [string], factor: string, count: i64) -> [string] {
    let mut out = dst
    let mut i = 0
    while i < count {
        out.push(factor)
        i = i + 1
    }
    return out
}

// Parse one factor token like "kg", "m", "s^2", "s^-2".
// Returns (base, exponent). Negative exponent flags denominator placement
// at the call site.
pub struct UnitFactor {
    base: string,
    exp: i64
}

fn _parse_factor(tok: string) -> UnitFactor {
    let t = _trim_units(tok)
    let n = len(t)
    if n == 0 { return UnitFactor { base: "", exp: 0 } }

    // Find "^"
    let mut i = 0
    while i < n {
        if t.substring(i, i + 1) == "^" { break }
        i = i + 1
    }
    if i == n {
        // No exponent — implicit 1.
        return UnitFactor { base: t, exp: 1 }
    }

    let base = t.substring(0, i)
    // Parse exponent (may have leading "-")
    let mut j = i + 1
    let mut sign = 1
    if j < n && t.substring(j, j + 1) == "-" {
        sign = -1
        j = j + 1
    }
    if j < n && t.substring(j, j + 1) == "+" {
        j = j + 1
    }
    let mut acc = 0
    while j < n {
        let c = t.substring(j, j + 1)
        if !_is_digit_ch(c) { break }
        acc = acc * 10 + _units_digit_val(c)
        j = j + 1
    }
    if acc == 0 { acc = 1 }
    return UnitFactor { base: base, exp: sign * acc }
}

// Add factors from a "."-joined product string into num/den. Negative
// exponents flip side.
fn _ingest_product(spec: string, num: [string], den: [string], invert: bool) -> Unit {
    let mut nums = num
    let mut dens = den
    let s = _trim_units(spec)
    if len(s) == 0 { return Unit { num: nums, den: dens } }
    let parts = s.split(".")
    let mut i = 0
    while i < len(parts) {
        let f = _parse_factor(parts[i])
        if len(f.base) > 0 {
            let mut e = f.exp
            if invert { e = -e }
            if e > 0 {
                nums = _push_n(nums, f.base, e)
            } else if e < 0 {
                dens = _push_n(dens, f.base, -e)
            }
            // e == 0 → drop
        }
        i = i + 1
    }
    return Unit { num: nums, den: dens }
}

// In-place insertion sort for [string].
fn _units_sort_strings(xs: [string]) -> [string] {
    let mut a = xs
    let n = len(a)
    let mut i = 1
    while i < n {
        let key = a[i]
        let mut j = i - 1
        while j >= 0 && a[j] > key {
            a[j + 1] = a[j]
            j = j - 1
        }
        a[j + 1] = key
        i = i + 1
    }
    return a
}

// Cancel matching elements between num and den (e.g. m/m → unitless).
fn _cancel(u: Unit) -> Unit {
    let mut num = u.num
    let mut den = u.den
    let mut new_num: [string] = []
    let mut i = 0
    while i < len(num) {
        let factor = num[i]
        // search for factor in den
        let mut found = -1
        let mut j = 0
        while j < len(den) {
            if den[j] == factor {
                found = j
                break
            }
            j = j + 1
        }
        if found >= 0 {
            // remove from den
            let mut new_den: [string] = []
            let mut k = 0
            while k < len(den) {
                if k != found { new_den.push(den[k]) }
                k = k + 1
            }
            den = new_den
        } else {
            new_num.push(factor)
        }
        i = i + 1
    }
    return Unit { num: new_num, den: den }
}

fn _units_normalize(u: Unit) -> Unit {
    let cancelled = _cancel(u)
    return Unit {
        num: _units_sort_strings(cancelled.num),
        den: _units_sort_strings(cancelled.den)
    }
}

// ── Public unit ops ──────────────────────────────────────────

// Parse a simple unit spec like "kg.m/s^2" / "m" / "s^-2" / "" (unitless).
//
// Examples handled:
//   ""              → unit_empty()
//   "1"             → unit_empty()  (explicit unitless)
//   "kg"            → num=[kg]
//   "m/s"           → num=[m], den=[s]
//   "kg.m/s^2"      → num=[kg,m], den=[s,s]
//   "s^-2"          → num=[], den=[s,s]
//   "m^2/s"         → num=[m,m], den=[s]
//   "kg.m.m/s.s"    → num=[kg,m,m], den=[s,s]
pub fn parse_unit(spec: string) -> Unit {
    let s = _trim_units(spec)
    if len(s) == 0 { return unit_empty() }
    if s == "1" { return unit_empty() }

    // Split on "/" once — left = numerator product, right = denominator product.
    let n = len(s)
    let mut slash = -1
    let mut i = 0
    while i < n {
        if s.substring(i, i + 1) == "/" { slash = i; break }
        i = i + 1
    }

    let mut num_str = s
    let mut den_str = ""
    if slash >= 0 {
        num_str = s.substring(0, slash)
        den_str = s.substring(slash + 1, n)
    }

    let mut nums: [string] = []
    let mut dens: [string] = []
    let u1 = _ingest_product(num_str, nums, dens, false)
    let u2 = _ingest_product(den_str, u1.num, u1.den, true)
    return _units_normalize(u2)
}

pub fn unit_eq(a: Unit, b: Unit) -> bool {
    let an = _units_sort_strings(a.num)
    let ad = _units_sort_strings(a.den)
    let bn = _units_sort_strings(b.num)
    let bd = _units_sort_strings(b.den)
    if len(an) != len(bn) { return false }
    if len(ad) != len(bd) { return false }
    let mut i = 0
    while i < len(an) {
        if an[i] != bn[i] { return false }
        i = i + 1
    }
    i = 0
    while i < len(ad) {
        if ad[i] != bd[i] { return false }
        i = i + 1
    }
    return true
}

pub fn unit_mul(a: Unit, b: Unit) -> Unit {
    let mut num: [string] = []
    let mut i = 0
    while i < len(a.num) { num.push(a.num[i]); i = i + 1 }
    i = 0
    while i < len(b.num) { num.push(b.num[i]); i = i + 1 }
    let mut den: [string] = []
    i = 0
    while i < len(a.den) { den.push(a.den[i]); i = i + 1 }
    i = 0
    while i < len(b.den) { den.push(b.den[i]); i = i + 1 }
    return _units_normalize(Unit { num: num, den: den })
}

pub fn unit_div(a: Unit, b: Unit) -> Unit {
    let mut num: [string] = []
    let mut i = 0
    while i < len(a.num) { num.push(a.num[i]); i = i + 1 }
    i = 0
    while i < len(b.den) { num.push(b.den[i]); i = i + 1 }
    let mut den: [string] = []
    i = 0
    while i < len(a.den) { den.push(a.den[i]); i = i + 1 }
    i = 0
    while i < len(b.num) { den.push(b.num[i]); i = i + 1 }
    return _units_normalize(Unit { num: num, den: den })
}

// Pretty-print canonical unit for diagnostics.
pub fn unit_to_string(u: Unit) -> string {
    if unit_is_empty(u) { return "1" }
    let mut s = ""
    if len(u.num) == 0 {
        s = "1"
    } else {
        let mut i = 0
        while i < len(u.num) {
            if i > 0 { s = s + "." }
            s = s + u.num[i]
            i = i + 1
        }
    }
    if len(u.den) > 0 {
        s = s + "/"
        let mut j = 0
        while j < len(u.den) {
            if j > 0 { s = s + "." }
            s = s + u.den[j]
            j = j + 1
        }
    }
    return s
}

