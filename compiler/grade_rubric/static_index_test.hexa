// HEXA Native Compiler — Wave 1 absorption: grade_rubric smoke

use "compiler/grade_rubric/embed"
use "compiler/grade_rubric/embedded.gen"
use "compiler/grade_rubric/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 grade_rubric embed smoke")
    println("  hash:         " + GRADE_RUBRIC_HASH)
    println("  generated_at: " + GRADE_RUBRIC_GENERATED_AT)
    println("  source_count: " + to_string(GRADE_RUBRIC_SOURCE_COUNT))
    println("  entries:      " + to_string(len(GRADE_RUBRIC)))
    println("  kv_entries:   " + to_string(len(GRADE_RUBRIC_KV)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(GRADE_RUBRIC_HASH),                       fails)
    _check("generated_at non-empty",     len(GRADE_RUBRIC_GENERATED_AT) > 0,                 fails)
    _check("source_count > 0",           GRADE_RUBRIC_SOURCE_COUNT > 0,                      fails)
    _check("entries match source_count", len(GRADE_RUBRIC) == GRADE_RUBRIC_SOURCE_COUNT,     fails)

    let g10 = lookup_grade(10)
    _check("lookup_grade(10).grade == 10",   g10.grade == 10,                                fails)
    _check("lookup_grade(10).stage non-empty", len(g10.stage) > 0,                           fails)

    let g99 = lookup_grade(99)
    _check("lookup_grade(99) miss → grade 0", g99.grade == 0,                                fails)

    let vg = verify_grade("EXACT")
    _check("verify_grade(EXACT) == 10",   vg == 10,                                          fails)

    let pr = promotion_rule("9_to_10")
    _check("promotion_rule(9_to_10) non-empty", len(pr) > 0,                                 fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(GRADE_RUBRIC)) + "/" + to_string(GRADE_RUBRIC_SOURCE_COUNT) + " entries, hash=" + GRADE_RUBRIC_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
