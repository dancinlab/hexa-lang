// HEXA Native Compiler — Phase B4 / Lower: AST → HIR
//
// @version 0.1.0
// @capabilities [pure]
//
// Translates a (presumed-checked) parse Module into a typed HModule.
//
//   pub fn lower(module: Module, atlas: AtlasIndex) -> HModule
//
// This is a 1:1 translation pass: every AST Expr produces exactly one
// HExpr (no flattening, no semantic checks). Every AST Item produces
// exactly one HItem. Untyped expressions get Type{kind="?"} as a
// placeholder — downstream MIR will reject "?" types.
//
// Notes:
//   - We do NOT consume the bind.hexa Scopes output; instead we walk a
//     small inline scope stack for ident DefId resolution. This keeps
//     the lower pass self-contained while we wire B2 → B4 plumbing.
//   - Atlas refs (P/C/L/E) are resolved against the supplied AtlasIndex
//     at lower time so HExpr.atlas carries atlas_index + atlas_hash.
//   - 100% enum match dispatch on ExprKind / ItemKind (no string compares
//     against the AST kind tags).
//
// Stage0 caveats:
//   - HItem.kind is `string` per hir.hexa shape — we emit "ITEM_FN" /
//     "ITEM_STRUCT" / "ITEM_LET" / "ITEM_ENUM" / "ITEM_IMPORT".
//   - HExpr.kind likewise mirrors AST kind names lower-cased ("literal_int",
//     "ident", "binop", "atlas_ref", …).

import "../parse/ast.hexa"
import "../atlas/merger.hexa"
import "../atlas/parser.hexa"
import "../ir/hir.hexa"
import "../lex/tokens.hexa"
import "../diag/builder.hexa"
import "../diag/catalog.hexa"

// ── Lower-pass diagnostic sink (Stage1 Gap 14) ──────────────
// Module-level mutable buffer following the parse/check pass pattern.
// `lower(...)` resets it on entry and `lower_diags()` returns the
// collected diagnostics so the driver in compiler/main.hexa can merge
// them with the rest of the diag stream. Currently the only code that
// writes here is the HX1100 closure-capture detector (Gap 14.1 follow-
// up — inactive today because the parser does not yet emit a fn-literal
// / closure ExprKind).
pub let mut l_diags: array = []

pub fn lower_diags() -> array {
    return l_diags
}

// ── C19 (stage1 punch list v2): unique-id counter for `for`-desugar
// temporaries. Each `for x in iter { body }` mints two fresh names —
// `__for_it_<n>` (iterable snapshot) and `__for_idx_<n>` (counter) —
// so nested for-loops do not shadow each other. The counter is reset
// per `lower(...)` call below so output is determinate for a given
// input module.
pub let mut _for_uid: i64 = 0

fn _next_for_uid() -> i64 {
    _for_uid = _for_uid + 1
    return _for_uid
}

// ── Sentinels / helpers ──────────────────────────────────────

fn _hir_miss_def_id() -> DefId {
    return DefId { module: "", index: -1 }
}

fn _hir_empty_type() -> Type {
    return Type {
        kind: "?",
        def: _hir_miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _prim_type(kind: string, domain: string) -> Type {
    return Type {
        kind: kind,
        def: _hir_miss_def_id(),
        args: [],
        ret: [],
        domain: domain,
        unit: ""
    }
}

fn _hir_t_i8()     -> Type { return _prim_type("i8",     "integer") }
fn _hir_t_i16()    -> Type { return _prim_type("i16",    "integer") }
fn _hir_t_i32()    -> Type { return _prim_type("i32",    "integer") }
fn _hir_t_i64()    -> Type { return _prim_type("i64",    "integer") }
fn _hir_t_f32()    -> Type { return _prim_type("f32",    "real") }
fn _hir_t_f64()    -> Type { return _prim_type("f64",    "real") }
fn _hir_t_bool()   -> Type { return _prim_type("bool",   "") }
fn _hir_t_string() -> Type { return _prim_type("string", "") }
fn _hir_t_char()   -> Type { return _prim_type("char",   "") }
fn _hir_t_unit()   -> Type { return _prim_type("unit",   "") }

fn _empty_atlas_binding() -> AtlasBinding {
    return AtlasBinding {
        ref_kind: "",
        id: "",
        atlas_index: -1,
        atlas_hash: ""
    }
}

// ── TypeRef → Type lowering ─────────────────────────────────

fn _hir_lower_type_ref(tr: TypeRef) -> Type {
    if len(tr.kind) == 0 { return _hir_t_unit() }
    if tr.kind == "named" {
        let n = tr.name
        // B1 (stage1 punch list v2): kind="named" with empty `name` is a stale
        // TypeRef shape — degrade to the unknown sentinel rather than falsely
        // mapping to `unit`. Mirrors the Gap 3 fix in
        // compiler/check/types.hexa::_types_lower_type_ref so the HIR lower
        // path does not re-introduce HX3001 cascades when it becomes visible.
        if len(n) == 0 { return _hir_empty_type() }
        if n == "i8"  { return _hir_t_i8() }
        if n == "i16" { return _hir_t_i16() }
        if n == "i32" { return _hir_t_i32() }
        if n == "i64" || n == "Int" || n == "int" { return _hir_t_i64() }
        if n == "f32" { return _hir_t_f32() }
        if n == "f64" || n == "Float" || n == "float" || n == "Real" { return _hir_t_f64() }
        if n == "bool" || n == "Bool" { return _hir_t_bool() }
        if n == "string" || n == "String" { return _hir_t_string() }
        if n == "char" || n == "Char" { return _hir_t_char() }
        if n == "unit" || n == "Unit" || n == "()" || len(n) == 0 { return _hir_t_unit() }
        // u8/u16/u32/u64 — deferred (mirror compiler/check/types.hexa policy).
        return Type {
            kind: "named:" + n,
            def: _hir_miss_def_id(),
            args: [],
            ret: [],
            domain: "",
            unit: ""
        }
    }
    return Type {
        kind: tr.kind + ":" + tr.name,
        def: _hir_miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// ── ItemKind dispatch (enum match) ───────────────────────────

fn _item_kind_tag(k: ItemKind) -> string {
    return match k {
        ItemKind::Fn -> "ITEM_FN",
        ItemKind::Let -> "ITEM_LET",
        ItemKind::Struct -> "ITEM_STRUCT",
        ItemKind::Enum -> "ITEM_ENUM",
        ItemKind::Import -> "ITEM_IMPORT"
    }
}

fn _hir_is_fn_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Fn -> true,
        ItemKind::Let -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false,
        ItemKind::Import -> false
    }
}

fn _hir_is_let_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Let -> true,
        ItemKind::Fn -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false,
        ItemKind::Import -> false
    }
}

fn _hir_is_struct_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Struct -> true,
        ItemKind::Fn -> false,
        ItemKind::Let -> false,
        ItemKind::Enum -> false,
        ItemKind::Import -> false
    }
}

fn _hir_is_enum_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Enum -> true,
        ItemKind::Fn -> false,
        ItemKind::Let -> false,
        ItemKind::Struct -> false,
        ItemKind::Import -> false
    }
}

fn _is_import_item(k: ItemKind) -> bool {
    return match k {
        ItemKind::Import -> true,
        ItemKind::Fn -> false,
        ItemKind::Let -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false
    }
}

// ── ExprKind dispatch (enum match) ───────────────────────────

fn _expr_kind_tag(k: ExprKind) -> string {
    return match k {
        ExprKind::LiteralInt -> "literal_int",
        ExprKind::LiteralFloat -> "literal_float",
        ExprKind::LiteralString -> "literal_string",
        ExprKind::LiteralBool -> "literal_bool",
        ExprKind::LiteralChar -> "literal_char",
        ExprKind::Ident -> "ident",
        ExprKind::AtlasRef -> "atlas_ref",
        ExprKind::Call -> "call",
        ExprKind::BinOp -> "binop",
        ExprKind::UnOp -> "unop",
        ExprKind::Block -> "block",
        ExprKind::If -> "if",
        ExprKind::While -> "while",
        ExprKind::For -> "for",
        ExprKind::Match -> "match",
        ExprKind::Return -> "return",
        ExprKind::Let -> "let",
        ExprKind::Assign -> "assign",
        ExprKind::Field -> "field",
        ExprKind::Index -> "index",
        ExprKind::ArrayLit -> "array_lit",
        ExprKind::StructLit -> "struct_lit",
        ExprKind::EnumPath -> "enum_path",
        ExprKind::Wildcard -> "wildcard"
    }
}

