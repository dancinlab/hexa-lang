}

// ── Inline scope walker ──────────────────────────────────────
// Self-contained DefId resolution table — flat name→DefId pairs with
// frame boundaries tracked by `frame_starts`. We build it as we walk.

pub struct LowerBinding {
    name: string,
    def: DefId,
    typ: Type
}

pub struct LowerScope {
    bindings: [LowerBinding],
    frame_starts: [i64],   // index into bindings[] where each frame begins
    next_index: i64,
    mod_file: string
}

fn _new_scope(mod_file: string) -> LowerScope {
    return LowerScope {
        bindings: [],
        frame_starts: [],
        next_index: 0,
        mod_file: mod_file
    }
}

fn _push_frame(sc: LowerScope) -> LowerScope {
    let mut starts = sc.frame_starts
    starts.push(len(sc.bindings))
    return LowerScope {
        bindings: sc.bindings,
        frame_starts: starts,
        next_index: sc.next_index,
        mod_file: sc.mod_file
    }
}

fn _pop_frame(sc: LowerScope) -> LowerScope {
    let n = len(sc.frame_starts)
    if n == 0 { return sc }
    let start = sc.frame_starts[n - 1]
    let mut new_bindings = []
    let mut i = 0
    while i < start {
        new_bindings.push(sc.bindings[i])
        i = i + 1
    }
    let mut new_starts = []
    let mut j = 0
    while j < n - 1 {
        new_starts.push(sc.frame_starts[j])
        j = j + 1
    }
    return LowerScope {
        bindings: new_bindings,
        frame_starts: new_starts,
        next_index: sc.next_index,
        mod_file: sc.mod_file
    }
}

fn _define_in_scope(sc: LowerScope, name: string, typ: Type) -> LowerScope {
    let def = DefId { module: sc.mod_file, index: sc.next_index }
    let mut bindings = sc.bindings
    bindings.push(LowerBinding { name: name, def: def, typ: typ })
    return LowerScope {
        bindings: bindings,
        frame_starts: sc.frame_starts,
        next_index: sc.next_index + 1,
        mod_file: sc.mod_file
    }
}

fn _define_with_def(sc: LowerScope, name: string, def: DefId, typ: Type) -> LowerScope {
    // For pre-pass module items where DefId is already minted.
    let mut bindings = sc.bindings
    bindings.push(LowerBinding { name: name, def: def, typ: typ })
    let mut next_idx = sc.next_index
    if def.index >= next_idx { next_idx = def.index + 1 }
    return LowerScope {
        bindings: bindings,
        frame_starts: sc.frame_starts,
        next_index: next_idx,
        mod_file: sc.mod_file
    }
}

fn _lookup_in_scope(sc: LowerScope, name: string) -> LowerBinding {
    let n = len(sc.bindings)
    let mut i = n - 1
    while i >= 0 {
        let b = sc.bindings[i]
        if b.name == name {
            return b
        }
        i = i - 1
    }
    return LowerBinding {
        name: "",
        def: _hir_miss_def_id(),
        typ: _hir_empty_type()
    }
}

// HX1100 closure-capture warning emitter (Stage1 Gap 14.1 follow-up).
// Inactive today because compiler/parse/parser.hexa does not yet emit
// a fn-literal / closure ExprKind. Wired here so the catalog entry has
// a canonical call site once closure-conversion lands. `site` is the
// enclosing function name; `name` is the captured outer variable.
pub fn emit_hx1100_closure_capture(sp: Span, site: string, name: string) {
    let mut b = diag_new("HX1100")
    b = diag_span(b, sp)
    b = diag_arg(b, "site", site)
    b = diag_arg(b, "name", name)
    l_diags.push(diag_emit(b))
}

// Split an "Enum::Variant" path into its halves. Returns ["Enum","Variant"].
// On miss returns [text, ""] so the caller can detect malformed paths.
fn _split_enum_path(text: string) -> [string] {
    let cs = text.chars()
    let n = len(cs)
    let mut i = 0
    while i + 1 < n {
        if cs[i] == ':' && cs[i + 1] == ':' {
            let mut left = ""
            let mut j = 0
            while j < i {
                left = left + to_string(cs[j])
                j = j + 1
            }
            let mut right = ""
            j = i + 2
            while j < n {
                right = right + to_string(cs[j])
                j = j + 1
            }
            return [left, right]
        }
        i = i + 1
    }
    return [text, ""]
}

fn _enum_named_type(enum_name: string) -> Type {
    if len(enum_name) == 0 { return _hir_empty_type() }
    return Type {
        kind: "enum:" + enum_name,
        def: _hir_miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _struct_named_type(struct_name: string) -> Type {
    if len(struct_name) == 0 { return _hir_empty_type() }
    return Type {
        kind: "struct:" + struct_name,
        def: _hir_miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// `let` text decoder (mirrors bind.hexa _let_name) — strips "mut:" prefix.
fn _hir_let_name(t: string) -> string {
    let chars = t.chars()
    let n = len(chars)
    if n >= 4 && chars[0] == 'm' && chars[1] == 'u' && chars[2] == 't' && chars[3] == ':' {
        let mut out = ""
        let mut i = 4
        while i < n {
            out = out + to_string(chars[i])
            i = i + 1
        }
        return out
    }
    return t
}

// ── Atlas binding resolver ───────────────────────────────────

fn _resolve_atlas(aref: AtlasRef, atlas: AtlasIndex) -> AtlasBinding {
    if len(aref.kind) == 0 {
        return _empty_atlas_binding()
    }
    let arr = _array_for_kind_a2h(atlas, aref.kind)
    let mut idx = -1
    let mut i = 0
    while i < len(arr) {
        let n = arr[i]
        if n.id == aref.id {
            idx = i
            break
        }
        i = i + 1
    }
    return AtlasBinding {
        ref_kind: aref.kind,
        id: aref.id,
        atlas_index: idx,
        atlas_hash: atlas.hash
    }
}

fn _array_for_kind_a2h(atlas: AtlasIndex, kind: string) -> array {
    if kind == "P" { return atlas.p_nodes }
    if kind == "C" { return atlas.c_nodes }
    if kind == "L" { return atlas.l_nodes }
    if kind == "E" { return atlas.e_nodes }
    return []
}

fn _atlas_kind_type(rk: string) -> Type {
    if len(rk) == 0 { return _hir_empty_type() }
    return Type {
        kind: "atlas_" + rk,
        def: _hir_miss_def_id(),
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// ── Numeric promotion helper for binops (same-kind passthrough) ──

fn _hir_is_numeric(t: Type) -> bool {
    if t.kind == "i8"  { return true }
    if t.kind == "i16" { return true }
    if t.kind == "i32" { return true }
    if t.kind == "i64" { return true }
    if t.kind == "f32" { return true }
    if t.kind == "f64" { return true }
    return false
}

fn _hir_is_compare_op(op: string) -> bool {
    if op == "==" { return true }
    if op == "!=" { return true }
    if op == "<"  { return true }
    if op == "<=" { return true }
    if op == ">"  { return true }
    if op == ">=" { return true }
    return false
}

// ── Expr lowering core ───────────────────────────────────────
//
// Returns (HExpr, updated scope). Stage0 has no by-ref structs, so we
// thread scope through. Pure tree shape — every AST Expr → one HExpr.

pub struct LowerResult {
    expr: HExpr,
    sc: LowerScope
}

fn _mk_hexpr(kind: string, sp: Span, typ: Type, text: string,
             children: [HExpr], atlas: AtlasBinding, def: DefId) -> HExpr {
    return HExpr {
        kind: kind,
        span: sp,
        typ: typ,
        text: text,
        children: children,
        atlas: atlas,
        def: def
    }
}

// ── C19: for-loop AST desugar helpers ────────────────────────
// Build synthetic AST Expr nodes; existing `_lower_expr` cases then
// handle scope plumbing, def-ids, and type fall-throughs uniformly.

fn _empty_atlas_ref(sp: Span) -> AtlasRef {
    return AtlasRef { kind: "", id: "", span: sp }
}

fn _mk_ast_ident(name: string, sp: Span) -> Expr {
    return Expr {
        kind: ExprKind::Ident,
        span: sp,
        text: name,
        children: [],
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_lit_int(text: string, sp: Span) -> Expr {
    return Expr {
        kind: ExprKind::LiteralInt,
        span: sp,
        text: text,
        children: [],
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_let(name: string, is_mut: bool, rhs: Expr, sp: Span) -> Expr {
    let mut t = name
    if is_mut { t = "mut:" + name }
    let mut kids: [Expr] = []
    kids.push(rhs)
    return Expr {
        kind: ExprKind::Let,
        span: sp,
        text: t,
        children: kids,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_binop(op: string, l: Expr, r: Expr, sp: Span) -> Expr {
    let mut kids: [Expr] = []
    kids.push(l)
    kids.push(r)
    return Expr {
        kind: ExprKind::BinOp,
        span: sp,
        text: op,
        children: kids,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_assign(op: string, l: Expr, r: Expr, sp: Span) -> Expr {
    let mut kids: [Expr] = []
    kids.push(l)
    kids.push(r)
    return Expr {
        kind: ExprKind::Assign,
        span: sp,
        text: op,
        children: kids,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_call1(callee_name: string, arg: Expr, sp: Span) -> Expr {
    let mut kids: [Expr] = []
    kids.push(_mk_ast_ident(callee_name, sp))
    kids.push(arg)
    return Expr {
        kind: ExprKind::Call,
        span: sp,
        text: "",
        children: kids,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_index(base: Expr, idx: Expr, sp: Span) -> Expr {
    let mut kids: [Expr] = []
    kids.push(base)
    kids.push(idx)
    return Expr {
        kind: ExprKind::Index,
        span: sp,
        text: "",
        children: kids,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_block(stmts: [Expr], sp: Span) -> Expr {
    return Expr {
        kind: ExprKind::Block,
        span: sp,
        text: "",
        children: stmts,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _mk_ast_while(cond: Expr, body: Expr, sp: Span) -> Expr {
    let mut kids: [Expr] = []
    kids.push(cond)
    kids.push(body)
    return Expr {
        kind: ExprKind::While,
        span: sp,
        text: "",
        children: kids,
        atlas_ref: _empty_atlas_ref(sp)
    }
}

fn _pick_for_iter(kids: [Expr], fallback: Expr) -> Expr {
    let n = len(kids)
    if n == 0 {
        return fallback
    }
    return kids[0]
}

fn _pick_for_body(kids: [Expr], fallback: Expr) -> Expr {
    let n = len(kids)
    if n < 2 {
        return fallback
    }
    return kids[1]
}

// C19: build the inner block of the desugared for-loop.
// Splices body-as-block children inline to avoid an extra scope frame;
// otherwise wraps the body expr as a single stmt.
fn _build_for_body(bind_var: Expr, body_e: Expr, inc: Expr) -> [Expr] {
    let mut inner: [Expr] = []
    inner.push(bind_var)
    let body_k = body_e.kind
    let is_blk = _hir_is_block_kind(body_k)
    if is_blk == false {
        inner.push(body_e)
        inner.push(inc)
        return inner
    }
    let mut j = 0
    while j < len(body_e.children) {
        inner.push(body_e.children[j])
        j = j + 1
    }
    inner.push(inc)
    return inner
}

// C19: desugar `for x in iter { body }` to an index-based while loop:
//
//   block {
//       let __for_it_<n>  = <iter>
//       let mut __for_idx_<n> = 0
//       while __for_idx_<n> < len(__for_it_<n>) {
//           let <x> = __for_it_<n>[__for_idx_<n>]
//           <body...>
//           __for_idx_<n> = __for_idx_<n> + 1
//       }
//   }
//
// Stage0 has no iterator protocol — arbitrary-iter exprs (range objects,
// custom generators) compile to MIR that type-checks wrong downstream.
// Accepted for the common range-or-array case.
// TODO(C19-followup): wire to a real `next()` protocol when it lands.
fn _desugar_for(e: Expr) -> Expr {
    let sp = e.span
    let loop_var = e.text
    let iter_e = _pick_for_iter(e.children, _mk_ast_ident(loop_var, sp))
    let body_e = _pick_for_body(e.children, _mk_ast_block([], sp))
    let uid = _next_for_uid()
    let it_name  = "__for_it_"  + to_string(uid)
    let idx_name = "__for_idx_" + to_string(uid)
    let let_it = _mk_ast_let(it_name, false, iter_e, sp)
    let let_idx = _mk_ast_let(idx_name, true, _mk_ast_lit_int("0", sp), sp)
    let cond = _mk_ast_binop("<",
        _mk_ast_ident(idx_name, sp),
        _mk_ast_call1("len", _mk_ast_ident(it_name, sp), sp), sp)
    let bind_var = _mk_ast_let(loop_var, false,
        _mk_ast_index(_mk_ast_ident(it_name, sp),
            _mk_ast_ident(idx_name, sp), sp), sp)
    let inc = _mk_ast_assign("=", _mk_ast_ident(idx_name, sp),
        _mk_ast_binop("+", _mk_ast_ident(idx_name, sp),
            _mk_ast_lit_int("1", sp), sp), sp)
    let inner = _build_for_body(bind_var, body_e, inc)
    let while_e = _mk_ast_while(cond, _mk_ast_block(inner, sp), sp)
    let mut outer: [Expr] = []
    outer.push(let_it)
    outer.push(let_idx)
    outer.push(while_e)
    return _mk_ast_block(outer, sp)
}

fn _lower_expr(e: Expr, atlas: AtlasIndex, sc: LowerScope) -> LowerResult {
    let k = e.kind
    let kind_tag = _expr_kind_tag(k)

    // ── literals ────────────────────────────────────────────
    if _hir_is_lit_int_kind(k) {
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_i64(), e.text,
                          [], _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }
    if _is_lit_float_kind(k) {
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_f64(), e.text,
                          [], _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }
    if _is_lit_string_kind(k) {
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_string(), e.text,
                          [], _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }
    if _is_lit_bool_kind(k) {
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_bool(), e.text,
                          [], _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }
    if _is_lit_char_kind(k) {
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_char(), e.text,
                          [], _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }

    // ── ident: resolve DefId via inline scope ───────────────
    if _hir_is_ident_kind(k) {
        let b = _lookup_in_scope(sc, e.text)
        let def = b.def
        let mut t = b.typ
        if len(t.kind) == 0 { t = _hir_empty_type() }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          [], _empty_atlas_binding(), def)
        return LowerResult { expr: h, sc: sc }
    }

    // ── atlas ref: resolve binding ──────────────────────────
    if _is_atlas_kind(k) {
        let ab = _resolve_atlas(e.atlas_ref, atlas)
        let t = _atlas_kind_type(e.atlas_ref.kind)
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          [], ab, _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }

    // ── binop: type from operand types (numeric promotion same-kind) ──
    if _hir_is_binop_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_empty_type()
        if _hir_is_compare_op(e.text) {
            t = _hir_t_bool()
        } else if len(kids) >= 2 {
            let lt = kids[0].typ
            let rt = kids[1].typ
            if _hir_is_numeric(lt) && _hir_is_numeric(rt) && lt.kind == rt.kind {
                t = lt
            } else if len(lt.kind) > 0 && lt.kind != "?" {
                t = lt
            } else {
                t = rt
            }
        } else if len(kids) == 1 {
            t = kids[0].typ
        }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── unop: type from operand ─────────────────────────────
    if _hir_is_unop_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_empty_type()
        if len(kids) > 0 { t = kids[0].typ }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── call: type from callee fn ret ───────────────────────
    if _is_call_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_empty_type()
        let mut callee_def = _hir_miss_def_id()
        if len(kids) > 0 {
            let callee = kids[0]
            callee_def = callee.def
            let ct = callee.typ
            if ct.kind == "fn" && len(ct.ret) > 0 {
                t = ct.ret[0]
            }
        }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), callee_def)
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── block: type = last child's type, opens a scope frame ──
    if _hir_is_block_kind(k) {
        let mut new_sc = _push_frame(sc)
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_t_unit()
        if len(kids) > 0 {
            t = kids[len(kids) - 1].typ
        }
        new_sc = _pop_frame(new_sc)
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── if: type = then-branch type ─────────────────────────
    if _is_if_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_t_unit()
        if len(kids) >= 2 { t = kids[1].typ }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── while: always unit ─────────────────────────────────
    if _is_while_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_unit(), e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── return: unit (control-flow), child carries return value ──
    if _hir_is_return_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_unit(), e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── let: lower RHS first, then bind. Type = unit (statement-shaped). ──
    if _is_let_expr_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let nm = _hir_let_name(e.text)
        if len(nm) > 0 {
            let mut rhs_t = _hir_empty_type()
            if len(kids) > 0 { rhs_t = kids[0].typ }
            new_sc = _define_in_scope(new_sc, nm, rhs_t)
        }
        let h = _mk_hexpr(kind_tag, e.span, _hir_t_unit(), e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── match: type = first arm body type ───────────────────
    if _hir_is_match_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        // children: [scrut, pat0, body0, pat1, body1, ...]
        // Lower scrutinee first, then each pat/body in a fresh frame so any
        // pattern-bound idents live only within the arm body.
        if len(e.children) >= 1 {
            let r = _lower_expr(e.children[0], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
        }
        let mut idx = 1
        let mut first_body_t = _hir_empty_type()
        let mut have_first = false
        while idx + 1 < len(e.children) {
            let pat = e.children[idx]
            let body = e.children[idx + 1]
            // arm scope
            let mut arm_sc = _push_frame(new_sc)
            // bind ident-pattern names so body lookups can see them
            if _hir_is_ident_kind(pat.kind) && len(pat.text) > 0 && pat.text != "_" {
                arm_sc = _define_in_scope(arm_sc, pat.text, _hir_empty_type())
            }
            let pr = _lower_expr(pat, atlas, arm_sc)
            arm_sc = pr.sc
            let br = _lower_expr(body, atlas, arm_sc)
            kids.push(pr.expr)
            kids.push(br.expr)
            arm_sc = br.sc
            new_sc = _pop_frame(arm_sc)
            if !have_first {
                first_body_t = br.expr.typ
                have_first = true
            }
            idx = idx + 2
        }
        let mut t = _hir_t_unit()
        if have_first { t = first_body_t }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }

    // ── Stage1 Gap 14 idiom handlers (struct_lit / enum_path /
    // field / index / for / assign / wildcard). Each branch lowers
    // children explicitly so downstream hir_to_mir can emit the
    // matching STMT_ASSIGN / STMT_BR_COND patterns. ────────────
    if _hir_is_struct_lit_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let f = e.children[i]
            if _hir_is_ident_kind(f.kind) && len(f.children) > 0 {
                let vr = _lower_expr(f.children[0], atlas, new_sc)
                new_sc = vr.sc
                let mut field_kids: [HExpr] = []
                field_kids.push(vr.expr)
                let fh = _mk_hexpr("field_lit", f.span, vr.expr.typ, f.text,
                                   field_kids, _empty_atlas_binding(),
                                   _hir_miss_def_id())
                kids.push(fh)
            } else {
                let vr = _lower_expr(f, atlas, new_sc)
                new_sc = vr.sc
                kids.push(vr.expr)
            }
            i = i + 1
        }
        let t = _struct_named_type(e.text)
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }
    if _hir_is_enum_path_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let parts = _split_enum_path(e.text)
        let t = _enum_named_type(parts[0])
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }
    if _hir_is_field_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        if len(e.children) > 0 {
            let r = _lower_expr(e.children[0], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
        }
        let h = _mk_hexpr(kind_tag, e.span, _hir_empty_type(), e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }
    if _hir_is_index_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_empty_type()
        if len(kids) > 0 { t = kids[0].typ }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }
    if _hir_is_for_kind(k) {
        // C19 (stage1 punch list v2): desugar `for x in iter { body }` into
        // an explicit index-based while loop BEFORE hir_to_mir ever sees a
        // "for" node. hir_to_mir lacks a `for` handler and would otherwise
        // fall through to generic-recurse, producing MIR with no loop CFG.
        //
        // Stage0 has no iterator protocol, so we lower to the common
        // index-into-array form:
        //
        //   block {
        //       let __for_it_<n>  = <iter>
        //       let mut __for_idx_<n> = 0
        //       while __for_idx_<n> < len(__for_it_<n>) {
        //           let <x> = __for_it_<n>[__for_idx_<n>]
        //           <body>
        //           __for_idx_<n> = __for_idx_<n> + 1
        //       }
        //   }
        //
        // TODO(C19-followup): once an iterator protocol lands
        // (`iter.next() -> Option<T>` or similar), desugar arbitrary-expr
        // iteration to that shape instead. Today any non-indexable iterable
        // (e.g. a custom generator) compiles to MIR that will type-check
        // wrong downstream — accepted for stage0.
        let desugared = _desugar_for(e)
        return _lower_expr(desugared, atlas, sc)
    }
    if _hir_is_assign_kind(k) {
        let mut new_sc = sc
        let mut kids: [HExpr] = []
        let mut i = 0
        while i < len(e.children) {
            let r = _lower_expr(e.children[i], atlas, new_sc)
            kids.push(r.expr)
            new_sc = r.sc
            i = i + 1
        }
        let mut t = _hir_t_unit()
        if len(kids) >= 2 { t = kids[1].typ }
        let h = _mk_hexpr(kind_tag, e.span, t, e.text,
                          kids, _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: new_sc }
    }
    if _hir_is_wildcard_kind(k) {
        let h = _mk_hexpr(kind_tag, e.span, _hir_empty_type(), e.text,
                          [], _empty_atlas_binding(), _hir_miss_def_id())
        return LowerResult { expr: h, sc: sc }
    }

    // ── Default — generic recurse for any kind not handled above. ──
    // Generic recurse — every child lowered in order.
    let mut new_sc = sc
    let mut kids: [HExpr] = []
    let mut i = 0
    while i < len(e.children) {
        let r = _lower_expr(e.children[i], atlas, new_sc)
        kids.push(r.expr)
        new_sc = r.sc
        i = i + 1
    }
    let h = _mk_hexpr(kind_tag, e.span, _hir_empty_type(), e.text,
                      kids, _empty_atlas_binding(), _hir_miss_def_id())
    return LowerResult { expr: h, sc: new_sc }
}

// ── Module-level pre-pass: mint DefIds for items, build top env ─

fn _hir_signature_type(it: Item) -> Type {
    let mut params: [Type] = []
    let mut i = 0
    while i < len(it.params) {
        params.push(_hir_lower_type_ref(it.params[i].typ))
        i = i + 1
    }
    let mut ret: [Type] = []
    let r = _hir_lower_type_ref(it.return_type)
    ret.push(r)
    return Type {
        kind: "fn",
        def: _hir_miss_def_id(),
        args: params,
        ret: ret,
        domain: "",
        unit: ""
    }
}

fn _hir_struct_type(it: Item, def: DefId) -> Type {
    let mut fields: [Type] = []
    let mut i = 0
    while i < len(it.params) {
        fields.push(_hir_lower_type_ref(it.params[i].typ))
        i = i + 1
    }
    return Type {
        kind: "struct",
        def: def,
        args: fields,
        ret: [],
        domain: "",
        unit: ""
    }
}

fn _hir_enum_type(def: DefId) -> Type {
    return Type {
        kind: "enum",
        def: def,
        args: [],
        ret: [],
        domain: "",
        unit: ""
    }
}

// Return a HItem placeholder body (empty Block-like HExpr) used for items
// that have no AST body (struct/enum/import).
fn _empty_hbody(sp: Span) -> HExpr {
    return HExpr {
        kind: "block",
        span: sp,
        typ: _hir_t_unit(),
        text: "",
        children: [],
        atlas: _empty_atlas_binding(),
        def: _hir_miss_def_id()
    }
}

// ── Item lowering ────────────────────────────────────────────

fn _lower_item(it: Item, def: DefId, atlas: AtlasIndex,
               module_scope: LowerScope) -> HItem {
    let kind_tag = _item_kind_tag(it.kind)

    if _hir_is_fn_item(it.kind) {
        // Build a function-local scope: module env + params.
        let mut fn_sc = _push_frame(module_scope)
        let mut sig_params: [Type] = []
        let mut p = 0
        while p < len(it.params) {
            let par = it.params[p]
            let pt = _hir_lower_type_ref(par.typ)
            sig_params.push(pt)
            if len(par.name) > 0 {
                fn_sc = _define_in_scope(fn_sc, par.name, pt)
            }
            p = p + 1
        }
        let sig_ret = _hir_lower_type_ref(it.return_type)
        let r = _lower_expr(it.body, atlas, fn_sc)
        return HItem {
            kind: kind_tag,
            def: def,
            name: it.name,
            span: it.span,
            annotations: it.annotations,
            sig_params: sig_params,
            sig_return: sig_ret,
            body: r.expr,
            is_pub: it.is_pub,
            discoverable: false,
            proof_hash: "",
            verifier_version: ""
        }
    }

    if _hir_is_let_item(it.kind) {
        let declared = _hir_lower_type_ref(it.return_type)
        let r = _lower_expr(it.body, atlas, module_scope)
        let mut sig_ret = declared
        if len(declared.kind) == 0 || declared.kind == "?" || declared.kind == "unit" {
            // Prefer RHS type if declared was empty/unknown.
            if len(r.expr.typ.kind) > 0 && r.expr.typ.kind != "?" {
                sig_ret = r.expr.typ
            }
        }
        return HItem {
            kind: kind_tag,
            def: def,
            name: it.name,
            span: it.span,
            annotations: it.annotations,
            sig_params: [],
            sig_return: sig_ret,
            body: r.expr,
            is_pub: it.is_pub,
            discoverable: false,
            proof_hash: "",
            verifier_version: ""
        }
    }

    if _hir_is_struct_item(it.kind) {
        let mut fields: [Type] = []
        let mut i = 0
        while i < len(it.params) {
            fields.push(_hir_lower_type_ref(it.params[i].typ))
            i = i + 1
        }
        return HItem {
            kind: kind_tag,
            def: def,
            name: it.name,
            span: it.span,
            annotations: it.annotations,
            sig_params: fields,
            sig_return: _hir_struct_type(it, def),
            body: _empty_hbody(it.span),
            is_pub: it.is_pub,
            discoverable: false,
            proof_hash: "",
            verifier_version: ""
        }
    }

    if _hir_is_enum_item(it.kind) {
        return HItem {
            kind: kind_tag,
            def: def,
            name: it.name,
            span: it.span,
            annotations: it.annotations,
            sig_params: [],
            sig_return: _hir_enum_type(def),
            body: _empty_hbody(it.span),
            is_pub: it.is_pub,
            discoverable: false,
            proof_hash: "",
            verifier_version: ""
        }
    }

    // Import — minimal HItem; no body.
    return HItem {
        kind: kind_tag,
        def: def,
        name: it.name,
        span: it.span,
        annotations: it.annotations,
        sig_params: [],
        sig_return: _hir_t_unit(),
        body: _empty_hbody(it.span),
        is_pub: it.is_pub,
        discoverable: false,
        proof_hash: "",
        verifier_version: ""
    }
}

// ── Public entry ─────────────────────────────────────────────

pub fn lower(module: Module, atlas: AtlasIndex) -> HModule {
    // Reset the per-invocation diag buffer so successive lower() calls in
    // the same process do not leak HX1100 emissions across compilations.
    l_diags = []
    // C19: reset for-desugar uid counter so output is determinate.
    _for_uid = 0

    // Pre-pass: mint DefIds + collect module-level type bindings so that
    // intra-module references (calls, struct-of-fields, etc.) can resolve.
    let mut module_sc = _new_scope(module.file)
    module_sc = _push_frame(module_sc)

    let mut item_defs: [DefId] = []
    let mut idx: i64 = 0
    let mut i = 0
    while i < len(module.items) {
        let it = module.items[i]
        let def = DefId { module: module.file, index: idx }
        item_defs.push(def)
        if _is_import_item(it.kind) {
            // Imports are not bound as defs in scope.
        } else if _hir_is_fn_item(it.kind) {
            module_sc = _define_with_def(module_sc, it.name, def, _hir_signature_type(it))
        } else if _hir_is_struct_item(it.kind) {
            module_sc = _define_with_def(module_sc, it.name, def, _hir_struct_type(it, def))
        } else if _hir_is_enum_item(it.kind) {
            module_sc = _define_with_def(module_sc, it.name, def, _hir_enum_type(def))
        } else if _hir_is_let_item(it.kind) {
            module_sc = _define_with_def(module_sc, it.name, def, _hir_lower_type_ref(it.return_type))
        }
        idx = idx + 1
        i = i + 1
    }

    // Main pass: lower each item using the populated module scope.
    let mut hitems: [HItem] = []
    let mut k = 0
    while k < len(module.items) {
        let it = module.items[k]
        let def = item_defs[k]
        let h = _lower_item(it, def, atlas, module_sc)
        hitems.push(h)
        k = k + 1
    }

    return HModule {
        file: module.file,
        items: hitems
    }
}
