// HEXA Native Compiler — PR-C piece 3 falsifier
//
// Verifies that an AST `Expr` with `kind == Let` and a non-empty
// `annotations` list lowers to a HIR `HExpr` whose `annotations` field
// PRESERVES the annotation set.

import "../parse/ast.hexa"
import "../ir/hir.hexa"
import "../lex/tokens.hexa"
import "../atlas/static_index.hexa"
import "./ast_to_hir.hexa"

fn _sp() -> Span { return Span { file: "", line: 0, col: 0, len: 0 } }

fn _empty_atlas_ref() -> AtlasRef {
    return AtlasRef { kind: "", id: "", span: _sp() }
}

fn _empty_type_ref() -> TypeRef {
    return TypeRef { kind: "", name: "", args: [], span: _sp() }
}

fn _print(name: string, ok: bool) {
    if ok { println("  PASS " + name) } else { println("  FAIL " + name) }
}

fn case_let_preserves_anns() {
    // Build an AST Module containing:
    //   fn k() -> i64 { @shared let sm = 0; return 0 }
    // and lower it. Find the Let in the body block and check annotations.

    let shared_ann = Annotation { name: "shared", args: [], span: _sp() }

    let rhs_lit = Expr {
        kind: ExprKind::LiteralInt,
        span: _sp(),
        text: "0",
        annotations: [],
        children: [],
        atlas_ref: _empty_atlas_ref()
    }

    let let_expr = Expr {
        kind: ExprKind::Let,
        span: _sp(),
        text: "sm",
        annotations: [shared_ann],
        children: [rhs_lit],
        atlas_ref: _empty_atlas_ref()
    }

    let ret_lit = Expr {
        kind: ExprKind::LiteralInt,
        span: _sp(),
        text: "0",
        annotations: [],
        children: [],
        atlas_ref: _empty_atlas_ref()
    }
    let ret_expr = Expr {
        kind: ExprKind::Return,
        span: _sp(),
        text: "",
        annotations: [],
        children: [ret_lit],
        atlas_ref: _empty_atlas_ref()
    }

    let body = Expr {
        kind: ExprKind::Block,
        span: _sp(),
        text: "",
        annotations: [],
        children: [let_expr, ret_expr],
        atlas_ref: _empty_atlas_ref()
    }

    let ret_type = TypeRef { kind: "i64", name: "i64", args: [], span: _sp() }

    let item = Item {
        kind: ItemKind::Fn,
        name: "k",
        span: _sp(),
        annotations: [],
        params: [],
        return_type: ret_type,
        body: body,
        is_pub: false
    }

    let m = Module { file: "<inline>", items: [item], imports: [] }
    let hm = lower(m, static_atlas())

    let mut ok_one_item = (len(hm.items) == 1)
    _print("HIR has 1 item", ok_one_item)

    let mut found_let = false
    let mut ok_anns_count = false
    let mut ok_anns_name = false
    if len(hm.items) > 0 {
        let hbody = hm.items[0].body
        let mut i = 0
        while i < len(hbody.children) {
            let c = hbody.children[i]
            if c.kind == "let" {
                found_let = true
                if len(c.annotations) == 1 {
                    ok_anns_count = true
                    if c.annotations[0].name == "shared" {
                        ok_anns_name = true
                    }
                }
                break
            }
            i = i + 1
        }
    }
    _print("HIR has Let in body block", found_let)
    _print("HIR Let has 1 annotation", ok_anns_count)
    _print("HIR Let annotation name == \"shared\"", ok_anns_name)
}

println("══════════════════════════════════════════════")
println("  HEXA — ast_to_hir PR-C piece 3 falsifier")
println("══════════════════════════════════════════════")
case_let_preserves_anns()
println("══════════════════════════════════════════════")
println("  done.")
