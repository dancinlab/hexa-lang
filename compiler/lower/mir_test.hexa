// HEXA Native Compiler — Phase B5 / Lower: HIR → MIR smoke test
//
// @version 0.1.0
// @capabilities [pure]
//
// Hand-builds three small HModules, runs lower_hir, and prints a
// summary of each produced MFunc. Exits 0 only if every assertion holds.
//
// Cases:
//   (a) fn add(x:Int, y:Int) -> Int { return x + y }
//       expect: 1 block, ≥3 locals, last stmt = STMT_RETURN, contains BINOP.
//   (b) fn abs(x: Int) -> Int { if x < 0 { return -x } return x }
//       expect: ≥3 blocks, entry has STMT_BR_COND with both target ids set.
//   (c) fn loop_sum() { let mut i = 0; while i < 10 { i = i + 1 } }
//       expect: header + body + after blocks (≥4 blocks), SSA-renamed locals
//       on each i = i + 1 (multiple Locals share name_hint "i").
//
// Run:
//   hexa run compiler/lower/mir_test.hexa

import "../parse/ast.hexa"
import "../ir/hir.hexa"
import "../ir/mir.hexa"
import "../lex/tokens.hexa"
import "./hir_to_mir.hexa"

// ── HExpr/HItem builders ─────────────────────────────────────

fn _span(file: string, line: i64, col: i64, length: i64) -> Span {
    return Span { file: file, line: line, col: col, len: length }
}

fn _empty_span() -> Span { return _span("", 0, 0, 0) }

fn _miss_def() -> DefId { return DefId { module: "", index: -1 } }

fn _empty_atlas_binding() -> AtlasBinding {
    return AtlasBinding { ref_kind: "", id: "", atlas_index: -1, atlas_hash: "" }
}

fn _t(kind: string) -> Type {
    return Type {
        kind: kind, def: _miss_def(),
        args: [], ret: [],
        domain: "", unit: ""
    }
}

fn _t_i64()  -> Type { return _t("i64") }
fn _t_bool() -> Type { return _t("bool") }
fn _t_unit() -> Type { return _t("unit") }
fn _t_f16()  -> Type { return _t("f16") }
fn _t_bf16() -> Type { return _t("bf16") }
fn _t_f32()  -> Type { return _t("f32") }

fn _hexpr(kind: string, typ: Type, text: string, kids: [HExpr]) -> HExpr {
    return HExpr {
        kind: kind,
        span: _empty_span(),
        typ: typ,
        text: text,
        children: kids,
        atlas: _empty_atlas_binding(),
        def: _miss_def()
    }
}

fn _ident(name: string, typ: Type) -> HExpr {
    return _hexpr("ident", typ, name, [])
}

fn _lit_int(text: string) -> HExpr {
    return _hexpr("literal_int", _t_i64(), text, [])
}

fn _binop(op: string, lhs: HExpr, rhs: HExpr, typ: Type) -> HExpr {
    let mut k = []
    k.push(lhs)
    k.push(rhs)
    return _hexpr("binop", typ, op, k)
}

fn _unop(op: string, x: HExpr, typ: Type) -> HExpr {
    let mut k = []
    k.push(x)
    return _hexpr("unop", typ, op, k)
}

fn _ret(value: HExpr) -> HExpr {
    let mut k = []
    k.push(value)
    return _hexpr("return", _t_unit(), "", k)
}

fn _block(kids: [HExpr]) -> HExpr {
    return _hexpr("block", _t_unit(), "", kids)
}

fn _hif(cond: HExpr, then_branch: HExpr) -> HExpr {
    let mut k = []
    k.push(cond)
    k.push(then_branch)
    return _hexpr("if", _t_unit(), "", k)
}

fn _hwhile(cond: HExpr, body: HExpr) -> HExpr {
    let mut k = []
    k.push(cond)
    k.push(body)
    return _hexpr("while", _t_unit(), "", k)
}

fn _hlet(name: string, rhs: HExpr) -> HExpr {
    let mut k = []
    k.push(rhs)
    return _hexpr("let", _t_unit(), name, k)
}

fn _hassign(lhs: HExpr, rhs: HExpr) -> HExpr {
    let mut k = []
    k.push(lhs)
    k.push(rhs)
    return _hexpr("assign", _t_unit(), "", k)
}

// HItem builder with optional param_names annotation.
fn _hfn(name: string, param_names: [string], param_types: [Type], ret: Type, body: HExpr) -> HItem {
    let mut anns: [Annotation] = []
    let mut name_args: [Expr] = []
    let mut p = 0
    while p < len(param_names) {
        name_args.push(Expr {
            kind: ExprKind::Ident,
            span: _empty_span(),
            text: param_names[p],
            children: [],
            atlas_ref: AtlasRef { kind: "", id: "", span: _empty_span() }
        })
        p = p + 1
    }
    anns.push(Annotation { name: "param_names", args: name_args, span: _empty_span() })
    return HItem {
        kind: "ITEM_FN",
        def: _miss_def(),
        name: name,
        span: _empty_span(),
        annotations: anns,
        sig_params: param_types,
        sig_return: ret,
        body: body,
        is_pub: false,
        discoverable: false,
        proof_hash: "",
        verifier_version: ""
    }
}

// ── Pretty-print ─────────────────────────────────────────────

fn _kind_count(blocks: [Block], target: string) -> i64 {
    let mut n: i64 = 0
    let mut i = 0
    while i < len(blocks) {
        let b = blocks[i]
        let mut j = 0
        while j < len(b.stmts) {
            if b.stmts[j].kind == target { n = n + 1 }
            j = j + 1
        }
        i = i + 1
    }
    return n
}

fn _total_stmts(blocks: [Block]) -> i64 {
    let mut n: i64 = 0
    let mut i = 0
    while i < len(blocks) {
        n = n + len(blocks[i].stmts)
        i = i + 1
    }
    return n
}

fn _last_stmt_kind(blocks: [Block]) -> string {
    if len(blocks) == 0 { return "" }
    let last = blocks[len(blocks) - 1]
    if len(last.stmts) == 0 { return "" }
    return last.stmts[len(last.stmts) - 1].kind
}

fn _print_mfunc_summary(label: string, mf: MFunc) {
    let total = _total_stmts(mf.blocks)
    let n_assign = _kind_count(mf.blocks, STMT_ASSIGN)
    let n_binop  = _kind_count(mf.blocks, STMT_BINOP)
    let n_unop   = _kind_count(mf.blocks, STMT_UNOP)
    let n_call   = _kind_count(mf.blocks, STMT_CALL)
    let n_ret    = _kind_count(mf.blocks, STMT_RETURN)
    let n_br     = _kind_count(mf.blocks, STMT_BR)
    let n_brc    = _kind_count(mf.blocks, STMT_BR_COND)
    println("  " + label + " " + mf.name +
            " blocks=" + to_string(len(mf.blocks)) +
            " locals=" + to_string(len(mf.locals)) +
            " stmts=" + to_string(total) +
            " entry=" + to_string(mf.entry_block) +
            " arena_root=" + to_string(mf.arena_root))
    println("    kinds: assign=" + to_string(n_assign) +
            " binop=" + to_string(n_binop) +
            " unop=" + to_string(n_unop) +
            " call=" + to_string(n_call) +
            " return=" + to_string(n_ret) +
            " br=" + to_string(n_br) +
            " br_cond=" + to_string(n_brc))
    let mut i = 0
    while i < len(mf.blocks) {
        let b = mf.blocks[i]
        let mut succ = ""
        let mut k = 0
        while k < len(b.succs) {
            if k > 0 { succ = succ + "," }
            succ = succ + to_string(b.succs[k])
            k = k + 1
        }
        println("    blk[" + to_string(b.id) + "] stmts=" + to_string(len(b.stmts)) +
                " preds=" + to_string(len(b.preds)) +
                " succs=[" + succ + "]")
        i = i + 1
    }
}

// ── Cases ────────────────────────────────────────────────────

// RFC-074 Phase 3 helper — hand-build an EnumPath HExpr with N payload args.
// `path` is the full `Enum::Variant` string the producer/consumer hash on
// (matches the `_path_hash(text)` MIR tag-compare contract in this file's
// L1800 + L2186). `args` are the lowered payload child HExpr's.
fn _enum_path(path: string, args: [HExpr], typ: Type) -> HExpr {
    return _hexpr("enum_path", typ, path, args)
}

// Helper — hand-build a match `enum_path` PATTERN with N positional binders
// (each binder is an `ident` HExpr whose text is the destructured-name).
fn _enum_pat(path: string, binder_names: [string], typ: Type) -> HExpr {
    let mut binders: [HExpr] = []
    let mut i = 0
    while i < len(binder_names) {
        binders.push(_ident(binder_names[i], _t_i64()))
        i = i + 1
    }
    return _hexpr("enum_path", typ, path, binders)
}

// (a) fn add(x:Int, y:Int) -> Int { return x + y }
fn _build_case_a() -> HModule {
    let x = _ident("x", _t_i64())
    let y = _ident("y", _t_i64())
    let plus = _binop("+", x, y, _t_i64())
    let body = _block([_ret(plus)])
    let mut pn: [string] = []
    pn.push("x")
    pn.push("y")
    let mut pt: [Type] = []
    pt.push(_t_i64())
    pt.push(_t_i64())
    let it = _hfn("add", pn, pt, _t_i64(), body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_a.hexa", items: items }
}

// (b) fn abs(x: Int) -> Int { if x < 0 { return -x } return x }
fn _build_case_b() -> HModule {
    let x_for_cond = _ident("x", _t_i64())
    let zero = _lit_int("0")
    let cond = _binop("<", x_for_cond, zero, _t_bool())
    let x_for_neg = _ident("x", _t_i64())
    let neg_x = _unop("-", x_for_neg, _t_i64())
    let then_blk = _block([_ret(neg_x)])
    let if_e = _hif(cond, then_blk)
    let x_tail = _ident("x", _t_i64())
    let body = _block([if_e, _ret(x_tail)])
    let mut pn: [string] = []
    pn.push("x")
    let mut pt: [Type] = []
    pt.push(_t_i64())
    let it = _hfn("abs", pn, pt, _t_i64(), body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_b.hexa", items: items }
}

// (c) fn loop_sum() { let mut i = 0; while i < 10 { i = i + 1 } }
fn _build_case_c() -> HModule {
    let init = _lit_int("0")
    let let_i = _hlet("mut:i", init)
    let i_in_cond = _ident("i", _t_i64())
    let ten = _lit_int("10")
    let cond = _binop("<", i_in_cond, ten, _t_bool())
    let i_lhs = _ident("i", _t_i64())
    let i_rhs = _ident("i", _t_i64())
    let one = _lit_int("1")
    let inc = _binop("+", i_rhs, one, _t_i64())
    let assign = _hassign(i_lhs, inc)
    let body_blk = _block([assign])
    let while_e = _hwhile(cond, body_blk)
    let body = _block([let_i, while_e])
    let it = _hfn("loop_sum", [], [], _t_unit(), body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_c.hexa", items: items }
}

// (d) RFC-074 Phase 3 + Phase 5 — multi-arg enum payload survives HIR→MIR.
//
//     fn _ev_d() {
//         let e = Event::Click(7, 9)
//         match e { Event::Click(x, y) -> { return x + y } }
//     }
//
// MIR shape assertions (Phase 5 storage swap — arity >= 2 packs payload
// cells into a single contiguous array under one "__payload" map slot):
//   1. construction site emits ONE array_lit STMT_ASSIGN with the 2
//      payload elem operands (the contiguous payload array), AND ONE
//      enum_ctor STMT_ASSIGN whose args contain the const_str "__tag"
//      AND const_str "__payload" keys (no longer "__p0"/"__p1").
//   2. match-arm binder destructure emits ONE `field` extract on
//      const_str "__payload" (single map lookup), AND TWO `index`
//      extracts on const_int 0 and const_int 1 — one binder per
//      ordinal. Pre-Phase-3 the binders were single-slot (op="payload"
//      with no key) so arity≥2 silently collapsed; Phase-3 fan-out was
//      per-slot "__p<i>"; Phase 5 collapses N map keys into 1 + N array
//      indices.
fn _build_case_d() -> HModule {
    // RHS: Event::Click(7, 9) — enum_path with 2 payload arg children
    let mut click_args: [HExpr] = []
    click_args.push(_lit_int("7"))
    click_args.push(_lit_int("9"))
    let click_ctor = _enum_path("Event::Click", click_args, _t("enum:Event"))
    let let_e = _hlet("e", click_ctor)

    // match e { Event::Click(x, y) -> return x + y }
    let scrut = _ident("e", _t("enum:Event"))
    let mut bn: [string] = []
    bn.push("x")
    bn.push("y")
    let pat = _enum_pat("Event::Click", bn, _t("enum:Event"))
    let arm_body = _block([_ret(_binop("+", _ident("x", _t_i64()),
                                            _ident("y", _t_i64()),
                                            _t_i64()))])
    let mut mk: [HExpr] = []
    mk.push(scrut)
    mk.push(pat)
    mk.push(arm_body)
    let mat = _hexpr("match", _t_i64(), "", mk)

    let body = _block([let_e, mat])
    let it = _hfn("ev_d", [], [], _t_i64(), body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_d.hexa", items: items }
}

// (e) RFC 068 P2 + N57 follow-on — mixed-precision opcode synthesis.
//
//     fn f(a: <dtype>, b: <dtype>) -> <dtype> { return a <op> b }
//
// For each of (op ∈ {+, -, *, /}) × (dtype ∈ {f16, bf16, f32}) we
// expect `_op_with_precision` to synthesize `<op>_<dtype>` (e.g.
// `add_bf16`, `div_bf16`, `mul_f16`, `sub_f32`) on the resulting
// STMT_BINOP, and stamp the dst Local's `precision` field with
// `.<dtype>`. This is the HIR→MIR synthesis seam — codegen-side
// consumers (`_nvptx_binop_mnemonic`, `_nvptx_classify_local_for_stmt`,
// Metal shape-matchers) already recognise this opcode family per
// PR #170 / N41 / N51, so wiring the synthesis here UNBLOCKS the
// future flame bf16/f16 lowering path without a second pass.
//
// Honest scope (`@D g3`): this case verifies SYNTHESIS only — that
// HIR `bf16` type tag → MIR `STMT_BINOP("op_bf16")`. The parser-side
// `bf16` keyword recognition is independent (and already present in
// `check/types.hexa`); this test bypasses parsing by hand-building
// the HIR. No silicon fire.
fn _build_case_e_binop(op: string, dtype: Type) -> HModule {
    let a = _ident("a", dtype)
    let b = _ident("b", dtype)
    let expr = _binop(op, a, b, dtype)
    let body = _block([_ret(expr)])
    let mut pn: [string] = []
    pn.push("a")
    pn.push("b")
    let mut pt: [Type] = []
    pt.push(dtype)
    pt.push(dtype)
    let it = _hfn("op_e", pn, pt, dtype, body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_e.hexa", items: items }
}

// Walk a lowered MModule and return the first STMT_BINOP's op string
// + dst.precision tag (mirrors `nvptx_lower_test::_find_first_binop_*`).
fn _case_e_first_binop_op(m: MModule) -> string {
    let mut fi = 0
    while fi < len(m.funcs) {
        let mf = m.funcs[fi]
        let mut bi = 0
        while bi < len(mf.blocks) {
            let b = mf.blocks[bi]
            let mut si = 0
            while si < len(b.stmts) {
                let s = b.stmts[si]
                if s.kind == STMT_BINOP { return s.op }
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return ""
}

fn _case_e_first_binop_precision(m: MModule) -> string {
    let mut fi = 0
    while fi < len(m.funcs) {
        let mf = m.funcs[fi]
        let mut bi = 0
        while bi < len(mf.blocks) {
            let b = mf.blocks[bi]
            let mut si = 0
            while si < len(b.stmts) {
                let s = b.stmts[si]
                if s.kind == STMT_BINOP { return s.dst.precision }
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return ""
}

fn _case_e_check_pair(ok_in: bool, op: string, dtype: Type, want_op: string, want_prec: string) -> bool {
    let m = lower_hir(_build_case_e_binop(op, dtype))
    let got_op = _case_e_first_binop_op(m)
    let got_prec = _case_e_first_binop_precision(m)
    let mut ok = ok_in
    if got_op != want_op {
        println("  FAIL: case (e) " + dtype.kind + " `" + op + "` → op got `" + got_op + "`, want `" + want_op + "`")
        ok = false
    }
    if got_prec != want_prec {
        println("  FAIL: case (e) " + dtype.kind + " `" + op + "` → prec got `" + got_prec + "`, want `" + want_prec + "`")
        ok = false
    }
    if got_op == want_op && got_prec == want_prec {
        println("  OK:   case (e) " + dtype.kind + " `" + op + "` → op=`" + got_op + "` prec=`" + got_prec + "`")
    }
    return ok
}

// (f) RFC 071 P5++ — `gpu_matmul(c, a, b, M, N, K)` synthesis.
//
//     fn matmul_kernel(a, b, c, M, N, K) {
//         gpu_matmul(c, a, b, M, N, K)
//     }
//
// MIR shape assertions — the call-branch intercept in `hir_to_mir.hexa`
// must emit the synthetic STMT_LOAD + STMT_LOAD + STMT_BINOP("matmul")
// + STMT_STORE skeleton that the NVPTX `_nvptx_mfunc_is_matmul_shape`
// recogniser keys on (mirrors the ROCm + Metal lanes). We assert on
// the FIRST four stmts of the entry block (a trailing implicit
// STMT_RETURN is appended by `_lower_fn`, which the codegen
// recogniser tolerates via `len(stmts) >= 4`).
//
// HONEST SCOPE (@D g3): codegen-only HIR→MIR synthesis check. The
// NVPTX-side `_nvptx_emit_matmul_*` emit functions are silent-wiped on
// this worktree's main ancestry (N88 commit e9c89904 dropped 424
// lines from the N86 contribution). The synthesis seam is verified
// here; PTX-text + silicon-fire is BLOCKED until the parallel N99
// worktree restores the codegen lane.
fn _build_case_f(matmul_callee: string) -> HModule {
    // Body: gpu_matmul(c, a, b, M, N, K)
    let c_arg = _ident("c", _t_f32())
    let a_arg = _ident("a", _t_f16())
    let b_arg = _ident("b", _t_f16())
    let m_arg = _ident("M", _t("i32"))
    let n_arg = _ident("N", _t("i32"))
    let k_arg = _ident("K", _t("i32"))
    let callee = _ident(matmul_callee, _t_unit())
    let mut call_kids: [HExpr] = []
    call_kids.push(callee)
    call_kids.push(c_arg)
    call_kids.push(a_arg)
    call_kids.push(b_arg)
    call_kids.push(m_arg)
    call_kids.push(n_arg)
    call_kids.push(k_arg)
    let call = _hexpr("call", _t_unit(), matmul_callee, call_kids)
    let body = _block([call])

    let mut pn: [string] = []
    pn.push("a")
    pn.push("b")
    pn.push("c")
    pn.push("M")
    pn.push("N")
    pn.push("K")
    let mut pt: [Type] = []
    pt.push(_t_f16())  // a
    pt.push(_t_f16())  // b
    pt.push(_t_f32())  // c
    pt.push(_t("i32"))  // M
    pt.push(_t("i32"))  // N
    pt.push(_t("i32"))  // K
    let it = _hfn("matmul_kernel", pn, pt, _t_unit(), body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_f.hexa", items: items }
}

// _case_f_check — verify the 4-stmt matmul-shape skeleton lands at the
// start of the entry block. Each call counts the kinds of the first
// four stmts AND probes the STMT_BINOP op string for the expected
// "matmul" / "matmul_NT_a" / "matmul_NT_b" discriminator.
fn _case_f_check(ok_in: bool, callee: string, binop_op: string) -> bool {
    let m = lower_hir(_build_case_f(callee))
    let mut ok = ok_in
    let mut local_ok = true
    if len(m.funcs) != 1 {
        println("  FAIL: case (f) " + callee + " expected 1 MFunc, got " + to_string(len(m.funcs)))
        return false
    }
    let mf = m.funcs[0]
    if len(mf.blocks) == 0 {
        println("  FAIL: case (f) " + callee + " expected >=1 block, got 0")
        return false
    }
    let entry = mf.blocks[0]
    if len(entry.stmts) < 4 {
        println("  FAIL: case (f) " + callee + " expected >=4 entry stmts, got " + to_string(len(entry.stmts)))
        return false
    }
    if entry.stmts[0].kind != STMT_LOAD {
        println("  FAIL: case (f) " + callee + " stmts[0] kind got " + entry.stmts[0].kind + ", want STMT_LOAD")
        local_ok = false
    }
    if entry.stmts[1].kind != STMT_LOAD {
        println("  FAIL: case (f) " + callee + " stmts[1] kind got " + entry.stmts[1].kind + ", want STMT_LOAD")
        local_ok = false
    }
    if entry.stmts[2].kind != STMT_BINOP {
        println("  FAIL: case (f) " + callee + " stmts[2] kind got " + entry.stmts[2].kind + ", want STMT_BINOP")
        local_ok = false
    }
    if entry.stmts[2].op != binop_op {
        println("  FAIL: case (f) " + callee + " stmts[2] op got `" + entry.stmts[2].op + "`, want `" + binop_op + "`")
        local_ok = false
    }
    if entry.stmts[3].kind != STMT_STORE {
        println("  FAIL: case (f) " + callee + " stmts[3] kind got " + entry.stmts[3].kind + ", want STMT_STORE")
        local_ok = false
    }
    // Negative — there must be NO STMT_CALL with op = the gpu_matmul callee
    // (the synthesis short-circuited the generic STMT_CALL emit).
    let mut bi = 0
    while bi < len(mf.blocks) {
        let b = mf.blocks[bi]
        let mut si = 0
        while si < len(b.stmts) {
            if b.stmts[si].kind == STMT_CALL && b.stmts[si].op == callee {
                println("  FAIL: case (f) " + callee + " unexpected STMT_CALL with op=`" + callee + "` — synthesis did not short-circuit")
                local_ok = false
            }
            si = si + 1
        }
        bi = bi + 1
    }
    if local_ok {
        println("  OK:   case (f) " + callee + " → STMT_LOAD + STMT_LOAD + STMT_BINOP(`" + binop_op + "`) + STMT_STORE")
    } else {
        ok = false
    }
    return ok
}

// ── Driver ───────────────────────────────────────────────────

fn main() {
    println("══════════════════════════════════════════════")
    println("  HEXA Compiler — Lower (HIR→MIR) Smoke Test (B5)")
    println("══════════════════════════════════════════════")

    let mut ok = true

    // (a)
    println("")
    println("── (a) add(x,y) = x + y ──")
    let m_a = lower_hir(_build_case_a())
    if len(m_a.funcs) != 1 {
        println("  FAIL: case (a) expected 1 MFunc, got " + to_string(len(m_a.funcs)))
        ok = false
    } else {
        let mf = m_a.funcs[0]
        _print_mfunc_summary("(a)", mf)
        if mf.name != "add" {
            println("  FAIL: case (a) expected name=add, got " + mf.name)
            ok = false
        }
        if len(mf.blocks) != 1 {
            println("  FAIL: case (a) expected 1 block, got " + to_string(len(mf.blocks)))
            ok = false
        }
        if len(mf.locals) < 3 {
            println("  FAIL: case (a) expected >=3 locals, got " + to_string(len(mf.locals)))
            ok = false
        }
        if len(mf.params) != 2 {
            println("  FAIL: case (a) expected 2 params, got " + to_string(len(mf.params)))
            ok = false
        }
        if _last_stmt_kind(mf.blocks) != STMT_RETURN {
            println("  FAIL: case (a) expected last stmt=return, got " + _last_stmt_kind(mf.blocks))
            ok = false
        }
        if _kind_count(mf.blocks, STMT_BINOP) < 1 {
            println("  FAIL: case (a) expected >=1 binop")
            ok = false
        }
    }

    // (b)
    println("")
    println("── (b) abs(x) ──")
    let m_b = lower_hir(_build_case_b())
    if len(m_b.funcs) != 1 {
        println("  FAIL: case (b) expected 1 MFunc")
        ok = false
    } else {
        let mf = m_b.funcs[0]
        _print_mfunc_summary("(b)", mf)
        if len(mf.blocks) < 3 {
            println("  FAIL: case (b) expected >=3 blocks (entry+then+after), got " + to_string(len(mf.blocks)))
            ok = false
        }
        if _kind_count(mf.blocks, STMT_BR_COND) < 1 {
            println("  FAIL: case (b) expected >=1 br_cond")
            ok = false
        }
        if _kind_count(mf.blocks, STMT_RETURN) < 2 {
            println("  FAIL: case (b) expected >=2 return (one per arm/path), got " + to_string(_kind_count(mf.blocks, STMT_RETURN)))
            ok = false
        }
        // Verify entry block has a br_cond with both targets set.
        let entry = mf.blocks[0]
        let mut found_brc = false
        let mut s = 0
        while s < len(entry.stmts) {
            let st = entry.stmts[s]
            if st.kind == STMT_BR_COND {
                if st.target_block >= 0 && st.target_block_else >= 0 {
                    found_brc = true
                }
            }
            s = s + 1
        }
        if !found_brc {
            println("  FAIL: case (b) entry block missing br_cond w/ both targets")
            ok = false
        }
        if len(entry.succs) < 2 {
            println("  FAIL: case (b) entry expected >=2 succs, got " + to_string(len(entry.succs)))
            ok = false
        }
    }

    // (c)
    println("")
    println("── (c) loop_sum() ──")
    let m_c = lower_hir(_build_case_c())
    if len(m_c.funcs) != 1 {
        println("  FAIL: case (c) expected 1 MFunc")
        ok = false
    } else {
        let mf = m_c.funcs[0]
        _print_mfunc_summary("(c)", mf)
        if len(mf.blocks) < 4 {
            println("  FAIL: case (c) expected >=4 blocks (entry+header+body+after), got " + to_string(len(mf.blocks)))
            ok = false
        }
        if _kind_count(mf.blocks, STMT_BR_COND) < 1 {
            println("  FAIL: case (c) expected >=1 br_cond (loop header)")
            ok = false
        }
        if _kind_count(mf.blocks, STMT_BR) < 2 {
            println("  FAIL: case (c) expected >=2 br (entry→header, body→header), got " + to_string(_kind_count(mf.blocks, STMT_BR)))
            ok = false
        }
        // Count locals named "i" — let-binding + assign rebind => >=2
        let mut n_i: i64 = 0
        let mut k = 0
        while k < len(mf.locals) {
            if mf.locals[k].name_hint == "i" { n_i = n_i + 1 }
            k = k + 1
        }
        if n_i < 2 {
            println("  FAIL: case (c) expected >=2 SSA-renamed locals 'i', got " + to_string(n_i))
            ok = false
        }
        // Every Local should have arena_id == arena_root
        let mut bad_arena = false
        let mut q = 0
        while q < len(mf.locals) {
            if mf.locals[q].arena_id != mf.arena_root {
                bad_arena = true
            }
            q = q + 1
        }
        if bad_arena {
            println("  FAIL: case (c) some local has arena_id != arena_root")
            ok = false
        }
    }

    // (d) — RFC-074 Phase 3 multi-arg enum payload (construction + match
    //       destructure with 2 binders → per-slot field extracts).
    println("")
    println("── (d) Event::Click(7, 9) + match Event::Click(x, y) — RFC-074 Phase 3 ──")
    let m_d = lower_hir(_build_case_d())
    if len(m_d.funcs) != 1 {
        println("  FAIL: case (d) expected 1 MFunc, got " + to_string(len(m_d.funcs)))
        ok = false
    } else {
        let mf = m_d.funcs[0]
        _print_mfunc_summary("(d)", mf)
        // (d-1) construction site (RFC 074 Phase 5):
        //       - ONE STMT_ASSIGN op="array_lit" with >= 2 elem operands
        //         (the contiguous payload array, one slot per cell).
        //       - ONE STMT_ASSIGN op="enum_ctor" whose args include
        //         const_str "__tag" AND const_str "__payload"
        //         (single map slot for the whole payload array).
        let mut saw_payload_array_lit = false
        let mut saw_ctor_enum_ctor = false
        let mut saw_tag_key_ctor = false
        let mut saw_payload_key_ctor = false
        // (d-2) match-arm destructure (RFC 074 Phase 5):
        //       - ONE STMT_ASSIGN op="field" whose args include const_str
        //         "__payload" (the single map lookup that lifts the
        //         payload array out of the scrut value).
        //       - TWO STMT_ASSIGN op="index" whose args include
        //         const_int 0 AND const_int 1 respectively (one binder
        //         per array ordinal — the per-cell positional read).
        let mut saw_payload_extract = false
        let mut saw_idx0_extract = false
        let mut saw_idx1_extract = false
        let mut bi = 0
        while bi < len(mf.blocks) {
            let b = mf.blocks[bi]
            let mut si = 0
            while si < len(b.stmts) {
                let st = b.stmts[si]
                if st.kind == STMT_ASSIGN {
                    if st.op == "enum_ctor" {
                        saw_ctor_enum_ctor = true
                        let mut ai = 0
                        while ai < len(st.args) {
                            let a = st.args[ai]
                            if a.kind == "const_str" && a.str_val == "__tag" { saw_tag_key_ctor = true }
                            if a.kind == "const_str" && a.str_val == "__payload" { saw_payload_key_ctor = true }
                            ai = ai + 1
                        }
                    } else if st.op == "array_lit" && len(st.args) >= 2 {
                        saw_payload_array_lit = true
                    } else if st.op == "field" {
                        let mut ai = 0
                        while ai < len(st.args) {
                            let a = st.args[ai]
                            if a.kind == "const_str" && a.str_val == "__payload" { saw_payload_extract = true }
                            ai = ai + 1
                        }
                    } else if st.op == "index" {
                        let mut ai = 0
                        while ai < len(st.args) {
                            let a = st.args[ai]
                            if a.kind == "const_int" && a.int_val == 0 { saw_idx0_extract = true }
                            if a.kind == "const_int" && a.int_val == 1 { saw_idx1_extract = true }
                            ai = ai + 1
                        }
                    }
                }
                si = si + 1
            }
            bi = bi + 1
        }
        if !saw_ctor_enum_ctor {
            println("  FAIL: case (d) construction missing STMT_ASSIGN op=enum_ctor (RFC-074 P5)")
            ok = false
        }
        if !saw_payload_array_lit {
            println("  FAIL: case (d) construction missing payload array_lit (RFC-074 P5 storage swap)")
            ok = false
        }
        if !saw_tag_key_ctor {
            println("  FAIL: case (d) construction missing __tag key in enum_ctor args")
            ok = false
        }
        if !saw_payload_key_ctor {
            println("  FAIL: case (d) construction missing __payload key in enum_ctor args (Phase 5 storage swap regressed)")
            ok = false
        }
        if !saw_payload_extract {
            println("  FAIL: case (d) match destructure missing field extract on __payload (Phase 5)")
            ok = false
        }
        if !saw_idx0_extract {
            println("  FAIL: case (d) match binder x missing index extract on const_int 0 (Phase 5 payload fan-out)")
            ok = false
        }
        if !saw_idx1_extract {
            println("  FAIL: case (d) match binder y missing index extract on const_int 1 (Phase 5 payload fan-out)")
            ok = false
        }
        // The tag-compare path still uses op="field" with key "__tag" —
        // ensure RFC-074 Phase 3's per-slot field extracts ADDED to (not
        // displaced) the existing tag-extract instrumentation.
        let mut saw_tag_field = false
        let mut bj = 0
        while bj < len(mf.blocks) {
            let b = mf.blocks[bj]
            let mut sj = 0
            while sj < len(b.stmts) {
                let st = b.stmts[sj]
                if st.kind == STMT_ASSIGN && st.op == "field" {
                    let mut aj = 0
                    while aj < len(st.args) {
                        if st.args[aj].kind == "const_str" && st.args[aj].str_val == "__tag" {
                            saw_tag_field = true
                        }
                        aj = aj + 1
                    }
                }
                sj = sj + 1
            }
            bj = bj + 1
        }
        if !saw_tag_field {
            println("  FAIL: case (d) tag-compare extract on __tag missing (match-arm dispatch broken)")
            ok = false
        }
    }

    // (e) RFC 068 P2 + N57 follow-on — mixed-precision opcode synthesis.
    // For each (op ∈ {+,-,*,/}) × (dtype ∈ {f16, bf16, f32}) verify
    // `_op_with_precision` synthesizes `<op>_<dtype>` + stamps dst.precision.
    println("")
    println("── (e) RFC 068 P2 + N57 — mixed-precision binop synthesis ──")
    ok = _case_e_check_pair(ok, "+", _t_f16(),  "add_f16",  ".f16")
    ok = _case_e_check_pair(ok, "-", _t_f16(),  "sub_f16",  ".f16")
    ok = _case_e_check_pair(ok, "*", _t_f16(),  "mul_f16",  ".f16")
    ok = _case_e_check_pair(ok, "/", _t_f16(),  "div_f16",  ".f16")
    ok = _case_e_check_pair(ok, "+", _t_bf16(), "add_bf16", ".bf16")
    ok = _case_e_check_pair(ok, "-", _t_bf16(), "sub_bf16", ".bf16")
    ok = _case_e_check_pair(ok, "*", _t_bf16(), "mul_bf16", ".bf16")
    ok = _case_e_check_pair(ok, "/", _t_bf16(), "div_bf16", ".bf16")
    ok = _case_e_check_pair(ok, "+", _t_f32(),  "add_f32",  ".f32")
    ok = _case_e_check_pair(ok, "-", _t_f32(),  "sub_f32",  ".f32")
    ok = _case_e_check_pair(ok, "*", _t_f32(),  "mul_f32",  ".f32")
    ok = _case_e_check_pair(ok, "/", _t_f32(),  "div_f32",  ".f32")
    // f64 byte-eq guard: a plain `+` on i64 must NOT pick up a precision
    // suffix (precision tag is empty for non-low-precision kinds — see
    // `_precision_from_typ_kind`). Mirrors nvptx_lower_test Case 20 sub-D.
    ok = _case_e_check_pair(ok, "+", _t_i64(),  "+",        "")

    // (f) RFC 071 P5++ — gpu_matmul builtin synthesis (3 variants).
    println("")
    println("── (f) RFC 071 P5++ — gpu_matmul builtin → STMT_BINOP(matmul*) synthesis ──")
    ok = _case_f_check(ok, "gpu_matmul",      "matmul")
    ok = _case_f_check(ok, "gpu_matmul_NT_a", "matmul_NT_a")
    ok = _case_f_check(ok, "gpu_matmul_NT_b", "matmul_NT_b")

    println("")
    println("══════════════════════════════════════════════")
    if ok {
        println("PASS: hir_to_mir lowers HIR → MIR per contract.")
    } else {
        println("FAIL: hir_to_mir contract not satisfied.")
    }
    println("══════════════════════════════════════════════")
    if !ok { exit(1) }
}
