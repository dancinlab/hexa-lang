// compiler/lenses/types.hexa — LensNode + Candidate + AtlasView types
//
// RFC 065 §8 (binary built-in lens system).
// Companion to compiler/atlas/parser.hexa::AtlasNode.
//
// authority: AGENTS.tape @D g_atlas_binary_builtin
//   "atlas is unconditionally binary built-in" — the same shape extended
//   to a sibling lens SSOT. See RFC 065 §10 governance matrix.

use "compiler/atlas/parser"

// A lens-emitted hypothesis. Carries the derivation chain back to the
// atlas nodes it was synthesized from (`cite`). Strict-lint stage 4
// rejects Candidates whose cite is empty or references an unknown id.
pub struct Candidate {
    slug: string,               // unique stable id, gates the cooldown set
    family: string,             // one of 8 (see RFC 065 §9)
    proposed: string,           // human-readable hypothesis text
    cite: array,                // [string] of atlas_node_id
    fire_needed: bool,          // Wilson fire-gate classification
    fire_estimate_usd: float    // populated by lens, consumed by --budget
}

// Read-only view over the baked atlas. Cycle stage 1 (SCAN) materializes
// one AtlasView per cycle from compiler/atlas/embedded.gen.hexa.
pub struct AtlasView {
    p_nodes: array,             // [AtlasNode]
    c_nodes: array,
    l_nodes: array,
    f_nodes: array,
    r_nodes: array,
    s_nodes: array,
    x_nodes: array,
    q_nodes: array,
    atlas_hash: string,
    atlas_generated_at: string
}

// A lens metadata record. The `apply` callable is NOT a field — hexa-lang
// const struct arrays do not promise fn-pointer-in-struct support, so
// dispatch is by id through compiler/lenses/embedded.gen.hexa::lens_apply_by_id.
pub struct LensNode {
    kind: string,               // always "L"
    id: string,                 // canonical slug "family.name"
    family: string,             // 8 families per RFC 065 §9
    docstring: string,          // 1-line derivation basis
    cite: array                 // [string] of prior atlas_node_id
}

pub fn empty_candidate_list() -> array {
    let xs: array = []
    return xs
}
