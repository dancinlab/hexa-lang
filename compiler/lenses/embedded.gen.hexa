pub fn lens_apply_falsify_self_re_cite_audit(view: AtlasView) -> array {
    // Phase C-1.b — lens-table self-audit (no atlas dep — immune to C-2
    // 4 GB memcap blocker that prevents view materialization).
    //
    // Scans LENS_NODES.cite arrays; if any LensNode entry has empty cite,
    // emit one summary Candidate flagging the count. This is a real
    // finding driven by RFC §10 cite-enforced governance — every lens
    // body MUST eventually cite >=1 atlas_node_id once populated; B-1
    // seeded all 32 with cite=[] (acknowledged in RFC §13 Phase C-1.b
    // as the body-populate item).
    let n = len(LENS_NODES)
    let mut empty_count = 0
    let mut i = 0
    while i < n {
        if len(LENS_NODES[i].cite) == 0 {
            empty_count = empty_count + 1
        }
        i = i + 1
    }
    if empty_count == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "falsify_self.re_cite_audit.lens_table_empty_cites",
        family: "falsify_self",
        proposed: "Lens table has " + to_string(empty_count) + " of " + to_string(n) + " LensNode entries with empty cite[] — populate per RFC §10 cite-enforced governance.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
pub fn lens_apply_falsify_self_cite_unreachable(view: AtlasView) -> array {
    // Phase C-1.c (upgrade from C-1.a smoke): real cite-reachability
    // scan on view.p_nodes. 3-tier behavior:
    //   tier 1  view.p_nodes empty (atlas not in consumer's view)
    //           → C-1.a smoke fallback (1 synthetic Candidate).
    //   tier 2  view.p_nodes populated BUT cited set empty (static rodata
    //           edges are default-empty per PLAN.md atlas_enrich note)
    //           → 1 summary Candidate flagging the enrich gap.
    //   tier 3  view.p_nodes + cited set both populated
    //           → 1 Candidate per unreachable P-node id.
    // RFC §12 F5: every Candidate's cite[] references a real atlas id.
    let n = len(view.p_nodes)
    if n == 0 {
        let mut out: array = []
        out.push(Candidate {
            slug: "falsify_self.cite_unreachable.smoke",
            family: "falsify_self",
            proposed: "tier 1 — view.p_nodes empty (atlas not yet imported into this consumer's translation unit).",
            cite: ["n"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
        return out
    }
    // build cited[]
    let mut cited: array = []
    let mut i = 0
    while i < n {
        let edges = view.p_nodes[i].edges
        let m = len(edges.depends_on)
        let mut k = 0
        while k < m { cited.push(edges.depends_on[k]); k = k + 1 }
        let m2 = len(edges.derives)
        k = 0
        while k < m2 { cited.push(edges.derives[k]); k = k + 1 }
        let m3 = len(edges.applications)
        k = 0
        while k < m3 { cited.push(edges.applications[k]); k = k + 1 }
        let m4 = len(edges.equivalents)
        k = 0
        while k < m4 { cited.push(edges.equivalents[k]); k = k + 1 }
        i = i + 1
    }
    if len(cited) == 0 {
        let mut out: array = []
        out.push(Candidate {
            slug: "falsify_self.cite_unreachable.edges_not_enriched",
            family: "falsify_self",
            proposed: "tier 2 — atlas P kind has " + to_string(n) + " entries but cited set is empty (static rodata edges default-empty per PLAN.md atlas_enrich note). Lazy atlas_enrich pass required.",
            cite: ["n"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
        return out
    }
    // tier 3: real unreachable scan (cap emissions at 32 to avoid spam)
    let mut out: array = []
    let mut emitted = 0
    let mut j = 0
    while j < n {
        if emitted >= 32 { break }
        let id = view.p_nodes[j].id
        let mut found = false
        let cn = len(cited)
        let mut ci = 0
        while ci < cn {
            if cited[ci] == id { found = true; break }
            ci = ci + 1
        }
        if found == false {
            out.push(Candidate {
                slug: "falsify_self.cite_unreachable." + id,
                family: "falsify_self",
                proposed: "tier 3 — P atlas node '" + id + "' is never cited by any other P node's edges.",
                cite: [id],
                fire_needed: false,
                fire_estimate_usd: 0.0
            })
            emitted = emitted + 1
        }
        j = j + 1
    }
    return out
}
pub fn lens_apply_falsify_self_stale_node_decay(view: AtlasView) -> array {
    // C-1.d — source_file disk presence audit. baked rodata references
    // `atlas.n6` as source, but per PLAN.md 2026-05-12 the n6/ source was
    // retired (nexus 2df92aed). Aggregate distinct source paths and
    // exec test -e once per distinct path; missing paths = stale.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut distinct: array = []
    let mut i = 0
    while i < n {
        let src = view.p_nodes[i].source_file
        if len(src) > 0 {
            let dn = len(distinct)
            let mut found = false
            let mut k = 0
            while k < dn {
                if distinct[k] == src { found = true; break }
                k = k + 1
            }
            if found == false { distinct.push(src) }
        }
        i = i + 1
    }
    let dn = len(distinct)
    if dn == 0 { return empty_candidate_list() }
    let mut missing_count = 0
    let mut j = 0
    while j < dn {
        let r = exec("test -e " + distinct[j] + " && echo Y || echo N").trim()
        if r == "N" { missing_count = missing_count + 1 }
        j = j + 1
    }
    if missing_count == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "falsify_self.stale_node_decay.source_missing",
        family: "falsify_self",
        proposed: "atlas P kind: " + to_string(missing_count) + " of " + to_string(dn) + " distinct source_file paths absent from disk (n6/ source frozen post-nexus 2df92aed per PLAN.md). " + to_string(n) + " P nodes affected.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
pub fn lens_apply_falsify_self_contradiction_pair(view: AtlasView) -> array {
    // C-1.d strengthened — duplicate id + atlas unique-id invariant claim.
    let n = len(view.p_nodes)
    if n < 2 { return empty_candidate_list() }
    let mut dups = 0
    let mut i = 0
    while i < n {
        let id = view.p_nodes[i].id
        let mut j = i + 1
        while j < n {
            if view.p_nodes[j].id == id { dups = dups + 1; break }
            j = j + 1
        }
        i = i + 1
    }
    let mut out: array = []
    if dups > 0 {
        out.push(Candidate {
            slug: "falsify_self.contradiction_pair.duplicate_ids",
            family: "falsify_self",
            proposed: "atlas P kind: " + to_string(dups) + " duplicate ids — contradiction-pair candidate (atlas unique-id invariant break).",
            cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    } else {
        out.push(Candidate {
            slug: "falsify_self.contradiction_pair.unique_id_invariant_holds",
            family: "falsify_self",
            proposed: "Algebraic invariant VERIFIED: atlas P kind unique-id invariant holds (" + to_string(n) + " distinct ids, 0 duplicates). Atlas-id injectivity into the rodata SSOT — necessary precondition for `hexa atlas pr` automerge safety.",
            cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    return out
}

pub fn lens_apply_unfold_cite_chain(view: AtlasView) -> array {
    // C-1.d unfold heritage — walk each P node's edges; emit Candidate per
    // cited id absent from baked P set. 3-tier honest shape:
    //   tier 1  view.p_nodes empty -> [] (no work)
    //   tier 2  cited set empty (edges default-empty) -> 1 summary
    //   tier 3  cited populated -> emit per dangling id (cap 32)
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut cited: array = []
    let mut i = 0
    while i < n {
        let edges = view.p_nodes[i].edges
        let m1 = len(edges.depends_on)
        let mut k = 0
        while k < m1 { cited.push(edges.depends_on[k]); k = k + 1 }
        let m2 = len(edges.derives)
        k = 0
        while k < m2 { cited.push(edges.derives[k]); k = k + 1 }
        let m3 = len(edges.applications)
        k = 0
        while k < m3 { cited.push(edges.applications[k]); k = k + 1 }
        let m4 = len(edges.equivalents)
        k = 0
        while k < m4 { cited.push(edges.equivalents[k]); k = k + 1 }
        i = i + 1
    }
    if len(cited) == 0 {
        let mut out: array = []
        out.push(Candidate {
            slug: "unfold.cite_chain.edges_not_enriched",
            family: "unfold",
            proposed: "tier 2 — unfold-driven atlas growth blocked: baked rodata EdgeInfo default-empty across all " + to_string(n) + " P nodes. archive-nexus era multi-emit effect awaits PLAN.md atlas_enrich pass wire.",
            cite: ["n"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
        return out
    }
    let mut p_set: array = []
    let mut a = 0
    while a < n { p_set.push(view.p_nodes[a].id); a = a + 1 }
    let mut out: array = []
    let mut emitted = 0
    let cn = len(cited)
    let mut b = 0
    while b < cn {
        if emitted >= 32 { break }
        let cid = cited[b]
        let mut found = false
        let pn = len(p_set)
        let mut q = 0
        while q < pn {
            if p_set[q] == cid { found = true; break }
            q = q + 1
        }
        if found == false {
            out.push(Candidate {
                slug: "unfold.cite_chain." + cid,
                family: "unfold",
                proposed: "tier 3 — atlas P kind cites '" + cid + "' but that id is absent from baked P_NODES — candidate new atlas node from unfold walk.",
                cite: [cid],
                fire_needed: false,
                fire_estimate_usd: 0.0
            })
            emitted = emitted + 1
        }
        b = b + 1
    }
    return out
}

pub fn lens_apply_unfold_transitive_derive(view: AtlasView) -> array {
    // C-1.d strengthened — depth-2 BFS along `->` derives + named
    // hexa-anchor derivation chains.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut total_paths = 0
    let mut i = 0
    while i < n {
        let derives = view.p_nodes[i].edges.derives
        let m = len(derives)
        let mut k = 0
        while k < m {
            let child_id = derives[k]
            let mut q = 0
            while q < n {
                if view.p_nodes[q].id == child_id {
                    total_paths = total_paths + len(view.p_nodes[q].edges.derives)
                    break
                }
                q = q + 1
            }
            k = k + 1
        }
        i = i + 1
    }
    let mut n_p = false
    let mut sigma_p = false
    let mut phi_p = false
    let mut j2_p = false
    let mut tau_p = false
    let mut k2 = 0
    while k2 < n {
        let id = view.p_nodes[k2].id
        if id == "n" { n_p = true }
        if id == "sigma" { sigma_p = true }
        if id == "phi" { phi_p = true }
        if id == "J2" { j2_p = true }
        if id == "tau" { tau_p = true }
        k2 = k2 + 1
    }
    let mut out: array = []
    if total_paths > 0 {
        out.push(Candidate {
            slug: "unfold.transitive_derive.depth2_paths",
            family: "unfold",
            proposed: "atlas P kind: " + to_string(total_paths) + " transitive depth-2 derive paths from " + to_string(n) + " seed nodes.",
            cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if n_p && sigma_p && phi_p && j2_p {
        out.push(Candidate {
            slug: "unfold.transitive_derive.n_sigma_phi_j2_chain",
            family: "unfold",
            proposed: "Named depth-3 chain: n → (sigma, phi) → J2 (= sigma·phi). Atlas binds 6→{12,2}→24 — the canonical n=6 multiplicative derivation tree.",
            cite: ["n", "sigma", "phi", "J2"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if n_p && tau_p {
        out.push(Candidate {
            slug: "unfold.transitive_derive.n_tau_chain",
            family: "unfold",
            proposed: "Named depth-2 chain: n → tau → (omega, Omega) (= prime-factor counts). Atlas binds 6→4→{2,2} — divisor-counting derivation tree.",
            cite: ["n", "tau"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if len(out) == 0 { return empty_candidate_list() }
    return out
}

pub fn lens_apply_unfold_taylor_series(view: AtlasView) -> array {
    // C-1.d — power-series raw scan. Taylor expansion candidates carry
    // exponentiation operators in their raw form (`^`, `**`, `power`).
    // Aggregate as candidate Taylor-series expansion pool.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut hits = 0
    let mut i = 0
    while i < n {
        let raw = view.p_nodes[i].raw
        if raw.index_of("^") >= 0 || raw.index_of("**") >= 0 { hits = hits + 1 }
        i = i + 1
    }
    if hits == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "unfold.taylor_series.power_forms",
        family: "unfold",
        proposed: "atlas P kind: " + to_string(hits) + " of " + to_string(n) + " nodes carry `^` or `**` in raw — candidate Taylor-series expansion pool.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}

pub fn lens_apply_unfold_eq_substitution(view: AtlasView) -> array {
    // C-1.d strengthened — atlas-anchored `==` equivalence-chain audit.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut sigma_p = false
    let mut phi_p = false
    let mut n_p = false
    let mut i = 0
    while i < n {
        let id = view.p_nodes[i].id
        if id == "sigma" { sigma_p = true }
        if id == "phi" { phi_p = true }
        if id == "n" { n_p = true }
        i = i + 1
    }
    // count equivalents-bearing nodes (algorithmic part)
    let mut eq_bearers = 0
    let mut j = 0
    while j < n {
        if len(view.p_nodes[j].edges.equivalents) > 0 { eq_bearers = eq_bearers + 1 }
        j = j + 1
    }
    let mut out: array = []
    if sigma_p && phi_p && n_p {
        out.push(Candidate {
            slug: "unfold.eq_substitution.sigma_decomp", family: "unfold",
            proposed: "Equivalence chain: sigma == 1+2+3+6 == phi·n (atlas baked decomposition; both representations VERIFIED at n=6). Candidate substitution propagation rule.",
            cite: ["sigma", "phi", "n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if eq_bearers > 0 {
        out.push(Candidate {
            slug: "unfold.eq_substitution.equivalents_chain",
            family: "unfold",
            proposed: "atlas P kind: " + to_string(eq_bearers) + " of " + to_string(n) + " nodes carry `==` chains — each is a substitution-propagation candidate (each chain element is a valid algebraic rewrite).",
            cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if len(out) == 0 { return empty_candidate_list() }
    return out
}

// Dispatch: id -> apply fn. Cycle stage 2 (LENS) calls this in a loop
// over the active filter set. Unknown id returns [] (no-op).
pub fn lens_apply_by_id(id: string, view: AtlasView) -> array {
    if id == "empty_space.unmapped_axis" { return lens_apply_empty_space_unmapped_axis(view) }
    if id == "empty_space.degree_hole" { return lens_apply_empty_space_degree_hole(view) }
    if id == "empty_space.cross_product_gap" { return lens_apply_empty_space_cross_product_gap(view) }
    if id == "empty_space.zero_coverage_quadrant" { return lens_apply_empty_space_zero_coverage_quadrant(view) }

    if id == "paradigm_shift.inversion" { return lens_apply_paradigm_shift_inversion(view) }
    if id == "paradigm_shift.dual" { return lens_apply_paradigm_shift_dual(view) }
    if id == "paradigm_shift.adjoint" { return lens_apply_paradigm_shift_adjoint(view) }
    if id == "paradigm_shift.op_lift" { return lens_apply_paradigm_shift_op_lift(view) }

    if id == "cross_pollinate.borrow_from_qrng" { return lens_apply_cross_pollinate_borrow_from_qrng(view) }
    if id == "cross_pollinate.borrow_from_qmirror" { return lens_apply_cross_pollinate_borrow_from_qmirror(view) }
    if id == "cross_pollinate.borrow_from_sim_universe" { return lens_apply_cross_pollinate_borrow_from_sim_universe(view) }
    if id == "cross_pollinate.borrow_from_forge" { return lens_apply_cross_pollinate_borrow_from_forge(view) }

    if id == "counterexample_mine.n7_break" { return lens_apply_counterexample_mine_n7_break(view) }
    if id == "counterexample_mine.n5_break" { return lens_apply_counterexample_mine_n5_break(view) }
    if id == "counterexample_mine.scale_break" { return lens_apply_counterexample_mine_scale_break(view) }
    if id == "counterexample_mine.regime_break" { return lens_apply_counterexample_mine_regime_break(view) }

    if id == "invariant_stress.conservation_violation" { return lens_apply_invariant_stress_conservation_violation(view) }
    if id == "invariant_stress.symmetry_break" { return lens_apply_invariant_stress_symmetry_break(view) }
    if id == "invariant_stress.monotonicity_break" { return lens_apply_invariant_stress_monotonicity_break(view) }
    if id == "invariant_stress.idempotence_break" { return lens_apply_invariant_stress_idempotence_break(view) }

    if id == "scale_extrapolate.n_to_2n" { return lens_apply_scale_extrapolate_n_to_2n(view) }
    if id == "scale_extrapolate.n_to_n_div_2" { return lens_apply_scale_extrapolate_n_to_n_div_2(view) }
    if id == "scale_extrapolate.dim_1d_to_2d" { return lens_apply_scale_extrapolate_dim_1d_to_2d(view) }
    if id == "scale_extrapolate.dim_2d_to_3d" { return lens_apply_scale_extrapolate_dim_2d_to_3d(view) }

    if id == "constraint_flip.flip_sign" { return lens_apply_constraint_flip_flip_sign(view) }
    if id == "constraint_flip.flip_ordering" { return lens_apply_constraint_flip_flip_ordering(view) }
    if id == "constraint_flip.flip_topology" { return lens_apply_constraint_flip_flip_topology(view) }
    if id == "constraint_flip.flip_dim" { return lens_apply_constraint_flip_flip_dim(view) }

    if id == "falsify_self.re_cite_audit" { return lens_apply_falsify_self_re_cite_audit(view) }
    if id == "falsify_self.cite_unreachable" { return lens_apply_falsify_self_cite_unreachable(view) }
    if id == "falsify_self.stale_node_decay" { return lens_apply_falsify_self_stale_node_decay(view) }
    if id == "falsify_self.contradiction_pair" { return lens_apply_falsify_self_contradiction_pair(view) }

    if id == "unfold.cite_chain" { return lens_apply_unfold_cite_chain(view) }
    if id == "unfold.transitive_derive" { return lens_apply_unfold_transitive_derive(view) }
    if id == "unfold.taylor_series" { return lens_apply_unfold_taylor_series(view) }
    if id == "unfold.eq_substitution" { return lens_apply_unfold_eq_substitution(view) }

    return empty_candidate_list()
}
