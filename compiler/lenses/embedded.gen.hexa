// Dispatch: id -> apply fn. Cycle stage 2 (LENS) calls this in a loop
// over the active filter set. Unknown id returns [] (no-op).
pub fn lens_apply_by_id(id: string, view: AtlasView) -> array {
    if id == "empty_space.unmapped_axis" { return lens_apply_empty_space_unmapped_axis(view) }
    if id == "empty_space.degree_hole" { return lens_apply_empty_space_degree_hole(view) }
    if id == "empty_space.cross_product_gap" { return lens_apply_empty_space_cross_product_gap(view) }
    if id == "empty_space.zero_coverage_quadrant" { return lens_apply_empty_space_zero_coverage_quadrant(view) }

    if id == "paradigm_shift.inversion" { return lens_apply_paradigm_shift_inversion(view) }
    if id == "paradigm_shift.dual" { return lens_apply_paradigm_shift_dual(view) }
    if id == "paradigm_shift.adjoint" { return lens_apply_paradigm_shift_adjoint(view) }
    if id == "paradigm_shift.op_lift" { return lens_apply_paradigm_shift_op_lift(view) }

    if id == "cross_pollinate.borrow_from_qrng" { return lens_apply_cross_pollinate_borrow_from_qrng(view) }
    if id == "cross_pollinate.borrow_from_qmirror" { return lens_apply_cross_pollinate_borrow_from_qmirror(view) }
    if id == "cross_pollinate.borrow_from_sim_universe" { return lens_apply_cross_pollinate_borrow_from_sim_universe(view) }
    if id == "cross_pollinate.borrow_from_forge" { return lens_apply_cross_pollinate_borrow_from_forge(view) }

    if id == "counterexample_mine.n7_break" { return lens_apply_counterexample_mine_n7_break(view) }
    if id == "counterexample_mine.n5_break" { return lens_apply_counterexample_mine_n5_break(view) }
    if id == "counterexample_mine.scale_break" { return lens_apply_counterexample_mine_scale_break(view) }
    if id == "counterexample_mine.regime_break" { return lens_apply_counterexample_mine_regime_break(view) }

    if id == "invariant_stress.conservation_violation" { return lens_apply_invariant_stress_conservation_violation(view) }
    if id == "invariant_stress.symmetry_break" { return lens_apply_invariant_stress_symmetry_break(view) }
    if id == "invariant_stress.monotonicity_break" { return lens_apply_invariant_stress_monotonicity_break(view) }
    if id == "invariant_stress.idempotence_break" { return lens_apply_invariant_stress_idempotence_break(view) }

    if id == "scale_extrapolate.n_to_2n" { return lens_apply_scale_extrapolate_n_to_2n(view) }
    if id == "scale_extrapolate.n_to_n_div_2" { return lens_apply_scale_extrapolate_n_to_n_div_2(view) }
    if id == "scale_extrapolate.dim_1d_to_2d" { return lens_apply_scale_extrapolate_dim_1d_to_2d(view) }
    if id == "scale_extrapolate.dim_2d_to_3d" { return lens_apply_scale_extrapolate_dim_2d_to_3d(view) }

    if id == "constraint_flip.flip_sign" { return lens_apply_constraint_flip_flip_sign(view) }
    if id == "constraint_flip.flip_ordering" { return lens_apply_constraint_flip_flip_ordering(view) }
    if id == "constraint_flip.flip_topology" { return lens_apply_constraint_flip_flip_topology(view) }
    if id == "constraint_flip.flip_dim" { return lens_apply_constraint_flip_flip_dim(view) }

    if id == "falsify_self.re_cite_audit" { return lens_apply_falsify_self_re_cite_audit(view) }
    if id == "falsify_self.cite_unreachable" { return lens_apply_falsify_self_cite_unreachable(view) }
    if id == "falsify_self.stale_node_decay" { return lens_apply_falsify_self_stale_node_decay(view) }
    if id == "falsify_self.contradiction_pair" { return lens_apply_falsify_self_contradiction_pair(view) }

    return empty_candidate_list()
}
