pub fn lens_apply_constraint_flip_flip_ordering(view: AtlasView) -> array {
    // C-1.d strengthened — directional edge skew + atlas-anchored
    // retro-causal hypothesis.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut deps_total = 0
    let mut der_total = 0
    let mut i = 0
    while i < n {
        let e = view.p_nodes[i].edges
        deps_total = deps_total + len(e.depends_on)
        der_total = der_total + len(e.derives)
        i = i + 1
    }
    let sum = deps_total + der_total
    let mut out: array = []
    if sum > 0 {
        let third = sum / 3
        if deps_total < third || der_total < third {
            out.push(Candidate {
                slug: "constraint_flip.flip_ordering.skew",
                family: "constraint_flip",
                proposed: "Directional skew: depends_on=" + to_string(deps_total) + " vs derives=" + to_string(der_total) + " (one side < 1/3). Atlas edge orientation is asymmetric — candidate retro-causal sibling.",
                cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
            })
        }
        out.push(Candidate {
            slug: "constraint_flip.flip_ordering.balance",
            family: "constraint_flip",
            proposed: "Atlas P kind directional balance: depends_on=" + to_string(deps_total) + " / derives=" + to_string(der_total) + ". Hypothesis: a fully balanced atlas (depends_on ≈ derives) is the invariant target; current imbalance measures the retrocausal-direction gap.",
            cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if len(out) == 0 { return empty_candidate_list() }
    return out
}
pub fn lens_apply_constraint_flip_flip_topology(view: AtlasView) -> array {
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut hits = 0
    let mut i = 0
    while i < n {
        let raw = view.p_nodes[i].raw
        if raw.index_of("topology") >= 0 || raw.index_of("planar") >= 0 || raw.index_of("toroidal") >= 0 || raw.index_of("genus") >= 0 {
            hits = hits + 1
        }
        i = i + 1
    }
    if hits == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "constraint_flip.flip_topology.topology_signals",
        family: "constraint_flip",
        proposed: "atlas P kind: " + to_string(hits) + " of " + to_string(n) + " nodes carry topology/planar/toroidal/genus in raw — candidate pool for topology-flip survival test.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
