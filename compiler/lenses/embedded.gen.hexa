pub fn lens_apply_invariant_stress_symmetry_break(view: AtlasView) -> array {
    // C-1.d — identifier-ASCII invariant audit. P node ids should be
    // ASCII identifiers (per atlas grammar convention); non-ASCII or
    // space-bearing ids = symmetry-break candidates (e.g. ids that
    // sneaked in via parse_edge_lines false-positive from description text).
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut broken = 0
    let mut i = 0
    while i < n {
        let id = view.p_nodes[i].id
        let m = len(id)
        let mut bad = false
        let mut k = 0
        while k < m {
            let c = id.substring(k, k + 1)
            if c == " " || c == "\"" || c == "'" { bad = true; break }
            k = k + 1
        }
        if bad { broken = broken + 1 }
        i = i + 1
    }
    if broken == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "invariant_stress.symmetry_break.id_format",
        family: "invariant_stress",
        proposed: "atlas P kind: " + to_string(broken) + " of " + to_string(n) + " node ids contain spaces or quotes — identifier-format invariant break, candidate for atlas hygiene.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
