pub fn lens_apply_empty_space_unmapped_axis(view: AtlasView) -> array {
    // C-1.d — atlas P kind grade-distribution audit. With enrich_node
    // populating grade.value (parse_grade from raw marker `[N]` / `[N*]`),
    // P nodes with grade=-1 (no marker) represent ungraded entries that
    // block grade-aware coverage analysis. Flag the total as one
    // summary Candidate when significant.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut graded = 0
    let mut hi_grade = 0
    let mut i = 0
    while i < n {
        let g = view.p_nodes[i].grade.value
        if g >= 0 { graded = graded + 1 }
        if g >= 10 { hi_grade = hi_grade + 1 }
        i = i + 1
    }
    let ungraded = n - graded
    if ungraded == 0 && hi_grade == n {
        return empty_candidate_list()  // perfect coverage, no finding
    }
    let mut out: array = []
    out.push(Candidate {
        slug: "empty_space.unmapped_axis.grade_distribution",
        family: "empty_space",
        proposed: "atlas P kind grade audit: " + to_string(graded) + "/" + to_string(n) + " graded (>=0), " + to_string(hi_grade) + " at grade>=10 (verified). " + to_string(ungraded) + " ungraded entries block grade-axis coverage analysis.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    // algebraic: at n=6, atlas anchors saturate the high-grade bucket
    out.push(Candidate {
        slug: "empty_space.unmapped_axis.n6_anchor_saturation",
        family: "empty_space",
        proposed: "Algebraic anchor: at n=6 the high-grade tier (grade>=10) is saturated by the 8 hexa primitives; coverage proxy = hi_grade / 8 (where 8 = anchor count). Atlas perfect-coverage hypothesis: every grade-10 P node should map to one of {n, sigma, phi, tau, sopfr, J2, mu, M3} or its direct derivation.",
        cite: ["n"], fire_needed: false, fire_estimate_usd: 0.0
    })
    return out
}
pub fn lens_apply_empty_space_degree_hole(view: AtlasView) -> array {
    // C-1.d — degree (total edge count) distribution audit. P nodes with
    // degree below half the family mean = "thin" nodes, candidate for
    // edge-population attention.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut total_deg = 0
    let mut i = 0
    while i < n {
        let e = view.p_nodes[i].edges
        total_deg = total_deg + len(e.depends_on) + len(e.derives) + len(e.applications) + len(e.equivalents)
        i = i + 1
    }
    if total_deg == 0 { return empty_candidate_list() }
    let mean_x2 = total_deg / n  // half-mean threshold via integer truncation
    let mut thin = 0
    let mut j = 0
    while j < n {
        let e = view.p_nodes[j].edges
        let deg = len(e.depends_on) + len(e.derives) + len(e.applications) + len(e.equivalents)
        if deg < mean_x2 { thin = thin + 1 }
        j = j + 1
    }
    if thin == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "empty_space.degree_hole.below_mean",
        family: "empty_space",
        proposed: "atlas P kind: " + to_string(thin) + " of " + to_string(n) + " nodes have edge-degree below the family mean (" + to_string(mean_x2) + "). Candidate pool for edge enrichment.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
pub fn lens_apply_empty_space_cross_product_gap(view: AtlasView) -> array {
    // C-1.d — P × L cross-reference density. Total derives count from P
    // nodes; if the mean derives-per-node is below 1.0, the P-L surface is
    // sparse (= many P nodes have no L children), candidate for connectivity audit.
    let p_n = len(view.p_nodes)
    if p_n == 0 { return empty_candidate_list() }
    let mut total_derives = 0
    let mut i = 0
    while i < p_n {
        total_derives = total_derives + len(view.p_nodes[i].edges.derives)
        i = i + 1
    }
    if total_derives >= p_n { return empty_candidate_list() }  // mean ≥ 1.0 = healthy
    let mut out: array = []
    out.push(Candidate {
        slug: "empty_space.cross_product_gap.sparse_derives",
        family: "empty_space",
        proposed: "atlas P × L cross-product: " + to_string(total_derives) + " total `->` derives from " + to_string(p_n) + " P nodes (mean < 1.0/node). P-L surface is sparse — candidate for derives enrichment.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
pub fn lens_apply_empty_space_zero_coverage_quadrant(view: AtlasView) -> array {
    // C-1.d — grade-quadrant audit. Partition P kind into LOW (grade<5) /
    // MID (5..9) / HIGH (>=10) buckets; flag if any bucket has 0 entries.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut lo = 0
    let mut mid = 0
    let mut hi = 0
    let mut i = 0
    while i < n {
        let g = view.p_nodes[i].grade.value
        if g >= 0 && g < 5 { lo = lo + 1 }
        if g >= 5 && g <= 9 { mid = mid + 1 }
        if g >= 10 { hi = hi + 1 }
        i = i + 1
    }
    if lo > 0 && mid > 0 && hi > 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "empty_space.zero_coverage_quadrant.grade_bucket_empty",
        family: "empty_space",
        proposed: "atlas P kind grade buckets: lo<5=" + to_string(lo) + " mid5-9=" + to_string(mid) + " hi>=10=" + to_string(hi) + ". One or more bucket is empty — coverage gap.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}

pub fn lens_apply_paradigm_shift_inversion(view: AtlasView) -> array {
    // C-1.d strengthened — atlas-specific algebraic inversion hypothesis.
    // Identify presence of hexa primitives (sigma · phi · tau · n · sopfr
    // · J2 · mu · M3 per AGENTS.tape signature) and emit named Candidate
    // per known + hypothesis multiplicative inversion relation.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut sigma_p = false
    let mut phi_p = false
    let mut tau_p = false
    let mut n_p = false
    let mut sopfr_p = false
    let mut j2_p = false
    let mut mu_p = false
    let mut m3_p = false
    let mut i = 0
    while i < n {
        let id = view.p_nodes[i].id
        if id == "sigma" { sigma_p = true }
        if id == "phi" { phi_p = true }
        if id == "tau" { tau_p = true }
        if id == "n" { n_p = true }
        if id == "sopfr" { sopfr_p = true }
        if id == "J2" { j2_p = true }
        if id == "mu" { mu_p = true }
        if id == "M3" { m3_p = true }
        i = i + 1
    }
    let mut out: array = []
    if sigma_p && phi_p && n_p {
        out.push(Candidate {
            slug: "paradigm_shift.inversion.sigma_div_phi_eq_n",
            family: "paradigm_shift",
            proposed: "Algebraic inversion: sigma / phi = n (atlas binds sigma=12, phi=2, n=6 — verifies 12/2=6; dual of sigma=phi*n).",
            cite: ["sigma", "phi", "n"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
    }
    if sigma_p && j2_p && phi_p {
        out.push(Candidate {
            slug: "paradigm_shift.inversion.j2_div_sigma_eq_phi",
            family: "paradigm_shift",
            proposed: "Algebraic inversion: J2 / sigma = phi (atlas binds J2=24, sigma=12, phi=2 — verifies 24/12=2; dual of J2=sigma*phi).",
            cite: ["J2", "sigma", "phi"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
    }
    if tau_p && n_p && phi_p {
        out.push(Candidate {
            slug: "paradigm_shift.inversion.n_div_phi_eq_tau",
            family: "paradigm_shift",
            proposed: "Algebraic inversion: n + tau / phi = ? (atlas binds n=6, tau=4, phi=2; hypothesis candidate for unreported identity 6 + 4/2 = 8).",
            cite: ["n", "tau", "phi"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
    }
    if mu_p && sigma_p {
        out.push(Candidate {
            slug: "paradigm_shift.inversion.mu_times_sigma_sign_flip",
            family: "paradigm_shift",
            proposed: "Algebraic sign-dual: mu * sigma = -12 (atlas binds mu=-1, sigma=12; sign-flipped dual node candidate).",
            cite: ["mu", "sigma"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
    }
    if m3_p && n_p {
        out.push(Candidate {
            slug: "paradigm_shift.inversion.m3_plus_n_eq_13",
            family: "paradigm_shift",
            proposed: "Algebraic offset: M3 + n = 13 (atlas binds M3=7, n=6; prime-sum dual candidate, unreported relation).",
            cite: ["M3", "n"],
            fire_needed: false,
            fire_estimate_usd: 0.0
        })
    }
    if len(out) == 0 { return empty_candidate_list() }
    return out
}
pub fn lens_apply_paradigm_shift_dual(view: AtlasView) -> array {
    // C-1.d — n=6 lattice signature audit. The atlas's P kind should
    // anchor on the 8 hexa primitives (n=6, sigma=12, phi=2, tau=4,
    // sopfr=5, J2=24, mu=1, M3=7) per AGENTS.tape signature
    // "n=6 primitives". Verify presence; flag total presence as a
    // single summary Candidate if anything is missing.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut anchors: array = []
    anchors.push("n")
    anchors.push("sigma")
    anchors.push("phi")
    anchors.push("tau")
    anchors.push("sopfr")
    anchors.push("J2")
    anchors.push("mu")
    anchors.push("M3")
    let an = len(anchors)
    let mut missing_count = 0
    let mut a = 0
    while a < an {
        let anchor = anchors[a]
        let mut found = false
        let mut p = 0
        while p < n {
            if view.p_nodes[p].id == anchor { found = true; break }
            p = p + 1
        }
        if found == false { missing_count = missing_count + 1 }
        a = a + 1
    }
    if missing_count == 0 { return empty_candidate_list() }
    let mut out: array = []
    out.push(Candidate {
        slug: "paradigm_shift.dual.anchor_audit",
        family: "paradigm_shift",
        proposed: "atlas P kind anchor audit: " + to_string(an - missing_count) + "/" + to_string(an) + " of the 8 hexa primitives (n, sigma, phi, tau, sopfr, J2, mu, M3) present. " + to_string(missing_count) + " missing — candidate for baking attention.",
        cite: ["n"],
        fire_needed: false,
        fire_estimate_usd: 0.0
    })
    return out
}
pub fn lens_apply_paradigm_shift_adjoint(view: AtlasView) -> array {
    // C-1.d strengthened — atlas-anchored dual-pair audit. Each pair of
    // present primitives that have a documented or hypothesized adjoint
    // relation emits a named Candidate.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut sigma_p = false
    let mut phi_p = false
    let mut tau_p = false
    let mut sopfr_p = false
    let mut mu_p = false
    let mut m3_p = false
    let mut j2_p = false
    let mut n_p = false
    let mut i = 0
    while i < n {
        let id = view.p_nodes[i].id
        if id == "sigma" { sigma_p = true }
        if id == "phi" { phi_p = true }
        if id == "tau" { tau_p = true }
        if id == "sopfr" { sopfr_p = true }
        if id == "mu" { mu_p = true }
        if id == "M3" { m3_p = true }
        if id == "J2" { j2_p = true }
        if id == "n" { n_p = true }
        i = i + 1
    }
    let mut out: array = []
    if sigma_p && phi_p {
        out.push(Candidate {
            slug: "paradigm_shift.adjoint.sigma_phi_pair", family: "paradigm_shift",
            proposed: "Adjoint pair: sigma ↔ phi (multiplicative dual; sigma·phi=J2 verified at n=6). Atlas-baked adjoint family.",
            cite: ["sigma", "phi"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if tau_p && sopfr_p {
        out.push(Candidate {
            slug: "paradigm_shift.adjoint.tau_sopfr_pair", family: "paradigm_shift",
            proposed: "Adjoint pair: tau ↔ sopfr (count vs sum of prime factors; 4 vs 5 at n=6). Hypothesis: tau and sopfr are arithmetic-information duals.",
            cite: ["tau", "sopfr"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if mu_p && m3_p {
        out.push(Candidate {
            slug: "paradigm_shift.adjoint.mu_m3_pair", family: "paradigm_shift",
            proposed: "Adjoint pair: mu ↔ M3 (Möbius vs Mersenne; 1 vs 7 at n=6). Hypothesis: number-theoretic duality across squarefree-status and prime-test.",
            cite: ["mu", "M3"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if j2_p && n_p {
        out.push(Candidate {
            slug: "paradigm_shift.adjoint.j2_n_squared", family: "paradigm_shift",
            proposed: "Adjoint pair: J2 ↔ n² (Jordan totient vs square; 24 vs 36 at n=6). Hypothesis: J2 = n²·prod(1−1/p²) is the totient-cousin of n² along the squarefree filter.",
            cite: ["J2", "n"], fire_needed: false, fire_estimate_usd: 0.0
        })
    }
    if len(out) == 0 { return empty_candidate_list() }
    return out
}
pub fn lens_apply_paradigm_shift_op_lift(view: AtlasView) -> array {
    // C-1.d strengthened — atlas-anchored scalar → vector/tensor lift.
    let n = len(view.p_nodes)
    if n == 0 { return empty_candidate_list() }
    let mut sigma_p = false
    let mut phi_p = false
    let mut tau_p = false
    let mut mu_p = false
    let mut i = 0
    while i < n {
        let id = view.p_nodes[i].id
