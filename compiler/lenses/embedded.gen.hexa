        let e = view.p_nodes[i].edges
        let mut found = false
        let dn = len(e.derives)
        let mut k = 0
        while k < dn { if e.derives[k] == id { found = true; break } k = k + 1 }
        if found == false {
            let pn = len(e.depends_on)
            k = 0
            while k < pn { if e.depends_on[k] == id { found = true; break } k = k + 1 }
        }
        if found { self_cites = self_cites + 1 }
        i = i + 1
    }
    let mut mu_p = false
