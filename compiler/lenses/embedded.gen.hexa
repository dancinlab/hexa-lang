    // C-1.d strengthened — grade inversion count + sigma-monotone anchor
    // hypothesis.
    let n = len(view.p_nodes)
    if n < 2 { return empty_candidate_list() }
    let mut inversions = 0
    let mut prev = view.p_nodes[0].grade.value
    let mut i = 1
    while i < n {
        let g = view.p_nodes[i].grade.value
        if g >= 0 && prev >= 0 && g < prev { inversions = inversions + 1 }
        prev = g
