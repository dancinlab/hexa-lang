// HEXA Native Compiler — Phase 1-extension absorption: cli_spec archive smoke
//
// @version 0.1.0
// @capabilities [pure]
//
// Run:
//   hexa run compiler/cli_spec_archive/static_index_test.hexa

use "compiler/cli_spec_archive/embed"
use "compiler/cli_spec_archive/embedded.gen"
use "compiler/cli_spec_archive/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("phase1-ext cli_spec archive embed smoke")
    println("  hash:         " + CLI_SPEC_ARCHIVE_HASH)
    println("  generated_at: " + CLI_SPEC_ARCHIVE_GENERATED_AT)
    println("  source_count: " + to_string(CLI_SPEC_ARCHIVE_SOURCE_COUNT))
    println("  sections:     " + to_string(len(CLI_SPEC_SECTIONS)))
    println("  subcommands:  " + to_string(len(CLI_SPEC_SUBCOMMAND_NAMES)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",                _is_hex64(CLI_SPEC_ARCHIVE_HASH),                  fails)
    _check("generated_at non-empty",             len(CLI_SPEC_ARCHIVE_GENERATED_AT) > 0,            fails)
    _check("source_count > 0",                   CLI_SPEC_ARCHIVE_SOURCE_COUNT > 0,                 fails)
    _check("sections match source_count",        len(CLI_SPEC_SECTIONS) == CLI_SPEC_ARCHIVE_SOURCE_COUNT, fails)
    _check("subcommands list non-empty",         len(CLI_SPEC_SUBCOMMAND_NAMES) > 0,                fails)

    // Top-level sections present per the schema (2026-04-20).
    let must_have = ["_meta", "projects", "env", "global_flags", "exit_codes", "audit", "subcommands"]
    let mh_n = len(must_have)
    let mut h = 0
    while h < mh_n {
        let want = must_have[h]
        let e = cli_spec_archive_lookup(want)
        _check("section present: " + want,       e.name == want && len(e.raw_json) > 0,             fails)
        h = h + 1
    }

    let miss = cli_spec_archive_lookup("NOT-A-REAL-SECTION")
    _check("lookup miss → name == \"\"",        miss.name == "",                                   fails)

    // Section names list helper.
    let sn = cli_spec_archive_section_names()
    _check("section_names() count == sections",  len(sn) == len(CLI_SPEC_SECTIONS),                 fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(CLI_SPEC_SECTIONS)) + "/" + to_string(CLI_SPEC_ARCHIVE_SOURCE_COUNT) + " sections, " + to_string(len(CLI_SPEC_SUBCOMMAND_NAMES)) + " subcmds, hash=" + CLI_SPEC_ARCHIVE_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
