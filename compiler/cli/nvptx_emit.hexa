// nvptx_emit.hexa — standalone CLI: `.hexa` @gpu_kernel source → PTX.
//
// Thin runnable wrapper over `compiler/cli/build_nvptx`'s library entry
// `build_nvptx_emit_driver(src_path, sm_arch) -> int` (which runs
// lex → parse → lower → lower_hir → codegen_emit_ptx_for_sm and writes
// `<src>.ptx`). build_nvptx.hexa itself is main-less (it is `use`d by
// nvptx_p3_module_loader_bridge_test.hexa, so it must NOT carry a `main`);
// this sibling adds the executable entry so users can emit PTX from a
// source file WITHOUT routing through `self/main.hexa::cmd_build`'s
// NVPTX branch (that single-CLI path stays gated until Path C links the
// compiler pipeline into the bootstrap binary). Build + run:
//
//   hexa build compiler/cli/nvptx_emit.hexa -o nvptx_emit
//   ./nvptx_emit kernel.hexa sm_80        # writes kernel.hexa.ptx
//
// @rfc 071  @phase P3-usable  @sister compiler/cli/build_nvptx.hexa
use "compiler/cli/build_nvptx"

fn main() {
    let av = args()
    if len(av) < 2 {
        println("usage: nvptx_emit <src.hexa> [sm_arch]")
        println("  sm_arch default = sm_80 (also sm_90 / sm_120); writes <src>.ptx")
        return
    }
    let src = av[1]
    let sm  = if len(av) >= 3 { av[2] } else { "sm_80" }
    let rc  = build_nvptx_emit_driver(src, sm)
    if rc != 0 {
        println("nvptx_emit: FAILED (rc=" + str(rc) + ") for " + src)
    }
}
