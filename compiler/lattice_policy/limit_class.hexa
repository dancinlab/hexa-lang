// absorbed from ~/core/hexa-bio/LIMIT_BREAKTHROUGH.md (Apache-2.0, hexa-bio v1.1.0)
//
// compiler/lattice_policy/limit_class.hexa — 4-way taxonomy for real-limit
// classification per LATTICE_POLICY.md §1.2 audits.
//
// Definitions (one-line each):
//   HARD_WALL            — violation requires breaking known physics / biochemistry
//                          (e.g. c, h-bar, Carnot, ATP ~30.5 kJ/mol, Smoluchowski).
//   SOFT_WALL            — engineering/economic ceiling; improvable within physics
//                          (e.g. $2.6B/drug, 10% Phase-I->approval, ASML throughput).
//   BREAKABLE_WITH_TECH  — physics permits more, current tech is the bottleneck;
//                          named tech vector exists (e.g. CRISPR off-target via
//                          prime-editor, Levinthal-practical via AlphaFold).
//   UNCLEAR              — wall type not yet decidable from current evidence;
//                          requires further audit (e.g. Levinthal-physical kinetics).
//
// The taxonomy is enum-shaped but encoded as a struct with a `kind` discriminant
// string, matching hexa-lang's current style (cf. compiler/n6_lattice/verify.hexa
// VerifyCheck / VerifyResult). Each ctor returns a frozen instance carrying both
// the kind tag and a rationale phrase.
//
// Parse direction: `parse_limit_class(s)` accepts any of the four canonical
// uppercase kind strings; anything else yields the UNCLEAR sentinel with
// rationale "unrecognized class string". This keeps the function total without
// introducing an Option/Result type just for the taxonomy.

pub struct LimitClass {
    kind: string,
    rationale: string
}

pub fn limit_class_hard_wall() -> LimitClass {
    return LimitClass {
        kind:      "HARD_WALL",
        rationale: "violation requires breaking known physics or biochemistry"
    }
}

pub fn limit_class_soft_wall() -> LimitClass {
    return LimitClass {
        kind:      "SOFT_WALL",
        rationale: "engineering or economic ceiling, improvable within physics"
    }
}

pub fn limit_class_breakable_with_tech() -> LimitClass {
    return LimitClass {
        kind:      "BREAKABLE_WITH_TECH",
        rationale: "physics permits more; current tech is the bottleneck"
    }
}

pub fn limit_class_unclear() -> LimitClass {
    return LimitClass {
        kind:      "UNCLEAR",
        rationale: "wall type not yet decidable from current evidence"
    }
}

// parse_limit_class — text -> LimitClass (total; unrecognized -> UNCLEAR).
pub fn parse_limit_class(s: string) -> LimitClass {
    if s == "HARD_WALL"           { return limit_class_hard_wall() }
    if s == "SOFT_WALL"           { return limit_class_soft_wall() }
    if s == "BREAKABLE_WITH_TECH" { return limit_class_breakable_with_tech() }
    if s == "UNCLEAR"             { return limit_class_unclear() }
    return LimitClass {
        kind:      "UNCLEAR",
        rationale: "unrecognized class string"
    }
}

// limit_class_to_string — LimitClass -> canonical uppercase tag.
pub fn limit_class_to_string(c: LimitClass) -> string {
    return c.kind
}
