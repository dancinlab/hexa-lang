// HEXA Native Compiler — Wave 1 absorption: calculators smoke
//
// Run:
//   hexa run compiler/calculators/static_index_test.hexa

use "compiler/calculators/embed"
use "compiler/calculators/embedded.gen"
use "compiler/calculators/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 calculators embed smoke")
    println("  hash:         " + CALCULATORS_HASH)
    println("  generated_at: " + CALCULATORS_GENERATED_AT)
    println("  source_count: " + to_string(CALCULATORS_SOURCE_COUNT))
    println("  entries:      " + to_string(len(CALCULATORS)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(CALCULATORS_HASH),                       fails)
    _check("generated_at non-empty",     len(CALCULATORS_GENERATED_AT) > 0,                 fails)
    _check("source_count > 0",           CALCULATORS_SOURCE_COUNT > 0,                      fails)
    _check("entries match source_count", len(CALCULATORS) == CALCULATORS_SOURCE_COUNT,      fails)

    let sedi = calculators_by_project("SEDI")
    _check("project SEDI has entries",   len(sedi) > 0,                                     fails)

    let canon = calculators_by_project("CANON")
    _check("project CANON has entries",  len(canon) > 0,                                    fails)

    let miss = calculators_lookup("NOT-A-PROJECT", "nope")
    _check("lookup miss → project == \"\"", miss.project == "",                             fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(CALCULATORS)) + "/" + to_string(CALCULATORS_SOURCE_COUNT) + " entries, hash=" + CALCULATORS_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
