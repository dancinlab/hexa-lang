// HEXA Native Compiler — link pass: hexa_ld v1.1 smoke test
//
// @version 0.2.0
// @capabilities [fs_read, fs_write, shell]
// @allow-bare-exec-file
// @allow-silent-exit-file
// @allow-silent-catch-file
// @allow-relop-banned-file
//
// End-to-end test for `compiler/link/hexa_ld.hexa`:
//
//   ELF case (Linux):
//   1. Synthesize a hand-written `_start` assembly source that performs
//      `exit(0)` via the Linux x86_64 syscall ABI.
//   2. Assemble it with system `as --64`.
//   3. Drive `link()` → static ELF64.
//   4. `file <out>` substring match for "ELF 64-bit LSB executable".
//   5. Linux only: chmod +x and exec — expect rc=0.
//
//   Mach-O case (macOS arm64):
//   1. Synthesize an `_main` assembly source that performs the arm64
//      `exit(0)` SVC ABI:
//          mov x16, #1   ; sys_exit
//          mov x0,  #0   ; status
//          svc #0x80
//   2. Assemble with Apple `as -arch arm64`.
//   3. Drive `link()` → MH_EXECUTE Mach-O.
//   4. `file <out>` substring match for "Mach-O 64-bit executable arm64".
//   5. Note ad-hoc codesign requirement; exec is best-effort —
//      kernel will refuse without codesign on Apple Silicon.
//
// Both cases skip cleanly on the wrong host (linux skips Mach-O,
// macOS-x86 skips both, etc.).
//
// Run:
//   hexa run compiler/link/hexa_ld_test.hexa

import "../../stdlib/portable_fs.hexa"
import "./hexa_ld.hexa"

// ── tiny string utility (substring match without stdlib regex) ──────

fn _contains(hay: string, needle: string) -> bool {
    if len(needle) == 0 { return true }
    let h = hay.chars()
    let n = needle.chars()
    let hn = len(h)
    let nn = len(n)
    if nn > hn { return false }
    let mut i = 0
    while i + nn < hn + 1 {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if h[i + j] != n[j] {
                ok = false
                break
            }
            j = j + 1
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

// ── env probe: do we have system `as`? ──────────────────────────────

fn _have_system_as() -> bool {
    let probe = exec("command -v as 2>/dev/null").trim()
    return len(probe) > 0
}

fn _is_linux() -> bool {
    let u = exec("uname -s 2>/dev/null").trim()
    return u == "Linux"
}

fn _is_macos() -> bool {
    let u = exec("uname -s 2>/dev/null").trim()
    return u == "Darwin"
}

fn _is_macos_arm64() -> bool {
    if !_is_macos() { return false }
    let m = exec("uname -m 2>/dev/null").trim()
    return m == "arm64"
}

// ── synthesize the .s source and assemble ──────────────────────────

let _ASM_SOURCE_GAS_INTEL = "" +
    ".intel_syntax noprefix\n" +
    ".section .text\n" +
    ".globl _start\n" +
    "_start:\n" +
    "    mov rax, 60\n" +     // sys_exit
    "    xor rdi, rdi\n" +    // status = 0
    "    syscall\n"

// AT&T syntax fallback for hosts whose `as` rejects intel_syntax.
let _ASM_SOURCE_GAS_ATT = "" +
    ".section .text\n" +
    ".globl _start\n" +
    "_start:\n" +
    "    movq $60, %rax\n" +  // sys_exit
    "    xorq %rdi, %rdi\n" + // status = 0
    "    syscall\n"

fn _assemble(s_path: string, o_path: string) -> bool {
    let cmd = "as --64 -o '" + o_path + "' '" + s_path + "' 2>&1"
    let out_msg = exec(cmd)
    let trimmed = out_msg.trim()
    let sz = pfs_file_size(o_path)
    if sz < 1 {
        println("    as failed: " + trimmed)
        return false
    }
    return true
}

// arm64 macOS exit(0):
//   mov  x16, #1     ; sys_exit
//   mov  x0,  #0     ; status = 0
//   svc  #0x80
let _ASM_SOURCE_MACHO_ARM64 = "" +
    ".section __TEXT,__text\n" +
    ".globl _main\n" +
    ".p2align 2\n" +
    "_main:\n" +
    "    mov x16, #1\n" +
    "    mov x0, #0\n" +
    "    svc #0x80\n"

fn _assemble_macho(s_path: string, o_path: string) -> bool {
    // Apple `as` on arm64 ignores --64; pass -arch arm64 explicitly.
    let cmd = "as -arch arm64 -o '" + o_path + "' '" + s_path + "' 2>&1"
    let out_msg = exec(cmd)
    let trimmed = out_msg.trim()
    let sz = pfs_file_size(o_path)
    if sz < 1 {
        println("    as (mach-o) failed: " + trimmed)
        return false
    }
    return true
}

// ── main test driver ───────────────────────────────────────────────

fn main() {
    println("══════════════════════════════════════════════")
    println("  hexa_ld v1.2 — ELF + Mach-O (ad-hoc signed) Linker Smoke Test")
    println("══════════════════════════════════════════════")

    let mut ok = true               // ELF case ok (true if PASS or SKIP)
    let mut elf_ran = false

    if !_have_system_as() {
        println("")
        println("  ELF SKIPPED: system `as` (GNU assembler) not on PATH.")
    } else {
        let s_path = "/tmp/hexa_ld_smoke.s"
        let o_path = "/tmp/hexa_ld_smoke.o"
        let exe    = "/tmp/hexa_ld_smoke.exe"

        write_file(s_path, _ASM_SOURCE_GAS_INTEL)
        let mut asm_ok = _assemble(s_path, o_path)
        if !asm_ok {
            println("  retrying with AT&T syntax...")
            write_file(s_path, _ASM_SOURCE_GAS_ATT)
            asm_ok = _assemble(s_path, o_path)
        }
        if !asm_ok {
            println("")
            println("  ELF SKIPPED: system `as` could not assemble the ELF fixture.")
            println("  (likely macOS toolchain `as` which does not target ELF64).")
        } else {
            elf_ran = true
            let osize = pfs_file_size(o_path)
            println("  fixture: " + o_path + " (" + to_string(osize) + " bytes)")

            let rc = link(o_path, exe)
            if rc != 0 {
                println("  FAIL: link() returned non-zero rc=" + to_string(rc))
                println("        (1=parse-fail, 2=no-entry-symbol, 3=write-fail)")
                ok = false
            } else {
                let elf_size = pfs_file_size(exe)
                println("  emitted: " + exe + " (" + to_string(elf_size) + " bytes)")

                let file_out = exec("file '" + exe + "' 2>&1").trim()
                println("  file: " + file_out)

                if !_contains(file_out, "ELF 64-bit") {
                    println("  FAIL: `file` output does not include `ELF 64-bit`.")
                    ok = false
                } else {
                    println("  ok: format = ELF 64-bit")
                }
                if !_contains(file_out, "LSB") {
                    println("  FAIL: `file` output does not include `LSB`.")
                    ok = false
                } else {
                    println("  ok: byte order = LSB (little-endian)")
                }
                if !_contains(file_out, "executable") {
                    println("  FAIL: `file` output does not include `executable`.")
                    ok = false
                } else {
                    println("  ok: type = executable")
                }

                if _is_linux() {
                    let chmod_rc = exec("chmod +x '" + exe + "' 2>&1").trim()
                    if len(chmod_rc) > 0 { println("  chmod note: " + chmod_rc) }
                    let probe = exec("'" + exe + "' ; echo __RC=$?").trim()
                    if !_contains(probe, "__RC=0") {
                        println("  FAIL: emitted ELF did not exit 0 — got: " + probe)
                        ok = false
                    } else {
                        println("  ok: emitted ELF executed and returned 0")
                    }
                } else {
                    println("  EXEC_SKIPPED: non-Linux host — cannot run ELF directly.")
                }
            }
        }
    }
    if !elf_ran {
        println("  (ELF case skipped — Mach-O case still attempted below.)")
    }

    // ── Mach-O case (macOS arm64 only) ──
    let mut macho_ok = true
    if _is_macos_arm64() {
        println("")
        println("──────────── Mach-O arm64 case ────────────")
        let s_m = "/tmp/hexa_ld_macho_smoke.s"
        let o_m = "/tmp/hexa_ld_macho_smoke.o"
        let e_m = "/tmp/hexa_ld_macho_smoke.exe"

        write_file(s_m, _ASM_SOURCE_MACHO_ARM64)
        let asm_m_ok = _assemble_macho(s_m, o_m)
        if !asm_m_ok {
            println("  SKIPPED: Apple `as -arch arm64` could not assemble.")
        } else {
            let omsz = pfs_file_size(o_m)
            println("  fixture: " + o_m + " (" + to_string(omsz) + " bytes)")

            let rc_m = link(o_m, e_m)
            if rc_m != 0 {
                println("  FAIL: link() Mach-O returned rc=" + to_string(rc_m))
                macho_ok = false
            } else {
                let macho_size = pfs_file_size(e_m)
                println("  emitted: " + e_m + " (" + to_string(macho_size) + " bytes)")

                let f_m = exec("file '" + e_m + "' 2>&1").trim()
                println("  file: " + f_m)
                if !_contains(f_m, "Mach-O 64-bit executable") {
                    println("  FAIL: `file` does not report Mach-O 64-bit executable.")
                    macho_ok = false
                } else {
                    println("  ok: format = Mach-O 64-bit executable")
                }
                if !_contains(f_m, "arm64") {
                    println("  FAIL: `file` does not report arm64.")
                    macho_ok = false
                } else {
                    println("  ok: arch = arm64")
                }

                // v1.2 contract: hexa_ld emits a self-signed binary;
                // we run it directly. NO post-link codesign shellout —
                // the whole point of v1.2 is that hexa_ld emits valid
                // ad-hoc CDHash inline (CSMAGIC_EMBEDDED_SIGNATURE +
                // CSMAGIC_CODEDIRECTORY w/ per-4-KiB SHA-256 hashes).
                // @allow-bare-exec @allow-silent-exit  (lints below)
                let probe = exec("'" + e_m + "' ; echo __RC=$?").trim()
                if _contains(probe, "__RC=0") {
                    println("  ok: emitted Mach-O exited 0 (kernel CDHash accepted)")
                } else {
                    println("  EXEC_BLOCKED: kernel refused to run.")
                    println("    probe: " + probe)
                    // diagnostics: ask the system codesign tool to
                    // verify what we emitted; a CDHash mismatch or blob
                    // structure error shows up here.
                    // @allow-bare-exec @allow-silent-exit
                    let cs_v = exec("codesign -v -v '" + e_m + "' 2>&1").trim()
                    println("    codesign -v -v: " + cs_v)
                    // @allow-bare-exec @allow-silent-exit
                    let cs_d = exec("codesign -d -v '" + e_m + "' 2>&1").trim()
                    println("    codesign -d -v: " + cs_d)
                    macho_ok = false
                }
            }
        }
    } else {
        println("")
        println("  MACHO_SKIPPED: not running on macOS arm64.")
    }

    println("")
    println("══════════════════════════════════════════════")
    let final_ok = ok && macho_ok
    if final_ok {
        println("PASS: hexa_ld v1.2 emits valid ELF64 + Mach-O 64 (ad-hoc signed) executables.")
    } else {
        println("FAIL: hexa_ld v1.2 contract broken — see lines above.")
    }
    println("══════════════════════════════════════════════")
    if !final_ok { exit(1) }
    exit(0)
}
