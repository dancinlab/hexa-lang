// absorbed from ~/core/anima/anima/config/consciousness_laws.json (MIT, dancinlab 2026-05-14)
//
// compiler/atlas/anima_main.hexa — CLI shim for anima atlas data.
//
// Usage:
//   hexa anima-show psi-constants    # 11 Ψ-constant @C rows
//   hexa anima-show psi-laws         # 14 runtime gate @L rows (L1..L14)
//   hexa anima-show cdesm            # 6 CDESM channel @C rows (formerly "hexad" —
//                                    # renamed to dodge the argv_skip starts_with("hexa")
//                                    # interpreter-binary heuristic that eats `hexa*` verbs)
//   hexa anima-show all              # all 31 rows
//   hexa anima-show help
//
// Each row prints as its single-line raw payload (the @C/@L header line
// only). Multi-line provenance is suppressed for terminal readability;
// use `hexa atlas dump <id>` for full provenance.

import "compiler/atlas/anima_psi.gen.hexa"
import "compiler/atlas/anima_hexad.gen.hexa"
use "self/stdlib/argv_skip"

fn _cli() -> [string] {
    let raw = args()
    let mut out: [string] = []
    let mut i = skip_invocation_prefix(raw)
    while i < len(raw) {
        out.push(raw[i])
        i = i + 1
    }
    return out
}

fn _first_line(s) {
    let nl = s.find("\n")
    if nl < 0 { return s }
    return s.substring(0, nl)
}

fn _print_help() {
    println("hexa anima-show — anima Ψ-constants + laws + CDESM channels (MIT, dancinlab 2026-05-14)")
    println("")
    println("usage:")
    println("  hexa anima-show <verb>")
    println("")
    println("verbs:")
    println("  psi-constants   11 Ψ-constants — alpha/balance/steps/entropy/gate_train/gate_infer/")
    println("                  gate_micro/f_critical/f_lethal/bio_noise/soc_glacial")
    println("  psi-laws        14 runtime gate laws (L1 holo_positivity .. L14)")
    println("  cdesm           6 CDESM channel constants (c/d/w/s/m/e)")
    println("  all             print all 31 rows")
    println("  help")
}

fn _print_nodes(nodes) {
    let mut i = 0
    while i < len(nodes) {
        println(_first_line(nodes[i].raw))
        i = i + 1
    }
}

fn main(args) {
    let argv = _cli()
    if len(argv) == 0 || argv[0] == "help" || argv[0] == "--help" || argv[0] == "-h" {
        _print_help()
        return
    }
    let verb = argv[0]
    if verb == "psi-constants" {
        _print_nodes(anima_psi_constants())
        println("# total: " + str(anima_psi_constants_count()) + " @C rows")
        return
    }
    if verb == "psi-laws" {
        _print_nodes(anima_psi_laws())
        println("# total: " + str(anima_psi_laws_count()) + " @L rows")
        return
    }
    if verb == "cdesm" {
        _print_nodes(anima_hexad_constants())
        println("# total: " + str(anima_hexad_constants_count()) + " @C rows")
        return
    }
    if verb == "all" {
        _print_nodes(anima_psi_constants())
        _print_nodes(anima_psi_laws())
        _print_nodes(anima_hexad_constants())
        let total = anima_psi_constants_count() + anima_psi_laws_count() + anima_hexad_constants_count()
        println("# total: " + str(total) + " rows (11 @C + 14 @L + 6 @C)")
        return
    }
    println("error: unknown verb '" + verb + "' — try `hexa anima-show help`")
}
