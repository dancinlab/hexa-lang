// HEXA Native Compiler — Wave 1 doctrine audit (CLI dispatcher)
//
// @version 0.1.0
// @capabilities [pure, fs_read]
//
// Standalone dispatcher for the two doctrine audits ported from
// hexa-matter v1.2.0 (MIT). Lets agents run
//
//   hexa run compiler/atlas/audit_main.hexa external-entity
//   hexa run compiler/atlas/audit_main.hexa anchor
//   hexa run compiler/atlas/audit_main.hexa all
//
// without touching self/main.hexa. Future CLI surface (per the absorption
// plan §4.1 / §5): `hexa atlas audit --doctrine` and `hexa atlas audit
// --anchors` should dispatch here.
//
// Corpus source policy (2026-05-14):
//   `compiler/atlas/static_index` materializes 6,594 nodes at module-load.
//   Under `hexa run` (interpreter) that parse+typecheck of 7,451 deeply
//   nested struct literals hangs >10 min. The codegen path (AOT-compiled
//   binary) is fast — the const arrays land as rodata at 0 ms.
//
//   For the interpreter-dispatched CLI verb, this module reads
//   `~/.hx/data/atlas.overlay.n6` via `parse_atlas_file()` instead. That
//   covers the overlay corpus (drill output + sibling absorption appends)
//   in ~3 s. The full 6,594-node rodata view will be re-enabled once
//   `static_index` gets a lazy/streaming loader. Audit modules themselves
//   stay rodata-agnostic — they consume an `[AtlasNode]` parameter.

use "compiler/atlas/parser"
use "compiler/atlas/external_entity_audit"
use "compiler/atlas/anchor_audit"
use "self/stdlib/argv_skip"

let _OVERLAY_PATH: string = "/Users/ghost/.hx/data/atlas.overlay.n6"

fn _load_corpus() -> array {
    // Read the overlay corpus. If absent (fresh install), return empty —
    // the audits still run and report 0 nodes scanned.
    if !file_exists(_OVERLAY_PATH) {
        return []
    }
    return parse_atlas_file(_OVERLAY_PATH, "atlas.overlay.n6")
}

pub fn audit_external_entities() -> AuditResult {
    return audit_external_entities_in(_load_corpus())
}

pub fn audit_anchors() -> AuditResult {
    return audit_anchors_in(_load_corpus())
}

fn _run_external() -> i64 {
    let r = audit_external_entities()
    println(audit_result_to_text(r))
    if r.pass { return 0 }
    return 1
}

fn _run_anchor() -> i64 {
    let r = audit_anchors()
    println(anchor_audit_to_text(r))
    if r.pass { return 0 }
    return 1
}

fn _run_all() -> i64 {
    let a = _run_external()
    let b = _run_anchor()
    if a != 0 { return a }
    return b
}

fn _usage() {
    println("usage: hexa run compiler/atlas/audit_main.hexa <verb>")
    println("  verbs: external-entity | anchor | all")
}

fn _cli() -> [string] {
    let raw = args()
    let mut out: [string] = []
    let mut i = skip_invocation_prefix(raw)
    while i < len(raw) {
        out.push(raw[i])
        i = i + 1
    }
    return out
}

fn main(args: array) {
    let argv = _cli()
    if len(argv) < 1 {
        _usage()
        exit(2)
    }
    let verb = to_string(argv[0])
    let mut rc: i64 = 0
    if verb == "external-entity" { rc = _run_external() }
    else if verb == "anchor"     { rc = _run_anchor() }
    else if verb == "all"        { rc = _run_all() }
    else {
        _usage()
        rc = 2
    }
    exit(rc)
}
