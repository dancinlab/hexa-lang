// --- accessors ------------------------------------------------------------

pub fn materials_limits() -> [AtlasNode] { return MATERIALS_LIMITS }

pub fn materials_limits_count() -> i64 { return len(MATERIALS_LIMITS) }

// materials_limits_by_class — linear scan over MATERIALS_LIMITS, filter on
// the `class: <CLS>` continuation line in each node's raw payload.
// Accepts the canonical 4 LimitClass tags ("HARD_WALL", "SOFT_WALL",
// "BREAKABLE_WITH_TECH", "UNCLEAR"); unrecognized inputs return [].
pub fn materials_limits_by_class(cls: string) -> [AtlasNode] {
    let needle = "class: " + cls
    let nodes = MATERIALS_LIMITS
    let n = len(nodes)
    let out = []
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node.raw.contains(needle) { out.push(node) }
        i = i + 1
    }
    return out
}
