// compiler/atlas/embed_fold.hexa — shared atlas absorption pipeline.
//
// Canonical fold-into-embedded.gen.hexa helpers, extracted from
// tool/atlas_cli.hexa per @D g_atlas_absorb_direct. EVERY atlas absorption
// verb (hexa atlas register --auto-pr {--from-verify|--from-drill}, hexa
// kick/drill --auto-pr, hexa loop --dfs auto-absorption, future absorbers)
// MUST use these helpers — no `.n6` staging shard, no inbox markdown
// intermediate, no atlas.overlay.n6 export-write.
//
// Pipeline (per absorber):
//   1. build in-memory AtlasNode struct-literal text   (embed_build_node_struct_text)
//   2. id-duplicate check against the embed             (embed_has_id, inside fold)
//   3. splice into the matching kind section before `]` (embed_fold_into)
//   4. (caller) git switch -c <branch> + git add + commit
//   5. (caller) gh pr create (or HTTP 201 API fallback)
//
// The PR diff IS the absorption record on embedded.gen.hexa. Promotion
// human-gated by PR review (PR-only fold-to-live; ref @D
// g_atlas_binary_builtin). NEVER claim "PR opened" unless gh rc=0
// or HTTP 201 (honest degrade).
//
// History: previously private to tool/atlas_cli.hexa (_hxesc /
// _build_node_struct_text / _fold_into_embedded /...). RFC 080 Phase O
// extracted as the 2nd consumer (DFS) arrived, per the original TODO note
// in atlas_cli.

use "self/stdlib/fs"               // read_file_safe / write_file_safe

// ── private — shell helpers (kept local to keep embed_fold self-contained) ──

fn _ef_shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _ef_exec_ok(cmd: string) -> bool {
    let out = exec("( " + cmd + " ) >/dev/null 2>&1 && echo __OK__ || echo __FAIL__").trim()
    return out == "__OK__"
}

// ── pub — string + struct-literal emission ──

// embed_hxesc — escape a string for use inside a hexa double-quoted string
// literal (backslash, then double-quote, then newline). Mirrors what
// tool/atlas_embed_gen emits when serializing AtlasNode.raw into
// embedded.gen.hexa.
pub fn embed_hxesc(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { out = out + "\\\\" }
        else if c == "\"" { out = out + "\\\"" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\r" { out = out + "\\r" }
        else if c == "\t" { out = out + "\\t" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

// embed_build_node_struct_text — direct in-memory node-generation. Produces
// the EXACT struct-literal text `tool/atlas_embed_gen.hexa::embed_atlas`
// would emit for one AtlasNode, ready to splice into
// compiler/atlas/embedded.gen.hexa. No `.n6` intermediate; no converter —
// the node is the hexa-source-form AtlasNode literal that the next compile
// will fold into the binary built-in atlas (@D g_atlas_binary_builtin).
pub fn embed_build_node_struct_text(kind: string, id: string, raw_body: string, source_file: string, source_line: i64) -> string {
    let raw_e = embed_hxesc(raw_body)
    let id_e = embed_hxesc(id)
    let sf_e = embed_hxesc(source_file)
    let kind_e = embed_hxesc(kind)
    return "    AtlasNode { kind: \"" + kind_e + "\", id: \"" + id_e +
           "\", raw: \"" + raw_e + "\", source_file: \"" + sf_e +
           "\", source_line: " + to_string(source_line) +
           ", grade: GradeInfo { value: -1, verified: false, breakthrough: false, hypothesis: false }" +
           ", edges: EdgeInfo { depends_on: [], derives: [], applications: [], equivalents: [], converges: [], verified_by: [], breakthroughs: [] } }"
}

// ── pub — path / section / dup-check ──

pub fn embed_gen_path(atlas_root: string) -> string {
    return atlas_root + "/compiler/atlas/embedded.gen.hexa"
}

pub fn embed_section_marker(kind: string) -> string {
    return "pub let ATLAS_" + kind + "_NODES: [AtlasNode] = ["
}

// embed_has_id — true iff embedded.gen.hexa text already contains a node
// with `id: "<id>"`. Cheap textual scan — the embed is one-line-per-node
// and ids are quoted right after `id: `.
pub fn embed_has_id(embed_text: string, id: string) -> bool {
    let needle = "id: \"" + id + "\""
    return embed_text.contains(needle)
}

// ── pub — fold into embedded.gen.hexa ──

// embed_fold_into — direct fold. Reads embedded.gen.hexa, finds the
// section for `kind`, inserts the new struct-literal line just before the
// closing `]`. Returns "" on success, otherwise an error message.
// No `.n6` intermediate; the AtlasNode literal IS the storage form.
pub fn embed_fold_into(embed_path: string, kind: string, node_text: string, id: string) -> string {
    let body = read_file_safe(embed_path)
    if len(body) == 0 {
        return "embedded.gen.hexa not readable or empty at: " + embed_path
    }
    if embed_has_id(body, id) {
        return "id already present in embedded atlas: " + id + " (refusing to duplicate)"
    }
    let marker = embed_section_marker(kind)
    let mi = body.index_of(marker)
    if mi < 0 {
        return "section marker not found in embedded.gen.hexa: " + marker
    }
    // Find the closing `]` of THIS section. The section's open bracket is the
    // `[` at end of marker; the closing `]` is the next line that is exactly `]`
    // at column 0 (matches the emitter convention; see tool/atlas_embed_gen).
    let mut scan = mi + len(marker)
    let mut close_at = -1
    let blen = len(body)
    while scan < blen {
        let nl = body.index_of("\n", scan)
        if nl < 0 { break }
        let line_start = scan
        let line = body.substring(line_start, nl)
        // The closing line is a bare `]` (no leading whitespace, no `,`).
        if line == "]" {
            close_at = line_start
            break
        }
        scan = nl + 1
    }
    if close_at < 0 {
        return "could not locate closing `]` for section " + kind + " in embedded.gen.hexa"
    }
    // Decide whether the prior element needs a `,`. Walk backward from
    // close_at and find the previous non-blank line; if it ends with `}`
    // (a struct literal), insert `,` before our line. The section opens
    // empty as `= [\n]`, in which case the immediately-prior line ends with `[`.
    let mut prev_end = close_at - 1
    while prev_end > 0 && body.substring(prev_end, prev_end + 1) == "\n" {
        prev_end = prev_end - 1
    }
    // Walk to start of that non-blank line.
    let mut prev_start = prev_end
    while prev_start > 0 && body.substring(prev_start - 1, prev_start) != "\n" {
        prev_start = prev_start - 1
    }
    let prev_line = body.substring(prev_start, prev_end + 1)
    let mut prefix = body.substring(0, close_at)
    let suffix = body.substring(close_at, blen)
    // If the prior line is an existing struct literal (ends with `}`), it
    // needs a trailing comma; we add it by appending `,\n` before our line.
    // If the section is empty (prev line ends with `[`), no comma.
    let mut splice = ""
    if prev_line.ends_with("}") {
        // Strip any trailing whitespace/newlines we want to preserve.
        // prefix currently includes prev_line plus the newline(s) before `]`.
        // We rewrite: drop content from prev_end+1 .. close_at, re-add as `,\n` + node + `\n`.
        let head = body.substring(0, prev_end + 1)
        splice = head + ",\n" + node_text + "\n"
        prefix = splice
    } else {
        // Empty section path. prev_line ends with `[`. Insert node_text then newline.
        splice = prefix + node_text + "\n"
        prefix = splice
    }
    let new_body = prefix + suffix
    write_file_safe(embed_path, new_body)
    return ""
}

// embed_id_slug — id-safe slug (lowercase, hyphen-separator, no spaces).
pub fn embed_id_slug(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let is_lo = c >= "a" && c <= "z"
        let is_up = c >= "A" && c <= "Z"
        let is_di = c >= "0" && c <= "9"
        if is_lo || is_di { out = out + c }
        else if is_up { out = out + c }
        else if c == "_" || c == "-" { out = out + c }
        else { out = out + "-" }
        i = i + 1
    }
    return out
}
