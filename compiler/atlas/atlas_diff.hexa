// HEXA Native Compiler — ATLAS R6: atlas diff
//
// @version 0.1.0
// @capabilities [pure, fs_read]
//
// `hexa atlas diff <A> <B>` — the atlas analog of `git diff`. Compares two
// atlas states keyed on (kind, id) and reports:
//   - removed : nodes only in A
//   - added   : nodes only in B
//   - changed : nodes in BOTH whose raw text differs (raw carries the
//               header + grade marker + every edge line, so a raw diff
//               surfaces value / grade / edge changes)
//
// Sources A / B may be EITHER a plain `.n6` export (`hexa atlas export`
// output) OR an `embedded.gen.hexa` file (the runtime SSOT, where each
// node's `.n6` block is escaped inside a struct literal). The loader
// auto-detects: a file carrying `raw: "` markers is treated as an embed
// (extract → parse); anything else is parsed as plain n6 text. This is
// strictly READ-ONLY — it never writes either source.
//
// Reuses the canonical parser (`parse_atlas_string`) + the embed raw-block
// extractor (`_extract_raw_blocks`) — no parser is duplicated here.

use "compiler/atlas/parser"
use "compiler/atlas/static_index"

// load_atlas_source — read `path` and return its AtlasNodes. Auto-detects
// embedded.gen.hexa (has `raw: "` struct-literal markers → extract the
// embedded .n6 stream first) vs a plain `.n6` export (parse directly).
pub fn load_atlas_source(path: string) -> array {
    let text = read_file(path)
    if len(text) == 0 { return [] }
    let base = _diff_basename(path)
    // Embed detection: embedded.gen.hexa emits one struct literal per line
    // with a `raw: "` field. A plain .n6 never contains that token.
    if text.index_of("raw: \"") >= 0 {
        let n6_stream = _extract_raw_blocks(text)
        return parse_atlas_string(n6_stream, base)
    }
    return parse_atlas_string(text, base)
}

fn _diff_basename(path: string) -> string {
    let n = len(path)
    let mut i = n
    while i > 0 {
        if path.substring(i - 1, i) == "/" { return path.substring(i, n) }
        i = i - 1
    }
    return path
}

fn _diff_key(node: AtlasNode) -> string {
    return node.kind + "|" + node.id
}

// AtlasDiff — the three keyed result buckets plus a same-count.
pub struct AtlasDiff {
    removed: array,   // [AtlasNode] only in A
    added:   array,   // [AtlasNode] only in B
    changed: array,   // [AtlasNode] (B-side) whose raw differs from A
    same:    i64      // count of identical (kind,id,raw) nodes
}

// diff_atlas — compare two node-sets keyed on (kind, id). raw differences
// (header / grade / edges / value) classify a shared key as `changed`.
pub fn diff_atlas(a_nodes: array, b_nodes: array) -> AtlasDiff {
    let mut a_map: any = {}
    let mut i = 0
    while i < len(a_nodes) {
        let na = a_nodes[i]
        a_map[_diff_key(na)] = na
        i = i + 1
    }
    let mut b_keys: any = {}
    let mut added = []
    let mut changed = []
    let mut same = 0
    i = 0
    while i < len(b_nodes) {
        let nb = b_nodes[i]
        let kb = _diff_key(nb)
        b_keys[kb] = true
        if has_key(a_map, kb) {
            let na = a_map[kb]
            if na.raw == nb.raw { same = same + 1 }
            else { changed.push(nb) }
        } else {
            added.push(nb)
        }
        i = i + 1
    }
    let mut removed = []
    i = 0
    while i < len(a_nodes) {
        let na = a_nodes[i]
        if !has_key(b_keys, _diff_key(na)) { removed.push(na) }
        i = i + 1
    }
    return AtlasDiff {
        removed: removed,
        added:   added,
        changed: changed,
        same:    same
    }
}

fn _diff_line(sign: string, n: AtlasNode) {
    println(sign + " @" + n.kind + " " + n.id)
}

// diff_report_text — human summary: per-node ± lines then a count footer.
pub fn diff_report_text(d: AtlasDiff) {
    let mut i = 0
    while i < len(d.removed) { _diff_line("-", d.removed[i]); i = i + 1 }
    i = 0
    while i < len(d.added) { _diff_line("+", d.added[i]); i = i + 1 }
    i = 0
    while i < len(d.changed) { _diff_line("~", d.changed[i]); i = i + 1 }
    println("--")
    println("removed " + to_string(len(d.removed))
        + " · added " + to_string(len(d.added))
        + " · changed " + to_string(len(d.changed))
        + " · same " + to_string(d.same))
}

fn _diff_json_ids(arr: array) -> string {
    let mut parts = []
    let mut i = 0
    while i < len(arr) {
        let n = arr[i]
        parts.push("{\"kind\":\"" + _diff_jq(n.kind) + "\",\"id\":\"" + _diff_jq(n.id) + "\"}")
        i = i + 1
    }
    return "[" + parts.join(",") + "]"
}

fn _diff_jq(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { out = out + "\\\\" }
        else if c == "\"" { out = out + "\\\"" }
        else if c == "\n" { out = out + "\\n" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

// diff_report_json — machine-readable summary with id lists per bucket.
pub fn diff_report_json(d: AtlasDiff) {
    println("{\"removed\":" + _diff_json_ids(d.removed)
        + ",\"added\":" + _diff_json_ids(d.added)
        + ",\"changed\":" + _diff_json_ids(d.changed)
        + ",\"counts\":{\"removed\":" + to_string(len(d.removed))
        + ",\"added\":" + to_string(len(d.added))
        + ",\"changed\":" + to_string(len(d.changed))
        + ",\"same\":" + to_string(d.same) + "}}")
}
