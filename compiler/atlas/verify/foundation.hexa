// compiler/atlas/verify/foundation.hexa — §1 N6-FOUNDATION verifier (Stage 1)
//
// @version 0.1.0
// @capabilities [pure]
//
// Hexa-native Stage 1 symbolic verification for atlas/MAIN.tape §1 N6-FOUNDATION
// anchor seed entries (s1_n6_foundational, s1_phi_sigma_unique, s1_perfect_number,
// s1_triangular_sigma_tau).
//
// Cross-link: atlas/MAIN.tape §1 · atlas/VERIFY.tape stage_1 · atlas/AGENTS.tape
// g_self_verify (atlas-built verifier mandatory) · stdlib/core/math.hexa
// (sigma · euler_phi · tau · sopfr primitives).
//
// Phase 2 first sprint — closes 4 anchor seeds 🟡 SUPPORTED-BY-CITATION → 🔵
// SUPPORTED-IDENTITY upon PASS.

import "stdlib/core/math.hexa"
import "compiler/n6_lattice/verify.hexa"
import "compiler/atlas/symbolic/divisor_field_theory.hexa"

// ── AtlasVerdict struct (shared across compiler/atlas/verify/*) ────────

pub struct AtlasVerdict {
    entry_id: string,         // atlas/MAIN.tape entry id (e.g. "s1_n6_foundational")
    domain: string,           // "§1 N6-FOUNDATION"
    tier: string,             // "🔵 SUPPORTED-IDENTITY" | "🔴 FALSIFIED" | etc
    pass: bool,
    detail: string,
    stage: string             // "Stage 1 — symbolic identity (hexa-native)"
}

fn _vd(entry_id: string, tier: string, pass: bool, detail: string) -> AtlasVerdict {
    return AtlasVerdict {
        entry_id: entry_id,
        domain: "§1 N6-FOUNDATION",
        tier: tier,
        pass: pass,
        detail: detail,
        stage: "Stage 1 — symbolic identity (hexa-native)"
    }
}

fn _tier_for(ok: bool) -> string {
    if ok { return "🔵 SUPPORTED-IDENTITY" }
    return "🔴 FALSIFIED"
}

// ── Helper: int array → "[a, b, c]" stringify (array stringify 빌트인 X) ─

fn _arr_to_string(arr: [int]) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(arr) {
        if i > 0 { s = s + ", " }
        s = s + to_string(arr[i])
        i = i + 1
    }
    s = s + "]"
    return s
}

// ──────────────────────────────────────────────────────────────────────
// s1_n6_foundational — n=6 yields σ=12 · φ=2 · τ=4 · sopfr=5
// ──────────────────────────────────────────────────────────────────────
// MAIN.tape: [@P n] base — sigma(6)=12 (perfect-number ⇔ 1+2+3+6),
// euler_phi(6)=2 (totients {1,5}), tau(6)=4 (divisors {1,2,3,6}),
// sopfr(6)=5 (2+3 prime sum). All four derived from stdlib/core/math primitives.

pub fn verify_s1_n6_foundational() -> AtlasVerdict {
    let sig = sigma(6)
    let phi = euler_phi(6)
    let tau_v = tau(6)
    let sop = sopfr(6)
    let ok = sig == 12 && phi == 2 && tau_v == 4 && sop == 5
    let detail = "σ(6)=" + to_string(sig) + " · φ(6)=" + to_string(phi) + " · τ(6)=" + to_string(tau_v) + " · sopfr(6)=" + to_string(sop) + " (expected 12 · 2 · 4 · 5)"
    return _vd("s1_n6_foundational", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_phi_sigma_unique — σ(n)·φ(n) = n·τ(n) iff n ∈ {1, 6}
// ──────────────────────────────────────────────────────────────────────
// MAIN.tape: T1-26 phi-sigma-unique carry. Sweep n ∈ [1, 30], verify hits = [1, 6].
// Spot-check: n=1 → 1·1 = 1·1 ✓ · n=6 → 12·2 = 6·4 = 24 ✓ · n=2 → 3·1 ≠ 2·2 ✓
// (All n ≠ 1, 6 must violate.)

pub fn verify_s1_phi_sigma_unique() -> AtlasVerdict {
    let mut hits: [int] = []
    let mut n = 1
    while n <= 30 {
        let lhs = sigma(n) * euler_phi(n)
        let rhs = n * tau(n)
        if lhs == rhs { hits.push(n) }
        n = n + 1
    }
    let ok = len(hits) == 2 && hits[0] == 1 && hits[1] == 6
    let detail = "σ·φ=n·τ hits in n∈[1,30]: " + _arr_to_string(hits) + " (expected [1, 6])"
    return _vd("s1_phi_sigma_unique", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_perfect_number — σ(n) = 2n iff n is perfect (n=6, 28, 496 in [2, 500])
// ──────────────────────────────────────────────────────────────────────
// MAIN.tape: Euclid-Euler theorem carry — even perfect ⇔ 2^(p-1)·(2^p-1) for
// Mersenne prime 2^p-1. Sweep verifies n=6 NOT unique (28, 496 also perfect).
// Honest C3 (per MAIN.tape s1_perfect_number): n=6 perfectness IS evidence,
// n=6 uniqueness is FALSE (sweep confirms).

pub fn verify_s1_perfect_number() -> AtlasVerdict {
    let mut hits: [int] = []
    let mut n = 2
    while n <= 500 {
        if sigma(n) == 2 * n { hits.push(n) }
        n = n + 1
    }
    let ok = len(hits) == 3 && hits[0] == 6 && hits[1] == 28 && hits[2] == 496
    let detail = "σ(n)=2n hits in n∈[2,500]: " + _arr_to_string(hits) + " (expected [6, 28, 496] per Euclid-Euler — n=6 NOT unique)"
    return _vd("s1_perfect_number", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_triangular_sigma_tau — n=6 = T_3 (3rd triangular) ∧ τ(6)=4
// ──────────────────────────────────────────────────────────────────────
// MAIN.tape: T1-33 triangular-sigma-tau carry. T_3 = 3·4/2 = 6, τ(6) = 4 = (3+1).
// Triangular T_k = k(k+1)/2; for k=3 → 6 matches n=6 atlas foundation.

pub fn verify_s1_triangular_sigma_tau() -> AtlasVerdict {
    let k = 3
    let t_k = k * (k + 1) / 2     // 3rd triangular = 6
    let n = 6
    let tau_n = tau(n)            // 4
    let ok = t_k == n && tau_n == k + 1
    let detail = "T_3 = 3·(3+1)/2 = " + to_string(t_k) + " · τ(6) = " + to_string(tau_n) + " · k+1 = " + to_string(k + 1) + " (T_3=6=n ∧ τ(6)=4=k+1)"
    return _vd("s1_triangular_sigma_tau", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_master_identity_geometric — σ·φ = n·τ = J₂ = 24 via geometric/group enumeration
// ──────────────────────────────────────────────────────────────────────
// MAIN.tape: §1 N6-FOUNDATION master identity wrap of compiler/n6_lattice/verify.hexa.
// 5 deductive checks (sigma via Euler V-E+F=2 on icosahedron · tau 4-state ladder ·
// phi binary dichotomy · J₂ via Cayley table closure of S₄ · master identity).
// 단순 arithmetic 이 아니라 geometric (icosahedron V/E/F count) + group-theoretic
// (Cayley closure) anchor 까지 포함 — strongest available Stage 1 verdict.

pub fn verify_s1_master_identity_geometric() -> AtlasVerdict {
    let r = verify_all()                  // VerifyResult from n6_lattice/verify.hexa
    let ok = r.verdict == "PASS"
    let detail = "n6_lattice/verify.hexa::verify_all() — " + r.verdict + " (" + to_string(r.n_pass) + "/" + to_string(r.n_total) + " checks: σ via Euler V-E+F=2 + τ 4-state + φ binary + J₂ via Cayley closure of S₄ + master identity σ·φ=n·τ=J₂=24)"
    return _vd("s1_master_identity_geometric", _tier_for(ok), ok, detail)
}

// ══════════════════════════════════════════════════════════════════════
// archive-TECS-L _tecsl carries — g_self_verify Phase-2 hexa-native verifiers
// ══════════════════════════════════════════════════════════════════════
// MAIN.tape cycle 035 merged 41 _tecsl @D verdicts; each honest_c3 records
// "🔵-eligible after a hexa-native Phase-2 verifier (g_self_verify)". The
// closed-form-bearing §1 entries below are exact-integer / finite-enumeration
// checkable hexa-native (zero external sympy/python — g_self_verify HARD).
// f_atlas_lattice_external HARD: n=6 is the OUTPUT of each NT constraint, not
// fed in as a lattice premise — the verifier sweeps the constraint over a
// range and reads off the solution set.
//
// Tier on PASS → 🔵 SUPPORTED-IDENTITY (reviewer-merge owns the MAIN.tape
// 🟠/🟡 → 🔵 tier upgrade + ~> supersedes; this is the ENGINE only).

// ──────────────────────────────────────────────────────────────────────
// s1_prime_pair_two_unique_tecsl — (p−1)(q−1)=2 ⇒ unique (p,q)=(2,3) ⇒ n=6
// ──────────────────────────────────────────────────────────────────────
// P-NEW Thm 1: the Diophantine (p−1)(q−1)=2 over primes has the unique
// unordered solution {2,3} (unique factorisation of 2 = 1×2). Finite
// enumeration over the prime grid; n = p·q = 6 the unique value.

pub fn verify_s1_prime_pair_two_unique_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut p = 2
    while p <= 60 {
        if is_prime(p) {
            let mut q = p
            while q <= 60 {
                if is_prime(q) {
                    if (p - 1) * (q - 1) == 2 {
                        sols.push(p * q)
                    }
                }
                q = q + 1
            }
        }
        p = p + 1
    }
    let ok = len(sols) == 1 && sols[0] == 6
    let detail = "(p−1)(q−1)=2 over prime pairs p≤q in [2,60]: n=p·q hits " + _arr_to_string(sols) + " (expected [6] — unique unordered {2,3} by unique-factorisation of 2; P-NEW Thm 1)"
    return _vd("s1_prime_pair_two_unique_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_semiprime_perfect_unique_tecsl — 6 unique semiprime perfect: σ(pq)=2pq
// ──────────────────────────────────────────────────────────────────────
// P-NEW Thm 2: σ(pq)=2pq ⟺ (1+p)(1+q)=2pq ⟺ (p−1)(q−1)=2 ⟺ (p,q)=(2,3).
// Sweep distinct-prime semiprimes; the only perfect one is 6.

pub fn verify_s1_semiprime_perfect_unique_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut p = 2
    while p <= 60 {
        if is_prime(p) {
            let mut q = p + 1
            while q <= 60 {
                if is_prime(q) {
                    let pq = p * q
                    if sigma(pq) == 2 * pq { sols.push(pq) }
                }
                q = q + 1
            }
        }
        p = p + 1
    }
    let ok = len(sols) == 1 && sols[0] == 6
    let detail = "σ(p·q)=2·p·q over distinct-prime semiprimes (p<q≤60): hits " + _arr_to_string(sols) + " (expected [6] — unique semiprime perfect; P-NEW Thm 2, Nielsen 2015 odd-perfect bound cite-only)"
    return _vd("s1_semiprime_perfect_unique_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_divisor_field_action_zero_tecsl — S(n)=0 ⟺ n=6 (unique zero)
// ──────────────────────────────────────────────────────────────────────
// S(n) = [σφ − nτ]² + [σ(n+φ) − nτ²]². Reuses symbolic/divisor_field_theory
// (compute_action / action_zero_solutions). MAIN.tape evidence: S(6)=
// [24−24]²+[96−96]²=0 and S(n)=0 ⟺ n=6 (singleton — n=1 has term2=σ(1+φ)−τ²
// = 1·2−1 = 1 ≠ 0, so 1 is NOT a zero of the FULL action). The sum-of-squares
// makes S(n)=0 a simultaneous double-constraint uniqueness statement.

pub fn verify_s1_divisor_field_action_zero_tecsl() -> AtlasVerdict {
    let sols = action_zero_solutions(300)
    let a6 = compute_action(6)
    let a1 = compute_action(1)
    let ok = len(sols) == 1 && sols[0] == 6 && a6.action == 0 && a6.term1 == 0 && a6.term2 == 0 && a1.action != 0
    let detail = "S(n)=[σφ−nτ]²+[σ(n+φ)−nτ²]²=0 in [1,300]: " + _arr_to_string(sols) + " (expected [6] — unique zero); S(6) t1=" + to_string(a6.term1) + " t2=" + to_string(a6.term2) + " action=" + to_string(a6.action) + " · S(1) action=" + to_string(a1.action) + " (≠0, double-constraint separates 1; symbolic/divisor_field_theory engine)"
    return _vd("s1_divisor_field_action_zero_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_tau_plus_2_eq_n_tecsl — τ(n)+2=n ⟺ n=6
// ──────────────────────────────────────────────────────────────────────
// Divisor-count bound τ(n) ≤ 2√n ⇒ τ(n)+2=n forces n ≤ 7; finite n∈[1,7]
// scan (verifier sweeps a generous [1,200] to also confirm no large solution).

pub fn verify_s1_tau_plus_2_eq_n_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 1
    while n <= 200 {
        if tau(n) + 2 == n { sols.push(n) }
        n = n + 1
    }
    let ok = len(sols) == 1 && sols[0] == 6
    let detail = "τ(n)+2=n in [1,200]: " + _arr_to_string(sols) + " (expected [6]; bound τ(n)≤2√n ⇒ n≤7, τ(6)=4, 4+2=6)"
    return _vd("s1_tau_plus_2_eq_n_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_sigma_n_plus_phi_eq_n_tau_sq_tecsl — σ(n)(n+φ(n))=n·τ(n)² ⟺ n=6 (n>1)
// ──────────────────────────────────────────────────────────────────────
// Second residual of the S(n)=0 system. σ(6)·(6+φ(6))=12·8=96 = 6·τ(6)²=6·16.

pub fn verify_s1_sigma_n_plus_phi_eq_n_tau_sq_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 2
    while n <= 300 {
        if sigma(n) * (n + euler_phi(n)) == n * tau(n) * tau(n) { sols.push(n) }
        n = n + 1
    }
    let ok = len(sols) == 1 && sols[0] == 6
    let detail = "σ(n)·(n+φ(n))=n·τ(n)² for n>1 in [2,300]: " + _arr_to_string(sols) + " (expected [6]; σ(6)·8=96=6·16)"
    return _vd("s1_sigma_n_plus_phi_eq_n_tau_sq_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_pnew_eq2_phi_sigma_tecsl — φ(σ(n))=τ(n) ⟶ {1,2,3,5,6}
// ──────────────────────────────────────────────────────────────────────
// P-NEW Appendix-A Eq#2 (= OEIS #2). Solution set computed by sweep.

pub fn verify_s1_pnew_eq2_phi_sigma_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 1
    while n <= 300 {
        if euler_phi(sigma(n)) == tau(n) { sols.push(n) }
        n = n + 1
    }
    let mut ok = len(sols) == 5
    if ok {
        if sols[0] != 1 { ok = false }
        if sols[1] != 2 { ok = false }
        if sols[2] != 3 { ok = false }
        if sols[3] != 5 { ok = false }
        if sols[4] != 6 { ok = false }
    }
    let detail = "φ(σ(n))=τ(n) in [1,300]: " + _arr_to_string(sols) + " (expected [1,2,3,5,6]; P-NEW Appendix-A Eq#2 / OEIS #2)"
    return _vd("s1_pnew_eq2_phi_sigma_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_pnew_eq7_ore_harmonic_tecsl — Ore harmonic H(n)=φ(n) ⟶ {1,6}
// ──────────────────────────────────────────────────────────────────────
// H(n)=n·τ(n)/σ(n). Integer form (no float): n·τ(n)=φ(n)·σ(n).

pub fn verify_s1_pnew_eq7_ore_harmonic_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 1
    while n <= 300 {
        if n * tau(n) == euler_phi(n) * sigma(n) { sols.push(n) }
        n = n + 1
    }
    let ok = len(sols) == 2 && sols[0] == 1 && sols[1] == 6
    let detail = "Ore H(n)=n·τ(n)/σ(n)=φ(n) (integer form n·τ=φ·σ) in [1,300]: " + _arr_to_string(sols) + " (expected [1,6]; P-NEW Eq#7 / OEIS #3)"
    return _vd("s1_pnew_eq7_ore_harmonic_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_pnew_eq8_sigma3_tecsl — σ₃(n)=τ(n)(2ⁿ−1) ⟶ {1,6}
// ──────────────────────────────────────────────────────────────────────
// Reuses symbolic/divisor_field_theory σ via dft, σ₃ computed locally
// (Σ d³). 2ⁿ−1 outgrows σ₃(n)/τ(n) for n>6 ⇒ finite; scan n∈[1,28]
// (2²⁸ stays within int range).

fn _sigma3(n: int) -> int {
    let mut s = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 { s = s + d * d * d }
        d = d + 1
    }
    return s
}

pub fn verify_s1_pnew_eq8_sigma3_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 1
    while n <= 28 {
        let lhs = _sigma3(n)
        let rhs = tau(n) * (pow(2, n) - 1)
        if lhs == rhs { sols.push(n) }
        n = n + 1
    }
    let ok = len(sols) == 2 && sols[0] == 1 && sols[1] == 6
    let detail = "σ₃(n)=τ(n)·(2ⁿ−1) in [1,28]: " + _arr_to_string(sols) + " (expected [1,6]; exp-vs-poly finiteness, P-NEW Eq#8 / OEIS #4)"
    return _vd("s1_pnew_eq8_sigma3_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_pnew_eq9_sigmaphi_tau_tecsl — σ(φ(n))·τ(n)=σ(n) ⟶ {1,6}
// ──────────────────────────────────────────────────────────────────────

pub fn verify_s1_pnew_eq9_sigmaphi_tau_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 1
    while n <= 300 {
        if sigma(euler_phi(n)) * tau(n) == sigma(n) { sols.push(n) }
        n = n + 1
    }
    let ok = len(sols) == 2 && sols[0] == 1 && sols[1] == 6
    let detail = "σ(φ(n))·τ(n)=σ(n) in [1,300]: " + _arr_to_string(sols) + " (expected [1,6]; P-NEW Eq#9 / OEIS #7)"
    return _vd("s1_pnew_eq9_sigmaphi_tau_tecsl", _tier_for(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s1_pnew_eq10_sopfr_tecsl — σ(n)(sopfr(n)−1)=n·φ(n)·τ(n) ⟶ {6}
// ──────────────────────────────────────────────────────────────────────
// σ(6)·(sopfr(6)−1)=12·(5−1)=48 = 6·φ(6)·τ(6)=6·2·4=48. Singleton {6}.

pub fn verify_s1_pnew_eq10_sopfr_tecsl() -> AtlasVerdict {
    let mut sols: [int] = []
    let mut n = 2
    while n <= 300 {
        if sigma(n) * (sopfr(n) - 1) == n * euler_phi(n) * tau(n) { sols.push(n) }
        n = n + 1
    }
    let ok = len(sols) == 1 && sols[0] == 6
    let detail = "σ(n)·(sopfr(n)−1)=n·φ(n)·τ(n) in [2,300]: " + _arr_to_string(sols) + " (expected [6]; σ(6)·4=48=6·2·4, P-NEW Eq#10 / OEIS #8)"
    return _vd("s1_pnew_eq10_sopfr_tecsl", _tier_for(ok), ok, detail)
}

// ── Aggregate ───────────────────────────────────────────────────────────

pub fn verify_foundation_all() -> [AtlasVerdict] {
    let mut out: [AtlasVerdict] = []
    out.push(verify_s1_n6_foundational())
    out.push(verify_s1_phi_sigma_unique())
    out.push(verify_s1_perfect_number())
    out.push(verify_s1_triangular_sigma_tau())
    out.push(verify_s1_master_identity_geometric())
    return out
}

// _tecsl Phase-2 aggregate (separate from verify_foundation_all so the
// reviewer-merge can wire these into the §1 ledger independently).
pub fn verify_foundation_tecsl_all() -> [AtlasVerdict] {
    let mut out: [AtlasVerdict] = []
    out.push(verify_s1_prime_pair_two_unique_tecsl())
    out.push(verify_s1_semiprime_perfect_unique_tecsl())
    out.push(verify_s1_divisor_field_action_zero_tecsl())
    out.push(verify_s1_tau_plus_2_eq_n_tecsl())
    out.push(verify_s1_sigma_n_plus_phi_eq_n_tau_sq_tecsl())
    out.push(verify_s1_pnew_eq2_phi_sigma_tecsl())
    out.push(verify_s1_pnew_eq7_ore_harmonic_tecsl())
    out.push(verify_s1_pnew_eq8_sigma3_tecsl())
    out.push(verify_s1_pnew_eq9_sigmaphi_tau_tecsl())
    out.push(verify_s1_pnew_eq10_sopfr_tecsl())
    return out
}
