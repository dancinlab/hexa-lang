// s3_lotka_volterra_fixed_point — anima Hc_A3-5: (γ/δ, α/β) fixed point
// ──────────────────────────────────────────────────────────────────────
// Lotka-Volterra predator-prey: dx/dt = αx - βxy, dy/dt = δxy - γy
// Non-trivial fixed point: x* = γ/δ, y* = α/β.

pub fn verify_s3_lotka_volterra_fixed_point() -> AtlasVerdict {
    // Sample: α=2, β=1, γ=3, δ=1.5 → x*=2, y*=2
    let alpha = 2.0
    let beta = 1.0
    let gamma = 3.0
    let delta = 1.5
    let x_star = gamma / delta
    let y_star = alpha / beta
    let dx_dt = alpha * x_star - beta * x_star * y_star
    let dy_dt = delta * x_star * y_star - gamma * y_star
    let fixed_point_ok = _abs_f(dx_dt) < 0.000000001 && _abs_f(dy_dt) < 0.000000001
    let detail = "Lotka-Volterra (α=" + to_string(alpha) + ",β=" + to_string(beta) + ",γ=" + to_string(gamma) + ",δ=" + to_string(delta) + ") fixed (γ/δ, α/β) = (" + to_string(x_star) + ", " + to_string(y_star) + ") · dx/dt=" + to_string(dx_dt) + " · dy/dt=" + to_string(dy_dt) + " (anima Hc_A3-5 carry)"
    return _vd_trans("s3_lotka_volterra_fixed_point", "§3 PHYS", _tier_pass(fixed_point_ok), fixed_point_ok, detail)
}

