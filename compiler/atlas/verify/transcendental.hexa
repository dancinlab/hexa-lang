    let err = _abs_f(g_star - reference)
    let ok = err < 0.000000001 && g_star > 0.0
    let detail = "Wilson-Fisher g* = 16π²ε/3 at ε=" + to_string(epsilon) + " → " + to_string(g_star) + " · 16π²/3 ≈ " + to_string(16.0 * pi2 / 3.0) + " (φ⁴ d=4-ε RG fixed point · anima Hc_A3-6 carry)"
    return _vd_trans("s3_rg_wilson_fisher", "§3 PHYS", _tier_pass(ok), ok, detail)
}

