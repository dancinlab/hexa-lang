// ──────────────────────────────────────────────────────────────────────
// s6_heisenberg_uncertainty — anima Hc_A9-5: Δx · Δp ≥ ℏ/2
// ──────────────────────────────────────────────────────────────────────
// Heisenberg uncertainty principle: minimum-uncertainty wavepacket saturates ℏ/2.
// Test the lower bound: Δx · Δp ≥ ℏ/2 in natural units (ℏ=1).

pub fn verify_s6_heisenberg_uncertainty() -> AtlasVerdict {
    let hbar = 1.0                  // natural units
    let lower_bound = hbar / 2.0
    // Sample Gaussian wavepacket saturating bound: Δx = 1/√2, Δp = 1/√2 → Δx·Δp = 1/2
    let dx = 1.0 / sqrt(2.0)
    let dp = 1.0 / sqrt(2.0)
    let product = dx * dp
    let saturation_ok = _abs_f(product - lower_bound) < 0.000000001
    // Sample non-minimum: Δx=1, Δp=1 → product = 1 > 1/2
    let non_min_ok = 1.0 * 1.0 > lower_bound
    let ok = saturation_ok && non_min_ok
    let detail = "Heisenberg Δx·Δp ≥ ℏ/2=" + to_string(lower_bound) + " — minimum-uncertainty Gaussian (Δx=Δp=1/√2): Δx·Δp=" + to_string(product) + " (saturates) ✓ · non-min sample (Δx=Δp=1): product=1 > 0.5 ✓ (anima Hc_A9-5 carry)"
    return _vd_trans("s6_heisenberg_uncertainty", "§6 COSMO", _tier_pass(ok), ok, detail)
}

