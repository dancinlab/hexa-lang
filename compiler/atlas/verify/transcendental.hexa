    let j5 = 2.0
    let c5 = cos(j5); let s5 = sin(j5)
    let err5 = _abs_f(c5 * c5 + s5 * s5 - 1.0)
    let tol = 0.000000000000001
    let ok = err1 < tol && err2 < tol && err3 < tol && err4 < tol && err5 < tol
    let detail = "Bao 2025 kicked-Ising bond exp(-iJσ^zσ^z) eigenvalues exp(±iJ) · per-bond unitarity ← cos²(J)+sin²(J)=1 · paper J=1: " + to_string(sum1) + " (|err|=" + to_string(err1) + ") · off-paper J=0.5,0.7,1.5,2.0 max |err|=" + to_string(err5) + " (Stage 2 libm cos/sin, tolerance 1e-15). σ^z Hermitian eigenvalues ±1 → σ^z⊗σ^z eigenvalues ±1 → exp(-iJ σ^zσ^z) eigenvalues exp(∓iJ), unit modulus. Load-bearing identity behind `norm_drift=0.000000` in the dtc selftest (Trotter-free Floquet evolution). See atlas/inbox/dtc-bond-ising-diag-phase-unitarity.md (≥6 falsifiers pre-registered)."
