    let ok = nat_ok
    let detail = "Planck ℓ_P=√(ℏG/c³) — natural units (ℏ=G=c=1) → ℓ_P=" + to_string(l_p) + " ✓ · dimensional structure: ℏ¹·G¹·c⁻³ → L²·T⁰ → L (length) (anima Hc_A9-4 carry)"
    return _vd_trans("s6_planck_length", "§6 COSMO", _tier_pass(ok), ok, detail)
