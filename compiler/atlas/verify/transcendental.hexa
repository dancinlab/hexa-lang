// ΔE = E_{n+1} - E_n = ℏω uniform.

pub fn verify_s3_qho_eigenvalue() -> AtlasVerdict {
    // Use ℏω = 1 unit. E_n = n + 0.5 for n = 0, 1, 2, ...
    let e0 = 0.5
    let e1 = 1.5
    let e2 = 2.5
    let de_01 = e1 - e0
    let de_12 = e2 - e1
    let uniform_spacing = _abs_f(de_01 - de_12) < 0.000000001
    let unit_gap = _abs_f(de_01 - 1.0) < 0.000000001
    let ground_zero_point = _abs_f(e0 - 0.5) < 0.000000001
    let ok = uniform_spacing && unit_gap && ground_zero_point
    let detail = "QHO E_n = ℏω(n+1/2) at ℏω=1 — E_0=" + to_string(e0) + " (zero-point) · E_1=" + to_string(e1) + " · E_2=" + to_string(e2) + " · ΔE uniform = " + to_string(de_01) + " ✓ (anima Hc_A3-7 carry)"
    return _vd_trans("s3_qho_eigenvalue", "§3 PHYS", _tier_pass(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s3_ginzburg_landau — anima Hc_NEW_PHYSICS-3: φ_min² = -a/(2b)
// ──────────────────────────────────────────────────────────────────────
// Ginzburg-Landau φ⁴ free energy: F(φ) = aφ² + bφ⁴
// dF/dφ = 0 gives φ² = -a/(2b) (minimum at a < 0, b > 0).

pub fn verify_s3_ginzburg_landau() -> AtlasVerdict {
    // Sample a = -2, b = 1 → φ² = 1, φ_min = ±1
    let a = -2.0
    let b = 1.0
    let phi_squared = -a / (2.0 * b)
    let phi_min = sqrt(phi_squared)
    let dF_dphi_at_min = 2.0 * a * phi_min + 4.0 * b * phi_min * phi_min * phi_min
    let dF_zero = _abs_f(dF_dphi_at_min) < 0.000000001
    // d²F/dφ² at min = 2a + 12bφ² = 2·(-2) + 12·1·1 = 8 > 0 (true minimum)
    let d2F = 2.0 * a + 12.0 * b * phi_squared
    let convex_at_min = d2F > 0.0
    let ok = dF_zero && convex_at_min
    let detail = "Ginzburg-Landau F=aφ²+bφ⁴ (a=" + to_string(a) + ", b=" + to_string(b) + ") · φ²=-a/(2b)=" + to_string(phi_squared) + " · φ_min=" + to_string(phi_min) + " · dF/dφ=" + to_string(dF_dphi_at_min) + " · d²F=" + to_string(d2F) + " > 0 ✓ (true min · anima Hc_NEW_PHYSICS-3 carry)"
    return _vd_trans("s3_ginzburg_landau", "§3 PHYS", _tier_pass(ok), ok, detail)
}

