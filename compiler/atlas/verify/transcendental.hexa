    let ok = err < 0.000000000001
    let detail = "Morvan 2024 weak-link κ_c(T=4) = (4/T)·log 2 = log 2 = " + to_string(kappa_c) + " · reference ln 2 = 0.6931471805599453 · |err| = " + to_string(err) + " (Stage 2 libm log, tolerance 1e-12). sim-universe supremacy-frontier selftest invariant. See atlas/inbox/supremacy-kappa-c-critical-noise.md (≥5 falsifiers pre-registered)."
    return _vd_trans("s3_supremacy_kappa_c_log2_T4", "§3 PHYS", _tier_pass(ok), ok, detail)
}

