pub fn verify_s3_higgs_doublet_2() -> AtlasVerdict {
    let p = euler_phi(6)
    let higgs_components = 2
    let ok = p == 2 && p == higgs_components
    let detail = "φ(6) = " + to_string(p) + " · SM Higgs SU(2) doublet components = " + to_string(higgs_components) + " (OBSERVATION per g2)"
