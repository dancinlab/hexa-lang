pub fn verify_s3_fundamental_forces_4() -> AtlasVerdict {
    let t = tau(6)
    let fundamental_forces = 4               // gravity, EM, weak, strong
    let ok = t == 4 && t == fundamental_forces
    let detail = "τ(6) = " + to_string(t) + " · fundamental forces (gravity, EM, weak, strong) = " + to_string(fundamental_forces) + " (OBSERVATION per g2)"
    return _vd_phys("s3_fundamental_forces_4", _tier_phys(ok), ok, detail)
