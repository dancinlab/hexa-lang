// ── Aggregate ───────────────────────────────────────────────────────────

pub fn verify_phys_all() -> [AtlasVerdict] {
    let mut out: [AtlasVerdict] = []
    out.push(verify_s3_conservation_law())
    out.push(verify_s3_cusp_discriminant())
    out.push(verify_s3_phys_conservation_count_n6())
    out.push(verify_s3_phys_lorentz_generators_C42())
    out.push(verify_s3_phys_poincare_generators_10())
    out.push(verify_s3_higgs_doublet_2())
    out.push(verify_s3_sm_fermion_total_12())
    out.push(verify_s3_astro_spacetime_dims_4())
    out.push(verify_s3_quark_flavors_6())
    out.push(verify_s3_quark_colors_3())
    out.push(verify_s3_gluons_8())
    out.push(verify_s3_generations_3())
    out.push(verify_s3_fundamental_forces_4())
    return out
}
