// Atlas internal: n(6)/φ(6) = 3. External: 3 SM fermion generations.

pub fn verify_s3_generations_3() -> AtlasVerdict {
    let n = 6
    let p = euler_phi(6)
    let computed = n / p                    // 3
    let sm_generations = 3                   // (e,νe,u,d), (μ,νμ,c,s), (τ,ντ,t,b)
    let ok = computed == 3 && computed == sm_generations
    let detail = "n/φ(6) = " + to_string(computed) + " · SM fermion generations (e/μ/τ families) = " + to_string(sm_generations) + " (OBSERVATION per g2)"
    return _vd_phys("s3_generations_3", _tier_phys(ok), ok, detail)
}

