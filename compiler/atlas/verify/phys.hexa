// ──────────────────────────────────────────────────────────────────────
// s3_quark_colors_3 — atlas embed L0-quark-colors = n/φ = 3
// ──────────────────────────────────────────────────────────────────────
// Atlas internal: n(6)/φ(6) = 6/2 = 3. External: 3 color charges (RGB) in QCD.

pub fn verify_s3_quark_colors_3() -> AtlasVerdict {
    let n = 6
    let p = euler_phi(6)
    let computed = n / p                    // 3
    let qcd_colors = 3                       // R, G, B
    let ok = computed == 3 && computed == qcd_colors
    let detail = "n/φ(6) = " + to_string(n) + "/" + to_string(p) + " = " + to_string(computed) + " · QCD color charges (RGB) = " + to_string(qcd_colors) + " (OBSERVATION per g2)"
    return _vd_phys("s3_quark_colors_3", _tier_phys(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s3_gluons_8 — atlas embed L0-gluons = σ-τ = 8
// ──────────────────────────────────────────────────────────────────────
// Atlas internal: σ(6)-τ(6) = 12-4 = 8. External: 8 gluons (SU(3) generators
// = 3²-1 = 8). OBSERVATION per g2.

pub fn verify_s3_gluons_8() -> AtlasVerdict {
    let s = sigma(6)
    let t = tau(6)
    let computed = s - t                    // 8
    // SU(3) adjoint = 3²-1 = 8 generators
    let su3_dim = 3 * 3 - 1
    let ok = computed == 8 && computed == su3_dim
    let detail = "σ(6)-τ(6) = " + to_string(s) + "-" + to_string(t) + " = " + to_string(computed) + " · SU(3) adjoint = 3²-1 = " + to_string(su3_dim) + " gluons (OBSERVATION per g2)"
    return _vd_phys("s3_gluons_8", _tier_phys(ok), ok, detail)
}

// ──────────────────────────────────────────────────────────────────────
// s3_generations_3 — atlas embed L0-generations = n/φ = 3
