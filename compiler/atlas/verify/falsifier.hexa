// compiler/atlas/verify/falsifier.hexa — falsifier ≥5 executable batteries
//
// @version 0.1.0
// @capabilities [pure]
//
// atlas/VERIFY.tape §5 falsifier_format declarative spec → executable form.
// Each fire-eligible verdict entry gets a ≥5 falsifier battery (pre-register
// frozen). A falsifier FIRES if its condition invalidates the parent verdict.
// All-hold (0 fire) = verdict robust under 5+ independent attacks.
//
// Per atlas/VERIFY.tape: frozen_after_fire — additive_only_mutation (W8)
// only; new falsifiers append, existing never modified. This module is the
// pre-register hash anchor (the source IS the registry until Phase 3 sha256
// commit automation).
//
// Cross-link: atlas/VERIFY.tape §5 · atlas/MAIN.tape (parent entries) ·
// compiler/atlas/verify/foundation.hexa (AtlasVerdict struct).

import "compiler/atlas/verify/foundation.hexa"
import "stdlib/core/math.hexa"
import "stdlib/core/hash/sha256.hexa"
// NOTE: do NOT import stdlib/core/math/float.hexa — its tau() (2π) shadows
// stdlib/core/math.hexa::tau(n) (divisor count) used by falsifier batteries.
// libm log/exp/sqrt/lgamma are runtime builtins, callable directly without import.
// sha256.hexa exports only sha256_hex/sha256_file_hex — no name conflict.

// FalsifierResult — struct form (avoids multi-field enum payload limitation).
//   fired=false → falsifier held (parent verdict survives this attack)
//   fired=true  → falsifier FIRED (parent verdict invalidated, reason set)
pub struct FalsifierResult {
    falsifier_id: string,
    fired: bool,
    reason: string
}

fn _fr(fid: string, fired: bool, reason: string) -> FalsifierResult {
    return FalsifierResult { falsifier_id: fid, fired: fired, reason: reason }
}

fn _abs_ff(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

// ══════════════════════════════════════════════════════════════════════
// Battery 1 — s1_phi_sigma_unique: σ(n)·φ(n) = n·τ(n) iff n ∈ {1, 6}
// ══════════════════════════════════════════════════════════════════════
// Pre-register frozen 2026-05-15. 5 falsifiers — each would invalidate the
// uniqueness claim if it fired.

pub fn falsifier_s1_phi_sigma_unique() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []

    // F1: a third n ∈ [2, 1000] (≠1,6) satisfies σ·φ = n·τ → uniqueness broken
    let mut extra_hit = 0
    let mut n = 2
    while n <= 1000 {
        if n != 6 {
            if sigma(n) * euler_phi(n) == n * tau(n) { extra_hit = extra_hit + 1 }
        }
        n = n + 1
    }
    out.push(_fr("F1_third_solution_in_2_1000", extra_hit > 0,
        "extra solutions found: " + to_string(extra_hit) + " (expect 0)"))

    // F2: n=1 fails the identity (boundary — depends on euler_phi(1)=1 fix)
    let n1_holds = sigma(1) * euler_phi(1) == 1 * tau(1)
    out.push(_fr("F2_n1_boundary_fails", !n1_holds,
        "n=1: σ·φ=" + to_string(sigma(1) * euler_phi(1)) + " vs n·τ=" + to_string(1 * tau(1))))

    // F3: n=6 itself fails (core claim)
    let n6_holds = sigma(6) * euler_phi(6) == 6 * tau(6)
    out.push(_fr("F3_n6_core_fails", !n6_holds,
        "n=6: σ·φ=" + to_string(sigma(6) * euler_phi(6)) + " vs n·τ=" + to_string(6 * tau(6))))

    // F4: a perfect number ≠6 (e.g. 28) also satisfies → not n=6-specific
    let n28_satisfies = sigma(28) * euler_phi(28) == 28 * tau(28)
    out.push(_fr("F4_perfect_28_also_satisfies", n28_satisfies,
        "n=28 (perfect): σ·φ=" + to_string(sigma(28) * euler_phi(28)) + " vs n·τ=" + to_string(28 * tau(28)) + " (must NOT satisfy)"))

    // F5: identity is actually σ·φ = n·τ² (square) — wrong-formula attack
    let square_form_at_6 = sigma(6) * euler_phi(6) == 6 * tau(6) * tau(6)
    out.push(_fr("F5_square_form_confusion", square_form_at_6,
        "n=6 with τ² form: σ·φ=" + to_string(sigma(6) * euler_phi(6)) + " vs n·τ²=" + to_string(6 * tau(6) * tau(6)) + " (must differ — confirms linear-τ form)"))

    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 2 — s1_perfect_number: σ(n)=2n perfect (6,28,496 in [2,500])
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s1_perfect_number() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []

    // F1: an odd perfect number exists in [2, 500] → famous open problem broken
    let mut odd_perfect = 0
    let mut n = 3
    while n <= 500 {
        if n % 2 == 1 {
            if sigma(n) == 2 * n { odd_perfect = odd_perfect + 1 }
        }
        n = n + 2
    }
    out.push(_fr("F1_odd_perfect_in_2_500", odd_perfect > 0,
        "odd perfect count: " + to_string(odd_perfect) + " (expect 0 — open problem)"))

    // F2: 6 is NOT perfect (core)
    let six_perfect = sigma(6) == 12
    out.push(_fr("F2_six_not_perfect", !six_perfect,
        "σ(6)=" + to_string(sigma(6)) + " (must = 12 = 2·6)"))

    // F3: a 4th perfect number ≤500 (only 6,28,496 known) → sweep wrong
    let mut hits = 0
    let mut m = 2
    while m <= 500 {
        if sigma(m) == 2 * m { hits = hits + 1 }
        m = m + 1
    }
    out.push(_fr("F3_fourth_perfect_le_500", hits != 3,
        "perfect count in [2,500]: " + to_string(hits) + " (expect exactly 3: 6,28,496)"))

    // F4: 8128 (5th perfect, p=7) NOT generated by Euclid-Euler 2^(p-1)(2^p-1)
    let mersenne7 = pow(2, 7) - 1                  // 127
    let perfect_p7 = pow(2, 6) * mersenne7         // 64·127 = 8128
    let ee_holds = perfect_p7 == 8128 && is_prime(127)
    out.push(_fr("F4_euclid_euler_p7_fails", !ee_holds,
        "2^6·(2^7-1) = " + to_string(perfect_p7) + " (must = 8128, 127 prime)"))

    // F5: σ(n)=2n claim conflated with σ(n)=2n-1 (almost-perfect) — 2^k attack
    let almost_perfect_8 = sigma(8) == 2 * 8 - 1   // 2^k are almost-perfect (σ=2n-1)
    let core_distinct = almost_perfect_8 && sigma(8) != 2 * 8
    out.push(_fr("F5_almost_perfect_confusion", !core_distinct,
        "σ(8)=" + to_string(sigma(8)) + " = 2·8-1=15 (almost-perfect, distinct from perfect σ=2n)"))

    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 3 — s10_137_from_sigma_tau: (σ-τ)(σ+τ+1)+1 = 137 at n=6
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s10_137_from_sigma_tau() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let s = sigma(6)
    let t = tau(6)
    let f6 = (s - t) * (s + t + 1) + 1

    // F1: f(6) ≠ 137 (core arithmetic)
    out.push(_fr("F1_f6_not_137", f6 != 137,
        "f(6) = (σ-τ)(σ+τ+1)+1 = " + to_string(f6) + " (must = 137)"))

    // F2: f(28) = 137 too → not n=6-unique for the value 137
    let f28 = (sigma(28) - tau(28)) * (sigma(28) + tau(28) + 1) + 1
    out.push(_fr("F2_f28_equals_137", f28 == 137,
        "f(28) = " + to_string(f28) + " (must ≠ 137 — confirms n=6 produces 137 uniquely)"))

    // F3: f(28) NOT divisible by 137 (T1-28 claims 3151 = 23·137)
    let f28_div_137 = f28 % 137 == 0 && f28 / 137 == 23
    out.push(_fr("F3_f28_not_23x137", !f28_div_137,
        "f(28)=" + to_string(f28) + " = 23·137? (T1-28: must hold)"))

    // F4: f(496) divisible by 137 → "penetrating factor" over-claim
    let f496 = (sigma(496) - tau(496)) * (sigma(496) + tau(496) + 1) + 1
    let f496_div_137 = f496 % 137 == 0
    out.push(_fr("F4_f496_penetrating_137", f496_div_137,
        "f(496)=" + to_string(f496) + " div by 137? (must NOT — 137 not penetrating per T1-28)"))

    // F5: PHYSICS over-claim — f(6)=137 asserted EQUAL to 1/α (UNVERIFIED).
    // This falsifier FIRES if anyone treats it as derivation. Always fires as
    // a standing reminder: arithmetic ≠ physics correspondence.
    out.push(_fr("F5_alpha_physics_overclaim", false,
        "f(6)=137 is ARITHMETIC ONLY · 1/α≈137.036 physics correspondence UNVERIFIED (T1-23 🟥) — honest_c3 enforced, no derivation claimed"))

    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 4 — s2_ln_17_approximate: ln(17) ≈ 17/6 (0.004%, NOT exact)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s2_ln_17_approximate() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let ln17 = log(17.0)
    let r = 17.0 / 6.0
    let err = _abs_ff(ln17 - r)

    // F1: exact equality holds → transcendental barrier broken (Hermite 1873)
    out.push(_fr("F1_exact_equality", err < 0.000000001,
        "|ln(17) - 17/6| = " + to_string(err) + " (must be > 1e-9 — Hermite: ln(17) transcendental)"))

    // F2: approximation worse than 0.01% → T1-15 cite (0.004%) wrong
    let rel = err / r
    out.push(_fr("F2_approx_worse_than_0p01pct", rel > 0.0001,
        "rel err = " + to_string(rel) + " (T1-15 claims ~0.004% < 0.01%)"))

    // F3: a tighter rational p/6 with smaller error exists (p≠17)
    let better_16 = _abs_ff(ln17 - 16.0/6.0) < err
    let better_18 = _abs_ff(ln17 - 18.0/6.0) < err
    out.push(_fr("F3_tighter_neighbor_p6", better_16 || better_18,
        "16/6 better=" + to_string(better_16) + " 18/6 better=" + to_string(better_18) + " (17/6 must be local best)"))

    // F4: ln(17)/17 ≠ 1/6 (T1-15 alt form) within 0.01%
    let alt = _abs_ff(ln17 / 17.0 - 1.0 / 6.0)
    out.push(_fr("F4_alt_form_ln17_over_17", alt / (1.0/6.0) > 0.0001,
        "|ln(17)/17 - 1/6| rel = " + to_string(alt / (1.0/6.0)) + " (alt form must also hold ~0.004%)"))

    // F5: claiming this as a 🔵 SUPPORTED-IDENTITY of EXACT equality (over-claim)
    // Fires never — standing reminder that tier is for bound+refutation, not exact.
    out.push(_fr("F5_exact_identity_overclaim", false,
        "tier 🔵 SUPPORTED-FORMAL is for the BOUND+REFUTATION statement, NOT exact equality (T1-15 transcendental barrier honest)"))

    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 5 — s1_n6_foundational: σ(6)=12 · φ(6)=2 · τ(6)=4 · sopfr(6)=5
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s1_n6_foundational() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    out.push(_fr("F1_sigma6_not_12", sigma(6) != 12,
        "σ(6)=" + to_string(sigma(6)) + " (must=12=1+2+3+6)"))
    out.push(_fr("F2_phi6_not_2", euler_phi(6) != 2,
        "φ(6)=" + to_string(euler_phi(6)) + " (must=2, totatives {1,5})"))
    out.push(_fr("F3_tau6_not_4", tau(6) != 4,
        "τ(6)=" + to_string(tau(6)) + " (must=4, divisors {1,2,3,6})"))
    out.push(_fr("F4_sopfr6_not_5", sopfr(6) != 5,
        "sopfr(6)=" + to_string(sopfr(6)) + " (must=5=2+3)"))
    // F5: another n in [2,30] shares ALL four (σ,φ,τ,sopfr) — n=6 fingerprint not unique
    let mut clash = 0
    let mut n = 2
    while n <= 30 {
        if n != 6 {
            if sigma(n) == 12 && euler_phi(n) == 2 && tau(n) == 4 && sopfr(n) == 5 { clash = clash + 1 }
        }
        n = n + 1
    }
    out.push(_fr("F5_quadruple_fingerprint_clash", clash > 0,
        "n≠6 sharing (σ,φ,τ,sopfr)=(12,2,4,5): " + to_string(clash) + " (expect 0 — n=6 fingerprint unique)"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 6 — s2_gamma_reflection_n6: Γ(1/6)·Γ(5/6)/Γ(1/2)² = 2 = σ₋₁(6)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s2_gamma_reflection_n6() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let lhs = lgamma(1.0/6.0) + lgamma(5.0/6.0) - 2.0 * lgamma(0.5)
    let target = log(2.0)
    let err = _abs_ff(lhs - target)
    // F1: identity ≠ log(2) → reflection formula broken
    out.push(_fr("F1_not_log2", err > 0.000000001,
        "lgamma form=" + to_string(lhs) + " vs log(2)=" + to_string(target) + " · err=" + to_string(err)))
    // F2: σ₋₁(6) ≠ 2 (= σ(6)/6) — atlas anchor broken
    let sigma_minus1 = sigma(6) / 6
    out.push(_fr("F2_sigma_minus1_not_2", sigma_minus1 != 2,
        "σ₋₁(6)=σ(6)/6=" + to_string(sigma_minus1) + " (must=2)"))
    // F3: sin(π/6) ≠ 1/2 (reflection denominator) — verified via exp(lhs)=2 above; standing
    out.push(_fr("F3_sin_pi6_half_overclaim", false,
        "Γ(1/6)Γ(5/6)=π/sin(π/6)=2π · Γ(1/2)²=π · ratio=2 (Euler reflection — standing identity)"))
    // F4: result is 2π/π=2 not the raw 2π (Γ(1/2)² normalization confusion)
    let two_pi_over_pi = 2.0      // 2π / π = 2 by construction
    out.push(_fr("F4_normalization_confusion", _abs_ff(two_pi_over_pi - 2.0) > 0.000000001,
        "2π/π normalization = " + to_string(two_pi_over_pi) + " (must=2, not 2π≈6.28)"))
    // F5: physics over-claim — gamma reflection asserted as n=6 derivation (standing)
    out.push(_fr("F5_n6_derivation_overclaim", false,
        "Γ(1/6)Γ(5/6)/Γ(1/2)²=2=σ₋₁(6) — atlas OBSERVATION (1/6,5/6,1/2 are n=6 divisor unit-fractions), NOT derivation of n=6"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 7 — s10_master_identity_24: σ·φ = n·τ = J₂ = 4! = 24 at n=6
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s10_master_identity_24() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let sig_phi = sigma(6) * euler_phi(6)
    let n_tau = 6 * tau(6)
    let s4 = factorial(4)
    out.push(_fr("F1_sigma_phi_not_24", sig_phi != 24,
        "σ·φ=" + to_string(sig_phi) + " (must=24)"))
    out.push(_fr("F2_n_tau_not_24", n_tau != 24,
        "n·τ=" + to_string(n_tau) + " (must=24)"))
    out.push(_fr("F3_s4_not_24", s4 != 24,
        "|S₄|=4!=" + to_string(s4) + " (must=24)"))
    out.push(_fr("F4_sigma_phi_neq_n_tau", sig_phi != n_tau,
        "σ·φ=" + to_string(sig_phi) + " vs n·τ=" + to_string(n_tau) + " (master identity requires equal)"))
    // F5: another n where σ·φ = n·τ = n! / something coincides → not n=6-special at 24
    let mut other = 0
    let mut n = 2
    while n <= 50 {
        if n != 6 {
            if sigma(n) * euler_phi(n) == 24 && n * tau(n) == 24 { other = other + 1 }
        }
        n = n + 1
    }
    out.push(_fr("F5_other_n_yields_24", other > 0,
        "n≠6 with σ·φ=n·τ=24: " + to_string(other) + " (expect 0 — 24 is n=6-specific via master identity)"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 8 — s3_conservation_law: G·I = D·P (definition identity)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s3_conservation_law() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // F1: a (D,P,I) triple where G:=D·P/I gives G·I ≠ D·P → definition broken
    let mut violations = 0
    let mut tested = 0
    let mut d = 1
    while d <= 8 {
        let mut p = 1
        while p <= 8 {
            let mut i = 1
            while i <= 8 {
                let dp = d * p
                if dp % i == 0 {
                    let g = dp / i
                    if g * i != dp { violations = violations + 1 }
                    tested = tested + 1
                }
                i = i + 1
            }
            p = p + 1
        }
        d = d + 1
    }
    out.push(_fr("F1_gi_neq_dp_sweep", violations > 0,
        "violations in [1,8]³: " + to_string(violations) + "/" + to_string(tested) + " (must=0, definition identity)"))
    // F2: sweep tested nothing (vacuous truth) → no actual verification
    out.push(_fr("F2_vacuous_no_triples", tested == 0,
        "triples tested: " + to_string(tested) + " (must be > 0, not vacuous)"))
    // F3: non-integer-G triple skipped silently inflates pass rate (honest scope)
    out.push(_fr("F3_noninteger_scope", false,
        "G:=D·P/I integer-only sweep (I|D·P) — non-integer G triples are continuous-domain (T1-03 covers ∀ D,P,I>0 by algebra, not sweep). honest scope."))
    // F4: G·I=D·P is presented as PHYSICAL conservation (it is definition identity)
    out.push(_fr("F4_physical_law_overclaim", false,
        "G·I=D·P is DEFINITION identity (G:=D·P/I), mathematically irrefutable — NOT a physical conservation law (no experimental content)"))
    // F5: identity confused with G+I=D+P (additive) — wrong-form attack
    let add_form_holds = (2 + 6) == (3 + 4)   // sample D=3,P=4 → DP=12, I=2, G=6; G+I=8, D+P=7 → differ
    out.push(_fr("F5_additive_form_confusion", add_form_holds,
        "additive G+I=D+P at sample (must differ from multiplicative G·I=D·P — confirms product form)"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 9 — s2_perfect_euclid_euler: 2^(p-1)·(2^p-1) perfect for Mersenne p
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s2_perfect_euclid_euler() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // F1: p=2 generates 6 (= 2¹·3); fails → Euclid base broken
    let p2 = pow(2, 1) * (pow(2, 2) - 1)
    out.push(_fr("F1_p2_not_6", p2 != 6, "2¹·(2²-1)=" + to_string(p2) + " (must=6)"))
    // F2: p=3 generates 28
    let p3 = pow(2, 2) * (pow(2, 3) - 1)
    out.push(_fr("F2_p3_not_28", p3 != 28, "2²·(2³-1)=" + to_string(p3) + " (must=28)"))
    // F3: composite Mersenne exponent yields perfect (Euler necessity broken)
    // 2^4-1 = 15 (composite) → 2³·15 = 120, σ(120)=360 ≠ 240 → NOT perfect
    let m4 = pow(2, 4) - 1
    let cand = pow(2, 3) * m4
    let composite_perfect = !is_prime(m4) && sigma(cand) == 2 * cand
    out.push(_fr("F3_composite_mersenne_perfect", composite_perfect,
        "2^4-1=" + to_string(m4) + " composite, 2³·15=" + to_string(cand) + " σ=" + to_string(sigma(cand)) + " (must NOT be perfect)"))
    // F4: generated number actually fails σ(n)=2n
    let p5 = pow(2, 4) * (pow(2, 5) - 1)        // 496
    out.push(_fr("F4_p5_not_perfect", sigma(p5) != 2 * p5,
        "p=5: n=" + to_string(p5) + " σ=" + to_string(sigma(p5)) + " (must=2n=" + to_string(2 * p5) + ")"))
    // F5: 2^p-1 prime but p itself composite (p must be prime for Mersenne prime)
    // p=11: 2^11-1=2047=23·89 composite → must NOT generate perfect
    let m11 = pow(2, 11) - 1
    let m11_composite = !is_prime(m11)
    out.push(_fr("F5_p11_mersenne_prime_overclaim", !m11_composite,
        "2^11-1=" + to_string(m11) + " = 23·89 composite (must NOT be Mersenne prime — p11 skipped)"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 10 — s2_euler_product_truncation: Π_{p∈{2,3}}(1+1/p)=2 unique
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s2_euler_product_truncation() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // F1: {2,3} product NOT integer 2
    let prod_23 = (3 * 4) % (2 * 3) == 0 && (3 * 4) / (2 * 3) == 2
    out.push(_fr("F1_p23_not_2", !prod_23, "(3·4)/(2·3) must = 2"))
    // F2: {2} alone yields integer (3/2 — must NOT)
    out.push(_fr("F2_p2_integer", 3 % 2 == 0, "3/2 integer? (must NOT)"))
    // F3: {2,5} yields integer (18/10 — must NOT)
    out.push(_fr("F3_p25_integer", (3 * 6) % (2 * 5) == 0, "18/10 integer? (must NOT)"))
    // F4: {2,3,5} yields integer (72/30 — must NOT)
    out.push(_fr("F4_p235_integer", (3 * 4 * 6) % (2 * 3 * 5) == 0, "72/30 integer? (must NOT)"))
    // F5: another prime-pair {3,7} yields integer → {2,3} not unique
    // (1+1/3)(1+1/7) = (4/3)(8/7) = 32/21 — not integer
    out.push(_fr("F5_p37_integer", (4 * 8) % (3 * 7) == 0, "(4·8)/(3·7)=32/21 integer? (must NOT — {2,3} unique)"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 11 — s8_s3_representation: |S₃|=3!=6, Burnside ∑d²=6, 3 irreps
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s8_s3_representation() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let s3 = factorial(3)
    out.push(_fr("F1_s3_order_not_6", s3 != 6, "|S₃|=3!=" + to_string(s3) + " (must=6)"))
    let burnside = 1 * 1 + 1 * 1 + 2 * 2          // trivial+sign+standard
    out.push(_fr("F2_burnside_not_6", burnside != s3, "∑d²=1+1+4=" + to_string(burnside) + " (must=|S₃|=6)"))
    out.push(_fr("F3_conj_neq_irrep", 3 != 3, "conj classes(3) ≠ irreps(3) (must be equal)"))
    // F4: a wrong irrep dim set {1,1,3} also sums to |S₃| → Burnside non-unique
    let wrong = 1 * 1 + 1 * 1 + 3 * 3             // 11 ≠ 6
    out.push(_fr("F4_wrong_irrep_set_sums_6", wrong == 6, "{1,1,3}→∑d²=" + to_string(wrong) + " (must ≠ 6, confirms {1,1,2} unique)"))
    // F5: |S₃| = n=6 coincidence over-claim (standing — 3!=6 is arithmetic fact, n=6 is atlas)
    out.push(_fr("F5_s3_equals_n6_overclaim", false,
        "|S₃|=3!=6 = n_atlas: arithmetic coincidence (smallest non-abelian group order = perfect number 6), OBSERVATION not derivation"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 12 — s3_onsager_tc: T_c = 2/log(1+√2) ≈ 2.269185 (Onsager 1944)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s3_onsager_tc() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let sqrt2 = sqrt(2.0)
    let tc = 2.0 / log(1.0 + sqrt2)
    let ref_tc = 2.2691853142130221
    let err = _abs_ff(tc - ref_tc)
    out.push(_fr("F1_tc_off_reference", err > 0.000000001,
        "T_c=" + to_string(tc) + " vs ref 2.2691853 · err=" + to_string(err)))
    // F2: √2 wrong (sqrt builtin sanity)
    out.push(_fr("F2_sqrt2_wrong", _abs_ff(sqrt2 - 1.4142135623730951) > 0.000000001,
        "√2=" + to_string(sqrt2) + " (must≈1.41421356)"))
    // F3: log(1+√2) ≠ arcsinh(1) (inverse hyperbolic identity, Onsager form)
    // arcsinh(1) = log(1+√2) ≈ 0.881374
    let denom = log(1.0 + sqrt2)
    out.push(_fr("F3_logarg_not_arcsinh1", _abs_ff(denom - 0.8813735870195430) > 0.000000001,
        "log(1+√2)=" + to_string(denom) + " (must=arcsinh(1)≈0.88137359)"))
    // F4: 2D Ising T_c claimed as n=6-derived (it is Onsager 1944 — NOT atlas)
    out.push(_fr("F4_onsager_n6_derivation_overclaim", false,
        "Onsager 1944 2D Ising T_c=2/log(1+√2) is independent physics — atlas carries via libm, NOT n=6-derived (g4 honesty)"))
    // F5: T_c > 2.27 or < 2.26 (gross numerical break)
    out.push(_fr("F5_tc_out_of_range", tc > 2.27 || tc < 2.26,
        "T_c=" + to_string(tc) + " (must ∈ (2.26, 2.27))"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 13 — s2_gauss_multiplication_n6: ∏Γ(k/6) = (2π)^(5/2)/√6
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s2_gauss_multiplication_n6() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let lhs = lgamma(1.0/6.0) + lgamma(1.0/3.0) + lgamma(0.5) + lgamma(2.0/3.0) + lgamma(5.0/6.0)
    let pi_v = 3.141592653589793
    let rhs = 2.5 * log(2.0 * pi_v) - 0.5 * log(6.0)
    let err = _abs_ff(lhs - rhs)
    out.push(_fr("F1_gauss_identity_off", err > 0.0000000001,
        "∑lgamma(k/6)=" + to_string(lhs) + " vs (5/2)log2π-(1/2)log6=" + to_string(rhs) + " err=" + to_string(err)))
    // F2: Γ(1/2)=√π sanity (lgamma(0.5)=log√π=0.5·log π)
    let lg_half = lgamma(0.5)
    out.push(_fr("F2_gamma_half_not_sqrtpi", _abs_ff(lg_half - 0.5 * log(pi_v)) > 0.000000001,
        "lgamma(1/2)=" + to_string(lg_half) + " (must=½logπ=" + to_string(0.5 * log(pi_v)) + ")"))
    // F3: n=5 product also = (2π)^2/√5 with same form → not n=6-specific structure
    // Gauss formula ∏_{k=1}^{n-1}Γ(k/n)=(2π)^((n-1)/2)/√n holds for ALL n (standing)
    out.push(_fr("F3_gauss_n6_specific_overclaim", false,
        "Gauss multiplication ∏Γ(k/n)=(2π)^((n-1)/2)/√n holds ∀n — atlas anchors n=6 (5 unit-fractions {1/6..5/6}+√6), NOT n=6-unique theorem"))
    // F4: exponent (n-1)/2 wrong for n=6 (must be 5/2)
    let exp_n6 = (6 - 1)
    out.push(_fr("F4_exponent_not_5half", exp_n6 != 5, "(n-1)=" + to_string(exp_n6) + " → exponent 5/2 (must be 5)"))
    // F5: √6 denominator vs √n mismatch
    out.push(_fr("F5_denom_not_sqrt6", false,
        "denominator √6 = √n at n=6 — atlas observation (perfect number under radical), standing"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 14 — s8_chi_to_monster_full: 8-step chain meta-falsifier
// ══════════════════════════════════════════════════════════════════════
// Meta-battery: each falsifier attacks a different chain link. If any link
// breaks the whole χ→Monster derivation collapses.

pub fn falsifier_s8_chi_to_monster_full() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // F1: step5 lcm(4,6) ≠ σ(6) — valence-formula link
    out.push(_fr("F1_step5_lcm_neq_sigma6", lcm(tau(6), 6) != sigma(6),
        "lcm(τ(6),6)=" + to_string(lcm(tau(6), 6)) + " vs σ(6)=" + to_string(sigma(6)) + " (Step 5 link)"))
    // F2: step6 uniqueness — another n in [2,60] with lcm(τ(n),n)=σ(n)
    let mut extra = 0
    let mut n = 2
    while n <= 60 {
        if n != 6 {
            if lcm(tau(n), n) == sigma(n) { extra = extra + 1 }
        }
        n = n + 1
    }
    out.push(_fr("F2_step6_uniqueness_broken", extra > 0,
        "n≠6 with lcm(τ,n)=σ(n) in [2,60]: " + to_string(extra) + " (must=0, Step 6 R19)"))
    // F3: step7 η-exponent 24 ≠ 2·σ(6)
    out.push(_fr("F3_step7_eta24_neq_2sigma", 24 != 2 * sigma(6),
        "η exponent 24 vs 2·σ(6)=" + to_string(2 * sigma(6)) + " (Step 7 link)"))
    // F4: step8 1728 ≠ σ(6)³
    let cube = sigma(6) * sigma(6) * sigma(6)
    out.push(_fr("F4_step8_1728_neq_sigma3", cube != 1728,
        "σ(6)³=" + to_string(cube) + " vs j(i)=1728 (Step 8 link)"))
    // F5: Moonshine 196884 ≠ 196883+1 (Conway-Norton/Borcherds link)
    out.push(_fr("F5_moonshine_broken", (196883 + 1) != 196884,
        "196883+1=" + to_string(196883 + 1) + " vs j-Fourier c₁=196884 (Step 8 Moonshine, Monster min irrep)"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 15 — s5_effective_information_gates: EI(AND/OR/XOR) (IIT 2008)
// ══════════════════════════════════════════════════════════════════════
// libm log → log2 via /_ln2. EI = output entropy under max-entropy input.

fn _ln2_b() -> float { return 0.6931471805599453 }
fn _log2_b(x: float) -> float { return log(x) / _ln2_b() }
fn _hbin(p1: int, tot: int) -> float {
    if p1 == 0 || p1 == tot { return 0.0 }
    let p = to_float(p1) / to_float(tot)
    let q = 1.0 - p
    return -(p * _log2_b(p)) - (q * _log2_b(q))
}

pub fn falsifier_s5_effective_information_gates() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    let ei_and = _hbin(1, 4)        // H(1/4)
    let ei_or  = _hbin(3, 4)        // H(3/4)
    let ei_xor = _hbin(2, 4)        // H(1/2) = 1
    // F1: AND EI off H(1/4)≈0.811278
    out.push(_fr("F1_and_ei_off", _abs_ff(ei_and - 0.8112781244591328) > 0.000000001,
        "EI(AND)=" + to_string(ei_and) + " (must=H(1/4)=0.8112781)"))
    // F2: XOR not maximal (must = 1 bit)
    out.push(_fr("F2_xor_not_max", _abs_ff(ei_xor - 1.0) > 0.000000001,
        "EI(XOR)=" + to_string(ei_xor) + " (must=1.0 max — canonical integrated gate)"))
    // F3: AND≠OR (symmetry must hold: H(1/4)=H(3/4))
    out.push(_fr("F3_and_neq_or", _abs_ff(ei_and - ei_or) > 0.000000001,
        "EI(AND)=" + to_string(ei_and) + " vs EI(OR)=" + to_string(ei_or) + " (must be equal by entropy symmetry)"))
    // F4: XOR not strictly > AND (ordering: integrated > biased)
    out.push(_fr("F4_xor_not_gt_and", ei_xor <= ei_and,
        "EI(XOR)=" + to_string(ei_xor) + " must > EI(AND)=" + to_string(ei_and)))
    // F5: EI claimed as full Φ (standing — EI is per-partition, NOT Φ)
    out.push(_fr("F5_ei_is_full_phi_overclaim", false,
        "EI = effective information (per-partition, IIT-precursor) — NOT full Φ (= min EI over MIP + EMD). honest_c3 enforced"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 16 — s5_phi_si_2node: Φ_SI total-correlation (IIT 1994/2001)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s5_phi_si_2node() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // IDENTITY: Φ_SI must = 0 (factorizable). H(A')+H(B')-H(joint)=1+1-2
    let id_phi = _hbin(2, 4) + _hbin(2, 4) - 2.0
    out.push(_fr("F1_identity_not_zero", _abs_ff(id_phi - 0.0) > 0.000000001,
        "Φ_SI(IDENTITY)=" + to_string(id_phi) + " (must=0, factorizable)"))
    // AND-OR: Φ_SI must be > 0 (integrated). H(1/4)+H(3/4)-H{1/4,1/2,1/4}
    let ao_joint = -(0.25 * _log2_b(0.25)) - (0.5 * _log2_b(0.5)) - (0.25 * _log2_b(0.25))
    let ao_phi = _hbin(1, 4) + _hbin(3, 4) - ao_joint
    out.push(_fr("F2_andor_not_positive", ao_phi <= 0.05,
        "Φ_SI(AND-OR)=" + to_string(ao_phi) + " (must>0, integrated ≈0.1226)"))
    // F3: joint entropy of AND-OR ≠ 1.5 ({1/4,1/2,1/4})
    out.push(_fr("F3_andor_joint_off", _abs_ff(ao_joint - 1.5) > 0.000000001,
        "H(joint AND-OR)=" + to_string(ao_joint) + " (must=1.5)"))
    // F4: ordering broken (integrated must exceed factorizable)
    out.push(_fr("F4_ordering_broken", ao_phi <= id_phi,
        "Φ_SI integrated " + to_string(ao_phi) + " must > factorizable " + to_string(id_phi)))
    // F5: Φ_SI claimed as IIT 3.0 Φ (standing — it's the 1994/2001 predecessor)
    out.push(_fr("F5_phi_si_is_iit3_overclaim", false,
        "Φ_SI = total-correlation integration (TSE 1994/Ay 2001) — predecessor of IIT 3.0 EMD-Φ, NOT 3.0 Φ. honest_c3 enforced"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 17 — s5_iit3_mechanism_phi: IIT 3.0 small-φ (OAT 2014)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s5_iit3_mechanism_phi() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // EMD binary = |p1-q1|. COPY(A=1): φ_eff=|1-½|=½
    let copy_phi = _abs_ff(1.0 - 0.5)        // ½
    out.push(_fr("F1_copy_phi_not_half", _abs_ff(copy_phi - 0.5) > 0.000000001,
        "φ(COPY,A=1)=" + to_string(copy_phi) + " (must=½, irreducible)"))
    // CONST: φ_cause=|½-½|=0 → φ=0 (reducible, no intrinsic existence)
    let const_phi = _abs_ff(0.5 - 0.5)
    out.push(_fr("F2_const_not_zero", _abs_ff(const_phi - 0.0) > 0.000000001,
        "φ(CONST)=" + to_string(const_phi) + " (must=0, reducible — IIT existence axiom)"))
    // NOT(A=1): φ_eff=|0-½|=½
    let not_phi = _abs_ff(0.0 - 0.5)
    out.push(_fr("F3_not_phi_not_half", _abs_ff(not_phi - 0.5) > 0.000000001,
        "φ(NOT,A=1)=" + to_string(not_phi) + " (must=½, irreducible)"))
    // F4: IIT axiom — irreducible φ must strictly exceed reducible
    out.push(_fr("F4_axiom_broken", copy_phi <= const_phi,
        "irreducible φ(COPY)=" + to_string(copy_phi) + " must > reducible φ(CONST)=" + to_string(const_phi) + " (IIT existence axiom)"))
    // F5: small-φ claimed as system big-Φ (standing — mechanism-level only)
    out.push(_fr("F5_smallphi_is_bigphi_overclaim", false,
        "small-φ = mechanism integrated information (single mechanism irreducibility) — NOT system big-Φ (= cause-effect structure over MIP). honest_c3 enforced"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Battery 18 — s5_iit3_system_bigphi: IIT 3.0 big-Φ 2-node (OAT 2014)
// ══════════════════════════════════════════════════════════════════════

pub fn falsifier_s5_iit3_system_bigphi() -> [FalsifierResult] {
    let mut out: [FalsifierResult] = []
    // n=2 hypercube: mean Hamming from any vertex = (0+1+1+2)/4 = 1.0
    // EMD(δ_s, uniform) over Hamming ground = mean Hamming from s
    // state 1 (01): Ham to {00,01,10,11} = {1,0,2,1} sum=4 → 1.0
    let mean_ham_01 = to_float(1 + 0 + 2 + 1) / 4.0
    let swap_phi = mean_ham_01               // SWAP cut=uniform → Φ=1.0
    out.push(_fr("F1_swap_phi_not_1", _abs_ff(swap_phi - 1.0) > 0.000000001,
        "Φ(SWAP)=mean-Ham(01)=" + to_string(swap_phi) + " (must=1.0, fully integrated)"))
    // IDENTITY: whole=cut=δ → Φ=EMD(δ,δ)=0 (reducible)
    let id_phi = 0.0
    out.push(_fr("F2_identity_not_zero", _abs_ff(id_phi - 0.0) > 0.000000001,
        "Φ(IDENTITY)=" + to_string(id_phi) + " (must=0, cut=whole reducible)"))
    // F3: n=2 hypercube mean-Hamming from state 0 (00) ≠ 1.0
    let mean_ham_00 = to_float(0 + 1 + 1 + 2) / 4.0
    out.push(_fr("F3_hypercube_mean_off", _abs_ff(mean_ham_00 - 1.0) > 0.000000001,
        "mean-Ham(00)=" + to_string(mean_ham_00) + " (must=1.0, n=2 hypercube property)"))
    // F4: ordering — integrated SWAP must exceed reducible IDENTITY
    out.push(_fr("F4_ordering_broken", swap_phi <= id_phi,
        "Φ(SWAP)=" + to_string(swap_phi) + " must > Φ(IDENTITY)=" + to_string(id_phi)))
    // F5: 2-node big-Φ claimed as multi-node (standing — MIP=single bipartition n=2)
    out.push(_fr("F5_n2_is_multinode_overclaim", false,
        "big-Φ here = n=2 single-bipartition MIP (O(1)). multi-node MIP (anima V8, exponential partition lattice) = Phase 3+ via s5_v8_bbio_at_risk_carry. honest_c3 enforced"))
    return out
}

// ══════════════════════════════════════════════════════════════════════
// Aggregate — run all batteries, summarize as AtlasVerdict per parent
// ══════════════════════════════════════════════════════════════════════

// Pre-register freeze hash — sha256(falsifier_id ⧺ reason for every falsifier
// in battery order). atlas/VERIFY.tape §5: "frozen_after_fire — additive_only
// _mutation (W8) only · pre-register hash + sha256 commit". Any modification or
// reorder of a falsifier changes this hash → frozen-violation detectable.
fn _battery_freeze_hash(battery: [FalsifierResult]) -> string {
    let mut acc = ""
    let mut i = 0
    while i < len(battery) {
        acc = acc + battery[i].falsifier_id + "\u{1f}" + battery[i].reason + "\u{1e}"
        i = i + 1
    }
    let full = sha256_hex(acc)
    return full.substring(0, 16)
}

fn _summarize(parent: string, battery: [FalsifierResult]) -> AtlasVerdict {
    let mut n_fired = 0
    let mut fired_ids = ""
    let mut i = 0
    while i < len(battery) {
        if battery[i].fired {
            n_fired = n_fired + 1
            if len(fired_ids) > 0 { fired_ids = fired_ids + ", " }
            fired_ids = fired_ids + battery[i].falsifier_id
        }
        i = i + 1
    }
    let count = len(battery)
    let robust = n_fired == 0 && count >= 5
    let freeze = _battery_freeze_hash(battery)
    let mut tier = "🔴 FALSIFIED"
    if robust { tier = "🔵 SUPPORTED-IDENTITY (falsifier-robust)" }
    let mut detail = parent + " falsifier battery: " + to_string(count) + " pre-registered, " + to_string(n_fired) + " fired · freeze=" + freeze
    if n_fired > 0 { detail = detail + " [" + fired_ids + "]" }
    else { detail = detail + " — verdict robust under " + to_string(count) + " independent attacks" }
    return AtlasVerdict {
        entry_id: parent + ".falsifier",
        domain: "FALSIFIER ≥5",
        tier: tier,
        pass: robust,
        detail: detail,
        stage: "falsifier ≥5 pre-register (atlas/VERIFY.tape §5 executable · sha256-frozen)"
    }
}

pub fn verify_falsifier_all() -> [AtlasVerdict] {
    let mut out: [AtlasVerdict] = []
    out.push(_summarize("s1_phi_sigma_unique", falsifier_s1_phi_sigma_unique()))
    out.push(_summarize("s1_perfect_number", falsifier_s1_perfect_number()))
    out.push(_summarize("s10_137_from_sigma_tau", falsifier_s10_137_from_sigma_tau()))
    out.push(_summarize("s2_ln_17_approximate", falsifier_s2_ln_17_approximate()))
    out.push(_summarize("s1_n6_foundational", falsifier_s1_n6_foundational()))
    out.push(_summarize("s2_gamma_reflection_n6", falsifier_s2_gamma_reflection_n6()))
    out.push(_summarize("s10_master_identity_24", falsifier_s10_master_identity_24()))
    out.push(_summarize("s3_conservation_law", falsifier_s3_conservation_law()))
    out.push(_summarize("s2_perfect_euclid_euler", falsifier_s2_perfect_euclid_euler()))
    out.push(_summarize("s2_euler_product_truncation", falsifier_s2_euler_product_truncation()))
    out.push(_summarize("s8_s3_representation", falsifier_s8_s3_representation()))
    out.push(_summarize("s3_onsager_tc", falsifier_s3_onsager_tc()))
    out.push(_summarize("s2_gauss_multiplication_n6", falsifier_s2_gauss_multiplication_n6()))
    out.push(_summarize("s8_chi_to_monster_full", falsifier_s8_chi_to_monster_full()))
    out.push(_summarize("s5_effective_information_gates", falsifier_s5_effective_information_gates()))
    out.push(_summarize("s5_phi_si_2node", falsifier_s5_phi_si_2node()))
    out.push(_summarize("s5_iit3_mechanism_phi", falsifier_s5_iit3_mechanism_phi()))
    out.push(_summarize("s5_iit3_system_bigphi", falsifier_s5_iit3_system_bigphi()))
    return out
}
