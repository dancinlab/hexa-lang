// HEXA Native Compiler — atlas overlay surface (EXPORT-ONLY)
//
// @version 0.2.0
// @capabilities [fs_write]
//
// POLICY 2026-05-19 — atlas is unconditionally binary built-in.
// The hexa-lang atlas is compile-time embedded; its SSOT is
// compiler/atlas/embedded.gen.hexa, merged into the compiler at build
// time (SPEC.md §2.2 "atlas embedding — static, baked into compiler").
// `.n6` files (atlas.overlay.n6, atlas.append.*.n6) are now ONLY a
// `hexa atlas export` OUTPUT artifact — produced on demand for interop
// / inspection. They are NOT a runtime-loaded "live overlay".
//
// New equations discovered via `hexa kick` / `hexa verify` are absorbed
// via GitHub PR directly into the binary built-in atlas. The old runtime
// path — "~/.hx/data/atlas.overlay.n6 discovery → 3+ hits → promote into
// rodata regen" — is RETIRED. Equations do NOT pass through `.n6` to
// reach the live atlas.
//
// This module therefore keeps ONLY the write surface (overlay_append* —
// the export-artifact emitters). The runtime LOAD path (overlay_load /
// overlay_load_cached) is retired-to-empty: it returns [] unconditionally
// so the live, binary-built-in atlas is never mutated by an on-disk file.
// See @D g_atlas_binary_builtin in AGENTS.tape.
//
// .n6 export format: same syntax as the rodata seed (see
// compiler/atlas/parser), header line `@P|@C|@L|@E <id> ...` plus
// continuation lines.
//
// Why append-only:
//   * Single writer, many readers — no locking required (POSIX write(2)
//     atomicity on lines ≤ PIPE_BUF, 512 B on macOS).
//   * Crash-safe — a partial write at most truncates the LAST line; the
//     parser drops malformed lines.
//   * Audit trail — the file is a tail of every discovery in insertion
//     order; rotating is a `mv && touch` away.
//
use "compiler/atlas/parser"

// --- meta / cache ----------------------------------------------------------

@phase("parse_only")
pub struct OverlayMeta {
    file_path: string,      // resolved ~/.hx/data/atlas.overlay.n6
    entry_count: i64,       // number of nodes the cached array currently holds
    last_size: i64,         // file_size at last refresh — drives invalidation
    loaded: bool            // false until first overlay_load_cached call
}

// Module-private cache. Single overlay file per process; the cache state
// piggybacks on it. Reset across process boundaries (intentional — the
// overlay is the source of truth between runs).
let mut _g_overlay_meta: OverlayMeta = OverlayMeta {
    file_path: "",
    entry_count: 0,
    last_size: -1,
    loaded: false
}
let mut _g_overlay_cache: [AtlasNode] = []

// One-shot warning state for ID conflicts (overlay tried to override
// a rodata id — silently dropped, but flagged once on stderr).
let mut _g_overlay_warned_conflict: bool = false

// --- path resolution -------------------------------------------------------

// Resolve the hx data directory. Single helper consulted by every
// overlay/checkpoint path-construction site so the rule lives in ONE
// place. Precedence (downstream multi-tenant requirement, filed via
// archive/patches/phanes-hx-data-dir-per-tenant-isolation.md):
//
//   1. HX_DATA_DIR — explicit override; preferred for per-tenant
//      isolation (a hosted SaaS can point each job at its own dir
//      without hijacking $HOME, which would also redirect every
//      other home-relative read the process makes).
//   2. $HOME/.hx/data — historical default; preserves single-user
//      behaviour and existing test idiom (`HOME=$base` jail used by
//      drill_test / mkx_test / accumulation_test).
//   3. ".hx/data" — last-resort fallback when neither env is set
//      (matches the prior overlay_path() / checkpoint_path() shape).
//
// Trailing slash is NOT included; callers compose with "/<name>".
pub fn hx_data_dir() -> string {
    let override = env("HX_DATA_DIR")
    if len(override) > 0 { return override }
    let home = env("HOME")
    if len(home) == 0 { return ".hx/data" }
    return home + "/.hx/data"
}

pub fn overlay_path() -> string {
    return hx_data_dir() + "/atlas.overlay.n6"
}

// Create the hx data dir if missing. Idempotent — mkdir -p semantics
// under the hood. No-op on the bare ".hx/data" fallback only when
// HOME is unset AND HX_DATA_DIR is unset (caller has chosen relative).
pub fn overlay_ensure_dir() -> void {
    let dir = hx_data_dir()
    if len(dir) == 0 { return }
    mkdir(dir)
}

// --- read surface (RETIRED — atlas is binary built-in) ---------------------
//
// POLICY 2026-05-19: the runtime overlay-LOAD path is retired. The live
// atlas is unconditionally the binary built-in (compiler/atlas/embedded.gen
// → dist/atlas.hxc sidecar). No `.n6` file on disk is ever merged into the
// live atlas at runtime — `.n6` is an EXPORT artifact only. New equations
// reach the live atlas via GitHub PR into embedded.gen.hexa, never through
// an on-disk overlay. See @D g_atlas_binary_builtin in AGENTS.tape.
//
// overlay_load / overlay_load_cached are kept ONLY as stable, empty-return
// surfaces so existing callers (atlas_lookup_merged, audit_overlay, drill
// round seed-dedup) compile unchanged and observe a binary-only atlas.

// overlay_load — RETIRED. Always returns []; the on-disk `.n6` file is
// never parsed into the live atlas. parse_atlas_file remains available to
// the `hexa atlas export` artifact path (export, not runtime load).
pub fn overlay_load() -> array {
    return []
}

// overlay_load_cached — RETIRED. Always returns []. The atlas is binary
// built-in; there is no runtime overlay to cache.
pub fn overlay_load_cached() -> array {
    return []
}

// Linear scan over an overlay node list to find a node by id.
// Returns a sentinel AtlasNode with kind == "" on miss — matches
// the merger.hexa::lookup contract.
pub fn overlay_find_by_id(nodes: array, id: string) -> AtlasNode {
    let n = len(nodes)
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node.id == id { return node }
        i = i + 1
    }
    return AtlasNode {
        kind: "",
        id: id,
        raw: "",
        source_file: "",
        source_line: 0,
        grade: empty_grade(),
        edges: empty_edges()
    }
}

// --- write surface ---------------------------------------------------------

// Format an AtlasNode back into a .n6 line. The node's `raw` field
// already carries the full header + continuation block, so for
// rodata-parsed nodes the round-trip is identity. For nodes constructed
// in-memory (without a `raw` field set) we synthesize a minimal
// `@<kind> <id>` header.
fn _node_to_n6(node: AtlasNode) -> string {
    if len(node.raw) > 0 { return node.raw }
    let mut parts = []
    parts.push("@")
    parts.push(node.kind)
    parts.push(" ")
    parts.push(node.id)
    return parts.join("")
}

// Append a single AtlasNode as a .n6 record. The directory is created
// lazily on first write. No de-duplication at write time — de-dup
// happens at lookup-merge time via the rodata-wins policy.
pub fn overlay_append(node: AtlasNode) -> void {
    overlay_ensure_dir()
    let path = overlay_path()
    let line = _node_to_n6(node)
    let mut chunks = []
    chunks.push(line)
    chunks.push("\n")
    append_file(path, chunks.join(""))
    // Invalidate cache — next overlay_load_cached() will refresh.
    _g_overlay_meta = OverlayMeta {
        file_path: _g_overlay_meta.file_path,
        entry_count: _g_overlay_meta.entry_count,
        last_size: -1,
        loaded: false
    }
}

// Append a batch of raw .n6 lines verbatim. Used by drill chain for
// flush-on-checkpoint patterns where the caller already has the
// canonical line format (header + continuations joined by "\n").
// Each entry in `lines` is one logical record; we add a trailing "\n"
// between entries so the parser's blank-line guard still terminates
// the previous block cleanly.
pub fn overlay_append_lines(lines: array) -> void {
    if len(lines) == 0 { return }
    overlay_ensure_dir()
    let path = overlay_path()
    let mut chunks = []
    let mut i = 0
    while i < len(lines) {
        chunks.push(to_string(lines[i]))
        chunks.push("\n")
        i = i + 1
    }
    append_file(path, chunks.join(""))
    _g_overlay_meta = OverlayMeta {
        file_path: _g_overlay_meta.file_path,
        entry_count: _g_overlay_meta.entry_count,
        last_size: -1,
        loaded: false
    }
}

// --- conflict policy -------------------------------------------------------

// Called by the merged-lookup path when an overlay entry shadows a
// rodata id. Emits a single stderr warning per process (the cache is
// keyed on the boolean — repeated conflicts are silent so log noise
// stays bounded on heavy drill runs).
pub fn overlay_note_conflict(kind: string, id: string, rodata_src: string) -> void {
    if _g_overlay_warned_conflict { return }
    _g_overlay_warned_conflict = true
    let mut parts = []
    parts.push("[atlas-overlay] conflict ignored: overlay tried to override rodata ")
    parts.push(kind)
    parts.push(":")
    parts.push(id)
    parts.push(" (rodata src=")
    parts.push(rodata_src)
    parts.push("); rodata wins, overlay entry dropped on lookup. Further conflicts in this run are silent.")
    eprintln(parts.join(""))
}

// Test-only helper: reset cache + warning state. Smoke tests use this
// to make repeated load/append cycles deterministic. Production paths
// should never call it — the cache is correct across the natural
// process lifetime.
pub fn overlay_reset_cache() -> void {
    _g_overlay_meta = OverlayMeta {
        file_path: "",
        entry_count: 0,
        last_size: -1,
        loaded: false
    }
    _g_overlay_cache = []
    _g_overlay_warned_conflict = false
}
