// compiler/atlas/symbolic/congruence_chain_engine.hexa — Γ₀(N) invariants
//
// @version 0.1.0
// @capabilities [pure]
//
// Hexa-native port of archive-TECS-L/congruence_chain_engine.py (TECS-L
// absorption). Exact congruence-subgroup Γ₀(N) invariants and the
// "forcing chain" isotropy-lcm relations:
//
//   index   μ(N) = N·Π_{p|N}(1+1/p)         (integer form Π p^(e−1)(p+1))
//   cusps   c(N) = Σ_{d|N} φ(gcd(d, N/d))
//   e2(N)   = 0 if 4|N else Π_{p|N}(1+kron(−1,p))  (p=2 factor → 1)
//   e3(N)   = 0 if 9|N else Π_{p|N}(1+kron(−3,p))  (p=3 factor → 1)
//   genus   g(N) = (12 + μ − 3·e2 − 4·e3 − 6·c) / 12
//   dim S_k(Γ₀(N)) Riemann-Roch cusp-form dimension (k=2 ⇒ g)
//
// Closes the GAP flagged in _archive_tecs_l_absorption_manifest.md §C
// (Γ₀(N) invariant computation, Kronecker/Jacobi symbol, dim S_k). All
// exact integer arithmetic; zero external dependency (g5 hexa-native-only).
//
// Cross-link: atlas/inbox/_tecsl_calculator_port_manifest.md §B ·
// stdlib/core/math.hexa (gcd/lcm reused via local copies kept self-contained).

// ── number-theory primitives (self-contained, integer-exact) ────────────

fn _gcd(a: int, b: int) -> int {
    let mut x = if a < 0 { -a } else { a }
    let mut y = if b < 0 { -b } else { b }
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

fn _lcm(a: int, b: int) -> int {
    if a == 0 || b == 0 { return 0 }
    let m = a * b
    let am = if m < 0 { -m } else { m }
    return am / _gcd(a, b)
}

// prime factorization as parallel [prime] / [exponent] arrays.
pub struct Factorization {
    primes: [int],
    exps: [int]
}

pub fn factorize(n: int) -> Factorization {
    let mut ps: [int] = []
    let mut es: [int] = []
    if n <= 1 {
        return Factorization { primes: ps, exps: es }
    }
    let mut m = n
    let mut d = 2
    while d * d <= m {
        if m % d == 0 {
            let mut e = 0
            while m % d == 0 {
                e = e + 1
                m = m / d
            }
            ps.push(d)
            es.push(e)
        }
        d = d + 1
    }
    if m > 1 {
        ps.push(m)
        es.push(1)
    }
    return Factorization { primes: ps, exps: es }
}

pub fn divisors(n: int) -> [int] {
    let mut ds: [int] = []
    if n <= 0 { return ds }
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            ds.push(i)
            if i != n / i { ds.push(n / i) }
        }
        i = i + 1
    }
    // insertion sort (small divisor lists)
    let mut a = 1
    while a < len(ds) {
        let key = ds[a]
        let mut b = a - 1
        while b >= 0 && ds[b] > key {
            ds[b + 1] = ds[b]
            b = b - 1
        }
        ds[b + 1] = key
        a = a + 1
    }
    return ds
}

pub fn euler_phi(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let f = factorize(n)
    let mut r = n
    let mut i = 0
    while i < len(f.primes) {
        let p = f.primes[i]
        r = r * (p - 1) / p
        i = i + 1
    }
    return r
}

pub fn mobius(n: int) -> int {
    if n == 1 { return 1 }
    let f = factorize(n)
    let mut i = 0
    while i < len(f.exps) {
        if f.exps[i] > 1 { return 0 }
        i = i + 1
    }
    let k = len(f.primes)
    if k % 2 == 0 { return 1 }
    return -1
}

// Mertens function M(n) = Σ_{k=1..n} μ(k) (OEIS A002321).
// Riemann hypothesis adjacency: |M(n)| < c·√n for some c equivalent to RH;
// Mertens conjecture |M(n)|<√n was DISPROVED (Odlyzko-te Riele 1985) — so we
// store M(n) as a descriptive ground value, NOT a conjectural inequality.
// Trivial loop summation; pure integer arithmetic. M(1)=1, M(2)=0, M(3)=-1,
// M(4)=-1, M(5)=-2 ... (sign drift around 0). For n<=0 we return 0 (empty sum).
// TECS-L F20 — INBOX entry 3 (mertens·single-arg verify-fn) of the Clay-RH lane.
pub fn mertens(n: int) -> int {
    if n <= 0 { return 0 }
    let mut s = 0
    let mut k = 1
    while k <= n {
        s = s + mobius(k)
        k = k + 1
    }
    return s
}

// σ_k(n) = Σ_{d|n} d^k
pub fn sigma_k(n: int, k: int) -> int {
    if n <= 0 { return 0 }
    let ds = divisors(n)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        if k == 0 {
            s = s + 1
        } else {
            let mut term = 1
            let mut e = 0
            while e < k {
                term = term * ds[i]
                e = e + 1
            }
            s = s + term
        }
        i = i + 1
    }
    return s
}

// sopfr(n) → sum of prime factors with multiplicity (OEIS A001414).
// Trial division up to √x; the residual x>1 is the final prime factor.
// sopfr(1)=0 (empty product), sopfr(prime p)=p. Mirrors the integer-exact
// style above (while loops · % · no float) so the module flattener pulls it
// into tool/verify_cli's compile unit alongside its divisor/phi siblings —
// closes the verify_cli build-break where `_recompute`'s `return sopfr(n)`
// (verify_cli.hexa:431) had no reachable definition (sopfr lived only in
// stdlib/core/math.hexa, which verify_cli does not `use`).
pub fn sopfr(n: int) -> int {
    let mut sum = 0
    let mut x = n
    let mut d = 2
    while d * d <= x {
        while x % d == 0 {
            sum = sum + d
            x = x / d
        }
        d = d + 1
    }
    if x > 1 { sum = sum + x }
    return sum
}

// ── combinatorial / prime integer primitives (VERIFY-KIT V7) ────────────
// Pure-integer closed-forms backing OEIS sequences that the verify CLI had
// NO recompute path for (A000040 prime×67 etc.). Mirrors the sigma_k/phi
// integer-exact style above (while loops · push · no float). Each is the
// hexa-native 🔵 recompute path consumed by tool/verify_cli::_recompute.

// is_prime(n) → 1 if n is prime, else 0 (trial division to √n).
pub fn is_prime_int(n: int) -> int {
    if n < 2 { return 0 }
    if n < 4 { return 1 }
    if n % 2 == 0 { return 0 }
    let mut d = 3
    while d * d <= n {
        if n % d == 0 { return 0 }
        d = d + 2
    }
    return 1
}

// nth_prime(n) → A000040: the n-th prime (1-indexed; 1→2, 5→11).
pub fn nth_prime(n: int) -> int {
    if n < 1 { return 0 }
    let mut count = 0
    let mut cand = 1
    while count < n {
        cand = cand + 1
        if is_prime_int(cand) == 1 { count = count + 1 }
    }
    return cand
}

// factorial(n) → A000142: n! (0→1, 5→120). Exact integer product.
pub fn factorial_int(n: int) -> int {
    if n < 0 { return 0 }
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    return r
}

// catalan(n) → A000108: Cₙ = (2n)! / ((n+1)!·n!), iterative integer form
// Cₙ = Cₙ₋₁·2(2n−1)/(n+1) (0→1, 4→14). Exact (every step divides evenly).
pub fn catalan(n: int) -> int {
    if n < 0 { return 0 }
    let mut c = 1
    let mut i = 1
    while i <= n {
        c = c * 2 * (2 * i - 1) / (i + 1)
        i = i + 1
    }
    return c
}

// bell(n) → A000110: number of set partitions of an n-set (3→5, 4→15).
// Bell triangle (Aitken's array) — exact integer recurrence.
pub fn bell(n: int) -> int {
    if n < 0 { return 0 }
    if n == 0 { return 1 }
    let mut row: [int] = [1]
    let mut r = 1
    while r <= n {
        let prev = row
        let mut next: [int] = [prev[len(prev) - 1]]
        let mut j = 0
        while j < len(prev) {
            next.push(next[j] + prev[j])
            j = j + 1
        }
        row = next
        r = r + 1
    }
    return row[0]
}

// partition(n) → A000041: number of integer partitions of n (4→5, 5→7).
// Euler pentagonal-number recurrence: p(n)=Σ(−1)^(k−1)[p(n−gₖ)+p(n−gₖ')]
// with generalized pentagonal numbers gₖ=k(3k−1)/2. Exact integer DP.
pub fn partition(n: int) -> int {
    if n < 0 { return 0 }
    let mut p: [int] = []
    let mut i = 0
    while i <= n {
        p.push(0)
        i = i + 1
    }
    p[0] = 1
    let mut m = 1
    while m <= n {
        let mut s = 0
        let mut k = 1
        let mut done = 0
        while done == 0 {
            let g1 = k * (3 * k - 1) / 2
            let g2 = k * (3 * k + 1) / 2
            if g1 > m && g2 > m { done = 1 }
            else {
                let sign = if k % 2 == 1 { 1 } else { -1 }
                if g1 <= m { s = s + sign * p[m - g1] }
                if g2 <= m { s = s + sign * p[m - g2] }
                k = k + 1
            }
        }
        p[m] = s
        m = m + 1
    }
    return p[n]
}

// Jacobi symbol (a/n), n odd positive.
pub fn jacobi_symbol(a: int, n: int) -> int {
    if n <= 0 || n % 2 == 0 { return 0 }
    if n == 1 { return 1 }
    let mut aa = a % n
    if aa < 0 { aa = aa + n }
    let mut nn = n
    let mut result = 1
    while aa != 0 {
        while aa % 2 == 0 {
            aa = aa / 2
            let r = nn % 8
            if r == 3 || r == 5 { result = -result }
        }
        let t = aa
        aa = nn
        nn = t
        if aa % 4 == 3 && nn % 4 == 3 { result = -result }
        aa = aa % nn
    }
    if nn == 1 { return result }
    return 0
}

// Kronecker symbol (a/n) — extends Jacobi to even / negative modulus.
pub fn kronecker_symbol(a: int, n: int) -> int {
    if n == 0 {
        if a == 1 || a == -1 { return 1 }
        return 0
    }
    if n == 1 { return 1 }
    if n == -1 {
        if a < 0 { return -1 }
        return 1
    }
    if n == 2 {
        if a % 2 == 0 { return 0 }
        let mut r = a % 8
        if r < 0 { r = r + 8 }
        if r == 1 || r == 7 { return 1 }
        return -1
    }
    if n < 0 {
        return kronecker_symbol(a, -1) * kronecker_symbol(a, -n)
    }
    let mut s = 0
    let mut m = n
    while m % 2 == 0 {
        s = s + 1
        m = m / 2
    }
    let mut result = 1
    if s > 0 {
        let k2 = kronecker_symbol(a, 2)
        let mut i = 0
        while i < s {
            result = result * k2
            i = i + 1
        }
    }
    if m == 1 { return result }
    return result * jacobi_symbol(a, m)
}

// ── Γ₀(N) invariants ────────────────────────────────────────────────────

// μ(N) = [SL(2,Z) : Γ₀(N)] = Π_{p|N} p^(e−1)·(p+1)
pub fn gamma0_index(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let f = factorize(n)
    let mut r = 1
    let mut i = 0
    while i < len(f.primes) {
        let p = f.primes[i]
        let e = f.exps[i]
        let mut pe = 1
        let mut j = 0
        while j < e - 1 {
            pe = pe * p
            j = j + 1
        }
        r = r * pe * (p + 1)
        i = i + 1
    }
    return r
}

// c(N) = Σ_{d|N} φ(gcd(d, N/d))
pub fn gamma0_cusps(n: int) -> int {
    if n <= 0 { return 0 }
    let ds = divisors(n)
    let mut c = 0
    let mut i = 0
    while i < len(ds) {
        let d = ds[i]
        c = c + euler_phi(_gcd(d, n / d))
        i = i + 1
    }
    return c
}

// e2(N): order-2 elliptic points.
pub fn gamma0_elliptic2(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    if n % 4 == 0 { return 0 }
    let f = factorize(n)
    let mut r = 1
    let mut i = 0
    while i < len(f.primes) {
        let p = f.primes[i]
        let e = f.exps[i]
        if e >= 2 && p == 2 { return 0 }
        if p == 2 {
            r = r * 1
        } else {
            if e >= 2 { return 0 }
            r = r * (1 + kronecker_symbol(-1, p))
        }
        i = i + 1
    }
    return r
}

// e3(N): order-3 elliptic points.
pub fn gamma0_elliptic3(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    if n % 9 == 0 { return 0 }
    let f = factorize(n)
    let mut r = 1
    let mut i = 0
    while i < len(f.primes) {
        let p = f.primes[i]
        let e = f.exps[i]
        if p == 3 && e >= 2 { return 0 }
        if p == 3 {
            r = r * 1
        } else {
            if e >= 2 { return 0 }
            r = r * (1 + kronecker_symbol(-3, p))
        }
        i = i + 1
    }
    return r
}

// g(N) = 1 + μ/12 − e2/4 − e3/3 − c/2  (common-denominator integer form)
pub fn gamma0_genus(n: int) -> int {
    let mu = gamma0_index(n)
    let e2 = gamma0_elliptic2(n)
    let e3 = gamma0_elliptic3(n)
    let c = gamma0_cusps(n)
    let numerator = 12 + mu - 3 * e2 - 4 * e3 - 6 * c
    return numerator / 12
}

// dim S_k(Γ₀(N)): Riemann-Roch cusp-form dimension (k even ≥ 2).
//   k=2  ⇒ g
//   k≥4  ⇒ (k−1)(g−1) + ⌊k/4⌋·e2 + ⌊k/3⌋·e3 + (k/2−1)·c
pub fn dim_cusp_forms(k: int, n: int) -> int {
    if k < 2 || k % 2 != 0 { return 0 }
    let g = gamma0_genus(n)
    if k == 2 { return g }
    let e2 = gamma0_elliptic2(n)
    let e3 = gamma0_elliptic3(n)
    let c = gamma0_cusps(n)
    let dim = (k - 1) * (g - 1) + (k / 4) * e2 + (k / 3) * e3 + (k / 2 - 1) * c
    if dim < 0 { return 0 }
    return dim
}

// least even weight k (≤48) with dim S_k > 0; −1 if none.
pub fn first_cusp_form_weight(n: int) -> int {
    let mut k = 2
    while k < 50 {
        if dim_cusp_forms(k, n) > 0 { return k }
        k = k + 2
    }
    return -1
}

// ── forcing-chain analysis ──────────────────────────────────────────────

pub struct ForcingChain {
    n: int,
    iso_lcm: int,       // lcm of isotropy orders {1, [2 if e2>0], [3 if e3>0]}
    sigma_1: int,
    index: int,
    cusps: int,
    lcm_times_cusps_eq_sigma: bool   // the "exact match" relation
}

pub fn forcing_chain(n: int) -> ForcingChain {
    let e2 = gamma0_elliptic2(n)
    let e3 = gamma0_elliptic3(n)
    let mut il = 1
    if e2 > 0 { il = _lcm(il, 2) }
    if e3 > 0 { il = _lcm(il, 3) }
    let sig = sigma_k(n, 1)
    let mu = gamma0_index(n)
    let c = gamma0_cusps(n)
    let exact = (il * c) == sig
    return ForcingChain {
        n: n,
        iso_lcm: il,
        sigma_1: sig,
        index: mu,
        cusps: c,
        lcm_times_cusps_eq_sigma: exact
    }
}

// isotropy-lcm with the SL(2,Z) (N=1) special case: {1,2,3} → lcm 6
// (= first perfect number; the source's "why N=1 is self-referential").
pub fn isotropy_lcm(n: int) -> int {
    let e2 = gamma0_elliptic2(n)
    let e3 = gamma0_elliptic3(n)
    let mut il = 1
    if e2 > 0 { il = _lcm(il, 2) }
    if e3 > 0 { il = _lcm(il, 3) }
    return il
}
