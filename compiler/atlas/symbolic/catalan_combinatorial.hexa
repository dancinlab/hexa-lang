// compiler/atlas/symbolic/catalan_combinatorial.hexa — combinatorial primitives
//
// @version 0.1.0
// @capabilities [pure]
//
// Hexa-native port of catalan_combinatorial_n6.py from
// archive-TECS-L/.shared/calc (commit 4ee05c39; TECS-L absorption Wave 3 —
// manifest §Backlog #10, also covers the standalone "binomial" #11 helper).
//
// Closed-form combinatorial primitives (exact integer, no plotting / no
// numerology section — only the named sequence kernels):
//   binomial C(n,k)            multiplicative descent
//   catalan  Cₙ = C(2n,n)/(n+1)
//   fibonacci Fₙ               (F₀=0, F₁=1) iterative
//   bell B(n) = Σ C(n−1,k)·B(k)   set-partition count
//   stirling2 S(n,k)           explicit inclusion-exclusion formula
//   derangement !n = n!·Σ (−1)ᵏ/k!  (computed as integer sum)
//   partition p(n)             Euler pentagonal recurrence (shared kernel)
//
// n=6 reference ties (the verdict-relevant observations):
//   C₃ = 5 = sopfr(6) · C₄ = 14 = 2·M3 · catalan(6)=132=σ(6)·11
//   F₆ = 8 = φ·τ · B(6)=203 · derangement(6)=265 · p(6)=11
//
// Zero external dependency (g5). Cross-link: manifest §C / §Backlog #10,#11.

pub fn cc_factorial(n: int) -> int {
    if n <= 1 { return 1 }
    let mut r = 1
    let mut k = 2
    while k <= n {
        r = r * k
        k = k + 1
    }
    return r
}

pub fn cc_binomial(n: int, k: int) -> int {
    if k < 0 || k > n { return 0 }
    let mut kk = k
    if kk > n - kk { kk = n - kk }
    let mut num = 1
    let mut den = 1
    let mut i = 0
    while i < kk {
        num = num * (n - i)
        den = den * (i + 1)
        i = i + 1
    }
    return num / den
}

// Catalan Cₙ = C(2n,n)/(n+1)
pub fn cc_catalan(n: int) -> int {
    if n < 0 { return 0 }
    return cc_binomial(2 * n, n) / (n + 1)
}

// Fibonacci Fₙ (F₀=0, F₁=1) — iterative (recursion-free)
pub fn cc_fibonacci(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let c = a + b
        a = b
        b = c
        i = i + 1
    }
    return b
}

// Bell number B(n) = Σ_{k=0}^{n−1} C(n−1,k)·B(k), B(0)=1.
pub fn cc_bell(n: int) -> int {
    if n <= 0 { return 1 }
    let mut b: [int] = []
    b.push(1)                        // B(0)
    let mut m = 1
    while m <= n {
        let mut s = 0
        let mut k = 0
        while k < m {
            s = s + cc_binomial(m - 1, k) * b[k]
            k = k + 1
        }
        b.push(s)
        m = m + 1
    }
    return b[n]
}

// Stirling number of the 2nd kind S(n,k) = (1/k!) Σ (−1)^{k−j} C(k,j) jⁿ
pub fn cc_stirling2(n: int, k: int) -> int {
    if n == 0 && k == 0 { return 1 }
    if n == 0 || k == 0 { return 0 }
    if k > n { return 0 }
    let mut acc = 0
    let mut j = 0
    while j <= k {
        let mut sign = 1
        if (k - j) % 2 != 0 { sign = -1 }
        // jⁿ
        let mut pw = 1
        let mut e = 0
        while e < n {
            pw = pw * j
            e = e + 1
        }
        acc = acc + sign * cc_binomial(k, j) * pw
        j = j + 1
    }
    return acc / cc_factorial(k)
}

// Derangement !n = Σ_{k=0}^{n} (−1)ᵏ · n!/k!
pub fn cc_derangement(n: int) -> int {
    if n == 0 { return 1 }
    if n == 1 { return 0 }
    let nf = cc_factorial(n)
    let mut acc = 0
    let mut k = 0
    while k <= n {
        let mut sign = 1
        if k % 2 != 0 { sign = -1 }
        acc = acc + sign * (nf / cc_factorial(k))
        k = k + 1
    }
    return acc
}

// Integer-partition count p(n) — Euler pentagonal recurrence.
pub fn cc_partition_count(n: int) -> int {
    if n < 0 { return 0 }
    let mut p: [int] = []
    let mut idx = 0
    while idx <= n {
        p.push(0)
        idx = idx + 1
    }
    p[0] = 1
    let mut m = 1
    while m <= n {
        let mut total = 0
        let mut k = 1
        let mut stop = false
        while !stop {
            let g1 = (k * (3 * k - 1)) / 2
            let g2 = (k * (3 * k + 1)) / 2
            if g1 > m { stop = true }
            else {
                let mut sign = 1
                if k % 2 == 0 { sign = -1 }
                total = total + sign * p[m - g1]
                if g2 <= m { total = total + sign * p[m - g2] }
                k = k + 1
            }
        }
        p[m] = total
        m = m + 1
    }
    return p[n]
}
