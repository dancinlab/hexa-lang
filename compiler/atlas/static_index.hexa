// HEXA Native Compiler — Phase A3: static atlas index facade
//
// @version 0.1.0
// @capabilities [pure]
//
// Reads the const arrays produced by compiler/atlas/embed.hexa
// (which writes compiler/atlas/embedded.gen.hexa) and exposes the
// same shape compiler/atlas/merger.hexa does — `static_atlas()`
// returning an AtlasIndex, and `lookup_static(kind, id)` mirroring
// merger.hexa::lookup.
//
// At runtime the compiler binary should call static_atlas() exactly
// once at startup; the cost is the (zero-)cost of materializing four
// already-resident const arrays into a struct. There is NO file I/O,
// NO parsing, NO hashing — that all happened at compiler-build time.
//
// Bootstrap note (RFC-017 §3.6 compatibility):
//   On a clean checkout `compiler/atlas/embedded.gen.hexa` does not
//   yet exist (it is a build artifact, not committed). To keep this
//   file parseable we accept either:
//     (a) the generated file is present → import its consts directly
//     (b) the generated file is absent → fall back to an empty index
//         with a sentinel hash so the rest of the compiler tree still
//         compiles. tool/atlas_embed_gen.hexa is then the user-facing
//         remediation.
//
// We pick (b) by NOT `use`-ing the generated file from this module.
// Instead, `static_atlas()` calls a small wrapper `_load_embedded()`
// that the build process patches: when embedded.gen.hexa exists we
// rewrite this file (or wire it via a generated indirection module).
// For Phase A3 we ship the empty-fallback so the smoke test does not
// require the generated file to be present — Phase A4 wires the pin.

use "compiler/atlas/parser"
use "compiler/atlas/merger"

// --- fallback constants (used when embedded.gen.hexa is absent) -----------

// Sentinel hash. The empty-string sha256 is a valid 64-char hex but
// would collide with a deliberately-empty atlas; using "" is clearer
// and the A4 drift gate must reject it.
let _FALLBACK_HASH: string = ""
let _FALLBACK_SOURCE_COUNT: i64 = 0

// --- public API ------------------------------------------------------------

// static_atlas — return an AtlasIndex constructed from the embedded
// const arrays. When embedded.gen.hexa is absent (clean checkout,
// pre-A4 bootstrap) this returns an empty index with an empty hash;
// downstream code that REQUIRES a real atlas must check
//   idx.hash == "" || idx.source_count == 0
// and fail-loud per RFC-017 §3.2.
pub fn static_atlas() -> AtlasIndex {
    return AtlasIndex {
        p_nodes: [],
        c_nodes: [],
        l_nodes: [],
        e_nodes: [],
        hash: _FALLBACK_HASH,
        source_count: _FALLBACK_SOURCE_COUNT,
        duplicates: [],
        skipped_oversize: []
    }
}

// lookup_static — same signature as merger.hexa::lookup. Linear scan
// over the per-kind array; for atlas-resolve typical workloads this
// is O(unique_id_cites_in_user_program). Phase A3 keeps the linear
// scan; a packed perfect-hash variant lands later if profiling
// justifies it.
pub fn lookup_static(kind: string, id: string) -> AtlasNode {
    let idx = static_atlas()
    return lookup(idx, kind, id)
}
