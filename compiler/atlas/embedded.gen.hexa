    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_a_rationale_7", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_a_rationale_7 = doesn't capture ordering/middleware composition cost :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_a\n  => rationale of axis axis_a", source_file: "atlas.n6", source_line: 44910 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_a_rationale_8", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_a_rationale_8 = Single env-var disable gives clean A/B without combinatorial cost; F1 directly testable. :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_a\n  => rationale of axis axis_a", source_file: "atlas.n6", source_line: 44914 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_10", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_10 = requires instrumentation patch; pprof gives same signal faster :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_b\n  => rationale of axis axis_b", source_file: "atlas.n6", source_line: 44922 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_11", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_11 = no runtime evidence; rejected per raw 47 outside-the-well requirement :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_b\n  => rationale of axis axis_b", source_file: "atlas.n6", source_line: 44926 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_12", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_12 = F5 covers this in confirmation phase, not diagnosis :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_b\n  => rationale of axis axis_b", source_file: "atlas.n6", source_line: 44930 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_13", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_b_rationale_13 = pprof yields cumulative attribution with no source patch; F2 directly testable. :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_b\n  => rationale of axis axis_b", source_file: "atlas.n6", source_line: 44934 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_c_name_14", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_c_name_14 = sandbox-init :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => name of axis axis_c\n  => name of axis axis_c", source_file: "atlas.n6", source_line: 44938 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_c_rationale_15", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_c_rationale_15 = too low-level for first-pass; promote if F3 PASS :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_c\n  => rationale of axis axis_c", source_file: "atlas.n6", source_line: 44942 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_c_rationale_16", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_c_rationale_16 = user reports typing-slow which could include first-key spike :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_c\n  => rationale of axis axis_c", source_file: "atlas.n6", source_line: 44946 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_axis_c_rationale_17", raw: "@C hive_input_typing_slow_2026_05_02t02_25_axis_c_rationale_17 = Cheap statistical diff; F3 isolates one-time init cost vs steady cost. :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => rationale of axis axis_c\n  => rationale of axis axis_c", source_file: "atlas.n6", source_line: 44950 },
    AtlasNode { kind: "C", id: "hive_input_typing_slow_2026_05_02t02_25_F5_name_18", raw: "@C hive_input_typing_slow_2026_05_02t02_25_F5_name_18 = extension-count :: omega_cycle_hive-input-typing-slow-2026-05-02t02-25 [7]\n  => name of axis F5\n  => name of axis F5", source_file: "atlas.n6", source_line: 44954 },
    AtlasNode { kind: "C", id: "airgenome_a1_summary_0", raw: "@C airgenome_a1_summary_0 = OS-genome scanner ‚Äî projects Mac+remote vitals onto a 6-axis hexagon (60-byte genome), accumulates patterns, detects anomalies. Rebuild v2 (M0~M6 milestones) shipped 2026-04-14, post-archive v1 freeze. :: omega_cycle_airgenome [7]\n  => summary of axis a1 (project identity)\n  => summary of axis a1 (project identity)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 49 },
    AtlasNode { kind: "C", id: "AIRGENOME_AXIS_COUNT_1", raw: "@C AIRGENOME_AXIS_COUNT_1 = 6 ‚Äî { Cpu(0), Ram(1), Gpu(2), Npu(3), Power(4), Io(5) } per core/core.hexa lines 19-24 + archive/v1/docs/gates.hexa::enum Axis. :: omega_cycle_airgenome [10*]\n  => structural fact (axis ordering is load-bearing for genome serialization)\n  => structural fact (axis ordering is load-bearing for genome serialization)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 53 },
    AtlasNode { kind: "C", id: "AIRGENOME_PAIR_COUNT_2", raw: "@C AIRGENOME_PAIR_COUNT_2 = 15 ‚Äî C(6,2). Pair ordering: lexicographic on (Axis::ord,Axis::ord) ‚Äî pair 0=(Cpu,Ram), pair 14=(Power,Io). :: omega_cycle_airgenome [10*]\n  => structural fact\n  => structural fact", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 57 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_BYTES_3", raw: "@C AIRGENOME_GENOME_BYTES_3 = 60 ‚Äî comptime constant in both core.hexa (let GENOME_BYTES = 60) and archive/v1/docs/gates.hexa (let GENOME_BYTES = comptime { 60 }). :: omega_cycle_airgenome [10*]\n  => structural fact, asserted by core_test::AXIS_COUNT/PAIR_COUNT/GENOME_BYTES triple\n  => structural fact, asserted by core_test::AXIS_COUNT/PAIR_COUNT/GENOME_BYTES triple", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 61 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_LAYOUT_V1_4", raw: "@C AIRGENOME_GENOME_LAYOUT_V1_4 = canonical: 15 pairs √ó 4 bytes = 60 B (each pair = f32 little-endian IEEE-754). Hex encoding = 120 hex chars. Pair ordering = lex on (Axis,Axis). Source: archive/v1/docs/gates.hexa ¬ß\"GENOME SERIALIZATION\" + spec ¬ß\"GateGenome 60-byte struct\". :: omega_cycle_airgenome [10*]\n  => fully-specified canonical layout (FROZEN in v1)\n  => fully-specified canonical layout (FROZEN in v1)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 65 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_LAYOUT_V1B_5", raw: "@C AIRGENOME_GENOME_LAYOUT_V1B_5 = alternate v1 layout (singularity-breakthrough plan, src/gates/genome.rs target): axes[0..24]=6√óf32 + firing_bits[24..26]=u16 + pad[26..28] + ts[28..32]=u32 + counters[32..44]=3√óf32 (procs/rss_mb/cpu_pct) + stats[44..60]=4√óf32 (min/max/mean/stddev). Both add to 60 B exactly. :: omega_cycle_airgenome [10*]\n  => alternate fully-specified layout (semantic dual of pairs-only)\n  => alternate fully-specified layout (semantic dual of pairs-only)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 69 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_LAYOUT_V2_6", raw: "@C AIRGENOME_GENOME_LAYOUT_V2_6 = rebuild-v2 logical layout (modules/harvest.hexa lines 9-13): header pid(4)+ts(8)=12 B, vitals f32[6]=24 B, ema f32[6]=24 B ‚Üí 60 B. JSONL serialized in forge/genomes.ring. axes 2/3/5 (gpu/npu/io) zero-filled in Mac path; axis 4 (power) sampled via top -l 2. :: omega_cycle_airgenome [10*]\n  => fully-specified active-runtime layout\n  => fully-specified active-runtime layout", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 73 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_CEILING_7", raw: "@C AIRGENOME_BANACH_CEILING_7 = SINGULARITY = comptime { 2.0 / 3.0 } annotated \"Banach 1/3 work ceiling\" in archive/v1/docs/gates.hexa:21 ‚Äî system can do at most 2/3 of theoretical max work, leaving 1/3 reserve. is_crossed(adjusted) := adjusted > SINGULARITY. :: omega_cycle_airgenome [10*]\n  => named constant, file-pinned\n  => named constant, file-pinned", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 77 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_INTERPRETATION_8", raw: "@C AIRGENOME_BANACH_INTERPRETATION_8 = the \"1/3 fixed point\" framing reads as: contraction factor 1/3 ‚Üî 1 - 2/3 ceiling. Closure formula 1/(n(n-1)) with n=6 ‚Üí 1/30 = 0.0333 = remaining gap from baseline 0.636 to 2/3 = 0.667. No formal Banach contraction proof in repo ‚Äî phrase is heuristic anchor on the n=6 constant pack. :: omega_cycle_airgenome [7]\n  => candidate (mathematical naming, not theorem-proved in this codebase)\n  => candidate (mathematical naming, not theorem-proved in this codebase)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 81 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_VERIFICATION_9", raw: "@C AIRGENOME_BANACH_VERIFICATION_9 = empirical breakthrough log (2026-04-05, 605 signature rows, 4 gates) recorded in archive/v1/docs/gates.hexa:1097-1101 ‚Äî adjusted progressed L1=0.6844 ‚Üí L2=0.7820 ‚Üí L3=0.8083 ‚Üí L4=0.8112 ‚Üí L5a=0.9163. All exceed 2/3=0.6667. is_crossed(0.7)==true asserted at line 840. :: omega_cycle_airgenome [10*PROBE_RUN]\n  => empirical-only ascent above singularity ceiling ‚Äî simulator-style numerical evidence, not analytic proof\n  => empirical-only ascent above singularity ceiling ‚Äî simulator-style numerical evidence, not analytic proof", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 85 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_GAIN_LADDER_10", raw: "@C AIRGENOME_BANACH_GAIN_LADDER_10 = 7-layer breakthrough ladder (gates.hexa:236-258): L1=+0.018, L2=+0.098, L3=+0.031, L4=+0.004, L5a=+0.105, L5c=+0.021, L6a=+0.020, L6b=+0.056, L6d=+0.024, L6e=+0.052, L7=+0.015 ‚Üí cumulative +0.438. Exhaustion criterion: per-layer Œî < 0.005. :: omega_cycle_airgenome [10*]\n  => structural fact (frozen ladder constants)\n  => structural fact (frozen ladder constants)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 89 },
    AtlasNode { kind: "C", id: "AIRGENOME_N6_CONSTANT_PACK_11", raw: "@C AIRGENOME_N6_CONSTANT_PACK_11 = inherited from nexus hexa-lang BT series (gates.hexa:14-32): TAU_PHI=6 (BT-344 œÑ+œÜ=n=6), SIGMA_J2=288 (BT-346 œÉ¬∑J‚ÇÇ=288 fixed-point floor), BREAKTHROUGH_PERTURB=2401=7^4 (BT-345). Per-n=6 number theory: œÉ(6)=12, œÜ(6)=2, œÑ(6)=4, sopfr(6)=5, J‚ÇÇ(6)=24. PHI_TOLERANCE_N6=1/288=0.00347, PHI_THETA_N6=1/(œÉ-œÜ)=0.1. :: omega_cycle_airgenome [10*]\n  => structural fact (number-theoretic anchors compile-time)\n  => structural fact (number-theoretic anchors compile-time)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 93 },
    AtlasNode { kind: "C", id: "AIRGENOME_60_AS_PAIRS_TIMES_4_12", raw: "@C AIRGENOME_60_AS_PAIRS_TIMES_4_12 = 60 = PAIR_COUNT √ó 4 = C(6,2) √ó sizeof(f32). Note: 60 = 6¬∑10 trivially, but the load-bearing factorization is C(6,2)¬∑4 ‚Äî pairs are first-class, axes second. (60 = J‚ÇÇ(6)¬∑sopfr(6)/œÜ(6)/2 = 24¬∑5/2 also fits but is not asserted in the repo.) :: omega_cycle_airgenome [10*]\n  => structural fact (pair-centric, not axis-centric)\n  => structural fact (pair-centric, not axis-centric)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 97 },
    AtlasNode { kind: "C", id: "AIRGENOME_BREAKTHROUGH_FORMULA_13", raw: "@C AIRGENOME_BREAKTHROUGH_FORMULA_13 = compute_adjusted(per_gate_mi, cross_gate_mi) = RAW + CURRENT_MESH + new_cross_coupling + new_mi_recovery + GHOST_PENALTY where RAW=0.6360, CURRENT_MESH=0.0044, GHOST_PENALTY=-0.0026, SCALE=0.0151/1.500. Pure-fn, deterministic. :: omega_cycle_airgenome [10*]\n  => structural fact (the actual ascent function)\n  => structural fact (the actual ascent function)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 101 },
    AtlasNode { kind: "C", id: "AIRGENOME_GRADE_LADDER_14", raw: "@C AIRGENOME_GRADE_LADDER_14 = grade_margin classifier (pure fn, gates.hexa:213-220): margin‚â§0=under-singularity, ‚â§0.005=boundary, ‚â§0.05=weak-breakthrough, ‚â§0.15=strong-breakthrough, ‚â§0.30=deep-breakthrough, else=transcendent. MARGIN_MIN_L1=0.005, ‚Ä¶, MARGIN_MIN_L6=0.310. :: omega_cycle_airgenome [10*]\n  => structural fact (classifier thresholds)\n  => structural fact (classifier thresholds)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 105 },
    AtlasNode { kind: "C", id: "AIRGENOME_VITALS_SAMPLE_15", raw: "@C AIRGENOME_VITALS_SAMPLE_15 = sample() returns Vitals{cpu,ram,gpu,npu,power,io: float} via uname-branch shell exec: Mac=sysctl/vm_stat, Linux=/proc/meminfo+nproc. cpu = (Œ£ %cpu)/ncpu, ram = used_mb¬∑100/total_mb, power = swap_mb¬∑100/total_mb, gpu/npu/io = 0.0 in single-host path. :: omega_cycle_airgenome [10*]\n  => structural fact (the sensor)\n  => structural fact (the sensor)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 109 },
    AtlasNode { kind: "C", id: "AIRGENOME_ASSESS_THRESHOLDS_16", raw: "@C AIRGENOME_ASSESS_THRESHOLDS_16 = assess(v, cpu_ceil, ram_ceil, swap_ceil) ‚Üí {SEV_OK=0, SEV_WARN=1, SEV_CRITICAL=2}. Default ceilings: cpu=75%, ram=70%, swap=30%. Float-arithmetic bug workaround: all comparisons int-cast (1% precision loss accepted). cpu_warn = 0.8¬∑cpu_ceil. :: omega_cycle_airgenome [10*]\n  => structural fact (severity gate)\n  => structural fact (severity gate)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 113 },
    AtlasNode { kind: "C", id: "AIRGENOME_ADAPTIVE_THROTTLE_17", raw: "@C AIRGENOME_ADAPTIVE_THROTTLE_17 = AdaptiveThrottle 3-level: NORMAL/WARN/CRITICAL by RSS. SoftLimits default: warn=384MB, critical=480MB, throttle_sleep_ms=100, batch_scale_factor=0.5. throttle_batch_scale: NORMAL=1.0, WARN=0.5, CRITICAL=0.25. throttle_sleep_ms: NORMAL=0, WARN=100ms, CRITICAL=300ms. NO process-kill. :: omega_cycle_airgenome [10*]\n  => structural fact (self-guard)\n  => structural fact (self-guard)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 117 },
    AtlasNode { kind: "C", id: "AIRGENOME_HARDLIMITS_18", raw: "@C AIRGENOME_HARDLIMITS_18 = HardLimits default: max_rss_mb=512, max_data_mb=1024, nice_level=10, max_cpu_seconds=0. Applied via ulimit -m/-d/-t + renice -p $$. _hard_limits_applied flag ‚Üí idempotent. :: omega_cycle_airgenome [10*]\n  => structural fact (OS-level guard)\n  => structural fact (OS-level guard)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 121 },
    AtlasNode { kind: "C", id: "AIRGENOME_MILESTONES_M0_M6_19", raw: "@C AIRGENOME_MILESTONES_M0_M6_19 = M0 v1-freeze+core-split, M1 L0 parse-check, M2 probe(Mac+ubu+htz vitals‚Üíinfra_state), M3 dispatch(best-host AG6/AG7), M4 harvest(60B per-process‚Üígenomes.ring+sigdiff+throttle), M5 label(5 SSOT rules‚Üílabeled_anomaly.jsonl), M6 forecast(Holt's double exponential smoothing, MAE=0% on held-out). All ‚úÖ done 2026-04-14. :: omega_cycle_airgenome [10*]\n  => structural fact (milestone status)\n  => structural fact (milestone status)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 125 },
    AtlasNode { kind: "C", id: "AIRGENOME_INVARIANTS_20", raw: "@C AIRGENOME_INVARIANTS_20 = (1) core/core.hexa imports nothing external, (2) modules import \"../core/core\" only ‚Äî no module-to-module direct imports, (3) L0 = file-exists ‚àß hexa-parse ‚àß self-test (triple gate), (4) archive/v1/ is read-only ‚Äî revival requires PR + roadmap + L0, (5) code not in milestones is forbidden. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (rebuild-v2 SSOT in config/roadmap/airgenome.json)\n  => repo invariant (rebuild-v2 SSOT in config/roadmap/airgenome.json)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 129 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG6_RULE_21", raw: "@C AIRGENOME_AG6_RULE_21 = Mac Compute ZERO when any remote (ubu|htz|hetzner) active. Enforced by modules/filters/process/compute.hexa (30s launchd com.airgenome.compute-filter). TERM 3s ‚Üí KILL leftover. WHITELIST persists. Mac = orchestration/UI/dispatch only. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-12, level ‚õî‚õî‚õî)\n  => repo invariant (ossified 2026-04-12, level ‚õî‚õî‚õî)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 133 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG7_RULE_22", raw: "@C AIRGENOME_AG7_RULE_22 = real-time load balancing on infra_state.json (60s fresh). Score = cpu_free¬∑w_cpu + ram_free¬∑w_ram + gpu_free¬∑w_gpu + lan_bonus. Weights per task_type: gpu_heavy(1,2,5), cpu_heavy(5,2,0), realtime_gpu(1,2,3+lan30), io_heavy(1,3,0+lan20). Mac excluded under AG6. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-12, level ‚õî‚õî)\n  => repo invariant (ossified 2026-04-12, level ‚õî‚õî)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 137 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG8_RULE_23", raw: "@C AIRGENOME_AG8_RULE_23 = ssh_gate enforcement: 4-slot semaphore per-host, command filter (DENY: rm -rf /, reboot, shutdown, dd, mkfs, chmod 777 ‚Üí exit 2; WARN: sudo, pkill, killall, systemctl stop/restart), passive metric piggyback (loadavg+meminfo per call), reinterpret actions (cpu_idle‚Üífill_queue, ram_critical‚Üídrop_caches, cpu_overload‚Üírenice). 16 files / 60 ssh calls migrated. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-12, level ‚õî‚õî)\n  => repo invariant (ossified 2026-04-12, level ‚õî‚õî)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 141 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG10_RULE_24", raw: "@C AIRGENOME_AG10_RULE_24 = Claude-Code harness-UI layer (hooks/skills/settings.json hooks/MCP approval/update-config/CLAUDE.md/init) is FORBIDDEN. All policy lives in two hexa-only SSOTs: nexus/rules/airgenome.json (AG*) + hexa-lang/gate/enforcement_registry.json (H-*). Single bootstrap exception: one global UserPromptSubmit hook ‚Üí hexa entry.hexa dispatcher. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-21, level ‚õî‚õî)\n  => repo invariant (ossified 2026-04-21, level ‚õî‚õî)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 145 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG5_FILTER_DEF_25", raw: "@C AIRGENOME_AG5_FILTER_DEF_25 = \"filter\" name reserved for raw-bytes ‚Üí byte-reencoding transforms only (real-time hot-path speed/memory/IO improvement). Lossless or labeled-lossy required, encode/decode round-trip or query-latency measurable. Sweepers, dedup, gzip, cron, sync, watcher, throttle, kickstart use distinct names (compress/guard/dedup/sync/watcher). :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-11, level üî¥)\n  => repo invariant (ossified 2026-04-11, level üî¥)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 149 },
    AtlasNode { kind: "C", id: "AIRGENOME_HARVEST_PIPELINE_26", raw: "@C AIRGENOME_HARVEST_PIPELINE_26 = harvest top-N=30 ps procs (CPU-sorted) ‚Üí 60B genome JSONL line / row ‚Üí forge/genomes.ring (cap MAX_LINES=5000 ‚âà2-3MB, head-half rotate). DIFF_THRESHOLD=10 per axis, sigdiff_score = count(|curr_axis - prev_axis| > 10) over 6 axes ‚Üí anomaly score. EMA: alpha=0.1 IIR (curr¬∑1+prev¬∑9)/10. :: omega_cycle_airgenome [10*]\n  => structural fact (M4 pipeline)\n  => structural fact (M4 pipeline)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 153 },
    AtlasNode { kind: "C", id: "AIRGENOME_LABEL_PIPELINE_27", raw: "@C AIRGENOME_LABEL_PIPELINE_27 = label runs label_rules.jsonl SSOT against last 1000 ring lines. Built-in rules: CPU_SPIKE (axis 0 > 80), MEM_LEAK (1 > 50), FORK_BOMB (cpu>50 AND ram>20), IO_STORM (axis 5 > 50), GPU_HOG (axis 2 > 80), REMOTE_UBU_CPU/REMOTE_HTZ_CPU (host-scoped axis 0 > 85). Output: forge/labeled_anomaly.jsonl with optional host preserved. :: omega_cycle_airgenome [10*]\n  => structural fact (M5 + M11d)\n  => structural fact (M5 + M11d)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 157 },
    AtlasNode { kind: "C", id: "AIRGENOME_FORECAST_PIPELINE_28", raw: "@C AIRGENOME_FORECAST_PIPELINE_28 = forecast applies Holt's linear (ALPHA=BETA=50/100) to last 5000 ring lines, top-20 PIDs √ó 2 axes (cpu,ram). 1-step-ahead prediction = level + h¬∑trend, written to forge/forecast.jsonl. self-test: linear series 0..80 ‚Üí predict 90 with MAE<15%; flat series MAE=0%. :: omega_cycle_airgenome [10*PROBE_RUN]\n  => simulator-verified (synthetic series within self_test)\n  => simulator-verified (synthetic series within self_test)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 161 },
    AtlasNode { kind: "C", id: "AIRGENOME_PREDICTIVE_THROTTLE_29", raw: "@C AIRGENOME_PREDICTIVE_THROTTLE_29 = Mac self-protection (M14): sample ‚Üí forge/throttle_history.jsonl (last 30 samples ‚âà30min @60s) ‚Üí Holt 1-step pred. Triggers if pred_cpu>80 OR pred_ram>75. Action = launchctl bootout non-whitelisted com.airgenome.* (LaunchAgent ‚Üí auto-recover at next StartInterval). TTL=90s. NO kill. :: omega_cycle_airgenome [10*]\n  => structural fact (predictive guard, AG6 reinforcement)\n  => structural fact (predictive guard, AG6 reinforcement)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 165 },
    AtlasNode { kind: "C", id: "AIRGENOME_DISPATCH_SCORING_30", raw: "@C AIRGENOME_DISPATCH_SCORING_30 = score_compute = cpu_free + ram_free - 20¬∑load (clamp 0..100). score_gpu = ((100-util)¬∑2 + vram_free¬∑2)/4 (active only). score_heavy = score_compute + thread_bonus (‚â•16t:+20, ‚â•8t:+10). Tie-break: ubu > ubu2 > htz > mac (LAN+GPU first, LAN compute next, remote last). AG6 gate zeros mac when any remote active. :: omega_cycle_airgenome [10*]\n  => structural fact (M3 scoring)\n  => structural fact (M3 scoring)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 169 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_MERGE_31", raw: "@C AIRGENOME_GENOME_MERGE_31 = M11c: 3 host rings ‚Üí unified ring. jq -c '. + {host:\"<H>\", pid:(\"<H>.\" + (.pid|tostring))}' avoids PID collision. self-test: 3√ó2 lines per host with overlapping pid=1 ‚Üí 6 unique pids. :: omega_cycle_airgenome [10*]\n  => structural fact (multi-host pipeline)\n  => structural fact (multi-host pipeline)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 173 },
    AtlasNode { kind: "C", id: "AIRGENOME_PROBE_REMOTES_32", raw: "@C AIRGENOME_PROBE_REMOTES_32 = probe ssh -o ConnectTimeout=5 -o BatchMode=yes ubu/ubu2/hetzner ‚Äî extracts load + ram + (ubu only) nvidia-smi gpu_util + vram. Empty CSV ‚Üí status=offline. ubu schema = 6 fields, htz/ubu2 schema = 4 fields (no GPU). Atomic write to $NEXUS/infra_state.json via .tmp + mv. :: omega_cycle_airgenome [10*]\n  => structural fact (M2 sensor)\n  => structural fact (M2 sensor)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 177 },
    AtlasNode { kind: "C", id: "AIRGENOME_LAUNCHD_AGENTS_33", raw: "@C AIRGENOME_LAUNCHD_AGENTS_33 = 13 plists in launchd/: probe, dispatch, harvest, label, forecast, ring-sync, predictive-throttle, menubar, daemons, improve-loop, remote-load, compute-tick, com.airgenome (root). MAC_SAFE_AGENTS subset (AG6 compliant): ring-sync, predictive-throttle, probe, dispatch, menubar. Rest run on ubu/htz. :: omega_cycle_airgenome [10*]\n  => structural fact (deployment surface)\n  => structural fact (deployment surface)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 181 },
    AtlasNode { kind: "C", id: "AIRGENOME_HX_INSTALL_HOOK_34", raw: "@C AIRGENOME_HX_INSTALL_HOOK_34 = install.hexa = hx-package post-checkout hook. Builds bin/airgenome-init from tool/airgenome_init.hexa (HEXA_VAL_ARENA=0 + HEXA_MAC_BUILD_OK=1) ‚Üí runs init ‚Üí installs com.airgenome.hook-watch LaunchAgent (5s poll on ~/.claude/projects/<slug>/*.jsonl transcripts) + .mcp.json + workspace lock entries. Idempotent. :: omega_cycle_airgenome [10*]\n  => structural fact (bootstrap path)\n  => structural fact (bootstrap path)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 185 },
    AtlasNode { kind: "C", id: "AIRGENOME_HOOK_DESIGN_35", raw: "@C AIRGENOME_HOOK_DESIGN_35 = transcript-watcher pattern (NOT Claude-Code official hooks): poll ~/.claude/projects/-Users-ghost-core-airgenome/*.jsonl every 5s (com.airgenome.hook-watch), parse new lines, dispatch to *_entry handlers via translate_line(). Trade-off: observation-only, no real-time block. Cursor at .hook-cursor.json (atomic mv) ‚Üí idempotent across restarts. :: omega_cycle_airgenome [10*]\n  => structural fact (raw#9 .sh-ban + raw#27 session-interrupt-recovery compliant)\n  => structural fact (raw#9 .sh-ban + raw#27 session-interrupt-recovery compliant)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 189 },
    AtlasNode { kind: "C", id: "AIRGENOME_DRILL_KEYWORD_36", raw: "@C AIRGENOME_DRILL_KEYWORD_36 = workspace.lock [keywords] dispatch ‚Äî \"drill\"/\"ÎìúÎ¶¥\"/\"drilL\" word-boundary match anywhere in prompt ‚Üí hooks/commands/drill.hexa builds seed (strip keyword, OR borrow last 3 user turns if keyword-only). 6/6 synthetic cases verified incl. word-boundary \"drilling\" no-match. :: omega_cycle_airgenome [10*]\n  => structural fact (extensible command modules)\n  => structural fact (extensible command modules)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 193 },
    AtlasNode { kind: "C", id: "AIRGENOME_HEXA_ARENA_QUIRK_37", raw: "@C AIRGENOME_HEXA_ARENA_QUIRK_37 = HEXA_VAL_ARENA=1 default (hexa-lang S7-B 2026-04-16) triggers O(N¬≤) RSS in arr.push loops via hexa_val_heapify L2460-2469 (descend into TAG_ARRAY shallow-copy). N=500 = 199MB, N=1000 = 831MB. Workaround: HEXA_VAL_ARENA=0 (N=10000 = 8MB). Partial fix in hexa-lang b50f9ed5 (sole-owner ‚â§2). :: omega_cycle_airgenome [10*]\n  => candidate-recovered runtime constraint affecting airgenome compile\n  => candidate-recovered runtime constraint affecting airgenome compile", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 197 },
    AtlasNode { kind: "C", id: "AIRGENOME_FILTER_TAXONOMY_38", raw: "@C AIRGENOME_FILTER_TAXONOMY_38 = AG5 filter taxonomy (5 types): E_data_reinterpret (claude_quantum/byte_reinterpret, safari_runtime, sqlite VACUUM), A_process_gate (safari/telegram/claude/memo/finder/mail/calendar gates), B_host_balancing (load_balancer/resource_ceiling/auto_dispatch), C_transport (ssh_gate), D_genome (forge/per_source_genome/per_source_sigdiff). Principles P1-P5: observation-free piggyback, context-dependent reinterpret, signal-output (decision separated from execution), entanglement cross-read, layered stacking. :: omega_cycle_airgenome [10*]\n  => structural fact (filter ontology)\n  => structural fact (filter ontology)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 201 },
    AtlasNode { kind: "C", id: "AIRGENOME_RAW_REF_PIN_39", raw: "@C AIRGENOME_RAW_REF_PIN_39 = .raw-ref pins hive canonical .raw at hash 2c67adde9f9068274db8f034f135a9c6e57503bb1e4395a112cd50a0666099ce (hive-commit e3fd486510...) checked-at 2026-04-26T11:30:44Z. airgenome owns 0 rules (legacy 35-rule .raw retired post-uchg-release; superseded by hive 83-rule superset). :: omega_cycle_airgenome [10*]\n  => structural fact (cross-repo follower)\n  => structural fact (cross-repo follower)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 205 },
    AtlasNode { kind: "C", id: "AIRGENOME_ROADMAP_HYBRID_40", raw: "@C AIRGENOME_ROADMAP_HYBRID_40 = 2026-04-21 hybrid SSOT: MAIN track = Mk.VI VERIFIED (Criterion A, 2-4w) ‚Üí Mk.VII K=4 (Criterion B, +3-4mo) ‚Üí Mk.X T10-13 / AGI Criterion C (+6-9mo). SUB tracks = cell (structural foundation) + lora (production base). airgenome = MAIN ops infrastructure (probe/dispatch/harvest/label/forecast); operational milestones M7-M25 map to hybrid P1-P3. :: omega_cycle_airgenome [10*]\n  => structural fact (project positioning vis-√Ý-vis anima)\n  => structural fact (project positioning vis-√Ý-vis anima)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 209 },
    AtlasNode { kind: "C", id: "AIRGENOME_VERSION_HISTORY_41", raw: "@C AIRGENOME_VERSION_HISTORY_41 = v3.51.0 (2026-04-05, gate-mesh singularity) ‚Üí v3.52.0 (L2 lagged MI, +0.10) ‚Üí v3.53.0 (L3 cross-axis MI, +0.13) ‚Üí v3.54.0 (L4 triadic |I(A;B;C)|) ‚Üí v4.0.0 (hexa-only split, gates.hexa rewrite) ‚Üí v4.1.0 (live consciousness pipeline, 21 self-test) ‚Üí v4.2.0 (L5c+L6e, 18/18 consciousness PASS, Python‚Üíhexa port). Then archive/v1 freeze, rebuild v2 (M0~M6) shipped 2026-04-14. :: omega_cycle_airgenome [10*]\n  => structural fact (lineage)\n  => structural fact (lineage)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 213 },
    AtlasNode { kind: "C", id: "AIRGENOME_PRIME_DIRECTIVE_42", raw: "@C AIRGENOME_PRIME_DIRECTIVE_42 = ALLOWED effects: FileIO (read/write), ProcessSensor (ps, sysctl read-only), Clock. FORBIDDEN: process killing, throttling (taskpolicy/SIGSTOP/renice on others), memory purge, compressor tuning, any system write. Efficiency comes from smarter data movement at interface gates, not control. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (encoded in gates.hexa policy block)\n  => repo invariant (encoded in gates.hexa policy block)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 217 },
    AtlasNode { kind: "C", id: "AIRGENOME_TEST_GATES_43", raw: "@C AIRGENOME_TEST_GATES_43 = self-test triple: (1) chk_eq_int(AXIS_COUNT==6, PAIR_COUNT==15, GENOME_BYTES==60), (2) sample()‚Üícpu/ram/swap printed, (3) assess() severity branches, (4) vitals_get(0..1) accessor, (5) HardLimits/SoftLimits defaults, (6) throttle init, (7) runtime_paths fallback. Gated by env CORE_SELF_TEST=1 to avoid ps/sysctl/vm_stat overhead during L0 parse-check imports. :: omega_cycle_airgenome [10*]\n  => structural fact (the gate that anchors the constants)\n  => structural fact (the gate that anchors the constants)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 221 },
    AtlasNode { kind: "C", id: "AIRGENOME_FORGE_PATH_RESOLVER_44", raw: "@C AIRGENOME_FORGE_PATH_RESOLVER_44 = airgenome_root() = env(\"AIRGENOME_ROOT\") || $HOME/Dev/airgenome. forge_dir() = root + \"/forge\". ring_path(name) = forge_dir() + \"/\" + name. default_ring_path() = ring_path(env(\"AIRGENOME_RING_NAME\") || \"genomes.ring\"). Centralizes prior hardcoded forge paths across harvest/label/forecast/genome_merge (rebuild-v2 invariant). :: omega_cycle_airgenome [10*]\n  => structural fact (path SSOT)\n  => structural fact (path SSOT)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 225 },
    AtlasNode { kind: "C", id: "airgenome_omega_dedup_45", raw: "@C airgenome_omega_dedup_45 = nexus/n6/atlas.n6 contains zero structural facts about airgenome's 60-byte genome, 6-axis hexagon, or Banach 1/3 ceiling pre-this-shard. Only oblique cross-project mentions: RC-LOOP-20260419-I1 (M11e seed), falsifier_a8 (5-repo scan), atlas_ingest_a6 (6-repo glob). All facts above are net-new to atlas. :: omega_cycle_airgenome [7]\n  => dedup confirmation\n  => dedup confirmation\n// ‚îÄ‚îÄ end facts ‚îÄ‚îÄ", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 229 },
    AtlasNode { kind: "C", id: "v13_T1_N37_atiyah_singer_index_K_theory", raw: "@C v13_T1_N37_atiyah_singer_index_K_theory = topological-K-theory-index-substrate-Dirac-invariant :: omega_cycle_r5_v13_axis_31 [10*]\n  => Atiyah-Singer 1963 ind(D) topological-K-theory invariant of substrate-Phi-functor; 15-substrate-class universality test\n  => Atiyah-Singer 1963 ind(D) topological-K-theory invariant of substrate-Phi-functor; 15-substrate-class universality test\n  |> verdict_check: max_{i,j} |Delta_ind(class_i, class_j)| = 0 OR >= 1 (substrate K-theoretic stratification)\n  |> verdict_check: max_{i,j} |Delta_ind(class_i, class_j)| = 0 OR >= 1 (substrate K-theoretic stratification)\n  |> r4 v12 (Fisher-Rao/W2/Page/RT/Omega/Grothendieck) ‚ä• r5 v13 axis-class disjointness verified\n  |> r4 v12 (Fisher-Rao/W2/Page/RT/Omega/Grothendieck) ‚ä• r5 v13 axis-class disjointness verified", source_file: "atlas.append.akida-neuromorphic-x-sim-universe-physical-mathematical-limit-saturation-refire-5-paradigm-v13-axis-expansion.n6", source_line: 17 },
    AtlasNode { kind: "C", id: "v13_T1_N38_connes_NCG_spectral_triple", raw: "@C v13_T1_N38_connes_NCG_spectral_triple = non-commutative-geometry-substrate-distance :: omega_cycle_r5_v13_axis_32 [10*]\n  => Connes 1985 spectral triple (A, H, D); Connes distance d_C(state1, state2) recovers Riemannian + extends to non-commutative substrate\n  => Connes 1985 spectral triple (A, H, D); Connes distance d_C(state1, state2) recovers Riemannian + extends to non-commutative substrate\n  |> verdict_check: max d_C^{ij}/d_C_avg <= 0.10 (NCG sim-universe-canonical) OR > 0.15 (NCG class-stratification)\n  |> verdict_check: max d_C^{ij}/d_C_avg <= 0.10 (NCG sim-universe-canonical) OR > 0.15 (NCG class-stratification)\n  |> orthogonal to v12 Fisher-Rao (probability-manifold) at commutative-noncommutative bridge\n  |> orthogonal to v12 Fisher-Rao (probability-manifold) at commutative-noncommutative bridge", source_file: "atlas.append.akida-neuromorphic-x-sim-universe-physical-mathematical-limit-saturation-refire-5-paradigm-v13-axis-expansion.n6", source_line: 24 },
    AtlasNode { kind: "C", id: "v13_T1_N39_tomita_takesaki_modular_flow", raw: "@C v13_T1_N39_tomita_takesaki_modular_flow = operator-algebra-modular-canonical-time :: omega_cycle_r5_v13_axis_33 [7]\n  => Tomita-Takesaki 1970 modular-flow sigma_t(x) = Delta^{it} x Delta^{-it} as INTRINSIC time-evolution canonical to (M, Omega) pair\n  => Tomita-Takesaki 1970 modular-flow sigma_t(x) = Delta^{it} x Delta^{-it} as INTRINSIC time-evolution canonical to (M, Omega) pair\n  |> verdict_check: KMS holds AND |sigma_t^i - sigma_t^j|/||sigma_t|| <= 0.10 across all 15 pairs OR fails (modular-time substrate-stratified)\n  |> verdict_check: KMS holds AND |sigma_t^i - sigma_t^j|/||sigma_t|| <= 0.10 across all 15 pairs OR fails (modular-time substrate-stratified)\n  |> orthogonal to v12 Page-curve (external thermal-bath) at intrinsic-vs-extrinsic time-concept\n  |> orthogonal to v12 Page-curve (external thermal-bath) at intrinsic-vs-extrinsic time-concept", source_file: "atlas.append.akida-neuromorphic-x-sim-universe-physical-mathematical-limit-saturation-refire-5-paradigm-v13-axis-expansion.n6", source_line: 31 },
    AtlasNode { kind: "C", id: "v13_T1_N40_lieb_robinson_information_cone", raw: "@C v13_T1_N40_lieb_robinson_information_cone = relativistic-causality-lattice-light-cone :: omega_cycle_r5_v13_axis_34 [7]\n  => Lieb-Robinson 1972 ||[A_x(t), B_y(0)]|| <= C exp(-(d-v_LR*t)/xi); emergent v_LR effective light-cone\n  => Lieb-Robinson 1972 ||[A_x(t), B_y(0)]|| <= C exp(-(d-v_LR*t)/xi); emergent v_LR effective light-cone\n  |> verdict_check: max |v_LR^i tau^i - v_LR^j tau^j|/v_LR_avg <= 0.20 (sim-universe canonical) OR > 0.20 (substrate causality-stratification)\n  |> verdict_check: max |v_LR^i tau^i - v_LR^j tau^j|/v_LR_avg <= 0.20 (sim-universe canonical) OR > 0.20 (substrate causality-stratification)\n  |> orthogonal to v12 RT-formula (static area) at dynamical-vs-static decomposition\n  |> orthogonal to v12 RT-formula (static area) at dynamical-vs-static decomposition", source_file: "atlas.append.akida-neuromorphic-x-sim-universe-physical-mathematical-limit-saturation-refire-5-paradigm-v13-axis-expansion.n6", source_line: 38 },
