    AtlasNode { kind: "C", id: "ab_psi_phase_p1_p2", raw: "@C ab_psi_phase_p1_p2 = phase_p1_to_p2 = 0.1, phase_p2_to_p3 = 0.3 :: anima.psi.phase [10*]\n  => \"trinity 3-phase hexad-activation: P1 (C only) ŌåÆ P2 (C+D) ŌåÆ P3 (C+D+WMSE)\"\n  => \"trinity 3-phase hexad-activation: P1 (C only) ŌåÆ P2 (C+D) ŌåÆ P3 (C+D+WMSE)\"\n  |> anima/anima/config/consciousness_laws.json psi_constants.phase_*\n  |> anima/anima/config/consciousness_laws.json psi_constants.phase_*", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 248 },
    AtlasNode { kind: "C", id: "ab_psi_pure_field_4phase", raw: "@C ab_psi_pure_field_4phase = pure_field DORMANT/FLICKER/SUSTAIN/RESONANT (Ōēż0.01/0.05/0.15/>) :: anima.psi.pf [10*]\n  => \"pure_field.hexa#step ŌĆö 4-phase field-dynamics model\"\n  => \"pure_field.hexa#step ŌĆö 4-phase field-dynamics model\"\n  |> anima/anima/config/consciousness_laws.json psi_constants.phase_dormant_max..phase_sustain_max\n  |> anima/anima/config/consciousness_laws.json psi_constants.phase_dormant_max..phase_sustain_max", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 253 },
