    AtlasNode { kind: "C", id: "clay-cascade-s2-tick6-damped-oscillator-REFUTED-witness", raw: "@C clay-cascade-s2-tick6-damped-oscillator-REFUTED-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick4-revised-hypothesis-damped-diffusion\n  -> clay-cascade-s2-tick6-rebound-not-fittable-by-3param\n  -> clay-cascade-s2-tick6-Q-descent-only-validated\n  => \"вҳ… 7th raw 71 retraction вҖ” 3-param damped-oscillator y=y_inf+A_diff*exp(-t/tau)+A_osc*sin(omega*t)*exp(-gamma*t) REFUTED on dense 0..256 chain1d L=8 m^2 scan\"\n  => \"omega=sqrt(m^2/PSCALE) prediction FAILS (ratios 0.007x to 45x вҖ” not constant); 3-param vs single-saturation BOTH fit poorly (R^2<0.07 at m^2 in {0.10, 0.20, 0.50})\"\n  => \"low m^2 {0.01, 0.05} traces UNBOUNDED past t~128 вҖ” integer-step instability NOT damped relaxation\"", source_file: "atlas.n6", source_line: 53682 },
