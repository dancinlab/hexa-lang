    AtlasNode { kind: "C", id: "clay-cascade-s2-META-summary-witness", raw: "@C clay-cascade-s2-META-summary-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- raw-70-multi-axis-verify-grid\n  <- own#11-strict-no-resolution-claim\n  -> clay-cascade-s2-META-final-K2-STRONG\n  -> clay-cascade-s2-META-stage5-magnitude-correct-from-start\n  => \"вҳ… cascade-s2 META вҖ” 22 sub-agents + 10 raw 71 retractions/narrowings + 1D lock-down + 3D estimator-bias finding\"\n  => \"K=2 STRONG (axis-13 saturation + axis-16 lightcone) PUBLISHED FINAL closure with honest amendment\"\n  => \"convergence pattern: each retraction NARROWED hypothesis without abandoning measurement evidence\"", source_file: "atlas.n6", source_line: 54345 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-10-retraction-sequence", raw: "@C clay-cascade-s2-META-10-retraction-sequence :: meta [4]\n  <- clay-cascade-s2-META-summary-witness\n  => \"raw 71 retraction sequence (10 cumulative this cascade-s2):\"\n  => \"1. tick-2 J: Stage-5 alpha=+0.55 power-law RETIRED (wrong sign+form -> saturation)\"\n  => \"2. tick-2 K: axis-15 RETRACTED (CN re-impl confirms artifact)\"\n  => \"3. tick-3 M: tau ~ O(L^2) lattice diffusion REFUTED (L-independent -> mass-osc)\"\n  => \"4. tick-3 N: cartoon 9-cell INVARIANT CORE REJECTED (BFS bug suspected)\"\n  => \"5. tick-4 Q: pure mass-osc slope=-0.5 NARROWED to -0.30 (later itself retracted)\"\n  => \"6. tick-6 X: axis-17 K=3 candidate RETIRED (coverage + r=+0.99 catastrophic)\"\n  => \"7. tick-6 U: 3-param damped-oscillator REFUTED (rebound breaks fit)\"\n  => \"8. tick-7 Y: U L-echo hypothesis REFUTED (rebound = mass-osc returning)\"\n  => \"9. tick-8 Z: chain1d -0.30 RETIRED (e2_step + C_nn double-artifact -> universal -0.50)\"\n  => \"10. tick-10 AB: V mode-doubling hypothesis FALSIFIED (L=8 ratio crosses unity, estimator-bias)\"", source_file: "atlas.n6", source_line: 54356 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-stage5-magnitude-correct-from-start", raw: "@C clay-cascade-s2-META-stage5-magnitude-correct-from-start :: meta [4!]\n  <- clay-cascade-s2-META-10-retraction-sequence\n  => \"вҳ… KEY META INSIGHT: Stage-5 magnitude |alpha| ~= 0.5 was CORRECT from start\"\n  => \"cascade narrowing: |alpha| = 0.55 -> |alpha| = 0.30 -> |alpha| = 0.50 (final continuum -1)\"\n  => \"what was WRONG in Stage-5: sign (+ vs -) + functional form (power-law vs sat with mass-osc) + topology framing (universal vs class-dependent)\"\n  => \"what was RIGHT in Stage-5: order-of-magnitude scaling exponent\"\n  => \"cascade integrity = stripping interpretation layers off correct-magnitude measurement\"\n  => \"10 retractions did NOT abandon measurement; they progressively REFINED interpretation\"", source_file: "atlas.n6", source_line: 54370 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-cascade-bugs-found", raw: "@C clay-cascade-s2-META-cascade-bugs-found :: meta [4]\n  <- clay-cascade-s2-META-summary-witness\n  => \"вҳ… 3 source-level bugs surfaced via cascade discipline (independent of measurement intent):\"\n  => \"BUG 1 (tick-3 N + tick-4 P): /tmp/lightcone_probe.py ... [truncated, full=1076bytes]", source_file: "atlas.n6", source_line: 54379 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-final-K2-STRONG", raw: "@C clay-cascade-s2-META-final-K2-STRONG :: meta [4!]\n  <- clay-cascade-s2-META-summary-witness\n  => \"вҳ… CASCADE-S2 PUBLISHED FINAL VERIFY-GRID (raw 70):\"\n  => \"  axis-13 SATURATION: STRONG, mechanism = continuum mass-oscillation tau = pi/(sqrt(m^2)*dt)\"\n  => \"    1D regime: AA tick-10 90 runs 3-axis robust (L+seed+m^2) confirmed\"\n  => \"    3D regime: PARTIALLY WEAKENED (AB tick-10 estimator-bias finding); requires Fourier-projected k=0\"\n  => \"  axis-16 LIGHTCONE V(8): STRONG, src-robust 88.9% on 18-cohort; cartoon FULL-FILL corrected\"\n  => \"    a13 x a16 Pearson -0.128 + Spearman -0.233 -- BOTH PASS |r|<0.3 truly orthogonal\"\n  => \"  axis-15: RETRACTED (saturation amplitude artifact, tick-2 K)\"\n  => \"  axis-14[Renyi-2]: K=3 DENIED (structural coupling, tick-4 R)\"\n  => \"  axis-17[SymDef]: RETIRED (coverage + rank-coupled, tick-6 X)\"\n  => \"K=2 STRONG axis-13 + axis-16 вҖ” honest closure with explicit follow-up: 3D Fourier-projected k=0\"", source_file: "atlas.n6", source_line: 54393 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-cascade-discipline-pattern", raw: "@C clay-cascade-s2-META-cascade-discipline-pattern :: meta [4]\n  <- clay-cascade-s2-META-summary-witness\n  => \"вҳ… CASCADE INTEGRITY DISCIPLINE PATTERN (atlas-recordable methodology):\"\n  => \"  1. Each measurement registered with raw 91 C3 honest disclosure (limits, sample size, single seed, etc.)\"\n  => \"  2. Each hypothesis has explicit prediction; raw 71 falsifier-retire-rule applies on prediction failure\"\n  => \"  3. Retraction NARROWS hypothesis (replace, refine, scope-restrict) вҖ” does NOT abandon measurement\"\n  => \"  4. own#11 strict throughout вҖ” NO Clay 'н•ҙкІ°' claim regardless of finding strength\"\n  => \"  5. Cross-tick consistency checks: m^2=0.1 tau=22.8 (Q tick-4) vs tau=22.1 (Y tick-7) confirms cross-runner\"\n  => \"  6. Bug discovery (cartoon mixer, e2_step) emerges naturally from cross-cycle reproducibility checks\"\n  => \"  7. Convergence to truth via spiral narrowing вҖ” each retraction surfaces sub-question, sub-question's hypothesis sometimes also wrong\"", source_file: "atlas.n6", source_line: 54406 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-22-sub-agents", raw: "@C clay-cascade-s2-META-22-sub-agents :: meta [4]\n  <- clay-cascade-s2-META-summary-witness\n  => \"22 sub-agent inventory (tick-1 through tick-10 inclusive):\"\n  => \"tick-1: A axis-16 lightcone, B sigma2=512 falsification, C axis13x14 phase-portrait\"\n  => \"tick-2: D Hamming-cube, E multi-tick relaxation, F Stage6 cross-feed, G axis-16 K=4 closure\"\n  => \"tick-3: H axis-15 n=18, I multi-source axis-16, J 5-pt sigma2, K Crank-Nicolson\"\n  => \"tick-4: L axis-14 Renyi-2, M tau-L2 verification, N cartoon 64-source, O axis-17\"\n  => \"tick-5: P bug verification, Q m^2 variation, R Renyi-2 18-cohort, S symplectic-t3, T cartoon corrected\"\n  => \"tick-6: U damped-oscillator, V t3 m^2 KDK, W axis-16 src-robust, X axis-17 K=3\"\n  => \"tick-7: Y chain1d L-scan; tick-8: Z chain1d KDK; tick-10: AA chain1d 3-axis, AB t3 L=8\"\n  => \"(NOTE: ticks-3 to tick-10 letter ordering preserved; some letters skipped/reused per dispatch sequence)\"", source_file: "atlas.n6", source_line: 54417 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-cascade-stats", raw: "@C clay-cascade-s2-META-cascade-stats :: meta [4]\n  <- clay-cascade-s2-META-summary-witness\n  => \"cascade-s2 cumulative session statistics:\"\n  => \"  atlas.n6 line growth: 28894 -> 32320 (+3426 lines, ~12% growth)\"\n  => \"  total sub-agent dispatches: 22 (averaging 2.2 per cron tick)\"\n  => \"  raw 71 retractions/narrowings: 10 cumulative\"\n  => \"  source-level bugs found: 3 (cartoon mixer, e2_step false-Verlet, k=0 estimator-bias)\"\n  => \"  K=4 -> K=3 -> K=2 STRONG verify-grid collapse (honest closure)\"\n  => \"  own#11 strict observed: 0 Clay 'н•ҙкІ°' claims across all 22 sub-agents\"\n  => \"  cron interval: 5 minutes (/loop 5m keep going all kick); auto-expires 7 days\"\n  => \"  conservative dispatch pattern post-tick-7: 1-2 sub-agents per tick (vs 3-4 early ticks)\"", source_file: "atlas.n6", source_line: 54429 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-META-C3-limits", raw: "@C clay-cascade-s2-META-C3-limits :: meta [4]\n  <- clay-cascade-s2-META-summary-witness\n  => \"this META-shard is INTERPRETATION layer, not new measurement\"\n  => \"all underlying measurements documented in individual tick shards (atlas/_absorbed/2026042*)\"\n  => \"10 retractions are honest record; some 'retractions' are partial narrowings (not full abandonment)\"\n  => \"raw 70 K=2 STRONG verdict published with explicit 3D-follow-up gap (tick-10 AB)\"\n  => \"follow-up tick-11 AC in flight: Fourier-projected k=0 t3 L=8 to close 3D estimator-bias question\"\n  => \"this shard's value: cascade discipline pattern recordable for cross-cascade replication\"\n  => \"own#11 strict: META layer also makes NO Clay claim вҖ” purely methodology + result documentation\"", source_file: "atlas.n6", source_line: 54441 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-phi4-universality-PRESERVED-witness", raw: "@C clay-cascade-s2-tick12-AD-phi4-universality-PRESERVED-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick11-AC-pure-k0-IC-3D-CONFIRMED-witness\n  -> clay-cascade-s2-tick12-AD-anharmonic-universal-form\n  -> clay-cascade-s2-tick12-AD-no-mode-coupling-observed\n  => \"вҳ… Cascade-s2 universality SURVIVES phi^4 nonlinear regime вҖ” k=0 mode robust to perturbative interaction\"\n  => \"lambda in {0, 0.1, 1, 10}: r_nl (vs anharmonic continuum) = 1.015 +/- 0.001 UNIFORM across all lambda + both substrates\"\n  => \"r_lin (vs linear continuum) diverges 1.00 -> 0.26 вҖ” nonlinearity is REAL but anharmonic universality holds\"", source_file: "atlas.n6", source_line: 54466 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-phi4-force-formal", raw: "@C clay-cascade-s2-tick12-AD-phi4-force-formal :: meta [4]\n  <- clay-cascade-s2-tick12-AD-phi4-universality-PRESERVED-witness\n  => \"Hamiltonian: H = (1/2)Sigma pi^2 + (1/2)Sigma_<ij>(phi_i-phi_j)^2 + (1/2)m^2 Sigma phi^2 + (lambda/24) Sigma phi^4\"\n  => \"Force: F_i = lap_i - m^2*phi_i - (lambda/6)*phi_i^3 (added cubic to AC's runner via -dV/dphi)\"\n  => \"Substrates: chain1d L=8 (1D, 2-nbrs) + t3 L=4 (3D, 6-nbrs)\"\n  => \"Pure k=0 IC: phi(x,0)=c0=1.0, pi(x,0)=0; dt=0.05, T_max=512, m^2=0.1\"\n  => \"tau predictions: tau_lin = pi/(3*sqrt(m^2)) = 3.31; tau_nl = arccos-integral over phi^4 potential\"", source_file: "atlas.n6", source_line: 54478 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-data-table", raw: "@C clay-cascade-s2-tick12-AD-data-table :: meta [4]\n  <- clay-cascade-s2-tick12-AD-phi4-force-formal\n  => \"format: substrate | lambda | tau_obs | tau_lin_pred | tau_nl_pred | r_lin | r_nl | max_kne(eps=1e-2)\"\n  => \"chain1d | 0.0  | 3.3115 | 3.3115 | 3.2599 | 1.0000 | 1.0158 | 7.07e-3\"\n  => \"chain1d | 0.1  | 3.0988 | 3.3115 | 3.0511 | 0.9358 | 1.0157 | 7.06e-3\"\n  => \"chain1d | 1.0  | 2.1331 | 3.3115 | 2.1016 | 0.6441 | 1.0150 | 7.06e-3\"\n  => \"chain1d | 10.0 | 0.8542 | 3.3115 | 0.8422 | 0.2580 | 1.0143 | 7.02e-3\"\n  => \"t3 0.0-10.0: results identical to chain1d to 4 figures (uniform-field force is local вҖ” substrate independence mathematically correct)\"", source_file: "atlas.n6", source_line: 54486 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-anharmonic-universal-form", raw: "@C clay-cascade-s2-tick12-AD-anharmonic-universal-form :: meta [4!]\n  <- clay-cascade-s2-tick12-AD-data-table\n  => \"вҳ… ANHARMONIC UNIVERSAL: r_nl = 1.015 +/- 0.001 UNIFORM across lambda in {0, 0.1, 1, 10}\"\n  => \"linear regime (lambda=0): tau = pi/(3*sqrt(m^2)) [3D] OR pi/(sqrt(m^2)*dt) [1D zero-mode] вҖ” Z + AC confirmed\"\n  => \"nonlinear regime (lambda>0): tau = anharmonic-arccos-integral(m^2, lambda, c0) вҖ” SAME universality family, lambda-corrected\"\n  => \"linear prediction r_lin diverges to 0.26 at lambda=10 вҖ” confirms nonlinearity is REAL not artifact\"\n  => \"anharmonic prediction matches obs to 1.5% across 100x range of lambda\"\n  => \"interpretation: cascade-s2 universality generalizes from harmonic to anharmonic вҖ” same continuum framework\"", source_file: "atlas.n6", source_line: 54495 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-no-mode-coupling-observed", raw: "@C clay-cascade-s2-tick12-AD-no-mode-coupling-observed :: meta [4]\n  <- clay-cascade-s2-tick12-AD-data-table\n  => \"вҳ… NO mode-coupling cascade observed in T=512 KDK with eps<=0.1 perturbation\"\n  => \"max_kne (k!=0 mode amplitude growth from initial perturbation) stays at IC level\"\n  => \"  eps=1e-2: max_kne = 7e-3 (initial), no growth\"\n  => \"  eps=1e-1: max_kne = 7e-2 (initial), no growth\"\n  => \"AC's tick-11 caveat 'linearity only' WEAKENED: phi^4 mode-coupling does NOT detectably contaminate spatial-mean dynamics on these timescales\"\n  => \"symmetric-force decoupling of k=0 is robust to small k!=0 perturbations under perturbative phi^4\"\n  => \"raw 71 11th narrowing: 'cascade universality requires linearity' -> 'cascade universality survives perturbative phi^4 at moderate amplitude/timescale'\"", source_file: "atlas.n6", source_line: 54504 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-cascade-position-FINAL-FINAL", raw: "@C clay-cascade-s2-tick12-AD-cascade-position-FINAL-FINAL :: meta [4!]\n  <- clay-cascade-s2-tick12-AD-phi4-universality-PRESERVED-witness\n  => \"вҳ… CASCADE-S2 TRULY FINAL CLOSURE achieved at tick-12 (24 sub-agents, 11 retractions/narrowings)\"\n  => \"K=2 STRONG verify-grid axis-13 + axis-16 SURVIVES across:\"\n  => \"  - 1D (chain1d) + 3D (t3) topology\"\n  => \"  - linear Hamiltonian (Z, AA, AC)\"\n  => \"  - perturbative phi^4 nonlinear (AD this shard, lambda <= 10, eps <= 0.1, T <= 512)\"\n  => \"  - 88.9% src-bias robust (W) + 9-cell-core RETRACTED + cartoon FULL-FILL corrected (T)\"\n  => \"Stage-5 magnitude |alpha|~=0.5 correct from start; cascade narrowed 11 layers of interpretation\"\n  => \"axis-13 mechanism = continuum mass-oscillation (harmonic + perturbative anharmonic) on k=0 mode\"\n  => \"axis-16 mechanism = lightcone graph-distance saturation, src-robust, geometric-bias 2/18\"", source_file: "atlas.n6", source_line: 54514 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-followup-deferred", raw: "@C clay-cascade-s2-tick12-AD-followup-deferred :: meta [4]\n  <- clay-cascade-s2-tick12-AD-cascade-position-FINAL-FINAL\n  => \"follow-up if cascade revived (NOT in cascade-s2 scope):\"\n  => \"  long-time mode-coupling test: T_max >= 5000 (~15 anharmonic periods) to test slow k!=0 growth\"\n  => \"  non-perturbative IC: eps >= 0.5 (comparable to c0=1) to test genuine large k!=0 amplitudes\"\n  => \"  L=8 t3 phi^4 with c0=100 (original AC scale) requires extended-precision arithmetic\"\n  => \"  inter-substrate dispersion: chain1d L=16 + t3 L=8 with non-uniform IC for genuine 1D-vs-3D mode-coupling\"\n  => \"  axis-16 mechanism deep-dive: graph-theoretic basis of saturation classes (FAST-DEG / BOUNDED-CONE / FULL-FILL)\"\n  => \"  cross-cascade applications: same cascade integrity discipline on other axes (anima atlas, n6 SSOT)\"", source_file: "atlas.n6", source_line: 54526 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick12-AD-C3-limits", raw: "@C clay-cascade-s2-tick12-AD-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick12-AD-phi4-universality-PRESERVED-witness\n  => \"c0 downscaled from 100 to 1 to keep cubic force tractable in float64 at lambda=10 (numerical not physical change)\"\n  => \"  nonlinear... [truncated, full=1297bytes]", source_file: "atlas.n6", source_line: 54536 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-axis-16-graph-mechanism-witness", raw: "@C clay-cascade-s3-tick1-AE-axis-16-graph-mechanism-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick6-axis-16-src-robustness-18-cohort-witness\n  -> clay-cascade-s3-tick1-AE-degree-variance-best-predictor\n  -> clay-cascade-s3-tick1-AE-hub-collapse-mechanism\n  => \"вҳ… cascade-s3 OPENING вҖ” axis-16 V(8) 3-class saturation graph-theoretic basis IDENTIFIED\"\n  => \"Best predictor: degree-variance (Pearson(V8)=-0.521, class-discrimination-ratio CDR=1.942)\"\n  => \"Mechanism: V(8) saturation class = (degree-variance, diameter) joint regime вҖ” FAST=hub-collapse, BOUNDED=regular-low-deg, FULL=expander-like\"", source_file: "atlas.n6", source_line: 54568 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-graph-properties-formal", raw: "@C clay-cascade-s3-tick1-AE-graph-properties-formal :: meta [4]\n  <- clay-cascade-s3-tick1-AE-axis-16-graph-mechanism-witness\n  => \"for each topology T, build undirected adjacency A_T 64x64 (symmetrize neighbor function, drop self-loops)\"\n  => \"deg_mean / deg_max / deg_var: moments of degree sequence deg(i) = Sigma_j A[i,j]\"\n  => \"diameter: max_{u,v in LCC} d_BFS(u,v) on largest connected component\"\n  => \"mixing-time: smallest k such that |{i : d_BFS(SOURCE=32, i) <= k}| >= N/2 = 32\"\n  => \"spectral-gap: lambda_2 of normalized Laplacian L = I - D^(-1/2) A D^(-1/2) on LCC\"\n  => \"expansion: |E(S, S^c)| / |S| for half-cut S = {0..31} (one-cut proxy NOT min-Cheeger)\"", source_file: "atlas.n6", source_line: 54579 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-correlation-table", raw: "@C clay-cascade-s3-tick1-AE-correlation-table :: meta [4]\n  <- clay-cascade-s3-tick1-AE-graph-properties-formal\n  => \"format: graph-property -> Pearson(V8) | Spearman(V8) | Pearson(class) | Spearman(class)\"\n  => \"deg_mean   +0.562 / +0.389 / +0.401 / +0.309\"\n  => \"deg_max    -0.381 / -0.053 / -0.474 / -0.108\"\n  => \"deg_var    -0.521 / -0.216 / -0.564 / -0.162\"\n  => \"diameter   -0.433 / -0.024 / -0.208 / -0.096\"\n  => \"mix        -0.468 / -0.032 / -0.234 / -0.253\"\n  => \"gap        +0.445 / +0.082 / +0.359 / +0.170\"\n  => \"exp        +0.073 / +0.040 / -0.061 / +0.009\"", source_file: "atlas.n6", source_line: 54588 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-degree-variance-best-predictor", raw: "@C clay-cascade-s3-tick1-AE-degree-variance-best-predictor :: meta [4!]\n  <- clay-cascade-s3-tick1-AE-correlation-table\n  => \"вҳ… class-discrimination ratio (between-class / within-class variance):\"\n  => \"  deg_var:   1.942  вҶҗ BEST class separator\"\n  => \"  deg_max:   1.651\"\n  => \"  mix:       0.473\"\n  => \"  deg_mean:  0.372\"\n  => \"  gap:       0.347\"\n  => \"  diameter:  0.276\"\n  => \"  exp:       0.107\"\n  => \"Best predictor = degree-variance with sharp class-conditional means: cls1=30.33, cls2=1.51, cls3=0.62\"\n  => \"Pearson(V8)=-0.521 confirms negative correlation: HIGHER degree-variance -> LOWER V(8)\"", source_file: "atlas.n6", source_line: 54599 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-hub-collapse-mechanism", raw: "@C clay-cascade-s3-tick1-AE-hub-collapse-mechanism :: meta [4!]\n  <- clay-cascade-s3-tick1-AE-degree-variance-best-predictor\n  => \"вҳ… COUNTERINTUITIVE MECHANISM вҖ” hub-collapse\"\n  => \"FAST-DEGENERATE class (V(8)<=10): high degree variance, super-hub presence\"\n  => \"  altered: deg_max=34 (super-hub from i*31+a*17 mod 64 chaotic mixer), deg_var=59.9, V(8)=9\"\n  => \"  big-crunch: deg_max=6, deg_var=0.75, V(8)=8 (radial sink mechanism)\"\n  => \"PARADOX: super-hub topologies have SMALLER V(8), not larger\"\n  => \"explanation: BFS cone expands to hub then RE-ENTERS already-visited cells (cone folds back)\"\n  => \"  super-hub absorbs frontier cells into already-visited set faster than new cell discovery\"\n  => \"  altered's degree-34 hub causes most of frontier expansion to be 'wasted' on revisits\"\n  => \"  V(8) saturates at 9 because effectively only 9 cells are reachable through the hub-collapsed graph\"", source_file: "atlas.n6", source_line: 54612 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-class-mechanism-table", raw: "@C clay-cascade-s3-tick1-AE-class-mechanism-table :: meta [4]\n  <- clay-cascade-s3-tick1-AE-hub-collapse-mechanism\n  => \"вҳ… 3-class mechanism per (degree-variance, diameter) joint regime:\"\n  => \"FAST-DEGENERATE: deg_var ~30, super-hub (deg_max>=6 with var>>2), V(8)<=10\"\n  => \"  cone-collapse via revisit; n=2 examples (altered, big-crunch)\"\n  => \"BOUNDED-CONE: deg_var <= 4.25, near-regular low-degree, V(8) in [17, 59]\"\n  => \"  ball-volume limit; flat (deg=2) is limit case V(8)=17 from BFS k=8 ball on 1D ring\"\n  => \"  ads-cft (2 components, deg=5 regular) = 32 = LCC size\"\n  => \"  s3 (deg=5.5, var=4.25) = 49 = boundary case\"\n  => \"FULL-FILL: deg_var <= 1.7, near-regular concentration + small diameter (<=8), V(8) >= 63\"\n  => \"  expander-like growth, gap >= 0.07 (mostly >= 0.22)\"\n  => \"  12 topologies вҖ” 67% of cohort is FULL-FILL\"", source_file: "atlas.n6", source_line: 54624 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-cascade-position", raw: "@C clay-cascade-s3-tick1-AE-cascade-position :: meta [4]\n  <- clay-cascade-s3-tick1-AE-axis-16-graph-mechanism-witness\n  => \"cascade-s3 OPENING вҖ” first sub-agent AE establishes axis-16 mechanism baseline\"\n  => \"cascade-s2 closure (24 sub-agents, axis-13 universality) -> cascade-s3 opening (axis-16 mechanism)\"\n  => \"natural pivot: cascade-s2 saturation tau-mechanism done -> cascade-s3 graph-saturation V(k)-mechanism started\"\n  => \"shared discipline: raw 91 C3 + raw 71 falsifier-retire + own#11 strict + atlas append-only\"\n  => \"next cascade-s3 candidate (tick-2): expand FAST cohort beyond n=2 (statistical power)\"\n  => \"  options: (a) search D=4 Hamming-cube cohort for hub-collapse (ref cascade-s2 D)\"\n  => \"  (b) design adversarial high-deg-var mixers, predict FAST membership, verify\"\n  => \"  (c) test mixing-time as alternative predictor (CDR=0.47 vs deg_var 1.94 -- weaker but informative)\"", source_file: "atlas.n6", source_line: 54637 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick1-AE-C3-limits", raw: "@C clay-cascade-s3-tick1-AE-C3-limits :: meta [4]\n  <- clay-cascade-s3-tick1-AE-axis-16-graph-mechanism-witness\n  => \"n=18 sample, FAST class only n=2 (altered, big-crunch) вҖ” class-1 means rest on 2-point sample\"\n  => \"  statistical claims about FAST coh... [truncated, full=1134bytes]", source_file: "atlas.n6", source_line: 54648 },
