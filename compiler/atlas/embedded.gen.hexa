    AtlasNode { kind: "C", id: "clay-cascade-s6-AL-orthogonal-residual-estimator", raw: "@C clay-cascade-s6-AL-orthogonal-residual-estimator :: meta [4]\n  <- clay-cascade-s6-tick1-AL-axis-14-K3-PROMOTED-witness\n  => \"вҳ… a14_perp = a14_R2 - (ОІ*a13 + Оұ) by OLS regression on 18-cohort\"\n  => \"fit results: ОІ = -0.000163, Оұ = +0.405540, R^2(a14_R2 ~ a13) = 0.2873\"\n  => \"interpretation: a13 explains ~29% of a14_R2 linear variance\"\n  => \"by OLS normal equations: sum(a14_perp) = 0 AND sum(a14_perp * a13) = 0\"\n  => \"вҶ’ Pearson(a14_perp, a13) = 0 exactly (by construction)\"\n  => \"Spearman(a14_perp, a13) = +0.022 (rank-correlation also near-zero вҖ” not a linear-only artifact)\"", source_file: "atlas.n6", source_line: 55571 },
