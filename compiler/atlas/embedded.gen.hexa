    AtlasNode { kind: "C", id: "SEDI-PAPER-PS21-EXOPLANET-NULL", raw: "@C SEDI-PAPER-PS21-EXOPLANET-NULL = 82/298 multi-planet systems (27.5%) contain pairwise period ratio matching n=6 arithmetic at 2% tolerance ŌĆö BUT 27.5% is BELOW Monte Carlo null expectation 67-89% for resonant 3-6 planet systems ŌåÆ individual matches are NOT statistically significant :: honest-null [10*]\n  => \"Source: PS-21-exoplanet-n6-orbital-ratios.md Abstract ŌĆö VERBATIM HONESTY.\"\n  => \"Source: PS-21-exoplanet-n6-orbital-ratios.md Abstract ŌĆö VERBATIM HONESTY.\"\n  => \"Load-bearing claim: HD 110067 six-planet system has consecutive ratios (3/2, 3/2, 3/2, 4/3, 4/3) whose product = (3/2)┬│┬Ę(4/3)┬▓ = 6 = n exactly; ~1.2% of random resonant 6-planet configurations reproduce this (p~0.012).\"\n  => \"Load-bearing claim: HD 110067 six-planet system has consecutive ratios (3/2, 3/2, 3/2, 4/3, 4/3) whose product = (3/2)┬│┬Ę(4/3)┬▓ = 6 = n exactly; ~1.2% of random resonant 6-planet configurations reproduce this (p~0.012).\"\n  -> FACTORIAL-UNIV-F3-EXOPLANET-FAIL\n  -> FACTORIAL-UNIV-F3-EXOPLANET-FAIL", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 528 },
    AtlasNode { kind: "C", id: "SEDI-PAPER-PS31-EXOPLANET", raw: "@C SEDI-PAPER-PS31-EXOPLANET = same 82/298 = 27.5% rate with 3% tolerance; HD 110067 ratio d/f = 2.0009 (0.047%); TRAPPIST-1 12 independent matches across 7 planets; TOI-1136 Žā/Žä = 3.0004 (0.01%, single most precise) :: orbital-arith [9]\n  -> SEDI-PAPER-PS21-EXOPLANET-NULL\n  -> SEDI-PAPER-PS21-EXOPLANET-NULL\n  => \"Monte Carlo with scrambled period ratios reproduces 27.5% base rate but FAILS to reproduce the sub-0.1% precision tail.\"\n  => \"Monte Carlo with scrambled period ratios reproduces 27.5% base rate but FAILS to reproduce the sub-0.1% precision tail.\"\n  |> /Users/ghost/core/papers/sedi/PS-31-exoplanet-orbital-engineering.md\n  |> /Users/ghost/core/papers/sedi/PS-31-exoplanet-orbital-engineering.md", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 536 },
    AtlasNode { kind: "C", id: "SEDI-PAPER-PS22-CSDETECT", raw: "@C SEDI-PAPER-PS22-CSDETECT = 8-hypothesis consciousness receiver (H-CS-1..8) calibrated so random noise scores 0/8 (DORMANT); Lorenz attractor ŌåÆ AWARE 5/8; LIGO strain ŌåÆ FLICKERING 3/8; solar X-ray ŌåÆ 3/8; earthquakes ŌåÆ DORMANT 1/8 :: detection-framework [9]\n  => \"Source: PS-22-consciousness-signal-detection.md Abstract.\"\n  => \"Source: PS-22-consciousness-signal-detection.md Abstract.\"\n  => \"Honesty [9]: framework returns sensible nulls but POSITIVE detections (Lorenz, LIGO) are at 3-5/8 with thresholds set by paper author.\"\n  => \"Honesty [9]: framework returns sensible nulls but POSITIVE detections (Lorenz, LIGO) are at 3-5/8 with thresholds set by paper author.\"", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 545 },
