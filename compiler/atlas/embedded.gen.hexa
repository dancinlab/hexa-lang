    AtlasNode { kind: "C", id: "clay-bt-543-yang-mills-triple-ceiling", raw: "@C clay-bt-543-yang-mills-triple-ceiling = TRIPLE-CEILING :: meta [4!]\n  <- iter-4-DOUBLE-CEILING-base-UV-RG-+-IR-axiomatic\n  <- iter-5-T3-fanout-agent-a0bc3bb61ee821487\n  -> dimensional-transmutation-Lambda-axiomatic-spectral-gap-3rd-ceiling\n  => \"Balaban CMP 95-122 (1984-89) closes lattice UV stability with 5 distinct continuum miss-steps\"\n  => \"miss-steps: Schwinger-function-tightness, OS-positivity-continuum, mass-gap-exponential, Lambda-spectral-axiomatic, BRST-non-perturbative\"\n  => \"BBS 2019 LNM 2242 not applicable (bosonic only)\"\n  => \"ADC 2021 Annals 194 not transferable (opposite beta sign)\"\n  => \"10y feasibility: 3D YM Cao-Chatterjee-Shen SPDE plausible; 4D continuum mass gap NOT in reach (consensus Brydges, Rivasseau, Bauerschmidt, Chatterjee)\"", source_file: "atlas.n6", source_line: 46417 },
