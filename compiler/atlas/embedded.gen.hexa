    AtlasNode { kind: "C", id: "PIXIE-002-channel-count", raw: "@C PIXIE-002-channel-count = config/topics.json declares EXACTLY 8 channels in canonical sidebar order: ­¤öź-campfire, ­¤¦Ā-anima, ­¤öŁ-nexus, ­¤ÅŚ’ĖÅ-n6-architecture, ­¤ÆÄ-hexa-lang, ­¤ÉØ-hive, ­¤Ģ│’ĖÅ-void, ­¤¦¼-airgenome ŌĆö note: 8 = 6 projects + campfire + airgenome (post-hoc reading: NOT n=6, NOT Žä(8)=4, just project count) :: pixie/config/topics.json [N?]\n  => channel inventory (numerical fact, not n6-anchored)\n  => channel inventory (numerical fact, not n6-anchored)", source_file: "atlas.append.pixie-gohive-2026-04-27.n6", source_line: 55 },
    AtlasNode { kind: "C", id: "PIXIE-005-cron-period-2min", raw: "@C PIXIE-005-cron-period-2min = Cloudflare Workers scheduled() handler runs every 2 min (\"*/2 * * * *\") to wake GatewayDO and keep Discord WebSocket alive ŌĆö note: 2 = first prime, NOT 6-anchored; chosen for CF Worker tickle SLA, not n6 reasons :: pixie/worker/wrangler.toml L20, src/index.js L121 [6]\n  => operational cadence (honest non-anchor)\n  => operational cadence (honest non-anchor)", source_file: "atlas.append.pixie-gohive-2026-04-27.n6", source_line: 67 },
