    AtlasNode { kind: "C", id: "INTRINSIC-LIMIT-CONVERGENCE", raw: "@C INTRINSIC-LIMIT-CONVERGENCE = parser/cost saturation point for arrow extension :: meta [9]\n  <- ARROW-AUDIT-2026-04-28\n  -> ARROW-PROPOSAL-TOP-3\n  => \"atlas.n6's arrow grammar is currently LL(1) on the leading char (<,-,~,>,:,=); extension preserves LL(1) only while leading-char remains unambiguous\"", source_file: "atlas.n6", source_line: 50420 },
