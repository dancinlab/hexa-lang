    AtlasNode { kind: "C", id: "clay-cascade-s5-tick1-AJ-axis-14-K3-REOPENED-witness", raw: "@C clay-cascade-s5-tick1-AJ-axis-14-K3-REOPENED-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick11-AC-pure-k0-IC-3D-CONFIRMED-witness\n  <- clay-cascade-s2-tick4-axis-14-renyi2-K3-DENIED-witness\n  -> clay-cascade-s5-AJ-IC-cut-alignment-saturation\n  -> clay-cascade-s5-AJ-K3-denial-conditional-NOT-robust\n  => \"вҳ… cascade-s2 AC tick-11 untested caveat CONFIRMED вҖ” non-boundary IC restores axis-14 discrimination ~10x\"\n  => \"Shannon disc i=32 0.080 -> i=16 0.786 / i=48 0.766; Renyi-2 i=32 0.106 -> i=16 0.837 / i=48 0.803\"\n  => \"axis-14 K=3 denial (cascade-s2 R) REVERSIBLE вҖ” conditional on boundary IC, NOT topology-intrinsic\"", source_file: "atlas.n6", source_line: 55123 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AJ-3-IC-sweep-table", raw: "@C clay-cascade-s5-AJ-3-IC-sweep-table :: meta [4]\n  <- clay-cascade-s5-tick1-AJ-axis-14-K3-REOPENED-witness\n  => \"format: topology | i=16 (p/Sh/R2) | i=32 (p/Sh/R2 control) | i=48 (p/Sh/R2)\"\n  => \"flat:       0.9999/4/0.0002    | 0.4317/981/0.675   | 0.0003/0/0.0006\"\n  => \"t3:         0.7955/652/0.394   | 0.3026/843/0.548   | 0.2046/650/0.394\"\n  => \"s3:         0.5679/982/0.675   | 0.3926/953/0.648   | 0.2066/654/0.397\"\n  => \"blackhole:  0.8050/628/0.377   | 0.3286/882/0.582   | 0.1677/556/0.327\"\n  => \"wormhole:   0.9999/4/0.0002    | 0.3796/941/0.637   | 0.0000/0/0.0000\"\n  => \"ads-cft:    0.6489/912/0.608   | 0.4670/996/0.689   | 0.3541/915/0.611\"\n  => \"calabi6:    0.9998/4/0.0004    | 0.3780/940/0.635   | 0.0003/0/0.0006\"\n  => \"cartoon:    0.8581/487/0.279   | 0.3944/955/0.650   | 0.1119/395/0.222\"\n  => \"brane:      0.7839/680/0.414   | 0.2511/752/0.472   | 0.2158/675/0.413\"\n  => \"de-sitter:  0.9476/201/0.105   | 0.5024/1000/0.693  | 0.0710/264/0.141\"", source_file: "atlas.n6", source_line: 55136 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AJ-discrimination-restored", raw: "@C clay-cascade-s5-AJ-discrimination-restored :: meta [4!]\n  <- clay-cascade-s5-AJ-3-IC-sweep-table\n  => \"вҳ… DISCRIMINATION (stddev/mean) per IC center:\"\n  => \"  i=16 non-boundary: p disc=0.171, Shannon disc=0.786, Renyi-2 disc=0.837\"\n  => \"  i=32 boundary control: p disc=0.186, Shannon disc=0.080, Renyi-2 disc=0.106\"\n  => \"  i=48 non-boundary: p disc=0.838, Shannon disc=0.766, Renyi-2 disc=0.803\"\n  => \"Shannon range: i=32 [752, 1000] (saturated near 1000); i=16 [4, 982]; i=48 [0, 915]\"\n  => \"saturation-band [0.40, 0.60] count: i=32 3/10; i=16 1/10; i=48 0/10\"\n  => \"non-boundary IC mass shifts AWAY from p=0.5: mean i=16 0.841 / i=48 0.133 vs i=32 0.383\"", source_file: "atlas.n6", source_line: 55150 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AJ-IC-cut-alignment-saturation", raw: "@C clay-cascade-s5-AJ-IC-cut-alignment-saturation :: meta [4!]\n  <- clay-cascade-s5-AJ-discrimination-restored\n  => \"вҳ… MECHANISM IDENTIFIED: IC-cut alignment saturation\"\n  => \"wavepacket center coincident with bipartite cut location (i=32 = cut location)\"\n  => \"  Gaussian symmetry forces p->0.5 regardless of topology\"\n  => \"  neighbor-graph dynamics cannot break IC-imposed symmetry within 64 ticks\"\n  => \"moving center OFF the cut (i=16 -> mass left of cut -> p->1; i=48 -> mass right -> p->0)\"\n  => \"  creates asymmetric initial bipartite weight\"\n  => \"  topology-dependent transport rates across the cut become observable in late-time p\"\n  => \"  discrimination вҲқ |center - cut| heuristic\"\n  => \"prediction: any cut location вү  wavepacket center recovers discrimination\"", source_file: "atlas.n6", source_line: 55160 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AJ-K3-denial-conditional-NOT-robust", raw: "@C clay-cascade-s5-AJ-K3-denial-conditional-NOT-robust :: meta [4!]\n  <- clay-cascade-s5-AJ-IC-cut-alignment-saturation\n  => \"вҳ… raw 71 14th finding: cascade-s2 R axis-14 K=3 denial NOT robust to IC variation\"\n  => \"cascade-s2 R denied K=3 promotion based on:\"\n  => \"  Shannon disc=0.080 (noise-floor) on i=32 boundary IC\"\n  => \"  Renyi-2 disc=0.106 marginal on i=32 boundary IC\"\n  => \"  Structural coupling a14Г—a13 Spearman 0.519 + a14Г—a16 Pearson -0.370\"\n  => \"AJ this shard reveals: discrimination claim was IC-conditional\"\n  => \"  Shannon disc 10x restored on non-boundary IC вҖ” escapes saturation\"\n  => \"  Renyi-2 disc 8x restored on non-boundary IC\"\n  => \"axis-14 K=3 promotion REOPENED (NOT yet promoted)\"\n  => \"  reopening requires structural coupling retest under non-boundary IC\"\n  => \"  if a14Г—a13 + a14Г—a16 ALSO change under non-boundary IC, K=3 promotion possible\"", source_file: "atlas.n6", source_line: 55172 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AJ-cascade-s5-position", raw: "@C clay-cascade-s5-AJ-cascade-s5-position :: meta [4]\n  <- clay-cascade-s5-tick1-AJ-axis-14-K3-REOPENED-witness\n  => \"cascade-s5 OPENING вҖ” axis-14 honest re-resolution\"\n  => \"cascade map this session:\"\n  => \"  s2 axis-13 universality (24 sub-agents, continuum 1D+3D+phi^4)\"\n  => \"  s3 axis-16 mechanism (4 sub-agents, src-cond directed in-deg confirmed)\"\n  => \"  s4 joint signature (1 sub-agent, NEGATIVE non-synergistic)\"\n  => \"  s5 axis-14 IC-conditional denial (this AJ tick-1, K=3 reopened)\"\n  => \"next cascade-s5 candidate (tick-2): structural coupling retest under non-boundary IC\"\n  => \"  if a14 decouples from a13/a16 under non-boundary IC -> axis-14 K=3 promotion confirmed\"\n  => \"  if structural coupling persists -> K=3 denial robust at deeper level\"", source_file: "atlas.n6", source_line: 55186 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AJ-trapped-wavepackets", raw: "@C clay-cascade-s5-AJ-trapped-wavepackets :: meta [4]\n  <- clay-cascade-s5-AJ-3-IC-sweep-table\n  => \"вҳ… honest C3: 4/10 topologies hit p extrema {0, 1} at non-boundary IC:\"\n  => \"  flat / wormhole / calabi6 at i=16 (p=0.9999/0.9999/0.9998) and i=48 (p=0.0003/0.0000/0.0003)\"\n  => \"  these are IC-trapped wavepackets that don't propagate across cut\"\n  => \"  Shannon=0 / Renyi-2вүҲ0 represents NO information transport, NOT discrimination signal proper\"\n  => \"  excluding trapped: i=16 disc drops to ~0.4-0.5 (still well above 0.10 threshold)\"\n  => \"  this is HONEST refinement: discrimination is partly real signal, partly trapped-mass artifact\"\n  => \"for proper K=3 promotion: need topologies that DO transport at non-boundary IC AND show structural decoupling\"", source_file: "atlas.n6", source_line: 55198 },
