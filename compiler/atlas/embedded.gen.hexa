    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-mass-tau-table", raw: "@C clay-cascade-s2-tick4-mass-tau-table :: meta [4]\n  <- clay-cascade-s2-tick4-axis-13-mass-power-law-refined-witness\n  => \"format: m^2 -> tau_fit ticks | R^2 fit | predicted 2pi/sqrt(m^2) | ratio meas/pred\"\n  => \"0.01 -> 46.35 | 0.937 | 62.83 | 0.74\"\n  => \"0.05 -> 33.07 | 0.960 | 28.10 | 1.18\"\n  => \"0.10 -> 22.78 | 0.945 | 19.87 | 1.15\"\n  => \"0.20 -> 19.29 | 0.896 | 14.05 | 1.37\"\n  => \"0.50 -> 14.93 | 0.901 |  8.89 | 1.68\"\n  => \"calibration anchor: m^2=0.1 tau=22.8 matches sub-agent M tick-3 tau=23.6 within 3.5% (cross-tick consistency confirmed)\"", source_file: "atlas.n6", source_line: 53403 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-mass-power-law-slope-minus-0-30", raw: "@C clay-cascade-s2-tick4-mass-power-law-slope-minus-0-30 :: meta [4!]\n  <- clay-cascade-s2-tick4-mass-tau-table\n  => \"log(tau) vs log(m^2) regression: slope = -0.2992 +/- (intercept=2.4943) R^2=0.9794\"\n  => \"predicted slope -0.500 (pure mass-oscillation tau ~ 1/sqrt(m^2)) | observed -0.300 | |delta|=0.20\"\n  => \"ratio tau_meas/(2pi/sqrt(m^2)) drifts MONOTONICALLY 0.74 -> 1.68 over m^2 in [0.01, 0.5] вҖ” NOT constant\"\n  => \"if pure mass-oscillation, ratio should be constant вҖ” monotone drift refutes pure form\"\n  => \"verdict: power law REAL (R^2=0.98), exponent -0.30 NOT -0.50, mass dependence weaker than sqrt(m^2)\"", source_file: "atlas.n6", source_line: 53413 },
