    AtlasNode { kind: "C", id: "clay-cascade-s2-tick6-V-tau-extractor-mismatch", raw: "@C clay-cascade-s2-tick6-V-tau-extractor-mismatch :: meta [4]\n  <- clay-cascade-s2-tick6-V-data-table\n  => \"вҳ… raw 91 C3 critical caveat: tau-extractor differs across cascade-s2 measurements\"\n  => \"Sub-agent Q tick-4: tau via descent-only saturation fit y=y_inf+A*exp(-t/tau) on dissipative-LOOKING e2_step output\"\n  => \"Sub-agent V tick-6 (this work): tau_half = peak-to-trough on conservative KDK output (oscillates not dissipates)\"\n  => \"if e2_step is fundamentally non-dissipative but appears dissipative due to integer truncation, Q's saturation fit measures FALSE saturation\"\n  => \"if true: Q's slope -0.30 is integrator artifact; t3 -0.494 is universal regime\"\n  => \"Z apples-to-apples test resolves: chain1d under SAME extractor + SAME integrator class as t3\"", source_file: "atlas.n6", source_line: 53767 },
