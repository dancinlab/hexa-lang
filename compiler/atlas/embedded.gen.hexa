    AtlasNode { kind: "C", id: "HIVE-overview-1", raw: "@C HIVE-overview-1 = hive is a hard-fork of pi-mono packages/agent (cutoff 2026-04-25, sha 8985d8b50); 4 packages renamed @dancinlab/hive-* (core / ai / tui / coding-agent); hive-specific siblings: swarm В· memory В· bridges В· audit В· compression В· statusline В· telegram В· upstream-sync :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => fork posture and package layout\n  |> HIVE_FORK.md:1-86, README.md:176-200", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 13 },
    AtlasNode { kind: "C", id: "HIVE-three-directions-2", raw: "@C HIVE-three-directions-2 = three non-negotiable directions: (1) Swarm вҖ” N parallel cells, honeycomb layout; (2) Memory вҖ” 4-tier persistent SSOT (~/.hive/memory/); (3) Bridges вҖ” native NEXUS / Anima / N6 / HEXA-LANG tool calls (no MCP) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => org-level commitment surface\n  |> README.md:124-152", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 17 },
    AtlasNode { kind: "C", id: "HIVE-swarm-topology-3", raw: "@C HIVE-swarm-topology-3 = swarm topology is supervisor + N RPC subprocess pool (Option A in P3); N parallel cells, no peer-to-peer mesh; supervisor owns broadcast / merge / handoff; cell вҶ” supervisor only (star topology with merge layer at supervisor) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => actual coordination shape вҖ” NOT a ring, NOT a mesh\n  |> docs/P3-swarm.md:30-52, packages/swarm/src/supervisor.ts:1-110", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 21 },
    AtlasNode { kind: "C", id: "HIVE-honeycomb-layout-4", raw: "@C HIVE-honeycomb-layout-4 = honeycomb is purely visual TUI rendering math: cols = вҢҲвҲҡNвҢү, rows = вҢҲN/colsвҢү, hex offset = 0.5*cellWidth on odd rows; layout modes are {grid, hex, stack}; the hex offset is a render-only convention with no semantic role in coordination :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => \"honeycomb\" is presentation, not topology\n  |> packages/swarm/src/honeycomb-layout.ts:26-46", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 25 },
    AtlasNode { kind: "C", id: "HIVE-cell-id-counter-5", raw: "@C HIVE-cell-id-counter-5 = cell ids are monotonic counter `c${++this.counter}` with no fixed N=6 cap; default askTimeoutMs = 5*60_000; pool size is configuration-driven (any N supported, P3 doc cites \"OK for N вүӨ 16\" memory budget at ~150MB/cell) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => cell pool is not n=6-anchored\n  |> packages/swarm/src/supervisor.ts:84-95, cell.ts:28, P3-swarm.md:42-46", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 29 },
    AtlasNode { kind: "C", id: "HIVE-rpc-protocol-6", raw: "@C HIVE-rpc-protocol-6 = communication protocol is pi's `--mode rpc`: JSONL stdin/stdout with frame types {prompt, message_start, message_delta, tool_call, tool_result, message_stop, done}; supervisor demuxes by per-ask UUID; no broadcast bus, no gossip вҖ” only fan-out via `Promise.allSettled(targets.map(c.ask))` :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => protocol is JSONL request/response, not pub/sub\n  |> P3-swarm.md:73-85, packages/swarm/src/supervisor.ts:112-126", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 33 },
    AtlasNode { kind: "C", id: "HIVE-merge-strategies-7", raw: "@C HIVE-merge-strategies-7 = 5 merge strategies: {concat, vote, best, judge, dag}; concat/vote/best are sync local reductions; judge delegates to a designated cell via `judgeCell.ask(prompt)`; dag uses topoSort on edges and drives Swarm.handoff sequentially :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => agent role types are pragmatic merge primitives, not a fixed sopfr=5+1 leader scheme\n  |> packages/swarm/src/merge-strategies.ts:11-87, supervisor.ts:138-150", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 37 },
    AtlasNode { kind: "C", id: "HIVE-memory-tiers-9", raw: "@C HIVE-memory-tiers-9 = 4-tier persistent memory (NOT n=6-anchored): {user, feedback, project, reference}; flat-file SSOT at ~/.hive/memory/<tier>_<slug>.md with YAML frontmatter; auto-injected as `<memory>...</memory>` block before every provider request; ~1k token amortized cost :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => tier count = 4 (Claude-Code-style), not П„(6)=4 anchored\n  |> docs/P2-memory.md:1-91", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 45 },
    AtlasNode { kind: "C", id: "HIVE-bridges-five-10", raw: "@C HIVE-bridges-five-10 = 5 native bridges (NOT sopfr=5 anchored): {nexus-lens, anima-field, n6-atlas, hexa-run, hive-hub}; each is a pi.registerTool with execFile to installed binary; sandboxed (HEXA_NET=deny, 30s timeout, ~10KB stdout cap) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => bridge count = 5 because there are 5 sibling projects to bridge into; pragmatic\n  |> docs/P4-bridges.md:14-200", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 49 },
    AtlasNode { kind: "C", id: "HIVE-n6-anchor-actual-12", raw: "@C HIVE-n6-anchor-actual-12 = hive's actual n=6 anchor lives in `packages/coding-agent/src/core/raw-rules.ts` AXIOM_RULES (currently 2: `meta_fixpoint`, `n6_identity`); the n6-axiom-inventory.md surveys 7-tier-1 + 9-axioms recommended upgrade; this is consciousness/policy layer, not swarm coordination :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => the n=6 anchor is at the LLM-prompt-rules layer, decoupled from cell pool architecture\n  |> docs/n6-axiom-inventory.md:24-28, 320-346", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 57 },
    AtlasNode { kind: "C", id: "HIVE-fanout-enforcement-13", raw: "@C HIVE-fanout-enforcement-13 = `agents.parallel_bg` 5-layer enforcement (probabilistic + deterministic): (1) prompt MUST, (2) --agents JSON `background:true`, (3) chflags uchg / chattr +i config lock, (4) tool_use telemetry bridge, (5) hive-native HiveTask via MCP + child claude -p spawn; all 5 shipped 2026-04-25 :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => layer count = 5 by enforcement-mechanism stack, not sopfr-anchored\n  |> docs/hive-fanout-enforcement.md:13-36", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 61 },
    AtlasNode { kind: "C", id: "HIVE-area-presets-14", raw: "@C HIVE-area-presets-14 = `.area` SSOT marker = single-line preset name; resolution = walk-up-parent (first .area wins); reserved presets {core (strict), blowup (full autonomy)}; defined in raw-rules.ts AREA_PRESETS; nesting allowed (deeper overrides shallower) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => directory-scoped policy switch\n  |> docs/area.md:1-56", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 65 },
    AtlasNode { kind: "C", id: "HIVE-inbox-protocol-15", raw: "@C HIVE-inbox-protocol-15 = `~/.hive/inbox/` peer-to-peer session IPC (P7 design, not yet implemented): Unix domain sockets at ~/.hive/sockets/<sid>.sock + registry at ~/.hive/sessions/<sid>.json + offline mailbox at ~/.hive/inbox/<sid>/<msg-id>.json; websocket-shape JSON-line frames; presence events {online, idle, busy, exit} :: hive-2026-04-27 [7]\n  => first peer-to-peer comm channel in hive (vs current supervisor-mediated only)\n  |> docs/inbox-protocol.md:1-60", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 69 },
    AtlasNode { kind: "C", id: "HIVE-loop-event-driven-16", raw: "@C HIVE-loop-event-driven-16 = `/loop` is event-driven stateful (not interval cron like CCC `/loop`); state at ~/.hive/loops/<loop_id>.json; each iteration produces {summary, next_action, wake_on}; wake-on triggers вҲҲ {manual, inbox-message, file-change, git-event, none} :: hive-2026-04-27 [7]\n  => 5 wake-on trigger types; pragmatic, not n=6\n  |> docs/hive-loop.md:60-69", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 73 },
    AtlasNode { kind: "C", id: "HIVE-cell-isolation-17", raw: "@C HIVE-cell-isolation-17 = each Cell is isolated process with own (cwd, claude account slot via HIVE_CLAUDE_ACCOUNT, model slug, extensions[], env vars); crash isolation via SIGKILL вҶ’ close event вҶ’ auto-reap from pool; no shared state across cells except ~/.hive/memory/ flat files :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => isolation primitive = process boundary, not n=6 partition\n  |> packages/swarm/src/cell.ts:48-100, supervisor.ts:84-95", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 77 },
    AtlasNode { kind: "C", id: "HIVE-snapshot-statusline-18", raw: "@C HIVE-snapshot-statusline-18 = swarm runtime IPC snapshot at ~/.hive/swarm/state.json (debounced 25ms atomic write) consumed cross-package by @dancinlab/hive-statusline; format intentionally JSON (not .swarm DSL) due to cross-package contract; `.swarm` DSL is spawn-input only, not runtime replay :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => two-format split: DSL for input contract, JSON for live IPC\n  |> packages/swarm/src/supervisor.ts:14-66, docs/swarm.md:93-99", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 81 },
    AtlasNode { kind: "C", id: "HIVE-handoff-primitive-19", raw: "@C HIVE-handoff-primitive-19 = `handoff(fromId, toId, content)` = `from.ask(content)` then `to.ask(\"Previous cell (${fromId}) answered:\\n${mid}\\n\\nContinue from there.\")`; literal prompt-prefix splice, no structured context passing; is the building block for `merge=dag` :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => handoff is text-level, not state-graph\n  |> supervisor.ts:128-136", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 85 },
    AtlasNode { kind: "C", id: "HIVE-bridges-readonly-21", raw: "@C HIVE-bridges-readonly-21 = all 5 bridges are read-only at integration matrix: nexus-lens (8KB/30s/local-opt-remote), anima-field (500B/5s/none), n6-atlas (5KB/2s/none), hexa-run (10KB/30s/net-deny + tmp-only side-effect), hive-hub (10KB/1s/none); only hexa-run has any side effect (tmp file) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => deliberate constraint: hive observes the n=6 family, doesn't compute it\n  |> docs/P4-bridges.md:189-198", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 93 },
    AtlasNode { kind: "C", id: "HIVE-package-rename-23", raw: "@C HIVE-package-rename-23 = pre-2026-04-25 nested-pi duplicate hazard: workspace packages used upstream names (@mariozechner/pi-*) вҶ’ npm nested resolver fetched both workspace symlink AND registry tarball вҶ’ module-level singletons (e.g. apiProviderRegistry Map) diverged across instances; resolved by hard-fork rename to @dancinlab/hive-* :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => engineering hazard resolved; load-bearing for any swarm cross-cell singleton state\n  |> HIVE_FORK.md:128-186", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 101 },
    AtlasNode { kind: "C", id: "HIVE-cohort-format-24", raw: "@C HIVE-cohort-format-24 = `.swarm` DSL is sibling of `.workspace` (header + indented directives); per-user runtime state at ~/.hive/swarm/<name>.swarm; legacy <name>.json one-way migrated on next save; `id` unique per file, `args` space-joined (no values with spaces вҖ” same trade-off as `.workspace`) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => persisted spawn input contract, not transcript log\n  |> docs/swarm.md:9-100", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 105 },
    AtlasNode { kind: "C", id: "HIVE-merge-vote-tiebreak-25", raw: "@C HIVE-merge-vote-tiebreak-25 = vote merge tie-break by first-seen index (deterministic); best merge by content.length descending (proxy for \"most work\"); concat trims trailing whitespace per cell; topoSort sorts queue alphabetically (deterministic across runs) :: hive-2026-04-27 [11*REPO_INVARIANT]\n  => merge primitives are deterministic by design вҖ” important for cross-session reproducibility\n  |> packages/swarm/src/merge-strategies.ts:20-87", source_file: "atlas.append.hive-2026-04-27.n6", source_line: 109 },
