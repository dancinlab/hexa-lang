    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-4-robustness-checks-formal", raw: "@C clay-cascade-s7-AM-4-robustness-checks-formal :: meta [4]\n  <- clay-cascade-s7-tick1-AM-K3-DOWNGRADE-REVERT-witness\n  => \"(1) Bootstrap (B=1000): resample 18 indices with replacement, refit OLS, recompute Gate B\"\n  => \"  PASS criterion: 97.5% percentile of |r| < 0.30 BOTH (Pearson + Spearman)\"\n  => \"(2) LOO: drop each topology k=1..18, refit OLS on n=17, Gate B on remainder\"\n  => \"  PASS criterion: max |r| across 18 LOO drops < 0.30\"\n  => \"(3) Alt-IC=48: re-run AL pipeline with center=48 (vs IC=16)\"\n  => \"  PASS criterion: Gate B passes |r|<0.3 at IC=48 (parallel to IC=16)\"\n  => \"(4) Quadratic: OLS a14 = ОІ1В·a13 + ОІ2В·a13ВІ + Оұ + Оө\"\n  => \"  PASS criterion: Gate B widens (|r| reduces) under nonlinear residualization\"", source_file: "atlas.n6", source_line: 55691 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-bootstrap-FAIL", raw: "@C clay-cascade-s7-AM-bootstrap-FAIL :: meta [4!]\n  <- clay-cascade-s7-AM-4-robustness-checks-formal\n  => \"вҳ… BOOTSTRAP B=1000 FAIL\"\n  => \"  |Pearson(perp, a16)| 95% CI: [0.025, 0.613] вҖ” 97.5% upper = 0.613 (exceeds 0.30 threshold)\"\n  => \"  |Spearman(perp, a16)| 95% CI: [0.026, 0.732] вҖ” 97.5% upper = 0.732\"\n  => \"  median values already exceed threshold: Pearson=0.311, Spearman=0.384\"\n  => \"  AL's Gate B Pearson=0.218 + Spearman=0.271 was a FAVORABLE DRAW within wide bootstrap distribution\"\n  => \"  Pearson SE estimate ~0.24 confirmed (consistent with AL's caveat)\"\n  => \"interpretation: at n=18, Gate B coupling distribution is so wide that |r|<0.3 is hit-or-miss\"", source_file: "atlas.n6", source_line: 55702 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-LOO-FAIL", raw: "@C clay-cascade-s7-AM-LOO-FAIL :: meta [4!]\n  <- clay-cascade-s7-AM-4-robustness-checks-formal\n  => \"вҳ… LEAVE-ONE-OUT FAIL вҖ” 6/18 drops produce Gate B violation\"\n  => \"Worst-case Pearson = 0.4095 (drop calabi6) [calabi6 a13=2889 high-leverage outlier]\"\n  => \"Worst-case Spearman = 0.5500 (drop calabi6)\"\n  => \"Gate B FAIL on 6 LOO drops: flat, brane, cartoon, nested, calabi6, bubble\"\n  => \"calabi6 is statistical leverage point вҖ” D=6 outlier (a13=2889, far from cohort mean ~430)\"\n  => \"  removing calabi6 dramatically shifts OLS ОІ + Оұ вҶ’ residual structure changes\"\n  => \"  AL's K=3 promotion was calabi6-dependent in part\"\n  => \"promotion is sample-fragile, NOT topology-invariant\"", source_file: "atlas.n6", source_line: 55712 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-alt-IC48-PASS-only", raw: "@C clay-cascade-s7-AM-alt-IC48-PASS-only :: meta [4]\n  <- clay-cascade-s7-AM-4-robustness-checks-formal\n  => \"вҳ… Alt-IC=48 вҖ” only check that PASSES\"\n  => \"Gate A (a14_perp Г— a13): Pearson=0.0000, Spearman=+0.2673 PASS\"\n  => \"Gate B (a14_perp Г— a16): Pearson=+0.0386, Spearman=+0.0574 PASS (much cleaner than IC=16)\"\n  => \"Gate C (discrimination): 0.5970 PASS\"\n  => \"interpretation: K=3 promotion may be IC-conditional (parallel to cascade-s5 AJ finding)\"\n  => \"  IC=48 cleanly passes; IC=16 thin-margin; full IC sweep {16, 32, 48, 64} would give consensus\"\n  => \"  cascade-s5 AJ found discrimination IC-conditional; AM confirms promotion ALSO IC-conditional\"\n  => \"but: 1/4 PASS is below threshold for K=3 SECURED status\"", source_file: "atlas.n6", source_line: 55723 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-quadratic-FAIL", raw: "@C clay-cascade-s7-AM-quadratic-FAIL :: meta [4]\n  <- clay-cascade-s7-AM-4-robustness-checks-formal\n  => \"вҳ… QUADRATIC RESIDUALIZATION FAIL вҖ” coupling worsens\"\n  => \"OLS fit a14 = ОІ1В·a13 + ОІ2В·a13ВІ + Оұ + Оө:\"\n  => \"  ОІ1 = -0.00036, ОІ2 вүҲ 0 (essentially zero вҖ” no quadratic signal in a13)\"\n  => \"Gate B on quadratic residual:\"\n  => \"  Pearson = 0.3747 FAIL (vs linear 0.218)\"\n  => \"  Spearman = 0.4838 FAIL (vs linear 0.271)\"\n  => \"BOTH metrics WIDEN, NOT NARROW\"\n  => \"interpretation: linear model already captured all systematic a13-structure\"\n  => \"  added quadratic parameter just adds noise, doesn't reduce coupling\"\n  => \"  confirms the a14Г—a16 coupling is INTRINSIC, not a13-projectable artifact\"", source_file: "atlas.n6", source_line: 55734 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-verdict-synthesis", raw: "@C clay-cascade-s7-AM-verdict-synthesis :: meta [4!]\n  <- clay-cascade-s7-AM-bootstrap-FAIL\n  <- clay-cascade-s7-AM-LOO-FAIL\n  <- clay-cascade-s7-AM-alt-IC48-PASS-only\n  <- clay-cascade-s7-AM-quadratic-FAIL\n  => \"вҳ… K=3 DOWNGRADE/REVERT вҖ” 1/4 robustness checks PASS (Alt-IC=48 only)\"\n  => \"AL's IC=16 promotion at Gate B Pearson=0.218, Spearman=0.271 was FAVORABLE DRAW within wide statistical distribution\"\n  => \"calabi6 a13=2889 outlier creates LOO leverage that exposes promotion fragility\"\n  => \"Quadratic residualization shows linear OLS already extracts all a13-projectable structure\"\n  => \"Only Alt-IC=48 PASS suggests K=3 candidate may be IC-specific, NOT topology-invariant\"\n  => \"K=3 promotion track TERMINATED вҖ” atlas state RETURNS TO K=2 STRONG\"\n  => \"raw 71 17th finding: cascade-s6 AL K=3 PROMOTE вҶ’ cascade-s7 AM REVERT\"\n  => \"axis-14 K=3 promotion permanently DENIED at n=18 cohort statistical floor\"\n  => \"  future K=3 attempt requires new estimator OR larger cohort (n>=50?)\"", source_file: "atlas.n6", source_line: 55747 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-K2-STRONG-TRULY-FINAL", raw: "@C clay-cascade-s7-AM-K2-STRONG-TRULY-FINAL :: meta [4!]\n  <- clay-cascade-s7-AM-verdict-synthesis\n  => \"вҳ… K=2 STRONG VERIFY-GRID CONFIRMED TRULY FINAL across 7 cascades + 33 sub-agents\"\n  => \"  axis-13 SATURATION: continuum mass-oscillation 1D+3D+phi^4 (cascade-s2)\"\n  => \"  axis-16 LIGHTCONE V(8): src-conditional directed in-deg + |R| (cascade-s3)\"\n  => \"  a13 Г— a16: Pearson -0.128 + Spearman -0.233 truly orthogonal\"\n  => \"REJECTED axis candidates:\"\n  => \"  axis-15: saturation amplitude artifact (cascade-s2 K)\"\n  => \"  axis-14[Renyi-2] raw: structural coupling (cascade-s2 R + s5 AK)\"\n  => \"  axis-14[Renyi-2 IC=16 non-boundary]: discrimination IC-conditional (s5 AJ)\"\n  => \"  axis-14_perp linear residual: noise floor at n=18 (s7 AM, this shard)\"\n  => \"  axis-17[SymDef]: coverage 5/18 + r=+0.993 (cascade-s2 X)\"\n  => \"joint signature (a13, a16): NEGATIVE non-synergistic (cascade-s4 AI)\"", source_file: "atlas.n6", source_line: 55762 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-cascade-s6-AL-reconciliation", raw: "@C clay-cascade-s7-AM-cascade-s6-AL-reconciliation :: meta [4]\n  <- clay-cascade-s7-AM-verdict-synthesis\n  => \"cascade-s6 AL вҶ” cascade-s7 AM cycle complete:\"\n  => \"  AL: K=3 PROMOTED (thin margin gate B Spearman 0.271 вҖ” 0.029 inside threshold)\"\n  => \"  AM: 4-method robustness check\"\n  => \"    bootstrap 1000: median Spearman 0.384 (much higher than AL's 0.271)\"\n  => \"    LOO: worst Spearman 0.550 (drop calabi6)\"\n  => \"  AL's promotion was at statistical noise floor as AL itself flagged\"\n  => \"  AM confirms: thin margin = noise, not signal\"\n  => \"  AL's recommendation 'cascade-s7 robustness verification warranted' was honest + necessary\"\n  => \"  AM's revert is honest follow-through on AL's caveat\"\n  => \"lesson: cascade discipline includes self-skepticism; promotion gates need robustness check at thin margins\"", source_file: "atlas.n6", source_line: 55776 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-cascade-position", raw: "@C clay-cascade-s7-AM-cascade-position :: meta [4]\n  <- clay-cascade-s7-tick1-AM-K3-DOWNGRADE-REVERT-witness\n  => \"cascade map this session (7 cascades, 33 sub-agents, 17 raw 71 findings):\"\n  => \"  s2 axis-13 universality (24 agents) closed: continuum 1D+3D+phi^4\"\n  => \"  s3 axis-16 mechanism (4 agents) closed: src-cond directed in-deg + |R|\"\n  => \"  s4 joint signature (1 agent) closed-NEGATIVE: non-synergistic\"\n  => \"  s5 axis-14 K=3 IC retest (2 agents) closed-DENIED-ROBUST\"\n  => \"  s6 axis-14_perp K=3 (1 agent) PROMOTED-thin (cascade-s7 review)\"\n  => \"  s7 K=3 robustness verification (1 agent, this AM): DOWNGRADE/REVERT\"\n  => \"K=2 STRONG (axis-13 + axis-16) FINAL вҖ” no further K=3 path at n=18\"", source_file: "atlas.n6", source_line: 55789 },
    AtlasNode { kind: "C", id: "clay-cascade-s7-AM-17-cumulative-findings", raw: "@C clay-cascade-s7-AM-17-cumulative-findings :: meta [4]\n  <- clay-cascade-s7-AM-verdict-synthesis\n  => \"17 cumulative raw 71 findings session-wide (post-AM):\"\n  => \"  s2 (11): hypothesis narrowings + axis-15 retract + cartoon 9-cell reject + ...\"\n  => \"  s3 (1): AFвҶ’AG src-cond directed in-deg refinement\"\n  => \"  s4 (1): joint signature NEGATIVE non-synergistic\"\n  => \"  s2 (1): X axis-17 SymDef RETIRED\"\n  => \"  s5 (2): AJ K=3 reopen + AK K=3 denied-robust IC level\"\n  => \"  s6 (1): AL K=3 PROMOTE thin margin\"\n  => \"  s7 (1) THIS: AM K=3 DOWNGRADE/REVERT robustness FAIL\"\n  => \"= 17 findings: 12 narrow + 1 negative + 1 retire + 2 special + 1 promote + 1 revert\"\n  => \"promoteвҶ’revert pair (ALвҶ’AM) is unique cycle вҖ” promotion was provisional pending robustness\"\n  => \"atlas integrity: provisional promotions are HONEST FLAG, not lock-in\"", source_file: "atlas.n6", source_line: 55800 },
