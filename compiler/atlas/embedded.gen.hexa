    AtlasNode { kind: "P", id: "TECSL-AR-A-EGYPT-UNIQUE", raw: "@P TECSL-AR-A-EGYPT-UNIQUE = 5/6 = 1/2 + 1/3 is the UNIQUE 2-term Egyptian fraction with 2 Ōēż a < b :: foundation [11*REPO_INVARIANT]\n  <- TECSL-AR-A-SIGMAINV-2\n  <- TECSL-AR-A-SIGMAINV-2\n  => \"The triple {1/2, 1/3, 1/6} sums to 1, derived from divisors of 6; this is the HŌéā-1 = 5/6 Compass upper bound.\"\n  => \"The triple {1/2, 1/3, 1/6} sums to 1, derived from divisors of 6; this is the HŌéā-1 = 5/6 Compass upper bound.\"\n  |> docs/hypotheses/078-egyptian-unique.md\n  |> docs/hypotheses/078-egyptian-unique.md", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 107 },
