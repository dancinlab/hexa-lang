    AtlasNode { kind: "C", id: "AIEFF-EXP-C-MOE-E8-CV", raw: "@C AIEFF-EXP-C-MOE-E8-CV = MoE E=8 top-2 vs E=6 top-2 ŌĆö E=6 wins theoretical CV lower-bound :: ai_moe [10]\n  <- n, sigma, tau, phi\n  <- n, sigma, tau, phi\n  => \"  params ratio E8/E6 = 4/3 (=Žä/n┬Ę2)\"\n  => \"  params ratio E8/E6 = 4/3 (=Žä/n┬Ę2)\"\n  => \"  ŌåÆ n=6 (E=6) wins load-uniformity at equal-token budget\"\n  => \"  ŌåÆ n=6 (E=6) wins load-uniformity at equal-token budget\"\n  => \"Reference: BT-22 (expert distribution uniform on n=6 divisors/multiples)\"\n  => \"Reference: BT-22 (expert distribution uniform on n=6 divisors/multiples)\"\n  |> ~/core/n6-architecture/experiments/ai-efficiency/experiment_moe_e8_top2.hexa\n  |> ~/core/n6-architecture/experiments/ai-efficiency/experiment_moe_e8_top2.hexa", source_file: "atlas.append.n6arch-ai-efficiency-rollup-2026-04-27.n6", source_line: 166 },
