    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-axis-14-renyi2-C3-limits", raw: "@C clay-cascade-s2-tick4-axis-14-renyi2-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick4-axis-14-renyi2-K3-DENIED-witness\n  => \"Python mirror /tmp/cascade_s2/axis14_renyi_n18.py + /tmp/cascade_s2/axis14_alt.py\"\n  => \"single seed=6 (no ensemble); 95% CI on individual r ~ Вұ0.4 at n=18\"\n  => \"estimator non-decoupling: Renyi-2 vs Shannon Spearman delta 0.017 вҖ” coupling not breakable by estimator alone\"\n  => \"cartoon V(8) ambiguity tick-3 N: n=17 reported alongside; excluding cartoon does NOT rescue K=3\"\n  => \"Pearson/Spearman split: a13 D=2/D=6 leverage outliers flat=1095 calabi6=2889; Spearman more robust\"\n  => \"recommendation: RETIRE axis-14 K=3 promotion candidacy OR loosen threshold |r|<0.55 (rank-only investigation)\"\n  => \"own#11 strict; chflags uchg honored\"", source_file: "atlas.n6", source_line: 53507 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-symplectic-t3-stabilized-witness", raw: "@C clay-cascade-s2-tick4-symplectic-t3-stabilized-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick3-t3-integrator-unstable\n  -> clay-cascade-s2-tick4-e2-step-not-Verlet-diagnosis\n  -> clay-cascade-s2-tick4-t3-saturation-extracted\n  => \"вҳ… symplectic KDK velocity Verlet STABILIZES t3 вҖ” energy drift -7.4e-05 vs hexa -8.2e-01 (10000x better)\"\n  => \"diagnoses tick-3 t3 instability as INTEGRATOR-CLASS ARTIFACT, NOT physical limit on dt\"\n  => \"unblocks 3D regime testing for axis-13 saturation hypothesis + sub-agent Q m^2 scan extension\"", source_file: "atlas.n6", source_line: 53526 },
