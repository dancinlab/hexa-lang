    AtlasNode { kind: "C", id: "clay-iter-50-FINAL-15-TOPO-D-3-BASELINE-MEAN", raw: "@C clay-iter-50-FINAL-15-TOPO-D-3-BASELINE-MEAN :: meta [4!]\n  => \"вҳ…вҳ…вҳ…вҳ…вҳ…вҳ… FULL 15-topology D=3 single-seed=6 ticks=64 baseline:\"\n  => \"  ca3d:        79\"\n  => \"  t3:          141\"\n  => \"  brane:       145\"\n  => \"  blackhole:   146\"\n  => \"  inflation:   169\"\n  => \"  ads-cft:     180\"\n  => \"  nested:      196\"\n  => \"  vacuum-decay: 203\"\n  => \"  de-sitter:   229\"\n  => \"  wormhole:    268    вҶҗ NEW iter-50\"\n  => \"  s3:          303\"\n  => \"  bubble:      434\"\n  => \"  altered:     463\"\n  => \"  minkowski:   478\"\n  => \"  big-crunch:  604\"\n  => \"  ОЈ = 4038\"\n  => \"  Mean (n=15): 269.2\"\n  => \"  Median: 203 (vacuum-decay)\"\n  => \"  Range: 79 (ca3d) to 604 (big-crunch) = 7.6Г— spread\"", source_file: "atlas.n6", source_line: 46507 },
