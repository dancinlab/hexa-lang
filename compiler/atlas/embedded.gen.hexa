    AtlasNode { kind: "C", id: "atlas-self-arch-axis-i-final-state", raw: "@C atlas-self-arch-axis-i-final-state = PROPOSAL-NOT-ACTUATED :: meta [4!]\n  <- atlas-self-arch-axis-i-graph-query-witness\n  -> next-axis-J-blocked-by-K-ceiling\n  => \"axis-I = atlas-self-arch-graph-query-evolution\"\n  => \"primitives proposed: <-* (transitive depends-on), ->* (transitive derives), <~> (bidirectional shortest path)\"\n  => \"raw 117 5-check: ALL PASS\"\n  => \"raw 91 C3: 5 grounded findings + 7 speculative gaps explicitly separated\"\n  => \"orthogonality vs D-H: composes with D/E/G/H synergistically, mild K-ceiling pressure on F (mitigated by suffix-style design)\"\n  => \"intrinsic ceiling: axis-I is the LAST inline-arrow extension before @REL registry block becomes mandatory\"\n  => \"actuation deferred to follow-up shard with raw 23 + raw 24 + raw 22 sign-off\"\n  => \"shard appended at: /Users/ghost/core/n6-architecture/atlas/atlas.append.atlas-self-arch-axis-i-graph-query-2026-04-28.n6\"\n  => \"DO NOT auto-absorb вҖ” separate step per user directive\"", source_file: "atlas.n6", source_line: 52464 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-15-n18-coverage-witness", raw: "@C clay-cascade-s2-tick2-axis-15-n18-coverage-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick1-axis-16-K4-verify-grid-closure-witness\n  -> clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  => \"вҳ… 4 axis-15 missing values FOUND already-absorbed in iter-70 (no fresh hexa run needed)\"\n  => \"n=18 4-axis correlation matrix computed; SUPERSEDED by K=3 collapse (sub-agent K retraction in same tick)\"\n  => \"convention disclosure: ticks=100 c=1 seed=6 (iter-69/70 actual), NOT task-spec seed=6/ticks=64\"", source_file: "atlas.n6", source_line: 52504 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-iter-70-recovered-values", raw: "@C clay-cascade-s2-tick2-iter-70-recovered-values :: meta [4]\n  <- clay-cascade-s2-tick2-axis-15-n18-coverage-witness\n  => \"source: atlas/_absorbed/20260428-071642/atlas.append.clay-millennium-iter-70-FINAL-+-NEXUS-ABSORB-2026-04-28.n6 lines 15-21\"\n  => \"flat:     axis-15 = 1,753,678 (causal_viol = 0)\"\n  => \"wormhole: axis-15 = 1,953,281 (causal_viol = 0)\"\n  => \"ca3d:     axis-15 = 2,087,413 (causal_viol = 0)\"\n  => \"bubble:   axis-15 = 2,312,561 (causal_viol = 0) вҖ” NEW MAX drift\"\n  => \"all 4 produced finite well-defined values вҖ” no inherent ill-definition for D=3 lattice projection\"", source_file: "atlas.n6", source_line: 52515 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-n18-correlation-matrices", raw: "@C clay-cascade-s2-tick2-n18-correlation-matrices :: meta [4]\n  <- clay-cascade-s2-tick2-iter-70-recovered-values\n  => \"Pearson RвӮ„ (n=18):\"\n  => \"  a13Г—a14=+0.294  a13Г—a15=вҲ’0.304  a13Г—a16=вҲ’0.128\"\n  => \"  a14Г—a15=вҲ’0.238  a14Г—a16=вҲ’0.380  a15Г—a16=+0.301\"\n  => \"Spearman ПҒвӮ„ (n=18):\"\n  => \"  a13Г—a14=+0.536  a13Г—a15=вҲ’0.115  a13Г—a16=вҲ’0.233\"\n  => \"  a14Г—a15=вҲ’0.170  a14Г—a16=вҲ’0.209  a15Г—a16=+0.154\"\n  => \"anchor reproductions: a14Г—a15 Pearson=вҲ’0.24 matches iter-70 r=вҲ’0.2376 EXACTLY; a13Г—a14 Spearman=+0.54 matches iter-63 ПҒ=0.51 Вұ0.03\"", source_file: "atlas.n6", source_line: 52525 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-det-R-pre-and-post-retraction", raw: "@C clay-cascade-s2-tick2-det-R-pre-and-post-retraction :: meta [4]\n  <- clay-cascade-s2-tick2-n18-correlation-matrices\n  -> clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  => \"PRE-RETRACTION (raw 70 K=4 reading):\"\n  => \"  det(RвӮ„ Pearson n=14)=0.7481 вҶ’ det(RвӮ„ Pearson n=18)=0.6512 (О”=вҲ’0.097, exceeds Вұ0.05 envelope)\"\n  => \"  det(RвӮ„ Spearman n=14)=0.7523 вҶ’ det(RвӮ„ Spearman n=18)=0.6383 (О”=вҲ’0.114)\"\n  => \"  ratio det(RвӮ„)/det(RвӮғ) = 0.807 вҶ’ axis-16 retains 81% volume as independent info\"\n  => \"POST-RETRACTION (axis-15 = saturation amplitude artifact):\"\n  => \"  the n=18 K=4 result re-interprets as K=3 (axis-13/14/16) + axis-15 amplitude characterization\"\n  => \"  det(RвӮғ) Pearson same-sample (n=18, axes 13/14/16) = 0.8072 вҶ’ axis-16 вҠҘ axis-13Г—14 with high orthogonality preserved\"", source_file: "atlas.n6", source_line: 52536 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-bubble-driver", raw: "@C clay-cascade-s2-tick2-bubble-driver :: meta [4]\n  <- clay-cascade-s2-tick2-det-R-pre-and-post-retraction\n  => \"bubble drives n=14 вҶ’ n=18 det(R) drop: high entropy (axis-14=887) + max drift (axis-15=2.31M) + V(8)=64\"\n  => \"strengthens a14Г—a16 from вҲ’0.333 (n=14) to вҲ’0.380 (n=18)\"\n  => \"lifts a15Г—a16 from +0.170 (n=14) to +0.301 (n=18)\"\n  => \"physical interpretation pre-retraction: 'high-entropy + max-amplitude + full-fill' coupling\"\n  => \"physical interpretation post-retraction: a15Г—a16=+0.301 is saturation-amplitude Г— graph-volume coupling, NOT physical drift Г— lightcone\"", source_file: "atlas.n6", source_line: 52548 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-n18-coverage-C3-limits", raw: "@C clay-cascade-s2-tick2-n18-coverage-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick2-axis-15-n18-coverage-witness\n  => \"convention disclosure: iter-69/70 used ticks=100 c=1 seed=6 (not seed=6/ticks=64); used actual recorded values to avoid mixing conventions\"\n  => \"no fresh hexa run executed вҖ” 4 missing values already-absorbed; verified verbatim from iter-70 lines 17-20\"\n  => \"flat axis-13=1095 is D=2 reference (iter-35/36) вҖ” including in n=18 Pearson is methodologically loose; Spearman more robust\"\n  => \"calabi6 axis-13=2889 D=6 leverage outlier вҖ” drives Pearson; Spearman ПҒ a13Г—a14=+0.54 vs Pearson +0.29 confirms\"\n  => \"n=18 95% CI on r still wide (~Вұ0.4 per individual r at ПғВІ=64 toy + single seed)\"\n  => \"this shard's K=4 reading is HISTORICAL вҖ” superseded by tick-2 sub-agent K axis-15 retraction (see paired retraction shard)\"\n  => \"own#11 strict: NO Clay claim; chflags uchg honored; no atlas writes\"", source_file: "atlas.n6", source_line: 52557 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-cartoon-9cell-invariant-core-witness", raw: "@C clay-cascade-s2-tick2-cartoon-9cell-invariant-core-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-cartoon-causal-sector-closure\n  -> clay-cascade-s2-tick2-axis-16-src-bias-invariant\n  -> clay-cascade-s2-tick2-cartoon-basin-fragmentation\n  => \"вҳ… cartoon V(8)=10 closed-orbit is NOT src=32-specific вҖ” 9-cell INVARIANT CORE attractor\"\n  => \"core: {11, 13, 20, 29, 36, 43, 52, 59, 61} вҖ” independent of srcвҲҲ{0,16,32,48}\"\n  => \"each src adds itself as +1-cell tail; |orbit_src|=10 = 9-cell core вҲӘ {src}\"", source_file: "atlas.n6", source_line: 52581 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-multi-source-V8-table", raw: "@C clay-cascade-s2-tick2-multi-source-V8-table :: meta [4]\n  <- clay-cascade-s2-tick2-cartoon-9cell-invariant-core-witness\n  => \"format: topology Г— src{0,16,32,48} вҶ’ V(8)\"\n  => \"flat:      17 / 17 / 17 / 17 = INVARIANT (ring translation-symmetric)\"\n  => \"t3:        63 / 63 / 63 / 63 = INVARIANT (Z/4Ві full symmetry)\"\n  => \"s3:        48 / 48 / 49 / 48 = LOW-VAR (src=32 boundary cell +1)\"\n  => \"cartoon:   10 / 10 / 10 / 10 = INVARIANT-VOLUME (orbit-shifted)\"\n  => \"blackhole: 64 / 63 / 63 / 63 = LOW-VAR (src=0 corner reaches sink one hop sooner)\"\n  => \"wormhole:  64 / 64 / 64 / 64 = INVARIANT (handle saturates from any src)\"", source_file: "atlas.n6", source_line: 52593 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-16-src-bias-invariant", raw: "@C clay-cascade-s2-tick2-axis-16-src-bias-invariant :: meta [4!]\n  <- clay-cascade-s2-tick2-multi-source-V8-table\n  => \"вҳ… V(8) is NEAR-TRANSLATION-INVARIANT observable at this 64-cell scale\"\n  => \"INVARIANT (stddev = 0): flat, t3, cartoon, wormhole вҖ” 4/6 topologies\"\n  => \"LOW-VAR (stddev вүӨ 0.5): s3, blackhole вҖ” 2/6 topologies\"\n  => \"DEPENDENT (stddev > 1): NONE on this 64-cell toy\"\n  => \"implication: tick-1 sub-agent A's src=32-only measurements not src-bias artifact; K=4 closure verdict (G) src-robust\"", source_file: "atlas.n6", source_line: 52604 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-cartoon-basin-fragmentation", raw: "@C clay-cascade-s2-tick2-cartoon-basin-fragmentation :: meta [4!]\n  <- clay-cascade-s2-tick2-axis-16-src-bias-invariant\n  => \"вҳ… cartoon V(8)=10 decomposition: 9-cell INVARIANT CORE + 1-cell src tail\"\n  => \"core: {11, 13, 20, 29, 36, 43, 52, 59, 61} вҖ” appears in BFS from every srcвҲҲ{0,16,32,48}\"\n  => \"src=0  orbit = core вҲӘ {0}\"\n  => \"src=16 orbit = core вҲӘ {16}\"\n  => \"src=32 orbit = core вҲӘ {32} вҖ” original tick-1 measurement\"\n  => \"src=48 orbit = core вҲӘ {48}\"\n  => \"pairwise orbit: |intersection|=9, |union|=11; union over all 4 sources = 13/64 cells (51 cells UNPROBED)\"\n  => \"structural meaning: cartoon partitions 64 cells into MANY small attractor basins; {0,16,32,48} all flow into shared 9-cell core\"", source_file: "atlas.n6", source_line: 52613 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-cartoon-mixer-interpretation", raw: "@C clay-cascade-s2-tick2-cartoon-mixer-interpretation :: meta [4]\n  <- clay-cascade-s2-tick2-cartoon-basin-fragmentation\n  => \"cartoon mixer: nbr(i, axis) = (i*47 + axis*23 + 13) mod 64\"\n  => \"the 9-cell core is closed-BFS-attractor: all 9 cells route ONLY into the core under axes {0,1,2}\"\n  => \"src cell has NO inbound edge from core under axes 0..2 вҖ” that's why src appears as 1-cell tail not absorbed\"\n  => \"cartoon is NOT 'a closed orbit from src=32' but 'a heavily-fragmented attractor landscape with a universal 9-cell sink'\"\n  => \"follow-up: full 64-source BFS sweep would enumerate ALL basins (~1 min compute, deferred to tick-3)\"", source_file: "atlas.n6", source_line: 52625 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-cartoon-cross-axis-coherence", raw: "@C clay-cascade-s2-tick2-cartoon-cross-axis-coherence :: meta [4]\n  <- clay-cascade-s2-tick2-cartoon-basin-fragmentation\n  => \"cross-link iter-62 phase-portrait: cartoon DOUBLE-HIGH (axis-13=741, axis-14=947) вҶ’ C3 amplitude-redistributor cluster\"\n  => \"cross-link tick-1 sub-agent E: cartoon Г— axis-13 sign-flips 1151вҶ’741вҶ’вҲ’407вҶ’163 (no plateau)\"\n  => \"cross-link tick-1 sub-agent A: cartoon V(8)=10 closed orbit\"\n  => \"cascade-coherent picture: cartoon's structural-isolation appears in ALL axes simultaneously вҖ” value-summary AND structural\"\n  => \"this is genuine cross-axis CORROBORATION (raw 70 multi-axis verify), not redundancy\"", source_file: "atlas.n6", source_line: 52634 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-multi-source-axis-16-C3-limits", raw: "@C clay-cascade-s2-tick2-multi-source-axis-16-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick2-cartoon-9cell-invariant-core-witness\n  => \"4 sources are all multiples of 16 (z-axis aligned in t3 coords) вҖ” sparse generic-offset coverage\"\n  => \"follow-up: {1, 7, 21, 37, 53} odd-prime sweep would test orbit-mixing more aggressively; deferred to tick-3\"\n  => \"cartoon basin coverage 13/64 cells; remaining 51 cells unprobed by this 4-src set\"\n  => \"s3 src=32 anomaly +1: src is in 'second-copy' half (iвүҘ32), one cell asymmetry vs three z-aligned mirrors вҖ” finite-size artifact\"\n  => \"blackhole src=0 anomaly +1: corner BFS reaches 21-sink one hop sooner, picks up one extra peripheral cell within k=8 вҖ” geometric\"\n  => \"files: /tmp/lightcone_multisource.py + /tmp/lightcone_probe.py (canonical BFS reused)\"\n  => \"own#11 strict: no fabrication; per-source orbit sets verified by independent full-orbit pass\"", source_file: "atlas.n6", source_line: 52643 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness", raw: "@C clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick1-axis-15-non-convergent-all-topologies\n  -> clay-cascade-s2-tick2-K4-verify-grid-collapse-to-K3\n  -> clay-cascade-s2-tick2-axis-15-relabel-saturation-amplitude\n  => \"вҳ… MAJOR RETRACTION вҖ” axis-15 (Lorentz energy-drift) is INTEGRATION ARTIFACT, not physical observable\"\n  => \"Crank-Nicolson Jacobi-8 implicit + 4-T refinement test {32,64,128,256} on flat/t3/cartoon\"\n  => \"verdict: drift fluctuates fixed band 0.7-4.7, NO T-refinement convergence; CN AMPLIFIES drift 1.6Г—-5Г— vs explicit-Euler\"", source_file: "atlas.n6", source_line: 52667 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-CN-Stage2-formal", raw: "@C clay-cascade-s2-tick2-CN-Stage2-formal :: meta [4]\n  <- clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  => \"phi^{n+1}[i] = T[i] + (1/2)(SA(phi^n)[i] + SA(phi^{n+1})[i])\"\n  => \"T[i] = -phi^n[i] + phi^{n-1}[i]/4 (time-like retarded, kept explicit, 2nd-order in t)\"\n  => \"SA(u)[i] = (1/3) ОЈ_{a=0..2} u[neighbor(i,a)] (light-cone-restricted spatial)\"\n  => \"implicit half: Jacobi-8 iters seeded from explicit prediction; mirrors lorentz_metric.hexa:362-405\"", source_file: "atlas.n6", source_line: 52679 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-CN-drift-measurements", raw: "@C clay-cascade-s2-tick2-CN-drift-measurements :: meta [4]\n  <- clay-cascade-s2-tick2-CN-Stage2-formal\n  => \"format: drift = |E(T) вҲ’ E(0)|/E(0); explicit-Euler vs CN side-by-side\"\n  => \"flat:    explicit T={32,64,128,256} вҶ’ 0.72/0.73/0.69/0.71 | CN вҶ’ 1.20/0.92/1.29/1.22 (CN ~1.7Г— larger)\"\n  => \"t3:      explicit вҶ’ 1.00/0.60/0.86/1.08            | CN вҶ’ 4.00/4.63/3.44/4.74 (CN ~5Г— larger)\"\n  => \"cartoon: explicit вҶ’ 1.07/0.11/0.77/0.77            | CN вҶ’ 4.94/3.28/4.32/3.97 (CN ~4Г— larger)\"\n  => \"rel-coeff-var across T (CN): flat=0.317, t3=0.309, cartoon=0.402 вҖ” same order as explicit-Euler\"\n  => \"no T-refinement convergence вҖ” drift in fixed band, doubling T leaves drift in same range\"", source_file: "atlas.n6", source_line: 52687 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-15-relabel-saturation-amplitude", raw: "@C clay-cascade-s2-tick2-axis-15-relabel-saturation-amplitude :: meta [4!]\n  <- clay-cascade-s2-tick2-CN-drift-measurements\n  -> clay-cascade-s2-tick2-K4-verify-grid-collapse-to-K3\n  => \"вҳ… axis-15 measures BOUNDED-SYSTEM SATURATION AMPLITUDE, NOT physical conserved quantity\"\n  => \"physical conserved quantity: drift вҶ’ 0 as T grows (continuum convergence). Observed: drift in fixed band.\"\n  => \"CN amplifies (not reduces) drift because trapezoidal mixing increases coupling to bounded mod-LSCALE folding\"\n  => \"interpretation: 'drift' is natural amplitude of energy oscillation in discrete wave system, NOT integration error\"\n  => \"raw 71 falsifier-retire-rule: axis-15 RETRACTED from verify-grid; recharacterize as 'bounded saturation amplitude' observable\"\n  => \"all prior axis-15 numerics in atlas (iter-69/70 + tick-1 G + tick-2 H) re-interpret as saturation-amplitude not drift\"", source_file: "atlas.n6", source_line: 52697 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-K4-verify-grid-collapse-to-K3", raw: "@C clay-cascade-s2-tick2-K4-verify-grid-collapse-to-K3 :: meta [4!]\n  <- clay-cascade-s2-tick2-axis-15-relabel-saturation-amplitude\n  => \"вҳ… raw 70 multi-axis-verify-grid: K=4 collapses to K=3 (axis-13/14/16 only)\"\n  => \"tick-1 G K=4 closure verdict (det(RвӮ„ Pearson n=14)=0.7481): re-interpret as K=3 with axis-15 confound\"\n  => \"tick-2 H n=18 closure (det(RвӮ„ n=18)=0.6512): re-interpret as K=3 axis-13Г—14Г—16 + axis-15 saturation-amplitude characterization\"\n  => \"axis-16 orthogonality preserved: ratio det(RвӮ„)/det(RвӮғ) = 0.807 (n=18) decomposes into 'true K=3' + 'axis-15 amplitude characterization'\"\n  => \"future verify-grid claims must use K=3 baseline; axis-15 retained as separate saturation-amplitude observable, not as orthogonal physical axis\"", source_file: "atlas.n6", source_line: 52708 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-15-RETRACTION-C3-limits", raw: "@C clay-cascade-s2-tick2-axis-15-RETRACTION-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  => \"tool source: /tmp/cascade_s2/cn_stage2.py вҖ” Python mirror, NOT canonical hexa CN port\"\n  => \"Jacobi-8 implicit approximati... [truncated, full=1028bytes]", source_file: "atlas.n6", source_line: 52717 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-stage5-COMPLETE-RETIREMENT-witness", raw: "@C clay-cascade-s2-tick2-stage5-COMPLETE-RETIREMENT-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-stage5-alpha055-falsification-witness\n  -> clay-cascade-s2-tick2-axis-13-saturation-fit-best\n  -> clay-cascade-s2-tick2-replacement-hypothesis-tau-L-squared\n  => \"вҳ… Stage-5 Оұ=+0.55 FULLY RETIRED вҖ” wrong sign + wrong functional form across all axes & both topologies\"\n  => \"supersedes tick-1 sub-agent B narrowing ('diffusive-scheme-specific'): the actual exponent has OPPOSITE sign to +0.55\"\n  => \"30-run 5-point fit: chain1d ПғВІвҲҲ{64,128,256,512,1024} + t3 NвҲҲ{64,216,343,512,1000} cubes Г— 3 seeds Г— axes 13/14/15\"", source_file: "atlas.n6", source_line: 52741 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-fit-comparison-table", raw: "@C clay-cascade-s2-tick2-fit-comparison-table :: meta [4]\n  <- clay-cascade-s2-tick2-stage5-COMPLETE-RETIREMENT-witness\n  => \"format: axis/topo вҶ’ power RВІ | log RВІ | saturation RВІ | BEST\"\n  => \"axis-13/chain1d: power Оұ=вҲ’0.484 RВІ=0.935 | log RВІ=0.854 | sat yвҲһ=3.33 П„=100 RВІ=0.997 | SAT\"\n  => \"axis-13/t3:      power Оұ=вҲ’0.571 RВІ=0.955 | log RВІ=0.892 | sat yвҲһ=4.00 П„=128 RВІ=0.966 | SAT\"\n  => \"axis-14/chain1d: ALL RВІ<0.45 вҶ’ noise floor ПғВІ-invariant\"\n  => \"axis-14/t3:      ALL RВІ<0.14 вҶ’ noise floor ПғВІ-invariant\"\n  => \"axis-15/chain1d: best RВІ=0.301 вҶ’ no scaling, drift вүҲ const вүҲ 230Вұ30\"\n  => \"axis-15/t3:      sat RВІ=0.798 yвҲһвүҲ19400 вҶ’ mild saturation; corroborates sub-agent K artifact verdict\"", source_file: "atlas.n6", source_line: 52753 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-13-saturation-fit-best", raw: "@C clay-cascade-s2-tick2-axis-13-saturation-fit-best :: meta [4!]\n  <- clay-cascade-s2-tick2-fit-comparison-table\n  -> clay-cascade-s2-tick2-replacement-hypothesis-tau-L-squared\n  => \"вҳ… axis-13 obeys SATURATION y = yвҲһ + AВ·exp(вҲ’N/П„) with RВІ=0.997 (chain1d) / 0.966 (t3)\"\n  => \"yвҲһ вүҲ 3-4 (decay-to-floor), П„ вүҲ 100-128 (lattice-equilibration scale)\"\n  => \"power-law alternative: Оұ_E вүҲ вҲ’0.484 (chain1d) / вҲ’0.571 (t3) вҖ” RВІ 0.93-0.96, viable but inferior to saturation\"\n  => \"Stage-5 Оұ=+0.55 prediction at N=1024: y(1024)=56.7 (chain1d). OBSERVED: yвҲһ=3.33 вҖ” ratio 0.059, OPPOSITE direction\"\n  => \"raw 71 retire: Stage-5 Оұ=+0.55 is wrong sign (+ vs вҲ’) + wrong functional form (power vs saturation) вҖ” fully retired\"", source_file: "atlas.n6", source_line: 52764 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-14-noise-floor-suspect", raw: "@C clay-cascade-s2-tick2-axis-14-noise-floor-suspect :: meta [4]\n  <- clay-cascade-s2-tick2-fit-comparison-table\n  => \"axis-14 entropy proxy is ПғВІ-INVARIANT across 16Г— range of N (mean ~970-1100, all RВІ<0.45)\"\n  => \"no scaling structure detectable at this resolution вҖ” likely artifact OR scale-invariant noise floor\"\n  => \"implication for cascade: axis-14 may NOT be a true orthogonal observable; downgraded confidence\"\n  => \"raw 71 narrow (preliminary): axis-14 status downgraded from 'verify-grid axis' to 'candidate axis pending re-resolution'\"\n  => \"follow-up needed: higher-PSCALE quantization OR alternative entropy estimator (Renyi, Tsallis) to rule in/out artifact\"", source_file: "atlas.n6", source_line: 52774 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-replacement-hypothesis-tau-L-squared", raw: "@C clay-cascade-s2-tick2-replacement-hypothesis-tau-L-squared :: meta [4]\n  <- clay-cascade-s2-tick2-axis-13-saturation-fit-best\n  => \"вҳ… replacement hypothesis: П„ вүҲ O(LВІ) is LATTICE-EQUILIBRATION scale, NOT critical exponent\"\n  => \"chain1d П„=100, L=вҲҡN=вҲҡ1024вүҲ32 вҶ’ LВІ=1024, П„/LВІвүҲ0.10\"\n  => \"t3 П„=128, N=1000 LвүҲ10 вҶ’ LВІ=100, П„/LВІвүҲ1.28\"\n  => \"lattice-equilibration: time/N for diffusion process to spread across system LВІ/D where D=diffusion const\"\n  => \"axis-13 captures NOT critical phenomenon BUT diffusion-equilibration scale вҖ” different physics class\"\n  => \"follow-up: measure П„ vs L explicitly to confirm LВІ scaling (Phase-3 candidate)\"", source_file: "atlas.n6", source_line: 52783 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-cascade-integrity-post-retirement", raw: "@C clay-cascade-s2-tick2-cascade-integrity-post-retirement :: meta [4]\n  <- clay-cascade-s2-tick2-stage5-COMPLETE-RETIREMENT-witness\n  <- clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  => \"post-retirement axis status:\"\n  => \"  axis-13: SATURATION verified (RВІ=0.997); functional form corrected; П„ replacement hypothesis\"\n  => \"  axis-14: noise-floor SUSPECT вҖ” downgraded confidence pending re-resolution\"\n  => \"  axis-15: ARTIFACT confirmed (Sub-agent K CN re-impl); RETRACTED from verify-grid\"\n  => \"  axis-16: orthogonal lightcone confirmed (Sub-agent G + I); src-bias INVARIANT\"\n  => \"honest verify-grid: K=2 STRONG (axis-13 + axis-16) + K=1 PROVISIONAL (axis-14 pending)\"\n  => \"Stage-5 retirement strengthens cascade integrity by removing hopeful overstatement\"", source_file: "atlas.n6", source_line: 52793 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-stage5-retirement-C3-limits", raw: "@C clay-cascade-s2-tick2-stage5-retirement-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick2-stage5-COMPLETE-RETIREMENT-witness\n  => \"tool sources: /tmp/cascade_s2/ensemble_5pt.hexa + /tmp/cascade_s2/fit_5pt.py вҖ” disclosed\"\n  => \"5 ПғВІ points per topology may mask higher-order multi-scale saturation invisible at this resolution\"\n  => \"axis-15 t3 RВІ=0.798 saturation might also be artifact (corroborates sub-agent K) вҖ” not an honest physical signal\"\n  => \"integer PSCALE=1000 quantization affects entropy proxy вҖ” coarse for axis-14 noise verdict\"\n  => \"mixed N-grids (chain1d powers-of-2, t3 cubes) вҖ” fits per-topology only; cross-topology Оұ-comparison only meaningful at shared anchors {64, 512}\"\n  => \"saturation grid-search (not nonlinear least-squares); П„=100/128 nearest-grid, true value within factor 2\"\n  => \"3 seeds per cell with std up to 80% of mean (axis-15 chain1d) вҖ” 5+ seeds would tighten drift RВІ\"\n  => \"own#11 strict: this is raw-71 retirement, strengthens (not weakens) cascade integrity\"", source_file: "atlas.n6", source_line: 52805 },
    AtlasNode { kind: "C", id: "atlas-self-arch-axis-j-supersession-witness", raw: "@C atlas-self-arch-axis-j-supersession-witness :: meta [4!]\n  <- raw-23-schema-guard\n  <- raw-24-foundation-axiom-immutable\n  <- raw-91-C3-honest-disclosure\n  <- raw-117-5-check-registration-gate\n  <- own#11-strict-no-resolution-claim\n  <- atlas-self-arch-... [truncated, full=1461bytes]", source_file: "atlas.n6", source_line: 52849 },
    AtlasNode { kind: "C", id: "axis-j-primitive-definition", raw: "@C axis-j-primitive-definition :: meta [4!]\n  <- atlas-self-arch-axis-j-supersession-witness\n  => \"primitive #1 = SUPERSEDED-BY BODY FIELD.   token: 2-space-indent  superseded_by = <slug>  (axis-G body-field family вҖ” already attested form)\"\n  => \"primiti... [truncated, full=1711bytes]", source_file: "atlas.n6", source_line: 52879 },
    AtlasNode { kind: "C", id: "axis-j-row-example-1-r34-back-pointer-installation", raw: "@C axis-j-row-example-1-r34-back-pointer-installation :: meta [4!]\n  <- axis-j-primitive-definition\n  => \"row example #1 вҖ” install superseded_by on R34 (closes the measured gap)\"\n  => \"  CURRENT (line 21894):\"\n  => \"    @? ANIMA-CXP-R34-PHI-COEFF-EHALF = [DEPRECATED 2026-04-26] Phi_coefficient вүҲ e^{-1/2} ... :: consciousness [9?вҶ’DEPRECATED]\"\n  => \"  PROPOSED (axis-J):\"\n  => \"    @? ANIMA-CXP-R34-PHI-COEFF-EHALF = [DEPRECATED 2026-04-26] Phi_coefficient вүҲ e^{-1/2} ... :: consciousness [9?вҶ’DEPRECATED]\"\n  => \"      superseded_by = ANIMA-CXP-R38-R34-T1-RETIRED-INCONCLUSIVE   # axis-J body-field\"\n  => \"      supersession_reason = \\\"T1 protocol executed; substrate-fragility prerequisite failure\\\"   # axis-G body-field\"\n  => \"  semantics: superseded_by accepts ONE @-id (slug); axis-I <-* superseded_by reconstructs the chain; commit message aad6e61d back-link is now also a queryable DSL fact\"\n  => \"  raw 24 invariance: foundation [11*] block untouched (R34 is consciousness, not foundation)\"", source_file: "atlas.n6", source_line: 52890 },
    AtlasNode { kind: "C", id: "axis-j-row-example-2-state-quartet-on-clay-iter-55", raw: "@C axis-j-row-example-2-state-quartet-on-clay-iter-55 :: meta [4!]\n  <- axis-j-primitive-definition\n  => \"row example #2 вҖ” formalise RETIRED state on clay-iter-55 (existing prose currently says 'iter-55 finding RETIRED (definitively wrong)')\"\n  => \"  CUR... [truncated, full=1242bytes]", source_file: "atlas.n6", source_line: 52902 },
    AtlasNode { kind: "C", id: "axis-j-row-example-3-supersession-graph-query", raw: "@C axis-j-row-example-3-supersession-graph-query :: meta [4!]\n  <- axis-j-primitive-definition\n  => \"row example #3 вҖ” axis-I Г— axis-J COMPOSITION: query supersession ancestry\"\n  => \"  PROPOSED (composes axis-I <-* with axis-J superseded_by field):\"\n  => \"    @C anima-cxp-r34-supersession-ancestry :: meta [4]\"\n  => \"      <-* superseded_by                      # axis-I transitive closure over axis-J body-field\"\n  => \"      => \\\"all rows transitively superseded by R34 вҖ” answers 'why was R34 deprecated?' from atlas.n6 alone\\\"\"\n  => \"  expansion at lint-time: <-* superseded_by walks the back-pointer graph from R34, collecting {R38, R36 (if cross-link), ...}\"\n  => \"  this row CANNOT EXIST without BOTH axes вҖ” concrete demonstration of axis-I/J co-design payoff\"\n  => \"  raw 91 C3 honest: this example is SPECULATIVE вҖ” no <-* lint-implementation exists yet (axis-I В§ final-state PROPOSAL-NOT-ACTUATED), so this row's evaluation is a DSL design illustration only\"", source_file: "atlas.n6", source_line: 52916 },
    AtlasNode { kind: "C", id: "axis-j-orthogonality-analysis", raw: "@C axis-j-orthogonality-analysis :: meta [4!]\n  <- axis-j-primitive-definition\n  -> axis-j-vs-D-meta-tag\n  -> axis-j-vs-E-arrow-poly\n  -> axis-j-vs-F-K-ceiling\n  -> axis-j-vs-G-body-field\n  -> axis-j-vs-H-id-convention\n  -> axis-j-vs-I-graph-query\n  => \"VERDICT: COMPOSES with all 6 prior axes. ZERO interference (unlike axis-I which had mild K-ceiling pressure on F). Axis-J was DELIBERATELY designed to live in axes D/E/G namespaces, leaving F arrow-budget untouched.\"", source_file: "atlas.n6", source_line: 52928 },
    AtlasNode { kind: "C", id: "axis-j-vs-D-meta-tag", raw: "@C axis-j-vs-D-meta-tag :: meta [4]\n  <- axis-j-orthogonality-analysis\n  => \"axis-D (@-type prefix). axis-J adds NO new @-types. Existing @? for hypothesis-status, @F for formula, @R for relation all accept the new meta-tag suffix unchanged. SYNERGY: axis-D meta-tag-layering reading is enriched вҖ” [DEPRECATED YYYY-MM-DD] joins the existing [d.r], [N*], [N!], [N?] family as a fifth tag-shape.\"", source_file: "atlas.n6", source_line: 52938 },
    AtlasNode { kind: "C", id: "axis-j-vs-E-arrow-poly", raw: "@C axis-j-vs-E-arrow-poly :: meta [4]\n  <- axis-j-orthogonality-analysis\n  => \"axis-E (arrow polymorphism). axis-J adds ONE arrow ONLY INSIDE GRADE BRACKETS вҖ” [9?вҶ’DEPRECATED] вҖ” which is grade-internal, not row-level. axis-E row-level arrow set {<-, ->, =>, ==, ~>, |>, !!, -|} unchanged. ZERO LL(1) leading-char addition. SYNERGY: the grade-internal вҶ’ is formally distinct from row-level вҶ’ (different lexer state), so axis-E parser separation is reinforced.\"", source_file: "atlas.n6", source_line: 52942 },
    AtlasNode { kind: "C", id: "axis-j-vs-F-K-ceiling", raw: "@C axis-j-vs-F-K-ceiling :: meta [4!]\n  <- axis-j-orthogonality-analysis\n  => \"axis-F (arrow K-ceiling). PRIOR CONCERN (axis-I synthesis line 30516): 'next-axis-J would HIT axis-F K-ceiling and force arrow-grammar redesign.' MEASURED RESULT: axis-J pick (g) AVOIDS this. axis-F K_arrow stays at K=10 post-axis-I (8 row-level + 2 axis-I suffix-on-existing). Axis-J adds ZERO row-level arrows. K-ceiling pressure: 0%. SYNERGY: axis-J is the EXISTENCE PROOF that 'next axis must hit K-ceiling' was a pessimistic prediction вҖ” the meta-tag/body-field namespaces have headroom even when the arrow namespace is saturated.\"\n  => \"honest disclosure: this is true ONLY because (g) was chosen over alternatives (a/d/e/f) which WOULD have added arrow-family tokens. Picking the right axis-J is precisely what avoided K-ceiling pressure.\"", source_file: "atlas.n6", source_line: 52946 },
    AtlasNode { kind: "C", id: "axis-j-vs-G-body-field", raw: "@C axis-j-vs-G-body-field :: meta [4!]\n  <- axis-j-orthogonality-analysis\n  => \"axis-G (body-field schema). axis-J adds 2 body-fields: superseded_by, supersession_reason. axis-F K_core audit ranks superseded_by as RANK-1 highest-value addition (line 28968: 'closes a MEASURED gap; zero ambiguity; adoption cost LOW ~8.5 min'). axis-G K_core: 13 вҶ’ 15 after axis-J вҖ” well within axis-G estimated 20-30 ceiling. SYNERGY: axis-J is the FIRST CONSUMER of the rank-1 axis-F recommendation вҖ” completes a planning loop opened in the synthesis shard.\"", source_file: "atlas.n6", source_line: 52951 },
    AtlasNode { kind: "C", id: "axis-j-vs-H-id-convention", raw: "@C axis-j-vs-H-id-convention :: meta [4]\n  <- axis-j-orthogonality-analysis\n  => \"axis-H (id-convention). superseded_by accepts a SLUG; axis-H slug-stability is the prerequisite. SYNERGY: axis-J motivates axis-H stability вҖ” if a slug renames, all superseded_by pointers must update (lint check). axis-H В§ slug-rename-cost just got a concrete consumer.\"\n  => \"INTERFERENCE check: axis-H allows id renames over time (e.g. id-convention-evolution); axis-J creates LONG-LIVED back-pointers that must survive renames. MITIGATION: axis-H must add a 'rename-shadow' alias mechanism OR axis-J body-field must accept multi-slug history. DEFER to next cycle вҖ” flag noted, not blocking for axis-J registration.\"", source_file: "atlas.n6", source_line: 52955 },
    AtlasNode { kind: "C", id: "axis-j-vs-I-graph-query", raw: "@C axis-j-vs-I-graph-query :: meta [4!]\n  <- axis-j-orthogonality-analysis\n  => \"axis-I (graph-query primitives). STRONG MUTUAL COMPLETION. axis-I gives <-* / ->* / <~> over arrow DAG. axis-J gives superseded_by body-field. composition: <-* superseded_by reconstructs supersession ancestry (row example #3). NEITHER axis is fully useful without the other for this query: axis-I alone has no supersession edges to walk; axis-J alone has back-pointers but no closure operator. PROOF that axes I and J were correctly sequenced.\"\n  => \"axis-I final-state was PROPOSAL-NOT-ACTUATED (line 30547). axis-J inherits that status вҖ” both wait on a real lint-tool implementation. THIS shard is design, not actuation.\"", source_file: "atlas.n6", source_line: 52960 },
    AtlasNode { kind: "C", id: "axis-j-raw-117-5-check-results", raw: "@C axis-j-raw-117-5-check-results :: meta [4!]\n  <- axis-j-primitive-definition\n  -> axis-j-5-check-1-genus-slug\n  -> axis-j-5-check-2-frameworks-cite\n  -> axis-j-5-check-3-realization-channels\n  -> axis-j-5-check-4-counter-example\n  -> axis-j-5-check-5-novelty-falsifier\n  => \"VERDICT: 5/5 PASS. axis-J registration gate cleared at registration time.\"", source_file: "atlas.n6", source_line: 52966 },
    AtlasNode { kind: "C", id: "axis-j-5-check-1-genus-slug", raw: "@C axis-j-5-check-1-genus-slug :: meta [4]\n  <- axis-j-raw-117-5-check-results\n  status = PASS\n  genus = \"intrinsic-supersession-DSL\"\n  slug = \"atlas-self-arch-supersession-evolution\"\n  citation = \"follows axis-H id-convention: domain-axis-tag pattern; 'evolution' suffix matches axis-I (graph-query-evolution) sibling shard\"", source_file: "atlas.n6", source_line: 52975 },
    AtlasNode { kind: "C", id: "axis-j-5-check-2-frameworks-cite", raw: "@C axis-j-5-check-2-frameworks-cite :: meta [4]\n  <- axis-j-raw-117-5-check-results\n  status = PASS\n  framework_1 = \"Lamport (1978) Time/Clocks/Ordering вҖ” happens-before primitive applied to row-supersession ordering. CITED-AND-MOVED-ON: atlas.n6's superseded_by is a static back-pointer, NOT a vector clock; we do not import distributed-system semantics.\"\n  framework_2 = \"W3C OWL2 owl:deprecated property + Semantic Versioning DEPRECATED annotation. CITED-AND-MOVED-ON: both use a single boolean flag; atlas.n6's [DEPRECATED YYYY-MM-DD] / [RETIRED YYYY-MM-DD] / [RETIRED_INCONCLUSIVE] / [SUPERSEDED] quartet is FINER than either, with date stamping not present in OWL2.\"\n  framework_3 = \"RFC 8174 BCP 14 'OBSOLETES' header (RFC supersession registry). CITED-AND-MOVED-ON: RFC OBSOLETES is also a forward-pointer between document IDs вҖ” atlas.n6's superseded_by has the same shape but operates on @-row slugs, not document numbers. PRECEDENT, not import.\"\n  citation_count = 3 (exceeds the 2+ requirement)", source_file: "atlas.n6", source_line: 52982 },
    AtlasNode { kind: "C", id: "axis-j-5-check-3-realization-channels", raw: "@C axis-j-5-check-3-realization-channels :: meta [4]\n  <- axis-j-raw-117-5-check-results\n  status = PASS\n  channel_1 = \"META-TAG channel вҖ” [DEPRECATED YYYY-MM-DD] inline tag (already attested 4 rows, formalised by axis-J)\"\n  channel_2 = \"BODY-FIELD channel вҖ” superseded_by = <slug> (axis-G family, NEW from axis-J)\"\n  channel_3 = \"GRADE-SUFFIX channel вҖ” [9?вҶ’DEPRECATED] / [10*RETIRED_INCONCLUSIVE] (already attested 2 rows, formalised by axis-J as the grade-internal arrow position)\"\n  channel_count = 3 (meets the 3+ requirement exactly; could add channel_4 = commit-message back-link cited from supersession_reason field)", source_file: "atlas.n6", source_line: 52990 },
    AtlasNode { kind: "C", id: "axis-j-5-check-4-counter-example", raw: "@C axis-j-5-check-4-counter-example :: meta [4]\n  <- axis-j-raw-117-5-check-results\n  status = PASS\n  counter_example = \"ANIMA-CXP-R38-R34-T1-RETIRED-INCONCLUSIVE (line 22060). This row uses [10*RETIRED_INCONCLUSIVE] in grade and supersedes R34 вҖ” but R38 is itself the RESULT of testing R34, not a REPLACEMENT for R34's claim. axis-J superseded_by would WRONGLY suggest 'R34 was replaced by R38' if applied naively. CORRECT semantics: R34's superseded_by points to R38 only in the 'this is the verdict on R34' sense, NOT 'R38 is the new claim.' RESOLUTION: supersession_reason field carries the disambiguation (\\\"verdict-on, not replacement-for\\\").\"\n  counter_example_lesson = \"axis-J supersession is NOT a single-relation; it requires the supersession_reason field to disambiguate {replacement, verdict, refinement, retraction}. Rejecting this nuance would make axis-J too coarse. PASS by demonstrating the disambiguation is built-in via supersession_reason.\"", source_file: "atlas.n6", source_line: 52998 },
    AtlasNode { kind: "C", id: "axis-j-5-check-5-novelty-falsifier", raw: "@C axis-j-5-check-5-novelty-falsifier :: meta [4]\n  <- axis-j-raw-117-5-check-results\n  status = PASS\n  novelty_claim = \"axis-J's superseded_by body-field is novel within atlas.n6 (zero current uses, 0 collisions per axis-F audit line 28533-28538 style mea... [truncated, full=1135bytes]", source_file: "atlas.n6", source_line: 53004 },
    AtlasNode { kind: "C", id: "axis-j-raw-91-C3-honest-disclosures", raw: "@C axis-j-raw-91-C3-honest-disclosures :: meta [4!]\n  <- axis-j-primitive-definition\n  -> axis-j-grounded-claims\n  -> axis-j-speculative-claims\n  -> axis-j-known-bounds\n  => \"raw 91 C3: every public claim must be flagged grounded vs speculative\"", source_file: "atlas.n6", source_line: 53013 },
    AtlasNode { kind: "C", id: "axis-j-grounded-claims", raw: "@C axis-j-grounded-claims :: meta [4]\n  <- axis-j-raw-91-C3-honest-disclosures\n  G1 = \"[DEPRECATED YYYY-MM-DD] / [RETIRED YYYY-MM-DD] meta-tags ALREADY EXIST on 4 @-rows in atlas.n6 (R34 line 21894, R36 line 21911, R38 line 22060, clay-iter-55-RETIRED line 25213). GROUNDED вҖ” direct grep evidence.\"\n  G2 = \"Zero superseded_by body-field instances exist today. GROUNDED вҖ” direct grep evidence (axis-F audit line 28933 honest_caveat).\"\n  G3 = \"axis-F K_core audit (line 28968) ranked superseded_by as RANK-1 highest-value field with adoption cost ~8.5 min. GROUNDED вҖ” recorded in atlas.n6 itself.\"\n  G4 = \"axis-J adds zero row-level arrow tokens, so axis-F K-ceiling stays at K=10. GROUNDED вҖ” by construction (axis-J defines no row-level arrows).\"\n  G5 = \"Commit aad6e61d back-link 'R34 DEPRECATED + R36 RETIRED вҖ” cross-repo sync from anima/.roadmap #202' exists in git log. GROUNDED вҖ” verifiable from current git state.\"", source_file: "atlas.n6", source_line: 53020 },
    AtlasNode { kind: "C", id: "axis-j-speculative-claims", raw: "@C axis-j-speculative-claims :: meta [4!]\n  <- axis-j-raw-91-C3-honest-disclosures\n  S1 = \"axis-J Г— axis-I composition (row example #3) for supersession-ancestry queries. SPECULATIVE вҖ” neither axis has a lint-tool implementation; the <-* operator is als... [truncated, full=1458bytes]", source_file: "atlas.n6", source_line: 53028 },
    AtlasNode { kind: "C", id: "axis-j-known-bounds", raw: "@C axis-j-known-bounds :: meta [4!]\n  <- axis-j-raw-91-C3-honest-disclosures\n  B1 = \"superseded_by accepts ONE slug (not a list). Multi-supersession (e.g. R34 вҶ’ {R38, anima/.roadmap#202, commit aad6e61d}) requires demoting secondary references to superse... [truncated, full=1271bytes]", source_file: "atlas.n6", source_line: 53036 },
    AtlasNode { kind: "C", id: "atlas-self-arch-axis-j-final-state", raw: "@C atlas-self-arch-axis-j-final-state = PROPOSAL-NOT-ACTUATED :: meta [4!]\n  <- atlas-self-arch-axis-j-supersession-witness\n  <- axis-j-orthogonality-analysis\n  <- axis-j-raw-117-5-check-results\n  <- axis-j-raw-91-C3-honest-disclosures\n  -> next-axis-K-candidates-deferred\n  => \"axis-J defined; 5-check 5/5 PASS; raw 91 C3 disclosures complete; orthogonality vs D-I clean (zero interference, strong synergy with G/I)\"\n  => \"next-step: axis-K discovery. Strongest remaining candidates from axis-J probe: (c) intrinsic time-axis (date metadata becomes queryable, complements axis-J's YYYY-MM-DD strings); (b) intrinsic grammar-version (atlas.n6 self-versioning, complements axis-J supersession at the SCHEMA level)\"\n  => \"DO NOT auto-absorb. shard awaits human review per scope contract.\"\n  => \"shard appended at: /Users/ghost/core/n6-architecture/atlas/atlas.append.atlas-self-arch-axis-j-supersession-2026-04-28.n6\"", source_file: "atlas.n6", source_line: 53045 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-14-renyi-2-witness", raw: "@C clay-cascade-s2-tick3-axis-14-renyi-2-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick2-axis-14-noise-floor-suspect\n  -> clay-cascade-s2-tick3-axis-14-saturating-proxy-explanation\n  => \"вҳ… axis-14 PARTIAL RECOVERY вҖ” REPLACE-ESTIMATOR with Renyi-2 H_2=-log(p^2+q^2), NOT full RETRACT\"\n  => \"diagnosis: 4p(1-p) Shannon-proxy SATURATES near p~0.5 (8/10 topologies within 5% of 1000 ceiling)\"\n  => \"underlying p-signal disc=0.186 (REAL); Renyi-2 disc=0.106 above 0.10 threshold; Shannon disc=0.080 (saturated)\"", source_file: "atlas.n6", source_line: 53081 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-14-saturating-proxy-explanation", raw: "@C clay-cascade-s2-tick3-axis-14-saturating-proxy-explanation :: meta [4]\n  <- clay-cascade-s2-tick3-axis-14-renyi-2-witness\n  => \"wavepacket centered at boundary i=32 вҶ’ all topologies see similar bipartition mass p~0.4-0.5\"\n  => \"4p(1-p) is parabolic with peak at p=0.5 вҶ’ near-peak inputs all map to ~1000 (collapsed)\"\n  => \"PSCALE 1000вҶ’10000 NO-HELP (disc 0.0798вҶ’0.0797): NOT resolution-limited, the proxy itself saturates\"\n  => \"Renyi-2 H_2=-log(p^2+q^2) is non-saturating monotone in |p-0.5| вҶ’ preserves signal in compression-blind regime\"\n  => \"Tsallis-0.5 super-additive (worse, disc=0.035); Tsallis-2 = 1-p^2-q^2 = (1/2)В·4p(1-p) algebraic re-scale (identical disc)\"", source_file: "atlas.n6", source_line: 53091 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-14-discrimination-table", raw: "@C clay-cascade-s2-tick3-axis-14-discrimination-table :: meta [4]\n  <- clay-cascade-s2-tick3-axis-14-renyi-2-witness\n  => \"format: estimator вҶ’ discrimination = stddev/mean across 10 D=3 topologies\"\n  => \"raw p_mille:           disc = 0.186 (strong-signal вҖ” underlying real signal)\"\n  => \"Renyi-2:               disc = 0.106 (REAL-SIGNAL вҖ” above 0.10 threshold)\"\n  => \"Shannon @ PSCALE=1000: disc = 0.0798 (marginal/saturated)\"\n  => \"Shannon @ PSCALE=10000:disc = 0.0797 (marginal вҖ” confirms NOT resolution issue)\"\n  => \"Tsallis-2:             disc = 0.0797 (marginal вҖ” algebraic re-scale of Shannon)\"\n  => \"Tsallis-0.5:           disc = 0.0353 (noise-floor-ish вҖ” over-compresses near p=0.5)\"", source_file: "atlas.n6", source_line: 53099 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-14-renyi-2-recommendation", raw: "@C clay-cascade-s2-tick3-axis-14-renyi-2-recommendation :: meta [4!]\n  <- clay-cascade-s2-tick3-axis-14-discrimination-table\n  -> clay-cascade-s2-tick3-K3-verify-grid-restoration\n  => \"вҳ… ATLAS RECOMMENDATION вҖ” adopt Renyi-2 estimator going forward; Shannon 4p(1-p) is replace-target\"\n  => \"K=2 STRONG (axis-13 + axis-16) restores to K=3 PROVISIONAL with axis-14[Renyi-2]\"\n  => \"previous axis-14 numerics (iter-46 to iter-70 with Shannon proxy) re-interpret as 'compressed signature, full signal in raw-p'\"\n  => \"follow-up: hexa fixed-point integer log approximation for Renyi-2 (current is Python float)\"\n  => \"follow-up: re-measure full 18 D=3 cohort with Renyi-2 to update phase-portrait + correlation matrix\"", source_file: "atlas.n6", source_line: 53109 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-14-C3-limits", raw: "@C clay-cascade-s2-tick3-axis-14-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick3-axis-14-renyi-2-witness\n  => \"n=5 disc=0.106 barely above 0.10 threshold вҖ” seed-jitter could straddle\"\n  => \"Renyi-2 here in float (Python /tmp/cascade_s2/axis14_alt.py); native-hexa needs integer log approximation\"\n  => \"Tsallis-0.5 needs fractional power p^0.5 вҖ” hexa-incompatible without Newton iter integer sqrt\"\n  => \"wavepacket boundary-init i=32 only; non-boundary (i=16, 48) might shift p and reverse saturation verdict\"\n  => \"saturation may be combined integer-Laplacian + half-cut quantization artifact вҖ” not deconvolved\"\n  => \"own#11 strict: Bekenstein exempt (sigma2=64 toy, no physical entropy claim)\"", source_file: "atlas.n6", source_line: 53118 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-tau-L2-REFUTED-witness", raw: "@C clay-cascade-s2-tick3-tau-L2-REFUTED-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick2-replacement-hypothesis-tau-L-squared\n  -> clay-cascade-s2-tick3-mass-oscillation-revised-mechanism\n  => \"вҳ… tau ~ O(L^2) REFUTED вҖ” chain1d log-log slope = -0.102 (R^2=0.58), NOT slope=2\"\n  => \"tau is L-INDEPENDENT вҖ” set by mass term not lattice diffusion\"\n  => \"revised mechanism: tau_fit ~23.6 ticks вүҲ mass-oscillation period 2pi/sqrt(m^2/PSCALE) = 19.9 ticks\"", source_file: "atlas.n6", source_line: 53140 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-tau-L-table", raw: "@C clay-cascade-s2-tick3-tau-L-table :: meta [4]\n  <- clay-cascade-s2-tick3-tau-L2-REFUTED-witness\n  => \"format: L вҶ’ tau_1/e ticks | tau_fit ticks | R^2 (descent-only saturation fit)\"\n  => \"L=4:  47.8 | 30.3 | 0.977\"\n  => \"L=6:  46.6 | 22.5 | 0.939\"\n  => \"L=8:  43.7 | 21.8 | 0.960\"\n  => \"L=10: 41.5 | 24.5 | 0.994\"\n  => \"L=12: 40.2 | 19.5 | 0.979\"\n  => \"L=16: 43.8 | 22.9 | 0.990\"\n  => \"tau_1/e mean = 43.9 Вұ 2.9 ticks (CV=6.6%); tau_fit mean = 23.6 Вұ 3.6 (CV=15%) вҖ” robust L-independence\"", source_file: "atlas.n6", source_line: 53150 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-mass-oscillation-revised-mechanism", raw: "@C clay-cascade-s2-tick3-mass-oscillation-revised-mechanism :: meta [4!]\n  <- clay-cascade-s2-tick3-tau-L-table\n  => \"вҳ… revised mechanism: HARMONIC OSCILLATION period set by mass term, NOT lattice diffusion\"\n  => \"omega = sqrt(m^2/PSCALE) = sqrt(0.1) = 0.316; period 2pi/omega = 19.9 ticks\"\n  => \"observed tau_fit = 23.6 ticks within 18% of mass period вҖ” close match\"\n  => \"descent bottom T_min ~ 64-96 ticks (~3-4 mass periods), L-independent\"\n  => \"regime: small-lattice mass-dominated (xi_lattice << xi_mass at all tested L)\"\n  => \"implication: tick-2 saturation R^2=0.997 was per-L oscillation envelope, NOT L-dependent equilibration\"", source_file: "atlas.n6", source_line: 53161 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-t3-integrator-unstable", raw: "@C clay-cascade-s2-tick3-t3-integrator-unstable :: meta [4]\n  <- clay-cascade-s2-tick3-tau-L2-REFUTED-witness\n  => \"t3 cubes NвҲҲ{27,64,125,216,512} INTEGRATOR-UNSTABLE on Verlet/force-20 step\"\n  => \"L=4 t3: correlator 9 вҶ’ 19 вҶ’ 30 вҶ’ 54 вҶ’ 339 вҶ’ -7281 вҶ’ -2.5e7 вҶ’ -2.7e10 over T={16..256}\"\n  => \"energy drift grows ~10^4Г— per 64-tick block вҖ” cannot test 3D regime without symplectic stepper or smaller dt\"\n  => \"current data only excludes L^2-scaling in small-lattice mass-dominated regime; large-L crossover untestable\"", source_file: "atlas.n6", source_line: 53170 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-tau-L2-followup", raw: "@C clay-cascade-s2-tick3-tau-L2-followup :: meta [4]\n  <- clay-cascade-s2-tick3-mass-oscillation-revised-mechanism\n  => \"follow-up test: vary m^2 explicitly, predict tau вҲқ 1/sqrt(m^2) (mass-oscillation hypothesis)\"\n  => \"follow-up: implement symplectic integrator for t3 to test 3D regime + larger L\"\n  => \"follow-up: enlarge chain1d L range [16, 64, 256] to detect potential xi_mass < L crossover where diffusion class might emerge\"\n  => \"atlas integrity strengthened by REFUTATION вҶ’ revised hypothesis registered, not silently retained\"", source_file: "atlas.n6", source_line: 53177 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-tau-L2-C3-limits", raw: "@C clay-cascade-s2-tick3-tau-L2-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick3-tau-L2-REFUTED-witness\n  => \"single seed=6 (CV<15% suggests robust but not multi-seed averaged)\"\n  => \"descent fit uses only 4-5 monotonic points per L; rebound after T~64-96 truncates tail\"\n  => \"chain1d L range [4,16] may be too narrow вҖ” true diffusion crossover might live at L>>16\"\n  => \"t3 untestable due to integrator instability вҖ” verdict applies to 1D ring only\"\n  => \"revised mass-oscillation hypothesis itself provisional pending m^2-variation test\"\n  => \"own#11 strict; tools: /tmp/cascade_s2_tick3/{chain1d_grid.txt, t3_grid.txt, fit_tau_v2.py}\"", source_file: "atlas.n6", source_line: 53184 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-cartoon-9cell-core-REJECTED-witness", raw: "@C clay-cascade-s2-tick3-cartoon-9cell-core-REJECTED-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick2-cartoon-9cell-invariant-core-witness\n  <- clay-cascade-s2-cartoon-causal-sector-closure\n  -> clay-cascade-s2-tick3-cartoon-true-basin-structure\n  -> clay-cascade-s2-tick3-axis-16-cartoon-V8-correction\n  => \"вҳ… tick-2 sub-agent I 9-cell INVARIANT CORE {11,13,20,29,36,43,52,59,61} FAILED TO REPLICATE at full 64-source enumeration\"\n  => \"TRUE structure: cartoon mixer V(k=7)=64 from 56/64 sources; only 8 special srcs {2,10,18,26,34,42,50,58} (вүЎ2 mod 8) give size-62 basins\"\n  => \"9-cell set is subset of universal 56-cell core, NOT a closed sub-attractor вҖ” claim REJECTED\"", source_file: "atlas.n6", source_line: 53206 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-cartoon-true-basin-structure", raw: "@C clay-cascade-s2-tick3-cartoon-true-basin-structure :: meta [4!]\n  <- clay-cascade-s2-tick3-cartoon-9cell-core-REJECTED-witness\n  => \"вҳ… TRUE cartoon basin structure (full 64-source BFS enumeration):\"\n  => \"9 distinct basins; size histogram {64: 1 basin, 62: 8 basins}\"\n  => \"56 sources вҶ’ size-64 basin (full saturation V(k>=7)=64); 8 special srcs each вҶ’ distinct size-62 basin missing 2 cells\"\n  => \"8 special sources: {2, 10, 18, 26, 34, 42, 50, 58} = 2 + 8n for n=0..7 (Z/64 cyclic-subgroup signature)\"\n  => \"universal core (intersection of all basins) = 56 cells, NOT 9 cells\"\n  => \"no basin admits a small (<62) closed attractor вҖ” every cell is recurrent under 3-axis closure\"", source_file: "atlas.n6", source_line: 53218 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-cartoon-mixer-bijectivity", raw: "@C clay-cascade-s2-tick3-cartoon-mixer-bijectivity :: meta [4]\n  <- clay-cascade-s2-tick3-cartoon-true-basin-structure\n  => \"structural reason: cartoon mixer (i*47 + axis*23 + 13) mod 64 has gcd(47, 64) = 1\"\n  => \"вҶ’ nbr(В·, axis) is a BIJECTION per axis (linear-affine map mod 64 with multiplier coprime to modulus)\"\n  => \"every cell IS recurrent under full 3-axis closure\"\n  => \"this is a number-theoretic property of the mixer, NOT a physical lattice signature\"\n  => \"findings DO NOT transfer to physical mixers (n_t3, n_minkowski, n_calabi6, etc.) without independent verification\"", source_file: "atlas.n6", source_line: 53227 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-16-cartoon-V8-correction", raw: "@C clay-cascade-s2-tick3-axis-16-cartoon-V8-correction :: meta [4!]\n  <- clay-cascade-s2-tick3-cartoon-true-basin-structure\n  => \"вҳ… tick-1 sub-agent A axis-16 cartoon V(8)=10 from src=32 вҖ” APPEARS TO BE BFS BUG\"\n  => \"src=32 is NOT in the 8 special sources {2,10,18,26,34,42,50,58} (32 mod 8 = 0, not 2)\"\n  => \"per sub-agent N: src=32 should reach V(7)=64 not V(8)=10\"\n  => \"tick-2 sub-agent I confirmed V(8)=10 across {0,16,32,48} вҖ” ALSO suspect (none of these are in special-8)\"\n  => \"likely cause: /tmp/lightcone_probe.py BFS may have premature truncation OR mixer formula divergence between scripts\"\n  => \"downstream: axis-16 cartoon V(8)=10 number is invalid; should be ~64 (full-fill class)\"\n  => \"follow-up: re-run /tmp/lightcone_probe.py with explicit verification against /tmp/cartoon_basin_enumerate.py\"", source_file: "atlas.n6", source_line: 53235 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-cartoon-correction-cascade-impact", raw: "@C clay-cascade-s2-tick3-cartoon-correction-cascade-impact :: meta [4]\n  <- clay-cascade-s2-tick3-axis-16-cartoon-V8-correction\n  => \"axis-16 saturation 3-class taxonomy revision needed:\"\n  => \"FAST-DEGENERATE was {altered V(8)=9, big-crunch V(8)=8, cartoon V(8)=10} вҖ” cartoon REMOVED вҶ’ only 2 members\"\n  => \"cartoon moves to FULL-FILL class (~64) along with t3, blackhole, wormhole, minkowski, etc.\"\n  => \"C3 amplitude-redistributor cluster (tick-1 phase-portrait): cartoon V(8) value affected; axis-13/14 cartoon values UNAFFECTED\"\n  => \"K=4 closure verdict (sub-agent G det(RвӮ„)=0.7481): cartoon V(8) row needs correction\"\n  => \"K=3 collapse (axis-15 retraction tick-2 K) compounds with this вҖ” cartoon row affects all det(R) computations\"", source_file: "atlas.n6", source_line: 53245 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-cartoon-rejection-C3-limits", raw: "@C clay-cascade-s2-tick3-cartoon-rejection-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick3-cartoon-9cell-core-REJECTED-witness\n  => \"cartoon mixer is TOY linear-affine map mod 64 вҖ” basin structure is number-theoretic not physical\"\n  => \"8-special-srcs arithmetic progression is Z/64 cyclic-subgroup, worth atlas absorption as structural-symmetry observation\"\n  => \"k=8 is past saturation (k=7 already reaches 64 from src=0) вҖ” choice of k>=7 makes analysis k-insensitive\"\n  => \"BFS-bug hypothesis for tick-1/tick-2 V(8)=10 is unverified вҖ” need direct comparison of /tmp/lightcone_probe.py vs /tmp/cartoon_basin_enumerate.py\"\n  => \"raw 71 retraction strengthens cascade integrity вҖ” error caught by 64-source enumeration vs 4-source confirmation bias\"\n  => \"own#11 strict: chflags uchg honored; this shard is candidate-text only awaiting absorption\"", source_file: "atlas.n6", source_line: 53254 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-17-DEFERRED-witness", raw: "@C clay-cascade-s2-tick3-axis-17-DEFERRED-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick1-stage6-topology-dependent-orthogonality\n  -> clay-cascade-s2-tick3-axis-17-symmetry-deficit-best-candidate\n  => \"вҳ… axis-17 promotion DEFERRED вҖ” n=5 95% Fisher-z CI on Pearson r вүҲ Вұ0.85, statistically indistinguishable from 0\"\n  => \"neither Symmetry-Deficit nor Diagonal-Dominance metric clears K=3 verify-grid promotion threshold under raw 91 C3\"\n  => \"K=2 STRONG (axis-13 saturation + axis-16 lightcone) HOLDS at this tick\"", source_file: "atlas.n6", source_line: 53276 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-17-symmetry-deficit-best-candidate", raw: "@C clay-cascade-s2-tick3-axis-17-symmetry-deficit-best-candidate :: meta [4]\n  <- clay-cascade-s2-tick3-axis-17-DEFERRED-witness\n  => \"Symmetry-Deficit (SD) = ||C - C^T||_F / ||C||_F  bounded [0,1]; 0=symmetric isotropic, 1=fully asymmetric\"\n  => \"Diagonal-Dominance (DD) = ОЈ diag / ОЈ off-diag; 1=balanced, вҲһ=strict-diagonal, 0=off-dominant\"\n  => \"5 topologies measured (flat/t3/s3/blackhole/wormhole) using sub-agent F's 3Г—3 cross-feed matrices\"\n  => \"SD values: flat=0.54, t3=0.05, s3=1.16, blackhole=0.00 (strict-diag), wormhole=1.06\"\n  => \"DD values: flat=0.50, t3=0.48, s3=0.53, blackhole=вҲһ (no off-diag), wormhole=0.50\"", source_file: "atlas.n6", source_line: 53286 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-17-orthogonality-vs-existing", raw: "@C clay-cascade-s2-tick3-axis-17-orthogonality-vs-existing :: meta [4]\n  <- clay-cascade-s2-tick3-axis-17-symmetry-deficit-best-candidate\n  => \"SD vs axis-13 + axis-16 (Pearson n=5):\"\n  => \"  r(SD, a13) = +0.161  r(SD, a16) = -0.160 вҖ” both PASS |r|<0.3 threshold\"\n  => \"  Spearman ПҒ(SD, a13) = +0.600 вҖ” FAILS rank-orthogonality (rank-coupled)\"\n  => \"DD vs axis-13 + axis-16 (Pearson n=5, blackhole inf clipped):\"\n  => \"  r(DD, a13) = -0.342  r(DD, a16) = +0.327 вҖ” both marginally exceed 0.3\"\n  => \"verdict: SD better candidate (lower Pearson, finite-valued, raw-91-cleaner) but rank-coupled\"", source_file: "atlas.n6", source_line: 53294 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-17-deferral-rationale", raw: "@C clay-cascade-s2-tick3-axis-17-deferral-rationale :: meta [4]\n  <- clay-cascade-s2-tick3-axis-17-orthogonality-vs-existing\n  => \"n=5 catastrophic: 95% Fisher-z CI on Pearson r вүҲ [-0.85, +0.91] вҖ” ALL r values INDISTINGUISHABLE FROM 0\"\n  => \"DD blackhole=вҲһ requires ad-hoc clipping; Pearson sensitivity Вұ0.1 depending on cap вҶ’ methodological hazard\"\n  => \"SD vs DD cosine similarity ~+0.4 вҶ’ partially co-measure same matrix structure (cannot promote both as independent)\"\n  => \"axis-13 sourcing inhomogeneous (multi-tick + iter-60) вҶ’ cross-source mixing methodologically loose\"\n  => \"DEFER axis-17 to full 18-topology cohort re-test (cross-feed measurement on all D=3 topologies)\"\n  => \"if SD passes |r|<0.3 + |ПҒ|<0.3 on n=18 вҶ’ promote to K=3 verify-grid\"", source_file: "atlas.n6", source_line: 53303 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick3-axis-17-DEFERRED-C3-limits", raw: "@C clay-cascade-s2-tick3-axis-17-DEFERRED-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick3-axis-17-DEFERRED-witness\n  => \"n=5 95% CI Вұ0.85 вҖ” fundamentally underpowered for orthogonality claims\"\n  => \"DD blackhole=вҲһ ad-hoc clipping (cap = 10Г— max finite); +/-0.1 Pearson sensitivity\"\n  => \"axis-13 mixed sources (ticks=64 multi-tick for flat/t3/s3 vs iter-60 v2-anchor for blackhole/wormhole) вҖ” cross-source loose\"\n  => \"sub-agent F matrices are single seed=6 sigma2=64 ticks=12 (not ensemble)\"\n  => \"5/18 topology coverage gap: cartoon, altered, big-crunch, calabi6, etc. NOT in propagation module\"\n  => \"SD and DD partially co-measure (cos~+0.4) вҖ” cannot promote both as separate axes\"\n  => \"own#11 strict; chflags uchg honored; atlas writes deferred to absorption stage\"", source_file: "atlas.n6", source_line: 53312 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-cartoon-bug-ROOT-CAUSE-witness", raw: "@C clay-cascade-s2-tick4-cartoon-bug-ROOT-CAUSE-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick3-cartoon-9cell-core-REJECTED-witness\n  -> clay-cascade-s2-tick4-bug-mechanism-explanation\n  -> clay-cascade-s2-tick4-cascade-impact-cartoon-only\n  => \"вҳ… BUG ROOT CAUSE вҖ” /tmp/lightcone_probe.py n_cartoon line 124-125: r=(i+off)%LSIGMA introduces extra +i\"\n  => \"promotes mixer (i*47+axis*23+13) вҶ’ effective (48i+23a+13) mod 64\"\n  => \"gcd(47,64)=1 (proper bijection) vs gcd(48,64)=16 (4-residue collapse, 12-cell image)\"", source_file: "atlas.n6", source_line: 53339 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-bug-mechanism-explanation", raw: "@C clay-cascade-s2-tick4-bug-mechanism-explanation :: meta [4]\n  <- clay-cascade-s2-tick4-cartoon-bug-ROOT-CAUSE-witness\n  => \"buggy code: off=(i*47+axis*23+13)%LSIGMA; r=(i+off)%LSIGMA\"\n  => \"вҶ’ algebraically: r = (i + 47i + 23a + 13) mod 64 = (48i + 23a + 13) mod 64\"\n  => \"fix: r = off (drop +i) вҶ’ preserves intended (47i + 23a + 13) mod 64\"\n  => \"tick-3 sub-agent N's '9-cell INVARIANT CORE' was 9 of those 12 collapsed-image cells вҖ” ARTIFACT not structure\"\n  => \"cross-check: enumerate.py docstring INVARIANT_CORE constant was hand-coded reference to bug-era output (bug vocabulary propagated)\"", source_file: "atlas.n6", source_line: 53350 },
