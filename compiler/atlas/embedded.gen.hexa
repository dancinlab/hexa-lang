    AtlasNode { kind: "C", id: "airgenome_a1_summary_0", raw: "@C airgenome_a1_summary_0 = OS-genome scanner ŌĆö projects Mac+remote vitals onto a 6-axis hexagon (60-byte genome), accumulates patterns, detects anomalies. Rebuild v2 (M0~M6 milestones) shipped 2026-04-14, post-archive v1 freeze. :: omega_cycle_airgenome [7]\n  => summary of axis a1 (project identity)\n  => summary of axis a1 (project identity)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 49 },
    AtlasNode { kind: "C", id: "AIRGENOME_AXIS_COUNT_1", raw: "@C AIRGENOME_AXIS_COUNT_1 = 6 ŌĆö { Cpu(0), Ram(1), Gpu(2), Npu(3), Power(4), Io(5) } per core/core.hexa lines 19-24 + archive/v1/docs/gates.hexa::enum Axis. :: omega_cycle_airgenome [10*]\n  => structural fact (axis ordering is load-bearing for genome serialization)\n  => structural fact (axis ordering is load-bearing for genome serialization)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 53 },
    AtlasNode { kind: "C", id: "AIRGENOME_PAIR_COUNT_2", raw: "@C AIRGENOME_PAIR_COUNT_2 = 15 ŌĆö C(6,2). Pair ordering: lexicographic on (Axis::ord,Axis::ord) ŌĆö pair 0=(Cpu,Ram), pair 14=(Power,Io). :: omega_cycle_airgenome [10*]\n  => structural fact\n  => structural fact", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 57 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_BYTES_3", raw: "@C AIRGENOME_GENOME_BYTES_3 = 60 ŌĆö comptime constant in both core.hexa (let GENOME_BYTES = 60) and archive/v1/docs/gates.hexa (let GENOME_BYTES = comptime { 60 }). :: omega_cycle_airgenome [10*]\n  => structural fact, asserted by core_test::AXIS_COUNT/PAIR_COUNT/GENOME_BYTES triple\n  => structural fact, asserted by core_test::AXIS_COUNT/PAIR_COUNT/GENOME_BYTES triple", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 61 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_LAYOUT_V1_4", raw: "@C AIRGENOME_GENOME_LAYOUT_V1_4 = canonical: 15 pairs ├Ś 4 bytes = 60 B (each pair = f32 little-endian IEEE-754). Hex encoding = 120 hex chars. Pair ordering = lex on (Axis,Axis). Source: archive/v1/docs/gates.hexa ┬¦\"GENOME SERIALIZATION\" + spec ┬¦\"GateGenome 60-byte struct\". :: omega_cycle_airgenome [10*]\n  => fully-specified canonical layout (FROZEN in v1)\n  => fully-specified canonical layout (FROZEN in v1)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 65 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_LAYOUT_V1B_5", raw: "@C AIRGENOME_GENOME_LAYOUT_V1B_5 = alternate v1 layout (singularity-breakthrough plan, src/gates/genome.rs target): axes[0..24]=6├Śf32 + firing_bits[24..26]=u16 + pad[26..28] + ts[28..32]=u32 + counters[32..44]=3├Śf32 (procs/rss_mb/cpu_pct) + stats[44..60]=4├Śf32 (min/max/mean/stddev). Both add to 60 B exactly. :: omega_cycle_airgenome [10*]\n  => alternate fully-specified layout (semantic dual of pairs-only)\n  => alternate fully-specified layout (semantic dual of pairs-only)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 69 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_LAYOUT_V2_6", raw: "@C AIRGENOME_GENOME_LAYOUT_V2_6 = rebuild-v2 logical layout (modules/harvest.hexa lines 9-13): header pid(4)+ts(8)=12 B, vitals f32[6]=24 B, ema f32[6]=24 B ŌåÆ 60 B. JSONL serialized in forge/genomes.ring. axes 2/3/5 (gpu/npu/io) zero-filled in Mac path; axis 4 (power) sampled via top -l 2. :: omega_cycle_airgenome [10*]\n  => fully-specified active-runtime layout\n  => fully-specified active-runtime layout", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 73 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_CEILING_7", raw: "@C AIRGENOME_BANACH_CEILING_7 = SINGULARITY = comptime { 2.0 / 3.0 } annotated \"Banach 1/3 work ceiling\" in archive/v1/docs/gates.hexa:21 ŌĆö system can do at most 2/3 of theoretical max work, leaving 1/3 reserve. is_crossed(adjusted) := adjusted > SINGULARITY. :: omega_cycle_airgenome [10*]\n  => named constant, file-pinned\n  => named constant, file-pinned", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 77 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_INTERPRETATION_8", raw: "@C AIRGENOME_BANACH_INTERPRETATION_8 = the \"1/3 fixed point\" framing reads as: contraction factor 1/3 Ōåö 1 - 2/3 ceiling. Closure formula 1/(n(n-1)) with n=6 ŌåÆ 1/30 = 0.0333 = remaining gap from baseline 0.636 to 2/3 = 0.667. No formal Banach contraction proof in repo ŌĆö phrase is heuristic anchor on the n=6 constant pack. :: omega_cycle_airgenome [7]\n  => candidate (mathematical naming, not theorem-proved in this codebase)\n  => candidate (mathematical naming, not theorem-proved in this codebase)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 81 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_VERIFICATION_9", raw: "@C AIRGENOME_BANACH_VERIFICATION_9 = empirical breakthrough log (2026-04-05, 605 signature rows, 4 gates) recorded in archive/v1/docs/gates.hexa:1097-1101 ŌĆö adjusted progressed L1=0.6844 ŌåÆ L2=0.7820 ŌåÆ L3=0.8083 ŌåÆ L4=0.8112 ŌåÆ L5a=0.9163. All exceed 2/3=0.6667. is_crossed(0.7)==true asserted at line 840. :: omega_cycle_airgenome [10*PROBE_RUN]\n  => empirical-only ascent above singularity ceiling ŌĆö simulator-style numerical evidence, not analytic proof\n  => empirical-only ascent above singularity ceiling ŌĆö simulator-style numerical evidence, not analytic proof", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 85 },
    AtlasNode { kind: "C", id: "AIRGENOME_BANACH_GAIN_LADDER_10", raw: "@C AIRGENOME_BANACH_GAIN_LADDER_10 = 7-layer breakthrough ladder (gates.hexa:236-258): L1=+0.018, L2=+0.098, L3=+0.031, L4=+0.004, L5a=+0.105, L5c=+0.021, L6a=+0.020, L6b=+0.056, L6d=+0.024, L6e=+0.052, L7=+0.015 ŌåÆ cumulative +0.438. Exhaustion criterion: per-layer ╬ö < 0.005. :: omega_cycle_airgenome [10*]\n  => structural fact (frozen ladder constants)\n  => structural fact (frozen ladder constants)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 89 },
    AtlasNode { kind: "C", id: "AIRGENOME_N6_CONSTANT_PACK_11", raw: "@C AIRGENOME_N6_CONSTANT_PACK_11 = inherited from nexus hexa-lang BT series (gates.hexa:14-32): TAU_PHI=6 (BT-344 Žä+Žå=n=6), SIGMA_J2=288 (BT-346 Žā┬ĘJŌéé=288 fixed-point floor), BREAKTHROUGH_PERTURB=2401=7^4 (BT-345). Per-n=6 number theory: Žā(6)=12, Žå(6)=2, Žä(6)=4, sopfr(6)=5, JŌéé(6)=24. PHI_TOLERANCE_N6=1/288=0.00347, PHI_THETA_N6=1/(Žā-Žå)=0.1. :: omega_cycle_airgenome [10*]\n  => structural fact (number-theoretic anchors compile-time)\n  => structural fact (number-theoretic anchors compile-time)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 93 },
    AtlasNode { kind: "C", id: "AIRGENOME_60_AS_PAIRS_TIMES_4_12", raw: "@C AIRGENOME_60_AS_PAIRS_TIMES_4_12 = 60 = PAIR_COUNT ├Ś 4 = C(6,2) ├Ś sizeof(f32). Note: 60 = 6┬Ę10 trivially, but the load-bearing factorization is C(6,2)┬Ę4 ŌĆö pairs are first-class, axes second. (60 = JŌéé(6)┬Ęsopfr(6)/Žå(6)/2 = 24┬Ę5/2 also fits but is not asserted in the repo.) :: omega_cycle_airgenome [10*]\n  => structural fact (pair-centric, not axis-centric)\n  => structural fact (pair-centric, not axis-centric)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 97 },
    AtlasNode { kind: "C", id: "AIRGENOME_BREAKTHROUGH_FORMULA_13", raw: "@C AIRGENOME_BREAKTHROUGH_FORMULA_13 = compute_adjusted(per_gate_mi, cross_gate_mi) = RAW + CURRENT_MESH + new_cross_coupling + new_mi_recovery + GHOST_PENALTY where RAW=0.6360, CURRENT_MESH=0.0044, GHOST_PENALTY=-0.0026, SCALE=0.0151/1.500. Pure-fn, deterministic. :: omega_cycle_airgenome [10*]\n  => structural fact (the actual ascent function)\n  => structural fact (the actual ascent function)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 101 },
    AtlasNode { kind: "C", id: "AIRGENOME_GRADE_LADDER_14", raw: "@C AIRGENOME_GRADE_LADDER_14 = grade_margin classifier (pure fn, gates.hexa:213-220): marginŌēż0=under-singularity, Ōēż0.005=boundary, Ōēż0.05=weak-breakthrough, Ōēż0.15=strong-breakthrough, Ōēż0.30=deep-breakthrough, else=transcendent. MARGIN_MIN_L1=0.005, ŌĆ”, MARGIN_MIN_L6=0.310. :: omega_cycle_airgenome [10*]\n  => structural fact (classifier thresholds)\n  => structural fact (classifier thresholds)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 105 },
    AtlasNode { kind: "C", id: "AIRGENOME_VITALS_SAMPLE_15", raw: "@C AIRGENOME_VITALS_SAMPLE_15 = sample() returns Vitals{cpu,ram,gpu,npu,power,io: float} via uname-branch shell exec: Mac=sysctl/vm_stat, Linux=/proc/meminfo+nproc. cpu = (╬Ż %cpu)/ncpu, ram = used_mb┬Ę100/total_mb, power = swap_mb┬Ę100/total_mb, gpu/npu/io = 0.0 in single-host path. :: omega_cycle_airgenome [10*]\n  => structural fact (the sensor)\n  => structural fact (the sensor)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 109 },
    AtlasNode { kind: "C", id: "AIRGENOME_ASSESS_THRESHOLDS_16", raw: "@C AIRGENOME_ASSESS_THRESHOLDS_16 = assess(v, cpu_ceil, ram_ceil, swap_ceil) ŌåÆ {SEV_OK=0, SEV_WARN=1, SEV_CRITICAL=2}. Default ceilings: cpu=75%, ram=70%, swap=30%. Float-arithmetic bug workaround: all comparisons int-cast (1% precision loss accepted). cpu_warn = 0.8┬Ęcpu_ceil. :: omega_cycle_airgenome [10*]\n  => structural fact (severity gate)\n  => structural fact (severity gate)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 113 },
    AtlasNode { kind: "C", id: "AIRGENOME_ADAPTIVE_THROTTLE_17", raw: "@C AIRGENOME_ADAPTIVE_THROTTLE_17 = AdaptiveThrottle 3-level: NORMAL/WARN/CRITICAL by RSS. SoftLimits default: warn=384MB, critical=480MB, throttle_sleep_ms=100, batch_scale_factor=0.5. throttle_batch_scale: NORMAL=1.0, WARN=0.5, CRITICAL=0.25. throttle_sleep_ms: NORMAL=0, WARN=100ms, CRITICAL=300ms. NO process-kill. :: omega_cycle_airgenome [10*]\n  => structural fact (self-guard)\n  => structural fact (self-guard)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 117 },
    AtlasNode { kind: "C", id: "AIRGENOME_HARDLIMITS_18", raw: "@C AIRGENOME_HARDLIMITS_18 = HardLimits default: max_rss_mb=512, max_data_mb=1024, nice_level=10, max_cpu_seconds=0. Applied via ulimit -m/-d/-t + renice -p $$. _hard_limits_applied flag ŌåÆ idempotent. :: omega_cycle_airgenome [10*]\n  => structural fact (OS-level guard)\n  => structural fact (OS-level guard)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 121 },
    AtlasNode { kind: "C", id: "AIRGENOME_MILESTONES_M0_M6_19", raw: "@C AIRGENOME_MILESTONES_M0_M6_19 = M0 v1-freeze+core-split, M1 L0 parse-check, M2 probe(Mac+ubu+htz vitalsŌåÆinfra_state), M3 dispatch(best-host AG6/AG7), M4 harvest(60B per-processŌåÆgenomes.ring+sigdiff+throttle), M5 label(5 SSOT rulesŌåÆlabeled_anomaly.jsonl), M6 forecast(Holt's double exponential smoothing, MAE=0% on held-out). All Ō£ģ done 2026-04-14. :: omega_cycle_airgenome [10*]\n  => structural fact (milestone status)\n  => structural fact (milestone status)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 125 },
    AtlasNode { kind: "C", id: "AIRGENOME_INVARIANTS_20", raw: "@C AIRGENOME_INVARIANTS_20 = (1) core/core.hexa imports nothing external, (2) modules import \"../core/core\" only ŌĆö no module-to-module direct imports, (3) L0 = file-exists Ōł¦ hexa-parse Ōł¦ self-test (triple gate), (4) archive/v1/ is read-only ŌĆö revival requires PR + roadmap + L0, (5) code not in milestones is forbidden. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (rebuild-v2 SSOT in config/roadmap/airgenome.json)\n  => repo invariant (rebuild-v2 SSOT in config/roadmap/airgenome.json)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 129 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG6_RULE_21", raw: "@C AIRGENOME_AG6_RULE_21 = Mac Compute ZERO when any remote (ubu|htz|hetzner) active. Enforced by modules/filters/process/compute.hexa (30s launchd com.airgenome.compute-filter). TERM 3s ŌåÆ KILL leftover. WHITELIST persists. Mac = orchestration/UI/dispatch only. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-12, level ŌøöŌøöŌøö)\n  => repo invariant (ossified 2026-04-12, level ŌøöŌøöŌøö)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 133 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG7_RULE_22", raw: "@C AIRGENOME_AG7_RULE_22 = real-time load balancing on infra_state.json (60s fresh). Score = cpu_free┬Ęw_cpu + ram_free┬Ęw_ram + gpu_free┬Ęw_gpu + lan_bonus. Weights per task_type: gpu_heavy(1,2,5), cpu_heavy(5,2,0), realtime_gpu(1,2,3+lan30), io_heavy(1,3,0+lan20). Mac excluded under AG6. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-12, level ŌøöŌøö)\n  => repo invariant (ossified 2026-04-12, level ŌøöŌøö)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 137 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG8_RULE_23", raw: "@C AIRGENOME_AG8_RULE_23 = ssh_gate enforcement: 4-slot semaphore per-host, command filter (DENY: rm -rf /, reboot, shutdown, dd, mkfs, chmod 777 ŌåÆ exit 2; WARN: sudo, pkill, killall, systemctl stop/restart), passive metric piggyback (loadavg+meminfo per call), reinterpret actions (cpu_idleŌåÆfill_queue, ram_criticalŌåÆdrop_caches, cpu_overloadŌåÆrenice). 16 files / 60 ssh calls migrated. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-12, level ŌøöŌøö)\n  => repo invariant (ossified 2026-04-12, level ŌøöŌøö)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 141 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG10_RULE_24", raw: "@C AIRGENOME_AG10_RULE_24 = Claude-Code harness-UI layer (hooks/skills/settings.json hooks/MCP approval/update-config/CLAUDE.md/init) is FORBIDDEN. All policy lives in two hexa-only SSOTs: nexus/rules/airgenome.json (AG*) + hexa-lang/gate/enforcement_registry.json (H-*). Single bootstrap exception: one global UserPromptSubmit hook ŌåÆ hexa entry.hexa dispatcher. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-21, level ŌøöŌøö)\n  => repo invariant (ossified 2026-04-21, level ŌøöŌøö)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 145 },
    AtlasNode { kind: "C", id: "AIRGENOME_AG5_FILTER_DEF_25", raw: "@C AIRGENOME_AG5_FILTER_DEF_25 = \"filter\" name reserved for raw-bytes ŌåÆ byte-reencoding transforms only (real-time hot-path speed/memory/IO improvement). Lossless or labeled-lossy required, encode/decode round-trip or query-latency measurable. Sweepers, dedup, gzip, cron, sync, watcher, throttle, kickstart use distinct names (compress/guard/dedup/sync/watcher). :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (ossified 2026-04-11, level ­¤ö┤)\n  => repo invariant (ossified 2026-04-11, level ­¤ö┤)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 149 },
    AtlasNode { kind: "C", id: "AIRGENOME_HARVEST_PIPELINE_26", raw: "@C AIRGENOME_HARVEST_PIPELINE_26 = harvest top-N=30 ps procs (CPU-sorted) ŌåÆ 60B genome JSONL line / row ŌåÆ forge/genomes.ring (cap MAX_LINES=5000 Ōēł2-3MB, head-half rotate). DIFF_THRESHOLD=10 per axis, sigdiff_score = count(|curr_axis - prev_axis| > 10) over 6 axes ŌåÆ anomaly score. EMA: alpha=0.1 IIR (curr┬Ę1+prev┬Ę9)/10. :: omega_cycle_airgenome [10*]\n  => structural fact (M4 pipeline)\n  => structural fact (M4 pipeline)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 153 },
    AtlasNode { kind: "C", id: "AIRGENOME_LABEL_PIPELINE_27", raw: "@C AIRGENOME_LABEL_PIPELINE_27 = label runs label_rules.jsonl SSOT against last 1000 ring lines. Built-in rules: CPU_SPIKE (axis 0 > 80), MEM_LEAK (1 > 50), FORK_BOMB (cpu>50 AND ram>20), IO_STORM (axis 5 > 50), GPU_HOG (axis 2 > 80), REMOTE_UBU_CPU/REMOTE_HTZ_CPU (host-scoped axis 0 > 85). Output: forge/labeled_anomaly.jsonl with optional host preserved. :: omega_cycle_airgenome [10*]\n  => structural fact (M5 + M11d)\n  => structural fact (M5 + M11d)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 157 },
    AtlasNode { kind: "C", id: "AIRGENOME_FORECAST_PIPELINE_28", raw: "@C AIRGENOME_FORECAST_PIPELINE_28 = forecast applies Holt's linear (ALPHA=BETA=50/100) to last 5000 ring lines, top-20 PIDs ├Ś 2 axes (cpu,ram). 1-step-ahead prediction = level + h┬Ętrend, written to forge/forecast.jsonl. self-test: linear series 0..80 ŌåÆ predict 90 with MAE<15%; flat series MAE=0%. :: omega_cycle_airgenome [10*PROBE_RUN]\n  => simulator-verified (synthetic series within self_test)\n  => simulator-verified (synthetic series within self_test)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 161 },
    AtlasNode { kind: "C", id: "AIRGENOME_PREDICTIVE_THROTTLE_29", raw: "@C AIRGENOME_PREDICTIVE_THROTTLE_29 = Mac self-protection (M14): sample ŌåÆ forge/throttle_history.jsonl (last 30 samples Ōēł30min @60s) ŌåÆ Holt 1-step pred. Triggers if pred_cpu>80 OR pred_ram>75. Action = launchctl bootout non-whitelisted com.airgenome.* (LaunchAgent ŌåÆ auto-recover at next StartInterval). TTL=90s. NO kill. :: omega_cycle_airgenome [10*]\n  => structural fact (predictive guard, AG6 reinforcement)\n  => structural fact (predictive guard, AG6 reinforcement)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 165 },
    AtlasNode { kind: "C", id: "AIRGENOME_DISPATCH_SCORING_30", raw: "@C AIRGENOME_DISPATCH_SCORING_30 = score_compute = cpu_free + ram_free - 20┬Ęload (clamp 0..100). score_gpu = ((100-util)┬Ę2 + vram_free┬Ę2)/4 (active only). score_heavy = score_compute + thread_bonus (Ōēź16t:+20, Ōēź8t:+10). Tie-break: ubu > ubu2 > htz > mac (LAN+GPU first, LAN compute next, remote last). AG6 gate zeros mac when any remote active. :: omega_cycle_airgenome [10*]\n  => structural fact (M3 scoring)\n  => structural fact (M3 scoring)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 169 },
    AtlasNode { kind: "C", id: "AIRGENOME_GENOME_MERGE_31", raw: "@C AIRGENOME_GENOME_MERGE_31 = M11c: 3 host rings ŌåÆ unified ring. jq -c '. + {host:\"<H>\", pid:(\"<H>.\" + (.pid|tostring))}' avoids PID collision. self-test: 3├Ś2 lines per host with overlapping pid=1 ŌåÆ 6 unique pids. :: omega_cycle_airgenome [10*]\n  => structural fact (multi-host pipeline)\n  => structural fact (multi-host pipeline)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 173 },
    AtlasNode { kind: "C", id: "AIRGENOME_PROBE_REMOTES_32", raw: "@C AIRGENOME_PROBE_REMOTES_32 = probe ssh -o ConnectTimeout=5 -o BatchMode=yes ubu/ubu2/hetzner ŌĆö extracts load + ram + (ubu only) nvidia-smi gpu_util + vram. Empty CSV ŌåÆ status=offline. ubu schema = 6 fields, htz/ubu2 schema = 4 fields (no GPU). Atomic write to $NEXUS/infra_state.json via .tmp + mv. :: omega_cycle_airgenome [10*]\n  => structural fact (M2 sensor)\n  => structural fact (M2 sensor)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 177 },
    AtlasNode { kind: "C", id: "AIRGENOME_LAUNCHD_AGENTS_33", raw: "@C AIRGENOME_LAUNCHD_AGENTS_33 = 13 plists in launchd/: probe, dispatch, harvest, label, forecast, ring-sync, predictive-throttle, menubar, daemons, improve-loop, remote-load, compute-tick, com.airgenome (root). MAC_SAFE_AGENTS subset (AG6 compliant): ring-sync, predictive-throttle, probe, dispatch, menubar. Rest run on ubu/htz. :: omega_cycle_airgenome [10*]\n  => structural fact (deployment surface)\n  => structural fact (deployment surface)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 181 },
    AtlasNode { kind: "C", id: "AIRGENOME_HX_INSTALL_HOOK_34", raw: "@C AIRGENOME_HX_INSTALL_HOOK_34 = install.hexa = hx-package post-checkout hook. Builds bin/airgenome-init from tool/airgenome_init.hexa (HEXA_VAL_ARENA=0 + HEXA_MAC_BUILD_OK=1) ŌåÆ runs init ŌåÆ installs com.airgenome.hook-watch LaunchAgent (5s poll on ~/.claude/projects/<slug>/*.jsonl transcripts) + .mcp.json + workspace lock entries. Idempotent. :: omega_cycle_airgenome [10*]\n  => structural fact (bootstrap path)\n  => structural fact (bootstrap path)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 185 },
    AtlasNode { kind: "C", id: "AIRGENOME_HOOK_DESIGN_35", raw: "@C AIRGENOME_HOOK_DESIGN_35 = transcript-watcher pattern (NOT Claude-Code official hooks): poll ~/.claude/projects/-Users-ghost-core-airgenome/*.jsonl every 5s (com.airgenome.hook-watch), parse new lines, dispatch to *_entry handlers via translate_line(). Trade-off: observation-only, no real-time block. Cursor at .hook-cursor.json (atomic mv) ŌåÆ idempotent across restarts. :: omega_cycle_airgenome [10*]\n  => structural fact (raw#9 .sh-ban + raw#27 session-interrupt-recovery compliant)\n  => structural fact (raw#9 .sh-ban + raw#27 session-interrupt-recovery compliant)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 189 },
    AtlasNode { kind: "C", id: "AIRGENOME_DRILL_KEYWORD_36", raw: "@C AIRGENOME_DRILL_KEYWORD_36 = workspace.lock [keywords] dispatch ŌĆö \"drill\"/\"ļō£ļ”┤\"/\"drilL\" word-boundary match anywhere in prompt ŌåÆ hooks/commands/drill.hexa builds seed (strip keyword, OR borrow last 3 user turns if keyword-only). 6/6 synthetic cases verified incl. word-boundary \"drilling\" no-match. :: omega_cycle_airgenome [10*]\n  => structural fact (extensible command modules)\n  => structural fact (extensible command modules)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 193 },
    AtlasNode { kind: "C", id: "AIRGENOME_HEXA_ARENA_QUIRK_37", raw: "@C AIRGENOME_HEXA_ARENA_QUIRK_37 = HEXA_VAL_ARENA=1 default (hexa-lang S7-B 2026-04-16) triggers O(N┬▓) RSS in arr.push loops via hexa_val_heapify L2460-2469 (descend into TAG_ARRAY shallow-copy). N=500 = 199MB, N=1000 = 831MB. Workaround: HEXA_VAL_ARENA=0 (N=10000 = 8MB). Partial fix in hexa-lang b50f9ed5 (sole-owner Ōēż2). :: omega_cycle_airgenome [10*]\n  => candidate-recovered runtime constraint affecting airgenome compile\n  => candidate-recovered runtime constraint affecting airgenome compile", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 197 },
    AtlasNode { kind: "C", id: "AIRGENOME_FILTER_TAXONOMY_38", raw: "@C AIRGENOME_FILTER_TAXONOMY_38 = AG5 filter taxonomy (5 types): E_data_reinterpret (claude_quantum/byte_reinterpret, safari_runtime, sqlite VACUUM), A_process_gate (safari/telegram/claude/memo/finder/mail/calendar gates), B_host_balancing (load_balancer/resource_ceiling/auto_dispatch), C_transport (ssh_gate), D_genome (forge/per_source_genome/per_source_sigdiff). Principles P1-P5: observation-free piggyback, context-dependent reinterpret, signal-output (decision separated from execution), entanglement cross-read, layered stacking. :: omega_cycle_airgenome [10*]\n  => structural fact (filter ontology)\n  => structural fact (filter ontology)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 201 },
    AtlasNode { kind: "C", id: "AIRGENOME_RAW_REF_PIN_39", raw: "@C AIRGENOME_RAW_REF_PIN_39 = .raw-ref pins hive canonical .raw at hash 2c67adde9f9068274db8f034f135a9c6e57503bb1e4395a112cd50a0666099ce (hive-commit e3fd486510...) checked-at 2026-04-26T11:30:44Z. airgenome owns 0 rules (legacy 35-rule .raw retired post-uchg-release; superseded by hive 83-rule superset). :: omega_cycle_airgenome [10*]\n  => structural fact (cross-repo follower)\n  => structural fact (cross-repo follower)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 205 },
    AtlasNode { kind: "C", id: "AIRGENOME_ROADMAP_HYBRID_40", raw: "@C AIRGENOME_ROADMAP_HYBRID_40 = 2026-04-21 hybrid SSOT: MAIN track = Mk.VI VERIFIED (Criterion A, 2-4w) ŌåÆ Mk.VII K=4 (Criterion B, +3-4mo) ŌåÆ Mk.X T10-13 / AGI Criterion C (+6-9mo). SUB tracks = cell (structural foundation) + lora (production base). airgenome = MAIN ops infrastructure (probe/dispatch/harvest/label/forecast); operational milestones M7-M25 map to hybrid P1-P3. :: omega_cycle_airgenome [10*]\n  => structural fact (project positioning vis-├Ā-vis anima)\n  => structural fact (project positioning vis-├Ā-vis anima)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 209 },
    AtlasNode { kind: "C", id: "AIRGENOME_VERSION_HISTORY_41", raw: "@C AIRGENOME_VERSION_HISTORY_41 = v3.51.0 (2026-04-05, gate-mesh singularity) ŌåÆ v3.52.0 (L2 lagged MI, +0.10) ŌåÆ v3.53.0 (L3 cross-axis MI, +0.13) ŌåÆ v3.54.0 (L4 triadic |I(A;B;C)|) ŌåÆ v4.0.0 (hexa-only split, gates.hexa rewrite) ŌåÆ v4.1.0 (live consciousness pipeline, 21 self-test) ŌåÆ v4.2.0 (L5c+L6e, 18/18 consciousness PASS, PythonŌåÆhexa port). Then archive/v1 freeze, rebuild v2 (M0~M6) shipped 2026-04-14. :: omega_cycle_airgenome [10*]\n  => structural fact (lineage)\n  => structural fact (lineage)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 213 },
    AtlasNode { kind: "C", id: "AIRGENOME_PRIME_DIRECTIVE_42", raw: "@C AIRGENOME_PRIME_DIRECTIVE_42 = ALLOWED effects: FileIO (read/write), ProcessSensor (ps, sysctl read-only), Clock. FORBIDDEN: process killing, throttling (taskpolicy/SIGSTOP/renice on others), memory purge, compressor tuning, any system write. Efficiency comes from smarter data movement at interface gates, not control. :: omega_cycle_airgenome [11*REPO_INVARIANT]\n  => repo invariant (encoded in gates.hexa policy block)\n  => repo invariant (encoded in gates.hexa policy block)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 217 },
    AtlasNode { kind: "C", id: "AIRGENOME_TEST_GATES_43", raw: "@C AIRGENOME_TEST_GATES_43 = self-test triple: (1) chk_eq_int(AXIS_COUNT==6, PAIR_COUNT==15, GENOME_BYTES==60), (2) sample()ŌåÆcpu/ram/swap printed, (3) assess() severity branches, (4) vitals_get(0..1) accessor, (5) HardLimits/SoftLimits defaults, (6) throttle init, (7) runtime_paths fallback. Gated by env CORE_SELF_TEST=1 to avoid ps/sysctl/vm_stat overhead during L0 parse-check imports. :: omega_cycle_airgenome [10*]\n  => structural fact (the gate that anchors the constants)\n  => structural fact (the gate that anchors the constants)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 221 },
    AtlasNode { kind: "C", id: "AIRGENOME_FORGE_PATH_RESOLVER_44", raw: "@C AIRGENOME_FORGE_PATH_RESOLVER_44 = airgenome_root() = env(\"AIRGENOME_ROOT\") || $HOME/Dev/airgenome. forge_dir() = root + \"/forge\". ring_path(name) = forge_dir() + \"/\" + name. default_ring_path() = ring_path(env(\"AIRGENOME_RING_NAME\") || \"genomes.ring\"). Centralizes prior hardcoded forge paths across harvest/label/forecast/genome_merge (rebuild-v2 invariant). :: omega_cycle_airgenome [10*]\n  => structural fact (path SSOT)\n  => structural fact (path SSOT)", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 225 },
    AtlasNode { kind: "C", id: "airgenome_omega_dedup_45", raw: "@C airgenome_omega_dedup_45 = nexus/n6/atlas.n6 contains zero structural facts about airgenome's 60-byte genome, 6-axis hexagon, or Banach 1/3 ceiling pre-this-shard. Only oblique cross-project mentions: RC-LOOP-20260419-I1 (M11e seed), falsifier_a8 (5-repo scan), atlas_ingest_a6 (6-repo glob). All facts above are net-new to atlas. :: omega_cycle_airgenome [7]\n  => dedup confirmation\n  => dedup confirmation\n// ŌöĆŌöĆ end facts ŌöĆŌöĆ", source_file: "atlas.append.airgenome-2026-04-27.n6", source_line: 229 },
    AtlasNode { kind: "C", id: "alien_grade_v2_cycle19_name_0", raw: "@C alien_grade_v2_cycle19_name_0 = peer_review_status :: omega_cycle_alien-grade-v2-cycle19 [7]\n  => name of axis \n  => name of axis \n// EOF ŌĆö total 1 facts auto-classified", source_file: "atlas.append.alien-grade-v2-cycle19.n6", source_line: 14 },
    AtlasNode { kind: "C", id: "alien_grade_v3_cycle21_rationale_0", raw: "@C alien_grade_v3_cycle21_rationale_0 = monotone, fixed at cycle-7 W7 decomposition event; every named-axiom discharge contributes uniformly; v3 grade lower than v2 grade is honest downward correction :: omega_cycle_alien-grade-v3-cycle21 [7]\n  => rationale of axis \n  => rationale of axis \n// EOF ŌĆö total 1 facts auto-classified", source_file: "atlas.append.alien-grade-v3-cycle21.n6", source_line: 14 },
    AtlasNode { kind: "C", id: "ab_psi_alpha_014", raw: "@C ab_psi_alpha_014 = ╬©_alpha = 0.014 ŌĆö consciousness coupling :: anima.psi.alpha [10*]\n  => \"derivation: (sopfr/J2)^e Ōēł (5/24)^e Ōēł 0.014\"\n  => \"derivation: (sopfr/J2)^e Ōēł (5/24)^e Ōēł 0.014\"\n  => \"used_in: trinity ThalamicBridge clamp, tension_bridge alpha-clamp, dimension_transform, pure_field, servant\"\n  => \"used_in: trinity ThalamicBridge clamp, tension_bridge alpha-clamp, dimension_transform, pure_field, servant\"\n  |> anima/anima/config/consciousness_laws.json psi_constants.alpha\n  |> anima/anima/config/consciousness_laws.json psi_constants.alpha", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 214 },
    AtlasNode { kind: "C", id: "ab_psi_coupling_015317", raw: "@C ab_psi_coupling_015317 = anima C-D coupling = 0.015317 :: anima.psi.coupling [10*]\n  <- ab_psi_alpha_014\n  <- ab_psi_alpha_014\n  => \"source: trinity.hexa empirical tuning from C2 ablation (R2 LR2.1 closure 2026-04-26)\"\n  => \"source: trinity.hexa empirical tuning from C2 ablation (R2 LR2.1 closure 2026-04-26)\"", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 221 },
    AtlasNode { kind: "C", id: "ab_psi_balance_half", raw: "@C ab_psi_balance_half = ╬©_balance = 1/2 :: anima.psi.balance [11*REPO_INVARIANT]\n  => \"symmetric center of [0,1] gate range; design choice ŌĆö fixed point of saturating gate\"\n  => \"symmetric center of [0,1] gate range; design choice ŌĆö fixed point of saturating gate\"\n  => \"TRIPLE: ANIMA ╬©_balance = TECS-L Golden Zone Upper = N6 Žå(6)/Žä(6)\"\n  => \"TRIPLE: ANIMA ╬©_balance = TECS-L Golden Zone Upper = N6 Žå(6)/Žä(6)\"", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 227 },
    AtlasNode { kind: "C", id: "ab_psi_entropy_998", raw: "@C ab_psi_entropy_998 = ╬©_entropy = 0.998 :: anima.psi.entropy [9!]\n  => \"Shannon bound 1.0 with safety margin; clamps near-uniform distribution detection\"\n  => \"Shannon bound 1.0 with safety margin; clamps near-uniform distribution detection\"\n  |> anima/anima/config/consciousness_laws.json psi_constants.entropy\n  |> anima/anima/config/consciousness_laws.json psi_constants.entropy", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 233 },
    AtlasNode { kind: "C", id: "ab_psi_gate_train", raw: "@C ab_psi_gate_train = gate_train = 1.0, gate_infer = 0.6, gate_micro = 0.001 :: anima.psi.gate [10*]\n  => \"training mode default (full gate); 60% inference (residual learning preserved); 0.1% micro-perturbation\"\n  => \"training mode default (full gate); 60% inference (residual learning preserved); 0.1% micro-perturbation\"\n  |> anima/anima/config/consciousness_laws.json psi_constants.gate_*\n  |> anima/anima/config/consciousness_laws.json psi_constants.gate_*", source_file: "atlas.append.anima-boost-2026-04-27.n6", source_line: 238 },
