    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-15-relabel-saturation-amplitude", raw: "@C clay-cascade-s2-tick2-axis-15-relabel-saturation-amplitude :: meta [4!]\n  <- clay-cascade-s2-tick2-CN-drift-measurements\n  <- clay-cascade-s2-tick2-CN-drift-measurements\n  => \"Ōśģ axis-15 measures BOUNDED-SYSTEM SATURATION AMPLITUDE, NOT physical conserved quantity\"\n  => \"Ōśģ axis-15 measures BOUNDED-SYSTEM SATURATION AMPLITUDE, NOT physical conserved quantity\"\n  => \"CN amplifies (not reduces) drift because trapezoidal mixing increases coupling to bounded mod-LSCALE folding\"\n  => \"CN amplifies (not reduces) drift because trapezoidal mixing increases coupling to bounded mod-LSCALE folding\"\n  => \"raw 71 falsifier-retire-rule: axis-15 RETRACTED from verify-grid; recharacterize as 'bounded saturation amplitude' observable\"\n  => \"raw 71 falsifier-retire-rule: axis-15 RETRACTED from verify-grid; recharacterize as 'bounded saturation amplitude' observable\"", source_file: "atlas.n6", source_line: 52697 },
