    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-symplectic-t3-C3-limits", raw: "@C clay-cascade-s2-tick4-symplectic-t3-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick4-symplectic-t3-stabilized-witness\n  => \"Python mirror only /tmp/cascade_s2/symplectic_t3.py вҖ” hexa port deferred\"\n  => \"verdict assumes f64 hexa would behave like Python f64 (true if hexa adds float type or scales i64 by SCALE^2)\"\n  => \"L=4 t3 only вҖ” extension to L=8/16 untested; CFL bound dt < c*a may tighten with finer lattice\"\n  => \"tau=33 fragile: 1% threshold one choice; correlator oscillates 60-82 band so tau measures first-plateau-touch\"\n  => \"m^2=1 continuum-units; hexa uses m^2=100/SCALE вҖ” effective-mass consistency check not done\"\n  => \"Gaussian initial bump centered (not random) вҖ” saturation behavior may depend on IC class\"\n  => \"own#11 strict; raw 71 retire/refine: 'Verlet' label retired from e2_step\"", source_file: "atlas.n6", source_line: 53581 },
