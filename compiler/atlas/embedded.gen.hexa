    AtlasNode { kind: "C", id: "GAP-BIDIRECTIONAL-EQUIVALENCE", raw: "@C GAP-BIDIRECTIONAL-EQUIVALENCE = mutual implication needs token, has only 4 prose uses :: meta [9]\n  <- ARROW-COUNT-IFF-DOUBLE\n  <- ARROW-COUNT-IFF-SINGLE\n  -> ARROW-PROPOSAL-BIDIR\n  => \"<-> and <=> together appear only 4 times yet pair-relation semantics (CubeвҶ”Octahedron, sigma=tau iff n=6) recur ~30+ times in prose\"", source_file: "atlas.n6", source_line: 50394 },
    AtlasNode { kind: "C", id: "GAP-NEGATION-BLOCKING", raw: "@C GAP-NEGATION-BLOCKING = no token for 'X blocks Y' or 'X incompatible-with Y' :: meta [9]\n  <- ARROW-AUDIT-2026-04-28\n  -> ARROW-PROPOSAL-NEGATION\n  => \"atlas.n6 expresses obstruction only via prose ('blocks', 'forbids', 'incompatible'); no -| or -Г— token; falsification raws (R34/R36) need this\"", source_file: "atlas.n6", source_line: 50400 },
