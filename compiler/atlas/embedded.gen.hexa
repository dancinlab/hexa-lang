    AtlasNode { kind: "C", id: "clay-cascade-s5-AK-correlation-matrix-i16", raw: "@C clay-cascade-s5-AK-correlation-matrix-i16 :: meta [4]\n  <- clay-cascade-s5-AK-18-cohort-renyi2-i16\n  => \"3-axis correlation matrix at non-boundary IC=16, full n=18:\"\n  => \"  a14 x a13: Pearson = -0.536 / Spearman = -0.483\"\n  => \"  a14 x a16: Pearson = -0.115 / Spearman = -0.239\"\n  => \"  a13 x a16: Pearson = -0.128 / Spearman = -0.233\"\n  => \"trapped-excluded n=15 cross-check:\"\n  => \"  a14 x a13: Pearson = -0.223 / Spearman = -0.307\"\n  => \"  a14 x a16: Pearson = -0.215 / Spearman = -0.255\"\n  => \"  a13 x a16: Pearson = -0.713 / Spearman = -0.315\"", source_file: "atlas.n6", source_line: 55270 },
    AtlasNode { kind: "C", id: "clay-cascade-s5-AK-coupling-sign-flip-IC-conditional", raw: "@C clay-cascade-s5-AK-coupling-sign-flip-IC-conditional :: meta [4!]\n  <- clay-cascade-s5-AK-correlation-matrix-i16\n  => \"вҳ… STRIKING FINDING: a14Г—a13 SIGN FLIP between IC=32 and IC=16\"\n  => \"format: pair | i=32 P | i=32 S | i=16 P | i=16 S | dP | dS\"\n  => \"a14 x a13: +0.282 / +0.519 | -0.536 / -0.483 | dP=-0.818, dS=-1.002\"\n  => \"a14 x a16: -0.370 / -0.209 | -0.115 / -0.239 | dP=+0.255, dS=-0.030\"\n  => \"a14Г—a13 magnitude GREW at non-boundary (from 0.282/0.519 to 0.536/0.483)\"\n  => \"  AND sign reversed (positive вҶ’ negative correlation)\"\n  => \"a14Г—a16 weakened slightly at non-boundary (Pearson FAILвҶ’PASS)\"\n  => \"interpretation: IC=32 forces pвҶ’0.5 saturating BOTH discrimination AND coupling magnitude artifically low\"\n  => \"  IC=16 reveals true a14вҶ”a13 coupling structure вҖ” anti-correlation under non-boundary\"\n  => \"qualitatively IC-conditional (sign flip!) but quantitatively still |r|>0.3 in BOTH ICs\"", source_file: "atlas.n6", source_line: 55281 },
