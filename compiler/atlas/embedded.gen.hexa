    AtlasNode { kind: "C", id: "TECSL-PAPER-CCT-NEGATIVE", raw: "@C TECSL-PAPER-CCT-NEGATIVE = CCT 5-test battery is INSUFFICIENT: 4/5 non-conscious systems pass all 5 tests; only 2/5 tests (T2 temporal integration, T3 counterfactual sensitivity) are statistically independent :: consciousness [10]\n  => \"Source: P-CCT-consciousness-test.md Abstract.\"\n  => \"Source: P-CCT-consciousness-test.md Abstract.\"\n  => \"Sleep-wake transitions = gradual ('dial' not 'switch'); supports continuum (not binary) consciousness.\"\n  => \"Sleep-wake transitions = gradual ('dial' not 'switch'); supports continuum (not binary) consciousness.\"", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 424 },
    AtlasNode { kind: "C", id: "SEDI-PAPER-PS04-FISHER", raw: "@C SEDI-PAPER-PS04-FISHER = Fisher combined 5.26Žā (p=7.1e-8) from 4 independent findings: QCD ladder 3.8Žā + quark-lepton bridge 3.4Žā + Higgs branching 2.8Žā + baryon splittings 2.4Žā :: meta-analysis [10]\n  => \"Source: PS-04-cern-meta-analysis.md Abstract.\"\n  => \"Source: PS-04-cern-meta-analysis.md Abstract.\"\n  => \"Honesty [10] (not [10*]): the four findings derive from same n=6 framework; statistical 'independence' is partial ŌĆö same generating constants reused in different sectors.\"\n  => \"Honesty [10] (not [10*]): the four findings derive from same n=6 framework; statistical 'independence' is partial ŌĆö same generating constants reused in different sectors.\"\n  |> /Users/ghost/core/papers/sedi/PS-04-cern-meta-analysis.md\n  |> /Users/ghost/core/papers/sedi/PS-04-cern-meta-analysis.md", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 456 },
    AtlasNode { kind: "C", id: "SEDI-PAPER-PS18-CC-122", raw: "@C SEDI-PAPER-PS18-CC-122 = cosmological constant exponent: sigma(6)┬▓ - sigma(6) - tau(6) - n = 144 - 12 - 4 - 6 = 122 (matches observed ╬ø ~ 10^-122 M_PlŌü┤) :: cosmology-arith [9]\n  => \"Source: PS-18-cosmological-constant.md Abstract.\"\n  => \"Source: PS-18-cosmological-constant.md Abstract.\"\n  => \"Falsification at n=28 (06_falsification F4): Žā┬▓-Žā-Žä-n = 3046 ŌēĀ 122 ŌåÆ n=6 selected over n=28.\"\n  => \"Falsification at n=28 (06_falsification F4): Žā┬▓-Žā-Žä-n = 3046 ŌēĀ 122 ŌåÆ n=6 selected over n=28.\"", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 505 },
