    AtlasNode { kind: "C", id: "clay-cascade-s3-tick2-AF-mixer-design", raw: "@C clay-cascade-s3-tick2-AF-mixer-design :: meta [4]\n  <- clay-cascade-s3-tick2-AF-deg-var-mechanism-NARROWED-witness\n  => \"adversarial mixer family: nbr(i, axis) = (i*A + axis*B + C) mod 64; src=32, 3 axes\"\n  => \"M1: A=8  B=17 C=5  | gcd(8,64)=8   | 8 cosets\"\n  => \"M2: A=16 B=7  C=11 | gcd(16,64)=16 | 4 cosets\"\n  => \"M3: A=32 B=13 C=3  | gcd(32,64)=32 | 2 cosets\"\n  => \"M4: A=4  B=23 C=7  | gcd(4,64)=4   | 16 cosets\"\n  => \"M5: A=48 B=19 C=9  | gcd(48,64)=16 | 4 cosets (cartoon-bug analog)\"\n  => \"C1: A=47 B=23 C=13 | gcd(47,64)=1  | 64 cosets (proper cartoon, FULL control)\"\n  => \"C2: A=45 B=23 C=13 | gcd(45,64)=1  | 64 cosets (low-deg-var FULL control)\"", source_file: "atlas.n6", source_line: 54690 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick2-AF-predictions-and-measurements", raw: "@C clay-cascade-s3-tick2-AF-predictions-and-measurements :: meta [4]\n  <- clay-cascade-s3-tick2-AF-mixer-design\n  => \"PRE-DECLARED prediction rule (file /tmp/cascade_s3/AF_predictions.txt):\"\n  => \"  deg_var >= 20 -> FAST | 5 <= deg_var < 20 -> BOUNDED | deg_var < 5 -> FULL\"\n  => \"format: mixer | deg_M | deg_var | predicted | V(8) measured | meas_class | hit?\"\n  => \"M1: deg_M=11  deg_var=13.37  pred=BOUNDED | V(8)=13 BOUNDED  HIT\"\n  => \"M2: deg_M=19  deg_var=34.37  pred=FAST    | V(8)=13 BOUNDED  MISS\"\n  => \"M3: deg_M=34  deg_var=76.53  pred=FAST    | V(8)=7  FAST     HIT\"\n  => \"M4: deg_M=7   deg_var=2.87   pred=FULL    | V(8)=40 BOUNDED  MISS\"\n  => \"M5: deg_M=19  deg_var=34.37  pred=FAST    | V(8)=10 FAST     HIT\"\n  => \"C1: deg_M=6   deg_var=0.31   pred=FULL    | V(8)=64 FULL     HIT\"\n  => \"C2: deg_M=6   deg_var=0.28   pred=FULL    | V(8)=64 FULL     HIT\"\n  => \"match rate: 5/7 = 71.4% < 80% threshold -> mechanism PARTIAL\"", source_file: "atlas.n6", source_line: 54701 },
