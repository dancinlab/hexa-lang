    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness", raw: "@C clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-91-C3-honest-disclosure\n  <- own#11-strict-no-resolution-claim\n  <- own#11-strict-no-resolution-claim\n  -> clay-cascade-s2-tick2-K4-verify-grid-collapse-to-K3\n  -> clay-cascade-s2-tick2-K4-verify-grid-collapse-to-K3\n  => \"Ōśģ MAJOR RETRACTION ŌĆö axis-15 (Lorentz energy-drift) is INTEGRATION ARTIFACT, not physical observable\"\n  => \"Ōśģ MAJOR RETRACTION ŌĆö axis-15 (Lorentz energy-drift) is INTEGRATION ARTIFACT, not physical observable\"\n  => \"verdict: drift fluctuates fixed band 0.7-4.7, NO T-refinement convergence; CN AMPLIFIES drift 1.6├Ś-5├Ś vs explicit-Euler\"\n  => \"verdict: drift fluctuates fixed band 0.7-4.7, NO T-refinement convergence; CN AMPLIFIES drift 1.6├Ś-5├Ś vs explicit-Euler\"", source_file: "atlas.n6", source_line: 52667 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick2-CN-Stage2-formal", raw: "@C clay-cascade-s2-tick2-CN-Stage2-formal :: meta [4]\n  <- clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  <- clay-cascade-s2-tick2-axis-15-MAJOR-RETRACTION-witness\n  => \"T[i] = -phi^n[i] + phi^{n-1}[i]/4 (time-like retarded, kept explicit, 2nd-order in t)\"\n  => \"T[i] = -phi^n[i] + phi^{n-1}[i]/4 (time-like retarded, kept explicit, 2nd-order in t)\"\n  => \"implicit half: Jacobi-8 iters seeded from explicit prediction; mirrors lorentz_metric.hexa:362-405\"\n  => \"implicit half: Jacobi-8 iters seeded from explicit prediction; mirrors lorentz_metric.hexa:362-405\"", source_file: "atlas.n6", source_line: 52679 },
