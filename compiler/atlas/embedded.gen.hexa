    AtlasNode { kind: "C", id: "clay-iter-52-WORMHOLE-NORM-DRIFT-DISCOVERY", raw: "@C clay-iter-52-WORMHOLE-NORM-DRIFT-DISCOVERY :: meta [4!]\n  => \"ŌśģŌśģŌśģ KEY FINDING: wormhole discrete unitary has 67% norm drift\"\n  => \"ŌśģŌśģŌśģ KEY FINDING: wormhole discrete unitary has 67% norm drift\"\n  => \"  wormhole norm: 39688 ŌåÆ 66208 (+66.8% drift, BROKEN unitarity!)\"\n  => \"  wormhole norm: 39688 ŌåÆ 66208 (+66.8% drift, BROKEN unitarity!)\"\n  => \"  wormhole _qneighbor_wormhole uses antipodal coupling (i Ōåö N-i)\"\n  => \"  wormhole _qneighbor_wormhole uses antipodal coupling (i Ōåö N-i)\"\n  => \"  Discrete Schr├Čdinger update over-counts amplitude ŌåÆ norm growth\"\n  => \"  Discrete Schr├Čdinger update over-counts amplitude ŌåÆ norm growth\"\n  => \"  raw 91 C3: discrete approximation insufficient for non-trivial topology\"\n  => \"  raw 91 C3: discrete approximation insufficient for non-trivial topology\"\n  => \"  For exact unitarity on wormhole: need symplectic-style propagator\"\n  => \"  For exact unitarity on wormhole: need symplectic-style propagator\"", source_file: "atlas.n6", source_line: 46720 },
