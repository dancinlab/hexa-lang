    AtlasNode { kind: "C", id: "axis-k-orthogonality-vs-D-through-J", raw: "@C axis-k-orthogonality-vs-D-through-J :: meta [4!]\n  <- atlas-self-arch-axis-k-temporal-provenance-witness\n  -> axis-k-vs-D-intrinsic-type\n  -> axis-k-vs-E-meta-tag\n  -> axis-k-vs-F-arrow-K-ceiling\n  -> axis-k-vs-G-body-field\n  -> axis-k-vs-H-id-convention\n  -> axis-k-vs-I-graph-query\n  -> axis-k-vs-J-supersession\n  => \"PER-AXIS verdict: 5 ORTHOGONAL, 2 SYNERGISTIC, 0 INTERFERENCE вҖ” axis-K is composition-clean across the prior axis stack\"", source_file: "atlas.n6", source_line: 56897 },
    AtlasNode { kind: "C", id: "axis-k-vs-D-intrinsic-type", raw: "@C axis-k-vs-D-intrinsic-type :: meta [4]\n  <- axis-k-orthogonality-vs-D-through-J\n  verdict = ORTHOGONAL\n  rationale = \"axis-D adds @-type letters (proposed @I invariant). axis-K adds body-fields and a meta-tag suffix. Different namespace; no parser conflict; introduced_at applies uniformly across @P/@C/@F/@R/@S/@X/@? AND a future @I.\"", source_file: "atlas.n6", source_line: 56908 },
    AtlasNode { kind: "C", id: "axis-k-vs-E-meta-tag", raw: "@C axis-k-vs-E-meta-tag :: meta [4]\n  <- axis-k-orthogonality-vs-D-through-J\n  verdict = SYNERGISTIC\n  rationale = \"axis-E proposed [10**] depth-2 tier marker; axis-K's [10*GOLDED] is a parallel suffix axis (lifecycle, not tier-depth). The two suffixes COMPOSE at the same grade-position but represent ORTHOGONAL dimensions. Concrete combo example would be [10**GOLDED] meaning 'tier-10-depth-2 row that has calcified'. NO collision because axis-E's ** modifies the asterisk-count (depth) while axis-K's GOLDED is a phase keyword.\"\n  composition_form = \"[N(\\\\*\\\\*?)(DRAFT|ACTIVE|GOLDED|DEPRECATED|RETIRED|RETIRED_INCONCLUSIVE)?]\"\n  axis_e_ceiling_pressure = \"ZERO вҖ” axis-K does not propose new asterisk-count tiers\"", source_file: "atlas.n6", source_line: 56913 },
    AtlasNode { kind: "C", id: "axis-k-vs-F-arrow-K-ceiling", raw: "@C axis-k-vs-F-arrow-K-ceiling :: meta [4!]\n  <- axis-k-orthogonality-vs-D-through-J\n  verdict = ZERO-PRESSURE-ON-K-CEILING\n  rationale = \"axis-F K-ceiling counts arrow tokens at line-leading positions ({<-, ->, =>, ==, ~>, |>, !!, <->, -|}). axis-K introduces ZERO arrow tokens. introduced_at, origin_shard, superseded_at are all body-fields (axis-G family). [10*GOLDED] is a meta-tag suffix (axis-E family). K-ceiling stays at K=10 post-axis-I, K=10+axis-F-proposals.\"\n  k_count_after_axis_k = 10  ; \"unchanged from post-axis-I state\"\n  critical_check = \"axis-K body-fields use '=' as assignment, which IS in the existing token set. No new lexer tokens required.\"", source_file: "atlas.n6", source_line: 56920 },
    AtlasNode { kind: "C", id: "axis-k-vs-G-body-field", raw: "@C axis-k-vs-G-body-field :: meta [4]\n  <- axis-k-orthogonality-vs-D-through-J\n  verdict = SYNERGISTIC (extends axis-G's vocabulary)\n  rationale = \"axis-G reserved a body-field vocabulary (confidence, verified, decay). axis-K adds (introduced_at, origin_shard, superseded_at). All five share the 2-space-indent key = value syntax. axis-G's K_core grew 13 вҶ’ 15 with axis-J; axis-K grows it 15 вҶ’ 18 (introduced_at + origin_shard + superseded_at вҖ” superseded_at is the date-typed promotion of axis-J's date string).\"\n  k_core_after_axis_k = 18\n  k_core_ceiling_estimate = \"20-30 (per axis-F audit) вҖ” axis-K stays comfortably below\"\n  type_extension = \"axis-G previously typed values as freeform strings or enum tokens. axis-K introduces a DATE TYPE (YYYY-MM-DD ISO 8601) вҖ” first typed body-field. This is a MINOR schema extension; parser must validate date format.\"", source_file: "atlas.n6", source_line: 56927 },
    AtlasNode { kind: "C", id: "axis-k-vs-H-id-convention", raw: "@C axis-k-vs-H-id-convention :: meta [4]\n  <- axis-k-orthogonality-vs-D-through-J\n  verdict = SYNERGISTIC (relieves axis-H pressure)\n  rationale = \"axis-H ID-convention currently HOSTS date-fragments inside slugs (n6-atlas-...-verified-2026-03-31-...). 9 such IDs exist. After axis-K adoption, those 9 IDs CAN drop the date fragment in favour of introduced_at body field вҖ” ID slugs become shorter and stable (no need to rename when date convention shifts). However axis-H rule is NOT immediately altered; existing 9 IDs stay (raw 24 atomicity); FUTURE IDs use axis-K instead.\"\n  retroactive_migration_cost = \"0 вҖ” existing IDs are immutable per raw 24 spirit; axis-K applies to NEW rows only\"\n  axis_h_pressure_reduction = \"9 dated IDs no longer need extension; axis-H slug-rule can stabilise\"", source_file: "atlas.n6", source_line: 56935 },
    AtlasNode { kind: "C", id: "axis-k-vs-I-graph-query", raw: "@C axis-k-vs-I-graph-query :: meta [4]\n  <- axis-k-orthogonality-vs-D-through-J\n  verdict = SYNERGISTIC (axis-K provides queryable fields for axis-I to traverse)\n  rationale = \"axis-I introduced ->* / <-* graph-query primitives but has NOTHING to query for temporal/origin metadata today. axis-K's introduced_at + origin_shard turn axis-I's traversal operators into time/provenance queries. Concrete: 'cascade-s10-shard-slug ->* origin_shard' returns all rows born from that shard; '2026-04-15 ->* introduced_at >= 2026-04-15' returns the recent-rows cohort.\"\n  composition_unlocked = \"axis-K is the FIRST axis after axis-J to give axis-I new query targets вҖ” the original axis-I shard noted 'no introspection without query targets'; axis-K provides the targets\"\n  speculative_caveat = \"axis-I is itself PROPOSAL-NOT-ACTUATED вҖ” composition is design-time, not implementation-time\"", source_file: "atlas.n6", source_line: 56942 },
