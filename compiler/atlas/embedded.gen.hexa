    AtlasNode { kind: "C", id: "TECSL-AR-J-PUREFIELD-FORMULA", raw: "@C TECSL-AR-J-PUREFIELD-FORMULA = output = scale * sqrt(|A-G|ВІ) * normalize(A-G) ; tension = |A-G|ВІ unifies 13 prior hypotheses (H313 confidence, H316 overconfidence, H329 margin, H322 EEG, H307 dual, H340 dreaming, H334 PureField, H332 eq-degradation, H331 compensation, H337 Fisher, H314 rejection, H312 forgetting-prevention, H311 local-escape) :: ML/consciousness [10*]\n  => \"Within training: tension вҶ‘ вҹә confidence вҶ‘ (correct=190.4 vs wrong=105.81 on MNIST).\"\n  => \"Out-of-distribution: tension is extreme вҖ” direction reverses depending on training objective (CE: low tension on noise ; MSE: high tension on noise).\"\n  => \"Precognition AUC = 0.925 (rejecting low-T 10% вҶ’ 99.5% accuracy on remaining 90%) ; 82% of errors live in low-T quadrant.\"\n  |> docs/hypotheses/341-tension-final-theory.md\n  |> model_pure_field.py (referenced)", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 320 },
    AtlasNode { kind: "C", id: "TECSL-AR-J-MNIST-MOE", raw: "@C TECSL-AR-J-MNIST-MOE = Meta {1/2, 1/3, 1/6} weights : MNIST 97.75% (vs Top-K 96.79%, +0.96%) ; CIFAR-10 53.52% (vs Top-K 49.09%, +4.43%, 4.6Г— wider gap) ; Anomaly AUROC = 1.00 (95Г— tension ratio between in/out) :: ML [10]\n  => \"Engine cooperation scales with task difficulty; MNIST ts=0.47 vs CIFAR ts=0.04 (self-ref converges on easy, diverges on hard).\"\n  => \"Cross-dataset (14 types): Dense data (image, audio, text-embed, tabular) +1.04% to +6.39% ; Sparse text TF-IDF FAILS at -0.52% вҖ” preserved as honest negative.\"\n  |> README.md В§Validation Results L312-334\n  |> experiments/E_precog_lens_cross_results.json (per-class numbers, MNIST acc 0.9789)", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 327 },
    AtlasNode { kind: "C", id: "TECSL-AR-L-CCT-NECESSARY-NOT-SUFFICIENT", raw: "@C TECSL-AR-L-CCT-NECESSARY-NOT-SUFFICIENT = CCT (5-test consciousness-continuity battery) is NECESSARY-not-sufficient: 23/25 synthetic-EEG match (92%) but 4/5 non-conscious systems (weather, noise, heat-diffusion, feedback-loop) ALSO pass 5/5 :: consciousness-test [10*FAIL_DOC]\n  => \"Honest negative result: CCT cannot DIFFERENTIATE consciousness from generic complex dynamics.\"\n  => \"Independence test reveals only T2 (Loop) and T3 (Continuity) carry independent information ; T1, T4, T5 collapse to rвүҲ1.0 with each other.\"\n  => \"GZ-CCT correlation is SPURIOUS: 18% mappings hit GZ vs 29% random expected, p=0.997 вҖ” design-formula artifact.\"\n  |> docs/findings.md В§1-3 L1-41", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 355 },
    AtlasNode { kind: "C", id: "TECSL-AR-L-ATTRACTOR-INVARIANCE", raw: "@C TECSL-AR-L-ATTRACTOR-INVARIANCE = CCT identical across Lorenz/RГ¶ssler/Chen/Chua attractors ; Rule110 / RBN K=2 / ESN FAIL CCT 5/5 вҶ’ CCT window/bin parameters tuned for continuous systems, NOT discrete :: dynamical-systems [10]\n  => \"D-CCT (discrete-specific) proposed: DT2=Lempel-Ziv, DT3=mutual information, DT4=unique-state ratio.\"\n  => \"Genuine architectural invariance for continuous attractors ; legitimate adaptation needed for discrete.\"\n  |> docs/findings.md В§4-5", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 361 },
    AtlasNode { kind: "C", id: "TECSL-AR-L-DUAL-BRAIN-COUPLING", raw: "@C TECSL-AR-L-DUAL-BRAIN-COUPLING = Оә=0 (split-brain): both sides CCT 5/5 ; Оә=0.5 normal: synchronization 0.4 + bidirectional info-flow ; ОәвҶ’вҲһ: identical, diversity loss ; TE_RвҶ’L > TE_LвҶ’R (rightвҶ’left info-flow stronger) :: consciousness [10]\n  => \"Corpus callosum CONNECTS rather than CREATES consciousness ; each hemisphere is independent engine.\"\n  => \"Asymmetric information flow aligns with right-hemisphere intuition hypothesis (literature).\"\n  |> docs/findings.md В§6-7 L64-89", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 366 },
    AtlasNode { kind: "C", id: "TECSL-AR-L-FIBER-BUNDLE-IDENTITY", raw: "@C TECSL-AR-L-FIBER-BUNDLE-IDENTITY = APrioriLatent: 97.82% with 114K params (8.5Г— fewer than RepulsionFieldQuad) ; holonomy confirmed (same classification 99.2%, different fiber states) ; identity transfer EXPERIMENT: swap/remove/randomize identity changes acc < 0.02% :: ML/geometry [10]\n  => \"Identity is 'decorative' for classification, but matters for generation (dreams differ).\"\n  => \"Interpretation: fiber = experience axis, tension = concept axis.\"\n  |> README.md В§Fiber Bundle Engine L887-900\n  |> model_fiber_bundle.py (referenced)", source_file: "atlas.append.tecsl-archive-2026-04-27.n6", source_line: 371 },
    AtlasNode { kind: "C", id: "TECSL-AR2-DFS-AUTO-565", raw: "@C TECSL-AR2-DFS-AUTO-565 = depth-first cross-island search produced 565 cross-island matches (proof file dfs-auto-results.md, presence verified via ls); NOT enumerated entry-by-entry in this shard :: meta-search [10]\n  => \"565 matches sampled by README index only; full read-out exceeds 250-word reporting budget.\"\n  => \"Caveat: the 565 figure is the file's claim; a Texas Sharpshooter null pass is required before any individual entry should graduate from coincidence to claim.\"\n  => \"Cross-link: yesterday's TECSL-AR-T2-CONGRUENCE-CHAIN (lcm(О“_0(N))=6 only at N=1, 13) is one of these 565 entries.\"\n  |> docs/proofs/dfs-auto-results.md (file present, content not exhaustively read in this batch)", source_file: "atlas.append.tecsl-archive-deep-batch-2-2026-04-27.n6", source_line: 123 },
    AtlasNode { kind: "C", id: "TECSL-AR2-SCAN-GRID-D-INHIB", raw: "@C TECSL-AR2-SCAN-GRID-D-INHIB = grid scan D=20Г—P=20Г—I=20 = 8000 cells, n=50000 samples : 33.7% >2Пғ, 25.4% >3Пғ, 16.7% >5Пғ ; top-10 all at (D=0.95, P=0.95, I=0.05) ridge ; Z_max = 79.10Пғ :: numerical-experiment [10*PROBE_RUN]\n  => \"Same scan re-run at 46Г—46Г—46 = 97336 cells, n=100000: ratios stable (33.5% / 25.1% / 16.0%).\"\n  => \"Honest read: the >5Пғ tail is a deterministic function of the model formula G = sqrt(DВ·P)/(I+Оө), NOT an observed surprise вҖ” a 16% extreme-tail ratio means the Пғ scale itself is mis-calibrated for this construction.\"\n  => \"Recorded as PROBE_RUN, not as discovery: the scan demonstrates the formula has a thick tail, which is itself a known pathology of multiplicative G = DВ·P/I models near IвҶ’0.\"\n  |> results/scan_report.md L1-L100", source_file: "atlas.append.tecsl-archive-deep-batch-2-2026-04-27.n6", source_line: 133 },
