    AtlasNode { kind: "C", id: "axis-l-vs-H-id-convention", raw: "@C axis-l-vs-H-id-convention :: meta [4]\n  <- axis-l-orthogonality-vs-D-through-K\n  introduced_at = 2026-04-28\n  origin_shard = atlas-self-arch-axis-l-axiom-cite-amendment-2026-04-28\n  verdict = SYNERGISTIC (axis-L1 motivates raw-N slug stability)\n  ration... [truncated, full=1121bytes]", source_file: "atlas.n6", source_line: 58657 },
