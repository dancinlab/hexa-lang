    AtlasNode { kind: "C", id: "clay-bt-546-bsd-rank-r-3-component-mechanism", raw: "@C clay-bt-546-bsd-rank-r-3-component-mechanism :: meta [4!]\n  <- iter-4-IMC-rank-transition-base\n  <- iter-5-T2-fanout-agent-aea61323da27ff951\n  => \"rank-r requires 3 components ALL: (a) canonical cycle with r-dim Selmer image; (b) p-adic L with ord-r vanishing; (c) reciprocity law linking (a)-(b)\"\n  => \"r=1 closed: Heegner + Gross-Zagier + BDP\"\n  => \"r>=2 blocked: (a) no Shimura source вҖ” Heegner hypothesis forces sign +1; (b) BDP / Skinner-Urban p-adic L encodes r<=1 by construction; (c) reciprocity for hypothetical higher cycles undefined\"\n  => \"attack axes (all partial/speculative): GGP cycles on higher unitary Shimura, Darmon-Rotger diagonal cycles triple product, plectic Heegner Nekovar-Scholl, motivic Euler systems higher-rank automorphic\"", source_file: "atlas.n6", source_line: 46448 },
