    AtlasNode { kind: "C", id: "axis-l-orthogonality-vs-D-through-K", raw: "@C axis-l-orthogonality-vs-D-through-K :: meta [4!]\n  <- atlas-self-arch-axis-l-axiom-cite-amendment-witness\n  introduced_at = 2026-04-28\n  origin_shard = atlas-self-arch-axis-l-axiom-cite-amendment-2026-04-28\n  -> axis-l-vs-D-intrinsic-type\n  -> axis-l-vs-E-meta-tag\n  -> axis-l-vs-F-arrow-K-ceiling\n  -> axis-l-vs-G-body-field\n  -> axis-l-vs-H-id-convention\n  -> axis-l-vs-I-graph-query\n  -> axis-l-vs-J-supersession\n  -> axis-l-vs-K-temporal-provenance\n  => \"PER-AXIS verdict: 4 ORTHOGONAL, 4 SYNERGISTIC, 0 INTERFERENCE вҖ” axis-L is composition-clean across the prior axis stack\"", source_file: "atlas.n6", source_line: 58606 },
    AtlasNode { kind: "C", id: "axis-l-vs-D-intrinsic-type", raw: "@C axis-l-vs-D-intrinsic-type :: meta [4]\n  <- axis-l-orthogonality-vs-D-through-K\n  introduced_at = 2026-04-28\n  origin_shard = atlas-self-arch-axis-l-axiom-cite-amendment-2026-04-28\n  verdict = ORTHOGONAL\n  rationale = \"axis-D adds @-type letters. axis-L1/L2 add body-fields (cites_raw, amends, amendment_pass, amended_at) and meta-tag suffixes ([10*RAW-Nxx], [10*AMENDED], [10*NARROWED], [10*HONESTY-CORRECTED]). Different namespace; no parser conflict. cites_raw + amends apply uniformly across @P/@C/@F/@R/@S/@X/@?/@L/@D/@E/@M/@T.\"\n  caveat = \"axis-D ceiling estimate 12-15; current count ~13. axis-L does NOT push @-type cardinality. SAFE.\"", source_file: "atlas.n6", source_line: 58620 },
    AtlasNode { kind: "C", id: "axis-l-vs-E-meta-tag", raw: "@C axis-l-vs-E-meta-tag :: meta [4]\n  <- axis-l-orthogonality-vs-D-through-K\n  introduced_at = 2026-04-28\n  origin_shard = atlas-self-arch-axis-l-axiom-cite-amendment-2026-04-28\n  verdict = SYNERGISTIC\n  rationale = \"axis-E hosts the meta-tag family. axis-L1 adds [N*RAW-Nxx] (1-of-45 raw-axiom binding) and axis-L2 adds [N*AMENDED] / [N*NARROWED] / [N*HONESTY-CORRECTED] amendment-kind tags. All compose as suffix at the same grade-position as axis-J's [N*DEPRECATED] / [N*RETIRED] and axis-K's [N*GOLDED]. NO collision because axis-L meta-tags use new keyword tokens (RAW-N{int}, AMENDED, NARROWED, HONESTY-CORRECTED).\"\n  composition_form = \"[N(\\\\*\\\\*?)(DRAFT|ACTIVE|GOLDED|DEPRECATED|RETIRED|RETIRED_INCONCLUSIVE|AMENDED|NARROWED|HONESTY-CORRECTED|RAW-N[0-9]+)?]\"\n  axis_e_ceiling_pressure = \"MILD вҖ” axis-L adds 4 new keyword forms (RAW-N{int} is a parameterised family, not 45 distinct keywords). Total meta-tag keyword count grows ~9 вҶ’ ~13. Still well within axis-E observed ceiling of 39+ patterns.\"", source_file: "atlas.n6", source_line: 58628 },
    AtlasNode { kind: "C", id: "axis-l-vs-F-arrow-K-ceiling", raw: "@C axis-l-vs-F-arrow-K-ceiling :: meta [4!]\n  <- axis-l-orthogonality-vs-D-through-K\n  introduced_at = 2026-04-28\n  origin_shard = atlas-self-arch-axis-l-axiom-cite-amendment-2026-04-28\n  verdict = ZERO-PRESSURE-ON-K-CEILING\n  rationale = \"axis-F K-ceiling counts arrow tokens at line-leading positions ({<-, ->, =>, ==, ~>, |>, !!, <->, -|}). axis-L1 introduces ZERO new arrow tokens (cites_raw is a body-field; the <- raw-91-... arrow form REUSES <- вҖ” already in the K=10 set). axis-L2 introduces ZERO new arrow tokens (amends is a body-field). K-ceiling stays at K=10 post-axis-I.\"\n  k_count_after_axis_l = 10  ; \"unchanged from post-axis-I/J/K state\"\n  critical_check = \"axis-L body-fields use '=' as assignment, which IS in the existing token set. No new lexer tokens required.\"", source_file: "atlas.n6", source_line: 58637 },
