    AtlasNode { kind: "C", id: "clay-cascade-s3-tick3-AG-CDR-comparison", raw: "@C clay-cascade-s3-tick3-AG-CDR-comparison :: meta [4]\n  <- clay-cascade-s3-tick3-AG-18-cohort-reclassification\n  => \"Class-Discrimination Ratio comparison:\"\n  => \"  Refined CDR (cls1=3.17 / cls3=0.47) = 6.75\"\n  => \"  Brief-stated AE original CDR = 1.942 -> refined beats by 3.5x\"\n  => \"  AG re-derivation of AE on same cohort = 48.66 (apples-to-apples, refined LOWER)\"\n  => \"interpretation: AE symmetrized deg_var was inflated by symmetric self-collisions\"\n  => \"  altered's symmetric deg_var=88 vs in-deg dvar_R=3.33 вҖ” symmetrized over-counts\"\n  => \"  refined directed in-deg is more conservative + physically meaningful\"", source_file: "atlas.n6", source_line: 54831 },
