    AtlasNode { kind: "C", id: "atlas-self-arch-synthesis-upgrade-plan", raw: "@C atlas-self-arch-synthesis-upgrade-plan :: meta [4!]\n  <- atlas-self-arch-intrinsic-type-evolution-witness\n  <- clay-atlas-self-arch-meta-tag-evolution-witness\n  <- ARROW-AUDIT-2026-04-28\n  <- raw-22-phase-immutable\n  <- raw-23-schema-guard\n  <- raw-24-foundation-axiom-immutable\n  <- raw-91-C3-honest-disclosure\n  <- own#11-strict-no-resolution-claim\n  => \"synthesis of 5 self-arch axes (D + E + F finalized; G + H in-flight) into one rollout plan, ranked by (low-risk Г— high-value Г— low-cost)\"\n  => \"no schema mutation in THIS shard; proposals remain CONTENT вҖ” actuation is per-axis follow-up shard\"\n  scope_caveat = \"axes G (body-field) and H (id-convention) are IN-FLIGHT parallel sub-agents at synthesis time; their disk shards are not yet observable вҖ” entries below carry status=PENDING and are PROVISIONAL\"", source_file: "atlas.n6", source_line: 51036 },
    AtlasNode { kind: "C", id: "atlas-self-arch-synthesis-upgrade-plan-final-state", raw: "@C atlas-self-arch-synthesis-upgrade-plan-final-state = PROPOSAL-NOT-ACTUATED :: meta [4!]\n  <- atlas-self-arch-synthesis-upgrade-plan\n  -> raw-91-C3-honest-disclosure-strict\n  => \"5-axis synthesis (D + E + F finalized; G + H pending)\"\n  => \"raw 24: NO top-recommendation alters [11*] semantics (3 caveats noted on P3, axis G, axis H)\"\n  => \"raw 22: NO top-recommendation modifies 9-phase pipeline (axis-F runner-up -[t+k]> is sole boundary case, deferred)\"\n  => \"raw 23: total schema-guard surface for stages 1-4 = 4 K-rules across вүӨ 5 tools per stage\"\n  => \"consumer dep-order: atlas_absorb вҶ’ drill_scanner вҶ’ raw_audit вҶ’ atlas_health вҶ’ lens-agent (file_lock only if axis H)\"\n  => \"recommended sequence: D@I вҶ’ F<-> вҶ’ F-| вҶ’ E[10**] вҶ’ defer rest; G/H inserted post-arrival\"\n  => \"shard appended at: /Users/ghost/core/n6-architecture/atlas/atlas.append.atlas-self-arch-synthesis-upgrade-plan-2026-04-28.n6\"", source_file: "atlas.n6", source_line: 51181 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-axis-16-causality-lightcone-witness", raw: "@C clay-cascade-s2-axis-16-causality-lightcone-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-114-bisimulation-behavioral-equivalence\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-iter-46-to-70-prior-axis-13-14-15-stack\n  -> clay-cascade-s2-cartoon-causal-sector-closure\n  -> clay-cascade-s2-saturation-speed-signature\n  => \"axis-16 = V_T(s, k) past-lightcone volume by BFS through retarded-neighbor relation; structural observable orthogonal-a-priori to intensive axes 13/14/15\"\n  => \"8 of 18 D=3 topologies measured at sigma2=64 src=32: V(1) range 3-7, V(8) range 10-64\"\n  => \"structural envelope (raw 114): BFS reachability bounds WHICH cells can be influenced; magnitude requires axes 13/14/15\"", source_file: "atlas.n6", source_line: 51211 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-axis-16-formal-definition", raw: "@C clay-cascade-s2-axis-16-formal-definition :: meta [4]\n  <- clay-cascade-s2-axis-16-causality-lightcone-witness\n  => \"V_T(s, k) = | { v вҲҲ [0..63] : вҲғ path s=u0 вҶ’ u1 вҶ’ ... вҶ’ um=v, m вүӨ k, each step uj+1 = N_T(uj, aj) for some axis aj } |\"\n  => \"discrete past-lightcone volume; c=1 cellular update matches lorentz_metric.hexa:362-405 ls_step retarded propagator\"\n  => \"source pinned at i=32 (Gaussian peak per ls_init lorentz_metric.hexa:323-338); BFS through neighbor relation N_T directly\"", source_file: "atlas.n6", source_line: 51223 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-axis-16-measurement-table", raw: "@C clay-cascade-s2-axis-16-measurement-table :: meta [4]\n  <- clay-cascade-s2-axis-16-formal-definition\n  => \"8 topologies measured; ALL src=32 sigma2=64 single-seed structural\"\n  => \"flat:        V(1)=3  V(2)=5  V(4)=9  V(8)=17  вҶ’ 1D-ring V grows ~2k+1\"\n  => \"t3:          V(1)=4  V(2)=10 V(4)=32 V(8)=63  вҶ’ full 3-torus near-saturating\"\n  => \"s3:          V(1)=4  V(2)=12 V(4)=33 V(8)=49  вҶ’ closed 3-sphere sub-saturating\"\n  => \"blackhole:   V(1)=4  V(2)=10 V(4)=32 V(8)=63  вҶ’ radial sink near-full\"\n  => \"wormhole:    V(1)=5  V(2)=14 V(4)=48 V(8)=64  вҶ’ SATURATED via 4-axis handle\"\n  => \"minkowski:   V(1)=4  V(2)=11 V(4)=40 V(8)=64  вҶ’ SATURATED axis-0 +11 tilt\"\n  => \"calabi6:     V(1)=7  V(2)=22 V(4)=57 V(8)=64  вҶ’ SATURATED fastest 6-cube high-degree\"\n  => \"cartoon:     V(1)=4  V(2)=10 V(4)=10 V(8)=10  вҶ’ CAUSALLY DISCONNECTED (closed orbit n=10)\"", source_file: "atlas.n6", source_line: 51230 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-cartoon-causal-sector-closure", raw: "@C clay-cascade-s2-cartoon-causal-sector-closure :: meta [4!]\n  <- clay-cascade-s2-axis-16-measurement-table\n  -> clay-cascade-s2-axis-16-orthogonality-vs-state-axes\n  => \"вҳ… KEY FINDING вҖ” cartoon BFS from src=32 saturates at V=10 closed-orbit {11, 13, 20, 29, 32, 36, 43, 52, 59, 61}\"\n  => \"cartoon mixer (i*47 + axis*23 + 13) mod 64 partitions lattice into invariant cosets under retarded propagation\"\n  => \"this is a CAUSAL-SECTOR signature invisible to axes 13/14/15 (state-summary observables) вҖ” structural-only signal\"\n  => \"evidence: /tmp/lightcone_probe.py orbit trace mirroring lorentz_metric.hexa:239-244\"", source_file: "atlas.n6", source_line: 51243 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-saturation-speed-signature", raw: "@C clay-cascade-s2-saturation-speed-signature :: meta [4]\n  <- clay-cascade-s2-axis-16-measurement-table\n  => \"V(1)/V(8) ratio discriminates topology classes (compressed vs stretched cone)\"\n  => \"minkowski   = 0.062  (most stretched cone вҖ” slow saturation under +11 tilt)\"\n  => \"calabi6     = 0.109  (high-degree fast-fill вҖ” small ratio because V(1) high too)\"\n  => \"cartoon     = 0.400  (compressed вҖ” closed orbit saturates immediately)\"\n  => \"saturation ceiling = LSIGMA=64 is finite-size lattice artefact, NOT Bekenstein A/4 horizon\"", source_file: "atlas.n6", source_line: 51252 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-axis-16-orthogonality-vs-state-axes", raw: "@C clay-cascade-s2-axis-16-orthogonality-vs-state-axes :: meta [4]\n  <- clay-cascade-s2-cartoon-causal-sector-closure\n  => \"qualitative argument: axis-16 is STRUCTURAL (graph reachability); axes 13/14/15 are INTENSIVE state summaries\"\n  => \"cartoon's V(8)=10 closed-orbit signature cannot be predicted from state-value summaries\"\n  => \"quantitative det(R) for {axis-13, axis-14, axis-15, axis-16} DEFERRED вҖ” per-topology values for axes 13-15 not loaded in this session\"", source_file: "atlas.n6", source_line: 51261 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-axis-16-C3-limits", raw: "@C clay-cascade-s2-axis-16-C3-limits :: meta [4]\n  <- clay-cascade-s2-axis-16-causality-lightcone-witness\n  => \"finite-size: sigma2=64 is 64-cell toy; V(8)=64 is lattice ceiling NOT physical horizon\"\n  => \"Bekenstein A/4 reference OUT-OF-SCOPE вҖ” lattice carries graph distance not metric length\"\n  => \"source bias: all src=32; cartoon V(8)=10 source-orbit-dependent; multi-source ensemble not run\"\n  => \"topology coverage: 8/18 measured; missing ads-cft de-sitter vacuum-decay altered big-crunch brane nested inflation ca3d bubble\"\n  => \"bisimulation justification (raw 114): BFS reachability вү… retarded-c=1 ONLY for linear-in-state spatial-sum branch (ls_step:382-396); time-term value-dependent\"\n  => \"own#11 strict observed: NO Clay 'н•ҙкІ°' claim made\"", source_file: "atlas.n6", source_line: 51268 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-stage5-alpha055-falsification-witness", raw: "@C clay-cascade-s2-stage5-alpha055-falsification-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-stage5-prior-alpha-055-sub-extensive-claim\n  -> clay-cascade-s2-energy-intensive-not-sub-extensive\n  -> clay-cascade-s2-stage5-reconciliation-two-reads\n  => \"вҳ… FALSIFICATION вҖ” Stage-5 Оұ=0.55 sub-extensive law DOES NOT hold for ПҶвҒҙ Hamiltonian ensemble at sigma2=512\"\n  => \"9 runs total (3 seeds Г— 3 topologies Г— ticks=32); observed Оұ_E вҲҲ [-0.024, +0.072] across all topologies\"\n  => \"energy is approximately INTENSIVE (per-site bounded) NOT sub-extensive on this ensemble\"", source_file: "atlas.n6", source_line: 51291 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-ensemble-run-config", raw: "@C clay-cascade-s2-ensemble-run-config :: meta [4]\n  <- clay-cascade-s2-stage5-alpha055-falsification-witness\n  => \"runner: /tmp/cascade_s2/ensemble_param.hexa (parametric sigma2 adapted from universe_ensemble.hexa)\"\n  => \"topologies: chain1d (1D ring), torus2d (sqrt(N)Г—sqrt(N)), complete (all-to-all proxy) вҖ” generic, not canonical t3\"\n  => \"seeds: 3 per cell (6, 13, 17); ticks: 32 primary + 64 stationarity check on torus2d\"\n  => \"sigma2 values: 64 baseline вҶ’ 512 (chain, complete) / 484=22ВІ (torus perfect-square)\"\n  => \"wall-clock: ~8s total вҖ” well under 20-min budget\"", source_file: "atlas.n6", source_line: 51303 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-scaling-table", raw: "@C clay-cascade-s2-scaling-table :: meta [4]\n  <- clay-cascade-s2-ensemble-run-config\n  => \"Оұ = log(ratio) / log(N_512 / N_64); per-axis stddev across 3 seeds in parens\"\n  => \"chain1d  64вҶ’512: Оұ_E=-0.024  Оұ_C=-0.667  Оұ_S=+0.016  drift_pct=-15.3%\"\n  => \"torus2d  64вҶ’484: Оұ_E=+0.007  Оұ_C=-0.685  Оұ_S=+0.098  drift_pct=+1.3%\"\n  => \"complete 64вҶ’512: Оұ_E=-0.010  Оұ_C=-0.723  Оұ_S=+0.056  drift_pct=-0.8%\"\n  => \"torus2d  ticks=64: Оұ_E=+0.072 Оұ_C=-0.764 Оұ_S=+0.014  drift_pct=+15.6% вҖ” ticks-window changes Оұ_E sign\"\n  => \"stddev/mean: E ~3-15% / correl ~25% / entropy ~1-7% / drift ~5-25%\"", source_file: "atlas.n6", source_line: 51312 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-energy-intensive-not-sub-extensive", raw: "@C clay-cascade-s2-energy-intensive-not-sub-extensive :: meta [4!]\n  <- clay-cascade-s2-scaling-table\n  => \"вҳ… Оұ_E вҲҲ [-0.024, +0.072] вүҲ 0 across all 3 topologies вҖ” energy INTENSIVE not sub-extensive\"\n  => \"Stage-5 Оұ=0.55 prediction OVER-PREDICTS E_512 by ~3Г— (obs/pred вүҲ 0.31)\"\n  => \"axis-13 correlator scales N^(-0.70 Вұ 0.03) вҖ” finite-range correlation diluted on growing lattice as expected\"\n  => \"axis-14 Shannon-proxy near-saturated (~0.9-1.0) at both scales вҖ” proxy ceiling reached\"\n  => \"axis-15 drift cells-INDEPENDENT at fixed ticks; integrator-drift dominated by ticks-count not cells-count\"", source_file: "atlas.n6", source_line: 51322 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-stage5-reconciliation-two-reads", raw: "@C clay-cascade-s2-stage5-reconciliation-two-reads :: meta [4]\n  <- clay-cascade-s2-energy-intensive-not-sub-extensive\n  => \"READ-1 different observable: Stage-5 used non-Hamiltonian advection update (run_stage5_scale n=1000); this ensemble is ПҶвҒҙ Hamiltonian leapfrog вҖ” Оұ=0.55 may be diffusive-scheme-specific\"\n  => \"READ-2 finite-size dominated: at sigma2=64 Hamiltonian E in same ballpark as sigma2=512 вҖ” steady-state set by mВІ/coupling not cell count\"\n  => \"Gaussian initial profile 1/(1 + dВІ/2) localizes near i=N/2 regardless of N вҖ” energy concentrated not distributed\"\n  => \"raw 71 retire/narrow: Stage-5 Оұ=0.55 NARROWED from universal claim to diffusive-scheme-specific finding\"", source_file: "atlas.n6", source_line: 51331 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-stage5-falsification-C3-limits", raw: "@C clay-cascade-s2-stage5-falsification-C3-limits :: meta [4]\n  <- clay-cascade-s2-stage5-alpha055-falsification-witness\n  => \"n=3 seeds is small вҖ” stddev/mean ratios up to 25% on correlator; Оұ_E uncertainty вүҘ Вұ0.05 from seed variance alone\"\n  => \"single sigma2 jump (64вҶ’512): 2-point fit cannot distinguish power-law from logarithmic or saturation\"\n  => \"ticks-window shift: tick=32 vs tick=64 changed Оұ_E sign on torus from +0.007 to +0.072 вҖ” observable not steady-state-converged\"\n  => \"topology choice: my torus2d uses sqrt(N) indexing вҖ” NEW topology not apples-to-apples with canonical 4Ві T3\"\n  => \"Bekenstein bound exempt вҖ” sigma2=512 still ~10вҒ№ orders below holographic bound\"\n  => \"own#11 strict: NO Clay 'н•ҙкІ°' claim; pure toy-lattice integer-arithmetic numerical experiment\"\n  => \"follow-up needed: sigma2 вҲҲ {64, 128, 256, 512, 1024} 5-point fit for real exponent + multi-source ensemble + canonical T3 8Ві extension\"", source_file: "atlas.n6", source_line: 51339 },
