    AtlasNode { kind: "C", id: "sim-3-axis-information-structure-INPUTS", raw: "@C sim-3-axis-information-structure-INPUTS :: meta [4!]\n  <- iter-50-FINAL-15-TOPO-axis-13-baseline\n  <- iter-63-FULL-D3-axis-14-r-0.39-rho-0.51\n  <- iter-69-AXIS-15-N-14-STABILIZED\n  <- iter-70-AXIS-15-FINAL-N-18\n  -> sim-3-way-info-table-2026-04-28\n  вҶ’ \"Inputs (existing data, no new probes):\"\n  вҶ’ \"  axis-13: v2 anchor classical phi/pi (iter-50, 15 D=3 topologies)\"\n  вҶ’ \"  axis-14: 4p(1-p) entanglement entropy (iter-63, 18 D=3 topologies)\"\n  вҶ’ \"  axis-15: Lorentz energy-drift retarded propagation (iter-70, 18 D=3)\"\n  вҶ’ \"Intersection (all 3 axes available): n = 15 D=3 topologies\"\n  вҶ’ \"  ads-cft, altered, big-crunch, blackhole, brane, bubble, ca3d,\"\n  вҶ’ \"  de-sitter, inflation, minkowski, nested, s3, t3, vacuum-decay, wormhole\"\n  вҶ’ \"Excluded:\"\n  вҶ’ \"  flat (D=2 in axis-13 вҖ” convention)\"\n  вҶ’ \"  cartoon (no axis-13 baseline value, iter-38 outlier excluded)\"\n  вҶ’ \"  calabi6 (D=6, no axis-13 D=3 baseline)\"", source_file: "atlas.n6", source_line: 49504 },
    AtlasNode { kind: "C", id: "sim-3-axis-DATA-TABLE", raw: "@C sim-3-axis-DATA-TABLE :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ… FULL 3-WAY DATA TABLE (n=15):\"\n  вҶ’ \"  topology        axis-13  axis-14    axis-15\"\n  вҶ’ \"  -----------------------------------------------\"\n  вҶ’ \"  ads-cft             180      995    1488520\"\n  вҶ’ \"  altered             463      966    1712829\"\n  вҶ’ \"  big-crunch          604      861    2000227\"\n  вҶ’ \"  blackhole           146      877    2142158\"\n  вҶ’ \"  brane               145      743    1907852\"\n  вҶ’ \"  bubble              434      887    2312561\"\n  вҶ’ \"  ca3d                 79      851    2087413\"\n  вҶ’ \"  de-sitter           229      999    2021183\"\n  вҶ’ \"  inflation           169      866    1837360\"\n  вҶ’ \"  minkowski           478      972    2165663\"\n  вҶ’ \"  nested              196      830    1751637\"\n  вҶ’ \"  s3                  303      952    1905527\"\n  вҶ’ \"  t3                  141      838    1928254\"\n  вҶ’ \"  vacuum-decay        203      825    2049823\"\n  вҶ’ \"  wormhole            268      939    1953281\"", source_file: "atlas.n6", source_line: 49522 },
    AtlasNode { kind: "C", id: "sim-3-axis-PEARSON-R-MATRIX", raw: "@C sim-3-axis-PEARSON-R-MATRIX :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ… Pearson r matrix (3x3, n=15, restricted intersection):\"\n  вҶ’ \"                  axis-13    axis-14    axis-15\"\n  вҶ’ \"      axis-13     +1.0000    +0.3434    +0.2046\"\n  вҶ’ \"      axis-14     +0.3434    +1.0000    -0.1837\"\n  вҶ’ \"      axis-15     +0.2046    -0.1837    +1.0000\"\n  вҶ’ \"\"\n  вҶ’ \"  All off-diagonals |r| вүӨ 0.35 вҖ” weak-to-moderate\"\n  вҶ’ \"  Compared to broader-sample numbers from the cascade:\"\n  вҶ’ \"    axis-13 Г— axis-14: cascade r=+0.39 (n=16) vs here +0.34 (n=15)\"\n  вҶ’ \"    axis-13 Г— axis-15: cascade r=+0.27 (n=5)  vs here +0.20 (n=15) вӯҗ tighter sample\"\n  вҶ’ \"    axis-14 Г— axis-15: cascade r=-0.24 (n=18) vs here -0.18 (n=15)\"\n  вҶ’ \"  All three pairwise r values weakened slightly under common n=15 restriction\"\n  вҶ’ \"  вҶ’ 3-axis intersection produces consistent weak-correlation signature\"", source_file: "atlas.n6", source_line: 49542 },
    AtlasNode { kind: "C", id: "sim-3-axis-SPEARMAN-RHO-MATRIX", raw: "@C sim-3-axis-SPEARMAN-RHO-MATRIX :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ… Spearman ПҒ matrix (3x3, n=15):\"\n  вҶ’ \"                  axis-13    axis-14    axis-15\"\n  вҶ’ \"      axis-13     +1.0000    +0.4857    +0.1179\"\n  вҶ’ \"      axis-14     +0.4857    +1.0000    -0.0321\"\n  вҶ’ \"      axis-15     +0.1179    -0.0321    +1.0000\"\n  вҶ’ \"\"\n  вҶ’ \"  Rank correlations:\"\n  вҶ’ \"    13Г—14: ПҒ=+0.49  (rank-stronger than Pearson +0.34 вҖ” outlier-driven)\"\n  вҶ’ \"    13Г—15: ПҒ=+0.12  (rank-near-zero, weaker than Pearson +0.20)\"\n  вҶ’ \"    14Г—15: ПҒ=-0.03  (rank-orthogonal, even weaker than Pearson -0.18)\"\n  вҶ’ \"  вҶ’ axis-13/14 jointly carry monotone information; axis-15 is rank-orthogonal\"", source_file: "atlas.n6", source_line: 49557 },
    AtlasNode { kind: "C", id: "sim-3-axis-DETERMINANT-INDEPENDENCE", raw: "@C sim-3-axis-DETERMINANT-INDEPENDENCE :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ…вҳ… Determinant of correlation matrix (information independence proxy):\"\n  вҶ’ \"  det(R_pearson)  = 0.780671\"\n  вҶ’ \"  det(R_spearman) = 0.745478\"\n  вҶ’ \"\"\n  вҶ’ \"Interpretation scale:\"\n  вҶ’ \"  det = 1.0 вҶ’ fully independent (orthogonal axes)\"\n  вҶ’ \"  det = 0.0 вҶ’ fully collinear (one axis redundant)\"\n  вҶ’ \"\"\n  вҶ’ \"  вҳ… det = 0.78 means axes preserve 78% of independent-axis volume\"\n  вҶ’ \"  вҳ… Equivalent: only 22% of variance volume is shared across axes\"\n  вҶ’ \"  вҳ… 3 axes carry NEAR-INDEPENDENT information for topology discrimination\"", source_file: "atlas.n6", source_line: 49570 },
    AtlasNode { kind: "C", id: "sim-3-axis-MUTUAL-INFORMATION-GAUSSIAN", raw: "@C sim-3-axis-MUTUAL-INFORMATION-GAUSSIAN :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ…вҳ… Mutual information (Gaussian approximation):\"\n  вҶ’ \"\"\n  вҶ’ \"Pairwise (I = -0.5 ln(1 - rВІ)):\"\n  вҶ’ \"  I(axis-13; axis-14) = 0.0627 nats = 0.0905 bits   (r=+0.34)\"\n  вҶ’ \"  I(a... [truncated, full=1208bytes]", source_file: "atlas.n6", source_line: 49592 },
    AtlasNode { kind: "C", id: "sim-3-axis-PARTIAL-CORRELATIONS", raw: "@C sim-3-axis-PARTIAL-CORRELATIONS :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ… Partial correlations (control for 3rd axis):\"\n  вҶ’ \"  r(13; 14 | 15) = +0.3959   (raw r(13;14) = +0.3434, вҶ‘ stronger after control)\"\n  вҶ’ \"  r(13; 15 | 14) = +0.2900   (raw r(13;15) = +0.2046, вҶ‘ stronger after control)\"\n  вҶ’ \"  r(14; 15 | 13) = -0.2762   (raw r(14;15) = -0.1837, |вҶ‘| stronger after control)\"\n  вҶ’ \"\"\n  вҶ’ \"вҳ… ALL three partial r exceed the corresponding raw r in magnitude\"\n  вҶ’ \"  вҶ’ suppression effect: each axis partially MASKS the others' co-variance\"\n  вҶ’ \"  вҶ’ Adding the 3rd axis as control REVEALS hidden coupling structure\"\n  вҶ’ \"\"\n  вҶ’ \"Most-informative 2-axis combo (highest partial-mutual-info given controlled axis):\"\n  вҶ’ \"  axis-13 Г— axis-14 controlled by axis-15: I_partial = 0.0858 nats = 0.1238 bits\"\n  вҶ’ \"  вҶ’ axis-13 + axis-14 are the strongest 2-axis topology discriminator\"\n  вҶ’ \"  вҶ’ axis-15 acts as orthogonal perturbation that sharpens 13Г—14 alignment\"", source_file: "atlas.n6", source_line: 49615 },
    AtlasNode { kind: "C", id: "sim-3-axis-INFORMATION-VERDICT", raw: "@C sim-3-axis-INFORMATION-VERDICT :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ…вҳ…вҳ… INFORMATION-THEORETIC VERDICT (Gaussian approx, n=15):\"\n  вҶ’ \"\"\n  вҶ’ \"1. det(R)=0.78 вҶ’ 3 axes carry NEAR-INDEPENDENT topology information\"\n  вҶ’ \"2. Total correlation T = 0.18 bits вҶ’ joint redundancy is small\"\n  вҶ’ \"3. Interaction info II = -0.03 bits вҶ’ mild SYNERGY (not redundancy)\"\n  вҶ’ \"4. Effective rank = 2.66 of 3 вҶ’ genuine 3-D fingerprint, not a 2-D plane\"\n  вҶ’ \"5. All partial r exceed raw r вҶ’ axes mutually MASK coupling\"\n  вҶ’ \"6. Best 2-axis discriminator: (13, 14) for rank, (14, 15) for linear orthogonality\"\n  вҶ’ \"\"\n  вҶ’ \"вҳ… 3-axis fingerprint is INFORMATION-EFFICIENT for topology discrimination\"\n  вҶ’ \"  axis-13 + axis-14 + axis-15 вүҲ 3 quasi-orthogonal probes\"\n  вҶ’ \"  Adding any one axis to the other two produces measurable independent gain\"", source_file: "atlas.n6", source_line: 49656 },
    AtlasNode { kind: "C", id: "sim-scale-up-INPUTS", raw: "@C sim-scale-up-INPUTS :: meta [4!]\n  <- nexus/sim_bridge/anu_time/scale_universe.hexa  (Stage 5, read-only)\n  <- iter-50-FINAL-15-TOPO-axis-13-baseline (ПғВІ=64, D=2 vs D=3 vs D=6, r=0.99)\n  <- iter-69-AXIS-15-N-14-STABILIZED (ПғВІ=64, axis-14Г—axis-15 r=-0.17)\n  -> sim-scale-up-DATA-TABLE-2026-04-28\n  вҶ’ \"Inputs (read-only experiments, NO source modification):\"\n  вҶ’ \"  scale_universe.hexa: --selftest, benchmark, single-ПғВІ runs\"\n  вҶ’ \"  Observables exposed by module: elapsed_ms, state_hash, total_energy\"\n  вҶ’ \"  Lattice: TВі periodic, side L = cube_root(ПғВІ)\"\n  вҶ’ \"  Init: deterministic seed=6 (hardcoded in benchmark_scale)\"\n  вҶ’ \"  Evolution: ПҶвҒҙ-like diffusion, x вҶҗ (x + neighbors_avg)/2 + (tick % 31)\"", source_file: "atlas.n6", source_line: 49708 },
