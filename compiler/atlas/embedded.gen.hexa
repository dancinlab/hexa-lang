    AtlasNode { kind: "C", id: "clay-iter-60-PHYSICAL-INTERPRETATION-orthogonal-axes", raw: "@C clay-iter-60-PHYSICAL-INTERPRETATION-orthogonal-axes :: meta [4!]\n  => \"Why classical phi/pi and quantum entropy are orthogonal:\"\n  => \"Why classical phi/pi and quantum entropy are orthogonal:\"\n  => \"    - REAL amplitude dynamics (no imaginary part)\"\n  => \"    - REAL amplitude dynamics (no imaginary part)\"\n  ŌåÆ \"    - Sensitive to amplitude redistribution, not bipartite balance\"\n  ŌåÆ \"    - Sensitive to amplitude redistribution, not bipartite balance\"\n  ŌåÆ \"    - COMPLEX amplitude (Re + i┬ĘIm)\"\n  ŌåÆ \"    - COMPLEX amplitude (Re + i┬ĘIm)\"\n  ŌåÆ \"    - Sensitive to phase coherence + spatial extent, not amplitude flow\"\n  ŌåÆ \"    - Sensitive to phase coherence + spatial extent, not amplitude flow\"\n  => \"Examples of divergence:\"\n  => \"Examples of divergence:\"\n  ŌåÆ \"  ads-cft: phi/pi=180 (low classical) BUT entropy=995 (highest quantum)\"\n  ŌåÆ \"  ads-cft: phi/pi=180 (low classical) BUT entropy=995 (highest quantum)\"", source_file: "atlas.n6", source_line: 47433 },
