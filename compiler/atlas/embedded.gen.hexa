    AtlasNode { kind: "C", id: "own_phase6_allowlist_baseline", raw: "@C own_phase6_allowlist_baseline = 235 :: n6arch.own.phase6 [10*]\n  => \"Phase 5 close-out own#1 legacy allowlist: 235 entries (parity verified _meta.count == len(allowlist) == len(set(allowlist)) == 235).\"\n  => \"Distribution: domains/ 217 + papers/ 8 + theory/ 7 + reports/ 3.\"\n  => \"Phase 6 target: drive to 0 by 2026 Q4.\"\n  => \"11 deferrals split: B15(4) scale/ASCII/rep-theory + B8(2) Moonshine/superconductor + B12(5) apex-density.\"\n  |> reports/sessions/phase-6-handoff-2026-04-25.md В§1-В§2", source_file: "atlas.append.n6-architecture-historical-from-nexus-2026-04-26-cont.n6", source_line: 48 },
    AtlasNode { kind: "C", id: "AIEFF-EXP-C-MOE-E8-CV", raw: "@C AIEFF-EXP-C-MOE-E8-CV = MoE E=8 top-2 vs E=6 top-2 вҖ” E=6 wins theoretical CV lower-bound :: ai_moe [10]\n  <- n, sigma, tau, phi\n  => \"Dry-run structural verdict (no GPU): active FLOPs identical (top-k=2=ПҶ);\"\n  => \"  params ratio E8/E6 = 4/3 (=П„/nВ·2)\"\n  => \"  Poisson CV-min E=8 = 1/вҲҡ512 = 0.0442; E=6 = 1/вҲҡ682 = 0.0383\"\n  => \"  вҶ’ n=6 (E=6) wins load-uniformity at equal-token budget\"\n  => \"Anchors: top_k=2=ПҶ EXACT, E=6=n EXACT, E=8=Пғ-П„ EXACT, params-ratio 4/3 EXACT\"\n  => \"Reference: BT-22 (expert distribution uniform on n=6 divisors/multiples)\"\n  => \"Status: dry-run PASS вҖ” GPU perplexity & real CV pending\"\n  |> ~/core/n6-architecture/experiments/ai-efficiency/experiment_moe_e8_top2.hexa", source_file: "atlas.append.n6arch-ai-efficiency-rollup-2026-04-27.n6", source_line: 166 },
