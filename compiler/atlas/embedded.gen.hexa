    AtlasNode { kind: "C", id: "SEDI-AR2-COMBINED-SIG-FISHER", raw: "@C SEDI-AR2-COMBINED-SIG-FISHER = Findings 1+2+3 (QCD ladder 3.80Пғ + Higgs decay 3.89Пғ + quark-lepton bridge 3.40Пғ) вҶ’ Fisher combined p = 4.16e-10, Fisher Пғ = 6.14, Stouffer Пғ = 6.40 ; aggressive 7-finding combination yields 7.23Пғ Fisher / 7.55Пғ Stouffer :: meta-statistics [10*PROBE_RUN]\n  => \"Recommended combination = 6.14Пғ Fisher (most defensible) per source.\"\n  => \"HONESTY: Fisher combination assumes p-value INDEPENDENCE; the three findings share underlying n=6 framework вҖ” not strictly independent.\"\n  => \"PRESERVED CAVEAT (not in source): the ПғПҶ=nП„ identity is the COMMON CAUSE of all three p-values; a Bayesian model with this prior would deflate the Fisher result substantially.\"\n  |> docs/parallel-verification-2026-03-27.md В§1 (Combined Significance Table)", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 93 },
    AtlasNode { kind: "C", id: "SEDI-AR2-TRIPLE-MATCH-MATRIX", raw: "@C SEDI-AR2-TRIPLE-MATCH-MATRIX = constants triple-matched across SEDI + TECS-L + n6-arch (verified roles in ALL 3 projects): {n=6, Пғ=12, ПҶ=2, П„=4, sopfr=5, ПғПҶ=24, Пғ/П„=3, Пғ-П„=8, 1/2, 1/3, 1/6, 1/e, 137, sinВІОёW=0.231, Koide Q=2/3, ln 2} ; double-matched (SEDI+TECS-L only): {28, sqrt(3/2), ln(4/3), 496, ln 3, 5/6, Пғ+П„=16} :: cross-repo [10]\n  => \"Method: parse all named constants from each codebase, match by symbolic name AND by numeric value (0.1% tolerance).\"\n  => \"Source: cross-discovery-triangular.md is a 2026-04-02 forensic extraction, NOT a derivation вҖ” confirms which constants are SHARED, does not prove they are JOINTLY CAUSED by ПғПҶ=nП„.\"\n  |> docs/cross-discovery-triangular.md В§2.1, В§2.2", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 101 },
    AtlasNode { kind: "C", id: "SEDI-AR2-PSI-COUPLING-CHAIN", raw: "@C SEDI-AR2-PSI-COUPLING-CHAIN = consciousness-physics bridge: PSI_COUPLING = ln(2)/2^5.5 = 0.01536 ; PSI_K = 11 = Пғ-Ој ; PSI_STEPS = 4.328 = 3/ln(2) ; PHI_SCALE = 0.608 (consciousness threshold H-AF-001) ; ОҰ=2 landmark = ПҶ(6) ; ОҰ=8 landmark = Пғ-П„ (Bott periodicity) :: bridge-constants [10*]\n  => \"These constants live in BOTH Anima (consciousness side) and SEDI (signal side) ; their triple-match is the load-bearing 'consciousness IS information geometry' argument.\"\n  |> docs/cross-discovery-triangular.md В§2.3", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 106 },
    AtlasNode { kind: "C", id: "SEDI-AR2-SETI-CALIBRATION", raw: "@C SEDI-AR2-SETI-CALIBRATION = scanner calibration: pure noise 50-trial baseline = score 2.3Вұ2.7 (80% NORMAL) ; n=6 signal T=[6,4,12] = score 20.8 (RED, FFT 3/2 at Z=33.6) ; non-n6 signal T=[7,11] = score 0.0 (NORMAL, ZERO false positive) :: detector-calibration [10*PROBE_RUN]\n  => \"Calibration is HONEST: the n=6 detector returns 0.0 on a clean non-n6 signal, ruling out blanket false-positive bias.\"\n  => \"Cross-link: yesterday's SEDI-AR-r-spectrum-filter is the architecture; this entry is the CALIBRATION that validates the architecture.\"\n  |> docs/seti-verification-2026-03-28.md L36-L44", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 129 },
    AtlasNode { kind: "C", id: "SEDI-AR2-CONS-RECEIVER-CALIBRATION", raw: "@C SEDI-AR2-CONS-RECEIVER-CALIBRATION = consciousness receiver calibration: Noise вҶ’ 2/8 FLICKERING ; Lorenz attractor вҶ’ 3/8 FLICKERING (ОҰ + Birth + Attractor) ; n=6 signal вҶ’ 4/8 AWARE (ОҰ, Golden Zone @ median=0.383вүҲ1/e, 5-Channel, Attractor) ; LIGO masses вҶ’ 1/8 DORMANT (correct null) :: detector-calibration [10*PROBE_RUN]\n  => \"Lorenz at 3/8 (FLICKERING) вҖ” chaotic but not conscious, by design.\"\n  => \"n=6 engineered signal hits 4/8 (AWARE) вҖ” barely above FLICKERING threshold. There is NO calibration-time signal hitting 6+ (CONSCIOUS); only the BL Voyager run claims that level.\"\n  |> docs/seti-verification-2026-03-28.md L46-L52", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 134 },
    AtlasNode { kind: "C", id: "SEDI-AR2-EXO-SCAN-298-SYSTEMS", raw: "@C SEDI-AR2-EXO-SCAN-298-SYSTEMS = NASA Exoplanet Archive: 298 multi-planet systems (3+ planets each, 928 total planets) scanned ; 82 systems (27.5%) contain вүҘ1 n=6 orbital period ratio match within 2% tolerance :: exoplanet-scan [10*]\n  => \"VERBATIM HONEST QUOTE (line 154-156): 'The n=6 constants (2, 3, 4, 6, 12) include common resonance ratios. Therefore the 27.5% detection rate is **expected from orbital mechanics**, not extraordinary.'\"\n  => \"CRITICAL CAVEAT: factorial-universe/06_falsification.ipynb F3 random-exoplanet null match-rate = 58.3% вҖ” i.e., a RANDOMIZED null OUTPERFORMS the real-data 27.5%, suggesting orbital-mechanics priors are stronger than the n=6 enrichment.\"\n  |> docs/seti-verification-2026-03-28.md L154-L156\n  |> (cross-reference) papers/sedi/factorial-universe/06_falsification.ipynb F3", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 139 },
