    AtlasNode { kind: "C", id: "PIXIE-008-airgenome-6axis-recap", raw: "@C PIXIE-008-airgenome-6axis-recap = airgenome long-topic restates \"6-axis hexagon projection ‚Äî vital signs live on one shape\" with axes (CPU/RAM/Swap/Net/Disk/GPU) ‚Äî this IS the genuine n=6 anchor in the pixie corpus, but it is a RECAP of airgenome, not pixie's own structure :: pixie/worker/src/topics.js L131-L138 [7]\n  => recap-of-anchor (n=6 lives in airgenome, pixie quotes it)\n  => recap-of-anchor (n=6 lives in airgenome, pixie quotes it)", source_file: "atlas.append.pixie-gohive-2026-04-27.n6", source_line: 79 },
    AtlasNode { kind: "C", id: "GOHIVE-002-features-six", raw: "@C GOHIVE-002-features-six = landing-page feature grid contains EXACTLY 6 cards: multi-provider, limit-free, TUI+CLI, self-hosted memory, sandbox, hexa-native ‚Äî 6 IS the perfect number; weak post-hoc reading (likely chosen for CSS 2-col grid aesthetics, not n6 doctrine) but the count IS 6 :: gohive.sh/index.html L162-L187 [N?]\n  => feature-count = 6 (genuine numerical hit, post-hoc semantics)\n  => feature-count = 6 (genuine numerical hit, post-hoc semantics)", source_file: "atlas.append.pixie-gohive-2026-04-27.n6", source_line: 93 },
