    AtlasNode { kind: "C", id: "TECSL-AR2-PERFECT-NUM-DISC-159", raw: "@C TECSL-AR2-PERFECT-NUM-DISC-159 = perfect_number_discovery: 4 perfect numbers, 28 atoms, 10 targets, 4762 attempts, 159 'discovered' ; 30+ rows at 0.0000% Error ; cross-relationships: 115 entries linking P6/P28/P496/P8128 :: enumeration-artifact [ENUMERATION_ARTIFACT]\n  => \"Notable EXACT cross: t(P496)+pf127(P8128) = 137 ; s(P496)/ПҶ(P6) = 496 ; ph(P28)-ПҶ(P6) = 10.\"\n  => \"Caveat: with 4762 attempts targeting 10 outputs, expected hits at 1.0% threshold вүҲ 47 ; observed 159 is 3.4Г— expected вҖ” modest but not the 'breakthrough' framing the file uses.\"\n  => \"The chains involving P6 alone (e.g., Пғ(P6)-Пғ_{-1}(P6) = 10) are CIRCULAR (Пғ(6)=12, Пғ_{-1}(6)=2, 12-2=10 by construction).\"\n  |> results/perfect_number_discovery.md L1-L80", source_file: "atlas.append.tecsl-archive-deep-batch-2-2026-04-27.n6", source_line: 151 },
