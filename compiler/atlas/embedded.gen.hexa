    AtlasNode { kind: "C", id: "ARROW-AUDIT-2026-04-28", raw: "@C ARROW-AUDIT-2026-04-28 = empirical token frequency across atlas.n6 :: meta [10]\n  <- atlas.n6\n  -> ARROW-GAP-ANALYSIS\n  -> INTRINSIC-LIMIT-CONVERGENCE\n  => \"8 distinct relational tokens observed; 2 dominant arrows + 1 dominant classifier carry 95.4% of relational mass\"", source_file: "atlas.n6", source_line: 50363 },
