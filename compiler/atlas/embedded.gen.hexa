    AtlasNode { kind: "C", id: "clay-iter-51-STAGE-1-ENTANGLEMENT-ENTROPY-COMPLETE", raw: "@C clay-iter-51-STAGE-1-ENTANGLEMENT-ENTROPY-COMPLETE :: meta [4!]\n  <- iter-50-FINAL-15-topo-baseline-99.89-percent-iter-36-match\n  -> iter-51-quantum_universe-entropy-observable-added\n  => \"Stage 1 priority components per user prompt:\"\n  => \"  вң“ complex amplitude state (qs_init w/ re/im, lines 30-185)\"\n  => \"  вң“ unitary evolution (qs_step w/ approximate-unitary, line 202)\"\n  => \"  вң“ entanglement entropy observable (NEW вҖ” qs_entanglement_entropy iter-51)\"\n  => \"Stage 1 = 100% feature complete\"", source_file: "atlas.n6", source_line: 46612 },
    AtlasNode { kind: "C", id: "clay-iter-51-NEW-axis-14-quantum-entanglement-entropy", raw: "@C clay-iter-51-NEW-axis-14-quantum-entanglement-entropy :: meta [4!]\n  => \"вҳ…вҳ…вҳ… NEW AXIS-14: quantum entanglement entropy across topologies\"\n  => \"  axis 14 dimension: Stage 1 quantum substrate Г— topology mode\"\n  => \"  measurement vocabulary: H(p) = 4p(1-p) per-mille\"\n  => \"  topology coverage: 5/5 base D=3 topologies\"\n  => \"  baseline range: 917-943 per-mille (3% spread)\"\n  => \"  hypothesis (raw 91 C3 honest): higher topology connectivity вҶ’\"\n  => \"    more uniform amplitude distribution вҶ’ higher entropy\"\n  => \"    s3 (highest connectivity, antipodal coupling) вҶ’ max entropy вң“\"\n  => \"    t3 (lowest connectivity, simple toroidal) вҶ’ min entropy вң“\"\n  => \"  Confirms hypothesis at preliminary 5-topology measurement\"", source_file: "atlas.n6", source_line: 46648 },
    AtlasNode { kind: "C", id: "clay-iter-52-axis-14-ticks-variance-PARTIAL", raw: "@C clay-iter-52-axis-14-ticks-variance-PARTIAL :: meta [4!]\n  <- iter-51-axis-14-quantum-entropy-baseline-ticks-32-seed-6\n  -> iter-52-axis-14-ticks-64-extension\n  => \"Dispatched 5 quantum_universe runs at ticks=64 seed=6\"\n  => \"Outcomes:\"\n  => \"  flat:      ENTROPY=980 norm_drift=3704 (9.3% drift)\"\n  => \"  t3:        incomplete (banner-only)\"\n  => \"  s3:        incomplete (banner-only)\"\n  => \"  blackhole: incomplete (banner-only)\"\n  => \"  wormhole:  ENTROPY=941 norm_drift=26520 (66.8% drift) вҡ \"\n  => \"Pattern matches iter-47 (1/7 success) вҖ” concurrent saturation likely\"", source_file: "atlas.n6", source_line: 46699 },
    AtlasNode { kind: "C", id: "clay-iter-52-WORMHOLE-NORM-DRIFT-DISCOVERY", raw: "@C clay-iter-52-WORMHOLE-NORM-DRIFT-DISCOVERY :: meta [4!]\n  => \"вҳ…вҳ…вҳ… KEY FINDING: wormhole discrete unitary has 67% norm drift\"\n  => \"  flat norm: 39688 вҶ’ 43392 (+9.3% drift, acceptable for approx-unitary)\"\n  => \"  wormhole norm: 39688 вҶ’ 66208 (+66.8% drift, BROKEN unitarity!)\"\n  => \"Cause hypothesis:\"\n  => \"  wormhole _qneighbor_wormhole uses antipodal coupling (i вҶ” N-i)\"\n  => \"  This effectively DOUBLES the neighbor count for boundary cells\"\n  => \"  Discrete SchrГ¶dinger update over-counts amplitude вҶ’ norm growth\"\n  => \"Implications:\"\n  => \"  raw 91 C3: discrete approximation insufficient for non-trivial topology\"\n  => \"  Stage 2 (Lorentz/causality) requires implicit/Crank-Nicolson scheme\"\n  => \"  For exact unitarity on wormhole: need symplectic-style propagator\"\n  => \"  For other topologies: 9% drift acceptable for entropy proxy\"", source_file: "atlas.n6", source_line: 46720 },
    AtlasNode { kind: "C", id: "clay-iter-53-NORM-PROJECTION-IMPLEMENTED", raw: "@C clay-iter-53-NORM-PROJECTION-IMPLEMENTED :: meta [4!]\n  <- iter-52-wormhole-67-percent-norm-drift-discovery\n  -> iter-53-Stage-2-prep-post-step-normalization\n  => \"Patch: quantum_universe.hexa qs_step + qs_init\"\n  => \"Algorithm:\"\n  => \"  1. qs_init captures initial norm into __qs_norm_target\"\n  => \"  2. After each qs_step, qs_normalize_to_target() rescales (re, im)\"\n  => \"  3. Scaling uses 1st-order Newton sqrt: scale = 1 + (ratio-1)/2\"\n  => \"  4. Maintains ОЈ|ПҲ|ВІ вүҲ initial across all topologies\"\n  => \"Effect: wormhole 67% drift eliminated (raw 91 C3 prediction)\"", source_file: "atlas.n6", source_line: 46770 },
    AtlasNode { kind: "C", id: "clay-iter-53-CLI-ARG-SHIFT-DISCOVERY", raw: "@C clay-iter-53-CLI-ARG-SHIFT-DISCOVERY :: meta [4!]\n  => \"Verification blocked: quantum_universe.hexa CLI arg-shift bug\"\n  => \"  Same root cause as iter-44 v2 anchor discovery\"\n  => \"  Probe: hexa run quantum_universe.hexa 64 wormhole\"\n  => \"  Result: 'ERROR unknown topology=64'\"\n  => \"  Cause: hetzner remote run shifts script-path to args[2]\"\n  => \"  Fix: apply iter-45 position-independent parser pattern\"\n  => \"  Deferred to iter-54+ (norm-projection commit standalone)\"\n  => \"Mitigation: iter-52 dispatch happened to land args correctly\"\n  => \"  (different hetzner LB pick window)\"", source_file: "atlas.n6", source_line: 46793 },
    AtlasNode { kind: "C", id: "clay-iter-54-CLI-FIX-+-NORM-PROJECTION-VERIFIED", raw: "@C clay-iter-54-CLI-FIX-+-NORM-PROJECTION-VERIFIED :: meta [4!]\n  <- iter-53-norm-projection-implementation-blocked-by-CLI-arg-shift\n  -> iter-54-mirror-iter-45-CLI-fix-+-verification\n  => \"Patch: quantum_universe.hexa main parser (line 387-426)\"\n  => \"Algorithm (mirror iter-45 v2 anchor pattern):\"\n  => \"  1. Scan _qargs for first arg whose _qtopo_id() returns >= 0\"\n  => \"  2. That is topology arg at idx i\"\n  => \"  3. Read ticks from args[i-1] with int parse fallback\"\n  => \"  4. BBM mode detection: if args[i-1] == 'bbm', re-read ticks from i-2\"\n  => \"  5. Fallback to legacy positional parser if no topology found\"\n  => \"Effect: CLI works on BOTH local hexa AND hetzner remote run\"", source_file: "atlas.n6", source_line: 46849 },
    AtlasNode { kind: "C", id: "clay-iter-54-NORM-PROJECTION-VERIFIED-1000X", raw: "@C clay-iter-54-NORM-PROJECTION-VERIFIED-1000X :: meta [4!]\n  => \"вҳ…вҳ…вҳ…вҳ… Wormhole norm conservation comparison:\"\n  => \"  iter-52 (no projection):  norm 39688 вҶ’ 66208, drift=26520 (66.8%)\"\n  => \"  iter-54 (with projection): norm 39688 вҶ’ 39662, drift=26 (0.07%)\"\n  => \"  IMPROVEMENT: 1000Г— drift reduction\"\n  => \"  Stage 2 prep validated вҖ” Euler + post-step Newton sqrt projection works\"\n  => \"  raw 91 C3 honest: 0.07% drift remaining is from O((dt)ВІ) projection error\"\n  => \"    True Crank-Nicolson would give exactly 0% вҖ” Stage 2 follow-up\"", source_file: "atlas.n6", source_line: 46861 },
    AtlasNode { kind: "C", id: "clay-iter-55-axis-14-multi-seed-3-of-3-SUCCESS", raw: "@C clay-iter-55-axis-14-multi-seed-3-of-3-SUCCESS :: meta [4!]\n  <- iter-54-CLI-fix-+-norm-projection-1000x-verification\n  -> iter-55-multi-seed-batch-with-projection\n  => \"Dispatched 3 quantum_universe runs at ticks=64 seed=13 (norm proj enabled):\"\n  => \"  flat:      drift=19 (0.05%) half_cut=430 ENTROPY=980\"\n  => \"  t3:        drift=18 (0.05%) half_cut=299 ENTROPY=838\"\n  => \"  blackhole: drift=24 (0.06%) half_cut=325 ENTROPY=877\"\n  => \"All 3 norm drifts < 0.1% вҖ” projection robust across topology classes\"\n  => \"Full success rate (vs iter-52 2/5 without projection)\"", source_file: "atlas.n6", source_line: 46936 },
    AtlasNode { kind: "C", id: "clay-iter-55-T3-SEED-VARIANCE-DISCOVERY", raw: "@C clay-iter-55-T3-SEED-VARIANCE-DISCOVERY :: meta [4!]\n  => \"вҳ…вҳ…вҳ… KEY DISCOVERY: t3 entropy shows significant seed-variance\"\n  => \"  flat seed=6 ticks=32: entropy=937\"\n  => \"  flat seed=13 ticks=64: entropy=980 (+43, ticks-effect)\"\n  => \"  flat seed=6 ticks=64: entropy=980 (iter-52 вҖ” same as seed=13!)\"\n  => \"  вҶ’ flat is SEED-STABLE (980 Вұ 0)\"\n  => \"\"\n  => \"  t3 seed=6 ticks=32: entropy=917\"\n  => \"  t3 seed=13 ticks=64: entropy=838 (-79, -8.6%)\"\n  вҶ’ t3 has HIGH seed-variance (917 вҶ’ 838 across seeds)\"\n  => \"\"\n  => \"  blackhole seed=6 ticks=32: entropy=923\"\n  => \"  blackhole seed=13 ticks=64: entropy=877 (-46, -5.0%)\"\n  => \"  вҶ’ blackhole intermediate seed-variance\"\n  => \"\"\n  => \"Seed-variance ranking: t3 (9%) > blackhole (5%) > flat (~0%)\"", source_file: "atlas.n6", source_line: 46946 },
    AtlasNode { kind: "C", id: "clay-iter-56-RETRACTION-seed-CLI-NOT-wired", raw: "@C clay-iter-56-RETRACTION-seed-CLI-NOT-wired :: meta [4!]\n  <- iter-55-claimed-9-percent-t3-seed-variance\n  -> iter-56-direct-source-audit\n  => \"iter-55 'seed-variance discovery' RETRACTED вҖ” major raw 91 C3 finding\"\n  => \"Root cause:\"\n  => \"  qs_init(6) was HARDCODED in main mode (line 438 pre-fix)\"\n  => \"  CLI parser at iter-54 read seed value but never passed to qs_init\"\n  => \"  All iter-55 'seed=13' probes ACTUALLY ran with seed=6\"\n  => \"Evidence:\"\n  => \"  iter-55 wormhole 'seed=13' hash=-7143937677 (IDENTICAL to seed=6 -7143937677)\"\n  => \"  iter-55 results were actually TICKS-variance (32 vs 64 ticks)\"", source_file: "atlas.n6", source_line: 47031 },
    AtlasNode { kind: "C", id: "clay-iter-56-FIX-applied", raw: "@C clay-iter-56-FIX-applied :: meta [4!]\n  => \"Patch: quantum_universe.hexa main parser + qs_init call\"\n  => \"  Added: let mut q_seed: i64 = 6 (default)\"\n  => \"  Added: read seed from args[topo_idx + 1] (post-CLI-parse)\"\n  => \"  Changed: qs_init(6) вҶ’ qs_init(q_seed)\"\n  => \"  Output line: now includes 'seed=N' label\"", source_file: "atlas.n6", source_line: 47043 },
    AtlasNode { kind: "C", id: "clay-iter-57-TRUE-SEED-VARIANCE-MEASURED", raw: "@C clay-iter-57-TRUE-SEED-VARIANCE-MEASURED :: meta [4!]\n  <- iter-56-fixed-qs_init-seed-CLI-wiring\n  -> iter-57-3-of-3-true-seed-17-batch\n  => \"3/3 success at ticks=64 seed=17 with FIXED CLI:\"\n  => \"  flat:      drift=16 (0.04%) entropy=976 hash=1515753281\"\n  => \"  blackhole: drift=1  (0.003%) entropy=876 hash=8129492137\"\n  => \"  wormhole:  drift=16 (0.04%) entropy=935 hash=-1036887267\"\n  => \"All 3 hashes DISTINCT вҖ” seed flow confirmed\"\n  => \"All 3 norm_initial=39926 (seed=17 perturbation), differs from seed=6=39688\"", source_file: "atlas.n6", source_line: 47111 },
    AtlasNode { kind: "C", id: "clay-iter-57-DEFINITIVE-LESS-THAN-1-PERCENT", raw: "@C clay-iter-57-DEFINITIVE-LESS-THAN-1-PERCENT :: meta [4!]\n  => \"вҳ…вҳ…вҳ… TRUE entropy seed-variance across 4 topologies (FIXED CLI):\"\n  => \"  flat:      seed=6 980 vs seed=17 976 = -4 (-0.4%) STABLE\"\n  => \"  t3:        seed=6 838 vs seed=13 833 = -5 (-0.6%) STABLE\"\n  => \"  blackhole: seed=6 877 vs seed=17 876 = -1 (-0.1%) STABLE\"\n  => \"  wormhole:  seed=6 939 vs seed=17 935 = -4 (-0.4%) STABLE\"\n  => \"ALL TOPOLOGIES: TRUE seed-variance < 1%\"\n  => \"Entropy is seed-INVARIANT under norm conservation\"", source_file: "atlas.n6", source_line: 47121 },
    AtlasNode { kind: "C", id: "clay-iter-58-S3-FILLED-AXIS-14-COMPLETE", raw: "@C clay-iter-58-S3-FILLED-AXIS-14-COMPLETE :: meta [4!]\n  <- iter-57-true-seed-variance-less-than-1-percent\n  -> iter-58-s3-baseline-+-axis-14-matrix-completion\n  => \"s3 ticks=64 final measurements (TRUE seed wiring + norm projection):\"\n  => \"  s3 seed=6:  drift=38 (0.10%) entropy=952 hash=-141405520\"\n  => \"  s3 seed=17: drift=35 (0.09%) entropy=951 hash=-4145586736\"\n  => \"s3 seed-variance: 952 vs 951 = -1 (0.1%)\"\n  => \"Confirms iter-57 finding: ALL 5 topologies seed-stable < 1%\"", source_file: "atlas.n6", source_line: 47192 },
    AtlasNode { kind: "C", id: "clay-iter-58-DEFINITIVE-TOPOLOGY-RANKING", raw: "@C clay-iter-58-DEFINITIVE-TOPOLOGY-RANKING :: meta [4!]\n  => \"вҳ…вҳ…вҳ…вҳ…вҳ…вҳ… DEFINITIVE axis-14 topology ranking (ticks=64 seed=6):\"\n  => \"  1. flat:      980 (highest)\"\n  => \"  2. s3:        952\"\n  => \"  3. wormhole:  939\"\n  => \"  4. blackhole: 877\"\n  => \"  5. t3:        838 (lowest)\"\n  => \"\"\n  => \"Mean (n=5): 917.2\"\n  => \"Median: 939 (wormhole)\"\n  => \"Range: 838 (t3) to 980 (flat) = 142 = 15.5% spread\"\n  => \"Stdev: ~57 per-mille\"", source_file: "atlas.n6", source_line: 47201 },
    AtlasNode { kind: "C", id: "clay-iter-59-QUANTUM-EXTENDED-5-NEW-TOPOLOGIES", raw: "@C clay-iter-59-QUANTUM-EXTENDED-5-NEW-TOPOLOGIES :: meta [4!]\n  <- iter-58-axis-14-5x2-matrix-complete-5-base-topologies\n  -> iter-59-port-5-t3-derivative-topologies-from-v2-anchor\n  => \"Code: 5 _qneighbor_* functions ported (vacuum-decay/altered/ca3d/big-crunch/ads-cft)\"\n  => \"  Direct port from v2 anchor _e2neighbor_* (E2_SIGMA=QSIGMA=64)\"\n  => \"  Constants added: QT_VACUUM_DECAY=8, QT_ALTERED=9, QT_CA3D=18,\"\n  => \"                   QT_BIG_CRUNCH=19, QT_ADS_CFT=13\"\n  => \"  _qtopo_id and _qtopo_neighbor extended with 5 new branches\"\n  => \"  Backwards compat preserved (existing 5 topologies unchanged)\"\n  => \"Quantum substrate now: 10/21 topologies (was 5/21)\"", source_file: "atlas.n6", source_line: 47293 },
    AtlasNode { kind: "C", id: "clay-iter-59-ADS-CFT-NEAR-MAX-DISCOVERY", raw: "@C clay-iter-59-ADS-CFT-NEAR-MAX-DISCOVERY :: meta [4!]\n  => \"вҳ…вҳ…вҳ… ads-cft entropy=995 вҖ” closest to MAX=1000 of any topology measured\"\n  => \"Cumulative axis-14 ranking (post-iter-59, ticks=64 seed=6):\"\n  => \"  1. ads-cft:    995 (NEW вҖ” closest to maximum entropy)\"\n  => \"  2. flat:       980\"\n  => \"  3. s3:         952\"\n  => \"  4. wormhole:   939\"\n  => \"  5. blackhole:  877\"\n  => \"  6. t3:         838\"\n  => \"  7. vacuum-decay: 825 (NEW вҖ” lower than t3, surprising)\"\n  => \"Range: 825 (vacuum-decay) to 995 (ads-cft) = 170 = 17% spread\"\n  => \"\"\n  => \"ads-cft physical interpretation:\"\n  => \"  axis 0,1 use t3 (toroidal) but axis 2 uses antipodal coupling (i+32)\"\n  => \"  This holographic AdS/CFT-like structure connects boundary regions\"\n  => \"  Maximal bipartite mixing вҶ’ near-maximum entanglement entropy\"\n  => \"  half_cut=465 (very close to 500 = perfectly balanced bipartition)\"", source_file: "atlas.n6", source_line: 47314 },
    AtlasNode { kind: "C", id: "clay-iter-60-3-of-3-RETRY-SUCCESS", raw: "@C clay-iter-60-3-of-3-RETRY-SUCCESS :: meta [4!]\n  <- iter-59-2-of-5-with-3-incomplete-concurrent-saturation\n  -> iter-60-3-parallel-retry\n  => \"Reduced concurrency 4 вҶ’ 3, all 3 succeeded:\"\n  => \"  altered:    drift=24 (0.06%) entropy=966 hash=492799474\"\n  => \"  ca3d:       drift=43 (0.11%) entropy=851 hash=-4857229480\"\n  => \"  big-crunch: drift=0  (0.00%) entropy=861 hash=-3608573908 вҳ…\"\n  => \"big-crunch achieved PERFECT zero norm drift (radial-attractor symmetry)\"\n  => \"Pattern: hetzner stable at 3-concurrent (consistent with iter-55, iter-58)\"", source_file: "atlas.n6", source_line: 47383 },
    AtlasNode { kind: "C", id: "clay-iter-60-FULL-10-TOPO-AXIS-14-BASELINE", raw: "@C clay-iter-60-FULL-10-TOPO-AXIS-14-BASELINE :: meta [4!]\n  => \"вҳ…вҳ…вҳ…вҳ…вҳ… COMPLETE 10-topology axis-14 baseline (ticks=64 seed=6, projection):\"\n  => \"  Rank  Topology      Entropy\"\n  => \"  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\"\n  => \"  1.    ads-cft       995  (near max)\"\n  => \"  2.    flat          980\"\n  => \"  3.    altered       966  вҶҗ NEW\"\n  => \"  4.    s3            952\"\n  => \"  5.    wormhole      939\"\n  => \"  6.    blackhole     877\"\n  => \"  7.    big-crunch    861  вҶҗ NEW\"\n  => \"  8.    ca3d          851  вҶҗ NEW\"\n  => \"  9.    t3            838\"\n  => \"  10.   vacuum-decay  825\"\n  => \"\"\n  => \"  Mean (n=10): 908.4\"\n  => \"  Median: ~933 (between blackhole 877 and wormhole 939)\"\n  => \"  Range: 825 (vacuum-decay) to 995 (ads-cft) = 170 = 17% spread\"\n  => \"  Stdev: ~63\"", source_file: "atlas.n6", source_line: 47393 },
    AtlasNode { kind: "C", id: "clay-iter-60-CROSS-AXIS-13-14-ORTHOGONALITY", raw: "@C clay-iter-60-CROSS-AXIS-13-14-ORTHOGONALITY :: meta [4!]\n  => \"вҳ…вҳ…вҳ…вҳ…вҳ… CRITICAL FINDING: axis-13 Г— axis-14 Pearson r = 0.2117\"\n  => \"\"\n  => \"9 topologies measured in BOTH axes (excluding flat вҖ” D=2 in axis-13):\"\n  => \"  Topology      v2-anchor-phi/pi   quantum-entropy\"\n  => \"  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\"\n  => \"  ca3d              79                851\"\n  => \"  t3               141                838\"\n  => \"  blackhole        146                877\"\n  => \"  ads-cft          180                995\"\n  => \"  vacuum-decay     203                825\"\n  => \"  wormhole         268                939\"\n  => \"  s3               303                952\"\n  => \"  altered          463                966\"\n  => \"  big-crunch       604                861\"\n  => \"\"\n  => \"  Pearson r = 0.2117 (n=9)\"\n  => \"  вҶ’ WEAK positive correlation\"\n  => \"  вҶ’ axes probe MOSTLY ORTHOGONAL physics\"", source_file: "atlas.n6", source_line: 47413 },
    AtlasNode { kind: "C", id: "clay-iter-60-PHYSICAL-INTERPRETATION-orthogonal-axes", raw: "@C clay-iter-60-PHYSICAL-INTERPRETATION-orthogonal-axes :: meta [4!]\n  => \"Why classical phi/pi and quantum entropy are orthogonal:\"\n  => \"  axis-13 (v2 anchor phi/pi):\"\n  => \"    - REAL amplitude dynamics (no imaginary part)\"\n  => \"    - Classical wave correlator over time evolution\"\n  вҶ’ \"    - Sensitive to amplitude redistribution, not bipartite balance\"\n  => \"  axis-14 (quantum entropy):\"\n  вҶ’ \"    - COMPLEX amplitude (Re + iВ·Im)\"\n  вҶ’ \"    - Bipartite Schmidt-like balance measure\"\n  вҶ’ \"    - Sensitive to phase coherence + spatial extent, not amplitude flow\"\n  вҶ’ \"\"\n  => \"Examples of divergence:\"\n  вҶ’ \"  big-crunch: phi/pi=604 (highest classical) BUT entropy=861 (mid quantum)\"\n  вҶ’ \"  ads-cft: phi/pi=180 (low classical) BUT entropy=995 (highest quantum)\"\n  вҶ’ \"  вҶ’ opposite rankings = orthogonal observables\"", source_file: "atlas.n6", source_line: 47433 },
    AtlasNode { kind: "C", id: "clay-iter-61-FULL-V2-PARITY-+8-TOPOLOGIES", raw: "@C clay-iter-61-FULL-V2-PARITY-+8-TOPOLOGIES :: meta [4!]\n  <- iter-60-axis-13-x-14-r-0.21-orthogonal-discovery\n  -> iter-61-port-remaining-8-topologies\n  => \"Code: 8 _qneighbor_* functions ported (cartoon, nested, calabi6, brane,\"\n  => \"  inflation, de-sitter, minkowski, bubble) вҖ” full v2 anchor parity\"\n  => \"Constants added: QT_CARTOON=10, QT_NESTED=11, QT_CALABI6=12,\"\n  => \"  QT_BRANE=14, QT_INFLATION=15, QT_DE_SITTER=16, QT_MINKOWSKI=17, QT_BUBBLE=20\"\n  => \"Quantum substrate now: 18/21 topologies (was 10/21)\"\n  => \"Missing: t2, s2, klein (D=2 only вҖ” outside D=3 scope)\"", source_file: "atlas.n6", source_line: 47491 },
    AtlasNode { kind: "C", id: "clay-iter-61-DE-SITTER-NEW-MAX-999", raw: "@C clay-iter-61-DE-SITTER-NEW-MAX-999 :: meta [4!]\n  => \"вҳ…вҳ…вҳ…вҳ…вҳ… de-sitter entropy=999 вҖ” NEW MAXIMUM (1 unit from absolute max=1000)\"\n  => \"  ticks=64 seed=6 norm projection enabled\"\n  => \"  drift=33 (0.08%)\"\n  => \"  half_cut=505 (PERFECT bipartition balance, off by only 0.5%)\"\n  => \"  hash=-2237153367\"\n  => \"Why de-sitter near-max:\"\n  вҶ’ \"  _qneighbor_de_sitter: t3 + per-cell amp=(i/8 + 1) shift\"\n  вҶ’ \"  Distance-graded perturbation creates PERFECT bipartite distribution\"\n  вҶ’ \"  Closest-to-max means amplitude split essentially 50/50 across i=32 cut\"\n  вҶ’ \"Cumulative ranking:\"\n  вҶ’ \"  1. de-sitter:    999  (NEW)\"\n  вҶ’ \"  2. ads-cft:      995\"\n  вҶ’ \"  3. flat:         980\"", source_file: "atlas.n6", source_line: 47501 },
    AtlasNode { kind: "C", id: "clay-iter-61-BRANE-NEW-LOW-743", raw: "@C clay-iter-61-BRANE-NEW-LOW-743 :: meta [4!]\n  => \"вҳ…вҳ…вҳ… brane entropy=743 вҖ” NEW LOWEST (was vacuum-decay 825)\"\n  => \"  drift=26 (0.07%) half_cut=247 (very imbalanced bipartition)\"\n  вҶ’ \"Why brane low:\"\n  вҶ’ \"  _qneighbor_brane has axis>=3 fallback вҖ” but our 3D loop only uses axis 0..2\"\n  вҶ’ \"  AND every 8th cell (i % 8 == 3) gets stochastic shift\"\n  вҶ’ \"  Stochastic perturbation creates concentration in one bipartition\"\n  вҶ’ \"  вҶ’ 247 half_cut means 24.7% in left, 75.3% in right (highly imbalanced)\"\n  вҶ’ \"Range: 743 (brane) to 999 (de-sitter) = 256 = 26% spread\"", source_file: "atlas.n6", source_line: 47516 },
    AtlasNode { kind: "C", id: "clay-iter-61-AXIS-13-x-14-r-0.27-STABLE", raw: "@C clay-iter-61-AXIS-13-x-14-r-0.27-STABLE :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ… axis-13 Г— axis-14 cross-correlation update (n=12):\"\n  вҶ’ \"  iter-60 r=0.2117 (n=9)\"\n  вҶ’ \"  iter-61 r=0.2694 (n=12)\"\n  вҶ’ \"  Increase: +0.06 with 3 more topologies\"\n  вҶ’ \"  Both well below strong-correlation threshold (r > 0.7)\"\n  вҶ’ \"  Orthogonality finding STABLE with larger sample\"\n  вҶ’ \"\"\n  вҶ’ \"12 topologies in BOTH axes:\"\n  вҶ’ \"  ca3d 79/851, t3 141/838, brane 145/743, blackhole 146/877,\"\n  вҶ’ \"  inflation 169/866, ads-cft 180/995, vacuum-decay 203/825,\"\n  вҶ’ \"  de-sitter 229/999, wormhole 268/939, s3 303/952,\"\n  вҶ’ \"  altered 463/966, big-crunch 604/861\"", source_file: "atlas.n6", source_line: 47544 },
    AtlasNode { kind: "C", id: "clay-iter-62-3-OF-3-SUCCESS", raw: "@C clay-iter-62-3-OF-3-SUCCESS :: meta [4!]\n  <- iter-61-de-sitter-999-NEW-MAX-+-r-0.27-n-12\n  -> iter-62-cartoon-calabi6-minkowski\n  => \"3/3 success at 3-concurrent (validated optimal):\"\n  => \"  cartoon:    drift=29 (0.07%) entropy=955 hash=6146296859\"\n  => \"  calabi6:    drift=28 (0.07%) entropy=940 hash=7498517673\"\n  вҶ’ \"  minkowski:  drift=22 (0.06%) entropy=972 hash=-549665564\"\n  вҶ’ \"All hashes distinct, all drifts < 0.1%, projection robust\"", source_file: "atlas.n6", source_line: 47597 },
    AtlasNode { kind: "C", id: "clay-iter-62-CARTOON-NOT-A-QUANTUM-OUTLIER", raw: "@C clay-iter-62-CARTOON-NOT-A-QUANTUM-OUTLIER :: meta [4!]\n  вҶ’ \"вҳ…вҳ… Cartoon DUAL-CONFIRMATION of axis orthogonality:\"\n  вҶ’ \"  axis-13 (v2 anchor phi/pi): cartoon = 741 (HIGH-RANK outlier)\"\n  вҶ’ \"  axis-14 (quantum entropy):  cartoon = 955 (MID-RANK, NOT outlier)\"\n  вҶ’ \"Cartoon's iter-38 outlier classification is CLASSICAL only\"\n  вҶ’ \"  Classical T/V=675000 is non-physical hopping artifact\"\n  вҶ’ \"  Quantum dynamics smooth out the discontinuity (entropy stays in normal range)\"\n  вҶ’ \"  вҶ’ Quantum substrate is more robust to topology pathologies\"\n  вҶ’ \"  вҶ’ axis-13 outlier вү  axis-14 outlier (orthogonality confirmed via cartoon)\"", source_file: "atlas.n6", source_line: 47606 },
    AtlasNode { kind: "C", id: "clay-iter-62-AXIS-13-x-14-r-EVOLUTION", raw: "@C clay-iter-62-AXIS-13-x-14-r-EVOLUTION :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ… axis-13 Г— axis-14 cross-correlation evolution:\"\n  вҶ’ \"  iter-60 r=0.2117 (n=9)\"\n  вҶ’ \"  iter-61 r=0.2694 (n=12)\"\n  вҶ’ \"  iter-62 r=0.3910 (n=14)\"\n  вҶ’ \"  Trend: r INCREASES as more topologies added\"\n  вҶ’ \"  But still WEAK-MODERATE (0.39 < 0.5)\"\n  вҶ’ \"\"\n  вҶ’ \"Why r increased:\"\n  вҶ’ \"  Adding cartoon (high classical 741, mid quantum 955)\"\n  вҶ’ \"  Adding minkowski (mid-high classical 478, high quantum 972)\"\n  вҶ’ \"  Both ended up in 'high-x, high-y' quadrant вҶ’ pulled correlation up\"\n  вҶ’ \"Conclusion: axes are MODERATELY correlated (~0.4), not strongly orthogonal\"\n  вҶ’ \"  Combined 2D fingerprint still informative but less so than thought\"", source_file: "atlas.n6", source_line: 47655 },
    AtlasNode { kind: "C", id: "clay-iter-63-FULL-D3-AXIS-14-COMPLETE", raw: "@C clay-iter-63-FULL-D3-AXIS-14-COMPLETE :: meta [4!]\n  <- iter-62-cartoon-minkowski-calabi6-r-0.39-n-14\n  -> iter-63-final-2-quantum-probes\n  => \"Final 2 quantum probes successful (ticks=64 seed=6, projection):\"\n  => \"  nested:  drift=5  (0.013%) entropy=830 hash=7325744978\"\n  => \"  bubble:  drift=48 (0.121%) entropy=887 hash=8836480351\"\n  => \"nested has SECOND-BEST norm conservation (after big-crunch's 0)\"\n  => \"axis-14 quantum substrate: 18 measured / 18 ported / 21 sim\"", source_file: "atlas.n6", source_line: 47702 },
    AtlasNode { kind: "C", id: "clay-iter-63-FINAL-D3-CORRELATION-r-0.39-rho-0.51", raw: "@C clay-iter-63-FINAL-D3-CORRELATION-r-0.39-rho-0.51 :: meta [4!]\n  вҶ’ \"вҳ…вҳ…вҳ…вҳ…вҳ… DEFINITIVE n=16 cross-axis correlation:\"\n  вҶ’ \"  Pearson r = 0.3939 (linear, with cartoon outlier influence)\"\n  вҶ’ \"  Spearman ПҒ = 0.5118 (rank-based, more robust)\"\n  вҶ’ \"\"\n  вҶ’ \"r evolution across 4 sample sizes:\"\n  вҶ’ \"  iter-60 r=0.21 (n=9)\"\n  вҶ’ \"  iter-61 r=0.27 (n=12)\"\n  вҶ’ \"  iter-62 r=0.39 (n=14)\"\n  вҶ’ \"  iter-63 r=0.39 (n=16) вҖ” STABILIZED\"\n  вҶ’ \"\"\n  вҶ’ \"Spearman ПҒ = 0.51 > Pearson r = 0.39 means:\"\n  вҶ’ \"  Rank-ordering is MORE correlated than linear values\"\n  вҶ’ \"  вҶ’ axes track topology ORDER better than topology MAGNITUDE\"\n  вҶ’ \"  вҶ’ outliers (cartoon, brane) drive Pearson down but not Spearman\"", source_file: "atlas.n6", source_line: 47711 },
    AtlasNode { kind: "C", id: "clay-iter-63-NESTED-LOW-EXPLAINS-CONNECTIVITY", raw: "@C clay-iter-63-NESTED-LOW-EXPLAINS-CONNECTIVITY :: meta [4!]\n  вҶ’ \"вҳ…вҳ… nested entropy=830 (16th of 18) вҖ” surprising LOW given complexity\"\n  вҶ’ \"  half_cut=294 (29.4%/70.6% imbalanced)\"\n  вҶ’ \"  drift=5 (0.013%) вҖ” second best after big-crunch's 0\"\n  вҶ’ \"  Why nested low entropy:\"\n  вҶ’ \"    Inner sphere (i<56) coupled to outer ring (i>=56) only at i=0,axis=2\"\n  вҶ’ \"    Bipartite cut at i=32 falls within inner sphere\"\n  вҶ’ \"    Outer ring contribution leaks to upper half through axis=2 only\"\n  вҶ’ \"    вҶ’ asymmetric population, lower 4p(1-p)\"\n  вҶ’ \"  Validates 'connectivity вҶ” entropy' hypothesis: low connectivity вҶ’ low entropy\"", source_file: "atlas.n6", source_line: 47763 },
