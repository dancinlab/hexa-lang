    AtlasNode { kind: "C", id: "axis-i-intrinsic-convergence-point", raw: "@C axis-i-intrinsic-convergence-point :: meta [4]\n  <- atlas-self-arch-axis-i-graph-query-witness\n  <- axis-i-orthogonality-vs-D-through-H\n  => \"axis-I converges at K=10 arrow tokens (axis-F LIMIT)\"\n  => \"after axis-I lands, atlas.n6 has K=10 = {::, =>, <-, ->, ~>, <->, <=>, <-*, ->*, <~>}\"\n  => \"next-axis-J would HIT axis-F's K-ceiling and force arrow-grammar redesign вҖ” explicit @REL registry per axis-F В§ ARROW-CONVERGENCE-NEXT-PHASE\"\n  => \"axis-I is therefore the LAST inline-arrow extension before atlas.n6 must move to a separate @REL registry block\"\n  => \"this is the intrinsic ceiling for graph-shape evolution within atlas.n6's own DSL\"", source_file: "atlas.n6", source_line: 52428 },
