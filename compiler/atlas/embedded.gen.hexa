    AtlasNode { kind: "C", id: "clay-cascade-s2-tick6-damped-osc-C3-limits", raw: "@C clay-cascade-s2-tick6-damped-osc-C3-limits :: meta [4]\n  <- clay-cascade-s2-tick6-damped-oscillator-REFUTED-witness\n  => \"single seed=6 chain1d L=8 only вҖ” no statistical ensemble\"\n  => \"integer arithmetic // truncation introduces grid artifacts that mimic/destroy oscillation patterns\"\n  => \"m^2 in {0.01, 0.05} traces structurally unbounded вҖ” fit form inapplicable, results pinned at fit bounds\"\n  => \"scaling slopes for tau_diff/gamma in those m^2 are artifacts not measurements\"\n  => \"Q's tau=22.8 preserved (descent-only regime); failed fit was global-range hypothesis test\"\n  => \"tools /tmp/cascade_s2_tick6/chain1d_3param_fit.py (Python mirror; scipy 1.17.1 nonlinear least squares)\"\n  => \"own#11 strict; raw 71 hypothesis class progressive narrowing: damped-oscillator -> piecewise-2-regime\"", source_file: "atlas.n6", source_line: 53717 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick6-t3-symplectic-slope-minus-0494-witness", raw: "@C clay-cascade-s2-tick6-t3-symplectic-slope-minus-0494-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s2-tick4-symplectic-t3-stabilized-witness\n  <- clay-cascade-s2-tick4-mass-power-law-slope-minus-0-30\n  -> clay-cascade-s2-tick6-topology-class-OR-integrator-artifact\n  -> clay-cascade-s2-tick6-V-tau-extractor-mismatch\n  => \"вҳ… t3 L=4 KDK Verlet dt=0.05 m^2 in {0.01..0.5}: log(tau) vs log(m^2) slope = -0.4938 R^2=0.9996\"\n  => \"matches continuum free-field oscillator law tau ~ m^(-1) (predicted slope -0.50, |delta|=+0.006 within noise)\"\n  => \"vs chain1d Q (e2_step) slope = -0.30 вҖ” TOPOLOGY-CLASS-DEPENDENT OR e2_step-INTEGRATOR-ARTIFACT\"", source_file: "atlas.n6", source_line: 53736 },
