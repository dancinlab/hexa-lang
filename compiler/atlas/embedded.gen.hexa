    AtlasNode { kind: "C", id: "clay-cascade-s5-tick2-AK-K3-DENIED-ROBUST-witness", raw: "@C clay-cascade-s5-tick2-AK-K3-DENIED-ROBUST-witness :: meta [4!]\n  <- raw-91-C3-honest-disclosure\n  <- raw-70-multi-axis-verify-grid\n  <- raw-71-falsifier-retire-rule\n  <- own#11-strict-no-resolution-claim\n  <- clay-cascade-s5-tick1-AJ-axis-14-K3-REOPENED-witness\n  <- clay-cascade-s2-tick4-axis-14-renyi2-K3-DENIED-witness\n  -> clay-cascade-s5-AK-coupling-sign-flip-IC-conditional\n  -> clay-cascade-s5-AK-K2-STRONG-FINAL-confirmed\n  => \"вҳ… axis-14 K=3 PROMOTION DENIED-ROBUST вҖ” cascade-s2 R verdict CONFIRMED at deeper IC-conditional level\"\n  => \"AJ (tick-1) resolved denial (a) discrimination вҶ’ IC-conditional 10x restored\"\n  => \"AK (tick-2) confirmed denial (b) structural coupling вҶ’ PERSISTS, only sign reverses IC-conditionally\"", source_file: "atlas.n6", source_line: 55241 },
