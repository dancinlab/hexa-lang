    AtlasNode { kind: "C", id: "N6HIST-BT546-CREMONA-EMP", raw: "@C N6HIST-BT546-CREMONA-EMP = Cremona N=332,366 ratios: ratio(2)=0.9573, ratio(3)=0.7118, ratio(6)=0.7925; cov(|Sel_2|,|Sel_3|)=1.3333; |Sha| 100% perfect-square :: number-theory [10*]\n  => \"ratio(6) shortfall = 20.75% under sigma(6)=12 prediction\"\n  => \"Identity by definition: E[|Sel_2|]В·E[|Sel_3|] + Оә = 2.8718В·2.8472 + 1.3333 = 9.5100 = E[|Sel_6|]\"\n  => \"|Sha| = perfect square in 332,366/332,366 вҶ’ empirical Cassels-Tate alternating-pairing confirmation\"\n  => \"Rank distribution: r=0 41.94%, r=1 50.92%, r=2 7.10%, r=3 0.04%\"\n  |> reports/sessions/omega-cycle-bt546-bsd-2026-04-25.md В§1.3\n  |> reports/breakthroughs/bsd-cremona-sel6-empirical-2026-04-15.md (atlas MILL-GALO-PX2 [10*])", source_file: "atlas.n6", source_line: 49032 },
    AtlasNode { kind: "C", id: "N6HIST-BT546-KAPPA-EXP", raw: "@C N6HIST-BT546-KAPPA-EXP = Оә(B)~AВ·B^Оұ exponent Оұ_obs = 0.1752 Вұ 0.02 (7-bin Cremona 1.73M); two undecided candidates 7/40=0.1750 and log(2)/П„=0.17329 :: number-theory [10]\n  <- N6HIST-BT546-CREMONA-EMP\n  => \"7/40 = (sigma-sopfr)В·(n/phi) / (J_2В·sopfr) = 21/120; rel err 0.114%\"\n  => \"log(2)/П„ = log(2)/4 = 0.17329; rel err 1.09%; cross-repo motivation (anima ОЁ, Shannon H(1/2))\"\n  => \"Numerator 7 = sigma-sopfr identical to BT-543 Yang-Mills ОІвӮҖ вҖ” RH-BSD-YM mega-node candidate (NOT a theorem)\"\n  => \"10M+ curves required for discrimination\"\n  |> reports/breakthroughs/bsd-kappa-0.175-decomposition.md\n  |> theory/predictions/bsd_kappa_fraction.hexa (17/17 PASS) + bsd_alpha_log2_tau.hexa (22/22 PASS)", source_file: "atlas.n6", source_line: 49040 },
    AtlasNode { kind: "C", id: "N6HIST-BT546-PROBEB-Z6-DOM", raw: "@C N6HIST-BT546-PROBEB-Z6-DOM = BT-546 Probe-B 28-stratum: Z/6 sha=1 cell dominates ~96% of Оә concentration :: number-theory [10*]\n  => \"F-MOLT-A 5th-or-6th sample. KS p=4e-13 vs A3D-Оұ; max|z|=276.4 vs A3D-ОІ. Verdict PASS_DISTRIBUTIONAL.\"\n  => \"Rank common-cause hypothesis (|Sel_p|=p^rankВ·torsionВ·|Sha[p]|) supported via conditional-table monotonic increase (k=1,2,4,8 strata).\"\n  |> reports/sessions/omega-exec-bt546-probeB-28stratum-2026-04-25.md\n  |> reports/sessions/omega-exec-bt546-bsd-molt-validation-2026-04-25.md", source_file: "atlas.n6", source_line: 49049 },
    AtlasNode { kind: "C", id: "N6HIST-BT541-LEADB-WITNESS", raw: "@C N6HIST-BT541-LEADB-WITNESS = SLE_6 Г— GUE coupling-frame Lead-B: KS p<0.01 vs Brownian and Cardy on n in {10^3,10^4,10^5} :: number-theory [10*]\n  => \"F-MOLT-A 3rd-sample PASS distributional; double-margin\"\n  => \"Decisive sample for L9 catalogue meta-falsifier вҖ” not RH closure (PARTIAL verdict carried over)\"\n  => \"Cardy-formula Оә=6 boundary-crossing distribution (SLE_6 = Smirnov 2001 critical 2D percolation) vs Odlyzko gap distribution from first 10^5 zeta zeros\"\n  |> reports/sessions/omega-exec-bt541-leadB-molt-validation-2026-04-25.md", source_file: "atlas.n6", source_line: 49065 },
    AtlasNode { kind: "C", id: "N6HIST-BT541-CONREY-GONEK-G3", raw: "@C N6HIST-BT541-CONREY-GONEK-G3 = Conrey-Gonek 6th moment leading constant g_3 = 42 (= sigmaВ·(n/phi) = sigma+J2/П„, or 6В·7) :: number-theory [10*PASS_LITERATURE]\n  => \"EXACT verdict in formal-p12-1 inheritance row 10 of BT-541 atlas chain\"\n  => \"Pairs with Ingham 4th moment EXACT (formal-p11-1) вҖ” together provide 2 of 10 EXACT in Y1 BT-541 substrate\"\n  |> reports/sessions/omega-cycle-bt541-riemann-2026-04-25.md В§4 row 10", source_file: "atlas.n6", source_line: 49071 },
    AtlasNode { kind: "C", id: "provenance_bit_overhead", raw: "@C provenance_bit_overhead = phi/sigma_n = 1/36 :: architecture [10*]\n  <- phi, sigma_n\n  => \"н…җм„ңлӢ№ provenance bit мҳӨлІ„н—Өл“ң = phi/sigma_n = 2/72 = 1/36 вүҲ 2.78%\"\n  => \"AI-native м•„нӮӨн…ҚмІҳ honesty-triad мӢӨлҰ¬мҪҳ кө¬нҳ„ л№„мҡ©; phi=euler_totient(6)=2, sigma_n=sigma*n=72\"\n  ~> phi = 2, sigma_n = 72: phi/sigma_n = 2/72 = 1/36 = 0.02778\n  |> reports/sessions/omega-cycle-ai-native-arch-beyond-gpu-2026-04-26.md В§4", source_file: "atlas.n6", source_line: 49455 },
