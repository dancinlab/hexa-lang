    AtlasNode { kind: "C", id: "sim-3-axis-SPEARMAN-RHO-MATRIX", raw: "@C sim-3-axis-SPEARMAN-RHO-MATRIX :: meta [4!]\n  ŌåÆ \"ŌśģŌśģŌśģŌśģ Spearman Žü matrix (3x3, n=15):\"\n  ŌåÆ \"ŌśģŌśģŌśģŌśģ Spearman Žü matrix (3x3, n=15):\"\n  ŌåÆ \"      axis-13     +1.0000    +0.4857    +0.1179\"\n  ŌåÆ \"      axis-13     +1.0000    +0.4857    +0.1179\"\n  ŌåÆ \"      axis-15     +0.1179    -0.0321    +1.0000\"\n  ŌåÆ \"      axis-15     +0.1179    -0.0321    +1.0000\"\n  ŌåÆ \"  Rank correlations:\"\n  ŌåÆ \"  Rank correlations:\"\n  ŌåÆ \"    13├Ś15: Žü=+0.12  (rank-near-zero, weaker than Pearson +0.20)\"\n  ŌåÆ \"    13├Ś15: Žü=+0.12  (rank-near-zero, weaker than Pearson +0.20)\"\n  ŌåÆ \"  ŌåÆ axis-13/14 jointly carry monotone information; axis-15 is rank-orthogonal\"\n  ŌåÆ \"  ŌåÆ axis-13/14 jointly carry monotone information; axis-15 is rank-orthogonal\"", source_file: "atlas.n6", source_line: 49557 },
