    AtlasNode { kind: "C", id: "BIPART-V2-CH1-FULL-SWEEP-ZERO", raw: "@C BIPART-V2-CH1-FULL-SWEEP-ZERO = full-sweep CH1 (body-text grep) PASS = 0 / 28,476 candidate pairs (0.00%) вҖ” NO paper in the corpus describes any technique by name :: meta [10*]\n  => \"126 papers Г— 226 techniques = 28,476 candidate pairs.\"\n  => \"CH1 PASS condition: technique name (or any of 5 variants) appears in paper body text.\"\n  => \"Zero PASS verdict reflects the corpus structure: 126 papers are n=6 ARITHMETIC COORDINATE MAPPING SEED PAPERS that map domain parameters to {Пғ=12, П„=4, ПҶ=2, sopfr=5}; they are not technique-implementation papers.\"\n  => \"Sole exception: string 'lora' appears in nexus6-discovery-engine paper, but that paper is NOT included among lint_progress.jsonl edges.\"\n  => \"OBSTRUCTION_DOCUMENTED: technique-paper bipartite matching has NO domain-level meaning given current paper structure.\"\n  |> /Users/ghost/core/n6-architecture/experiments/paper/bipartite_v2_report.md В§3.1, В§6", source_file: "atlas.append.n6arch-cross-paper-rollup-2026-04-27.n6", source_line: 153 },
    AtlasNode { kind: "C", id: "BIPART-V2-CH2-BT-XREF-6PASS", raw: "@C BIPART-V2-CH2-BT-XREF-6PASS = full-sweep CH2 (BT number cross-reference) PASS = 6 / 3,023 edges (0.20%) вҖ” only mechanism producing a true positive :: meta [10*]\n  => \"6 PASS pairs: {adamw_quintuplet, chinchilla_scaling, dpo_beta} Г— {ai-17-techniques-experimental, ai-techniques-68-integrated} = 3 Г— 2.\"\n  => \"Mechanism: each technique's .hexa file references BT-NN; the same BT-NN is cited in the paper. (BT-54 adamw, BT-26 chinchilla, BT-64 dpo).\"\n  => \"Of 226 techniques, only 9 (4.0%) carry any BT reference: adamw_quintuplet/BT-54, dpo_beta/BT-64+163, chinchilla_scaling/BT-26, inference_scaling/BT-42, lr_schedule_n6/BT-164, complete_llm_n6/BT-56, context_window_ladder/BT-44, vit_patch_n6/BT-66, moe_activation_fraction/BT-67.\"\n  => \"Of 9 BT-carrying techniques, 6 MISS even CH2 (their BT not cited in any paper).\"\n  |> /Users/ghost/core/n6-architecture/experiments/paper/bipartite_v2_report.md В§3.1, В§3.2, В§6", source_file: "atlas.append.n6arch-cross-paper-rollup-2026-04-27.n6", source_line: 161 },
