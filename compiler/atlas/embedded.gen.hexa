    AtlasNode { kind: "C", id: "N6HIST-META-AMEND-3PASS", raw: "@C N6HIST-META-AMEND-3PASS :: meta [10*]\n  introduced_at = 2026-04-25\n  origin_shard = nexus-6-history-omega-cycle-2026-04-25\n  amendment_pass = v1+v2+v3\n  amendment_pass_v1 = \"per-BT honesty\"\n  amendment_pass_v2 = \"confounded-correction\"\n  amendment_pass_v3 = \"d13-cross-cell\"\n  => \"Three-pass amendment loop: v1 + v2 + v3 вҖ” append-only, no retraction (axis-L2 type-level invariant)\"\n\"\"\"\n  current_form_at_line_27418 = \"@M N6HIST-META-AMEND-3PASS row exists with the 3-pass loop described in the row body via prose; passes are visible via grep but not queryable as structured data\"\n  axis_l2_lift = \"amendment_pass_v{N} body fields enumerate each pass with its name + scope; axis-I -> traversal can list 'all rows touched by amendment_pass v2' (queryable cohort)\"\n  family_match = \"axis-G body-field вҖ” keys with numeric suffix (v1/v2/v3) form an enumerated list; same shape as axis-K's form_1/form_2/form_3/form_4 in atlas-metadata-policy shard (lines 36191-36208)\"", source_file: "atlas.n6", source_line: 58571 },
