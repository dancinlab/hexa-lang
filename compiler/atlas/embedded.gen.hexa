    AtlasNode { kind: "C", id: "ARROW-CONVERGENCE-POINT", raw: "@C ARROW-CONVERGENCE-POINT = arrow-extension halts before grammar redesign :: meta [9]\n  <- INTRINSIC-LIMIT-CONVERGENCE\n  <- ARROW-PROPOSAL-TOP-3\n  => \"current K=7. After adopting <-> and -| (top-2 proposals): K=8 вҶ’ ARROW-TYPE-CARDINALITY-SAFE.  After ->[w] (suffix-only, K stays 8): still safe.  Beyond K=8 atlas.n6 hits leading-char crowding; further relations should move from inline-arrow to an explicit @REL registry block, not new ASCII tokens.  This is the intrinsic ceiling.\"", source_file: "atlas.n6", source_line: 50471 },
    AtlasNode { kind: "C", id: "ARROW-EVOLUTION-SELF-CHECK", raw: "@C ARROW-EVOLUTION-SELF-CHECK = honest scope per raw 91 C3 :: meta [10]\n  <- ARROW-AUDIT-2026-04-28\n  <- ARROW-PROPOSAL-TOP-3\n  <- ARROW-CONVERGENCE-POINT\n  => \"SHARD USES ONLY EXISTING TOKENS: <-, ->, ::, =>.  NO new arrows introduced in this file вҖ” only proposed in prose body of @R blocks.  NO foreign category theory cited (no functor/natural/adjoint/monad).  ALL counts grep-verified against atlas.n6 byte content.  Pending atlas.n6 unlock + absorption to enact ARROW-PROPOSAL-BIDIR + ARROW-PROPOSAL-NEGATION.\"", source_file: "atlas.n6", source_line: 50481 },
