    AtlasNode { kind: "C", id: "clay-cascade-s3-tick3-AG-mechanism-formal-refinement", raw: "@C clay-cascade-s3-tick3-AG-mechanism-formal-refinement :: meta [4]\n  <- clay-cascade-s3-tick3-AG-src-conditional-directed-indeg-CONFIRMED-witness\n  => \"for topology with nbr(i, a) and src=32:\"\n  => \"1. R(src) = nodes BFS-reachable from src under DIRECTED edges u -> nbr(u, a)\"\n  => \"2. indeg_R(j) = #{(i, a) : i in R, nbr(i, a) = j} for j in R\"\n  => \"   (NOT out-degree вҖ” out-deg is always D=3 by construction, carries no hub-collapse signal)\"\n  => \"3. dvar_R = Var_{j in R} [indeg_R(j)]\"\n  => \"addresses both AF blind spots: src-position (R restriction) + edge-direction (directed in-deg)\"", source_file: "atlas.n6", source_line: 54792 },
    AtlasNode { kind: "C", id: "clay-cascade-s3-tick3-AG-classification-rule", raw: "@C clay-cascade-s3-tick3-AG-classification-rule :: meta [4]\n  <- clay-cascade-s3-tick3-AG-mechanism-formal-refinement\n  => \"вҳ… TWO-BAND classification rule (refined):\"\n  => \"  |R| <= 10  -> FAST  (BFS-reachable component too small to escape hub orbit)\"\n  => \"  |R| >= 60  -> FULL  (near-full reach, expander-like)\"\n  => \"  10 < |R| < 60 mid-band: dvar_R >= 3 -> FAST else BOUNDED\"\n  => \"primary classifier: |R| (component size); dvar_R disambiguates mid-band only\"\n  => \"this is more conservative than AE original (which used dvar alone)\"", source_file: "atlas.n6", source_line: 54801 },
