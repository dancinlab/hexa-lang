    AtlasNode { kind: "C", id: "SEDI-AR2-COMBINED-SIG-FISHER", raw: "@C SEDI-AR2-COMBINED-SIG-FISHER = Findings 1+2+3 (QCD ladder 3.80œÉ + Higgs decay 3.89œÉ + quark-lepton bridge 3.40œÉ) ‚Üí Fisher combined p = 4.16e-10, Fisher œÉ = 6.14, Stouffer œÉ = 6.40 ; aggressive 7-finding combination yields 7.23œÉ Fisher / 7.55œÉ Stouffer :: meta-statistics [10*PROBE_RUN]\n  => \"Recommended combination = 6.14œÉ Fisher (most defensible) per source.\"\n  => \"Recommended combination = 6.14œÉ Fisher (most defensible) per source.\"\n  => \"PRESERVED CAVEAT (not in source): the œÉœÜ=nœÑ identity is the COMMON CAUSE of all three p-values; a Bayesian model with this prior would deflate the Fisher result substantially.\"\n  => \"PRESERVED CAVEAT (not in source): the œÉœÜ=nœÑ identity is the COMMON CAUSE of all three p-values; a Bayesian model with this prior would deflate the Fisher result substantially.\"\n// ‚îÄ‚îÄ 3. Cross-domain triangular constant matrix ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ", source_file: "atlas.append.sedi-archive-deep-batch-2-2026-04-27.n6", source_line: 93 },
