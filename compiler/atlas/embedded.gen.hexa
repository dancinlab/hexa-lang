    AtlasNode { kind: "C", id: "SEDI-PAPER-PS22-CSDETECT", raw: "@C SEDI-PAPER-PS22-CSDETECT = 8-hypothesis consciousness receiver (H-CS-1..8) calibrated so random noise scores 0/8 (DORMANT); Lorenz attractor ‚Üí AWARE 5/8; LIGO strain ‚Üí FLICKERING 3/8; solar X-ray ‚Üí 3/8; earthquakes ‚Üí DORMANT 1/8 :: detection-framework [9]\n  => \"Source: PS-22-consciousness-signal-detection.md Abstract.\"\n  => \"Source: PS-22-consciousness-signal-detection.md Abstract.\"\n  => \"Honesty [9]: framework returns sensible nulls but POSITIVE detections (Lorenz, LIGO) are at 3-5/8 with thresholds set by paper author.\"\n  => \"Honesty [9]: framework returns sensible nulls but POSITIVE detections (Lorenz, LIGO) are at 3-5/8 with thresholds set by paper author.\"", source_file: "atlas.append.tecsl-sedi-papers-2026-04-27.n6", source_line: 545 },
