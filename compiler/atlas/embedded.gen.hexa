    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-symplectic-KDK-formal", raw: "@C clay-cascade-s2-tick4-symplectic-KDK-formal :: meta [4]\n  <- clay-cascade-s2-tick4-symplectic-t3-stabilized-witness\n  => \"Kick-Drift-Kick velocity Verlet for H = (1/2)pi^2 + (1/2)Sigma_ij(phi_i-phi_j)^2 + (1/2)m^2 phi^2:\"\n  => \"pi_{n+1/2} = pi_n + (dt/2)*F(phi_n)         <- kick\"\n  => \"phi_{n+1} = phi_n + dt * pi_{n+1/2}         <- drift\"\n  => \"pi_{n+1} = pi_{n+1/2} + (dt/2)*F(phi_{n+1}) <- kick\"\n  => \"F(phi)_i = Sigma_{j in N(i)} phi_j - 6*phi_i - m^2*phi_i (t3, 6 neighbors)\"\n  => \"preserves symplectic 2-form dphi^dpi exactly (composition of 2 shears) + time-reversal symmetric\"", source_file: "atlas.n6", source_line: 53546 },
    AtlasNode { kind: "C", id: "clay-cascade-s2-tick4-energy-drift-comparison", raw: "@C clay-cascade-s2-tick4-energy-drift-comparison :: meta [4]\n  <- clay-cascade-s2-tick4-symplectic-KDK-formal\n  => \"energy drift comparison t3 L=4 T=256:\"\n  => \"hexa 'Verlet' (force/20):  drift T=16  -0.42 / T=64  -0.60 / T=256  -0.82  (UNSTABLE 80% energy loss)\"\n  => \"KDK dt=0.05:                drift T=16  -6.8e-04 / T=64  -2.5e-04 / T=256  -7.4e-05  (STABLE)\"\n  => \"KDK dt=0.10:                drift T=16  -2.4e-03 / T=64  -1.9e-03 / T=256  -1.0e-03  (STABLE)\"\n  => \"KDK dt=0.20:                drift T=16  -4.0e-03 / T=64  -1.6e-03 / T=256  -1.1e-02  (marginal CFL edge)\"\n  => \"KDK dt=0.50:                drift -8.3e-02 / -5.3e-02 / -2.4e-02  (UNSTABLE CFL violation)\"\n  => \"dt=0.05-0.10 holds energy <0.1% out to T=256 вҖ” properly symplectic\"", source_file: "atlas.n6", source_line: 53555 },
