// compiler/atlas/calc_dispatch.hexa — single SSOT for the float-recompute
// membership predicates + numerical tolerance shared by the verify ↔ atlas
// calculator surfaces.
//
// PROBLEM this kills (ATLAS R4 · @goal meta-signal ①): the "which fns are
// float-NUMERICAL" decision + the ε tolerance were DUPLICATED across two
// mirrors —
//   tool/verify_cli.hexa : _is_float_fn / _is_zero_arg_float_fn / _VERIFY_EPS
//   tool/atlas_cli.hexa  : _is_float_fn_register / _is_zero_arg_float_fn_register
//                          / _VERIFY_EPS_REGISTER
// A fn added to one mirror but not the other diverges (R3 reverify measured a
// 36-fn membership gap: verify knew 99, atlas-register knew 63). The atlas
// comment literally read "Extend this table whenever verify_cli's float table
// grows" — a manual-sync drift root. Hoisting the predicate + ε to ONE home
// that BOTH CLIs `use` removes the manual-sync step → kills the drift class.
//
// SCOPE: this module owns the PURE, helper-independent surface only — the
// string-membership predicates + the ε constant. The per-fn recompute bodies
// (`_<fn>` in verify_cli) stay in verify_cli, the canonical single calc home
// per @D g20; `hexa atlas register --from-verify` already shells out to
// `hexa verify --expr` for recompute, and atlas's local `_recompute_float_register`
// table is dead code except for `cmd_reverify`. Folding the ~2200-line recompute
// helper layer into this module is the deferred follow-up (see ATLAS.log).
//
// Canonical membership = verify_cli's table (the single calc home). Because
// no atlas numerical F-node references a fn outside the prior 63-set, widening
// atlas-register's predicate to the full set is byte-identical for `hexa atlas
// reverify` counts (verified: numerical_seen=36 match=32 drift=3 unverifiable=1).

// calc_eps — the canonical numerical tolerance (ε = 1e-9). Both
// verify_cli::cmd_expr_float and atlas_cli::cmd_reverify compare |Δ| against
// this; keeping it a single accessor removes the literal-duplication subclass.
pub fn calc_eps() -> float {
    return 0.000000001
}

// calc_is_float_fn — is fn_name a registered float-NUMERICAL form? (cheap
// pre-check so the caller can route float args BEFORE int truncation). The
// canonical table — verify_cli and atlas both consult this one.
pub fn calc_is_float_fn(fn_name: string) -> bool {
    return fn_name == "welch_t_crit" || fn_name == "wilson_hilferty_p"
        || fn_name == "compound_coverage" || fn_name == "cycles_to_target"
        || fn_name == "chsh_tsirelson" || fn_name == "hardy_bound"
        || fn_name == "cdr_perfect_mitigation" || fn_name == "wigner_stabilizer_sn"
        || fn_name == "mabk_quantum_max"
        || fn_name == "pt_doily_quantum_win" || fn_name == "pt_doily_classical_bound"
        || fn_name == "vqe_h2_fci_sto3g"
        || fn_name == "qfi_sql" || fn_name == "qfi_ghz"
        || fn_name == "shadow_pauli_var_bound" || fn_name == "shadow_clifford_var_bound"
        || fn_name == "page_curve_entropy_peak" || fn_name == "qdrift_error_bound"
        || fn_name == "sym_shadow_var_bound"
        || fn_name == "overlap_vqe_h2_shift_ha"
        || fn_name == "rpe_heisenberg_sigma"
        || fn_name == "mirror_bench_hog_asymptote"
        // Bio-physical Phase 1 (demiurge cross-domain V2 unlock):
        || fn_name == "exp_release" || fn_name == "ldl_pct" || fn_name == "beer_lambert"
        // Bio-statistics (LPA cycle 4 V2 unlock · NNT/ARR/HR trial readout):
        || fn_name == "nnt" || fn_name == "arr" || fn_name == "ln_hr_to_hr"
        // Bio-physical Phase 2 (demiurge cross-domain V2 unlock):
        || fn_name == "hill" || fn_name == "cheng_prusoff" || fn_name == "fick1"
        || fn_name == "laplace" || fn_name == "stokes_einstein"
        // Superconductivity (RTSC V2 closed-form push · 2026-05-24):
        || fn_name == "allen_dynes_tc" || fn_name == "mcmillan_tc"
        || fn_name == "bcs_gap_ratio" || fn_name == "lambda_eliashberg"
        || fn_name == "beenet_grid_bins" || fn_name == "migdal_ratio"
        // Stability↔coupling wall (RTSC NOVEL quantifier · 2026-05-25):
        || fn_name == "lambda_anharm_suppress" || fn_name == "stability_coupling_margin"
        // Superconductivity tranche 1 (RTSC #1/#5/#13/#15 · 2026-05-25):
        || fn_name == "allen_dynes_full" || fn_name == "morel_anderson_mustar"
        || fn_name == "coherence_length" || fn_name == "isotope_exponent"
        || fn_name == "gl_parameter_kappa"
        // Superconductivity tranche 2 (RTSC #15 device-side + BCS · 2026-05-25):
        || fn_name == "london_penetration_depth" || fn_name == "thermo_critical_field"
        || fn_name == "condensation_energy" || fn_name == "bcs_gap_zero"
        || fn_name == "pippard_coherence"
        // Antiproton pair-production threshold (ANTIMATTER ⓵생성 · 2026-05-25):
        || fn_name == "pair_threshold_kinetic" || fn_name == "pair_threshold_total"
        // AD/ELENA deceleration-ladder relativistic kinematics (ANTIMATTER ⓶감속 · 2026-05-25):
        || fn_name == "rel_kinetic_from_p" || fn_name == "rel_p_from_kinetic"
        // Cyclotron (synchrotron) cooling time-constant scalings (ANTIMATTER ⓸냉각 · 2026-05-25):
        || fn_name == "cyclotron_cool_bratio" || fn_name == "cyclotron_cool_massspeedup"
        // Ioffe-Pritchard magnetic-minimum trap (ANTIMATTER ⓺가둠 · RTSC magnet inherit · 2026-05-25):
        || fn_name == "ioffe_loop_bz" || fn_name == "ioffe_mirror_bmin"
        || fn_name == "ioffe_mirror_bcoil" || fn_name == "ioffe_mirror_deltab"
        || fn_name == "ioffe_trap_depth_k" || fn_name == "mu_b_over_kb"
        // Three-body recombination scaling (ANTIMATTER ⓹합성 · 2026-05-25):
        || fn_name == "recomb_3body_exponent" || fn_name == "recomb_3body_tratio"
        // (anti)hydrogen 1S-2S two-photon frequency (ANTIMATTER ⓻측정 · 2026-05-25):
        || fn_name == "transition_factor_1s2s" || fn_name == "h1s2s_rydberg"
        // Nuclear α-decay half-life (NUCLEAR.md N7/N11 funnel · 2026-05-25):
        || fn_name == "viola_seaborg_log10_t" || fn_name == "royer_log10_t"
        // Nuclear C1 — SF competition (NUCLEAR.md §4.2 · NOVEL C1 · 2026-05-25):
        || fn_name == "sf_log10_t" || fn_name == "total_halflife_log10"
        || fn_name == "alpha_sf_branching"
        // Nuclear C3/C4 — Round-2 A SF kernels (sim.hexa v0.8.0 · g5 atoms · 2026-05-25):
        || fn_name == "sf_log10_t_hindered" || fn_name == "sf_log10_t_zwp"
        || fn_name == "sf_consensus_mean" || fn_name == "sf_consensus_spread"
        // Nuclear C2 — island-of-stability weight (NUCLEAR.md §6.2 · 2026-05-25):
        || fn_name == "island_weight"
        // Nuclear G1 — (Z,N,A,Q_α) consistency guard (NUCLEAR.md §3.3 · gap-audit):
        || fn_name == "anz_reason"
        // Nuclear G2 — odd-A model-validity + consensus outlier (NUCLEAR.md §6.2 · gap-audit):
        || fn_name == "model_validity_flag" || fn_name == "consensus3_outlier_count"
        // Nuclear N10 — drip-line predicates (NUCLEAR.md §4.5 · dripline.hexa · 2026-05-25):
        || fn_name == "is_neutron_drip" || fn_name == "is_proton_drip"
        || fn_name == "dripline_margin"
        // FUSION F1 — Bosch-Hale ⟨σv⟩(T) reactivity (Nucl. Fusion 32, 611 (1992) · 2026-05-25):
        || fn_name == "sigma_v_dt" || fn_name == "sigma_v_dhe3"
        || fn_name == "sigma_v_ddp" || fn_name == "sigma_v_ddn"
        || fn_name == "sigma_v_dd_total" || fn_name == "sigma_v_dt_e18"
        // FUSION F1 (aneutronic) — p-¹¹B Nevins-Swain framework (Nucl. Fusion 40, 865 (2000) · 2026-05-25):
        || fn_name == "pb11_gamow_factor" || fn_name == "pb11_s_factor"
        || fn_name == "pb11_sigma_shape" || fn_name == "pb11_reactivity_moment"
        || fn_name == "pb11_reactivity_moment_e6"
        // FUSION F2 — Lawson triple product / 0-D Q_plasma (Lawson 1957 · 2026-05-25):
        || fn_name == "triple_product" || fn_name == "q_plasma"
        || fn_name == "ignition_margin"
        // FUSION F-funnel — design-point (a)×(b) composite scoring (FUSION.md §2.1 · 2026-05-25):
        || fn_name == "f_reactivity_coverage" || fn_name == "f_margin_coverage"
        || fn_name == "f_funnel_composite"
        // FUSION F4 — ideal-MHD β-limit / q* / kink (Troyon 1984 · gate (d) · 2026-05-25):
        || fn_name == "beta_max_pct" || fn_name == "beta_n" || fn_name == "q_star"
        // Bio-physical Phase 3 (demiurge cross-domain V2 closure):
        || fn_name == "higuchi" || fn_name == "tafel" || fn_name == "hagen_poiseuille"
        // TTR-ORAL / TTR-LAC bundle (topical PK + laser optics · INBOX T22:35Z):
        || fn_name == "higuchi_flux" || fn_name == "fick_steady_flux"
        || fn_name == "partition_coeff" || fn_name == "permeability_skin"
        || fn_name == "auc_first_order" || fn_name == "clearance"
        || fn_name == "beer_lambert_log10" || fn_name == "fluence"
        || fn_name == "beam_waist" || fn_name == "rayleigh_range"
        || fn_name == "absorption_depth"
        // Penning-trap eigenmotion (ANTIMATTER capture 3-freq closed-form):
        || fn_name == "penning_omega_plus" || fn_name == "penning_omega_minus"
        || fn_name == "penning_invariance"
        // Plasma-wakefield cold-linear scalings (CERN §1.5 tabletop accel · 2026-05-25):
        || fn_name == "wakefield_e0_gv_m" || fn_name == "wakefield_lambda_um"
        // FUSION gate (e) getdp parity oracle — thick finite-solenoid on-axis center B_z (2026-05-25):
        || fn_name == "solenoid_axis_bz"
        // natural log (CLM init-CE floor = ln(vocab) · CLAIMS chat_init_ce_floor · 1-arg):
        || fn_name == "ln"
        // VERIFY-KIT V4 — special-function primitives via native libm (2026-05-26):
        //   gamma(x)=Γ(x)·tgamma · erf(x) · bessel_j0/j1=libm j0/j1. All 1-arg,
        //   irrational => 🟢 SUPPORTED-NUMERICAL via --tol (never exact 🔵).
        || fn_name == "gamma" || fn_name == "erf"
        || fn_name == "bessel_j0" || fn_name == "bessel_j1"
}

// calc_is_zero_arg_float_fn — is fn_name a 0-arg closed-form constant?
// (--expr <fn> <v>, no operands — the operand parser needs to know).
pub fn calc_is_zero_arg_float_fn(fn_name: string) -> bool {
    return fn_name == "chsh_tsirelson"
        || fn_name == "pt_doily_quantum_win"
        || fn_name == "pt_doily_classical_bound"
        || fn_name == "vqe_h2_fci_sto3g"
        || fn_name == "overlap_vqe_h2_shift_ha"
        || fn_name == "mirror_bench_hog_asymptote"
        || fn_name == "bcs_gap_ratio"
        || fn_name == "transition_factor_1s2s"
        || fn_name == "recomb_3body_exponent"
        || fn_name == "mu_b_over_kb"
}
