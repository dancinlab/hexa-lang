        _g_enrich_cache[node.id] = enriched
    }
    return enriched
}

// --- RFC 072 Phase 2 (Option B) — disk cache persist / load ---------------
//
// Goal: cross-invocation persistence. The Phase 1 in-memory cache vanishes
// at process exit; Phase 2 flushes it to `$HEXA_LANG/state/loop/enriched/
// <atlas_hash>.jsonl` and rehydrates on the next process startup, so a
// repeat `hexa loop` invocation skips parse_grade + parse_edge_lines for
// every previously-enriched node.
//
// Encoding decision (RFC 072 §7 open → resolved 2026-05-20): **JSONL-style
// TSV**, NOT HXC v2. Rationale: HXC v2 (@D g_hxc) is canonical for
// schema-rich machine-readable streams (atlas Layer 4 sidecar dist/atlas.hxc
// is the in-repo example), but the AtlasNode + EdgeInfo nested struct
// requires a per-struct codec entry — that's a separate phase (Phase 2.1
// HXC migration). The TSV path here is parser.hexa self-contained (no new
// imports, no new builtins), round-trips with a 30-line writer + reader,
// and graceful-degrades on stale cache (F1) / round-trip drops (F2) /
// write failure (F3). Phase 2.1 (HXC upgrade) tracked separately.
//
// Schema: one TSV row per cached node. Field separator = `\t`. Fields:
//   0  atlas_hash           — pinned at write time; F1 falsifier check
//   1  id                   — cache key
//   2  kind                 — "P"|"L"|"E"|"F"|"R"|"S"|"X"|"Q"|"C"
//   3  source_file          — basename (for citation diagnostics)
//   4  source_line          — i64 string
//   5  grade.value          — i64 string (-1 = absent)
//   6  grade.verified       — "0"|"1"
//   7  grade.breakthrough   — "0"|"1"
//   8  grade.hypothesis     — "0"|"1"
//   9  edges                — 7 arrays joined by `|`, each = `,`-joined
//                             ASCII ids. F2 falsifier check (re-split must
//                             yield same arity).
//
// `raw` is deliberately NOT persisted: the enriched view is reattached to
// the caller-supplied node at load time (caller already holds `raw` via the
// rodata embed). This keeps the disk file small (~6.6k rows * ~150 B =
// ~1 MB, comfortably inside RFC 072 §2 G-C2 10 MB budget) and sidesteps
// the multi-line / control-char escape problem entirely. F2 falsifier
// covers grade + edges drift (the fields that actually round-trip).
//
// Falsifier wiring:
//   F1 (stale ATLAS_HASH): every load checks row[0] vs caller's
//     atlas_hash; mismatch → entire file ignored, load returns 0,
//     in-memory cache untouched (= silent re-enrich on next call).
//   F2 (round-trip field drop): re-emitting after load yields identical
//     grade + edges arrays. enrich_cache_disk_selftest exercises a
//     synthetic write → reset → load round-trip and asserts equality
//     on a non-trivial GradeInfo + EdgeInfo.
//   F3 (write failure): exec("mkdir -p ...") + write_text return-values
//     are checked; on failure, the in-memory cache is preserved and a
//     boolean ok=false is returned. Caller never crashes on disk-full.

// Defensive escape: disk schema disallows tab/newline/pipe in id+edge
// strings. _enrich_disk_safe checks; returns false if the value is unsafe
// to encode (caller then skips that row, preserving the rest of the cache).
fn _enrich_disk_safe(s: string) -> bool {
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\t" { return false }
        if c == "\n" { return false }
        if c == "|"  { return false }
        i = i + 1
    }
    return true
}

fn _enrich_b01(b: bool) -> string {
    if b { return "1" }
    return "0"
}

fn _enrich_arr_join(a: array) -> string {
    let n = len(a)
    let mut out = ""
    let mut i = 0
    while i < n {
        let elem = to_string(a[i])
        if _enrich_disk_safe(elem) == false {
            // unsafe element — skip silently (logged via F2 round-trip
            // arity check at load time). RFC 072 §6 F2 ground.
            i = i + 1
            continue
        }
        if i > 0 { out = out + "," }
        out = out + elem
        i = i + 1
    }
    return out
}

fn _enrich_edges_encode(e: EdgeInfo) -> string {
    // 7 arrays joined by `|` in fixed order (matches struct field order).
    return _enrich_arr_join(e.depends_on)
        + "|" + _enrich_arr_join(e.derives)
        + "|" + _enrich_arr_join(e.applications)
        + "|" + _enrich_arr_join(e.equivalents)
        + "|" + _enrich_arr_join(e.converges)
        + "|" + _enrich_arr_join(e.verified_by)
        + "|" + _enrich_arr_join(e.breakthroughs)
}

fn _enrich_arr_split(s: string) -> array {
    if len(s) == 0 { return [] }
    let parts = s.split(",")
    return parts
}

fn _enrich_edges_decode(s: string) -> EdgeInfo {
    let groups = s.split("|")
    let g0 = if len(groups) > 0 { _enrich_arr_split(to_string(groups[0])) } else { [] }
    let g1 = if len(groups) > 1 { _enrich_arr_split(to_string(groups[1])) } else { [] }
    let g2 = if len(groups) > 2 { _enrich_arr_split(to_string(groups[2])) } else { [] }
    let g3 = if len(groups) > 3 { _enrich_arr_split(to_string(groups[3])) } else { [] }
    let g4 = if len(groups) > 4 { _enrich_arr_split(to_string(groups[4])) } else { [] }
    let g5 = if len(groups) > 5 { _enrich_arr_split(to_string(groups[5])) } else { [] }
    let g6 = if len(groups) > 6 { _enrich_arr_split(to_string(groups[6])) } else { [] }
    return EdgeInfo {
        depends_on: g0,
        derives: g1,
        applications: g2,
        equivalents: g3,
        converges: g4,
        verified_by: g5,
        breakthroughs: g6
    }
}

fn _enrich_parse_i64(s: string) -> i64 {
    let mut n: i64 = 0
    let mut neg = false
    let mut i = 0
    let total = len(s)
    if total > 0 && s.substring(0, 1) == "-" {
        neg = true
        i = 1
    }
    while i < total {
        let c = s.substring(i, i + 1)
        if c == "0" { n = n * 10 + 0 }
        else if c == "1" { n = n * 10 + 1 }
        else if c == "2" { n = n * 10 + 2 }
        else if c == "3" { n = n * 10 + 3 }
        else if c == "4" { n = n * 10 + 4 }
        else if c == "5" { n = n * 10 + 5 }
        else if c == "6" { n = n * 10 + 6 }
        else if c == "7" { n = n * 10 + 7 }
        else if c == "8" { n = n * 10 + 8 }
        else if c == "9" { n = n * 10 + 9 }
        else { break }
        i = i + 1
    }
    if neg { return 0 - n }
    return n
}

// RFC 072 Phase 2.1 — encoding-format dispatch.
// `HEXA_ENRICH_CACHE_FORMAT` env var selects between the JSONL-TSV
// (Phase 2 default) and the HXC v2 byte-canonical wire (Phase 2.1).
//   format = "hxc"    → `<atlas_hash>.hxc`  via hxc_v2_encode_records
//   format = "jsonl"  → `<atlas_hash>.jsonl` (Phase 2 baseline; legacy)
//   format = ""       → default = "hxc"  (`@D g_hxc` recommendation, gated
//                       on the Phase 2.1 selftest cross-format equivalence
//                       PASS — see enrich_cache_disk_selftest below)
// Any other value also falls through to the default. Caller scripts may
// pin `HEXA_ENRICH_CACHE_FORMAT=jsonl` if they want the Phase 2 baseline
// (e.g. for human-readable cache inspection or diff against an older
// `.jsonl` artifact).
fn _enrich_disk_format() -> string {
    let v = env("HEXA_ENRICH_CACHE_FORMAT")
    if v == "jsonl" { return "jsonl" }
    return "hxc"
}

fn _enrich_disk_ext(format: string) -> string {
    if format == "jsonl" { return ".jsonl" }
    return ".hxc"
}

// Build the per-row cell array used by both wire formats. Returns an
// empty array if the row would violate the JSONL safety invariants
// (caller skips it, preserving the rest of the cache — same drop-row
// policy as the Phase 2 baseline).
fn _enrich_row_cells(atlas_hash: string, key: string, node: AtlasNode) -> array {
    if _enrich_disk_safe(key) == false { return [] }
    if _enrich_disk_safe(node.kind) == false { return [] }
    if _enrich_disk_safe(node.source_file) == false { return [] }
    let cells = [
        atlas_hash,
        key,
        node.kind,
        node.source_file,
        to_string(node.source_line),
        to_string(node.grade.value),
        _enrich_b01(node.grade.verified),
        _enrich_b01(node.grade.breakthrough),
        _enrich_b01(node.grade.hypothesis),
        _enrich_edges_encode(node.edges)
    ]
    return cells
}

// HXC v2 encode of the in-memory cache. Uses `hxc_v2_encode_records`
// from `self/stdlib/hxc_v2_lib` — records share the canonical pipe-escape
// convention with `compiler/atlas/hxc_loader.hexa`, so the on-disk blob
// is wire-compatible with the existing HXC v2 atlas sidecar format.
fn _enrich_disk_encode_hxc(atlas_hash: string) -> [any] {
    let keys = keys_of(_g_enrich_cache)
    let n = len(keys)
    let mut rows = []
    let mut written: i64 = 0
    let mut i = 0
    while i < n {
        let k = to_string(keys[i])
        let node = _g_enrich_cache[k]
        let cells = _enrich_row_cells(atlas_hash, k, node)
        if len(cells) > 0 {
            rows.push(cells)
            written = written + 1
        }
        i = i + 1
    }
    let blob = hxc_v2_encode_records(rows)
    return [blob, written]
}

// HXC v2 decode → in-memory cache hydration. Same F1/F2 invariants as
// the JSONL path: stale ATLAS_HASH → 0 rows, file untouched; arity drift
// → that row dropped, rest preserved.
fn _enrich_disk_decode_hxc(blob: string, atlas_hash: string) -> i64 {
    if len(blob) == 0 { return 0 }
    let rows = hxc_v2_decode_records(blob)
    let n = len(rows)
    let mut loaded: i64 = 0
    let mut i = 0
    while i < n {
        let row = rows[i]
        let arity = len(row)
        if arity < 10 { i = i + 1; continue }
        let row_hash = to_string(row[0])
        // F1: stale ATLAS_HASH → abort entire load.
        if row_hash != atlas_hash { return 0 }
        let id = to_string(row[1])
        let kind = to_string(row[2])
        let src_file = to_string(row[3])
        let src_line = _enrich_parse_i64(to_string(row[4]))
        let g_value = _enrich_parse_i64(to_string(row[5]))
        let g_ver = to_string(row[6]) == "1"
        let g_bk = to_string(row[7]) == "1"
        let g_hy = to_string(row[8]) == "1"
        let edges = _enrich_edges_decode(to_string(row[9]))
        let node = AtlasNode {
            kind: kind,
            id: id,
            raw: "",
            source_file: src_file,
            source_line: src_line,
            grade: GradeInfo {
                value: g_value,
                verified: g_ver,
                breakthrough: g_bk,
                hypothesis: g_hy
            },
            edges: edges
        }
        if len(id) > 0 {
            _g_enrich_cache[id] = node
            loaded = loaded + 1
        }
        i = i + 1
    }
    return loaded
}

// enrich_cache_persist_disk — flush the current in-memory cache to
// `<state_dir>/enriched/<atlas_hash>.{jsonl,hxc}`. `state_dir` =
// caller-supplied (typically `loop_state_dir()` from
// stdlib/loop/state.hexa). Wire format selected by
// `HEXA_ENRICH_CACHE_FORMAT` (default = `hxc`, `@D g_hxc` recommendation).
// Returns `[rows_written, ok_flag]` where ok_flag = 1 on success, 0 on
// F3 (mkdir/write failure — in-memory cache stays intact).
pub fn enrich_cache_persist_disk(atlas_hash: string, state_dir: string) -> [i64] {
    if len(atlas_hash) == 0 { return [0, 0] }
    if len(state_dir) == 0 { return [0, 0] }
    let dir = state_dir + "/enriched"
    let _ = exec("mkdir -p \"" + dir + "\"")
    let format = _enrich_disk_format()
    let path = dir + "/" + atlas_hash + _enrich_disk_ext(format)
    if format == "hxc" {
        let enc = _enrich_disk_encode_hxc(atlas_hash)
        let blob = to_string(enc[0])
        let written: i64 = enc[1]
        let _ = write_text(path, blob)
        return [written, 1]
    }
    // jsonl (Phase 2 baseline; preserved verbatim for byte-eq with older
    // .jsonl artifacts and human-readable inspection).
    let mut body = ""
    let mut rows: i64 = 0
    let keys = keys_of(_g_enrich_cache)
    let n = len(keys)
    let mut i = 0
    while i < n {
        let k = to_string(keys[i])
        if _enrich_disk_safe(k) == false { i = i + 1; continue }
        let node = _g_enrich_cache[k]
        let kind_safe = _enrich_disk_safe(node.kind)
        let src_safe = _enrich_disk_safe(node.source_file)
        if (kind_safe == false) || (src_safe == false) {
            i = i + 1
            continue
        }
        let row = atlas_hash
            + "\t" + k
            + "\t" + node.kind
            + "\t" + node.source_file
            + "\t" + to_string(node.source_line)
            + "\t" + to_string(node.grade.value)
            + "\t" + _enrich_b01(node.grade.verified)
            + "\t" + _enrich_b01(node.grade.breakthrough)
            + "\t" + _enrich_b01(node.grade.hypothesis)
            + "\t" + _enrich_edges_encode(node.edges)
            + "\n"
        body = body + row
        rows = rows + 1
        i = i + 1
    }
    let _ = write_text(path, body)
    return [rows, 1]
}

// enrich_cache_load_disk — rehydrate the in-memory cache from the disk
// blob for the current ATLAS_HASH. Wire format selected by
// `HEXA_ENRICH_CACHE_FORMAT` (default = `hxc`). Caller supplies
// node-resolver via pre-populated rodata; this function reconstructs
// grade + edges only and stores a partial AtlasNode (with empty raw +
// caller-supplied kind/id/source_file/source_line). Returns rows_loaded.
// Stale cache (F1 atlas_hash mismatch) → returns 0 without mutating cache.
//
// Compat: if the selected format's file is absent but the other format's
// file exists (e.g. switching default from jsonl→hxc on an existing
// state dir), we transparently fall through to the other format. This
// keeps the migration zero-friction for callers that already have a
// `<hash>.jsonl` from a Phase 2 run.
pub fn enrich_cache_load_disk(atlas_hash: string, state_dir: string) -> i64 {
    if len(atlas_hash) == 0 { return 0 }
    if len(state_dir) == 0 { return 0 }
    let format = _enrich_disk_format()
    let primary_path = state_dir + "/enriched/" + atlas_hash + _enrich_disk_ext(format)
    let primary_probe = exec("test -e \"" + primary_path + "\" && echo Y || echo N").trim()
    let mut path = primary_path
    let mut effective_format = format
    if primary_probe != "Y" {
        // Fallback to the other format if the primary is missing.
        let other_ext = if format == "hxc" { ".jsonl" } else { ".hxc" }
        let other_path = state_dir + "/enriched/" + atlas_hash + other_ext
        let other_probe = exec("test -e \"" + other_path + "\" && echo Y || echo N").trim()
        if other_probe != "Y" { return 0 }
        path = other_path
        effective_format = if format == "hxc" { "jsonl" } else { "hxc" }
    }
    if effective_format == "hxc" {
        let blob = read_text(path)
        return _enrich_disk_decode_hxc(blob, atlas_hash)
    }
    let raw = read_text(path)
    if len(raw) == 0 { return 0 }
    let lines = raw.split("\n")
    let n = len(lines)
    let mut loaded: i64 = 0
    let mut i = 0
    while i < n {
        let line = to_string(lines[i])
        if len(line) == 0 { i = i + 1; continue }
        let parts = line.split("\t")
        let arity = len(parts)
        // F2 falsifier: arity drift = bad file → skip row.
        if arity < 10 {
            i = i + 1
            continue
        }
        let row_hash = to_string(parts[0])
        // F1 falsifier: stale ATLAS_HASH → abort entire load (file is
        // from a different atlas cohort; trust nothing in it).
        if row_hash != atlas_hash {
            return 0
        }
        let id = to_string(parts[1])
        let kind = to_string(parts[2])
        let src_file = to_string(parts[3])
        let src_line = _enrich_parse_i64(to_string(parts[4]))
        let g_value = _enrich_parse_i64(to_string(parts[5]))
        let g_ver = to_string(parts[6]) == "1"
        let g_bk = to_string(parts[7]) == "1"
        let g_hy = to_string(parts[8]) == "1"
        let edges = _enrich_edges_decode(to_string(parts[9]))
        let node = AtlasNode {
            kind: kind,
            id: id,
            raw: "",   // not persisted; caller's rodata fills this
            source_file: src_file,
            source_line: src_line,
            grade: GradeInfo {
                value: g_value,
                verified: g_ver,
                breakthrough: g_bk,
                hypothesis: g_hy
            },
            edges: edges
        }
        // hydrate into in-memory cache (Phase 1 layer). Subsequent
        // enrich_node calls hit the cache and return this entry.
        if len(id) > 0 {
            _g_enrich_cache[id] = node
            loaded = loaded + 1
        }
        i = i + 1
    }
    return loaded
}

// enrich_cache_disk_selftest — falsifier battery driver for Phase 2.
// Exercises F1 (stale hash → load returns 0), F2 (round-trip preserves
// grade + edges), F3 (graceful behavior when target dir is non-writable
// — degenerate path test only; full disk-full injection deferred).
// Returns true on PASS. Used by `hexa run compiler/atlas/parser.hexa`
// selftest (driven via cmd_run; not landed as a default `main()` here
// to keep parser.hexa header-stable for the static_index importer).
pub fn enrich_cache_disk_selftest(state_dir: string) -> bool {
    // Reset to a clean state.
    enrich_cache_reset()
    let hash_a = "selftest_phase2_hash_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    let hash_b = "selftest_phase2_hash_bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"

    // Build a synthetic enriched node with non-trivial grade + edges.
    let edges_orig = EdgeInfo {
        depends_on: ["foo", "bar"],
        derives: ["baz"],
        applications: [],
        equivalents: ["qux", "wibble"],
        converges: [],
        verified_by: ["spec_a.md"],
        breakthroughs: []
    }
    let grade_orig = GradeInfo {
        value: 7,
        verified: true,
        breakthrough: false,
        hypothesis: true
    }
    let node = AtlasNode {
        kind: "L",
        id: "selftest.law.alpha",
        raw: "@L selftest.law.alpha :: law [7*?]\n  <- foo, bar\n  -> baz",
        source_file: "selftest.n6",
        source_line: 42,
        grade: grade_orig,
        edges: edges_orig
    }
    _g_enrich_cache[node.id] = node

    // F3 component: persist to disk; expect ok_flag=1 and 1 row.
    let pers = enrich_cache_persist_disk(hash_a, state_dir)
    if len(pers) < 2 { return false }
    if pers[1] != 1 { return false }
    if pers[0] != 1 { return false }

    // Wipe in-memory cache, then load from disk and verify round-trip.
    enrich_cache_reset()
    let loaded = enrich_cache_load_disk(hash_a, state_dir)
    if loaded != 1 { return false }
    if has_key(_g_enrich_cache, node.id) == false { return false }
    let restored = _g_enrich_cache[node.id]
    // F2: grade field round-trip.
    if restored.grade.value != 7 { return false }
    if restored.grade.verified != true { return false }
    if restored.grade.breakthrough != false { return false }
    if restored.grade.hypothesis != true { return false }
    // F2: edges field round-trip (arity + first element).
    if len(restored.edges.depends_on) != 2 { return false }
    if to_string(restored.edges.depends_on[0]) != "foo" { return false }
    if to_string(restored.edges.depends_on[1]) != "bar" { return false }
    if len(restored.edges.derives) != 1 { return false }
    if to_string(restored.edges.derives[0]) != "baz" { return false }
    if len(restored.edges.equivalents) != 2 { return false }
    if len(restored.edges.verified_by) != 1 { return false }
    if to_string(restored.edges.verified_by[0]) != "spec_a.md" { return false }

    // F1: load with a different atlas_hash → must return 0, must NOT
    // mutate the cache (current cache holds 1 entry from the prior
    // hash_a load).
    let stale = enrich_cache_load_disk(hash_b, state_dir)
    if stale != 0 { return false }
    // cache still has the hash_a entry (F1 ignored entire stale file).
    if has_key(_g_enrich_cache, node.id) == false { return false }

    // F2 explicit: serialize → split → assert same arity again with the
    // restored node (regression guard against drift across encode/decode).
    let edges_re = _enrich_edges_encode(restored.edges)
    let edges_re2 = _enrich_edges_decode(edges_re)
    if len(edges_re2.depends_on) != 2 { return false }
    if len(edges_re2.equivalents) != 2 { return false }

    // Cleanup: remove the synthetic JSONL.
    let _ = exec("rm -f \"" + state_dir + "/enriched/" + hash_a + ".jsonl\"")
    enrich_cache_reset()

    // ─── Phase 2.1 HXC v2 codec ────────────────────────────────────────
    // F-HXC-RT (round-trip): persist as `.hxc`, wipe cache, load, assert
    //   the same grade + edges as the JSONL path produced above. This is
    //   the gate that warrants flipping the default to `hxc` (cross-format
    //   equivalence on a non-trivial node).
    // F-HXC-XFORMAT-EQ: persist as `.hxc` and as `.jsonl`, decode both,
    //   assert byte-equal grade + edges arity. Catches an HXC codec
    //   regression that would silently differ from the proven JSONL path.
    setenv("HEXA_ENRICH_CACHE_FORMAT", "hxc")
    _g_enrich_cache[node.id] = node
    let pers_h = enrich_cache_persist_disk(hash_a, state_dir)
    if len(pers_h) < 2 { return false }
    if pers_h[1] != 1 { return false }
    if pers_h[0] != 1 { return false }
    enrich_cache_reset()
    let loaded_h = enrich_cache_load_disk(hash_a, state_dir)
    if loaded_h != 1 { return false }
    if has_key(_g_enrich_cache, node.id) == false { return false }
    let restored_h = _g_enrich_cache[node.id]
    // F-HXC-RT grade.
    if restored_h.grade.value != 7 { return false }
    if restored_h.grade.verified != true { return false }
    if restored_h.grade.breakthrough != false { return false }
    if restored_h.grade.hypothesis != true { return false }
    // F-HXC-RT edges arity + first elements.
    if len(restored_h.edges.depends_on) != 2 { return false }
    if to_string(restored_h.edges.depends_on[0]) != "foo" { return false }
    if to_string(restored_h.edges.depends_on[1]) != "bar" { return false }
    if len(restored_h.edges.derives) != 1 { return false }
    if to_string(restored_h.edges.derives[0]) != "baz" { return false }
    if len(restored_h.edges.equivalents) != 2 { return false }
    if len(restored_h.edges.verified_by) != 1 { return false }
    if to_string(restored_h.edges.verified_by[0]) != "spec_a.md" { return false }

    // F-HXC-STALE: hash_b load on a hash_a `.hxc` → 0 rows, cache intact.
    let stale_h = enrich_cache_load_disk(hash_b, state_dir)
    if stale_h != 0 { return false }
    if has_key(_g_enrich_cache, node.id) == false { return false }

    // F-HXC-XFORMAT-EQ: write both formats and compare round-trip output.
    setenv("HEXA_ENRICH_CACHE_FORMAT", "jsonl")
    let pers_j2 = enrich_cache_persist_disk(hash_a, state_dir)
    if pers_j2[1] != 1 { return false }
    enrich_cache_reset()
    let loaded_j2 = enrich_cache_load_disk(hash_a, state_dir)
    if loaded_j2 != 1 { return false }
    let restored_j2 = _g_enrich_cache[node.id]
    if restored_j2.grade.value != restored_h.grade.value { return false }
    if restored_j2.grade.verified != restored_h.grade.verified { return false }
    if restored_j2.grade.breakthrough != restored_h.grade.breakthrough { return false }
    if restored_j2.grade.hypothesis != restored_h.grade.hypothesis { return false }
    if len(restored_j2.edges.depends_on) != len(restored_h.edges.depends_on) { return false }
    if len(restored_j2.edges.derives) != len(restored_h.edges.derives) { return false }
    if len(restored_j2.edges.equivalents) != len(restored_h.edges.equivalents) { return false }
    if len(restored_j2.edges.verified_by) != len(restored_h.edges.verified_by) { return false }
    if to_string(restored_j2.edges.depends_on[0]) != to_string(restored_h.edges.depends_on[0]) { return false }
    if to_string(restored_j2.edges.verified_by[0]) != to_string(restored_h.edges.verified_by[0]) { return false }

    // F-HXC-COMPAT-FALLBACK: with HEXA_ENRICH_CACHE_FORMAT=hxc, delete the
    //   `.hxc` file and confirm the loader falls through to the `.jsonl`
    //   sibling produced by the prior write. Guards the migration story
    //   (caller already had a `.jsonl` from a Phase 2 run).
    setenv("HEXA_ENRICH_CACHE_FORMAT", "hxc")
    let _ = exec("rm -f \"" + state_dir + "/enriched/" + hash_a + ".hxc\"")
    enrich_cache_reset()
    let loaded_fb = enrich_cache_load_disk(hash_a, state_dir)
    if loaded_fb != 1 { return false }

    // Cleanup HXC + remaining JSONL.
    let _ = exec("rm -f \"" + state_dir + "/enriched/" + hash_a + ".hxc\"")
    let _ = exec("rm -f \"" + state_dir + "/enriched/" + hash_a + ".jsonl\"")
    // Restore env to default-empty so other tests see the documented
    // default (hxc) rather than the test-pinned override.
    setenv("HEXA_ENRICH_CACHE_FORMAT", "")
    enrich_cache_reset()
    return true
