// compiler/atlas/aliases.gen.hexa — verified-root → natural-language alias map
//
// Atlas Layer 3.0 bootstrap: the 24 g3-compliant verified roots in
// real_limits.gen.hexa + materials_limits.gen.hexa carry canonical ids of the
// form `real_limits.<snake>` and `materials_limits.<snake>`. The 7,398 nodes
// in embedded.gen.hexa never use those canonical ids — they cite the same
// concepts under natural-language surface forms ("Shannon entropy",
// "Planck length", "Bekenstein bound", "Hawking", "graphene", …) or under
// older hyphenated ids (`HBIO-*`, `cycle-25-26-*`).
//
// This file holds an additive alias table mapping each verified root to its
// surface-form siblings, so that cross-link audits / merger passes can bridge
// the two naming conventions without rewriting either .gen.hexa source.
//
// ── Scope ──────────────────────────────────────────────────────────────────
//   Only roots with ≥1 plausible alias hit in embedded.gen.hexa are listed.
//   Engineering rows (ASML / ERCOT / Starship / TCEQ / CHIPS / BLS / USPTO)
//   currently have 0 hits and are omitted. Bremermann + Margolus-Levitin
//   similarly omitted (zero embedded references).
//
// ── Confidence scale (0..100) ──────────────────────────────────────────────
//   100  exact citation-text match (e.g. "Shannon 1948 — A Mathematical Theory")
//    90  surface form quoted in cite/comment (e.g. "Bekenstein bound")
//    80  unambiguous surname / short tag (e.g. "Bekenstein", "Hales")
//    70  generic phrase that may collide with other concepts ("entropy",
//        "Boltzmann" without "constant", "diamond" as material vs object)
//
// ── Status ─────────────────────────────────────────────────────────────────
//   GENERATED by tool/atlas_build_aliases.hexa — do not hand-edit.
//   Regenerate via: ./hexa run tool/atlas_build_aliases.hexa

use "compiler/atlas/parser"

pub struct AtlasAlias {
    canonical_id: string,
    aliases: array,    // [string] — natural-language phrases or alt-ids
    confidence: i64    // 0..100, 100 = exact citation, lower = phrase-match
}

@phase("parse_only")
pub let ATLAS_ALIASES: [AtlasAlias] = [

    // --- real_limits.* (Mathematical) ----------------------------------
    AtlasAlias {
