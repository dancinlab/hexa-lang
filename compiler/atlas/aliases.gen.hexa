// --- accessors --------------------------------------------------------------

pub fn atlas_aliases() -> [AtlasAlias] { return ATLAS_ALIASES }

pub fn atlas_aliases_count() -> i64 { return len(ATLAS_ALIASES) }

// aliases_for — return the alias list registered for a canonical root id,
// or [] if no entry exists. Linear scan over ATLAS_ALIASES.
pub fn aliases_for(canonical_id: string) -> [string] {
    let table = ATLAS_ALIASES
    let n = len(table)
    let mut i = 0
    while i < n {
        let entry = table[i]
        if entry.canonical_id == canonical_id {
            return entry.aliases
        }
        i = i + 1
    }
    return []
}

// canonical_for — reverse lookup. Given a surface-form alias string, return
// the canonical id that owns it (case-sensitive exact match against any of
// the entries in `aliases`). Returns "" when no entry claims the alias.
pub fn canonical_for(alias: string) -> string {
    let table = ATLAS_ALIASES
    let n = len(table)
    let mut i = 0
    while i < n {
        let entry = table[i]
        let als = entry.aliases
        let m = len(als)
        let mut j = 0
        while j < m {
            if als[j] == alias {
                return entry.canonical_id
            }
            j = j + 1
        }
        i = i + 1
    }
    return ""
}
