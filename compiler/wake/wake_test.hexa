// wake smoke — sandbox HOME + manipulated signal file.

use "compiler/atlas/overlay"
use "compiler/wake/wake"

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn _setup_sandbox() -> string {
    let base = "/tmp/hexa_wake_smoke"
    exec("rm -rf '" + base + "' 2>/dev/null; mkdir -p '" + base + "/.hx/data'")
    setenv("HOME", base)
    setenv("NEXUS_WAKE_COOLDOWN_SEC", "0")
    return base
}

fn main() {
    println("phase-3 wake smoke")
    let sandbox = _setup_sandbox()
    overlay_reset_cache()
    let fails = []
    let mut pass: i64 = 0
    let mut total: i64 = 0

    let sig_path = sandbox + "/sig.txt"

    // 1) signal file missing → all cycles skip, fires=0.
    total = total + 1
    let r1 = wake_run("phase3 wake seed", sig_path, "3")
    if r1.fires == 0 && r1.skips == 3 { pass = pass + 1; _check("missing signal → all 3 skip", true, fails) }
    else { _check("expected fires=0 skips=3 got fires=" + to_string(r1.fires) + " skips=" + to_string(r1.skips), false, fails) }

    // 2) signal file changes between cycles → at least one fire.
    // We can't easily mutate between cycles in-process; create it first
    // (so cycle 1 sees "changed vs empty prev_fp"), then a flat run should
    // fire once (cycle 1) and skip after (fp stable).
    exec("printf 'v1' > '" + sig_path + "'")
    total = total + 1
    let r2 = wake_run("phase3 wake seed v2", sig_path, "3")
    if r2.fires == 1 && r2.skips == 2 { pass = pass + 1; _check("stable signal → fires=1, skips=2", true, fails) }
    else { _check("expected fires=1 skips=2 got fires=" + to_string(r2.fires) + " skips=" + to_string(r2.skips), false, fails) }

    // 3) overlay note appended for each run.
    total = total + 1
    let loaded = overlay_load()
    if len(loaded) >= 2 { pass = pass + 1; _check("overlay has >=2 wake notes", true, fails) }
    else { _check("overlay expected >=2 got " + to_string(len(loaded)), false, fails) }

    println("")
    println(to_string(pass) + "/" + to_string(total) + " PASS")
    if len(fails) == 0 {
        println("RESULT: PASS")
        exec("rm -rf '" + sandbox + "' 2>/dev/null")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/wake_test.hexa") { return true }
    if s == "wake_test.hexa" { return true }
    return false
}
if _is_main() { main() }
