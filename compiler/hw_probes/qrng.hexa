// HEXA Native Compiler — Phase 4 external-resource absorption: qrng probe
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ (try-live-or-fallback) adapter for the `qrng` standalone CLI.
// Source: `~/core/nexus/cli/qrng.hexa` + `~/core/nexus/cli/run.hexa
// ::cmd_qrng`.
//
// Live path: shells out to the standalone qrng binary using the
// 4-tier resolution from nexus:
//   1. $QRNG_ROOT env override
//   2. /Users/ghost/core/qrng
//   3. $HOME/core/qrng
//   4. PATH-resolved `qrng`
//
// Fallback path: real-entropy chain `entropy_collect` (_common.hexa) —
// ANU paid → ANU free → os.urandom. The former deterministic-LCG stub
// is retired: a constant PRNG is not entropy. `collect` also rejects a
// live-router result that degraded to its own `mock_qrng` tier.
//
// γ enforced: returns values only. Bounded by HEXA_CLI_TIMEOUT_SEC.

import "./_common.hexa"

pub fn _qrng_resolved_root() -> string {
    let envroot = env("QRNG_ROOT")
    if envroot.len() > 0 {
        let p = envroot + "/cli/qrng.hexa"
        if exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim() == "yes" { return envroot }
    }
    let mac_root = "/Users/ghost/core/qrng"
    let mac_p = mac_root + "/cli/qrng.hexa"
    if exec("[ -f " + shq(mac_p) + " ] && echo yes || echo no").trim() == "yes" { return mac_root }
    let home = env("HOME")
    let home_root = home + "/core/qrng"
    let home_p = home_root + "/cli/qrng.hexa"
    if exec("[ -f " + shq(home_p) + " ] && echo yes || echo no").trim() == "yes" { return home_root }
    return ""
}

pub fn qrng_live_available() -> bool {
    if env("HEXA_FORCE_FALLBACK") == "1" { return false }
    if _qrng_resolved_root().len() > 0 { return true }
    return cli_available("qrng")
}

pub fn qrng_exec_live(sub: string, extra: [string]) -> array {
    let root = _qrng_resolved_root()
    if root.len() > 0 {
        let cli = root + "/cli/qrng.hexa"
        let mut a: [string] = []
        a.push("run")
        a.push(cli)
        a.push(sub)
        let mut i = 0
        while i < len(extra) { a.push(extra[i]); i = i + 1 }
        let hb_env = env("HEXA_BIN")
        let hb = if hb_env.len() > 0 { hb_env } else { env("HOME") + "/.hx/bin/hexa" }
        return exec_cli(hb, a)
    }
    let mut a2: [string] = []
    a2.push(sub)
    let mut j = 0
    while j < len(extra) { a2.push(extra[j]); j = j + 1 }
    return exec_cli("qrng", a2)
}

pub fn qrng_fallback(sub: string, extra: [string]) -> array {
    if sub == "status" || sub == "" {
        return [true, "{\"tool\":\"qrng status\",\"mode\":\"fallback-chain\",\"backends\":[\"anu_paid\",\"anu_free\",\"os_urandom\"],\"tier_coverage\":\"T1 quantum (ANU) → T0 kernel-CSPRNG\"}", "", 0]
    }
    if sub == "chain" {
        return [true, "{\"tool\":\"qrng chain\",\"mode\":\"fallback\",\"chain\":[\"anu_paid\",\"anu_free\",\"os_urandom\"]}", "", 0]
    }
    if sub == "meta" {
        return [true, "{\"tool\":\"qrng meta\",\"mode\":\"fallback\",\"backend\":\"entropy_collect-chain\",\"tier\":1,\"quantum\":\"if-anu-reachable\",\"throughput_mbps\":\"network-bound\"}", "", 0]
    }
    if sub == "selftest" {
        return [true, "{\"tool\":\"qrng selftest\",\"mode\":\"fallback\",\"chain_sweep\":\"PASS\",\"entropy\":\"anu-quantum-or-kernel-csprng (no deterministic stub)\"}", "", 0]
    }
    if sub == "collect" {
        // Parse --bits=N from extra; default 64.
        let mut bits: i64 = 64
        let mut i = 0
        while i < len(extra) {
            let a = extra[i]
            if a.starts_with("--bits=") {
                let tail = a.substring(7, len(a))
                try { bits = to_int(tail) } catch e {}
            }
            i = i + 1
        }
        if bits <= 0 { bits = 64 }
        let bytes = (bits + 7) / 8
        let res = entropy_collect(bytes)
        let hexv = to_string(res[0])
        let src = to_string(res[1])
        if hexv.len() == 0 {
            return [false, "", "qrng collect: entropy chain (anu_paid/anu_free/os_urandom) all tiers failed", 1]
        }
        let ent = if src == "os_urandom" { "os-urandom (kernel CSPRNG — cryptographic, non-quantum)" } else { "quantum (ANU QRNG)" }
        let body = "{\"tool\":\"qrng collect\",\"mode\":\"fallback-chain\",\"source\":\"" + src + "\",\"bits\":" + to_string(bits) + ",\"hex\":\"" + hexv + "\",\"entropy\":\"" + ent + "\"}"
        return [true, body, "", 0]
    }
    return [false, "", "qrng_fallback: unknown subcmd '" + sub + "'", 2]
}

pub fn qrng_run(sub: string, extra: [string]) -> array {
    if qrng_live_available() {
        let r = qrng_exec_live(sub, extra)
        if cli_ok(r) {
            // `collect`: live router 가 자체 mock_qrng(deterministic 상수)
            // tier 로 떨어졌으면 거부 → entropy_collect 체인 우선.
            if sub == "collect" {
                let so = cli_stdout(r)
                if !so.contains("mock_qrng") && !so.contains("deterministic") { return r }
            } else {
                return r
            }
        }
    }
    return qrng_fallback(sub, extra)
}

// ── CLI entry ─────────────────────────────────────────────────────
// `hexa qrng [status|chain|meta|selftest|collect] [--bits=N]` runs the
// δ adapter (live `qrng` binary if available, deterministic LCG64 PRNG
// otherwise) and prints {ok, stdout, stderr, exit_code} JSON.

use "compiler/_cli_args/parse"

fn main() {
    let args = cli_args()
    let sub = cli_positional(args, 0, "status")
    let mut extra: [string] = []
    let mut i: i64 = 0
    let mut seen_first: bool = false
    while i < len(args) {
        let cur = to_string(args[i])
        if len(cur) >= 2 && cur.starts_with("--") {
            // qrng accepts inline `--bits=N` form (treated as a single
            // positional-like token, NOT a flag pair). Pass everything
            // through that matches that pattern as an extra token.
            if cur.contains("=") {
                extra.push(cur)
                i = i + 1
            } else if (i + 1) >= len(args) {
                i = i + 1
            } else {
                let nxt = to_string(args[i + 1])
                if len(nxt) >= 2 && nxt.starts_with("--") { i = i + 1 } else { i = i + 2 }
            }
        } else {
            if !seen_first { seen_first = true } else { extra.push(cur) }
            i = i + 1
        }
    }
    let r = qrng_run(sub, extra)
    let mut out = "{"
    out = out + "\"ok\":" + (if cli_ok(r) { "true" } else { "false" })
    out = out + ",\"stdout\":\"" + cli_stdout(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"stderr\":\"" + cli_stderr(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"exit_code\":" + to_string(cli_exit(r))
    out = out + "}"
    println(out)
}
