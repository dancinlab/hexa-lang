// HEXA Native Compiler — Wave 1 absorption: completion criterion smoke

use "compiler/completion_criterion/embed"
use "compiler/completion_criterion/embedded.gen"
use "compiler/completion_criterion/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 completion_criterion embed smoke")
    println("  hash:         " + COMPLETION_CRITERION_HASH)
    println("  generated_at: " + COMPLETION_CRITERION_GENERATED_AT)
    println("  source_count: " + to_string(COMPLETION_CRITERION_SOURCE_COUNT))
    let c = completion_criterion()
    println("  name:         " + c.name)
    println("  threshold:    " + to_string(c.breakthrough_threshold))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(COMPLETION_CRITERION_HASH),                       fails)
    _check("generated_at non-empty",     len(COMPLETION_CRITERION_GENERATED_AT) > 0,                 fails)
    _check("source_count == 1",          COMPLETION_CRITERION_SOURCE_COUNT == 1,                     fails)
    _check("name == closed_form",        c.name == "closed_form",                                    fails)
    _check("threshold == 10",            c.breakthrough_threshold == 10,                             fails)
    _check("forbidden non-empty",        len(c.forbidden) > 0,                                       fails)
    _check("allowed non-empty",          len(c.allowed) > 0,                                         fails)
    _check("verify_type non-empty",      len(c.verify_type) > 0,                                     fails)
    _check("breakthrough_threshold helper", breakthrough_threshold() == 10,                          fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (1/1 record, hash=" + COMPLETION_CRITERION_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
