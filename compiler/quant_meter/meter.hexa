// HEXA Native Compiler — quant_meter (P1 MVP)
//
// Rate-distortion instrumentation of the compile pipeline.
//
// Framing: compilation = progressive quantization. Each transform stage
// removes a category of representational freedom while preserving
// semantics. We measure two things per IR level:
//   S  — representation size (node count). NOT monotone (SSA expands the
//        statement count); observability / regression signal only.
//   F  — freedom vector. Per-kind count of open semantically-free choices.
//        MUST be monotone non-increasing across transform stages — a rise
//        means a stage added freedom, which is a design bug.
//
// P1 covers three zero-analysis F-counters (pure tree walks):
//   F_name — identifier occurrences still carried as a string (unresolved)
//   F_type — expressions whose concrete monotype is not yet pinned
//   F_ctrl — structured control constructs not yet lowered to branches
//
// True rate R is uncomputable (Kolmogorov full-employment theorem); these
// counts are an explicit operational proxy, not true entropy. The eventual
// D=0 distortion gate rests on CompCert-style observational equivalence
// (forward simulation), not on a real-valued distortion metric. See the
// forthcoming rate-distortion-pipeline RFC.

// Tree-shaped imports (self-contained): hir.hexa transitively imports
// ../parse/ast.hexa (→ ../lex/tokens.hexa); the flatten splices every
// symbol into one module, so AST types are visible here. Importing
// ast.hexa directly too would make the graph a diamond, and `hexa build`'s
// flatten does not dedup repeated files unless the module_loader path-
// canonicalization patch is present — which lives in a shared file outside
// this directory. Keeping the graph a tree (hir → ast → tokens; mir
// standalone) makes this module + meter_test build with the stock loader.
import "../ir/hir.hexa"
import "../ir/mir.hexa"

// ── RateVec ───────────────────────────────────────────────────

pub struct RateVec {
    stage: string,       // "ast" | "hir" | "mir"
    s_nodes: i64,        // S — representation size (verbosity; not monotone)
    f_name: i64,         // F_name — unresolved string-carried identifiers
    f_type: i64,         // F_type — expressions without a pinned monotype
    f_ctrl: i64          // F_ctrl — un-lowered structured control constructs
}

// ── HX2600 monotonicity gate (pure; no diag dependency) ──────
// Gate LOGIC lives here (diag-free so meter_test stays on the proven
// small-build path); the HX2600 Diagnostic is constructed in
// compiler/main.hexa where the diag catalog is already imported.

pub struct QuantViolation {
    hit: bool,
    component: string,   // "F_name" | "F_type" | "F_ctrl" | ""
    from_stage: string,
    to_stage: string,
    before: i64,
    after: i64
}

fn _qv_none() -> QuantViolation {
    return QuantViolation { hit: false, component: "", from_stage: "", to_stage: "", before: 0, after: 0 }
}

// First F component (name → type → ctrl) that ROSE prev→cur, if any.
// A rise = a transform added representational freedom = invariant breach.
pub fn quant_check_pair(prev: RateVec, cur: RateVec) -> QuantViolation {
    if cur.f_name > prev.f_name {
        return QuantViolation { hit: true, component: "F_name", from_stage: prev.stage, to_stage: cur.stage, before: prev.f_name, after: cur.f_name }
    }
    if cur.f_type > prev.f_type {
        return QuantViolation { hit: true, component: "F_type", from_stage: prev.stage, to_stage: cur.stage, before: prev.f_type, after: cur.f_type }
    }
    if cur.f_ctrl > prev.f_ctrl {
        return QuantViolation { hit: true, component: "F_ctrl", from_stage: prev.stage, to_stage: cur.stage, before: prev.f_ctrl, after: cur.f_ctrl }
    }
    return _qv_none()
}

pub fn quant_ok(prev: RateVec, cur: RateVec) -> bool {
    let v = quant_check_pair(prev, cur)
    return !v.hit
}

// ── AST expr-kind → string tag ───────────────────────────────
// Mirrors _expr_kind_tag in lower/ast_to_hir.hexa (not pub there). stage0
// has no derived Eq for enums, so kind dispatch routes through this single
// exhaustive match, then string compares — the same form HIR uses natively.

fn _ast_kind_str(k: ExprKind) -> string {
    return match k {
        ExprKind::LiteralInt -> "literal_int",
        ExprKind::LiteralFloat -> "literal_float",
        ExprKind::LiteralString -> "literal_string",
        ExprKind::LiteralBool -> "literal_bool",
        ExprKind::LiteralChar -> "literal_char",
        ExprKind::Ident -> "ident",
        ExprKind::AtlasRef -> "atlas_ref",
        ExprKind::Call -> "call",
        ExprKind::BinOp -> "binop",
        ExprKind::UnOp -> "unop",
        ExprKind::Block -> "block",
        ExprKind::If -> "if",
        ExprKind::While -> "while",
        ExprKind::For -> "for",
        ExprKind::Match -> "match",
        ExprKind::Return -> "return",
        ExprKind::Break -> "break",
        ExprKind::Continue -> "continue",
        ExprKind::Let -> "let",
        ExprKind::Assign -> "assign",
        ExprKind::Field -> "field",
        ExprKind::Index -> "index",
        ExprKind::ArrayLit -> "array_lit",
        ExprKind::StructLit -> "struct_lit",
        ExprKind::EnumPath -> "enum_path",
        ExprKind::Wildcard -> "wildcard"
    }
}

fn _is_ctrl_tag(t: string) -> bool {
    if t == "if" { return true }
    if t == "while" { return true }
    if t == "for" { return true }
    if t == "match" { return true }
    return false
}

// ── AST walk ─────────────────────────────────────────────────

fn _walk_ast_expr(e: Expr) -> RateVec {
    let ks = _ast_kind_str(e.kind)
    let mut sn = 1
    let mut fname = 0
    // AST is fully untyped — every expr node carries open type freedom.
    let mut ftype = 1
    let mut fctrl = 0
    if ks == "ident" { fname = 1 }
    if _is_ctrl_tag(ks) { fctrl = 1 }
    let mut i = 0
    while i < len(e.children) {
        let c = _walk_ast_expr(e.children[i])
        sn = sn + c.s_nodes
        fname = fname + c.f_name
        ftype = ftype + c.f_type
        fctrl = fctrl + c.f_ctrl
        i = i + 1
    }
    return RateVec { stage: "", s_nodes: sn, f_name: fname, f_type: ftype, f_ctrl: fctrl }
}

pub fn meter_ast(m: Module) -> RateVec {
    let mut sn = 0
    let mut fname = 0
    let mut ftype = 0
    let mut fctrl = 0
    let mut i = 0
    while i < len(m.items) {
        let it = m.items[i]
        sn = sn + 1
        let b = _walk_ast_expr(it.body)
        sn = sn + b.s_nodes
        fname = fname + b.f_name
        ftype = ftype + b.f_type
        fctrl = fctrl + b.f_ctrl
        i = i + 1
    }
    return RateVec { stage: "ast", s_nodes: sn, f_name: fname, f_type: ftype, f_ctrl: fctrl }
}

// ── HIR walk ─────────────────────────────────────────────────
// HExpr.kind is already a string tag (mirrors _expr_kind_tag).

fn _walk_hir_expr(e: HExpr) -> RateVec {
    let mut sn = 1
    let mut fname = 0
    let mut ftype = 0
    let mut fctrl = 0
    // F_name: an ident still carries naming freedom iff binding left its
    // DefId module empty (resolved idents point at a dense per-module index).
    if e.kind == "ident" {
        if e.def.module == "" { fname = 1 }
    }
    // F_type: HIR is well-typed by construction; a blank Type.kind is
    // residual type freedom (expected ~0 on a clean compile).
    if e.typ.kind == "" { ftype = 1 }
    if _is_ctrl_tag(e.kind) { fctrl = 1 }
    let mut i = 0
    while i < len(e.children) {
        let c = _walk_hir_expr(e.children[i])
        sn = sn + c.s_nodes
        fname = fname + c.f_name
        ftype = ftype + c.f_type
        fctrl = fctrl + c.f_ctrl
        i = i + 1
    }
    return RateVec { stage: "", s_nodes: sn, f_name: fname, f_type: ftype, f_ctrl: fctrl }
}

pub fn meter_hir(m: HModule) -> RateVec {
    let mut sn = 0
    let mut fname = 0
    let mut ftype = 0
    let mut fctrl = 0
    let mut i = 0
    while i < len(m.items) {
        let it = m.items[i]
        sn = sn + 1
        let b = _walk_hir_expr(it.body)
        sn = sn + b.s_nodes
        fname = fname + b.f_name
        ftype = ftype + b.f_type
        fctrl = fctrl + b.f_ctrl
        i = i + 1
    }
    return RateVec { stage: "hir", s_nodes: sn, f_name: fname, f_type: ftype, f_ctrl: fctrl }
}

// ── MIR walk ─────────────────────────────────────────────────
// By construction MIR has eliminated all three P1 freedom kinds:
//   names   → dense Local ids    (F_name = 0)
//   types   → interned type_id   (F_type = 0)
//   control → CFG basic blocks   (F_ctrl = 0)
// S is the per-block statement total. SSA 3-address form EXPANDS the count
// versus HIR — that size/freedom divergence is exactly what motivates the
// separate S and F tracks.

pub fn meter_mir(m: MModule) -> RateVec {
    let mut sn = 0
    let mut fi = 0
    while fi < len(m.funcs) {
        let f = m.funcs[fi]
        let mut bi = 0
        while bi < len(f.blocks) {
            sn = sn + len(f.blocks[bi].stmts)
            bi = bi + 1
        }
        fi = fi + 1
    }
    return RateVec { stage: "mir", s_nodes: sn, f_name: 0, f_type: 0, f_ctrl: 0 }
}

// ── Reporting ────────────────────────────────────────────────

fn _pad_left(s: string, w: i64) -> string {
    let mut out = s
    while len(out) < w { out = " " + out }
    return out
}

fn _pad_right(s: string, w: i64) -> string {
    let mut out = s
    while len(out) < w { out = out + " " }
    return out
}

fn _rv_row(r: RateVec) -> string {
    return "    " + _pad_right(r.stage, 5) + "  "
        + _pad_left(to_string(r.s_nodes), 9) + "  "
        + _pad_left(to_string(r.f_name), 7) + "  "
        + _pad_left(to_string(r.f_type), 7) + "  "
        + _pad_left(to_string(r.f_ctrl), 7)
}

fn _warn_regress(prev: RateVec, cur: RateVec) {
    if cur.f_name > prev.f_name {
        eprintln("hexa-compiler: quant_meter WARN: F_name rose "
            + prev.stage + "->" + cur.stage + " ("
            + to_string(prev.f_name) + "->" + to_string(cur.f_name)
            + ") — transform stage added naming freedom")
    }
    if cur.f_type > prev.f_type {
        eprintln("hexa-compiler: quant_meter WARN: F_type rose "
            + prev.stage + "->" + cur.stage + " ("
            + to_string(prev.f_type) + "->" + to_string(cur.f_type)
            + ") — transform stage added type freedom")
    }
    if cur.f_ctrl > prev.f_ctrl {
        eprintln("hexa-compiler: quant_meter WARN: F_ctrl rose "
            + prev.stage + "->" + cur.stage + " ("
            + to_string(prev.f_ctrl) + "->" + to_string(cur.f_ctrl)
            + ") — transform stage added control freedom")
    }
}

pub fn quant_report(a: RateVec, h: RateVec, m: RateVec) {
    eprintln("hexa-compiler: quant_meter (P1) — rate-distortion instrumentation")
    eprintln("    stage   S(nodes)   F_name   F_type   F_ctrl")
    eprintln("    -----------------------------------------------")
    eprintln(_rv_row(a))
    eprintln(_rv_row(h))
    eprintln(_rv_row(m))
    eprintln("    F columns must be monotone non-increasing (transform invariant).")
    _warn_regress(a, h)
    _warn_regress(h, m)
}
