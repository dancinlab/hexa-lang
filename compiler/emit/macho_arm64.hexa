// compiler/emit/macho_arm64.hexa
//
// S7-P0 SCAFFOLD — Mach-O arm64 object emitter (LIR -> .o bytes).
//
// RFC 063 § P0. Replaces the `.s` text -> `as` round-trip currently
// in `compiler/main.hexa:806`. Emits Mach-O 64-bit arm64 relocatable
// objects (`MH_OBJECT`, cputype `CPU_TYPE_ARM64`, cpusubtype
// `CPU_SUBTYPE_ARM64_ALL`) directly from `LModule`.
//
// STATUS: IMPLEMENTED (P0 in progress). Encoding table
// (`encode_arm64_insn`), Mach-O serializer (`serialize`), and LIR
// walker (`pack_lir`) are live and imported by `compiler/main.hexa`
// (the `--emit=obj` + `--backend=native` + `arm64-apple-darwin` path
// at main.hexa:882 writes the `.o` via `pack_lir` + `serialize`).
//
// F-P0-OBJEQ status (verified 2026-05-26, arm64 macOS 26.5, Apple
// clang 21.0.0 — measured on `mini`, all numbers verbatim):
//   - `__text` BYTE-EQ vs `clang -c`: HOLDS for {trivial, fib, while}
//     (17 / 74 / 44 instr words IDENTICAL); HEAD `__text` is also
//     byte-identical to the pre-symtab baseline (#1257) — this work
//     did NOT perturb `__text`.
//   - Symbol table now BYTE-EQ in LAYOUT: `nm -ap` (symbols, n_type,
//     n_sect, n_value, ORDER) is IDENTICAL to clang, and DYSYMTAB
//     (ilocalsym 0 / nlocalsym 6 / iextdefsym 6 / nextdefsym 1 /
//     iundefsym 7 / nundefsym 2) is IDENTICAL. Sections (__text,
//     __HEXA,__cap, __HEXA,__abi) + load commands (LC_SEGMENT_64,
//     LC_BUILD_VERSION, LC_SYMTAB, LC_DYSYMTAB) IDENTICAL.
//   - Whole-`.o` byte-eq vs the CWD-independent clang object
//     (`.s` with `.file`/`.loc` stripped): byte-diff == 0 for
//     {trivial, fib, while, if} (ours 800 / 1248 / 1096 / 1064 B ==
//     clang). The strtab interning residual below is now CLOSED.
//
// CLOSED (2026-05-26): STRTAB-INTERNING ORDER. clang's strtab is
//   built by MCStringTableBuilder's suffix-merge interning, which we
//   now reproduce in `_build_merged_strtab`: unique names sorted by
//   REVERSED bytes DESCENDING, a string that is a suffix of its
//   predecessor tail-merges (reuses the predecessor's trailing bytes +
//   NUL), and the table is padded so the file ends on an 8-byte
//   boundary. Every `n_strx` (name_offset) + the `strsize` field now
//   match clang byte-for-byte (verified against Apple clang 21.0.0).
//
// RESIDUAL to FULL byte-eq vs the *default* clang object (out of
// scope — non-portable):
//   (2) DWARF `__debug_line` / `__debug_line_str`. The default
//       `clang -c` object carries these (from `.file`/`.loc`) and
//       `__debug_line_str` EMBEDS the absolute build CWD — so the
//       default clang `.o` is not host/CWD-portable (two CWDs ->
//       two shas). We deliberately do NOT emit `__debug_*`; the
//       byte-eq target is the CWD-independent (`.file`/`.loc`-
//       stripped) clang object, which has no DWARF and which we
//       match section-for-section.
//   - Also out of scope here (separate increment): string/global
//     refs that lower to `adrp sym@PAGE` + `add sym@PAGEOFF` + a
//     `__cstring` section with PAGE21/PAGEOFF12 relocations.
//
// Falsifier (from RFC 063 § P0): `F-P0-OBJEQ` — byte-eq vs
// `clang -c -arch arm64 T.s -o T.ref.o` on {trivial, fib, while, if,
// compiler_self}, after stripping non-deterministic fields
// (timestamps, `LC_BUILD_VERSION` paths, `LC_UUID`, load-command
// order).
//
// Design references:
// - Mach-O spec: <https://github.com/apple-oss-distributions/cctools>
//   (`include/mach-o/loader.h`, `reloc.h`, `arm64/reloc.h`)
// - arm64 ISA: ARM ARM (DDI 0487), the LIR subset emitted by
//   `compiler/codegen/arm64_darwin.hexa`.
// - Existing `.s` emitter: `compiler/emit/asm.hexa` (~459 lines) —
//   line-level structure to mirror; the encoding decisions are
//   identical, only the output format differs (.s text vs Mach-O
//   bytes).

// ─────────────────────────────────────────────────────────────────
// Mach-O 64-bit constants (subset needed for arm64 `.o`)
// ─────────────────────────────────────────────────────────────────
//
// All public constant names are prefixed `MACHO_` / `MACHO_LC_` / `MACHO_S_`
// / `MACHO_ARM64_RELOC_`. The bare-name forms (`MH_OBJECT`, `LC_SEGMENT_64`,
// `CPU_TYPE_ARM64`, etc.) collide with the same-name `#define` macros in
// `<mach-o/loader.h>` / `<mach/machine.h>` that the C runtime
// transitively includes — preprocessor expansion would mangle our
// `HexaVal CPU_TYPE_ARM64 = ...` decl into invalid C. The MACHO_ prefix
// is unique to hexa-side constants.

// Mach-O file magic (little-endian 64-bit).
let MACHO_MH_MAGIC_64 = 0xfeedfacf

// File types we emit.
let MACHO_MH_OBJECT  = 1   // .o relocatable
let MACHO_MH_EXECUTE = 2   // executable (P1 uses this, not P0)

// CPU types.
let MACHO_CPU_TYPE_ARM64 = 0x0100000c  // 0x01000000 | 12 (arm64)
let MACHO_CPU_SUBTYPE_ARM64_ALL = 0

// Load commands we emit.
let MACHO_LC_SEGMENT_64    = 0x19
let MACHO_LC_SYMTAB        = 0x02
let MACHO_LC_DYSYMTAB      = 0x0b
let MACHO_LC_BUILD_VERSION = 0x32

// Section flags.
let MACHO_S_REGULAR               = 0x00000000
let MACHO_S_ATTR_PURE_INSTRUCTIONS = 0x80000000

// arm64 relocation types (`mach-o/arm64/reloc.h`).
let MACHO_ARM64_RELOC_UNSIGNED   = 0
let MACHO_ARM64_RELOC_BRANCH26   = 2
let MACHO_ARM64_RELOC_PAGE21     = 3
let MACHO_ARM64_RELOC_PAGEOFF12  = 4

// nlist `n_type` bits (`<mach-o/nlist.h>`).
let MACHO_N_UNDF = 0x00   // undefined (extern reference)
let MACHO_N_SECT = 0x0e   // defined in a section
let MACHO_N_EXT  = 0x01   // external (globally visible)
let MACHO_N_PEXT = 0x10   // private extern (`.private_extern` / `.hidden`)

// LC_BUILD_VERSION platform id (`<mach-o/loader.h>`).
let MACHO_PLATFORM_MACOS = 1
// minos packed as XXXX.YY.ZZ in 0xXXXXYYZZ. clang on macOS 26 stamps
// minos 26.0.0 -> 0x001a0000. (26 == 0x1a.) The native emitter mirrors
// the host clang's stamp so `--backend=native` objects carry the same
// LC_BUILD_VERSION clang's `-c` does (verified by `otool -l`).
let MACHO_BUILD_MINOS_26 = 0x001a0000


// ─────────────────────────────────────────────────────────────────
// Builder state — the in-progress Mach-O object as buffers
// ─────────────────────────────────────────────────────────────────

struct MachoArm64Obj {
    // __TEXT,__text section bytes (concatenated instruction words +
    // any literal pools).
    text:     [u8],
    // Per-instruction relocation records (deferred fix-ups for
    // ADRP/ADD symbol pairs, BL branches > 128 MB, etc.).
    relocs:   [Arm64Reloc],
    // Symbol table — function labels, extern references.
    symbols:  [MachoSymbol],
    // String table — null-terminated UTF-8, indexed by symbols.
    strtab:   [u8],
    // DWARF __debug_line bytes (optional; populated from the `.loc`
    // directives the LIR carries; see compiler/emit/asm.hexa for the
    // line-table builder this scaffold reuses).
    dwarf_line: [u8],
}

struct Arm64Reloc {
    offset:  i64,    // offset in __text where the patch applies
    sym_idx: i64,    // index into symbols[]
    kind:    i64,    // ARM64_RELOC_*
    pcrel:   i64,    // 0 or 1
    length:  i64,    // log2(byte size); 2 = 4 bytes (one arm64 insn)
}

struct MachoSymbol {
    name_offset: i64,   // index into strtab[]
    section:     i64,   // 0 = undefined extern, 1 = __text, 2 = __cap, 3 = __abi
    value:       i64,   // address (within its section for defined syms)
    kind:        i64,   // N_SECT (defined) / N_UNDF (extern) / ...
    is_external: i64,   // N_EXT flag
    is_pext:     i64,   // N_PEXT (.private_extern / .hidden) — non-entry fns
}

// The 12-byte `__HEXA,__abi` ABI stamp (RFC 070 §G7-D.B2): a 4-byte LE
// runtime_version (1) + 8-byte LE nanbox_layout_hash (0). Mirrors
// `compiler/emit/asm.hexa::_abi_stamp_hex` — same bytes the `.s` path
// emits via `.byte`, here packed directly. Held as a fixed constant so
// the `__abi` section content is byte-stable across the `.s` and native
// emit paths (`asm.hexa` HEXA_RUNTIME_VERSION=1, HEXA_NANBOX_LAYOUT_HASH=0).
fn _hexa_abi_stamp_bytes() -> [Int] {
    return [0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]
}

// Entry symbols keep default (public) visibility; everything else is
// `.private_extern` (N_PEXT). Mirrors `asm.hexa::_is_entry_symbol`.
fn _is_entry_symbol_name(name: string) -> bool {
    if name == "main"   { return true }
    if name == "_start" { return true }
    return false
}

// ─────────────────────────────────────────────────────────────────
// Public entry — LIR -> Mach-O arm64 .o
// ─────────────────────────────────────────────────────────────────

// pub fn emit_macho_arm64(lm: LModule, out_path: string) -> i64
//
// Returns 0 on success, non-zero on encoding / IO failure.
//
// RFC 063 § P0 IMPLEMENTATION CHECKLIST (in dispatch order):
//   1. arm64 encoding table — LIR opcode + operands -> 32-bit word.
//      ~150-200 rules covering the LIR subset
//      `compiler/codegen/arm64_darwin.hexa` currently emits.
//   2. Symbol pass — collect all function labels and extern refs
//      from `lm.funcs`, populate `symbols[]` + `strtab[]`.
//   3. Code pass — walk LInstr stream, encode each to 4 bytes, emit
//      relocation records for ADRP / ADD / LDR symbol pairs and
//      BL branches.
//   4. DWARF pass — reuse asm.hexa's `.loc` line-table builder, emit
//      `__debug_line` section bytes.
//   5. Mach-O serialization — header + LC_SEGMENT_64(__TEXT) +
//      LC_SYMTAB + LC_DYSYMTAB + LC_BUILD_VERSION, sections, then
//      the data buffers; relocations into `__text` section's reloff.
//   6. Write to `out_path`.
fn emit_macho_arm64(_lm: i64, _out_path: string) {
    // RFC 063 § P0 — implementation pending.
    // The signature uses placeholder types until LModule is wired
    // (the import will resolve to `compiler/ir/lir.hexa::LModule`
    // when this file is integrated).
    println("emit_macho_arm64: SCAFFOLD — not yet implemented (RFC 063 P0)")
}

// ─────────────────────────────────────────────────────────────────
// Encoding table — populated in P0 implementation cycles
// ─────────────────────────────────────────────────────────────────

// Register name -> index. arm64 has 31 general-purpose 64-bit regs
// (X0..X30) plus XZR (zero register, encoded as 31) and SP (stack
// pointer, also encoded as 31 in some contexts).
fn xreg_idx(s: string) -> i64 {
    if s == "XZR" || s == "xzr" { return 31 }
    if s == "SP"  || s == "sp"  { return 31 }
    // Strip leading "X"/"x", parse remaining as integer (0..30).
    let n = len(s)
    if n < 2 { return -1 }
    let head = s.substring(0, 1)
    if head != "X" && head != "x" { return -1 }
    let rest = s.substring(1, n)
    let v = rest.to_int()
    if v < 0 || v > 30 { return -1 }
    return v
}

// Parse "#42" or "#0x2a" (immediate operand) to i64.
fn imm_val(s: string) -> i64 {
    let n = len(s)
    if n < 2 { return 0 }
    if s.substring(0, 1) != "#" { return s.to_int() }
    return s.substring(1, n).to_int()
}

// Parse a MOVZ/MOVK immediate operand that may carry an optional shift:
// "#imm" or "#imm, lsl #N" (N ∈ {0,16,32,48}, emitted by arm64_darwin.hexa's
// >16-bit constant materializer). Returns [imm16, hw] where hw = N/16 (the
// ARM64 MOVZ/MOVK shift field, bits 22:21). Unshifted → hw 0. Without this the
// `, lsl #N` suffix reached imm_val→to_int ("trailing garbage") AND the shift
// was dropped from the encoding (wrong halfword for >16-bit constants).
fn _movw_imm_hw(operand: string) -> [i64] {
    let n = len(operand)
    let mut ci = 0 - 1
    let mut i = 0
    while i < n {
        if operand.substring(i, i + 1) == "," { ci = i; i = n } else { i = i + 1 }
    }
    if ci < 0 {
        let mut r0: [i64] = []
        r0.push(imm_val(operand) & 0xffff)
        r0.push(0)
        return r0
    }
    let imm = imm_val(operand.substring(0, ci)) & 0xffff
    let mut hi = 0 - 1
    let mut j = ci
    while j < n {
        if operand.substring(j, j + 1) == "#" { hi = j; j = n } else { j = j + 1 }
    }
    let mut hw = 0
    if hi >= 0 { hw = operand.substring(hi + 1, n).to_int() / 16 }
    let mut r: [i64] = []
    r.push(imm)
    r.push(hw)
    return r
}

// fn encode_arm64_insn(op: string, ops: [string]) -> i64
//
// Returns the 32-bit arm64 instruction word for `op` + `ops`.
// Each rule below mirrors a fixed arm64 encoding from ARM ARM
// (DDI 0487). All forms are 64-bit (sf=1) — the LIR subset emitted
// by `compiler/codegen/arm64_darwin.hexa` is uniformly 64-bit.
//
// On unknown op, returns 0 (caller should treat 0 = NOP-like as an
// encoding-failure marker, since real NOP is encoded as 0xd503201f).
//
// RFC 063 § P0 step 1 — first 16 rules landed (the LIR subset that
// `compiler/emit/asm.hexa` emits today as `.s` text). Symbol-
// relative forms (ADRP + ADD/LDR pair) are emitted as bare bits;
// the relocation record carries the symbol identity, the linker
// patches the bits.
fn encode_arm64_insn(op: string, ops: [string]) -> i64 {
    // ── Move ──
    // MOVZ Xd, #imm16  (zero-extend; canonical 16-bit immediate move).
    // The shifted variant `MOVZ Xd, #imm16, lsl #N` (N ∈ {0,16,32,48})
    // sets bits 22:21 = N/16; LIR may emit it as the 4th operand "lsl"
    // + 5th operand "#N" but cycle 7 ships the unshifted form only.
    // MOVK Xd, #imm16 (keep — OR the immediate, preserves others).
    if (op == "MOVZ" || op == "MOVK") && len(ops) == 2 && ops[1].substring(0, 1) == "#" {
        let rd = xreg_idx(ops[0])
        // Operand is "#imm" OR the shifted form "#imm, lsl #N" (N∈{0,16,32,48}).
        // _movw_imm_hw splits off the shift → hw (bits 22:21). The >16-bit
        // constant materializer (arm64_darwin.hexa) relies on these MOVK shifts.
        let parsed = _movw_imm_hw(ops[1])
        let imm = parsed[0]
        let hw = parsed[1]
        let mut base = 0xd2800000      // MOVZ
        if op == "MOVK" { base = 0xf2800000 }   // MOVK
        return base | (hw << 21) | (imm << 5) | rd
    }
    // MOV Xd, #imm16  (legacy alias — `MOV Xd, #imm` is a MOVZ alias
    // when the immediate fits 16 bits with no shift).
    if op == "MOV" && len(ops) == 2 && ops[1].substring(0, 1) == "#" {
        let rd = xreg_idx(ops[0])
        let imm = imm_val(ops[1]) & 0xffff
        return 0xd2800000 | (imm << 5) | rd
    }
    // MOV Xd, Xn. Two sub-cases per ARM ARM (C6.2.187):
    //   - `MOV Xd, SP` or `MOV SP, Xn` → alias for `ADD Xd, Xn, #0`
    //     (because the ORR alias treats Rm=31 as XZR, not SP).
    //   - Otherwise → alias for `ORR Xd, XZR, Xn`.
    // Detect SP either via the source string or via the destination —
    // when either side is "sp"/"SP", route through the ADD form.
    if op == "MOV" && len(ops) == 2 {
        let rd = xreg_idx(ops[0])
        let rn = xreg_idx(ops[1])
        let dst_is_sp = ops[0] == "sp" || ops[0] == "SP"
        let src_is_sp = ops[1] == "sp" || ops[1] == "SP"
        if dst_is_sp || src_is_sp {
            // ADD Xd, Xn, #0  (Rn=31 here means SP, not XZR)
            return 0x91000000 | (rn << 5) | rd
        }
        return 0xaa0003e0 | (rn << 16) | rd
    }

    // ── Arithmetic, register form ──
    // ADD Xd, Xn, Xm
    if op == "ADD" && len(ops) == 3 && ops[2].substring(0, 1) != "#" {
        let rd = xreg_idx(ops[0])
        let rn = xreg_idx(ops[1])
        let rm = xreg_idx(ops[2])
        return 0x8b000000 | (rm << 16) | (rn << 5) | rd
    }
    // ADD Xd, Xn, #imm12
    if op == "ADD" && len(ops) == 3 {
        let rd = xreg_idx(ops[0])
        let rn = xreg_idx(ops[1])
        let imm = imm_val(ops[2]) & 0xfff
        return 0x91000000 | (imm << 10) | (rn << 5) | rd
    }
    // SUB Xd, Xn, Xm
    if op == "SUB" && len(ops) == 3 && ops[2].substring(0, 1) != "#" {
        let rd = xreg_idx(ops[0])
        let rn = xreg_idx(ops[1])
        let rm = xreg_idx(ops[2])
        return 0xcb000000 | (rm << 16) | (rn << 5) | rd
    }
    // SUB Xd, Xn, #imm12
    if op == "SUB" && len(ops) == 3 {
        let rd = xreg_idx(ops[0])
        let rn = xreg_idx(ops[1])
        let imm = imm_val(ops[2]) & 0xfff
        return 0xd1000000 | (imm << 10) | (rn << 5) | rd
    }
    // MUL Xd, Xn, Xm  (alias for MADD Xd, Xn, Xm, XZR)
    if op == "MUL" && len(ops) == 3 {
        let rd = xreg_idx(ops[0])
        let rn = xreg_idx(ops[1])
        let rm = xreg_idx(ops[2])
        return 0x9b007c00 | (rm << 16) | (rn << 5) | rd
    }

    // ── Compare (SUBS XZR, ...) ──
    // CMP Xn, Xm
    if op == "CMP" && len(ops) == 2 && ops[1].substring(0, 1) != "#" {
        let rn = xreg_idx(ops[0])
        let rm = xreg_idx(ops[1])
        return 0xeb00001f | (rm << 16) | (rn << 5)
    }
    // CMP Xn, #imm12
    if op == "CMP" && len(ops) == 2 {
        let rn = xreg_idx(ops[0])
        let imm = imm_val(ops[1]) & 0xfff
        return 0xf100001f | (imm << 10) | (rn << 5)
    }

    // ── Memory (LDR/STR with `[Xn]` or `[Xn, #imm12]` mem operand) ──
    // The mem operand is parsed by `_parse_mem_op` into [base_idx,
    // offset]. The 64-bit form uses a SCALED imm12: encoded value =
    // offset / 8 (so the range is 0..32760 in 8-byte steps).
    //
    // LDR Xt, [Xn{, #imm}]
    if op == "LDR" && len(ops) == 2 {
        let rt = xreg_idx(ops[0])
        let mp = _parse_mem_op(ops[1])
        if mp[0] < 0 {
            // Treat as `[Xn]` bare (no `[`) — fall back to the original
            // path so legacy 2-string callers (no parens) still work.
            let rn = xreg_idx(ops[1])
            return 0xf9400000 | (rn << 5) | rt
        }
        let rn = mp[0]
        let imm = (mp[1] >> 3) & 0xfff       // scaled imm12, 64-bit form
        return 0xf9400000 | (imm << 10) | (rn << 5) | rt
    }
    // STR Xt, [Xn{, #imm}]
    if op == "STR" && len(ops) == 2 {
        let rt = xreg_idx(ops[0])
        let mp = _parse_mem_op(ops[1])
        if mp[0] < 0 {
            let rn = xreg_idx(ops[1])
            return 0xf9000000 | (rn << 5) | rt
        }
        let rn = mp[0]
        let imm = (mp[1] >> 3) & 0xfff
        return 0xf9000000 | (imm << 10) | (rn << 5) | rt
    }
    // ── Stack-pair (STP/LDP) — 3 mem modes (offset / pre-index /
    //    post-index) for 64-bit GPRs. Per ARM ARM C6.2.273-:
    //
    //    STP offset:     0xa9000000   `stp Xt, Xt2, [Xn, #imm]`
    //    STP pre-index:  0xa9800000   `stp Xt, Xt2, [Xn, #imm]!`
    //    STP post-index: 0xa8800000   `stp Xt, Xt2, [Xn], #imm`
    //    LDP offset:     0xa9400000
    //    LDP pre-index:  0xa9c00000
    //    LDP post-index: 0xa8c00000
    //
    // Signed imm7 in 8-byte steps (range -512..504). mode comes from
    // `_parse_mem_op` (0=offset, 1=pre, 2=post).
    if op == "STP" && len(ops) == 3 {
        let rt  = xreg_idx(ops[0])
        let rt2 = xreg_idx(ops[1])
        let mp  = _parse_mem_op(ops[2])
        if mp[0] < 0 { return 0 }
        let rn   = mp[0]
        let imm  = (mp[1] >> 3) & 0x7f
        let mode = mp[2]
        let mut base = 0xa9000000           // offset
        if mode == 1 { base = 0xa9800000 }   // pre-index
        if mode == 2 { base = 0xa8800000 }   // post-index
        return base | (imm << 15) | (rt2 << 10) | (rn << 5) | rt
    }
    if op == "LDP" && len(ops) == 3 {
        let rt  = xreg_idx(ops[0])
        let rt2 = xreg_idx(ops[1])
        let mp  = _parse_mem_op(ops[2])
        if mp[0] < 0 { return 0 }
        let rn   = mp[0]
        let imm  = (mp[1] >> 3) & 0x7f
        let mode = mp[2]
        let mut base = 0xa9400000           // offset
        if mode == 1 { base = 0xa9c00000 }   // pre-index
        if mode == 2 { base = 0xa8c00000 }   // post-index
        return base | (imm << 15) | (rt2 << 10) | (rn << 5) | rt
    }

    // ── Branches (bit-pattern only; imm26 / imm19 filled by reloc) ──
    // B label  — imm26 patched by ARM64_RELOC_BRANCH26 reloc
    if op == "B" && len(ops) == 1 { return 0x14000000 }
    // BL label
    if op == "BL" && len(ops) == 1 { return 0x94000000 }
    // RET (= RET X30)
    if op == "RET" && len(ops) == 0 { return 0xd65f03c0 }

    // ── Conditional branch (B.cond label) ──
    // op is "B.EQ" / "B.NE" / "B.LT" / "B.GE" / "B.GT" / "B.LE" etc.
    if len(op) > 2 && op.substring(0, 2) == "B." && len(ops) == 1 {
        let cc = op.substring(2, len(op))
        let mut c = -1
        if cc == "EQ" { c = 0  } else if cc == "NE" { c = 1  }
        else if cc == "CS" { c = 2  } else if cc == "CC" { c = 3  }
        else if cc == "MI" { c = 4  } else if cc == "PL" { c = 5  }
        else if cc == "VS" { c = 6  } else if cc == "VC" { c = 7  }
        else if cc == "HI" { c = 8  } else if cc == "LS" { c = 9  }
        else if cc == "GE" { c = 10 } else if cc == "LT" { c = 11 }
        else if cc == "GT" { c = 12 } else if cc == "LE" { c = 13 }
        else if cc == "AL" { c = 14 }
        if c >= 0 { return 0x54000000 | c }
    }

    // ── Bitfield / extension aliases (UBFM-family) ──
    // UBFM Xd, Xn, #immr, #imms   (64-bit, sf=1, opc=10, N=1)
    //   0xd3400000 | (immr<<16) | (imms<<10) | (rn<<5) | rd
    // UXTW Xd, Wn  is an alias for UBFM Xd, Xn, #0, #31  (zero-extend
    // the low 32 bits, clear the upper). codegen uses it to widen
    // 32-bit values to the 64-bit ABI slot.
    if op == "UXTW" && len(ops) == 2 {
        let rd = xreg_idx(ops[0])
        // Wn shares the same register-number encoding as Xn (low 5 bits).
        // Accept both "wN" and "xN" form.
        let nm = ops[1]
        let mut rn = -1
        let nn = len(nm)
        if nn >= 2 && (nm.substring(0, 1) == "w" || nm.substring(0, 1) == "W") {
            let rest = nm.substring(1, nn).to_int()
            if rest >= 0 && rest <= 30 { rn = rest }
            if nm == "wzr" || nm == "WZR" { rn = 31 }
        } else {
            rn = xreg_idx(nm)
        }
        if rd >= 0 && rn >= 0 {
            return 0xd3400000 | (0 << 16) | (31 << 10) | (rn << 5) | rd
        }
    }
    // UXTB Xd, Wn  →  UBFM Xd, Xn, #0, #7
    if op == "UXTB" && len(ops) == 2 {
        let rd = xreg_idx(ops[0])
        let nm = ops[1]
        let nn = len(nm)
        let mut rn = -1
        if nn >= 2 && (nm.substring(0, 1) == "w" || nm.substring(0, 1) == "W") {
            let rest = nm.substring(1, nn).to_int()
            if rest >= 0 && rest <= 30 { rn = rest }
        } else { rn = xreg_idx(nm) }
        if rd >= 0 && rn >= 0 {
            return 0xd3400000 | (0 << 16) | (7 << 10) | (rn << 5) | rd
        }
    }
    // UXTH Xd, Wn  →  UBFM Xd, Xn, #0, #15
    if op == "UXTH" && len(ops) == 2 {
        let rd = xreg_idx(ops[0])
        let nm = ops[1]
        let nn = len(nm)
        let mut rn = -1
        if nn >= 2 && (nm.substring(0, 1) == "w" || nm.substring(0, 1) == "W") {
            let rest = nm.substring(1, nn).to_int()
            if rest >= 0 && rest <= 30 { rn = rest }
        } else { rn = xreg_idx(nm) }
        if rd >= 0 && rn >= 0 {
            return 0xd3400000 | (0 << 16) | (15 << 10) | (rn << 5) | rd
        }
    }
    // SXTW Xd, Wn  →  SBFM Xd, Xn, #0, #31   (opc=00 base 0x93400000)
    if op == "SXTW" && len(ops) == 2 {
        let rd = xreg_idx(ops[0])
        let nm = ops[1]
        let nn = len(nm)
        let mut rn = -1
        if nn >= 2 && (nm.substring(0, 1) == "w" || nm.substring(0, 1) == "W") {
            let rest = nm.substring(1, nn).to_int()
            if rest >= 0 && rest <= 30 { rn = rest }
        } else { rn = xreg_idx(nm) }
        if rd >= 0 && rn >= 0 {
            return 0x93400000 | (0 << 16) | (31 << 10) | (rn << 5) | rd
        }
    }

    // ── Compare and branch (zero / non-zero) ──
    // CBZ Xt, label  — imm19 patched by reloc
    if op == "CBZ" && len(ops) == 2 {
        let rt = xreg_idx(ops[0])
        return 0xb4000000 | rt
    }
    // CBNZ Xt, label
    if op == "CBNZ" && len(ops) == 2 {
        let rt = xreg_idx(ops[0])
        return 0xb5000000 | rt
    }

    // Unknown op — caller checks for 0 as failure marker.
    return 0
}

// ─────────────────────────────────────────────────────────────────
// Mach-O byte-level serializer — RFC 063 § P0, cycle 1
// ─────────────────────────────────────────────────────────────────
//
// `serialize(obj)` lays out the in-memory `MachoArm64Obj` into a flat
// `[Int]` byte stream suitable for `write_bytes(path, ...)`. Layout:
//
//   [ mach_header_64                                  ]   32 B
//   [ LC_SEGMENT_64 __TEXT (+ section_64 __text)      ]  152 B
//   [ LC_SYMTAB                                       ]   24 B
//   [ LC_DYSYMTAB                                     ]   80 B
//   [ __text bytes                                    ]   N B   (4-aligned)
//   [ relocation entries (Arm64Reloc records)         ]   8·R B
//   [ symbol table (nlist_64 records)                 ]  16·S B
//   [ string table                                    ]   T B
//
// For an empty object (cycle 1 falsifier) the trailing sections are
// 0 bytes and the file ends at offset 288 (header + 4 LCs).
//
// All fields are little-endian per Mach-O on darwin-arm64.

// Append little-endian u16 to `out`. Used for `nlist_64.n_desc` and
// other 2-byte Mach-O fields.
fn _u16_le(out: [Int], v: Int) {
    out.push(v & 0xff)
    out.push((v >> 8) & 0xff)
}

// Append little-endian u32 to `out` (low byte first). Caller passes
// already-masked value; we mask defensively (& 0xff per byte) so an
// `i64` with the upper 32 bits non-zero does not corrupt the stream.
fn _u32_le(out: [Int], v: Int) {
    out.push(v & 0xff)
    out.push((v >> 8) & 0xff)
    out.push((v >> 16) & 0xff)
    out.push((v >> 24) & 0xff)
}

// Append little-endian u64 to `out`. `v` is `Int` (i64 in hexa-lang);
// negative values are written as their two's-complement bit pattern.
fn _u64_le(out: [Int], v: Int) {
    out.push(v & 0xff)
    out.push((v >> 8) & 0xff)
    out.push((v >> 16) & 0xff)
    out.push((v >> 24) & 0xff)
    out.push((v >> 32) & 0xff)
    out.push((v >> 40) & 0xff)
    out.push((v >> 48) & 0xff)
    out.push((v >> 56) & 0xff)
}

// Append `n` zero bytes (used for fixed-size name fields, alignment
// padding, and the trailing reserved word in `mach_header_64`).
fn _zero_n(out: [Int], n: Int) {
    let mut i = 0
    while i < n {
        out.push(0)
        i = i + 1
    }
}

// Append the ASCII bytes of `s`, then zero-pad to total length `n`.
// Mach-O `segname` / `sectname` fields are exactly 16 bytes — names
// shorter than 16 are zero-filled, names longer than 16 are truncated
// (the Mach-O spec mandates 16-byte field, and the system tools rely
// on it).
fn _str_fixed(out: [Int], s: String, n: Int) {
    let slen = len(s)
    let mut i = 0
    while i < n {
        if i < slen {
            out.push(char_code(s, i) & 0xff)
        } else {
            out.push(0)
        }
        i = i + 1
    }
}

// Emit `mach_header_64` (32 bytes). Per `<mach-o/loader.h>`:
//
//     struct mach_header_64 {
//         uint32_t magic;        // MH_MAGIC_64 (0xfeedfacf)
//         uint32_t cputype;      // CPU_TYPE_ARM64 (0x0100000c)
//         uint32_t cpusubtype;   // CPU_SUBTYPE_ARM64_ALL (0)
//         uint32_t filetype;     // MH_OBJECT (1)
//         uint32_t ncmds;        // load-command count
//         uint32_t sizeofcmds;   // total LC bytes
//         uint32_t flags;        // MH_SUBSECTIONS_VIA_SYMBOLS (0x2000)
//         uint32_t reserved;     // 64-bit reserved word, always 0
//     };
fn _emit_mach_header(out: [Int], ncmds: Int, sizeofcmds: Int, flags: Int) {
    _u32_le(out, MACHO_MH_MAGIC_64)
    _u32_le(out, MACHO_CPU_TYPE_ARM64)
    _u32_le(out, MACHO_CPU_SUBTYPE_ARM64_ALL)
    _u32_le(out, MACHO_MH_OBJECT)
    _u32_le(out, ncmds)
    _u32_le(out, sizeofcmds)
    _u32_le(out, flags)
    _u32_le(out, 0)        // reserved
}

// Emit `LC_SEGMENT_64` load command without its section table.
// Per `<mach-o/loader.h>`:
//
//     struct segment_command_64 {
//         uint32_t cmd;          // LC_SEGMENT_64 (0x19)
//         uint32_t cmdsize;      // 72 + 80*nsects
//         char     segname[16];  // "" for MH_OBJECT (single unnamed seg)
//         uint64_t vmaddr;       // 0 (relocatable)
//         uint64_t vmsize;       // sum of section sizes
//         uint64_t fileoff;      // header_size + sizeofcmds
//         uint64_t filesize;     // same as vmsize for relocatable
//         int32_t  maxprot;      // VM_PROT_READ|WRITE|EXECUTE = 7
//         int32_t  initprot;     // same
//         uint32_t nsects;       // count of section_64 records that follow
//         uint32_t flags;        // 0
//     };
//
// Caller follows up with one `_emit_section_64` per section.
fn _emit_seg64_cmd(out: [Int],
                   segname: String,
                   vmaddr: Int, vmsize: Int,
                   fileoff: Int, filesize: Int,
                   nsects: Int) {
    let cmdsize = 72 + 80 * nsects
    _u32_le(out, MACHO_LC_SEGMENT_64)
    _u32_le(out, cmdsize)
    _str_fixed(out, segname, 16)
    _u64_le(out, vmaddr)
    _u64_le(out, vmsize)
    _u64_le(out, fileoff)
    _u64_le(out, filesize)
    _u32_le(out, 7)            // maxprot
    _u32_le(out, 7)            // initprot
    _u32_le(out, nsects)
    _u32_le(out, 0)            // flags
}

// Emit one `section_64` (80 bytes). Per `<mach-o/loader.h>`:
//
//     struct section_64 {
//         char     sectname[16];
//         char     segname[16];
//         uint64_t addr;
//         uint64_t size;
//         uint32_t offset;
//         uint32_t align;        // log2(byte alignment); 2 == 4-byte
//         uint32_t reloff;
//         uint32_t nreloc;
//         uint32_t flags;
//         uint32_t reserved1;
//         uint32_t reserved2;
//         uint32_t reserved3;
//     };
fn _emit_section_64(out: [Int],
                    sectname: String, segname: String,
                    addr: Int, size: Int,
                    offset: Int, align: Int,
                    reloff: Int, nreloc: Int,
                    flags: Int) {
    _str_fixed(out, sectname, 16)
    _str_fixed(out, segname, 16)
    _u64_le(out, addr)
    _u64_le(out, size)
    _u32_le(out, offset)
    _u32_le(out, align)
    _u32_le(out, reloff)
    _u32_le(out, nreloc)
    _u32_le(out, flags)
    _u32_le(out, 0)            // reserved1
    _u32_le(out, 0)            // reserved2
    _u32_le(out, 0)            // reserved3
}

// Emit `LC_BUILD_VERSION` (24 bytes, ntools=0). Per `<mach-o/loader.h>`:
//
//     struct build_version_command {
//         uint32_t cmd;        // LC_BUILD_VERSION (0x32)
//         uint32_t cmdsize;    // 24 + 8*ntools (== 24 here, ntools=0)
//         uint32_t platform;   // PLATFORM_MACOS (1)
//         uint32_t minos;      // X.Y.Z packed nibble-wise: 0xXXXXYYZZ
//         uint32_t sdk;        // 0 (n/a — clang emits 0 for `-c` w/o -isysroot)
//         uint32_t ntools;     // 0
//     };
//
// clang -c on darwin-arm64 always emits this LC; matching it is required
// for full-object parity (it sits between LC_SEGMENT_64 and LC_SYMTAB).
fn _emit_build_version_cmd(out: [Int], platform: Int, minos: Int) {
    _u32_le(out, MACHO_LC_BUILD_VERSION)
    _u32_le(out, 24)
    _u32_le(out, platform)
    _u32_le(out, minos)
    _u32_le(out, 0)            // sdk — n/a
    _u32_le(out, 0)            // ntools
}

// Emit `LC_SYMTAB` (24 bytes). Per `<mach-o/loader.h>`:
//
//     struct symtab_command {
//         uint32_t cmd;          // LC_SYMTAB (0x02)
//         uint32_t cmdsize;      // 24
//         uint32_t symoff;       // file offset of nlist_64[]
//         uint32_t nsyms;
//         uint32_t stroff;       // file offset of string table
//         uint32_t strsize;
//     };
fn _emit_symtab_cmd(out: [Int],
                    symoff: Int, nsyms: Int,
                    stroff: Int, strsize: Int) {
    _u32_le(out, MACHO_LC_SYMTAB)
    _u32_le(out, 24)
    _u32_le(out, symoff)
    _u32_le(out, nsyms)
    _u32_le(out, stroff)
    _u32_le(out, strsize)
}

// Emit `LC_DYSYMTAB` (80 bytes). Per `<mach-o/loader.h>`:
//
//     struct dysymtab_command {
//         uint32_t cmd;          // LC_DYSYMTAB (0x0b)
//         uint32_t cmdsize;      // 80
//         uint32_t ilocalsym;
//         uint32_t nlocalsym;
//         uint32_t iextdefsym;
//         uint32_t nextdefsym;
//         uint32_t iundefsym;
//         uint32_t nundefsym;
//         uint32_t tocoff;       uint32_t ntoc;
//         uint32_t modtaboff;    uint32_t nmodtab;
//         uint32_t extrefsymoff; uint32_t nextrefsyms;
//         uint32_t indirectsymoff; uint32_t nindirectsyms;
//         uint32_t extreloff;    uint32_t nextrel;
//         uint32_t locreloff;    uint32_t nlocrel;
//     };
//
// Symtab partition contract (clang -c parity): the nlist array is laid
// out as [ nlocalsym locals | nextdefsym defined-externs | nundefsym
// undefs ], in that order. DYSYMTAB records the index+count of each run.
// (was: only nextdefsym; pre-symtab-layout the table had no locals/undefs.)
fn _emit_dysymtab_cmd(out: [Int],
                      nlocalsym: Int,
                      iextdefsym: Int, nextdefsym: Int,
                      iundefsym: Int, nundefsym: Int) {
    _u32_le(out, MACHO_LC_DYSYMTAB)
    _u32_le(out, 80)
    _u32_le(out, 0)            // ilocalsym (locals start at index 0)
    _u32_le(out, nlocalsym)    // nlocalsym
    _u32_le(out, iextdefsym)   // iextdefsym (== nlocalsym)
    _u32_le(out, nextdefsym)   // nextdefsym
    _u32_le(out, iundefsym)    // iundefsym (== nlocalsym + nextdefsym)
    _u32_le(out, nundefsym)    // nundefsym
    // Remaining 12 u32 fields all zero — no TOC, modtab, indirect refs,
    // or external/local relocation tables in MH_OBJECT.
    let mut i = 0
    while i < 12 {
        _u32_le(out, 0)
        i = i + 1
    }
}

// Emit one `nlist_64` symbol record (16 bytes). Per `<mach-o/nlist.h>`:
//
//     struct nlist_64 {
//         uint32_t n_strx;   // index into the string table
//         uint8_t  n_type;   // N_TYPE bits (N_SECT=0x0e, N_UNDF=0x00)
//                            // OR'd with N_EXT (0x01) for external.
//         uint8_t  n_sect;   // 1-based section index; 0 = NO_SECT.
//         uint16_t n_desc;   // misc flags / library ordinal — 0 here.
//         uint64_t n_value;  // section-relative offset for defined syms.
//     };
fn _emit_nlist64(out: [Int], strx: Int, n_type: Int, n_sect: Int, n_value: Int) {
    _u32_le(out, strx)            // n_strx — 4 bytes
    out.push(n_type & 0xff)       // n_type — 1 byte
    out.push(n_sect & 0xff)       // n_sect — 1 byte
    _u16_le(out, 0)               // n_desc — 2 bytes (REFERENCE_FLAG_*, 0 here)
    _u64_le(out, n_value)         // n_value — 8 bytes
}

// Emit one `relocation_info` record (8 bytes). Per `<mach-o/reloc.h>`:
//
//     struct relocation_info {
//         int32_t  r_address;        // section-relative byte offset of patch
//         uint32_t r_symbolnum:24,    // symbol index (extern=1) / section# (extern=0)
//                  r_pcrel:1,         // 1 if displacement is pc-relative
//                  r_length:2,        // log2(byte size); 2 = 4 bytes
//                  r_extern:1,        // 1 = symbolnum is sym idx; 0 = section
//                  r_type:4;          // ARM64_RELOC_*
//     };
//
// The bitfield is little-endian-packed within its u32 (same as the
// struct's natural memory order on darwin-arm64).
fn _emit_reloc_info(out: [Int], r_address: Int, r_symbolnum: Int,
                    r_pcrel: Int, r_length: Int, r_extern: Int, r_type: Int) {
    _u32_le(out, r_address)
    let bits = (r_symbolnum & 0xffffff)
             | ((r_pcrel & 1) << 24)
             | ((r_length & 3) << 25)
             | ((r_extern & 1) << 27)
             | ((r_type & 0xf) << 28)
    _u32_le(out, bits)
}

// ─────────────────────────────────────────────────────────────────
// `serialize(obj)` — top-level entry, RFC 063 § P0 cycle 1
// ─────────────────────────────────────────────────────────────────
//
// Returns the flat byte stream as `[Int]` (each value in 0..=255).
// Cycle 1 scope: header + 4 load commands. Section data, symbol
// records, and relocations follow `obj`'s buffers verbatim — the
// scaffold already exposes them as `text` / `relocs` / `symbols` /
// `strtab`. With those buffers empty (e.g. an empty input program)
// `serialize` produces a 288-byte well-formed Mach-O `.o` whose
// `mach_header_64` and `LC_SEGMENT_64`/`__text` shape matches what
// `clang -c -arch arm64` produces for an empty `.s`.
//
// Layout offsets (assuming nsects=1, ncmds=3 ⇒ sizeofcmds = 256):
//   data_off  = 32 + 256 = 288     (start of __text bytes)
//   reloff    = data_off + size_4aligned(text)
//   symoff    = reloff   + 8 * nreloc
//   stroff    = symoff   + 16 * nsyms
//   total     = stroff   + strsize
fn serialize(obj: MachoArm64Obj) -> [Int] {
    let out: [Int] = []
    let text_len = len(obj.text)
    let nreloc   = len(obj.relocs)
    let nsyms    = len(obj.symbols)
    let strsize_nat = len(obj.strtab)   // natural (unpadded) merged size

    // __text is 4-byte aligned (arm64 instructions are 4 bytes each).
    let mut text_pad = 0
    let trem = text_len & 3
    if trem != 0 { text_pad = 4 - trem }
    let text_size_aligned = text_len + text_pad

    // ── Empty-input corner case (1-section, 3-LC, 288 B) ─────────
    // An `.o` with zero code bytes carries no `__HEXA` metadata
    // sections and no symbols (clang's empty-`.s` output). Keep the
    // legacy compact layout so `emit_empty` / `run_F_P0_OBJEQ_HEADER`
    // stay byte-stable.
    if text_len == 0 {
        let e_sizeofcmds = 152 + 24 + 80   // seg(1 sect) + symtab + dysymtab
        let e_data_off = 32 + e_sizeofcmds // 288
        _emit_mach_header(out, 3, e_sizeofcmds, 0)
        _emit_seg64_cmd(out, "", 0, 0, e_data_off, 0, 1)
        _emit_section_64(out, "__text", "__TEXT", 0, 0, e_data_off, 0, 0, 0, 0x80000000)
        _emit_symtab_cmd(out, e_data_off, 0, e_data_off, 0)
        _emit_dysymtab_cmd(out, 0, 0, 0, 0, 0)
        return out
    }

    // ── Full layout (clang -c parity): 3 sections + LC_BUILD_VERSION ─
    //
    // Sections, in clang's emission order:
    //   1 __text   (__TEXT) — code; align 2^2; flags PURE|SOME_INSTRUCTIONS
    //   2 __cap    (__HEXA) — capability manifest; size 0; align 2^0
    //   3 __abi    (__HEXA) — 12-byte ABI stamp; align 2^0
    // The two `__HEXA` sections are 1-byte-aligned and follow __text in
    // file order (cap is empty so cap.offset == abi.offset). Both share
    // the post-__text addr (vmaddr is contiguous: cap.addr == abi.addr ==
    // text_size_aligned, cap.size == 0).  Mirrors `asm.hexa`'s
    // `_emit_meta_section` output assembled by clang.
    let abi = _hexa_abi_stamp_bytes()
    let abi_len = len(abi)
    let meta_addr = text_size_aligned          // __cap / __abi vmaddr
    let nsects = 3
    let sizeofcmds = (72 + 80 * nsects) + 24 + 24 + 80  // seg + buildver + symtab + dysymtab
    let data_off = 32 + sizeofcmds
    // __cap (size 0) and __abi (12 B) sit immediately after __text; both
    // are 1-byte aligned so no inter-section padding.
    let meta_off = data_off + text_size_aligned   // == __cap.offset == __abi.offset
    // clang aligns the relocation table to an 8-byte file boundary: it
    // pads the section data after __abi up to the next multiple of 8.
    // (Verified: clang reloff is 536/712/616 for the corpus — all %8==0.)
    let data_end = meta_off + abi_len
    let mut reloc_pad = 0
    let drem = data_end & 7
    if drem != 0 { reloc_pad = 8 - drem }
    let reloff   = data_end + reloc_pad
    let symoff   = reloff + 8 * nreloc
    let stroff   = symoff + 16 * nsyms

    // LLVM/MCStringTableBuilder pads the string table so the file ends
    // on an 8-byte boundary (`(stroff + strsize) % 8 == 0`). Verified
    // against clang: trivial 103->104, fib 207->208, while 195->200.
    let mut str_pad = 0
    let srem = (stroff + strsize_nat) & 7
    if srem != 0 { str_pad = 8 - srem }
    let strsize = strsize_nat + str_pad

    // Partition the symbol table into [locals | extdefs | undefs] runs and
    // count each (clang's nlist is laid out + DYSYMTAB-indexed this way).
    let mut nlocal = 0
    let mut nextdef = 0
    let mut nundef = 0
    let mut sx = 0
    while sx < nsyms {
        let s = obj.symbols[sx]
        if s.is_external == 0 {
            nlocal = nlocal + 1
        } else if s.section == 0 {
            nundef = nundef + 1
        } else {
            nextdef = nextdef + 1
        }
        sx = sx + 1
    }

    // flags = 0: aprime_cc's `.s` does NOT emit `.subsections_via_symbols`
    // (the `asm.hexa` emitter omits that directive), so `clang -c` on it
    // leaves MH_SUBSECTIONS_VIA_SYMBOLS (0x2000) UNSET. Verified by
    // `xxd -s24 -l4` on the clang reference: flags == 0x00000000.
    _emit_mach_header(out, 4, sizeofcmds, 0)

    let vmsize = meta_addr + abi_len
    _emit_seg64_cmd(out, "", 0, vmsize, data_off, vmsize, nsects)

    // __text — code section.
    _emit_section_64(out, "__text", "__TEXT",
                     0, text_size_aligned,
                     data_off, 2,
                     reloff, nreloc,
                     0x80000400)
    // __cap — empty capability manifest header (size 0, align 1, no reloc).
    _emit_section_64(out, "__cap", "__HEXA",
                     meta_addr, 0,
                     meta_off, 0,
                     0, 0,
                     0x00000000)
    // __abi — 12-byte ABI stamp (align 1, no reloc).
    _emit_section_64(out, "__abi", "__HEXA",
                     meta_addr, abi_len,
                     meta_off, 0,
                     0, 0,
                     0x00000000)

    _emit_build_version_cmd(out, MACHO_PLATFORM_MACOS, MACHO_BUILD_MINOS_26)
    _emit_symtab_cmd(out, symoff, nsyms, stroff, strsize)
    _emit_dysymtab_cmd(out, nlocal, nlocal, nextdef, nlocal + nextdef, nundef)

    // __text bytes + 4-byte alignment pad
    let mut i = 0
    while i < text_len { out.push(obj.text[i] & 0xff); i = i + 1 }
    _zero_n(out, text_pad)

    // __cap is empty (no bytes). __abi: the 12-byte stamp.
    let mut ai = 0
    while ai < abi_len { out.push(abi[ai] & 0xff); ai = ai + 1 }
    // 8-byte alignment pad so the relocation table starts on an 8-byte
    // boundary (matches clang's reloff alignment).
    _zero_n(out, reloc_pad)

    // Relocations: emit one `relocation_info` per Arm64Reloc. r_extern is
    // 1 — all our relocs are symbol-based BRANCH26 to undefined externs.
    let mut ri = 0
    while ri < nreloc {
        let rl = obj.relocs[ri]
        _emit_reloc_info(out, rl.offset, rl.sym_idx, rl.pcrel, rl.length, 1, rl.kind)
        ri = ri + 1
    }

    // Symbol records (nlist_64), in [locals | extdefs | undefs] order.
    // n_type = kind | N_EXT (if external) | N_PEXT (if .private_extern).
    let mut si = 0
    while si < nsyms {
        let s = obj.symbols[si]
        let mut n_type = s.kind
        if s.is_external != 0 { n_type = n_type | MACHO_N_EXT }
        if s.is_pext != 0     { n_type = n_type | MACHO_N_PEXT }
        _emit_nlist64(out, s.name_offset, n_type, s.section, s.value)
        si = si + 1
    }

    // String table bytes (verbatim) + 8-byte file-end alignment pad.
    let mut ki = 0
    while ki < strsize_nat { out.push(obj.strtab[ki] & 0xff); ki = ki + 1 }
    _zero_n(out, str_pad)

    return out
}

// ─────────────────────────────────────────────────────────────────
// LIR walker — `LModule` → byte stream  (RFC 063 § P0, cycle 2)
// ─────────────────────────────────────────────────────────────────
//
// `pack_lir(lm)` is the second half of P0: it walks `LModule.funcs`,
// turns each `LInstr` into one 4-byte little-endian arm64 instruction
// word, and records branch / call relocations against a pending
// symbol table.
//
// Cycle 2 subset (this commit):
//
//   - register operands: `LOperand.kind == "reg"` → `reg.name`
//     (lowercase from arm64_darwin LIR; `xreg_idx` handles both cases).
//   - immediate operands: `LOperand.kind == "imm"` → `#N`.
//   - label operands on intra-function branches (`b` / `b.cond` /
//     `cbz` / `cbnz` to a `label` pseudo-op in the same `LFunc`) —
//     resolved by a name→offset map, the imm bits patched in place,
//     no relocation record emitted.
//   - the `label` pseudo-op (`op == "label"`, name in `comment` or
//     `args[0].label`) records the current `text` offset in the
//     name→offset map and emits zero bytes.
//
// Out of scope (next cycles):
//
//   - mem operands with offsets (`[sp, #16]`, pre/post-index frame
//     ops) — need additional encoding rules in `encode_arm64_insn`
//     (cycle 3).
//   - extern-symbol branches / calls (`BL _main`, `ADRP _sym@PAGE`)
//     and the corresponding `Arm64Reloc` records (cycle 4).
//   - `LInstr` ops outside the 16 encoding rules currently in
//     `encode_arm64_insn` (cycle 3 fills out the table).
//
// Walker is silent on unsupported ops: it emits a sentinel 0x00000000
// word so the byte stream stays length-correct and `otool -d` shows
// the gap. A diagnostic counter (`pack_unhandled_ops`) is reserved
// for the next cycle when the wiring decides whether to hard-error
// on an unhandled op or fall back to `.s` + `as`.

fn _lir_op_uppercase(op: string) -> string {
    // arm64_darwin LIR uses lowercase mnemonics; encode_arm64_insn's
    // table is keyed on the canonical uppercase ARM ARM spelling.
    // Hand-mapped table — small, stable, faster + clearer than calling
    // a generic to_upper() pass.
    if op == "mov"   { return "MOV"  }
    if op == "movz"  { return "MOVZ" }
    if op == "movk"  { return "MOVK" }
    if op == "add"   { return "ADD"  }
    if op == "sub"   { return "SUB"  }
    if op == "mul"   { return "MUL"  }
    if op == "cmp"   { return "CMP"  }
    if op == "ldr"   { return "LDR"  }
    if op == "str"   { return "STR"  }
    if op == "ldp"   { return "LDP"  }
    if op == "stp"   { return "STP"  }
    if op == "b"     { return "B"    }
    if op == "bl"    { return "BL"   }
    if op == "ret"   { return "RET"  }
    if op == "cbz"   { return "CBZ"  }
    if op == "cbnz"  { return "CBNZ" }
    if op == "uxtw"  { return "UXTW" }
    if op == "uxtb"  { return "UXTB" }
    if op == "uxth"  { return "UXTH" }
    if op == "sxtw"  { return "SXTW" }
    if op == "sxtb"  { return "SXTB" }
    if op == "sxth"  { return "SXTH" }
    if op == "ubfm"  { return "UBFM" }
    if op == "sbfm"  { return "SBFM" }
    if op == "lsl"   { return "LSL"  }
    if op == "lsr"   { return "LSR"  }
    if op == "asr"   { return "ASR"  }
    if op == "cset"  { return "CSET" }
    if op == "csel"  { return "CSEL" }
    // Conditional branch: `b.eq` -> `B.EQ`. The encoder reads the
    // condition from the suffix; uppercasing the whole token preserves
    // the dot.
    if len(op) > 2 && op.substring(0, 2) == "b." {
        let cc = op.substring(2, len(op))
        let mut up = ""
        let mut i = 0
        while i < len(cc) {
            let c = char_code(cc, i)
            if c >= 97 && c <= 122 { up = up + from_char_code(c - 32) } else { up = up + cc.substring(i, i + 1) }
            i = i + 1
        }
        return "B." + up
    }
    // Unknown — pass through; the encoder returns 0 and the walker
    // emits the sentinel word for follow-up triage.
    return op
}

fn _lir_operand_str(op: LOperand) -> string {
    if op.kind == "reg"   { return op.reg.name }
    if op.kind == "imm"   { return "#" + to_string(op.imm) }
    if op.kind == "label" { return op.label }
    if op.kind == "mem" {
        // Format mirrors `compiler/emit/asm.hexa::_fmt_mem` for darwin
        // arm64: `[base, #offset]`. The encoder splits this back out
        // via `_parse_mem_op` when it sees a leading "[".
        return "[" + op.mem_base.name + ", #" + to_string(op.mem_offset) + "]"
    }
    return "<?" + op.kind + "?>"
}

// Parse a mem-operand string back to `[base_reg_idx, offset, mode]`.
// Recognized forms (arm64 LIR convention, matching `_fmt_label`'s
// carve-out for `[…]` literals):
//
//   `[Xn]`            -> mode 0 (offset, off=0)
//   `[Xn, #imm]`      -> mode 0 (offset)
//   `[Xn, #imm]!`     -> mode 1 (pre-index, writeback after)
//   `[Xn], #imm`      -> mode 2 (post-index, writeback before)
//
// Returns `[-1, 0, 0]` if the shape is not recognized.
fn _parse_mem_op(s: string) -> [Int] {
    let n = len(s)
    if n < 3 || s.substring(0, 1) != "[" { return [-1, 0, 0] }

    // Detect post-index: `[Xn], #imm` — closing `]` followed by `, #imm`.
    let mut close = -1
    let mut p = 0
    while p < n {
        if s.substring(p, p + 1) == "]" { close = p; break }
        p = p + 1
    }
    if close < 0 { return [-1, 0, 0] }
    let inner = s.substring(1, close)

    // Tail after `]`: either empty, `!` (pre-index), or `, #imm`
    // (post-index). Anything else is unrecognized.
    let tail = s.substring(close + 1, n)
    let tail_n = len(tail)

    // Split inner on the first ", " to get base and inline-offset (if
    // any). For the post-index form, `inner` is just `Xn` (no comma).
    let inn = len(inner)
    let mut comma = -1
    let mut i = 0
    while i < inn {
        if inner.substring(i, i + 1) == "," { comma = i; break }
        i = i + 1
    }
    let mut base = inner
    let mut inline_imm: Int = 0
    let mut has_inline_imm = false
    if comma >= 0 {
        base = inner.substring(0, comma)
        let rest = inner.substring(comma + 1, inn)
        let nr = len(rest)
        let mut j = 0
        while j < nr && rest.substring(j, j + 1) == " " { j = j + 1 }
        if j < nr && rest.substring(j, j + 1) == "#" { j = j + 1 }
        if j < nr {
            inline_imm = rest.substring(j, nr).to_int()
            has_inline_imm = true
        }
    }
    let rn = xreg_idx(base)
    if rn < 0 { return [-1, 0, 0] }

    if tail_n == 0 {
        return [rn, inline_imm, 0]   // offset-form
    }
    if tail == "!" {
        return [rn, inline_imm, 1]   // pre-index, writeback
    }
    // Post-index: tail looks like `, #imm` (or `, #-imm`).
    if tail.substring(0, 1) == "," {
        let post = tail.substring(1, tail_n)
        let pn = len(post)
        let mut j = 0
        while j < pn && post.substring(j, j + 1) == " " { j = j + 1 }
        if j < pn && post.substring(j, j + 1) == "#" { j = j + 1 }
        if j >= pn { return [-1, 0, 0] }
        let imm = post.substring(j, pn).to_int()
        return [rn, imm, 2]
    }
    return [-1, 0, 0]
}

// State carried while walking one LFunc. label_names / label_offsets
// are parallel arrays (no map-of-string in scope here); intra-fn
// branch resolution does a linear scan on this short list.
struct PackFnState {
    text:          [Int],
    label_names:   [string],
    label_offsets: [Int],
    unresolved_brs: [Int],         // text offsets of branches needing fixup
    unresolved_to:  [string],      // target label name per branch
}

fn _lookup_label(state: PackFnState, name: string) -> Int {
    let n = len(state.label_names)
    let mut i = 0
    while i < n {
        if state.label_names[i] == name { return state.label_offsets[i] }
        i = i + 1
    }
    return -1
}

// True if `name` already appears in `xs`. Linear scan — `xs` is the
// short per-module block-label reference-order list.
fn _str_in(xs: [string], name: string) -> bool {
    let n = len(xs)
    let mut i = 0
    while i < n {
        if xs[i] == name { return true }
        i = i + 1
    }
    return false
}

// Look up a label's __text offset in the parallel name/offset arrays.
// Returns -1 if absent.
fn _blabel_offset_of(names: [string], offsets: [Int], name: string) -> Int {
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] == name { return offsets[i] }
        i = i + 1
    }
    return -1
}

// Append a 4-byte little-endian instruction word to the running text
// buffer. Used by every encoded instruction path in `_pack_fn`.
fn _push_word_le(out: [Int], word: Int) {
    out.push(word & 0xff)
    out.push((word >> 8) & 0xff)
    out.push((word >> 16) & 0xff)
    out.push((word >> 24) & 0xff)
}

// Patch a 32-bit word in the text buffer at byte offset `off`. Reads
// the existing word (4 LE bytes), ORs the imm bits in, writes back.
// Used after the full function is walked to resolve intra-fn branches
// once every label offset is known.
fn _patch_word_le(out: [Int], off: Int, word: Int) {
    out[off + 0] = word & 0xff
    out[off + 1] = (word >> 8) & 0xff
    out[off + 2] = (word >> 16) & 0xff
    out[off + 3] = (word >> 24) & 0xff
}

// Append the ASCII bytes of `s` plus a trailing NUL to `out`. Returns
// the byte offset of the first byte appended — used to seed
// `MachoSymbol.name_offset` for the just-written name.
fn _push_cstr(out: [Int], s: string) -> Int {
    let off = len(out)
    let n = len(s)
    let mut i = 0
    while i < n {
        out.push(char_code(s, i) & 0xff)
        i = i + 1
    }
    out.push(0)
    return off
}

// ── MCStringTableBuilder suffix-merge string interning ──────────────
//
// clang/LLVM builds the Mach-O string table via `MCStringTableBuilder`
// (StringTableBuilder.cpp::finalizeStringTable). Names are NOT laid out
// in symbol order; instead:
//
//   1. A leading NUL occupies index 0 (the empty string).
//   2. The unique names are sorted by their bytes read RIGHT-TO-LEFT
//      (reversed-string lexicographic), DESCENDING. This groups every
//      string that shares a common suffix adjacently, longest-tail
//      first.
//   3. SUFFIX MERGE: when a string is a suffix of its immediate
//      predecessor in that order, it does NOT get its own bytes — its
//      offset is the predecessor's offset shifted by the length
//      difference (it reuses the predecessor's trailing bytes, NUL and
//      all). Otherwise it appends `<name>\0` and takes the new offset.
//
// `_macho_string_offset_of(names, name)` returns the merged offset of
// `name`; `_build_merged_strtab(out, names)` fills `out` with the
// merged byte buffer (NATURAL size — the trailing 8-byte file-end pad
// is applied later in `serialize`, which is the only place that knows
// `stroff`). Verified byte-for-byte against Apple clang 21.0.0 on the
// {trivial, fib, while} F-P0-OBJEQ corpus (every n_strx + the natural
// strsize match exactly).
//
// Reversed-string comparison: returns true if reverse(a) > reverse(b),
// i.e. `a` sorts BEFORE `b` in the descending-reversed order.
fn _rev_str_gt(a: string, b: string) -> bool {
    let la = len(a)
    let lb = len(b)
    let mut ia = la - 1
    let mut ib = lb - 1
    while ia >= 0 && ib >= 0 {
        let ca = char_code(a, ia) & 0xff
        let cb = char_code(b, ib) & 0xff
        if ca != cb { return ca > cb }
        ia = ia - 1
        ib = ib - 1
    }
    // One is a suffix of the other (shared all overlapping bytes).
    // The LONGER string sorts first (descending) so its suffix can
    // tail-merge into it.
    return la > lb
}

// In-place insertion sort of `xs` by `_rev_str_gt` (descending reversed
// string). Stable enough for the short symbol-name lists here.
fn _sort_rev_desc(xs: [string]) {
    let n = len(xs)
    let mut i = 1
    while i < n {
        let key = xs[i]
        let mut j = i - 1
        while j >= 0 && _rev_str_gt(key, xs[j]) {
            xs[j + 1] = xs[j]
            j = j - 1
        }
        xs[j + 1] = key
        i = i + 1
    }
}

// True iff `suf` is a (proper-or-equal) suffix of `s`.
fn _ends_with(s: string, suf: string) -> bool {
    let ls = len(s)
    let lf = len(suf)
    if lf > ls { return false }
    let mut k = 0
    while k < lf {
        if (char_code(s, ls - lf + k) & 0xff) != (char_code(suf, k) & 0xff) {
            return false
        }
        k = k + 1
    }
    return true
}

// Build the suffix-merged string table for `names` into `out` (starting
// with the index-0 NUL) and return a parallel `[Int]` of each input
// `names[i]`'s merged offset, in the SAME order as `names`.
fn _build_merged_strtab(out: [Int], names: [string]) -> [Int] {
    // Unique names, first-seen order preserved (only used to drive the
    // sort; the returned offsets map back to the original `names`).
    let uniq: [string] = []
    let mut i = 0
    while i < len(names) {
        if !_str_in(uniq, names[i]) { uniq.push(names[i]) }
        i = i + 1
    }
    _sort_rev_desc(uniq)

    // Index-0 NUL (empty string).
    out.push(0)

    // Assign a merged offset to each unique name, tail-merging suffixes.
    let uniq_off: [Int] = []
    let mut u = 0
    while u < len(uniq) {
        let s = uniq[u]
        if u > 0 && _ends_with(uniq[u - 1], s) {
            // `s` is a suffix of its predecessor: reuse the tail.
            let prev_off = uniq_off[u - 1]
            uniq_off.push(prev_off + (len(uniq[u - 1]) - len(s)))
        } else {
            uniq_off.push(len(out))
            let mut c = 0
            while c < len(s) { out.push(char_code(s, c) & 0xff); c = c + 1 }
            out.push(0)
        }
        u = u + 1
    }

    // Map each input name (in original order) to its unique offset.
    let result: [Int] = []
    i = 0
    while i < len(names) {
        let idx = _index_of_str(uniq, names[i])
        result.push(uniq_off[idx])
        i = i + 1
    }
    return result
}

// Index of `name` in `xs` (-1 if absent).
fn _index_of_str(xs: [string], name: string) -> Int {
    let mut i = 0
    while i < len(xs) {
        if xs[i] == name { return i }
        i = i + 1
    }
    return -1
}

// Darwin Mach-O symbol-name convention: every C/hexa symbol carries
// a leading `_` in the object file. Mirrors `compiler/emit/asm.hexa
// ::_fmt_label` for `_is_darwin(target)`.
fn _darwin_mangle(name: string) -> string {
    return "_" + name
}

// Darwin label mangle, matching `asm.hexa::_fmt_label`: prepend `_`
// UNCONDITIONALLY (injective — `_L…` → `__L…`) except for directive-
// like / addressing / reg-list / immediate literals. Block labels from
// arm64_darwin are `_L<hash>_<fn>_bb<n>`; the assembled symbol is the
// `_`-prefixed form. (The native path uses raw names for intra-fn
// branch resolution and the mangled form only for the symbol record.)
fn _darwin_mangle_label(label: string) -> string {
    if len(label) == 0 { return label }
    let first = label.substring(0, 1)
    if first == "." { return label }
    if first == "[" { return label }
    if first == "{" { return label }
    if first == "#" { return label }
    return "_" + label
}

// Walk one LFunc, append its instructions to `out_text`, record any
// label offsets, and resolve all intra-function branches.
//
// Out-params (cycle 4):
//   pending_offsets[] / pending_names[] — parallel arrays for branch
//   targets the intra-fn label table does not resolve. pack_lir's
//   post-walk pass turns each pair into an Arm64Reloc record (by
//   looking up `name` in obj.symbols).
// Out-params (symtab layout):
//   blabel_names[] / blabel_offsets[] — every intra-fn `label` op's
//     mangled name + __text byte offset, in DEFINITION order. pack_lir
//     turns these into local N_SECT symbols.
//   blabel_reforder[] — the SAME label names, but in FIRST-BRANCH-
//     REFERENCE order (the order each label is first used as a branch
//     target). clang/LLVM-MC orders block-label local symbols this way;
//     pack_lir uses it (with the entry label first) to match clang's
//     local-symbol ordering so `r_symbolnum` lines up. The entry block
//     (first-defined) is prepended by pack_lir.
fn _pack_fn(out_text: [Int],
            pending_offsets: [Int], pending_names: [string],
            blabel_names: [string], blabel_offsets: [Int],
            blabel_reforder: [string],
            f: LFunc) {
    let st = PackFnState {
        text:           out_text,
        label_names:    [],
        label_offsets:  [],
        unresolved_brs: [],
        unresolved_to:  [],
    }
    let n = len(f.instrs)
    let base = len(out_text)
    let mut i = 0
    while i < n {
        let ins = f.instrs[i]
        if ins.op == "label" {
            let mut name = ins.comment
            if len(name) == 0 && len(ins.args) > 0 { name = ins.args[0].label }
            st.label_names.push(name)
            st.label_offsets.push(len(out_text))
            // Export the label (mangled) + its __text offset for the
            // symbol-table pass. arm64_darwin label names already carry
            // the darwin `_` / `__L…` form, so emit verbatim.
            blabel_names.push(name)
            blabel_offsets.push(len(out_text))
            i = i + 1
            continue
        }

        // Format operands to the [string] form encode_arm64_insn expects.
        let mut ops: [string] = []
        let na = len(ins.args)
        let mut k = 0
        while k < na {
            ops.push(_lir_operand_str(ins.args[k]))
            k = k + 1
        }

        let up = _lir_op_uppercase(ins.op)
        let word = encode_arm64_insn(up, ops)
        let cur_off = len(out_text)

        // Branch targets: encoder emits the bare base bit-pattern;
        // intra-fn imm26 / imm19 / B.cond imm19 are patched below.
        // Track which instructions need patching by op shape.
        if (up == "B" || up == "BL") && na == 1 && ins.args[0].kind == "label" {
            _push_word_le(out_text, word)
            st.unresolved_brs.push(cur_off)
            st.unresolved_to.push(ins.args[0].label)
            i = i + 1
            continue
        }
        if up == "CBZ" || up == "CBNZ" {
            // CBZ Xt, label — label is args[1]
            if na == 2 && ins.args[1].kind == "label" {
                _push_word_le(out_text, word)
                st.unresolved_brs.push(cur_off)
                st.unresolved_to.push(ins.args[1].label)
                i = i + 1
                continue
            }
        }
        if len(up) > 2 && up.substring(0, 2) == "B." && na == 1 && ins.args[0].kind == "label" {
            _push_word_le(out_text, word)
            st.unresolved_brs.push(cur_off)
            st.unresolved_to.push(ins.args[0].label)
            i = i + 1
            continue
        }

        _push_word_le(out_text, word)
        i = i + 1
    }

    // Resolve intra-fn branches. imm26 (B/BL) is bits [25:0] of word,
    // multiplied by 4; imm19 (CBZ/CBNZ/B.cond) is bits [23:5] * 4.
    // Unresolved targets (cross-fn / extern) get pushed to pending_*
    // out-params; pack_lir's post-walk turns them into reloc records.
    let nb = len(st.unresolved_brs)
    let mut bi = 0
    while bi < nb {
        let off    = st.unresolved_brs[bi]
        let target = st.unresolved_to[bi]
        let toff   = _lookup_label(st, target)
        if toff < 0 {
            // Extern target — leave bare bit-pattern (imm26/imm19 = 0)
            // in place; the linker patches it via the relocation record
            // pack_lir emits from these pending lists.
            pending_offsets.push(off)
            pending_names.push(target)
            bi = bi + 1
            continue
        }
        // Intra-fn label resolved here → this is its first branch
        // reference if not already recorded. Collect in reference order
        // (deduped) so pack_lir can order the local block-label symbols
        // the way clang/LLVM-MC does.
        if !_str_in(blabel_reforder, target) {
            blabel_reforder.push(target)
        }
        let delta = (toff - off) / 4    // PC-rel instruction-count
        // Reconstruct the existing word bits.
        let w0 = out_text[off + 0]
        let w1 = out_text[off + 1]
        let w2 = out_text[off + 2]
        let w3 = out_text[off + 3]
        let cur = w0 | (w1 << 8) | (w2 << 16) | (w3 << 24)
        // Distinguish B/BL (high 6 bits = 0b000101 or 0b100101) from
        // CBZ/CBNZ/B.cond (imm19). The encoder gave the upper bits;
        // we OR the imm into the right field.
        let top = (cur >> 26) & 0x3f
        if top == 0x05 || top == 0x25 {
            // B / BL → imm26 = delta & 0x03ffffff
            let patched = (cur & 0xfc000000) | (delta & 0x03ffffff)
            _patch_word_le(out_text, off, patched)
        } else {
            // CBZ / CBNZ / B.cond → imm19 at bits [23:5]
            let imm19 = delta & 0x7ffff
            let patched = (cur & 0xff00001f) | (imm19 << 5)
            _patch_word_le(out_text, off, patched)
        }
        bi = bi + 1
    }
}

// Find the index of a symbol in `symbols[]` whose name-string (read
// out of `strtab` via `name_offset`) matches `mangled`. Returns -1 if
// no match — caller treats that as a missing-symbol bug.
fn _find_sym_by_name(symbols: [MachoSymbol], strtab: [Int], mangled: string) -> Int {
    let ns = len(symbols)
    let ml = len(mangled)
    let mut i = 0
    while i < ns {
        let off = symbols[i].name_offset
        let mut k = 0
        let mut ok = true
        while k < ml {
            if (strtab[off + k] & 0xff) != char_code(mangled, k) { ok = false; break }
            k = k + 1
        }
        // Match also requires the terminating NUL at the right spot —
        // guards against "_foo" matching the prefix of "_foobar".
        if ok && (strtab[off + ml] & 0xff) == 0 { return i }
        i = i + 1
    }
    return -1
}

// Public entry — walk all LFuncs in `lm`, produce a `MachoArm64Obj`
// with `text` + `symbols` + `strtab` + `relocs` populated.
//
// Symbol table contract (cycle 3):
//   - First byte of `strtab` is NUL (Mach-O index-0 convention).
//   - Each `LFunc` produces one `MachoSymbol` with:
//       name_offset = strtab offset of `_<fn.name>\0` (darwin mangle)
//       section     = 1 (1-based index for __text)
//       value       = byte offset of fn start within __text
//       kind        = 0x0e (N_SECT — defined in a section)
//       is_external = 1 (N_EXT — externally visible)
//   - LC_DYSYMTAB.nextdefsym counts these; `serialize` derives it.
//
// Relocation contract (cycle 4):
//   - Each unresolved branch / call target (intra-fn label miss) in
//     any `LFunc` becomes one `Arm64Reloc` with:
//       offset   = __text byte offset of the patched instruction
//       sym_idx  = index into `symbols[]` of the target symbol
//                  (post-walk lookup by mangled name)
//       kind     = ARM64_RELOC_BRANCH26 (= 2) for B/BL targets
//       pcrel    = 1
//       length   = 2 (log2 of 4-byte instruction)
//   - `serialize()` hardcodes `r_extern=1` (we only emit symbol-based
//     relocs in cycle 4; section-based relocations enter in cycle 5).
//   - Intra-module callees (the target is one of `symbols[]`) and
//     external undefined symbols both share this path; symbol-table
//     layout decides which is which (cycle 4 ships defined-only; the
//     N_UNDF undef record path lands when a real frontend supplies an
//     undefined target).
pub fn pack_lir(lm: LModule) -> MachoArm64Obj {
    let obj = MachoArm64Obj {
        text:       [],
        relocs:     [],
        symbols:    [],
        strtab:     [],
        dwarf_line: [],
    }

    // ── Pass 1: walk every LFunc → text bytes + collect symbol inputs ──
    //
    // We defer ALL symbol-table construction until the walk is done so
    // the table can be laid out in clang/LLVM-MC's order (locals, then
    // defined-externs, then undefs) — required for `r_symbolnum` parity.
    let pending_offsets: [Int]    = []   // __text offset of each extern BL
    let pending_names:   [string] = []   // target name per extern BL
    let blabel_names:    [string] = []   // every block label (def order)
    let blabel_offsets:  [Int]    = []   // its __text offset
    let blabel_reforder: [string] = []   // labels in first-branch-ref order
    let fn_names:        [string] = []   // mangled fn symbol names
    let fn_values:       [Int]    = []   // fn start offset in __text
    let fn_is_entry:     [Int]    = []   // 1 if main/_start (no N_PEXT)

    let nf = len(lm.funcs)
    let mut i = 0
    while i < nf {
        let f = lm.funcs[i]
        fn_names.push(_darwin_mangle(f.name))
        fn_values.push(len(obj.text))
        if _is_entry_symbol_name(f.name) { fn_is_entry.push(1) } else { fn_is_entry.push(0) }
        _pack_fn(obj.text, pending_offsets, pending_names,
                 blabel_names, blabel_offsets, blabel_reforder, f)
        i = i + 1
    }

    let text_len = len(obj.text)
    let mut text_pad = 0
    let trem = text_len & 3
    if trem != 0 { text_pad = 4 - trem }
    let meta_addr = text_len + text_pad     // __cap / __abi vmaddr (== abi value)

    // ── Pass 2: partition extern BL targets into intra-module-defined
    // (pre-patch, no reloc) vs undefined (sorted, get a reloc). ──
    //
    // Defined intra-module callees: BL imm26 resolved at emit time, NO
    // reloc (matches clang). Undefined externs (libc/runtime _hexa_*):
    // imm26 stays 0, a BRANCH26 reloc carries the symbol — and clang
    // emits the undef symbols ALPHABETICALLY, so we sort them and the
    // reloc `r_symbolnum` references that sorted slot.
    let undef_names: [string] = []
    let mut pi = 0
    let np = len(pending_offsets)
    while pi < np {
        let raw = pending_names[pi]
        let mut name = raw
        if len(raw) > 0 && raw.substring(0, 1) != "_" { name = _darwin_mangle(raw) }
        // Defined intra-module target? (one of this module's fns)
        if _str_in(fn_names, name) {
            pi = pi + 1
            continue
        }
        if !_str_in(undef_names, name) { undef_names.push(name) }
        pi = pi + 1
    }
    _sort_strings(undef_names)   // alphabetical — matches clang's undef order

    // ── Pass 3: build the symbol table in clang's order ──
    //
    //   LOCALS (n_type N_SECT, no N_EXT):
    //     ltmp0                 (__text, value 0)        — section-start temp
    //     <block labels>        (__text)  in first-ref order, entry-first
    //     ltmp1                 (__cap,  value meta_addr)
    //     _hexa_cap_manifest    (__cap,  value meta_addr)
    //     ltmp2                 (__abi,  value meta_addr)
    //     _hexa_abi_stamp       (__abi,  value meta_addr)
    //   EXTDEFS (N_SECT|N_EXT [|N_PEXT for non-entry]):
    //     each fn, in address order
    //   UNDEFS (N_UNDF|N_EXT), alphabetical:
    //     each runtime/libc target
    //
    // strtab is NOT built name-by-name in symbol order any more: we
    // collect every symbol's name into `sym_names` (parallel to
    // `obj.symbols`) with a placeholder `name_offset`, then after the
    // table is complete run `_build_merged_strtab` — clang/LLVM's
    // MCStringTableBuilder suffix-merge interning — to lay out the
    // bytes and assign each `n_strx` to its merged offset. This makes
    // the strtab byte-order + every `n_strx` + the natural `strsize`
    // byte-identical to clang (the symbol IDENTITIES, ORDER, n_type/
    // n_sect/n_value, and `r_symbolnum` indices already matched).
    let sym_names: [string] = []

    // ltmp0 (__text section-start temp).
    _push_local_sym(obj, sym_names, "ltmp0", 1, 0)

    // Block labels: entry (first-defined) first, then first-ref order.
    let ordered_labels: [string] = []
    if len(blabel_names) > 0 {
        ordered_labels.push(blabel_names[0])   // entry block (bb0)
    }
    let mut li = 0
    while li < len(blabel_reforder) {
        let nm = blabel_reforder[li]
        if !_str_in(ordered_labels, nm) { ordered_labels.push(nm) }
        li = li + 1
    }
    // Any defined-but-never-branched labels: append in definition order
    // (defensive — keeps every label represented).
    li = 0
    while li < len(blabel_names) {
        let nm = blabel_names[li]
        if !_str_in(ordered_labels, nm) { ordered_labels.push(nm) }
        li = li + 1
    }
    li = 0
    while li < len(ordered_labels) {
        let nm  = ordered_labels[li]
        let voff = _blabel_offset_of(blabel_names, blabel_offsets, nm)
        // The block-label SYMBOL name carries the darwin mangle the `.s`
        // path applies via `_fmt_label` (prepend `_`): LIR stores
        // `_L<hash>_<fn>_bb<n>`, the symbol is `__L<hash>…`. The raw
        // form (`nm`) is kept only for offset/reference lookup above.
        _push_local_sym(obj, sym_names, _darwin_mangle_label(nm), 1, voff)
        li = li + 1
    }

    // __HEXA section local symbols (cap then abi; ltmpN temp precedes
    // the named label in each, matching clang's per-section temp).
    _push_local_sym(obj, sym_names, "ltmp1",              2, meta_addr)
    _push_local_sym(obj, sym_names, "_hexa_cap_manifest", 2, meta_addr)
    _push_local_sym(obj, sym_names, "ltmp2",              3, meta_addr)
    _push_local_sym(obj, sym_names, "_hexa_abi_stamp",    3, meta_addr)

    // Defined externs (functions) — address order, N_PEXT for non-entry.
    let mut fi = 0
    while fi < len(fn_names) {
        let mut pext = 1
        if fn_is_entry[fi] != 0 { pext = 0 }
        sym_names.push(fn_names[fi])
        obj.symbols.push(MachoSymbol {
            name_offset: -1,
            section:     1,
            value:       fn_values[fi],
            kind:        MACHO_N_SECT,
            is_external: 1,
            is_pext:     pext,
        })
        fi = fi + 1
    }

    // Undefined externs — alphabetical (sorted above).
    let mut ui = 0
    while ui < len(undef_names) {
        sym_names.push(undef_names[ui])
        obj.symbols.push(MachoSymbol {
            name_offset: -1,
            section:     0,
            value:       0,
            kind:        MACHO_N_UNDF,
            is_external: 1,
            is_pext:     0,
        })
        ui = ui + 1
    }

    // ── Pass 3b: MCStringTableBuilder suffix-merge interning ──
    //
    // All symbol records are placed; lay out the merged string table
    // and back-patch every `name_offset` to its merged offset (clang
    // byte-order). `obj.strtab` is left at its NATURAL size — the
    // trailing 8-byte file-end pad is applied in `serialize`, the only
    // place that knows `stroff`.
    let merged_offs = _build_merged_strtab(obj.strtab, sym_names)
    let mut mi = 0
    while mi < len(obj.symbols) {
        let s = obj.symbols[mi]
        obj.symbols[mi] = MachoSymbol {
            name_offset: merged_offs[mi],
            section:     s.section,
            value:       s.value,
            kind:        s.kind,
            is_external: s.is_external,
            is_pext:     s.is_pext,
        }
        mi = mi + 1
    }

    // ── Pass 4: resolve branches; emit relocs (descending address) ──
    let reloc_offs: [Int] = []
    let reloc_idxs: [Int] = []
    pi = 0
    while pi < np {
        let off = pending_offsets[pi]
        let raw = pending_names[pi]
        let mut name = raw
        if len(raw) > 0 && raw.substring(0, 1) != "_" { name = _darwin_mangle(raw) }
        let idx = _find_sym_by_name(obj.symbols, obj.strtab, name)
        let sym = obj.symbols[idx]
        if sym.section != 0 {
            // Intra-module defined callee: pre-patch imm26, no reloc.
            let delta = (sym.value - off) / 4
            let w0 = obj.text[off + 0]
            let w1 = obj.text[off + 1]
            let w2 = obj.text[off + 2]
            let w3 = obj.text[off + 3]
            let cur = w0 | (w1 << 8) | (w2 << 16) | (w3 << 24)
            let patched = (cur & 0xfc000000) | (delta & 0x03ffffff)
            _patch_word_le(obj.text, off, patched)
        } else {
            reloc_offs.push(off)
            reloc_idxs.push(idx)
        }
        pi = pi + 1
    }
    // Flush extern relocs in DESCENDING address order (clang's __text
    // relocation table is emitted high-address-first).
    let nr = len(reloc_offs)
    let mut ri = nr - 1
    while ri >= 0 {
        obj.relocs.push(Arm64Reloc {
            offset:  reloc_offs[ri],
            sym_idx: reloc_idxs[ri],
            kind:    MACHO_ARM64_RELOC_BRANCH26,
            pcrel:   1,
            length:  2,
        })
        ri = ri - 1
    }
    return obj
}

// Push one local (N_SECT, non-external) symbol. The name is appended
// to `sym_names` (parallel to `obj.symbols`); `name_offset` is a
// placeholder (-1) back-patched after `_build_merged_strtab`. Used for
// ltmp* temps, block labels, and the `__HEXA` section symbols.
fn _push_local_sym(obj: MachoArm64Obj, sym_names: [string], name: string, section: Int, value: Int) {
    sym_names.push(name)
    obj.symbols.push(MachoSymbol {
        name_offset: -1,
        section:     section,
        value:       value,
        kind:        MACHO_N_SECT,
        is_external: 0,
        is_pext:     0,
    })
}

// In-place ASCII ascending sort (insertion sort — the undef list is
// short: one entry per distinct runtime/libc call). Matches clang's
// alphabetical undef-symbol ordering.
fn _sort_strings(xs: [string]) {
    let n = len(xs)
    let mut i = 1
    while i < n {
        let key = xs[i]
        let mut j = i - 1
        while j >= 0 && xs[j] > key {
            xs[j + 1] = xs[j]
            j = j - 1
        }
        xs[j + 1] = key
        i = i + 1
    }
}

// ─────────────────────────────────────────────────────────────────
// Notes for the P0 implementation sub-agent
// ─────────────────────────────────────────────────────────────────
//
// 1. `compiler/codegen/arm64_darwin.hexa` already chose registers
//    (linear-scan regalloc) and instruction mnemonics. Do NOT
//    re-decide; just encode what is there.
//
// 2. `compiler/emit/asm.hexa` emits the same instructions as `.s`
//    text. Mirror its structure (per-function loop, per-stmt switch)
//    and replace each `out = out + "<asm string>\n"` with a call to
//    `encode_arm64_insn(op, operands)` + append-bytes to `text`.
//
// 3. F-P0-OBJEQ falsifier corpus is in RFC 063 § P0; build it under
//    `compiler/test/macho_p0_corpus/` when implementing.
//
// 4. After F-P0-OBJEQ passes, wire into `compiler/main.hexa` next to
//    the existing `--emit=asm` arm: add `--emit=obj` that calls
//    `emit_macho_arm64` instead of `emit_asm` + `as`.
//
// 5. The `as` fork at `compiler/main.hexa:806` remains the fallback
//    until F-P0-OBJEQ corpus stabilizes; flip after.
