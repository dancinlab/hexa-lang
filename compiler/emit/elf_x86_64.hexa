// compiler/emit/elf_x86_64.hexa
//
// RFC 063 § P2 — ELF x86_64 relocatable object emitter.
//
// Mirror of `compiler/emit/macho_arm64.hexa` (P0) for the Linux
// platform. Emits ELF64 little-endian `.o` files for x86_64 from a
// flat byte-text + symbol/reloc model.
//
// STATUS: P2 cycle 1 — header + minimum section headers serialize.
// x86_64 instruction encoding follows. No code-signing on Linux →
// P2 achieves RFC 063 § P3's "zero external fork" goal more cleanly.

// ELF64 constants — `ELF_` prefix to avoid macro collision with any
// `<elf.h>` headers a future runtime.c might pull in.

let ELF_EI_MAG0           = 0x7F
let ELF_EI_MAG1           = 0x45    // 'E'
let ELF_EI_MAG2           = 0x4C    // 'L'
let ELF_EI_MAG3           = 0x46    // 'F'
let ELF_ELFCLASS64        = 2
let ELF_ELFDATA2LSB       = 1       // little-endian
let ELF_EV_CURRENT        = 1
let ELF_ELFOSABI_NONE     = 0       // System V

let ELF_ET_REL            = 1       // relocatable object
let ELF_ET_EXEC           = 2
let ELF_ET_DYN            = 3

let ELF_EM_X86_64         = 0x3E
let ELF_EM_AARCH64        = 0xB7

let ELF_SHT_NULL          = 0
let ELF_SHT_PROGBITS      = 1
let ELF_SHT_SYMTAB        = 2
let ELF_SHT_STRTAB        = 3
let ELF_SHT_RELA          = 4
let ELF_SHT_NOBITS        = 8

let ELF_SHF_WRITE         = 0x1
let ELF_SHF_ALLOC         = 0x2
let ELF_SHF_EXECINSTR     = 0x4

let ELF_STB_LOCAL         = 0
let ELF_STB_GLOBAL        = 1
let ELF_STT_NOTYPE        = 0
let ELF_STT_FUNC          = 2

let ELF_R_X86_64_NONE     = 0
let ELF_R_X86_64_64       = 1
let ELF_R_X86_64_PC32     = 2
let ELF_R_X86_64_PLT32    = 4

struct ElfX86Obj {
    text:    [u8],
    relocs:  [ElfRel],
    symbols: [ElfSym],
    strtab:  [u8],
}

struct ElfRel {
    offset:  i64,
    sym_idx: i64,
    kind:    i64,
    addend:  i64,
}

struct ElfSym {
    name_offset: i64,
    section:     i64,
    value:       i64,
    size:        i64,
    bind:        i64,
    type_:       i64,
}

fn _ew_u16(out: [Int], v: Int) {
    out.push(v & 0xFF); out.push((v >> 8) & 0xFF)
}
fn _ew_u32(out: [Int], v: Int) {
    out.push(v & 0xFF); out.push((v >> 8) & 0xFF)
    out.push((v >> 16) & 0xFF); out.push((v >> 24) & 0xFF)
}
fn _ew_u64(out: [Int], v: Int) {
    out.push(v & 0xFF); out.push((v >> 8) & 0xFF)
    out.push((v >> 16) & 0xFF); out.push((v >> 24) & 0xFF)
    out.push((v >> 32) & 0xFF); out.push((v >> 40) & 0xFF)
    out.push((v >> 48) & 0xFF); out.push((v >> 56) & 0xFF)
}
fn _ew_zero(out: [Int], n: Int) {
    let mut i = 0
    while i < n { out.push(0); i = i + 1 }
}
fn _ew_str(out: [Int], s: string) -> Int {
    let off = len(out)
    let n = len(s)
    let mut i = 0
    while i < n { out.push(char_code(s, i) & 0xFF); i = i + 1 }
    out.push(0)
    return off
}

// ─────────────────────────────────────────────────────────────────
// x86_64 instruction encoding — P2 cycle 2
// ─────────────────────────────────────────────────────────────────
//
// `encode_x86_64_insn(op, ops) -> [Int]` returns a *variable-length*
// byte array (unlike arm64's fixed 4-byte word).  x86_64 encoding
// breakdown:
//
//   [legacy prefix] [REX] [opcode 1-3B] [ModR/M] [SIB] [disp 0/8/32] [imm 0/8/16/32/64]
//
// Cycle 2 ships the minimum subset for a Linux `exit(N)` syscall:
//
//   MOV EAX, #N      B8 imm32          5 B  (32-bit MOV zero-extends to RAX)
//   MOV EDI, #N      BF imm32          5 B  (same for RDI)
//   MOV ESI, #N      BE imm32          5 B  (RSI arg)
//   MOV EDX, #N      BA imm32          5 B  (RDX arg)
//   SYSCALL          0F 05             2 B  (kernel trap)
//   RET              C3                1 B
//
// 32-bit register names parse to indices 0-7 (eax=0, ecx=1, edx=2,
// ebx=3, esp=4, ebp=5, esi=6, edi=7). The opcode for `MOV r32, imm32`
// is `B8 + reg_idx`.

fn _ex86_reg32(s: string) -> Int {
    if s == "eax" || s == "EAX" { return 0 }
    if s == "ecx" || s == "ECX" { return 1 }
    if s == "edx" || s == "EDX" { return 2 }
    if s == "ebx" || s == "EBX" { return 3 }
    if s == "esp" || s == "ESP" { return 4 }
    if s == "ebp" || s == "EBP" { return 5 }
    if s == "esi" || s == "ESI" { return 6 }
    if s == "edi" || s == "EDI" { return 7 }
    return -1
}

fn _ex86_imm(s: string) -> Int {
    let n = len(s)
    if n < 2 { return 0 }
    if s.substring(0, 1) != "#" { return s.to_int() }
    return s.substring(1, n).to_int()
}

// Emit `MOV r32, imm32`. Encoding: `B8+r` opcode, then imm32 LE.
fn _ex86_mov_r32_imm32(reg_idx: Int, imm: Int) -> [Int] {
    let out: [Int] = []
    out.push(0xB8 | (reg_idx & 0x7))
    out.push(imm & 0xFF)
    out.push((imm >> 8) & 0xFF)
    out.push((imm >> 16) & 0xFF)
    out.push((imm >> 24) & 0xFF)
    return out
}

pub fn encode_x86_64_insn(op: string, ops: [string]) -> [Int] {
    if op == "MOV" && len(ops) == 2 && ops[1].substring(0, 1) == "#" {
        let rd = _ex86_reg32(ops[0])
        let imm = _ex86_imm(ops[1])
        if rd >= 0 { return _ex86_mov_r32_imm32(rd, imm) }
    }
    if op == "SYSCALL" { return [0x0F, 0x05] }
    if op == "RET"     { return [0xC3] }
    // CALL rel32 — 5 bytes: E8 + 4-byte signed PC-relative offset.
    if op == "CALL" && len(ops) == 1 {
        return [0xE8, 0x00, 0x00, 0x00, 0x00]
    }

    // ── x86_64 arithmetic — P2 walker prep ──
    //
    // 81 /0 id: ADD r/m32, imm32 — 6 bytes (with mod=11 reg-direct).
    //   Layout: 81 c0+r imm32   (e.g. ADD EAX, imm32 → 81 c0 imm32)
    // 81 /5 id: SUB r/m32, imm32 — same shape, opcode-ext 5: 81 e8+r
    // 81 /7 id: CMP r/m32, imm32 — opcode-ext 7: 81 f8+r
    // The /N field selects via ModR/M.reg; we use mod=11 (reg-direct)
    // so ModR/M = 0b11_<ext>_<rm> = 0xC0 | (ext<<3) | r.
    if op == "ADD" && len(ops) == 2 && ops[1].substring(0, 1) == "#" {
        let rd = _ex86_reg32(ops[0])
        let imm = _ex86_imm(ops[1])
        if rd >= 0 {
            let modrm = 0xC0 | (0 << 3) | rd     // /0
            return [0x81, modrm,
                    imm & 0xFF, (imm >> 8) & 0xFF,
                    (imm >> 16) & 0xFF, (imm >> 24) & 0xFF]
        }
    }
    if op == "SUB" && len(ops) == 2 && ops[1].substring(0, 1) == "#" {
        let rd = _ex86_reg32(ops[0])
        let imm = _ex86_imm(ops[1])
        if rd >= 0 {
            let modrm = 0xC0 | (5 << 3) | rd     // /5 = ModR/M reg=5
            return [0x81, modrm,
                    imm & 0xFF, (imm >> 8) & 0xFF,
                    (imm >> 16) & 0xFF, (imm >> 24) & 0xFF]
        }
    }
    if op == "CMP" && len(ops) == 2 && ops[1].substring(0, 1) == "#" {
        let rd = _ex86_reg32(ops[0])
        let imm = _ex86_imm(ops[1])
        if rd >= 0 {
            let modrm = 0xC0 | (7 << 3) | rd     // /7
            return [0x81, modrm,
                    imm & 0xFF, (imm >> 8) & 0xFF,
                    (imm >> 16) & 0xFF, (imm >> 24) & 0xFF]
        }
    }
    // ADD/SUB/CMP r32, r32 — reg-reg form (2 bytes opcode + ModR/M).
    //   01 /r:  ADD r/m32, r32   (e.g. ADD EAX, EBX → 01 d8)
    //   29 /r:  SUB r/m32, r32
    //   39 /r:  CMP r/m32, r32
    // ModR/M = 0b11_<src>_<dst> for reg-reg with dst as destination.
    if op == "ADD" && len(ops) == 2 {
        let rd = _ex86_reg32(ops[0])
        let rs = _ex86_reg32(ops[1])
        if rd >= 0 && rs >= 0 {
            return [0x01, 0xC0 | (rs << 3) | rd]
        }
    }
    if op == "SUB" && len(ops) == 2 {
        let rd = _ex86_reg32(ops[0])
        let rs = _ex86_reg32(ops[1])
        if rd >= 0 && rs >= 0 {
            return [0x29, 0xC0 | (rs << 3) | rd]
        }
    }
    if op == "CMP" && len(ops) == 2 {
        let rd = _ex86_reg32(ops[0])
        let rs = _ex86_reg32(ops[1])
        if rd >= 0 && rs >= 0 {
            return [0x39, 0xC0 | (rs << 3) | rd]
        }
    }
    return []
}

// ─────────────────────────────────────────────────────────────────
// link_elf_x86_64 — P2 cycle 4: ELF multi-obj static-link
// ─────────────────────────────────────────────────────────────────
//
// Mirror of P1's `link_macho_arm64` but for ELF. Take N ElfX86Obj +
// concat their texts, resolve inter-obj CALL relocations, wrap in
// ET_EXEC PT_LOAD shell.
//
// Reloc handling (cycle 4 minimal):
//   - R_X86_64_PLT32 (kind=4) / R_X86_64_PC32 (kind=2): patch the
//     CALL instruction's imm32 field with the PC-relative offset to
//     the target symbol. Per x86_64 convention, the offset is
//     measured from the END of the CALL (so patch_addr+4-byte for
//     the imm32 field; target = sym_addr; delta = sym_addr -
//     (patch_addr + 4) + addend).
pub fn link_elf_x86_64(objs: [ElfX86Obj], out_path: string, entry: string) -> Int {
    // Concatenate text + record per-obj base + global symbol map.
    let mut text_bytes: [Int] = []
    let mut entry_off = 0
    let mut entry_found = false
    let mut def_names:   [string] = []
    let mut def_offsets: [Int]    = []
    let mut obj_bases:   [Int]    = []
    let mut obj_strtab_local: [string] = []     // running per-obj sym-name resolution

    let mut oi = 0
    while oi < len(objs) {
        let obj = objs[oi]
        let base = len(text_bytes)
        obj_bases.push(base)
        // Resolve each symbol's name from the obj's local strtab.
        let mut di = 0
        while di < len(obj.symbols) {
            let s = obj.symbols[di]
            // Read name from strtab starting at s.name_offset (NUL-term).
            let mut name = ""
            let mut k = 0
            while true {
                let b = obj.strtab[s.name_offset + k] & 0xFF
                if b == 0 { break }
                name = name + chr(b)
                k = k + 1
            }
            // Defined (section != 0) → global map.
            if s.section != 0 {
                def_names.push(name)
                def_offsets.push(base + s.value)
                if !entry_found && name == entry {
                    entry_off = base + s.value
                    entry_found = true
                }
            }
            di = di + 1
        }
        // Append text.
        let mut ti = 0
        while ti < len(obj.text) {
            text_bytes.push(obj.text[ti] & 0xFF)
            ti = ti + 1
        }
        oi = oi + 1
    }
    if !entry_found {
        eprintln("hexa_ld(elf): entry '" + entry + "' not defined in any obj")
        return 3
    }

    // Resolve relocations.
    let mut ro = 0
    while ro < len(objs) {
        let obj = objs[ro]
        let base = obj_bases[ro]
        let mut ri = 0
        while ri < len(obj.relocs) {
            let r = obj.relocs[ri]
            // Look up target sym name via the obj's symtab + strtab.
            let sym = obj.symbols[r.sym_idx]
            let mut name = ""
            let mut k = 0
            while true {
                let b = obj.strtab[sym.name_offset + k] & 0xFF
                if b == 0 { break }
                name = name + chr(b)
                k = k + 1
            }
            // Find target in global defined map.
            let mut found_idx = -1
            let mut sk = 0
            while sk < len(def_names) {
                if def_names[sk] == name { found_idx = sk; break }
                sk = sk + 1
            }
            if found_idx >= 0 {
                let tgt_off = def_offsets[found_idx]
                // ELF reloc formula: imm32 = S + A - P
                //   S = target symbol's address (here a text offset
                //       since we omit the vaddr base — both target
                //       and patch live in the same segment).
                //   A = addend (e.g. -4 for x86_64 CALL).
                //   P = patch site address (the imm32 field).
                // For CALL E8 imm32, A=-4 reproduces the canonical
                // imm32 = target - call_start - 5 (call_start =
                // patch_off - 1, so imm32 = target - patch_off - 4).
                let patch_off = base + r.offset
                let delta = tgt_off + r.addend - patch_off
                text_bytes[patch_off + 0] = delta & 0xFF
                text_bytes[patch_off + 1] = (delta >> 8) & 0xFF
                text_bytes[patch_off + 2] = (delta >> 16) & 0xFF
                text_bytes[patch_off + 3] = (delta >> 24) & 0xFF
            }
            ri = ri + 1
        }
        ro = ro + 1
    }

    // The exec's entry symbol must be at offset 0 of __text for our
    // minimal PT_LOAD layout (e_entry = vaddr_base + code_off where
    // code_off is the file position of the FIRST byte of text). If
    // entry symbol isn't at offset 0, shift the entry's text to the
    // front. For cycle 4 we require entry@offset 0 (caller's
    // responsibility) — entry_off != 0 returns rc=4.
    if entry_off != 0 {
        eprintln("hexa_ld(elf): entry symbol must be at text offset 0 (got " +
                 to_string(entry_off) + ")")
        return 4
    }

    let bytes = serialize_elf_exec_x86_64(text_bytes)
    write_bytes(out_path, bytes)
    return 0
}

// serialize_elf_x86_64 — P2 cycle 1: empty-object byte stream.
// Layout: header → .text → .symtab → .strtab → .shstrtab → section
// header table (5 entries: NULL, .text, .symtab, .strtab, .shstrtab).
pub fn serialize_elf_x86_64(obj: ElfX86Obj) -> [Int] {
    let out: [Int] = []
    let text_size = len(obj.text)
    let nsyms = len(obj.symbols)
    let symtab_size = 24 * nsyms
    let strsize = len(obj.strtab)

    let shstrtab: [Int] = []
    shstrtab.push(0)
    let off_text     = _ew_str(shstrtab, ".text")
    let off_symtab   = _ew_str(shstrtab, ".symtab")
    let off_strtab   = _ew_str(shstrtab, ".strtab")
    let off_shstrtab = _ew_str(shstrtab, ".shstrtab")
    let shstrsize = len(shstrtab)

    let elf_header_size = 64
    let shdr_size = 64
    let nshdrs = 5

    let text_off     = elf_header_size
    let text_pad     = (4 - (text_size & 3)) & 3
    let symtab_off   = text_off + text_size + text_pad
    let strtab_off   = symtab_off + symtab_size
    let shstrtab_off = strtab_off + strsize
    let shdr_off     = shstrtab_off + shstrsize

    // ── ELF64 header ──
    out.push(ELF_EI_MAG0); out.push(ELF_EI_MAG1)
    out.push(ELF_EI_MAG2); out.push(ELF_EI_MAG3)
    out.push(ELF_ELFCLASS64)
    out.push(ELF_ELFDATA2LSB)
    out.push(ELF_EV_CURRENT)
    out.push(ELF_ELFOSABI_NONE)
    _ew_zero(out, 8)                       // EI_ABIVERSION + 7 pad
    _ew_u16(out, ELF_ET_REL)
    _ew_u16(out, ELF_EM_X86_64)
    _ew_u32(out, ELF_EV_CURRENT)
    _ew_u64(out, 0)                         // e_entry
    _ew_u64(out, 0)                         // e_phoff
    _ew_u64(out, shdr_off)                  // e_shoff
    _ew_u32(out, 0)                         // e_flags
    _ew_u16(out, elf_header_size)           // e_ehsize
    _ew_u16(out, 0)                         // e_phentsize
    _ew_u16(out, 0)                         // e_phnum
    _ew_u16(out, shdr_size)                 // e_shentsize
    _ew_u16(out, nshdrs)                    // e_shnum
    _ew_u16(out, 4)                         // e_shstrndx

    // ── .text ──
    let mut ti = 0
    while ti < text_size { out.push(obj.text[ti] & 0xFF); ti = ti + 1 }
    _ew_zero(out, text_pad)

    // ── .symtab ──
    let mut si = 0
    while si < nsyms {
        let s = obj.symbols[si]
        _ew_u32(out, s.name_offset)
        let st_info = ((s.bind & 0xF) << 4) | (s.type_ & 0xF)
        out.push(st_info & 0xFF)
        out.push(0)                          // st_other
        _ew_u16(out, s.section)
        _ew_u64(out, s.value)
        _ew_u64(out, s.size)
        si = si + 1
    }

    // ── .strtab ──
    let mut ki = 0
    while ki < strsize { out.push(obj.strtab[ki] & 0xFF); ki = ki + 1 }

    // ── .shstrtab ──
    let mut hi = 0
    while hi < shstrsize { out.push(shstrtab[hi] & 0xFF); hi = hi + 1 }

    // ── Section header table ──
    // [0] SHT_NULL.
    _ew_zero(out, 64)
    // [1] .text.
    _ew_u32(out, off_text)
    _ew_u32(out, ELF_SHT_PROGBITS)
    _ew_u64(out, ELF_SHF_ALLOC | ELF_SHF_EXECINSTR)
    _ew_u64(out, 0)
    _ew_u64(out, text_off)
    _ew_u64(out, text_size)
    _ew_u32(out, 0); _ew_u32(out, 0)
    _ew_u64(out, 4); _ew_u64(out, 0)
    // [2] .symtab.
    _ew_u32(out, off_symtab)
    _ew_u32(out, ELF_SHT_SYMTAB)
    _ew_u64(out, 0); _ew_u64(out, 0)
    _ew_u64(out, symtab_off)
    _ew_u64(out, symtab_size)
    _ew_u32(out, 3)                         // sh_link → .strtab
    _ew_u32(out, 1)                         // sh_info
    _ew_u64(out, 8); _ew_u64(out, 24)
    // [3] .strtab.
    _ew_u32(out, off_strtab)
    _ew_u32(out, ELF_SHT_STRTAB)
    _ew_u64(out, 0); _ew_u64(out, 0)
    _ew_u64(out, strtab_off)
    _ew_u64(out, strsize)
    _ew_u32(out, 0); _ew_u32(out, 0)
    _ew_u64(out, 1); _ew_u64(out, 0)
    // [4] .shstrtab.
    _ew_u32(out, off_shstrtab)
    _ew_u32(out, ELF_SHT_STRTAB)
    _ew_u64(out, 0); _ew_u64(out, 0)
    _ew_u64(out, shstrtab_off)
    _ew_u64(out, shstrsize)
    _ew_u32(out, 0); _ew_u32(out, 0)
    _ew_u64(out, 1); _ew_u64(out, 0)

    return out
}

// ─────────────────────────────────────────────────────────────────
// serialize_elf_exec_x86_64 — P2 cycle 3: minimum ELF executable
// ─────────────────────────────────────────────────────────────────
//
// Static ELF exec for Linux x86_64. No dynamic linker, no symbol
// table — just header + one PT_LOAD segment containing entry code.
// Kernel maps segment at e_entry and starts execution there.
//
// Layout (132 bytes for a 12-byte exit syscall):
//   ELF64 header  64 B   e_type=ET_EXEC e_entry=vaddr+120
//   PT_LOAD phdr  56 B   p_offset=0 p_vaddr=0x400000 PF_R|PF_X
//   code bytes     N B
pub fn serialize_elf_exec_x86_64(text: [Int]) -> [Int] {
    let out: [Int] = []
    let text_size = len(text)

    let elf_header_size = 64
    let phdr_size = 56
    let phnum = 1
    let code_off = elf_header_size + phdr_size * phnum     // 120
    let vaddr_base = 0x400000
    let entry_vaddr = vaddr_base + code_off
    let file_size = code_off + text_size

    out.push(ELF_EI_MAG0); out.push(ELF_EI_MAG1)
    out.push(ELF_EI_MAG2); out.push(ELF_EI_MAG3)
    out.push(ELF_ELFCLASS64)
    out.push(ELF_ELFDATA2LSB)
    out.push(ELF_EV_CURRENT)
    out.push(ELF_ELFOSABI_NONE)
    _ew_zero(out, 8)
    _ew_u16(out, ELF_ET_EXEC)
    _ew_u16(out, ELF_EM_X86_64)
    _ew_u32(out, ELF_EV_CURRENT)
    _ew_u64(out, entry_vaddr)
    _ew_u64(out, elf_header_size)           // e_phoff
    _ew_u64(out, 0)                         // e_shoff
    _ew_u32(out, 0)                         // e_flags
    _ew_u16(out, elf_header_size)
    _ew_u16(out, phdr_size)
    _ew_u16(out, phnum)
    _ew_u16(out, 0)                         // e_shentsize
    _ew_u16(out, 0)                         // e_shnum
    _ew_u16(out, 0)                         // e_shstrndx

    // PT_LOAD
    _ew_u32(out, 1)                         // p_type = PT_LOAD
    _ew_u32(out, 5)                         // p_flags = PF_R | PF_X
    _ew_u64(out, 0)                         // p_offset
    _ew_u64(out, vaddr_base)                // p_vaddr
    _ew_u64(out, vaddr_base)                // p_paddr
    _ew_u64(out, file_size)                 // p_filesz
    _ew_u64(out, file_size)                 // p_memsz
    _ew_u64(out, 0x1000)                    // p_align

    let mut i = 0
    while i < text_size { out.push(text[i] & 0xFF); i = i + 1 }

    return out
}
