// HEXA Native Compiler — Phase 4 kick remote SSH-forward adapter
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ (try-live-or-fallback) adapter for the `nexus kick` ω-cycle
// dispatcher.
// Source:   ~/core/nexus/cli/run.hexa::cmd_kick (line 6607)
//         + ~/core/nexus/tool/kick_dispatch.hexa
//         + ~/core/nexus/tool/kick_{bench,tree,parallel,...}.hexa
//
// Live path: SSH-forward to HEXA_KICK_FORWARD_HOST (default `ubu2`)
//            for the actual kick dispatch — mirrors the existing
//            cli/run.hexa::_kick_run forwarding logic.
//
// Fallback path: local sub-pipeline (smaller batch, deterministic
//                witness emit) — see ./local_fallback.hexa.
//
// HISTORICAL DIRECTIVE (REVOKED 2026-05-13):
//   The 2026-04-29 user directive forbade Mac fallback entirely:
//     "mac 이용 , mac fallback , mac 으로 우회 kick 실행 모두 관련 폐기"
//   The hard-fail-no-mac-fallback path lived in
//   ~/core/nexus/cli/run.hexa::_kick_run lines 6313-6334. That
//   fortress policy is preserved in nexus for legacy callers but
//   is REVOKED for the Phase 4 absorption — this adapter treats
//   kick as ordinary δ (try-live-or-fallback), per user decision
//   2026-05-13. See block comment in local_fallback.hexa for the
//   archived directive text.
//
// Subcmds supported:
//   tree | bench | selftest | status | atlas
//   lock / unlock / lock-status | slots
//   run <topic> (default-run alias)
//
// γ enforced: returns values only. No atlas writes, no audit_log
// writes, no discovery_log writes. SSH probe bounded by
// HEXA_CLI_TIMEOUT_SEC / 8s connect timeout.

import "./../bridges/_common.hexa"
import "./local_fallback.hexa"

fn _forward_host() -> string {
    let h = env("HEXA_KICK_FORWARD_HOST")
    if h.len() > 0 { return h }
    return "ubu2"
}

pub fn kick_live_available() -> bool {
    if env("HEXA_FORCE_FALLBACK") == "1" { return false }
    if env("HEXA_KICK_LOCAL_ONLY") == "1" { return false }
    // 8-second SSH probe (BatchMode=yes — never prompt).
    let host = _forward_host()
    let probe = exec("timeout 8 ssh -o BatchMode=yes -o ConnectTimeout=5 " + shq(host) + " 'echo ok' 2>/dev/null").trim()
    return probe == "ok"
}

pub fn kick_exec_live(sub: string, topic: string, extra: [string]) -> array {
    let host = _forward_host()
    // Compose the remote argv. The remote runs hexa on its own copy
    // of nexus, with skip flags for Mac-orchestrator-local gates.
    let mut inner_args = ""
    inner_args = inner_args + " kick " + shq(sub)
    if topic.len() > 0 { inner_args = inner_args + " " + shq(topic) }
    let mut i = 0
    while i < len(extra) { inner_args = inner_args + " " + shq(extra[i]); i = i + 1 }
    let remote_inner = "cd ~/core/nexus && HEXA_KICK_SKIP_OAUTH_GATE=1 HEXA_KICK_SKIP_PREFLIGHT=1 ~/.hx/bin/hexa run cli/run.hexa" + inner_args
    let cmd = "ssh -o BatchMode=yes -o ServerAliveInterval=30 -o ConnectTimeout=10 " + shq(host) + " " + shq(remote_inner) + " 2>&1; echo __FORWARD_RC=$?"
    let r = exec_capture(cmd)
    let stdout_s = to_string(r[0])
    let stderr_s = to_string(r[1])
    let ec = to_int(r[2])
    // Strip __FORWARD_RC trailer for caller cleanliness.
    let cleaned = stdout_s
    return [ec == 0 && stdout_s.len() > 0, cleaned, stderr_s, ec]
}

pub fn kick_fallback(sub: string, topic: string, extra: [string]) -> array {
    if sub == "tree" { return local_kick_tree() }
    if sub == "bench" { return local_kick_bench(topic) }
    if sub == "selftest" { return local_kick_selftest(topic) }
    if sub == "status" { return local_kick_status() }
    if sub == "slots" {
        return ok_body("{\"tool\":\"kick slots\",\"mode\":\"fallback-local\",\"note\":\"slots surface deprecated upstream; see kick status\"}")
    }
    if sub == "atlas" { return local_kick_atlas(topic) }
    if sub == "lock" || sub == "unlock" || sub == "lock-status" {
        return local_kick_lock(sub, topic)
    }
    if sub == "run" || sub == "" {
        return local_kick_run("run", topic, extra)
    }
    // Treat unknown sub as a topic (canonical CLI shape: `kick <topic>`).
    return local_kick_run("run", sub, extra)
}

pub fn kick_run(sub: string, topic: string, extra: [string]) -> array {
    if kick_live_available() {
        let r = kick_exec_live(sub, topic, extra)
        if cli_ok(r) { return r }
    }
    return kick_fallback(sub, topic, extra)
}
