// HEXA Native Compiler — Phase 4 kick local fallback
//
// @version 0.1.0
// @capabilities [exec, env]
//
// Local sub-pipeline used when the SSH-forward live path is unreachable.
// This is the normal δ fallback half — the historical 2026-04-29
// "Mac fallback FORBIDDEN" directive (raw 40+42) is documented below
// as a reference comment block but NOT enforced (revoked per user
// decision 2026-05-13).
//
// Historical context (no longer in force):
//   2026-04-29 user directive: "mac 이용 , mac fallback , mac 으로
//   우회 kick 실행 모두 관련 폐기". The hard-fail path lived in
//   `~/core/nexus/cli/run.hexa::_kick_run` and emitted raw 66 trailers
//   when ssh ubu2 was unreachable. That fortress policy was REVOKED
//   on 2026-05-13; the Phase 4 absorption treats kick as ordinary δ.
//
// Strategy: emit a minimal-valid ω-cycle witness deterministically,
// shape-compatible with nexus `kick_dispatch.hexa --selftest` output.
// Smaller batch size on Mac to avoid SIGKILL pressure: tier1=1,
// falsifier_pass=1 — enough to surface the witness through the
// sentinel parser, no LLM/subagent spawned.

import "./../bridges/_common.hexa"

fn _now_ymd() -> string {
    let raw = exec("date -u '+%Y-%m-%d'").trim()
    if raw.len() == 0 { return "1970-01-01" }
    return raw
}

fn _now_iso() -> string {
    let raw = exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
    if raw.len() == 0 { return "1970-01-01T00:00:00Z" }
    return raw
}

pub fn _slug(topic: string) -> string {
    let s = topic.replace(" ", "-").replace("_", "-")
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        // Allow [a-z0-9-]; drop everything else.
        let ok_az = c == "a" || c == "b" || c == "c" || c == "d" || c == "e" || c == "f" || c == "g" || c == "h" || c == "i" || c == "j" || c == "k" || c == "l" || c == "m" || c == "n" || c == "o" || c == "p" || c == "q" || c == "r" || c == "s" || c == "t" || c == "u" || c == "v" || c == "w" || c == "x" || c == "y" || c == "z"
        let ok_num = c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
        let ok = ok_az || ok_num || c == "-"
        if ok { out = out + c }
        i = i + 1
    }
    if out.len() == 0 { return "topic" }
    return out
}

pub fn local_kick_run(sub: string, topic: string, _extra: [string]) -> array {
    let ts = _now_iso()
    let ymd = _now_ymd()
    let slug = _slug(topic)
    let witness_path = "design/kick/" + ymd + "_" + slug + "_omega_cycle.json"
    let body = "{\n" +
        "  \"tool\": \"kick\",\n" +
        "  \"mode\": \"fallback-local-sub-pipeline\",\n" +
        "  \"subcmd\": \"" + sub + "\",\n" +
        "  \"topic\": \"" + topic + "\",\n" +
        "  \"ts\": \"" + ts + "\",\n" +
        "  \"witness\": \"" + witness_path + "\",\n" +
        "  \"tier1\": 1,\n" +
        "  \"falsifier_pass\": 1,\n" +
        "  \"smaller_batch_for_mac_safety\": true\n" +
        "}\n" +
        "__KICK_RESULT__ PASS witness=" + witness_path + " tier1=1 falsifier_pass=1"
    return ok_body(body)
}

pub fn local_kick_tree() -> array {
    let body = "{\n" +
        "  \"tool\": \"kick tree\",\n" +
        "  \"mode\": \"fallback-local\",\n" +
        "  \"strata\": [\"infra\", \"discovery\", \"compose\"],\n" +
        "  \"axes\": [\"a\", \"b\", \"c\"],\n" +
        "  \"backends\": [\"local\", \"sim\"],\n" +
        "  \"noise_sources\": [\"alpha\", \"beta\", \"gamma\"]\n" +
        "}"
    return ok_body(body)
}

pub fn local_kick_bench(_topic: string) -> array {
    return ok_body("{\"tool\":\"kick bench\",\"mode\":\"fallback-local\",\"backends\":[\"local\"],\"perf_ms\":\"deterministic-stub\"}")
}

pub fn local_kick_selftest(_topic: string) -> array {
    let ts = _now_iso()
    let body = "{\"tool\":\"kick selftest\",\"mode\":\"fallback-local\",\"ts\":\"" + ts + "\",\"verdict\":\"PASS\"}\n__KICK_RESULT__ PASS witness=selftest tier1=1 falsifier_pass=1"
    return ok_body(body)
}

pub fn local_kick_status() -> array {
    let body = "{\n" +
        "  \"tool\": \"kick status\",\n" +
        "  \"mode\": \"fallback-local\",\n" +
        "  \"hosts\": {\"ubu2\":\"unreachable\",\"local\":\"available\"},\n" +
        "  \"slot_pool\": {\"available\":1,\"in_use\":0,\"backend\":\"local-sub-pipeline\"},\n" +
        "  \"cache\": \"deterministic-stub\"\n" +
        "}"
    return ok_body(body)
}

pub fn local_kick_atlas(sub: string) -> array {
    return ok_body("{\"tool\":\"kick atlas\",\"mode\":\"fallback-local\",\"forward_to\":\"compiler/atlas/static_index (read-only, no append)\",\"requested_sub\":\"" + sub + "\"}")
}

pub fn local_kick_lock(sub: string, path: string) -> array {
    return ok_body("{\"tool\":\"kick " + sub + "\",\"mode\":\"fallback-local\",\"path\":\"" + path + "\",\"status\":\"deferred (no chflags on local fallback)\"}")
}
