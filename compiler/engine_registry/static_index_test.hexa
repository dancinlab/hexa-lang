// HEXA Native Compiler — Wave 1 absorption: engine_registry smoke

use "compiler/engine_registry/embed"
use "compiler/engine_registry/embedded.gen"
use "compiler/engine_registry/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 engine_registry embed smoke")
    println("  hash:         " + ENGINE_REGISTRY_HASH)
    println("  generated_at: " + ENGINE_REGISTRY_GENERATED_AT)
    println("  source_count: " + to_string(ENGINE_REGISTRY_SOURCE_COUNT))
    println("  entries:      " + to_string(len(ENGINE_REGISTRY)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(ENGINE_REGISTRY_HASH),                       fails)
    _check("generated_at non-empty",     len(ENGINE_REGISTRY_GENERATED_AT) > 0,                 fails)
    _check("source_count > 0",           ENGINE_REGISTRY_SOURCE_COUNT > 0,                      fails)
    _check("entries match source_count", len(ENGINE_REGISTRY) == ENGINE_REGISTRY_SOURCE_COUNT,  fails)

    let e0 = ENGINE_REGISTRY[0]
    _check("first entry name non-empty",  len(e0.name) > 0,                                     fails)
    _check("first entry ts > 0",          e0.ts > 0,                                            fails)

    let miss = engine_registry_lookup("not-a-real-engine")
    _check("lookup miss → name == \"\"", miss.name == "",                                      fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(ENGINE_REGISTRY)) + "/" + to_string(ENGINE_REGISTRY_SOURCE_COUNT) + " entries, hash=" + ENGINE_REGISTRY_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
