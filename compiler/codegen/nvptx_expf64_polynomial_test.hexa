// compiler/codegen/nvptx_expf64_polynomial_test.hexa
// RFC 055 §13 — f64 exp(x) polynomial emit falsifier.
//
// @version 0.0.1
// @capabilities [pure]
// @phase("parse_only")
//
// Replaces the honest-stub at `_nvptx_lower_stmt`'s STMT_CALL math-intrinsic
// `exp f64` arm with a real PTX emit (range-reduction + degree-10 Taylor +
// 2^k bit-pattern). This fixture hand-builds a kernel whose body calls
// `exp(a[i])` over a `[f64]` input, drives it through
// `codegen_emit_ptx_sm80`, and substring-checks the resulting PTX text for:
//
//   - `cvt.rni.f64.f64` (range-reduction kf = round(x*log2e))
//   - `cvt.rni.s64.f64` (k = (s64) kf, used for 2^k bit-pattern)
//   - `mov.b64`         (bit-cast (k+1023)<<52 → f64 for 2^k)
//   - `shl.b64`         (k+1023 shifted into the exponent field)
//   - `fma.rn.f64`      (Horner polynomial — at least 10 occurrences)
//   - NO "honest stub" comment for the exp arm.
//
// HONEST SCOPE — codegen-only (parse + emit text inspection). Full
// source-to-silicon (a parser-driven `c[i] = exp(a[i])` kernel through
// the parser → HIR → MIR → NVPTX → ptxas → driver-JIT path with a
// libm tolerance fire on ubu-2 RTX 5070) is a separate falsifier
// (F-EXPF64-POLYNOMIAL-NUMERIC, deferred to a follow-on PR). This
// fixture proves the codegen seam emits the polynomial chain.

import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "./nvptx_target.hexa"

// ── Minimal MIR construction helpers (mirror the sibling
//    nvptx_shared_directive_test helpers — kept local for
//    self-containment). ───────────────────────────────────────────

fn _local(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name, precision: "", space: "" }
}

fn _local_i64(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 1, name_hint: name, precision: "", space: "" }
}

fn _local_array_f64(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 103, name_hint: name, precision: "", space: "" }
}

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "", precision: "", space: "" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local", local_id: local_id,
        int_val: 0, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _stmt_call(dst: Local, callee: string) -> Stmt {
    return Stmt {
        kind: STMT_CALL, dst: dst, op: callee, args: [],
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_call_with_args(dst: Local, callee: string, xs: [Operand]) -> Stmt {
    return Stmt {
        kind: STMT_CALL, dst: dst, op: callee, args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_index_get(dst: Local, base_id: i64, idx_id: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(base_id))
    xs.push(_op_local(idx_id))
    return Stmt {
        kind: STMT_ASSIGN, dst: dst, op: "index", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_index_set(base_id: i64, idx_id: i64, val_id: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(base_id))
    xs.push(_op_local(idx_id))
    xs.push(_op_local(val_id))
    return Stmt {
        kind: STMT_ASSIGN, dst: _miss_local(), op: "index_set", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_return() -> Stmt {
    return Stmt {
        kind: STMT_RETURN, dst: _miss_local(), op: "", args: [],
        target_block: -1, target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

// ── Text inspection helpers. ────────────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    return hay.find(needle) >= 0
}

fn _check(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if _contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (missing: `" + needle + "`)")
    return false
}

fn _check_not(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if !_contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (unexpected: `" + needle + "`)")
    return false
}

fn _count_substr(hay: string, needle: string) -> i64 {
    let n = len(needle)
    if n == 0 { return 0 }
    let mut cnt: i64 = 0
    let mut i: i64 = 0
    let h = len(hay)
    while i + n <= h {
        let s = hay.slice(i, i + n)
        if s == needle { cnt = cnt + 1; i = i + n }
        else { i = i + 1 }
    }
    return cnt
}

// ── Fixture: kernel `c[i] = exp(a[i])` ─────────────────────────
//
//   @gpu_kernel
//   fn exp_f64_probe(a: [f64], c: [f64], n: i64) {
//       let i32 = gpu_thread_id_x()        // U32
//       let i   = to_i64(i32)              // U64
//       let av  = a[i]                     // F64 (ld.global.f64)
//       let ex  = exp(av)                  // F64 → triggers polynomial chain
//       c[i] = ex                          // st.global.f64
//   }

fn _build_case_expf64_polynomial() -> MModule {
    let a     = _local_array_f64(0, "a")
    let c     = _local_array_f64(1, "c")
    let n_p   = _local_i64(2, "n")
    let i32_l = _local(3, "i32")
    let i_l   = _local(4, "i")
    let av    = _local(5, "av")
    let ex    = _local(6, "ex")

    let mut tii = []
    tii.push(_op_local(i32_l.id))

    let mut argsx = []
    argsx.push(_op_local(av.id))

    let mut s0 = []
    s0.push(_stmt_call(i32_l, "gpu_thread_id_x"))
    s0.push(_stmt_call_with_args(i_l, "to_i64", tii))
    s0.push(_stmt_index_get(av, a.id, i_l.id))            // av = a[i]
    s0.push(_stmt_call_with_args(ex, "exp", argsx))       // ex = exp(av) — polynomial chain
    s0.push(_stmt_index_set(c.id, i_l.id, ex.id))         // c[i] = ex
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a); params.push(c); params.push(n_p)
    let mut locals = []
    locals.push(a); locals.push(c); locals.push(n_p)
    locals.push(i32_l); locals.push(i_l)
    locals.push(av); locals.push(ex)

    let mf = MFunc {
        name: "exp_f64_probe",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_expf64_polynomial.hexa", funcs: fns, globals: [] }
}

fn _test_expf64_polynomial() -> bool {
    let mut ok = true
    let mod_e = _build_case_expf64_polynomial()
    let ptx = codegen_emit_ptx_sm80(mod_e)

    println("")
    println("── emitted PTX (RFC 055 §13 f64 exp polynomial, sm_80) ──")
    println(ptx)

    // Honest-stub comment for the exp arm must be GONE.
    ok = _check_not(ok, ptx, "RFC 055 S13 - exp f64 honest stub",
        "exp f64 honest-stub comment REPLACED (polynomial path active)")

    // Range-reduction surface.
    ok = _check(ok, ptx, "cvt.rni.f64.f64",
        "range-reduction kf = round(x * log2e) → cvt.rni.f64.f64")
    ok = _check(ok, ptx, "cvt.rni.s64.f64",
        "k = (s64) kf → cvt.rni.s64.f64")

    // 2^k bit-pattern construction.
    ok = _check(ok, ptx, "shl.b64",
        "(k + 1023) << 52 → shl.b64")
    ok = _check(ok, ptx, "mov.b64",
        "bit-cast (k+1023)<<52 → f64 via mov.b64")

    // Horner polynomial — at least 10 fma.rn.f64 occurrences.
    let n_fma = _count_substr(ptx, "fma.rn.f64")
    println("  fma.rn.f64 count = " + to_string(n_fma) + " (expected ≥10 for Horner chain)")
    if n_fma < 10 {
        println("  FAIL: expected ≥10 fma.rn.f64 for the Horner polynomial, got " + to_string(n_fma))
        ok = false
    }

    // Scratch reg declarations (Pass 6 in _nvptx_classify_locals).
    ok = _check(ok, ptx, "%fd_exp_t_",
        "Pass 6 declared `%fd_exp_t_<id>` scratch")
    ok = _check(ok, ptx, "%rd_exp_k_",
        "Pass 6 declared `%rd_exp_k_<id>` scratch")
    ok = _check(ok, ptx, "%fd_exp_pow2k_",
        "Pass 6 declared `%fd_exp_pow2k_<id>` scratch")

    return ok
}

fn main() {
    let ok = _test_expf64_polynomial()
    if ok {
        println("OK: nvptx_expf64_polynomial_test PASS")
    } else {
        println("FAIL: nvptx_expf64_polynomial_test")
    }
}
