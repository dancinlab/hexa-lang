                // `.b32` halves (`mov.b64 {%lo,%hi}, %fd<src>`), shuffle
                // EACH half with the same idx/clamp/membermask, then
                // recompose (`mov.b64 %fd<dst>, {%lo_out,%hi_out}`).
                // The lane operand stays a `%r` (u32) register either way.
                //   ref: NVIDIA PTX ISA §9.7.13.4 shfl.sync + §5.4 mov.b64.
                let src_kind = _nvptx_lookup_kind_for_local(kinds, s.args[0].local_id)
                if src_kind == NVPTX_RKIND_F64 {
                    let dst_f64 = _nvptx_reg_f64(s.dst.id)
                    let src_f64 = _nvptx_reg_f64(s.args[0].local_id)
                    let lo = _nvptx_reg_shfl_lo(s.dst.id)
                    let hi = _nvptx_reg_shfl_hi(s.dst.id)
                    let lo_out = _nvptx_reg_shfl_lo_out(s.dst.id)
                    let hi_out = _nvptx_reg_shfl_hi_out(s.dst.id)
                    // The lane operand must be `.b32` for shfl. When the
                    // lane Local sits in the u64 bank (`%rd`), narrow it to
                    // the `%shfl_mask_<dst>` u32 scratch first; else use
                    // `%r<lane>` directly.
                    let lane_kind = _nvptx_lookup_kind_for_local(kinds, s.args[1].local_id)
                    let mut lane_reg = _nvptx_reg_u32(s.args[1].local_id)
                    if lane_kind == NVPTX_RKIND_U64 {
