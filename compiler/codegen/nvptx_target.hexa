// HEXA Native Compiler — Codegen / NVPTX (hexa-src → PTX)  [RFC 055 Stage 1 scaffold]
//
// @version 0.0.1
// @capabilities [pure]
//
// ─────────────────────────────────────────────────────────────────────
// SCAFFOLD ONLY — RFC 055 Stage 1 (055-P0). Zero behavior change.
//
// This file is a STRUCTURAL SKELETON for the hexa-native GPU codegen
// target. It PARSES CLEAN but is NOT wired into the compiler's target
// dispatch — nothing routes MIR here. Every codegen function body is an
// honest `// RFC 055 Stage N — not yet implemented` stub. The codegen
// body + dispatch wiring are follow-up cycles (055-P0 emit pass, 055-P1
// `@gpu_kernel` parse + thread-index builtins + launch ABI).
//
// Lowers MIR (SSA CFG) -> LIR (PTX-flavored target instructions) for the
// NVPTX target — a sibling to the CPU targets arm64_darwin.hexa /
// x86_64_linux.hexa / thumbv7em_eabihf.hexa (RFC 055 §6.1).
//
//   pub fn codegen_nvptx_sm90(module: MModule) -> LModule   (Hopper sm_90)
//   pub fn codegen_nvptx_sm80(module: MModule) -> LModule   (Ampere sm_80)
//
// Same signature shape as codegen_arm64_darwin / codegen_x86_64_linux:
// MIR in, LModule out. The two sm_* entries share lowering logic and
// differ only in the PTX `.target` directive (RFC 055 §6.1).
//
// ─────────────────────────────────────────────────────────────────────
// RECONCILIATION with self/native/gpu_codegen_stub.c (RFC 055 §3)
//
// A pre-existing C-level skeleton — self/native/gpu_codegen_stub.c, the
// "rt#45-research scaffold" — locked a C ABI for a future @gpu codegen
// backend. RFC 055 §3 mandates this hexa scaffold reconcile with it.
// This file SUPERSEDES the rt#45 C stub, for three reasons:
//
//   1. ARCHITECTURE. The rt#45 stub is a C file (`gpu_codegen_stub.c`)
//      that walks a C `HexaNode*` AST and offers a `GPU_BACKEND_PTX_LLVM`
//      path as its *preferred* backend. That LLVM path directly violates
//      @D f2 "llvm-c-transpile-backend". The hexa-native answer is a
//      `compiler/codegen/nvptx_*.hexa` target that lowers MIR (not the C
//      AST) and emits PTX text directly — no LLVM. RFC 055 §6.2 / §6.4
//      Decision (A) replace the rt#45 design, they do not extend it.
//
//   2. PIPELINE STAGE. The rt#45 stub emits from the *AST* (parser
//      output). hexa-lang's real codegen targets lower from *MIR* (the
//      SSA CFG, post-HIR). NVPTX joins that pipeline at the same
//      MIR -> LIR boundary as every CPU target — the rt#45 AST-walk
//      stage is the wrong layer.
//
//   3. MISSING DESIGN DOC. The rt#45 stub header references a companion
//      `docs/rt-45-gpu-design.md` that does NOT exist in the repo
//      (confirmed missing — see @N native_dir). The rt#45 design is
//      therefore unrecoverable; RFC 055 is the replacement specification.
//
// The rt#45 stub's one reusable artifact is its INTRINSIC NAME SET
// (`gpu_thread_id_x`, `gpu_block_dim_x`, `gpu_sync`, ...). RFC 055 §6.4
// renames these to the `gpu_thread_idx() / gpu_block_dim() / gpu_barrier()`
// builtin family; the mapping is recorded in `nvptx_intrinsic_map()`
// below so the rename is auditable. A follow-up cleanup cycle should
// tombstone `self/native/gpu_codegen_stub.c` once 055-P0 lands.
//
// ─────────────────────────────────────────────────────────────────────
// HONEST SCOPE (RFC 055 §8 / @D g3)
//
//   IS  — a structural scaffold: the codegen entry points, the LModule
//         target tags, the GPU-IR concept structs, function-kind enum,
//         and the rt#45 reconciliation record.
//   NOT — a working backend. No PTX text is emitted. No `@gpu_kernel`
//         attribute is parsed. No kernel runs. `ptxas` is never invoked.
//         Nothing in the compiler dispatches to these entry points.
//
// `ptxas` (PTX -> SASS) remains an external NVIDIA assembler — the same
// g5 logic as the C-fallback `clang`/`as` path (RFC 055 §8). This file
// does not claim a closed-loop GPU toolchain.
// ─────────────────────────────────────────────────────────────────────

import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "./nvptx_ptx_ops.hexa"
import "./nvptx_tma_ops.hexa"

// ── LModule target tags ───────────────────────────────────────
//
// The `LModule.target` value an NVPTX-compiled module carries. Two
// sm_* variants: sm_80 is the conservative Ampere baseline, sm_90 adds
// Hopper features (wgmma, larger shared memory) additively (RFC 055 §6.1).
pub let NVPTX_TARGET_SM90: string = "nvptx64-nvidia-cuda-sm90"
pub let NVPTX_TARGET_SM80: string = "nvptx64-nvidia-cuda-sm80"
// RFC 071 P2.2 — sm_120 (Blackwell-class consumer / RTX 5070 driver-JIT
// forward-compat). Per `reference_gpu_fire_infra.md`: standalone ptxas
// (CUDA 12.0) does not recognise sm_120, but driver-JIT does — we emit
// the textual `.target sm_120` and let the driver JIT it forward.
pub let NVPTX_TARGET_SM120: string = "nvptx64-nvidia-cuda-sm120"

// RFC 055 055-P3c — kernel-marker prefix on LFunc.name. The 055-P3c
// codegen partition routes `@gpu_kernel` MFuncs through
// `_nvptx_lower_func` and tags the resulting LFunc.name with this
// sentinel so the emit pass can render `.visible .entry <real_name>`
// (the PTX form a host can `cuLaunchKernel`) instead of `.func`. The
// prefix is unlikely to clash with any user-defined symbol; the emit
// pass strips it before writing the kernel name to PTX.
pub let NVPTX_KERNEL_PREFIX: string = "__nvptx_kernel__"

// PTX `.target` directive arch string per variant.
pub let NVPTX_ARCH_SM90: string = "sm_90"
pub let NVPTX_ARCH_SM80: string = "sm_80"
// RFC 071 P2.2 — sm_120 arch string (Blackwell consumer, RTX 5070).
pub let NVPTX_ARCH_SM120: string = "sm_120"

// ── GPU function kind (RFC 055 §6.3 / §6.4) ───────────────────
//
// The GPU analogue of the CPU "exported symbol vs static helper" split.
//   KERNEL — `@gpu_kernel`, lowers to PTX `.visible .entry`; launchable
//            from host; return type must be void (strict-lint enforced).
//   DEVICE — `@gpu_device`, lowers to PTX `.func`; callable only from
//            other @gpu_* code; may return a value.
pub let NVPTX_FN_KERNEL: i64 = 0
pub let NVPTX_FN_DEVICE: i64 = 1

// ── GPU-specific IR concepts (RFC 055 §6.3) ───────────────────
//
// A GPU target needs concepts the flat single-threaded CPU MIR/LIR
// pipeline never carried. RFC 055 §6.3 adds them as ADDITIVE, GPU-ONLY
// annotations — invisible to the CPU targets (guarded by falsifier
// F-RFC055-CPU-CODEGEN-UNTOUCHED). These structs are the scaffold for
// those annotations; the lowering passes that populate them are 055-P1.

// NvptxKernelMeta — per-function GPU metadata attached when a hexa fn
// carries `@gpu_kernel` / `@gpu_device`.
pub struct NvptxKernelMeta {
    fn_kind: i64,             // NVPTX_FN_KERNEL | NVPTX_FN_DEVICE
    uses_shared: bool,        // body declares a @shared local array
    uses_barrier: bool,       // body calls gpu_barrier()
    shared_bytes: i64         // total .shared bytes requested (0 if none)
}

// _nvptx_empty_kernel_meta — default NvptxKernelMeta (device fn, no
// shared memory, no barrier).
fn _nvptx_empty_kernel_meta() -> NvptxKernelMeta {
    return NvptxKernelMeta {
        fn_kind: NVPTX_FN_DEVICE,
        uses_shared: false,
        uses_barrier: false,
        shared_bytes: 0
    }
}

// NvptxIntrinsic — one thread-hierarchy / sync builtin and the PTX
// sreg / mnemonic it lowers to (RFC 055 §6.3 table, §6.4 point 4).
// `rt45_name` records the OLD name from self/native/gpu_codegen_stub.c
// so the RFC 055 rename is auditable (see header §3 reconciliation).
pub struct NvptxIntrinsic {
    hexa_builtin: string,     // RFC 055 §6.4 name, e.g. "gpu_thread_idx"
    ptx_lowering: string,     // PTX sreg / mnemonic, e.g. "%tid"
    rt45_name: string         // superseded rt#45 stub name, e.g. "gpu_thread_id_x"
}

// _nvptx_intrinsic — NvptxIntrinsic constructor.
fn _nvptx_intrinsic(hexa_builtin: string, ptx_lowering: string, rt45_name: string) -> NvptxIntrinsic {
    return NvptxIntrinsic {
        hexa_builtin: hexa_builtin,
        ptx_lowering: ptx_lowering,
        rt45_name: rt45_name
    }
}

// nvptx_intrinsic_map — the @gpu builtin set legal inside `@gpu_*`
// function bodies, with the rt#45 → RFC 055 rename recorded per row.
//
// RFC 055 Stage 1 — informational scaffold. 055-P1 wires strict-lint to
// reject these builtins outside @gpu_* functions (a GPU/CPU
// phase-confusion guard, RFC 055 §6.4). Today unreferenced.
pub fn nvptx_intrinsic_map() -> [NvptxIntrinsic] {
    let mut m = []
    m.push(_nvptx_intrinsic("gpu_thread_idx", PTX_SREG_TID, "gpu_thread_id_*"))
    m.push(_nvptx_intrinsic("gpu_block_idx", PTX_SREG_CTAID, "gpu_block_id_*"))
    m.push(_nvptx_intrinsic("gpu_block_dim", PTX_SREG_NTID, "gpu_block_dim_*"))
    m.push(_nvptx_intrinsic("gpu_grid_dim", PTX_SREG_NCTAID, "gpu_grid_dim_*"))
    m.push(_nvptx_intrinsic("gpu_barrier", PTX_OP_BAR_SYNC, "gpu_sync"))
    return m
}

// ── PTX-flavored LIR encoding (RFC 055 §6.2 — 055-P0) ─────────
//
// RFC 055 §6.2: the NVPTX target reuses the existing LInstr / LFunc /
// LModule structs as-is for text emission, producing PTX-flavored
// `LInstr` records whose `op` field is a PTX mnemonic. PTX has its own
// operand surface (virtual registers `%rd1`, type-qualified ops, `[addr]`
// dereference) that the CPU LOperand reg/imm/mem encoding does not model.
// To keep the CPU emit path byte-identically untouched (falsifier
// F-RFC055-CPU-CODEGEN-UNTOUCHED), 055-P0 carries every PTX operand as a
// pre-rendered text string in `LOperand.label` (kind = "label"). The PTX
// text emit pass (`emit_ptx` below) then joins `op` + operand strings —
// it never invokes the CPU `_fmt_operand` reg/imm/mem renderer.
//
// PTX virtual registers map 1:1 to MIR `Local.id` — PTX's SSA-with-
// virtual-registers form needs no register-allocator pass; `ptxas`
// allocates physical registers downstream (RFC 055 §6.2). 055-P0
// therefore lowers MIR straight to PTX text with no regalloc.

// _nvptx_op — a PTX operand carried as a pre-rendered text string.
fn _nvptx_op(text: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: PReg { name: "", kind: "", frag_role: "", frag_dtype: "", frag_layout: "" },
        imm: 0,
        mem_base: PReg { name: "", kind: "", frag_role: "", frag_dtype: "", frag_layout: "" },
        mem_offset: 0,
        label: text
    }
}

// _nvptx_instr — a PTX-flavored LInstr (op = PTX mnemonic, args = operand
// text strings, comment = optional MIR-trace note).
fn _nvptx_instr(op: string, args: [LOperand], comment: string) -> LInstr {
    return LInstr { op: op, args: args, comment: comment }
}

// _nvptx_reg_f64 — the PTX virtual-register name for an FP64 value held
// in MIR Local `id`. PTX names FP64 registers `%fd<n>` by convention.
fn _nvptx_reg_f64(id: i64) -> string {
    return "%fd" + to_string(id)
}

// _nvptx_reg_s32 — PTX virtual register for an i32 (index) value.
fn _nvptx_reg_s32(id: i64) -> string {
    return "%r" + to_string(id)
}

// N71-B (N70/N91 GAP-C) — FP64 warp-shuffle scratch-half register names.
// `shfl.sync.*.b32` moves only 32 bits, so an f64 shuffle decomposes the
// source `%fd<src>` into two `.b32` halves, shuffles each, then recomposes
// into `%fd<dst>`. Each scratch reg is keyed on the shuffle's dst Local id
// so concurrent shuffles in one block never clobber each other's halves.
//   ref: NVIDIA PTX ISA §9.7.13.4 shfl.sync.
fn _nvptx_reg_shfl_lo(id: i64) -> string {
    return "%shfl_lo_" + to_string(id)
}
fn _nvptx_reg_shfl_hi(id: i64) -> string {
    return "%shfl_hi_" + to_string(id)
}
fn _nvptx_reg_shfl_lo_out(id: i64) -> string {
    return "%shfl_lo_out_" + to_string(id)
}
fn _nvptx_reg_shfl_hi_out(id: i64) -> string {
    return "%shfl_hi_out_" + to_string(id)
}
// _nvptx_reg_shfl_mask — u32 scratch for the lane/mask operand when the
// source Local is in the u64 bank (`%rd<id>`). `shfl.sync.*.b32`'s lane
// operand must be `.b32`/u32; a `mask: i32` Local that the classifier
// landed in the u64 bank (e.g. via an `i64`-typed `mask / 2`) must be
// narrowed with `cvt.u32.u64 %shfl_mask_<dst>, %rd<mask>` first.
fn _nvptx_reg_shfl_mask(id: i64) -> string {
    return "%shfl_mask_" + to_string(id)
}

// _nvptx_operand_text — render one MIR Operand as a PTX operand string
// for the FP64-arithmetic subset (RFC 055 §6.6).
//
//   local       -> the value's PTX virtual register (`%fd<id>`).
//   const_float -> a PTX FP64 immediate (decimal literal).
//   const_int   -> a PTX integer immediate.
//
// RFC 055 055-P0 — const_str / global operands are out of the FP64
// arithmetic slice; they lower to an honest placeholder so the emit
// pass never silently mis-renders. String/global GPU operands are 055-P1+.
fn _nvptx_operand_text(o: Operand) -> string {
    if o.kind == "local" {
        return _nvptx_reg_f64(o.local_id)
    }
    if o.kind == "const_float" {
        return to_string(o.float_val)
    }
    if o.kind == "const_int" {
        return to_string(o.int_val)
    }
    // RFC 055 055-P0 — non-FP64-slice operand kind (const_str / global).
    return "0d0000000000000000"
}

// _nvptx_operand_text_kinds — 055-P3b kind-aware operand renderer. When
// the operand references a MIR Local, consult the classified PReg roster
// to pick the right register name (`%fd`/`%r`/`%rd`/`%p`) instead of the
// 055-P0 unconditional `%fd<id>`. Falls back to `%fd<id>` for operands
// referencing Locals that don't appear in the roster (function params
// + caller-side temporaries that weren't classified by an assignment).
fn _nvptx_operand_text_kinds(o: Operand, kinds: [PReg]) -> string {
    if o.kind == "local" {
        return _nvptx_lookup_reg_for_local(kinds, o.local_id)
    }
    if o.kind == "const_float" {
        return to_string(o.float_val)
    }
    if o.kind == "const_int" {
        return to_string(o.int_val)
    }
    return "0d0000000000000000"
}

// _nvptx_lookup_reg_for_local — given a classified roster (one PReg per
// assignment-target Local), return the PTX register name for `id`. Each
// MIR Local maps to exactly one of `%fd<id>` / `%r<id>` / `%rd<id>` /
// `%p<id>` — test the four candidate names against the roster. Falls
// back to `%fd<id>` if the Local isn't classified (params + ext temps).
fn _nvptx_lookup_reg_for_local(kinds: [PReg], id: i64) -> string {
    let n_f64 = _nvptx_reg_f64(id)
    let n_u32 = _nvptx_reg_u32(id)
    let n_u64 = _nvptx_reg_u64(id)
    let n_pred = _nvptx_reg_pred(id)
    let n_f16 = _nvptx_reg_f16(id)
    let n_bf16 = _nvptx_reg_bf16(id)
    let n_f32 = _nvptx_reg_f32(id)
    let n_e4m3 = _nvptx_reg_f8_e4m3(id)
    let n_e5m2 = _nvptx_reg_f8_e5m2(id)
    // PR-C piece 4+5 — SHARED base pointer reg name (`%sh<id>`).
    let n_sh   = _nvptx_reg_shared(id)
    let mut i = 0
    while i < len(kinds) {
        let n = kinds[i].name
        if n == n_f64 { return n_f64 }
        if n == n_u32 { return n_u32 }
        if n == n_u64 { return n_u64 }
        if n == n_pred { return n_pred }
        if n == n_f16 { return n_f16 }
        if n == n_bf16 { return n_bf16 }
        if n == n_f32 { return n_f32 }
        if n == n_e4m3 { return n_e4m3 }
        if n == n_e5m2 { return n_e5m2 }
        if n == n_sh   { return n_sh }
        i = i + 1
    }
    return n_f64
}

// _nvptx_lookup_kind_for_local — find the PReg whose name matches Local
// `id` under any RKIND, return its kind. Default F64. RFC 068 P4
// `F-RFC068-NUMERIC-EQ` load/store dispatch reads this to pick the
// matching `ld.global.<ty>` / `st.global.<ty>` mnemonic.
fn _nvptx_lookup_kind_for_local(kinds: [PReg], id: i64) -> string {
    let n_f64 = _nvptx_reg_f64(id)
    let n_u32 = _nvptx_reg_u32(id)
    let n_u64 = _nvptx_reg_u64(id)
    let n_pred = _nvptx_reg_pred(id)
    let n_f16 = _nvptx_reg_f16(id)
    let n_bf16 = _nvptx_reg_bf16(id)
    let n_f32 = _nvptx_reg_f32(id)
    let n_e4m3 = _nvptx_reg_f8_e4m3(id)
    let n_e5m2 = _nvptx_reg_f8_e5m2(id)
    // PR-C piece 4+5 — SHARED reg-name probe.
    let n_sh   = _nvptx_reg_shared(id)
    let mut i = 0
    while i < len(kinds) {
        let r = kinds[i]
        if r.name == n_f64 { return NVPTX_RKIND_F64 }
        if r.name == n_u32 { return NVPTX_RKIND_U32 }
        if r.name == n_u64 { return NVPTX_RKIND_U64 }
        if r.name == n_pred { return NVPTX_RKIND_PRED }
        if r.name == n_f16 { return NVPTX_RKIND_F16 }
        if r.name == n_bf16 { return NVPTX_RKIND_BF16 }
        if r.name == n_f32 { return NVPTX_RKIND_F32 }
        if r.name == n_e4m3 { return NVPTX_RKIND_F8_E4M3 }
        if r.name == n_e5m2 { return NVPTX_RKIND_F8_E5M2 }
        if r.name == n_sh   { return NVPTX_RKIND_SHARED }
        i = i + 1
    }
    return NVPTX_RKIND_F64
}

// PR-A (GPU sweep #1284) — array element-kind decode helpers.
// hir_to_mir.hexa::_type_id_of encodes array element kinds as:
//   101 = array<i64>, 102 = array<i32>, 103 = array<f64>, 104 = array<f32>.
// IndexGet/IndexSet sites + the classifier IndexGet dst rule read these
// to drive the right ld/st/add bank (NOT the F64 fall-through default
// that silently miscompiles `[i64]` kernels to ld.global.f64/add.f64).
fn _nvptx_array_elem_kind_for_type_id(tid: i64) -> string {
    if tid == 101 { return NVPTX_RKIND_U64 }
    if tid == 102 { return NVPTX_RKIND_U32 }
    if tid == 103 { return NVPTX_RKIND_F64 }
    if tid == 104 { return NVPTX_RKIND_F32 }
    return ""   // not an array type / unknown element kind
}

// _nvptx_lookup_array_elem_kind_for_local — companion to
// `_nvptx_lookup_kind_for_local`. The array param's PReg kind is U64
// (the device pointer bank — used for address arithmetic), but the
// IndexGet/IndexSet sites need the ELEMENT kind to pick the right
// ld/st bank. The classifier (Pass 0) stamps the element kind into
// `PReg.frag_dtype` for array params; this helper retrieves it.
// Returns "" if the Local isn't an array param (caller falls through
// to the default F64 bank — backward compat for non-array workloads).
fn _nvptx_lookup_array_elem_kind_for_local(kinds: [PReg], id: i64) -> string {
    let n_u64 = _nvptx_reg_u64(id)
    let mut i = 0
    while i < len(kinds) {
        let r = kinds[i]
        if r.name == n_u64 && len(r.frag_dtype) > 0 {
            // Stamped by Pass 0 with NVPTX_RKIND_{U64,U32,F64,F32}.
            return r.frag_dtype
        }
        i = i + 1
    }
    return ""
}

// _nvptx_ld_mnem_for_kind — global load mnemonic per RKIND.
// (RFC 068 P4 `F-RFC068-NUMERIC-EQ` codegen seam.)
fn _nvptx_ld_mnem_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_F16 { return PTX_OP_LD_GLOBAL_F16 }
    if kind == NVPTX_RKIND_BF16 { return PTX_OP_LD_GLOBAL_BF16 }
    if kind == NVPTX_RKIND_F32 { return PTX_OP_LD_GLOBAL_F32 }
    // RFC 068 §3 fp8 scaffold — both e4m3 / e5m2 use `.b8` storage
    // (PTX has no native 8-bit float type tag; the reg interp is
    // selected by the consuming opcode, not the ld/st itself).
    if kind == NVPTX_RKIND_F8_E4M3 { return PTX_OP_LD_GLOBAL_F8 }
    if kind == NVPTX_RKIND_F8_E5M2 { return PTX_OP_LD_GLOBAL_F8 }
    // PR-A (GPU sweep #1284) — integer banks. [i64] / [i32] arrays
    // route through ld.global.u64 / ld.global.u32, not the F64 default
    // (which silently rounded large integers to f64-mantissa precision).
    if kind == NVPTX_RKIND_U64 { return PTX_OP_LD_GLOBAL_U64 }
    if kind == NVPTX_RKIND_U32 { return PTX_OP_LD_GLOBAL_U32 }
    return PTX_OP_LD_GLOBAL_F64
}

// PR-C piece 5 — shared-bank load mnemonic per RKIND. Mirrors
// `_nvptx_ld_mnem_for_kind` but emits `ld.shared.<ty>` (the address-space
// token switches from `.global` to `.shared`). The element-type token
// itself follows the same PR #189 convention — `.f16` / `.bf16` storage
// is `.b16` (ptxas rejects `ld.shared.f16`), fp8 is `.b8`.
fn _nvptx_ld_shared_mnem_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_F16 { return "ld.shared.b16" }
    if kind == NVPTX_RKIND_BF16 { return "ld.shared.b16" }
    if kind == NVPTX_RKIND_F32 { return "ld.shared.f32" }
    if kind == NVPTX_RKIND_F8_E4M3 { return "ld.shared.b8" }
    if kind == NVPTX_RKIND_F8_E5M2 { return "ld.shared.b8" }
    if kind == NVPTX_RKIND_U64 { return "ld.shared.u64" }
    if kind == NVPTX_RKIND_U32 { return "ld.shared.u32" }
    return PTX_OP_LD_SHARED_F64
}

// PR-C piece 5 — shared-bank store mnemonic per RKIND.
fn _nvptx_st_shared_mnem_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_F16 { return "st.shared.b16" }
    if kind == NVPTX_RKIND_BF16 { return "st.shared.b16" }
    if kind == NVPTX_RKIND_F32 { return "st.shared.f32" }
    if kind == NVPTX_RKIND_F8_E4M3 { return "st.shared.b8" }
    if kind == NVPTX_RKIND_F8_E5M2 { return "st.shared.b8" }
    if kind == NVPTX_RKIND_U64 { return "st.shared.u64" }
    if kind == NVPTX_RKIND_U32 { return "st.shared.u32" }
    return PTX_OP_ST_SHARED_F64
}

// _nvptx_st_mnem_for_kind — global store mnemonic per RKIND.
fn _nvptx_st_mnem_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_F16 { return PTX_OP_ST_GLOBAL_F16 }
    if kind == NVPTX_RKIND_BF16 { return PTX_OP_ST_GLOBAL_BF16 }
    if kind == NVPTX_RKIND_F32 { return PTX_OP_ST_GLOBAL_F32 }
    // RFC 068 §3 fp8 scaffold — `.b8` storage for both e4m3 and e5m2.
    if kind == NVPTX_RKIND_F8_E4M3 { return PTX_OP_ST_GLOBAL_F8 }
    if kind == NVPTX_RKIND_F8_E5M2 { return PTX_OP_ST_GLOBAL_F8 }
    // PR-A (GPU sweep #1284) — integer banks. [i64] / [i32] arrays.
    if kind == NVPTX_RKIND_U64 { return PTX_OP_ST_GLOBAL_U64 }
    if kind == NVPTX_RKIND_U32 { return PTX_OP_ST_GLOBAL_U32 }
    return PTX_OP_ST_GLOBAL_F64
}

// _nvptx_kind_short_label — for instruction-comment readability.
fn _nvptx_kind_short_label(kind: string) -> string {
    if kind == NVPTX_RKIND_F16 { return "f16" }
    if kind == NVPTX_RKIND_BF16 { return "bf16" }
    if kind == NVPTX_RKIND_F32 { return "f32" }
    if kind == NVPTX_RKIND_F8_E4M3 { return "f8_e4m3" }
    if kind == NVPTX_RKIND_F8_E5M2 { return "f8_e5m2" }
    return "f64"
}

// _nvptx_elem_size_for_kind — RFC 071 P4+ (N59 G2/G3) — byte width of
// an array element of the given PTX register kind. Used by the
// IndexGet / IndexSet lowering to compute the byte offset
// `idx * sizeof(elem)`. f8 dtypes stay 1 B; pred is non-stored (8 B
// fall-through is benign — pred values don't land in [pred] arrays).
fn _nvptx_elem_size_for_kind(kind: string) -> i64 {
    if kind == NVPTX_RKIND_F16 { return 2 }
    if kind == NVPTX_RKIND_BF16 { return 2 }
    if kind == NVPTX_RKIND_F32 { return 4 }
    if kind == NVPTX_RKIND_F8_E4M3 { return 1 }
    if kind == NVPTX_RKIND_F8_E5M2 { return 1 }
    if kind == NVPTX_RKIND_U32 { return 4 }
    if kind == NVPTX_RKIND_U64 { return 8 }
    return 8   // F64 default
}

// _nvptx_ld_param_mnem_for_kind — RFC 071 P4+ (N59 G2/G4) — kind-aware
// `ld.param.<ty>` mnemonic for the KERNEL param prologue. Each `.param`
// slot is loaded into its assigned register bank with the matching
// element type (i64/i32 params land in U64/U32 regs; f64/f32 land in
// FP regs; arrays / unknown-type land in U64 as device pointers).
fn _nvptx_ld_param_mnem_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_U32 { return "ld.param.u32" }
    if kind == NVPTX_RKIND_U64 { return "ld.param.u64" }
    if kind == NVPTX_RKIND_F32 { return "ld.param.f32" }
    if kind == NVPTX_RKIND_F16 { return "ld.param.f16" }
    if kind == NVPTX_RKIND_BF16 { return "ld.param.bf16" }
    return "ld.param.f64"
}

// _nvptx_mov_mnem_for_kind — RFC 071 P4+ (N59 G4) — kind-aware
// `mov.<ty>` mnemonic for STMT_ASSIGN lowering. A U32-classified dst
// must emit `mov.u32 ...` (not `mov.f64`) so ptxas accepts the
// instruction without bank-mismatch errors. Maps each RKIND to its
// canonical PTX mov form per PTX ISA §9.7.1.1.
fn _nvptx_mov_mnem_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_U32 { return "mov.u32" }
    if kind == NVPTX_RKIND_U64 { return "mov.u64" }
    if kind == NVPTX_RKIND_PRED { return "mov.pred" }
    if kind == NVPTX_RKIND_F16 { return "mov.b16" }
    if kind == NVPTX_RKIND_BF16 { return "mov.b16" }
    if kind == NVPTX_RKIND_F32 { return "mov.f32" }
    if kind == NVPTX_RKIND_F8_E4M3 { return "mov.b8" }
    if kind == NVPTX_RKIND_F8_E5M2 { return "mov.b8" }
    return "mov.f64"
}

// _nvptx_binop_mnemonic — map a MIR binop opcode to its PTX mnemonic.
// Covers the FP64 arithmetic subset (RFC 055 §6.6) PLUS the RFC 068 P3
// mixed-precision subset (`add_f16/_bf16/_f32`, sub/mul siblings) so
// PTX body emit matches the `.reg` bank declared via PR #148 short-
// circuit. A MIR binop outside the recognized set returns "" so the
// caller emits an honest `// RFC 055 055-P0 — unsupported binop` stub.
fn _nvptx_binop_mnemonic(op: string) -> string {
    if op == "add" || op == "+" { return PTX_OP_ADD_F64 }
    if op == "sub" || op == "-" { return PTX_OP_SUB_F64 }
    if op == "mul" || op == "*" { return PTX_OP_MUL_F64 }
    // RFC 071 P4+ — FP64 division (N56 vec_div gap). PTX ISA §9.7.1.4
    // requires an EXPLICIT rounding suffix on `div.<ty>` — bare `div.f64`
    // is not a legal mnemonic. For FP64 the ONLY native ISA mode is
    // `div.rn.f64` (IEEE round-to-nearest, ~52-bit accurate). There is
    // no `div.approx.f64` / `div.full.f64` (those exist only for `.f32`),
    // so this is the unique sensible default — no precision-policy
    // branching needed at the FP64 mnemonic table. Matches the
    // round-to-nearest default of `add.f64` / `sub.f64` / `mul.f64` (which
    // omit the `.rn` suffix because round-to-nearest is the implicit
    // default for those ops; div is the exception that requires the
    // explicit suffix).
    if op == "div" || op == "/" { return PTX_OP_DIV_RN_F64 }
    // RFC 068 P3 `F-RFC068-BODY-MNEMONIC` — mixed-precision arithmetic
    // mnemonics. The opcode-suffix comes from `hir_to_mir.hexa`'s
    // `_op_with_precision` (PR #170) when the dst Local carries an
    // explicit precision tag. Each new mnemonic matches the dst reg
    // bank declared by `_nvptx_classify_local_for_stmt`'s short-circuit:
    //   add_f16/sub_f16/mul_f16   → `add.f16 / sub.f16 / mul.f16`     → `%fh<id>` bank
    //   add_bf16/sub_bf16/mul_bf16 → `add.bf16 / sub.bf16 / mul.bf16` → `%fb<id>` bank
    //   add_f32/sub_f32/mul_f32   → `add.f32 / sub.f32 / mul.f32`     → `%fs<id>` bank
    if op == "add_f16"  { return "add.f16" }
    if op == "sub_f16"  { return "sub.f16" }
    if op == "mul_f16"  { return "mul.f16" }
    if op == "add_bf16" { return "add.bf16" }
    if op == "sub_bf16" { return "sub.bf16" }
    if op == "mul_bf16" { return "mul.bf16" }
    if op == "add_f32"  { return "add.f32" }
    if op == "sub_f32"  { return "sub.f32" }
    if op == "mul_f32"  { return "mul.f32" }
    // FP32 division — the "future codegen-side div row" that hir_to_mir's
    // `_op_with_precision` already emits `div_f32` for. PTX `div.rn.f32`
    // is IEEE round-to-nearest full-precision (matches the FP64
    // `div.rn.f64` default). Needed by ML kernels (softmax `e/Σe`,
    // layernorm `x/√var`). f16/bf16 div has NO native PTX mnemonic
    // (requires cvt-up → div.rn.f32 → cvt-down) → left as an honest ""
    // stub — SAFE (no wrong-mnemonic silent miscompile, just unsupported).
    if op == "div_f32"  { return "div.rn.f32" }
    return ""
}

// _nvptx_binop_mnemonic_for_kind — RFC 071 P4+ (N59 G4 sibling) —
// kind-aware ARITHMETIC binop mnemonic resolver. Integer-typed dst
// banks emit signed-integer PTX (add.s32 / mul.lo.s32 / add.s64 /
// mul.lo.s64); FP banks fall through to the FP64-default
// `_nvptx_binop_mnemonic`. PTX integer multiplies need a .lo / .hi /
// .wide qualifier (PTX ISA 9.7.1.3 mul); .lo selects the low half of
// the product, matching C-style int multiplication. Returns "" when
// no recognized mnemonic exists (caller emits an honest stub).
//
// RFC 071 N71-C — integer `/` and `%` on a u32/u64 dst bank. WITHOUT
// these arms, integer div/rem fell through to `_nvptx_binop_mnemonic`,
// which returns the FP64 `div.rn.f64` for "/" — a ptxas-REJECTED
// mnemonic on integer registers (silent miscompile: index math like
// `tid/32` / `mask/2` produced garbage → kernel hang, N70/N91 GAP-B).
// PTX integer division is `div.s32` / `div.s64` and remainder is
// `rem.s32` / `rem.s64` (PTX ISA 9.7.1.4), signed to match the existing
// add/sub/mul .s32/.s64 banks.
//
// Integer bitwise/shift on a u32/u64 dst bank (same fall-through-to-FP64
// silent-miscompile risk as div had). `& | ^` → untyped bit ops
// `and/or/xor.b32|b64`; `<<` → `shl.b32|b64`; `>>` → ARITHMETIC
// `shr.s32|s64` (hexa i32/i64 are signed; for the non-negative index/lane
// values these banks hold, arithmetic and logical shr agree). PTX ISA
// 9.7.1.2 (logic) + 9.7.1.10 (shift). Enables bit-math @gpu_kernels
// (masking / packing / quantization / swizzle d2xy) on the codegen path.
fn _nvptx_binop_mnemonic_for_kind(op: string, kind: string) -> string {
    if kind == NVPTX_RKIND_U32 {
        if op == "add" || op == "+" { return "add.s32" }
        if op == "sub" || op == "-" { return "sub.s32" }
        if op == "mul" || op == "*" { return "mul.lo.s32" }
        if op == "div" || op == "/" { return "div.s32" }
        if op == "rem" || op == "%" { return "rem.s32" }
        if op == "and" || op == "&" { return "and.b32" }
        if op == "or"  || op == "|" { return "or.b32" }
        if op == "xor" || op == "^" { return "xor.b32" }
        if op == "shl" || op == "<<" { return "shl.b32" }
        if op == "shr" || op == ">>" { return "shr.s32" }
    }
    if kind == NVPTX_RKIND_U64 {
        if op == "add" || op == "+" { return "add.s64" }
        if op == "sub" || op == "-" { return "sub.s64" }
        if op == "mul" || op == "*" { return "mul.lo.s64" }
        if op == "div" || op == "/" { return "div.s64" }
        if op == "rem" || op == "%" { return "rem.s64" }
        if op == "and" || op == "&" { return "and.b64" }
        if op == "or"  || op == "|" { return "or.b64" }
        if op == "xor" || op == "^" { return "xor.b64" }
        if op == "shl" || op == "<<" { return "shl.b64" }
        if op == "shr" || op == ">>" { return "shr.s64" }
    }
    return _nvptx_binop_mnemonic(op)
}

// ── RFC 055 §13 — floating-point math intrinsics (NN-stack) ───────────
//
// Source-level math builtins (`sqrt(x)` / `max(a,b)` / `min(a,b)` /
// `exp(x)` / `abs(x)` / `rsqrt(x)`) lower through `call → STMT_CALL`
// (hir_to_mir.hexa L1048-1245) with the callee text verbatim in `s.op`
// and the source arguments in `s.args` — the SAME path the CPU codegen
// recognises as math builtins (`hexa_math_sqrt` / `rt_math_max_v` …;
// self/codegen.hexa cg_math_sym). On the NVPTX target these reached the
// `// unsupported call` stub before this cycle. softmax (exp / max),
// RMSNorm / LayerNorm (sqrt / rsqrt), and attention (max) all need them.
//
// These are the SAME bare names CPU codegen maps; no @gpu_kernel frontend
// restriction filters them (hir_to_mir.hexa::_make_mfunc lowers a kernel
// body through the normal `_lower_hexpr` path).

// _nvptx_is_math_intrinsic — does this STMT_CALL op name denote one of
// the wired floating-point math builtins?
fn _nvptx_is_math_intrinsic(op: string) -> bool {
    if op == "sqrt"     { return true }
    if op == "rsqrt"    { return true }
    if op == "rsqrt_rn" { return true }
    if op == "max"      { return true }
    if op == "min"      { return true }
    if op == "exp"      { return true }
    if op == "abs"      { return true }
    return false
}

// _nvptx_math_arity — operand count for a math intrinsic (1 for unary
// sqrt / rsqrt / exp / abs; 2 for binary max / min). Returns 0 for a
// non-math op (caller should not have routed it here).
fn _nvptx_math_arity(op: string) -> i64 {
    if op == "max" || op == "min" { return 2 }
    if op == "sqrt" || op == "rsqrt" || op == "rsqrt_rn" || op == "exp" || op == "abs" { return 1 }
    return 0
}

// _nvptx_math_mnemonic_for_kind — pick the EXACT-op single-instruction
// PTX mnemonic for a math intrinsic at a given register kind. Returns ""
// when the op needs a multi-instruction decomposition (exp) or is not
// representable at this kind (rsqrt at f64 — `rsqrt.approx` is f32-only,
// no native f64 mnemonic; the body lowering honest-stubs that case).
//   sqrt  → sqrt.rn.f32 / sqrt.rn.f64    (EXACT, IEEE round-to-nearest)
//   rsqrt → rsqrt.approx.f32 (f32 only)  (APPROX, ~2^-23 rel tol)
//   max   → max.{f32,f64,s32,s64}        (EXACT)
//   min   → min.{f32,f64,s32,s64}        (EXACT)
//   abs   → abs.{f32,f64}                (EXACT)
//   ref: PTX ISA 9.7.3 (floating-point) + 9.7.2 (integer).
fn _nvptx_math_mnemonic_for_kind(op: string, kind: string) -> string {
    if op == "sqrt" {
        if kind == NVPTX_RKIND_F32 { return PTX_OP_SQRT_RN_F32 }
        return PTX_OP_SQRT_RN_F64
    }
    if op == "rsqrt" {
        // rsqrt.approx has no f64 mnemonic — only f32. F64 rsqrt is an
        // honest stub (a `1.0/sqrt.rn.f64` decomposition is a follow-on).
        if kind == NVPTX_RKIND_F32 { return PTX_OP_RSQRT_APPROX_F32 }
        return ""
    }
    if op == "max" {
        if kind == NVPTX_RKIND_F32 { return PTX_OP_MAX_F32 }
        if kind == NVPTX_RKIND_U32 { return PTX_OP_MAX_S32 }
        if kind == NVPTX_RKIND_U64 { return PTX_OP_MAX_S64 }
        return PTX_OP_MAX_F64
    }
    if op == "min" {
        if kind == NVPTX_RKIND_F32 { return PTX_OP_MIN_F32 }
        if kind == NVPTX_RKIND_U32 { return PTX_OP_MIN_S32 }
        if kind == NVPTX_RKIND_U64 { return PTX_OP_MIN_S64 }
        return PTX_OP_MIN_F64
    }
    if op == "abs" {
        if kind == NVPTX_RKIND_F32 { return PTX_OP_ABS_F32 }
        return PTX_OP_ABS_F64
    }
    // exp has no single-instruction form (decomposed in the body lowering).
    return ""
}

// _nvptx_cmp_mnemonic — map a MIR comparison binop opcode to the PTX
// `setp.<cond>.f64` mnemonic. PTX condition names match the MIR opcodes
// 1:1 (`lt` / `le` / `gt` / `ge` / `eq` / `ne`); 055-P3b uses `.f64` as
// the comparand type to match the FP64-first scope (gpu/SPEC.md §8) —
// integer comparisons (`.s32` / `.s64`) come through the kind-aware
// `_nvptx_cmp_mnemonic_for_type` wrapper below. Returns "" for
// non-comparison ops. RETAINED as the FP64-default callee so the
// existing 055-P3b smoke tests (`_test_setp_and_br_cond` etc.) stay
// byte-identical.
fn _nvptx_cmp_mnemonic(op: string) -> string {
    // RFC 071 P4+ (N59 G1) — accept symbol-form spellings alongside
    // the word forms so HIR->MIR-emitted `<` / `<=` / `>` / `>=` / `==`
    // / `!=` get a valid setp mnemonic instead of falling through to
    // the unsupported-binop stub.
    if op == "lt" || op == "<"  { return "setp.lt.f64" }
    if op == "le" || op == "<=" { return "setp.le.f64" }
    if op == "gt" || op == ">"  { return "setp.gt.f64" }
    if op == "ge" || op == ">=" { return "setp.ge.f64" }
    if op == "eq" || op == "==" { return "setp.eq.f64" }
    if op == "ne" || op == "!=" { return "setp.ne.f64" }
    return ""
}

// _nvptx_cmp_type_suffix_for_kind — pick the `.<ty>` suffix appended to
// a `setp.<cond>` mnemonic based on the register-bank kind of the
// comparison's source operand. RFC 071 P3+ — opens integer compares
// (`setp.lt.s64` for the i64-vs-i64 bounds check that arises from
// `to_i64(gid) < n`; `setp.lt.s32` for the i32-vs-i32 sibling). FP banks
// keep their existing `.f64` / `.f32` / `.f16` / `.bf16` defaults. The
// PTX integer-compare conditions (`eq`/`ne`/`lt`/`le`/`gt`/`ge`) are
// SIGNED (`.s*`) — gpu/SPEC.md §4 treats the source-level `<` on `i*`
// types as signed-int compare (UNSIGNED variants would key off `u*` MIR
// opcodes which the HIR→MIR layer doesn't synthesize yet).
//   ref: PTX ISA 8.7 §9.7.1.6 — setp predicates by type.
fn _nvptx_cmp_type_suffix_for_kind(kind: string) -> string {
    if kind == NVPTX_RKIND_U64 { return ".s64" }
    if kind == NVPTX_RKIND_U32 { return ".s32" }
    if kind == NVPTX_RKIND_F32 { return ".f32" }
    if kind == NVPTX_RKIND_F16 { return ".f16" }
    if kind == NVPTX_RKIND_BF16 { return ".bf16" }
    return ".f64"
}

// _nvptx_cmp_mnemonic_for_type — RFC 071 P3+ kind-aware setp mnemonic
// resolver. Identical to `_nvptx_cmp_mnemonic` for FP64 (the empty /
// default case) so callers that pass `.f64` get byte-identical output;
// callers that thread a non-default suffix (`.s32` / `.s64` for the
// integer bounds-check path) get the matching `setp.<cond><suffix>`.
// Returns "" for non-comparison ops (mirrors the F64 variant).
fn _nvptx_cmp_mnemonic_for_type(op: string, ty_suffix: string) -> string {
    // FP64 default short-circuit — preserves the 055-P3b byte-output.
    if ty_suffix == "" || ty_suffix == ".f64" {
        return _nvptx_cmp_mnemonic(op)
    }
    if op == "lt" || op == "<"  { return "setp.lt" + ty_suffix }
    if op == "le" || op == "<=" { return "setp.le" + ty_suffix }
    if op == "gt" || op == ">"  { return "setp.gt" + ty_suffix }
    if op == "ge" || op == ">=" { return "setp.ge" + ty_suffix }
    if op == "eq" || op == "==" { return "setp.eq" + ty_suffix }
    if op == "ne" || op == "!=" { return "setp.ne" + ty_suffix }
    return ""
}

// _nvptx_cmp_operand_type_suffix — RFC 071 P3+ — pick the `.<ty>`
// suffix for a `setp.<cond>` from a comparison binop's two source
// operands. Inspects the classified kind of BOTH `local` operands and
// returns the WIDEST integer suffix when the operands have different
// integer widths (`.s64` > `.s32`); falls back to F64 (the 055-P3b
// default) when both operands are unclassified or const literals.
//
// N73 (RFC 071 P4+) — widest-wins, NOT "first non-default wins". The
// canonical bounds-check `i < n` IS a mixed-bank compare: `i` is a
// 32-bit thread-index (`gpu_thread_id_x()+...` → u32 bank, `.s32`),
// `n` is an i64 param (loaded as u64, `.s64`). The old first-match
// policy returned `.s32` (from `i`) and ptxas REJECTED the resulting
// `setp.lt.s32 %p, %r, %rd` (the u64 operand `%rd` mismatches the
// `.s32` suffix — "Arguments mismatch for instruction 'setp'"). The
// fix inspects both operands and returns `.s64` whenever EITHER
// classifies into the 64-bit integer bank, so the setp's suffix matches
// the wider operand. The narrow operand is then sign-extended at the
// emit site (the `%cmpw_<dst>` widen). FP banks + same-width int cases
// stay byte-identical (a same-bank `.s32`/`.s32` returns `.s32`; a pure
// `.f64`/`.f64` returns `.f64` — the `_test_setp_and_br_cond` default).
// const-only operands keep the F64 default since the MIR layer doesn't
// propagate a literal's type into a per-Operand kind tag yet.
fn _nvptx_cmp_operand_type_suffix(a: Operand, b: Operand, kinds: [PReg]) -> string {
    let mut sa = ".f64"
    let mut sb = ".f64"
    if a.kind == "local" {
        sa = _nvptx_cmp_type_suffix_for_kind(_nvptx_lookup_kind_for_local(kinds, a.local_id))
    }
    if b.kind == "local" {
        sb = _nvptx_cmp_type_suffix_for_kind(_nvptx_lookup_kind_for_local(kinds, b.local_id))
    }
    // Widest-int wins: if either operand is the 64-bit integer bank,
    // the setp suffix MUST be `.s64` (the narrow operand is widened at
    // the emit site). This handles the mixed-width `i32 < i64`
    // bounds-check that the HIR→MIR layer DOES synthesize.
    if sa == ".s64" || sb == ".s64" { return ".s64" }
    // Otherwise the first non-F64-default suffix (same-width or single
    // explicit bank) — preserves the prior byte-output for every
    // non-mixed case (.s32/.s32, .f32, .f16, .bf16, single explicit).
    if sa != ".f64" { return sa }
    if sb != ".f64" { return sb }
    return ".f64"
}

// _nvptx_gpu_intrinsic_sreg — map a known gpu intrinsic STMT_CALL op
// name to the PTX special-register reference its body lowers to (a
// `mov.u32 %r<dst>, <sreg>.<axis>;`). gpu/SPEC.md §5 specifies the
// per-axis names; the classifier already routes the call dst into a
// `.reg .u32` bank, so the lowering only needs the `sreg.axis` string.
// Returns "" for non-intrinsic call names.
fn _nvptx_gpu_intrinsic_sreg(op: string) -> string {
    if op == "gpu_thread_id_x" { return PTX_SREG_TID + ".x" }
    if op == "gpu_thread_id_y" { return PTX_SREG_TID + ".y" }
    if op == "gpu_thread_id_z" { return PTX_SREG_TID + ".z" }
    if op == "gpu_block_id_x"  { return PTX_SREG_CTAID + ".x" }
    if op == "gpu_block_id_y"  { return PTX_SREG_CTAID + ".y" }
    if op == "gpu_block_id_z"  { return PTX_SREG_CTAID + ".z" }
    if op == "gpu_block_dim_x" { return PTX_SREG_NTID + ".x" }
    if op == "gpu_block_dim_y" { return PTX_SREG_NTID + ".y" }
    if op == "gpu_block_dim_z" { return PTX_SREG_NTID + ".z" }
    if op == "gpu_grid_dim_x"  { return PTX_SREG_NCTAID + ".x" }
    if op == "gpu_grid_dim_y"  { return PTX_SREG_NCTAID + ".y" }
    if op == "gpu_grid_dim_z"  { return PTX_SREG_NCTAID + ".z" }
    return ""
}

// RFC 067 marker — Real WMMA emit. The mnemonic table below is the
// SEAM that RFC 067 P3 re-keys by (op, role, dtype, layout) so non-
// canonical families (bf16×bf16→f32, f16×f16→f16, tf32) become
// reachable. See `docs/rfc/rfc_drafts_2026_05_20/rfc_067_wmma_real_emit.md`
// §3 P3 for the re-key plan and §4 F3 (F-RFC067-DTYPE-FAMILY) for the
// substring falsifier that closes that phase.
//
// _nvptx_wmma_mnemonic — map a `gpu_wmma_*` STMT_CALL op name to the
// PTX WMMA mnemonic (RFC 055 §12 P4+ Tensor Core MMA). SCAFFOLD ONLY —
// recognizing the op and resolving its mnemonic is all this returns.
// The lowering site emits a `// RFC 055 §12 P4+ WMMA (scaffold ...` stub
// comment, NOT a real PTX wmma instruction. A working emit needs (per
// the deferred-work list below) fragment register-bank allocation, a
// `.shared` staging declaration, per-fragment dtype tags, row/col
// orientation handling, and tile-loop integration — none of which this
// scaffold provides.
//
// First mnemonic table — the f16×f16→f32 family on the canonical
// m16n16k16 tile geometry (PTX ISA §9.7.13.4). The mnemonics are
// shaped so a later cycle can swap in per-fragment overrides without
// touching the call-site lookup.
//   gpu_wmma_load_a  — load matrix-A fragment from .shared, row-major, f16
//   gpu_wmma_load_b  — load matrix-B fragment from .shared, col-major, f16
//   gpu_wmma_mma     — multiply-accumulate, A.row × B.col → C.f32
//   gpu_wmma_store_c — store matrix-D (= C accumulator) to .shared, row-major, f32
//
// Returns "" for non-WMMA ops so the call-site can fall through to
// the next handler (or the unsupported-call stub).
fn _nvptx_wmma_mnemonic(op: string) -> string {
    // PTX ISA 7.0 §9.7.13.4 grammar: state-space token precedes the
    // element type on load/store (`.shared.f16`, NOT `.f16.shared`); the
    // f16×f16→f32 `wmma.mma` uses the SHORT 2-type form (`.f32.f32`) — the
    // long 4-type form `.f32.f16.f16.f32` is reserved for non-f16
    // multiplicands (bf16/tf32) and is ptxas-REJECTED for f16 (N122).
    if op == "gpu_wmma_load_a"  { return "wmma.load.a.sync.aligned.row.m16n16k16.shared.f16" }
    if op == "gpu_wmma_load_b"  { return "wmma.load.b.sync.aligned.col.m16n16k16.shared.f16" }
    if op == "gpu_wmma_mma"     { return "wmma.mma.sync.aligned.row.col.m16n16k16.f32.f32" }
    if op == "gpu_wmma_store_c" { return "wmma.store.d.sync.aligned.row.m16n16k16.shared.f32" }
    return ""
}

// _nvptx_lower_stmt — lower one MIR statement to PTX-flavored LInstr
// records, appending to `buf`. FP64-arithmetic subset only (RFC 055 §6.6).
//
//   STMT_ASSIGN  (1 arg)  -> `mov.f64  %fd<dst>, <src>`
//   STMT_BINOP   (2 args) -> `<op>.f64 %fd<dst>, <a>, <b>`
//   STMT_RETURN           -> `ret`  (the result lives in its %fd register;
//                            a PTX `.entry` writes results to a .global
//                            farr — that store wiring is 055-P1).
//
// RFC 055 055-P0 — STMT_CALL / STMT_BR / STMT_BR_COND / STMT_LOAD /
// STMT_STORE are NOT in the straight-line FP64 arithmetic slice; each
// lowers to an honest stub LInstr (op = "//") so the emitted PTX text
// stays readable and never silently drops a statement. Control flow
// (`bra`, `setp`) and global/shared load/store are 055-P1+.
// RFC 071 P4+ — `shared_idx_off` is a flat `[idx_local_id, elem_size, ...]`
// array (output of `_nvptx_collect_shared_idx_locals`). When non-empty
// AND the current IndexGet/IndexSet's idx operand matches, the body
// lowering emits `add.s64 addr, %rd_idx_off_<id>_<sz>, base` (2 instr)
// instead of `mul.lo.s64 addr, idx, sz; add.s64 addr, addr, base`
// (3 instr). The shared offset is declared as a U64 reg by
// `_nvptx_lower_func` and materialized once at the first qualifying
// index-op via an inline `mul.lo.s64` emitted in the per-block walk
// (which sees use/def order — kernel-entry pre-emit would compute the
// offset on the inactive lane when the index sits inside an
// `if to_i64(gid) < n { … }` bounds-check shape).
fn _nvptx_lower_stmt(buf: [LInstr], s: Stmt, kinds: [PReg], shared_idx_off: [i64]) -> [LInstr] {
    let mut out = buf
    if s.kind == STMT_ASSIGN {
        // RFC 071 P4+ (N59 G2) — `op == "index"` (IndexGet, `dst = base[idx]`).
        // Emit address compute + ld.global.<ty>. The scratch addr register
        // `%rd_idxa_<dst.id>` is pre-declared by `_nvptx_classify_locals`.
        //   mul.lo.s64  %rd_idxa_<id>, <idx_reg>, sizeof(elem);
        //   add.s64     %rd_idxa_<id>, %rd_idxa_<id>, <base_reg>;
        //   ld.global.<ty>  %<dst_reg>, [%rd_idxa_<id>];
        if s.op == "index" && s.dst.id >= 0 && len(s.args) >= 2 {
            // PR-A (GPU sweep #1284) — array element-kind threading.
            // Prefer the array base's element kind (stamped by Pass 0
            // into PReg.frag_dtype for array params). Falls back to the
            // dst Local's classified kind when the base isn't a known
            // array param (synthetic test fixtures + scalar pointers).
            let mut dst_kind = ""
            if s.args[0].kind == "local" {
                dst_kind = _nvptx_lookup_array_elem_kind_for_local(kinds, s.args[0].local_id)
            }
            if len(dst_kind) == 0 {
                dst_kind = _nvptx_lookup_kind_for_local(kinds, s.dst.id)
            }
            // PR-C piece 5 — @shared bank detection. If the base operand
            // is a Local whose PReg kind is SHARED, the IndexGet routes
            // to `ld.shared.<ty>` instead of `ld.global.<ty>`. The element
            // type defaults to f64 when no array-elem hint is attached
            // (the SHARED base PReg has no frag_dtype-as-elem hint today
            // — sm Locals are typeless in MIR; future cycles thread the
            // element kind via Local.precision or a dedicated field).
            let mut is_shared = false
            if s.args[0].kind == "local" {
                let base_kind = _nvptx_lookup_kind_for_local(kinds, s.args[0].local_id)
                if base_kind == NVPTX_RKIND_SHARED { is_shared = true }
            }
            let elem_size = _nvptx_elem_size_for_kind(dst_kind)
            let dst_reg = _nvptx_lookup_reg_for_local(kinds, s.dst.id)
            let base_reg = _nvptx_operand_text_kinds(s.args[0], kinds)
            let idx_reg = _nvptx_operand_text_kinds(s.args[1], kinds)
            let addr_reg = "%rd_idxa_" + to_string(s.dst.id)
            // RFC 071 P4+ — shared-offset fast path. If the idx operand
            // is a Local that's referenced by 2+ index ops (collected
            // by `_nvptx_collect_shared_idx_locals`), the byte-offset
            // (idx * elem_size) has already been computed into the
            // shared `%rd_idx_off_<id>_<sz>` register by an earlier
            // inline `mul.lo.s64` emit in this block. Skip the
            // per-op mul and read directly from the shared offset.
            let idx_op = s.args[1]
            let mut used_shared = false
            if idx_op.kind == "local" && _nvptx_shared_idx_has(shared_idx_off, idx_op.local_id, elem_size) {
                used_shared = true
                let shared_reg = _nvptx_shared_idx_off_reg(idx_op.local_id, elem_size)
                let mut a2 = []
                a2.push(_nvptx_op(addr_reg))
                a2.push(_nvptx_op(shared_reg))
                a2.push(_nvptx_op(base_reg))
                out.push(_nvptx_instr("add.s64", a2, "index addr = shared_off + base"))
            }
            if !used_shared {
                let mut a1 = []
                a1.push(_nvptx_op(addr_reg))
                a1.push(_nvptx_op(idx_reg))
                a1.push(_nvptx_op(to_string(elem_size)))
                out.push(_nvptx_instr("mul.lo.s64", a1, "index byte off = idx * " + to_string(elem_size)))
                let mut a2 = []
                a2.push(_nvptx_op(addr_reg))
                a2.push(_nvptx_op(addr_reg))
                a2.push(_nvptx_op(base_reg))
                out.push(_nvptx_instr("add.s64", a2, "index addr = base + off"))
            }
            let mut a3 = []
            a3.push(_nvptx_op(dst_reg))
            a3.push(_nvptx_op(_nvptx_addr_deref(addr_reg)))
            // PR-C piece 5 — address-space dispatch. SHARED base → `ld.shared.<ty>`,
            // every other base (.global default + future .const / .param) stays
            // on `ld.global.<ty>`. This is the byte-eq-preserving leaf swap: the
            // operand shape (dst_reg + addr_reg dereference) is identical to the
            // existing path; only the mnemonic prefix `.global` → `.shared`.
            let mnem = if is_shared { _nvptx_ld_shared_mnem_for_kind(dst_kind) } else { _nvptx_ld_mnem_for_kind(dst_kind) }
            let space_tag = if is_shared { " .shared" } else { "" }
            out.push(_nvptx_instr(mnem, a3, "ld base[idx]" + space_tag + " (" + _nvptx_kind_short_label(dst_kind) + ")"))
            return out
        }
        // RFC 071 P4+ (N59 G3) — `op == "index_set"` (IndexSet,
        // `base[key] = val`). Emit address compute + st.global.<ty>.
        // Single shared scratch %rd_idxs_addr (declared in Pass 3).
        if s.op == "index_set" && len(s.args) >= 3 {
            let val_op = s.args[2]
            let mut val_kind = NVPTX_RKIND_F64
            // PR-A (GPU sweep #1284) — prefer array element kind for the
            // store bank. The val_op's classified kind may have been
            // tainted by Pass-1 F64 default if upstream BINOPs didn't
            // pick up integer banks (e.g. via op="index" loads with
            // unclassified base). The base operand's element kind is
            // the authoritative ground truth for the store bank.
            let mut base_elem_kind = ""
            if s.args[0].kind == "local" {
                base_elem_kind = _nvptx_lookup_array_elem_kind_for_local(kinds, s.args[0].local_id)
            }
            if len(base_elem_kind) > 0 {
                val_kind = base_elem_kind
            } else if val_op.kind == "local" {
                val_kind = _nvptx_lookup_kind_for_local(kinds, val_op.local_id)
            }
            // PR-C piece 5 — @shared store detection (mirrors IndexGet).
            let mut is_shared_set = false
            if s.args[0].kind == "local" {
                let base_kind_s = _nvptx_lookup_kind_for_local(kinds, s.args[0].local_id)
                if base_kind_s == NVPTX_RKIND_SHARED { is_shared_set = true }
            }
            let elem_size = _nvptx_elem_size_for_kind(val_kind)
            let base_reg = _nvptx_operand_text_kinds(s.args[0], kinds)
            let idx_reg = _nvptx_operand_text_kinds(s.args[1], kinds)
            let val_reg = _nvptx_operand_text_kinds(val_op, kinds)
            let addr_reg = "%rd_idxs_addr"
            // RFC 071 P4+ — shared-offset fast path (mirrors IndexGet).
            let idx_op = s.args[1]
            let mut used_shared = false
            if idx_op.kind == "local" && _nvptx_shared_idx_has(shared_idx_off, idx_op.local_id, elem_size) {
                used_shared = true
                let shared_reg = _nvptx_shared_idx_off_reg(idx_op.local_id, elem_size)
                let mut a2 = []
                a2.push(_nvptx_op(addr_reg))
                a2.push(_nvptx_op(shared_reg))
                a2.push(_nvptx_op(base_reg))
                out.push(_nvptx_instr("add.s64", a2, "index_set addr = shared_off + base"))
            }
            if !used_shared {
                let mut a1 = []
                a1.push(_nvptx_op(addr_reg))
                a1.push(_nvptx_op(idx_reg))
                a1.push(_nvptx_op(to_string(elem_size)))
                out.push(_nvptx_instr("mul.lo.s64", a1, "index_set byte off = idx * " + to_string(elem_size)))
                let mut a2 = []
                a2.push(_nvptx_op(addr_reg))
                a2.push(_nvptx_op(addr_reg))
                a2.push(_nvptx_op(base_reg))
                out.push(_nvptx_instr("add.s64", a2, "index_set addr = base + off"))
            }
            let mut a3 = []
            a3.push(_nvptx_op(_nvptx_addr_deref(addr_reg)))
            a3.push(_nvptx_op(val_reg))
            // PR-C piece 5 — address-space dispatch (mirror of IndexGet).
            let mnem = if is_shared_set { _nvptx_st_shared_mnem_for_kind(val_kind) } else { _nvptx_st_mnem_for_kind(val_kind) }
            let space_tag = if is_shared_set { " .shared" } else { "" }
            out.push(_nvptx_instr(mnem, a3, "st base[idx] = val" + space_tag + " (" + _nvptx_kind_short_label(val_kind) + ")"))
            return out
        }
        // RFC 071 P4+ (N59 G5) — `_miss_local()` sentinel guard. A
        // STMT_ASSIGN whose dst.id < 0 carries no observable value (the
        // MIR layer emits it when a source-level expression's value is
        // discarded, or for op-shapes already handled above whose dst is
        // void). Without this guard `_nvptx_lookup_reg_for_local`
        // resolves to `%fd-1` — ptxas rejects the negative reg-id
        // syntax. The safe lowering is to drop the mov entirely +
        // record an honest stub so the surface stays self-describing.
        if s.dst.id < 0 {
            out.push(_nvptx_instr("//", [], "RFC 071 P4+ - skipped STMT_ASSIGN with miss-local dst (op=" + s.op + ")"))
            return out
        }
        // PR-C piece 6 — SHARED-bank dst default-init skip.
        // A bare `@shared let sm: [f64; N]` lowers (via hir_to_mir) into
        // a default-init STMT_ASSIGN whose dst is the SHARED-bank Local
        // (`Local.space == "shared"`). The prologue in `_nvptx_lower_func`
        // already initialises that `%sh<id>` reg with
        //   mov.u64 %sh<id>, _hexa_sh_<fn> + <offset>;
        // emitting a second `mov.f64 %sh<id>, 0;` here (the dst_kind
        // fall-through path) clobbers the runtime shared address — ptxas
        // rejects `mov.f64` into a `.reg .u64` reg ("Arguments mismatch
        // for instruction 'mov'"), surfaced by F-GPU-SWEEP-SHARED-REDUCE-
        // NUMERIC #1320. The safe lowering is to skip the redundant emit.
        if _nvptx_lookup_kind_for_local(kinds, s.dst.id) == NVPTX_RKIND_SHARED {
            out.push(_nvptx_instr("//", [], "PR-C piece 6 - skipped default-init STMT_ASSIGN for SHARED-bank dst (op=" + s.op + ", id=" + to_string(s.dst.id) + ")"))
            return out
        }
        if len(s.args) >= 1 {
            // 055-P3b kind-aware — destination reg picks .f64 / .u32 /
            // .u64 / .pred from the classifier; operand text likewise
            // resolves via `_nvptx_operand_text_kinds`.
            //
            // RFC 071 P4+ (N59 G4) — kind-aware mov mnemonic. The
            // classifier now routes integer-typed Locals (i64 / i32) to
            // U64 / U32 banks per `_nvptx_classify_local_for_stmt`'s
            // type_id rule; the mov mnemonic must match (mov.u64 /
            // mov.u32) so ptxas accepts mixed-bank-free PTX.
            let dst_kind = _nvptx_lookup_kind_for_local(kinds, s.dst.id)
            let mov_mnem = _nvptx_mov_mnem_for_kind(dst_kind)
            let mut a = []
            a.push(_nvptx_op(_nvptx_lookup_reg_for_local(kinds, s.dst.id)))
            a.push(_nvptx_op(_nvptx_operand_text_kinds(s.args[0], kinds)))
            out.push(_nvptx_instr(mov_mnem, a, "assign"))
        }
        return out
    }
    // RFC 068 P3 LANDED — Mixed-precision MIR body lowering. The
    // STMT_BINOP body branch dispatches through `_nvptx_binop_mnemonic`
    // which now covers `add_f16/_bf16/_f32` (+ sub/mul siblings)
    // alongside the existing `.f64` path. Real PTX `add.f16 %fh<d>,
    // %fh<a>, %fh<b>;` (and bf16/f32 variants) emit when source-level
    // `let t: f16 = a + b` lowers through P1 (precision tag) → P2
    // (op-name suffix) → P3 (body mnemonic). See
    // `docs/rfc/rfc_drafts_2026_05_20/rfc_068_mixed_precision_mir_layer.md`
    // §3 P3 + §4 F3 (`F-RFC068-BODY-MNEMONIC`).
    // Still pending: P4 (`F-RFC068-NUMERIC-EQ`) — real-silicon fire.
    if s.kind == STMT_BINOP {
        if len(s.args) >= 2 {
            // 055-P3b comparison-binop lowering — `setp.<cond>.<ty> %p<dst>,
            // <a>, <b>;` for lt/le/gt/ge/eq/ne. The destination is a
            // predicate (.pred bank) per the classifier; PTX `setp.<cond>`
            // takes the SAME mnemonic as the MIR opcode (1:1 mapping).
            //
            // RFC 071 P3+ kind-aware variant. The setp `.<ty>` suffix is
            // selected by the source-operand kind: U64 → `.s64`, U32 →
            // `.s32`, FP banks keep their existing `.f64` / `.f32` /
            // `.f16` / `.bf16` suffixes. The 055-P3b default (`.f64`) is
            // preserved when neither operand classifies into a non-FP64
            // bank — guarantees `_test_setp_and_br_cond` (unclassified
            // params default F64) stays byte-identical.
            //
            // Suffix resolution: if EITHER operand classifies into an
            // explicit (non-F64-default) bank, take that bank's suffix;
            // operands of mixed bank are not produced by the current
            // HIR→MIR layer, so a first-match strategy is sound.
            let cmp_ty = _nvptx_cmp_operand_type_suffix(s.args[0], s.args[1], kinds)
            let cmp = _nvptx_cmp_mnemonic_for_type(s.op, cmp_ty)
            if len(cmp) > 0 {
                // N73 (RFC 071 P4+ mixed-width cmp) — when the resolved
                // suffix is `.s64` but a source operand still sits in a
                // 32-bit integer bank (the `i < n` bounds-check: `i` is
                // u32, `n` is u64), `setp.lt.s64` against a 32-bit reg is
                // ptxas-ILLEGAL. Sign-extend the narrow operand into the
                // 64-bit `%cmpw_<dst>` scratch (`cvt.s64.s32`) BEFORE the
                // setp and use that widened reg as the setp operand. Both
                // setp operands are then 64-bit. The scratch is declared
                // by `_nvptx_classify_locals` Pass 5, keyed on dst.id.
                //   ref: PTX ISA 8.7 §9.7.1.5 cvt + §9.7.1.6 setp.
                let mut op0_txt = _nvptx_operand_text_kinds(s.args[0], kinds)
                let mut op1_txt = _nvptx_operand_text_kinds(s.args[1], kinds)
                if cmp_ty == ".s64" {
                    let cmpw_reg = _nvptx_reg_cmpw(s.dst.id)
                    if s.args[0].kind == "local" {
                        let k0 = _nvptx_lookup_kind_for_local(kinds, s.args[0].local_id)
                        if k0 == NVPTX_RKIND_U32 {
                            let mut w = []
                            w.push(_nvptx_op(cmpw_reg))
                            w.push(_nvptx_op(op0_txt))
                            out.push(_nvptx_instr("cvt.s64.s32", w, "widen cmp lhs (s32 to s64)"))
                            op0_txt = cmpw_reg
                        }
                    }
                    if s.args[1].kind == "local" {
                        let k1 = _nvptx_lookup_kind_for_local(kinds, s.args[1].local_id)
                        if k1 == NVPTX_RKIND_U32 {
                            let mut w = []
                            w.push(_nvptx_op(cmpw_reg))
                            w.push(_nvptx_op(op1_txt))
                            out.push(_nvptx_instr("cvt.s64.s32", w, "widen cmp rhs (s32 to s64)"))
                            op1_txt = cmpw_reg
                        }
                    }
                }
                let mut a = []
                a.push(_nvptx_op(_nvptx_lookup_reg_for_local(kinds, s.dst.id)))
                a.push(_nvptx_op(op0_txt))
                a.push(_nvptx_op(op1_txt))
                out.push(_nvptx_instr(cmp, a, "cmp " + s.op))
                return out
            }
            // 055-P0 arithmetic binop fallthrough.
            // RFC 071 P4+ (N59 G4 sibling) — kind-aware mnemonic. When
            // the dst classifies as an integer bank (U32/U64 via the
            // type_id rule), emit `add.s32`/`mul.lo.s64` etc. rather
            // than the F64 default. FP banks fall through to the
            // existing `_nvptx_binop_mnemonic` (byte-identical for f64).
            let dst_kind = _nvptx_lookup_kind_for_local(kinds, s.dst.id)
            let mnem = _nvptx_binop_mnemonic_for_kind(s.op, dst_kind)
            if len(mnem) > 0 {
                let mut a = []
                a.push(_nvptx_op(_nvptx_lookup_reg_for_local(kinds, s.dst.id)))
                a.push(_nvptx_op(_nvptx_operand_text_kinds(s.args[0], kinds)))
                a.push(_nvptx_op(_nvptx_operand_text_kinds(s.args[1], kinds)))
                out.push(_nvptx_instr(mnem, a, "binop " + s.op))
            } else {
                // RFC 055 055-P0 — binop outside the FP64 arithmetic
                // subset (e.g. div / bitwise). Honest stub.
                out.push(_nvptx_instr("//", [], "RFC 055 055-P0 - unsupported binop: " + s.op))
            }
        }
        return out
    }
    // 055-P3b STMT_CALL — lower known gpu intrinsic names (gpu/SPEC.md
    // §5) to a `mov.u32 %r<dst>, <sreg>.<axis>;` read. The classifier
    // has already put the dst Local into the `.reg .u32` bank; this
    // emits the body. Non-intrinsic STMT_CALLs remain a stub (a real
    // call ABI is 055-P3c-territory).
    if s.kind == STMT_CALL {
        // RFC 055 §5 multi-block global thread index. PTX has no single
        // sreg for "blockIdx * blockDim + threadIdx", so the call expands
        // to a 5-instr composition using one .u32 scratch reg (declared
        // in Pass 7). Per-axis: x/y/z. The classifier put the dst in U32.
        //   mov.u32 %r_gtid_<id>, %ctaid.<a>;
        //   mov.u32 %dst,         %ntid.<a>;
        //   mul.lo.u32 %dst, %r_gtid_<id>, %dst;
        //   mov.u32 %r_gtid_<id>, %tid.<a>;
        //   add.u32 %dst, %dst, %r_gtid_<id>;
        let is_gtid_x = s.op == "gpu_global_thread_id_x"
        let is_gtid_y = s.op == "gpu_global_thread_id_y"
        let is_gtid_z = s.op == "gpu_global_thread_id_z"
        if is_gtid_x || is_gtid_y || is_gtid_z {
            let mut axis = ".x"
            if is_gtid_y { axis = ".y" }
            if is_gtid_z { axis = ".z" }
            let dst_reg = _nvptx_lookup_reg_for_local(kinds, s.dst.id)
            let sc_reg  = _nvptx_reg_gtid(s.dst.id)
            let mut g1 = []
            g1.push(_nvptx_op(sc_reg))
            g1.push(_nvptx_op(PTX_SREG_CTAID + axis))
            out.push(_nvptx_instr(PTX_OP_MOV_U32, g1, "gpu_global_thread_id" + axis + "(): blockIdx"))
            let mut g2 = []
            g2.push(_nvptx_op(dst_reg))
            g2.push(_nvptx_op(PTX_SREG_NTID + axis))
            out.push(_nvptx_instr(PTX_OP_MOV_U32, g2, "gpu_global_thread_id" + axis + "(): blockDim"))
            let mut g3 = []
            g3.push(_nvptx_op(dst_reg))
            g3.push(_nvptx_op(sc_reg))
            g3.push(_nvptx_op(dst_reg))
            out.push(_nvptx_instr("mul.lo.u32", g3, "gpu_global_thread_id" + axis + "(): blockIdx*blockDim"))
            let mut g4 = []
            g4.push(_nvptx_op(sc_reg))
            g4.push(_nvptx_op(PTX_SREG_TID + axis))
            out.push(_nvptx_instr(PTX_OP_MOV_U32, g4, "gpu_global_thread_id" + axis + "(): threadIdx"))
            let mut g5 = []
            g5.push(_nvptx_op(dst_reg))
            g5.push(_nvptx_op(dst_reg))
            g5.push(_nvptx_op(sc_reg))
            out.push(_nvptx_instr("add.u32", g5, "gpu_global_thread_id" + axis + "(): += threadIdx"))
            return out
        }
        let sreg = _nvptx_gpu_intrinsic_sreg(s.op)
        if len(sreg) > 0 {
            let mut a = []
            a.push(_nvptx_op(_nvptx_lookup_reg_for_local(kinds, s.dst.id)))
            a.push(_nvptx_op(sreg))
            out.push(_nvptx_instr(PTX_OP_MOV_U32, a, s.op + "()"))
            return out
        }
        // RFC 071 P3+ — integer-cast intrinsics. `to_i64(x)` and
        // `to_i32(x)` (synthesized by HIR→MIR for source-level
        // `a[to_i64(gid)]` and `to_i64(gid) < n` shapes) lower to
        // a single PTX `cvt.<dst_ty>.<src_ty>` instruction. The dst
        // Local is already classified into the matching int bank
        // (U64 for `to_i64`, U32 for `to_i32`) by the rule added in
        // `_nvptx_classify_local_for_stmt`; the source operand kind
        // selects the `<src_ty>` half of the mnemonic:
        //   to_i64 ←  U32 / I32  →  `cvt.s64.s32  %rd<d>, %r<s>;`
        //   to_i64 ←  U64        →  `mov.b64      %rd<d>, %rd<s>;`  (no-op widen)
        //   to_i32 ←  U64        →  `cvt.s32.s64  %r<d>, %rd<s>;`
        //   to_i32 ←  U32        →  `mov.b32      %r<d>, %r<s>;`    (no-op narrow)
        //   const_int operand    →  `mov.<dst>    <dst>, <imm>;`    (immediate copy)
        // F64 source operands aren't a valid `to_iN` input under
        // gpu/SPEC.md §3 (no implicit FP→INT cast); we still emit an
        // honest-stub line so a future cycle catches mis-routed MIR.
        //   ref: PTX ISA 8.7 §9.7.1.5 — cvt: data-type conversion.
        if s.op == "to_i64" || s.op == "to_i32" {
            if len(s.args) >= 1 {
                let dst_kind = if s.op == "to_i64" { NVPTX_RKIND_U64 } else { NVPTX_RKIND_U32 }
                let dst_reg = _nvptx_lookup_reg_for_local(kinds, s.dst.id)
                let arg = s.args[0]
