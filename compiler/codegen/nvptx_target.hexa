        // The dst register kind (F32 / F64 / int) is read from the
        // classifier roster — Pass 1 inherits the operand bank so a
        // kernel over `[f32]` arrays emits the `.f32` family, `[f64]`
        // the `.f64` family. EXACT ops byte-eq; APPROX (rsqrt / exp via
        // ex2) within ~2^-23 rel tol.
        if _nvptx_is_math_intrinsic(s.op) {
            let arity = _nvptx_math_arity(s.op)
            if len(s.args) >= arity {
