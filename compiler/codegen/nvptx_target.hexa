        // RFC 067 LANDED — Real WMMA instruction emit. Replaces the
        // scaffold-comment-only path with real PTX wmma.* instructions
        // referencing the FRAG vector regs (P1) + `.shared` staging slot
        // (P2). The mnemonic resolves through `_nvptx_wmma_mnemonic` —
        // P3's `_nvptx_wmma_mnemonic_family` re-key extension is the
        // follow-on cycle that adds multi-family bf16/f16-acc emit.
        //
        // Per-op offset into the `.shared` staging slot (2048 B total,
        // 4 sub-slots of 512 B each = one 16×16 f16/f32 tile):
        //   gpu_wmma_load_a  → offset 0      (matrix A staging)
        //   gpu_wmma_load_b  → offset 512    (matrix B staging)
        //   gpu_wmma_mma     → in-register   (no staging touch)
        //   gpu_wmma_store_c → offset 1024   (result D staging)
        //
        // Honest scope: source operand text for `wmma.mma` is currently
        // taken from `s.args` operand list (placeholder fragments when
        // the upstream MIR doesn't yet attach them — Case 23 fixture
        // synthesizes the dst fragment Local but no source operands).
        // Real GEMM K-loop integration is the P4 wiring + numeric-eq
        // falsifier (separate cycle).
        let wmma_mnem = _nvptx_wmma_mnemonic(s.op)
        if len(wmma_mnem) > 0 {
            let dst_tuple = _nvptx_wmma_frag_tuple(s.dst.id, _nvptx_frag_width)
            if s.op == "gpu_wmma_load_a" || s.op == "gpu_wmma_load_b" {
                let stage_offset = if s.op == "gpu_wmma_load_a" { 0 } else { 512 }
                let mut a = []
                a.push(_nvptx_op(dst_tuple))
                a.push(_nvptx_op("[_hexa_wmma_stage+" + to_string(stage_offset) + "]"))
                out.push(_nvptx_instr(wmma_mnem, a, s.op))
            } else if s.op == "gpu_wmma_mma" {
                // Source operands: A, B, C fragments. If the MIR carried
                // them in s.args, use those Local ids for FRAG tuples;
                // otherwise emit placeholder tuples (Case 23 fixture).
                let src_a = if len(s.args) >= 1 && s.args[0].kind == "local" { _nvptx_wmma_frag_tuple(s.args[0].local_id, _nvptx_frag_width) } else { "{/* a */}" }
                let src_b = if len(s.args) >= 2 && s.args[1].kind == "local" { _nvptx_wmma_frag_tuple(s.args[1].local_id, _nvptx_frag_width) } else { "{/* b */}" }
                let src_c = if len(s.args) >= 3 && s.args[2].kind == "local" { _nvptx_wmma_frag_tuple(s.args[2].local_id, _nvptx_frag_width) } else { "{/* c */}" }
                let mut a = []
                a.push(_nvptx_op(dst_tuple))
                a.push(_nvptx_op(src_a))
                a.push(_nvptx_op(src_b))
                a.push(_nvptx_op(src_c))
                out.push(_nvptx_instr(wmma_mnem, a, s.op))
            } else if s.op == "gpu_wmma_store_c" {
                // store.d: address first, then source tuple. The
                // "destination" of MIR (s.dst) is void/_miss for
                // gpu_wmma_store_c — the actual fragment to store
                // comes from s.args[0] when wired; placeholder
                // otherwise.
                let src_d = if len(s.args) >= 1 && s.args[0].kind == "local" { _nvptx_wmma_frag_tuple(s.args[0].local_id, _nvptx_frag_width) } else { "{/* d */}" }
                let mut a = []
                a.push(_nvptx_op("[_hexa_wmma_stage+1024]"))
                a.push(_nvptx_op(src_d))
                out.push(_nvptx_instr(wmma_mnem, a, s.op))
            } else {
                // Unknown wmma op — emit honest stub comment.
                out.push(_nvptx_instr("//", [],
                    "RFC 067 — unsupported wmma op: " + s.op))
            }
            return out
        }
        // RFC 055 §13 — floating-point math intrinsics. `sqrt(x)` /
        // `max(a,b)` / `min(a,b)` / `exp(x)` / `abs(x)` / `rsqrt(x)`
