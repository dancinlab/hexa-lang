                // N71-B (N70/N91 GAP-C) — FP64 source decompose/recompose
                // for the XOR-butterfly mode (the warp-reduce primitive).
                // Identical 32-bit-halves split/shuffle/recompose as the
                // idx variant above, but with `shfl.sync.bfly.b32`. The
                // mask operand stays a `%r` (u32) register either way.
                //   ref: NVIDIA PTX ISA §9.7.13.4 shfl.sync + §5.4 mov.b64.
                let src_kind = _nvptx_lookup_kind_for_local(kinds, s.args[0].local_id)
                if src_kind == NVPTX_RKIND_F64 {
                    let dst_f64 = _nvptx_reg_f64(s.dst.id)
                    let src_f64 = _nvptx_reg_f64(s.args[0].local_id)
                    let lo = _nvptx_reg_shfl_lo(s.dst.id)
                    let hi = _nvptx_reg_shfl_hi(s.dst.id)
                    let lo_out = _nvptx_reg_shfl_lo_out(s.dst.id)
                    let hi_out = _nvptx_reg_shfl_hi_out(s.dst.id)
                    // The mask operand must be `.b32` for shfl. When the
                    // mask Local sits in the u64 bank (`%rd`), narrow it to
                    // the `%shfl_mask_<dst>` u32 scratch first (the warp-
                    // reduce `mask: i32` often lands in u64 via `mask / 2`);
                    // else use `%r<mask>` directly.
                    let mask_kind = _nvptx_lookup_kind_for_local(kinds, s.args[1].local_id)
                    let mut mask_reg = _nvptx_reg_u32(s.args[1].local_id)
                    if mask_kind == NVPTX_RKIND_U64 {
                        mask_reg = _nvptx_reg_shfl_mask(s.dst.id)
                        let mut c = []
                        c.push(_nvptx_op(mask_reg))
                        c.push(_nvptx_op(_nvptx_reg_u64(s.args[1].local_id)))
                        out.push(_nvptx_instr("cvt.u32.u64", c, "gpu_warp_shuffle_xor mask u64 -> u32 narrow"))
                    }
                    // 1. decompose f64 src into two 32-bit halves
                    let mut d = []
                    d.push(_nvptx_op("{" + lo + ", " + hi + "}"))
                    d.push(_nvptx_op(src_f64))
                    out.push(_nvptx_instr("mov.b64", d, "gpu_warp_shuffle_xor f64 decompose"))
                    // 2. butterfly-shuffle each half with identical mask/clamp/membermask
                    let mut slo = []
                    slo.push(_nvptx_op(lo_out))
                    slo.push(_nvptx_op(lo))
                    slo.push(_nvptx_op(mask_reg))
                    slo.push(_nvptx_op("0x1f"))
                    slo.push(_nvptx_op("0xffffffff"))
                    out.push(_nvptx_instr(PTX_OP_SHFL_SYNC_BFLY_B32, slo, "gpu_warp_shuffle_xor lo half"))
                    let mut shi = []
                    shi.push(_nvptx_op(hi_out))
                    shi.push(_nvptx_op(hi))
                    shi.push(_nvptx_op(mask_reg))
                    shi.push(_nvptx_op("0x1f"))
                    shi.push(_nvptx_op("0xffffffff"))
                    out.push(_nvptx_instr(PTX_OP_SHFL_SYNC_BFLY_B32, shi, "gpu_warp_shuffle_xor hi half"))
                    // 3. recompose the two shuffled halves into the f64 dst
                    let mut r = []
                    r.push(_nvptx_op(dst_f64))
                    r.push(_nvptx_op("{" + lo_out + ", " + hi_out + "}"))
                    out.push(_nvptx_instr("mov.b64", r, "gpu_warp_shuffle_xor f64 recompose"))
                    return out
                }
                // u32 source — existing single-instruction 32-bit path.
                let dst_reg = _nvptx_lookup_reg_for_local(kinds, s.dst.id)
                let src_reg = _nvptx_reg_u32(s.args[0].local_id)
                let mask_reg = _nvptx_reg_u32(s.args[1].local_id)
                let mut a = []
                a.push(_nvptx_op(dst_reg))
                a.push(_nvptx_op(src_reg))
                a.push(_nvptx_op(mask_reg))
                a.push(_nvptx_op("0x1f"))
                a.push(_nvptx_op("0xffffffff"))
                out.push(_nvptx_instr(PTX_OP_SHFL_SYNC_BFLY_B32, a,
