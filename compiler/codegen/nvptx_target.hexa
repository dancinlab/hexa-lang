                        let mut c = []
                        c.push(_nvptx_op(lane_reg))
                        c.push(_nvptx_op(_nvptx_reg_u64(s.args[1].local_id)))
                        out.push(_nvptx_instr("cvt.u32.u64", c, "gpu_warp_shuffle lane u64 -> u32 narrow"))
                    }
