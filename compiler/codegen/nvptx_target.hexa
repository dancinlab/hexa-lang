                    // Immediate folds to a `mov.b<width>` against the
                    // dst integer bank. PTX accepts decimal literals.
                    let mut a = []
                    a.push(_nvptx_op(dst_reg))
                    a.push(_nvptx_op(to_string(arg.int_val)))
                    let mnem = if dst_kind == NVPTX_RKIND_U64 { "mov.b64" } else { "mov.b32" }
                    out.push(_nvptx_instr(mnem, a, s.op + "(imm)"))
                    return out
                }
                if arg.kind == "local" {
                    let src_kind = _nvptx_lookup_kind_for_local(kinds, arg.local_id)
                    let src_reg = _nvptx_lookup_reg_for_local(kinds, arg.local_id)
                    let mut a = []
                    a.push(_nvptx_op(dst_reg))
                    a.push(_nvptx_op(src_reg))
                    if dst_kind == NVPTX_RKIND_U64 {
                        if src_kind == NVPTX_RKIND_U64 {
                            // Already 64-bit — fold to a register move.
                            // ASCII-only comment text (per memory
                            // reference_gpu_fire_infra.md: ptxas driver
                            // JIT rejects non-ASCII in PTX comments).
                            out.push(_nvptx_instr("mov.b64", a, s.op + " (widen no-op)"))
                        } else {
                            // Default: treat 32-bit source as s32 to s64.
                            // (Unsigned variant would require a `_u32` MIR
                            // opcode signal that the HIR to MIR layer
                            // doesn't yet emit; signed-extend is the
                            // gpu/SPEC.md section 3 default for the
                            // i64-source shape.)
                            out.push(_nvptx_instr("cvt.s64.s32", a, s.op + " (s32 to s64)"))
                        }
