        // RFC 055 §12 P4+ — `gpu_barrier()` block-wide synchronization
        // (gpu/SPEC.md §5). Lowers to `bar.sync 0;` — a PTX special
        // instruction that synchronizes all threads in a block. The
        // return type is void; no dst register written. Required by
        // the tiled `@shared` GEMM variant (§6.6 named follow-on) for
        // safe cross-thread reads of shared-memory writes.
        if s.op == "gpu_barrier" {
            let mut a = []
            a.push(_nvptx_op("0"))
            out.push(_nvptx_instr(PTX_OP_BAR_SYNC, a, "gpu_barrier()"))
            return out
