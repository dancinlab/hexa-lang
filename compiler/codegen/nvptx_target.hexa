        // XOR-butterfly exchange (closes N70 GAP-A; gpu/SPEC.md §5). Lowers to
        //   `shfl.sync.bfly.b32 %r<dst>, %r<src>, %r<mask>, 0x1f, 0xffffffff;`
        // The `bfly` mode XORs the calling thread's lane id with the mask
        // operand to compute the source lane — the canonical primitive for
        // warp-reduce (mask = 16, 8, 4, 2, 1 reduces 32 lanes pairwise).
        if s.op == "gpu_warp_shuffle_xor" {
