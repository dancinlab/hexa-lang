                    let mut d = []
                    d.push(_nvptx_op("{" + lo + ", " + hi + "}"))
                    d.push(_nvptx_op(src_f64))
                    out.push(_nvptx_instr("mov.b64", d, "gpu_warp_shuffle f64 decompose"))
                    // 2. shuffle each half with identical idx/clamp/membermask
                    let mut slo = []
                    slo.push(_nvptx_op(lo_out))
                    slo.push(_nvptx_op(lo))
                    slo.push(_nvptx_op(lane_reg))
                    slo.push(_nvptx_op("0x1f"))
                    slo.push(_nvptx_op("0xffffffff"))
                    out.push(_nvptx_instr(PTX_OP_SHFL_SYNC_IDX_B32, slo, "gpu_warp_shuffle lo half"))
                    let mut shi = []
                    shi.push(_nvptx_op(hi_out))
                    shi.push(_nvptx_op(hi))
                    shi.push(_nvptx_op(lane_reg))
                    shi.push(_nvptx_op("0x1f"))
                    shi.push(_nvptx_op("0xffffffff"))
                    out.push(_nvptx_instr(PTX_OP_SHFL_SYNC_IDX_B32, shi, "gpu_warp_shuffle hi half"))
