// compiler/codegen/nvptx_p5_multi_kernel_test.hexa
// RFC 071 P5 — multi-@gpu_kernel-per-file source-to-silicon fixture
//
// @version 0.0.1
// @capabilities [pure]
// @phase("parse_only")
//
// This file is a TEST FIXTURE for F-RFC071-E2E-MULTI-KERNEL-NUMERIC-EQ
// (RFC 071 §4 P5 follow-up to N34 vec_add + N50 vec_mul). Both prior
// fixtures contained a SINGLE `@gpu_kernel`. This fixture contains TWO
// — `vec_add` and `vec_mul` — so the codegen pipeline must:
//
//   1. Parse 2 @gpu_kernel functions in one source module.
//   2. Lower both through lex → parse → lower(ast_to_hir) → lower_hir
//      so the MModule contains 2 MFuncs with `gpu_kind=GPU_KIND_KERNEL`.
//   3. `_nvptx_codegen` iterates `module.funcs` and emits BOTH (filter
//      at compiler/codegen/nvptx_target.hexa:2391-2412 keeps any
//      `gpu_kind != GPU_KIND_CPU`).
//   4. `emit_ptx` joins per-LFunc bodies → ONE .ptx text with TWO
//      `.visible .entry` directives.
//
// PASS criteria:
//   - PTX contains `.visible .entry vec_add` AND `.visible .entry vec_mul`
//   - cuModuleLoadDataEx accepts the multi-entry PTX
//   - cuModuleGetFunction returns BOTH kernel handles
//   - Both kernels, fired with shared LCG inputs A+B, produce
//     bit-exact (max_abs=0, byte_mismatch=0) results vs CPU ref.
//
// `@phase("parse_only")` declares this file's role: input to the P5
// emit-driver, not a standalone test runner.

// ── Two kernels (gpu/SPEC.md §2 — @gpu_kernel must return void) ─────

@gpu_kernel
fn vec_add(a: [f64], b: [f64], c: [f64], n: i64) {
    let gid = gpu_block_id_x() * gpu_block_dim_x() + gpu_thread_id_x()
    if to_i64(gid) < n {
        c[to_i64(gid)] = a[to_i64(gid)] + b[to_i64(gid)]
    }
}

@gpu_kernel
fn vec_mul(a: [f64], b: [f64], c: [f64], n: i64) {
    let gid = gpu_block_id_x() * gpu_block_dim_x() + gpu_thread_id_x()
    if to_i64(gid) < n {
        c[to_i64(gid)] = a[to_i64(gid)] * b[to_i64(gid)]
    }
}
