// HEXA Native Compiler — RFC 075 P0 / ROCm lowering smoke (scaffold-only)
//
// @version 0.0.1
// @capabilities [pure]
//
// RFC 075 P0 scaffold smoke. The codegen entry `codegen_emit_rocm_il` is
// a P0 stub that honestly returns `""` (no HIP-IL emit yet). This file
// asserts that P0 contract: emit returns an empty string. Real lowering
// smokes (vec-add text, opcode coverage, address-space classifier) come
// P1+ — each new MIR construct lands a `_test_<construct>` case here,
// mirroring `nvptx_lower_test.hexa`'s shape.
//
// Run:
//   hexa build compiler/codegen/rocm_lower_test.hexa -o build/rocm_lower_test
//   ./build/rocm_lower_test

import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "./rocm_target.hexa"

// ── MIR construction helpers (minimum needed for the empty MModule)
//    P1+ will pull in the richer Local/Operand/Stmt helpers shape that
//    nvptx_lower_test.hexa uses; P0 only needs an empty module ──

fn _empty_mmodule() -> MModule {
    return MModule { file: "rocm_p0_smoke.hexa", funcs: [], globals: [] }
}

// ── Text inspection ──────────────────────────────────────────────────

fn _check_empty(ok_in: bool, text: string, label: string) -> bool {
    if text.length == 0 { return ok_in }
    println("  FAIL: " + label + " (expected empty, got " + to_string(text.length) + " chars)")
    return false
}

// ── Case 1 — P0 emit stub returns empty string ───────────────────────
//
// The P0 contract: `codegen_emit_rocm_il` is wired to the scaffold and
// honestly returns `""` until P3 fills in real HIP-IL text emit. This
// case verifies (a) the entry is callable, (b) the return type compiles
// against `string`, (c) the return value matches the P0 placeholder.
// Falsifier F-RFC075-ROCM-EMIT-VEC-ADD intentionally FAILS today; that
// is the point of a stub assertion.

fn _test_p0_empty_emit() -> bool {
    let mut ok = true
    let mod_empty = _empty_mmodule()
    let il = codegen_emit_rocm_il(mod_empty)

    println("")
    println("── emitted HIP-IL (RFC 075 P0 empty-emit case) ──")
    println("  [empty string, length=" + to_string(il.length) + "]")

    ok = _check_empty(ok, il, "P0 stub returns empty string")
    return ok
}

// ── Case 2 — target enum constants resolve to expected arch tags ─────
//
// Sanity-checks the gfx-rev constants land at their documented strings.
// This is a compile-time-ish smoke; in real P1 this becomes
// F-RFC075-ROCM-TARGET-ACCEPT (driven by a hypothetical `--target=`
// dispatch lookup).

fn _test_target_constants() -> bool {
    let mut ok = true
    if ROCM_ARCH_GFX1100 != "gfx1100" {
        println("  FAIL: ROCM_ARCH_GFX1100 expected 'gfx1100', got '" + ROCM_ARCH_GFX1100 + "'")
        ok = false
    }
    if ROCM_TARGET_GFX1100 != "amdgcn-amd-amdhsa-gfx1100" {
        println("  FAIL: ROCM_TARGET_GFX1100 mismatch")
        ok = false
    }
    if ROCM_WAVE_SIZE_RDNA != 32 {
        println("  FAIL: ROCM_WAVE_SIZE_RDNA expected 32, got " + to_string(ROCM_WAVE_SIZE_RDNA))
        ok = false
    }
    if ok {
        println("  ok: gfx1100 arch tag + RDNA wave32 constant verified")
    }
    return ok
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  RFC 075 P0 — ROCm scaffold smoke")
    println("══════════════════════════════════════════════")

    let ok_emit = _test_p0_empty_emit()
    let ok_tgt  = _test_target_constants()

    println("")
    if ok_emit && ok_tgt {
        println("  PASS: RFC 075 P0 ROCm scaffold smoke")
    } else {
        println("  FAIL: RFC 075 P0 ROCm scaffold smoke")
    }
}
