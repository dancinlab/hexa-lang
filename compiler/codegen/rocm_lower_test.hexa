    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, "logf(",                         "HIP builtin call `logf(`")
    ok = _check_contains(ok, il, "logf(a[i])",                    "full HIP call form `logf(a[i])`")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-log is 2-buffer; must NOT load `b[i]`.
    ok = _check_not_contains(ok, il, "b[i]",                      "vec-log should not load `b[i]` (2-buffer guard)")
    ok = _check_not_contains(ok, il, "#include <rocwmma/rocwmma.hpp>", "vec-log should not include rocWMMA header")
    ok = _check_not_contains(ok, il, "expf(",                     "vec-log should not call `expf(` (vec-exp guard)")
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "vec-log should not emit `a[i] + b[i]` (vec-add guard)")
    ok = _check_not_contains(ok, il, "a[i] * b[i]",               "vec-log should not emit `a[i] * b[i]` (vec-mul guard)")
    return ok
}

