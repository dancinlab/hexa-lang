// ── Case 5 — F-RFC075-ROCM-EMIT-VEC-SUB ──────────────────────────────

fn _test_vec_sub_emit() -> bool {
    let mut ok = true
    let mod_vs = _build_vec_sub_module()
    let il = codegen_emit_rocm_il(mod_vs)

    println("")
    println("── emitted HIP source (RFC 075 P1+ vec-sub case) ──")
    println(il)

    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void vec_sub",                  "kernel name `vec_sub` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "blockDim.x",                    "HIP built-in `blockDim.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, "b[i]",                          "read buffer index `b[i]`")
    ok = _check_contains(ok, il, "a[i] - b[i]",                   "binop applied between `a[i]` and `b[i]` (subtraction)")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-sub must NOT carry add's plus pattern or mul's star
    // pattern between the two loaded values. Use specific `a[i] OP b[i]`
    // patterns so the thread-idx expr (which contains `+` and `*`)
    // does not false-positive.
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "vec-sub should not emit `a[i] + b[i]` (vec-add inheritance check)")
    ok = _check_not_contains(ok, il, "a[i] * b[i]",               "vec-sub should not emit `a[i] * b[i]` (vec-mul inheritance check)")
    return ok
}

