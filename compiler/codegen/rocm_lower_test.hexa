    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "__shfl_xor",                    "HIP butterfly shuffle intrinsic")
    ok = _check_contains(ok, il, "__lane_id",                     "HIP within-wavefront lane index")
    ok = _check_contains(ok, il, "a[i]",                          "input load `a[i]`")
    ok = _check_contains(ok, il, "wave_id",                       "per-wavefront output index variable")
    ok = _check_contains(ok, il, "c[wave_id]",                    "per-wavefront output write `c[wave_id]`")
    ok = _check_contains(ok, il, "i / 32u",                       "wave_id = i / 32 (RDNA wave32)")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
