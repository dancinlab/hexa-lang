    return MModule { file: "rocm_vec_sub.hexa", funcs: fns, globals: [] }
}

// ── Case 5 — F-RFC075-ROCM-EMIT-VEC-SUB ──────────────────────────────

fn _test_vec_sub_emit() -> bool {
    let mut ok = true
    let mod_vs = _build_vec_sub_module()
    let il = codegen_emit_rocm_il(mod_vs)

    println("")
    println("── emitted HIP source (RFC 075 P1+ vec-sub case) ──")
    println(il)

    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void vec_sub",                  "kernel name `vec_sub` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "blockDim.x",                    "HIP built-in `blockDim.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, "b[i]",                          "read buffer index `b[i]`")
    ok = _check_contains(ok, il, "a[i] - b[i]",                   "binop applied between `a[i]` and `b[i]` (subtraction)")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-sub must NOT carry add's plus pattern or mul's star
    // pattern between the two loaded values. Use specific `a[i] OP b[i]`
    // patterns so the thread-idx expr (which contains `+` and `*`)
    // does not false-positive.
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "vec-sub should not emit `a[i] + b[i]` (vec-add inheritance check)")
    ok = _check_not_contains(ok, il, "a[i] * b[i]",               "vec-sub should not emit `a[i] * b[i]` (vec-mul inheritance check)")
    return ok
}

// ── vec-div MIR fixture (Case 6) ─────────────────────────────────────

fn _build_vec_div_module() -> MModule {
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_div(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "vec_div",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "rocm_vec_div.hexa", funcs: fns, globals: [] }
}

// ── Case 6 — F-RFC075-ROCM-EMIT-VEC-DIV ──────────────────────────────

fn _test_vec_div_emit() -> bool {
    let mut ok = true
    let mod_vd = _build_vec_div_module()
    let il = codegen_emit_rocm_il(mod_vd)

    println("")
    println("── emitted HIP source (RFC 075 P1+ vec-div case) ──")
    println(il)

    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void vec_div",                  "kernel name `vec_div` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "blockDim.x",                    "HIP built-in `blockDim.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, "b[i]",                          "read buffer index `b[i]`")
    ok = _check_contains(ok, il, "a[i] / b[i]",                   "binop applied between `a[i]` and `b[i]` (division)")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-div must NOT carry add's plus or mul's star pattern
    // between the two loaded values.
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "vec-div should not emit `a[i] + b[i]` (vec-add inheritance check)")
    ok = _check_not_contains(ok, il, "a[i] * b[i]",               "vec-div should not emit `a[i] * b[i]` (vec-mul inheritance check)")
    return ok
}

// ── vec-scale MIR fixture (Case 7) ───────────────────────────────────

fn _build_vec_scale_module() -> MModule {
    // Two kernel-buffer params (a, c) + two private Locals (va, vc).
    // Stmt sequence: STMT_LOAD a→va, STMT_BINOP_MUL (va, const_float
    // 2.5)→vc, STMT_STORE vc→c. The const operand sits at args[1],
    // matching `_rocm_mfunc_is_vec_scale_shape`'s lhs-local · rhs-const
    // expectation.
    let a  = _kern_local(0, "a")
    let c  = _kern_local(1, "c")
    let va = _priv_local(2, "va")
    let vc = _priv_local(3, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_binop_mul_scalar(vc, va.id, 2.5))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(c)
    locals.push(va)
    locals.push(vc)

    let mf = MFunc {
        name: "vec_scale",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "rocm_vec_scale.hexa", funcs: fns, globals: [] }
}

// ── Case 7 — F-RFC075-ROCM-EMIT-VEC-SCALE ────────────────────────────
//
// Synthesise a vec-scale MIR module (a[i] * 2.5 → c[i]), invoke
// `codegen_emit_rocm_il`, and assert the emitted HIP source contains
// the scalar literal, the `*` operator, `a[i]` and `c[i]`, and the
// 2-buffer signature (NO `b[i]` second-buffer load, NO `,` `float* b,`
// param row). Negative guards: addition operator absent + `b[i]` index
// absent (vec-scale is single-input — only `a` device buffer).

fn _test_vec_scale_emit() -> bool {
    let mut ok = true
    let mod_vs = _build_vec_scale_module()
    let il = codegen_emit_rocm_il(mod_vs)

    println("")
    println("── emitted HIP source (RFC 075 P1+ vec-scale case) ──")
    println(il)

    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void vec_scale",                "kernel name `vec_scale` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, " * ",                           "multiplication operator between load + scalar")
    ok = _check_contains(ok, il, "2.5",                           "scalar literal 2.5 in emitted body")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-scale is 2-buffer; must NOT load a second device
    // buffer `b[i]` and must NOT emit a vec-add-style `a[i] + b[i]`
    // body. (Bare ` + ` is unavoidable because the thread-idx expression
    // `blockIdx.x * blockDim.x + threadIdx.x` contains a literal `+`.)
    ok = _check_not_contains(ok, il, "a[i] + ",                   "vec-scale should not emit `a[i] + ` (binop guard)")
    ok = _check_not_contains(ok, il, "b[i]",                      "vec-scale should not load `b[i]` (2-buffer signature)")
    return ok
}

// ── reduce-sum MIR fixture (Case 8) ──────────────────────────────────

fn _build_reduce_sum_module() -> MModule {
    // Two kernel-buffer params (a, c) + two private Locals (va, vc).
    // Stmt sequence: STMT_LOAD a→va, STMT_UNOP("reduce_sum") va→vc,
    // STMT_STORE vc→c. SYNTHETIC opcode (no HIR/parser produces this
    // today). Output buffer `c` is per-wavefront sized — host launches
    // with N/32 output slots on RDNA gfx1100+.
    let a  = _kern_local(0, "a")
    let c  = _kern_local(1, "c")
    let va = _priv_local(2, "va")
    let vc = _priv_local(3, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_unop_reduce_sum(vc, va.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(c)
    locals.push(va)
    locals.push(vc)

    let mf = MFunc {
        name: "reduce_sum",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "rocm_reduce_sum.hexa", funcs: fns, globals: [] }
}

// ── Case 8 — F-RFC075-ROCM-EMIT-REDUCE-SUM ───────────────────────────
//
// Synthesise the FIRST non-element-wise MIR shape (reduce-sum on the
// AMD lane), invoke `codegen_emit_rocm_il`, and assert the emitted HIP
// source contains the HIP-canonical wavefront-reduction intrinsics
// (`__shfl_xor` butterfly + `__lane_id` lane-0 gate), per-wavefront
// output index `wave_id`, and the 2-buffer kernel signature.

fn _test_reduce_sum_emit() -> bool {
    let mut ok = true
    let mod_rs = _build_reduce_sum_module()
    let il = codegen_emit_rocm_il(mod_rs)

    println("")
    println("── emitted HIP source (RFC 075 P1+ reduce-sum case) ──")
    println(il)

    // F-RFC075-ROCM-EMIT-REDUCE-SUM substring battery — 15 positives.
    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void reduce_sum",               "kernel name `reduce_sum` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing (input)")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing (output)")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "__shfl_xor",                    "HIP butterfly shuffle intrinsic")
    ok = _check_contains(ok, il, "__lane_id",                     "HIP within-wavefront lane index")
    ok = _check_contains(ok, il, "a[i]",                          "input load `a[i]`")
    ok = _check_contains(ok, il, "wave_id",                       "per-wavefront output index variable")
    ok = _check_contains(ok, il, "c[wave_id]",                    "per-wavefront output write `c[wave_id]`")
    ok = _check_contains(ok, il, "i / 32u",                       "wave_id = i / 32 (RDNA wave32)")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — reduce-sum is unary (no second input, no infix +/*
    // between two loaded values, and no `b[i]` index expression).
    ok = _check_not_contains(ok, il, "b[i]",                      "reduce-sum should not load `b[i]` (single-input)")
    return ok
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  RFC 075 P1+ — ROCm codegen smoke (6 shapes)")
    println("══════════════════════════════════════════════")

    let ok_emit  = _test_p0_empty_emit()
    let ok_tgt   = _test_target_constants()
    let ok_va    = _test_vec_add_emit()
    let ok_vm    = _test_vec_mul_emit()
    let ok_vs    = _test_vec_sub_emit()
    let ok_vd    = _test_vec_div_emit()
    let ok_vsc   = _test_vec_scale_emit()
    let ok_rs    = _test_reduce_sum_emit()

    println("")
    if ok_emit && ok_tgt && ok_va && ok_vm && ok_vs && ok_vd && ok_vsc && ok_rs {
        println("  PASS: RFC 075 P1+ ROCm codegen smoke (vec-add + vec-mul + vec-sub + vec-div + vec-scale + reduce-sum)")
    } else {
        println("  FAIL: RFC 075 P1+ ROCm codegen smoke")
    }
}
