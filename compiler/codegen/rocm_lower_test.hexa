// ── Case 7 — F-RFC075-ROCM-EMIT-VEC-SCALE ────────────────────────────
//
// Synthesise a vec-scale MIR module (a[i] * 2.5 → c[i]), invoke
// `codegen_emit_rocm_il`, and assert the emitted HIP source contains
// the scalar literal, the `*` operator, `a[i]` and `c[i]`, and the
// 2-buffer signature (NO `b[i]` second-buffer load, NO `,` `float* b,`
// param row). Negative guards: addition operator absent + `b[i]` index
// absent (vec-scale is single-input — only `a` device buffer).

fn _test_vec_scale_emit() -> bool {
    let mut ok = true
    let mod_vs = _build_vec_scale_module()
    let il = codegen_emit_rocm_il(mod_vs)

    println("")
    println("── emitted HIP source (RFC 075 P1+ vec-scale case) ──")
    println(il)

    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void vec_scale",                "kernel name `vec_scale` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, " * ",                           "multiplication operator between load + scalar")
    ok = _check_contains(ok, il, "2.5",                           "scalar literal 2.5 in emitted body")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-scale is 2-buffer; must NOT load a second device
    // buffer `b[i]` and must NOT emit a vec-add-style `a[i] + b[i]`
    // body. (Bare ` + ` is unavoidable because the thread-idx expression
    // `blockIdx.x * blockDim.x + threadIdx.x` contains a literal `+`.)
    ok = _check_not_contains(ok, il, "a[i] + ",                   "vec-scale should not emit `a[i] + ` (binop guard)")
    ok = _check_not_contains(ok, il, "b[i]",                      "vec-scale should not load `b[i]` (2-buffer signature)")
    return ok
}

