    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void matmul_NT_a",              "kernel name `matmul_NT_a` after void return")
    ok = _check_contains(ok, il, "int M, int N, int K",           "M/N/K integer dims in signature")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::col_major>", "A fragment col_major (transposed-A)")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::col_major>", "B fragment col_major")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::accumulator, 16, 16, 16, float>", "C accumulator fragment 16x16x16 FP32")
    ok = _check_contains(ok, il, "rocwmma::fill_fragment(c_frag, 0.0f)", "accumulator zero-fill")
    ok = _check_contains(ok, il, "rocwmma::load_matrix_sync(a_frag, &a[k * M + row_tile], M)", "A tile load (col-major stride M for transposed-A)")
    ok = _check_contains(ok, il, "rocwmma::load_matrix_sync(b_frag, &b[k * N + col_tile], N)", "B tile load (col-major stride N)")
    ok = _check_contains(ok, il, "rocwmma::mma_sync(c_frag, a_frag, b_frag, c_frag)", "WMMA mma_sync intrinsic")
    ok = _check_contains(ok, il, "rocwmma::store_matrix_sync(&c[row_tile * N + col_tile], c_frag, N, rocwmma::mem_row_major)", "C tile store row-major")
    ok = _check_contains(ok, il, "k += 16",                       "K-loop tile-step 16")
    // Negative guards — matmul_NT_a must NOT emit the canonical A row_major
    // fragment, must NOT emit B row_major fragment, must NOT inherit a vec-* body.
    ok = _check_not_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::row_major>", "matmul_NT_a should not emit canonical A row_major fragment")
    ok = _check_not_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::row_major>", "matmul_NT_a should not emit transposed-B fragment")
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "matmul_NT_a should not emit vec-add body")
    ok = _check_not_contains(ok, il, "__shfl_xor",                "matmul_NT_a should not emit reduce-sum butterfly")
    return ok
}

// ── matmul_NT_b MIR fixture (Case 11) ────────────────────────────────

fn _build_matmul_NT_b_module() -> MModule {
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_matmul_NT_b(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "matmul_NT_b",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "rocm_matmul_NT_b.hexa", funcs: fns, globals: [] }
}

// ── Case 11 — F-RFC075-ROCM-EMIT-MATMUL-NT-B ─────────────────────────
//
// matmul_NT_b → A stays row_major, B fragment is row_major, B-load
// stride switches from N to K. Negative guards: canonical B col_major
// fragment, A col_major fragment.

fn _test_matmul_NT_b_emit() -> bool {
    let mut ok = true
    let mod_mt = _build_matmul_NT_b_module()
    let il = codegen_emit_rocm_il(mod_mt)

    println("")
    println("── emitted HIP source (RFC 075 P1++ matmul_NT_b case) ──")
    println(il)

    // F-RFC075-ROCM-EMIT-MATMUL-NT-B substring battery — 15 positives.
    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "#include <rocwmma/rocwmma.hpp>", "rocWMMA header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void matmul_NT_b",              "kernel name `matmul_NT_b` after void return")
    ok = _check_contains(ok, il, "int M, int N, int K",           "M/N/K integer dims in signature")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::row_major>", "A fragment row_major")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::row_major>", "B fragment row_major (transposed-B)")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::accumulator, 16, 16, 16, float>", "C accumulator fragment 16x16x16 FP32")
    ok = _check_contains(ok, il, "rocwmma::fill_fragment(c_frag, 0.0f)", "accumulator zero-fill")
    ok = _check_contains(ok, il, "rocwmma::load_matrix_sync(a_frag, &a[row_tile * K + k], K)", "A tile load (row-major stride K)")
    ok = _check_contains(ok, il, "rocwmma::load_matrix_sync(b_frag, &b[col_tile * K + k], K)", "B tile load (row-major stride K for transposed-B)")
    ok = _check_contains(ok, il, "rocwmma::mma_sync(c_frag, a_frag, b_frag, c_frag)", "WMMA mma_sync intrinsic")
    ok = _check_contains(ok, il, "rocwmma::store_matrix_sync(&c[row_tile * N + col_tile], c_frag, N, rocwmma::mem_row_major)", "C tile store row-major")
    ok = _check_contains(ok, il, "k += 16",                       "K-loop tile-step 16")
    // Negative guards — matmul_NT_b must NOT emit the canonical B col_major
    // fragment, must NOT emit A col_major fragment, must NOT inherit a vec-* body.
    ok = _check_not_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::col_major>", "matmul_NT_b should not emit canonical B col_major fragment")
    ok = _check_not_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::col_major>", "matmul_NT_b should not emit transposed-A fragment")
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "matmul_NT_b should not emit vec-add body")
    ok = _check_not_contains(ok, il, "__shfl_xor",                "matmul_NT_b should not emit reduce-sum butterfly")
    return ok
}

// ── vec-unary MIR fixtures (Cases 12-18) ─────────────────────────────
//
// Element-wise unary kernels: 2-buffer signature (a + c only, NO `b`).
// Stmt sequence: STMT_LOAD a→va, STMT_UNOP(op_name) va→vc, STMT_STORE
// vc→c (optional STMT_RETURN tail). The op_name discriminates which
// shape recogniser fires ("neg" / "abs" / "sqrt" / "exp" / "log" /
// "sin" / "cos"). All seven share the same fixture skeleton; the lone
// difference is the UNOP op string. Mirrors metal_lower_test.hexa's
// `_build_vec_unary_module`.

fn _build_vec_unary_module(op_name: string, kname: string, file: string) -> MModule {
    // Two kernel-buffer params (a, c) + two private Locals (va, vc).
    // Stmt sequence: STMT_LOAD a→va, STMT_UNOP(op_name) (va)→vc,
    // STMT_STORE vc→c. Matches `_rocm_mfunc_is_unary_shape_with_op`.
    let a  = _kern_local(0, "a")
    let c  = _kern_local(1, "c")
    let va = _priv_local(2, "va")
    let vc = _priv_local(3, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_unop(vc, va.id, op_name))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(c)
    locals.push(va)
    locals.push(vc)

    let mf = MFunc {
        name: kname,
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: file, funcs: fns, globals: [] }
}

fn _build_vec_neg_module() -> MModule {
    return _build_vec_unary_module("neg", "vec_neg", "rocm_vec_neg.hexa")
}

fn _build_vec_abs_module() -> MModule {
    return _build_vec_unary_module("abs", "vec_abs", "rocm_vec_abs.hexa")
}

fn _build_vec_sqrt_module() -> MModule {
    return _build_vec_unary_module("sqrt", "vec_sqrt", "rocm_vec_sqrt.hexa")
}

fn _build_vec_exp_module() -> MModule {
    return _build_vec_unary_module("exp", "vec_exp", "rocm_vec_exp.hexa")
}

fn _build_vec_log_module() -> MModule {
    return _build_vec_unary_module("log", "vec_log", "rocm_vec_log.hexa")
}

fn _build_vec_sin_module() -> MModule {
    return _build_vec_unary_module("sin", "vec_sin", "rocm_vec_sin.hexa")
}

fn _build_vec_cos_module() -> MModule {
    return _build_vec_unary_module("cos", "vec_cos", "rocm_vec_cos.hexa")
}

// ── Case 12 — F-RFC075-ROCM-EMIT-VEC-NEG ─────────────────────────────
//
// Synthesise a vec-neg MIR module (`c[i] = -a[i]`), invoke
// `codegen_emit_rocm_il`, and assert the emitted HIP kernel source uses
// the 2-buffer signature (a + c only) and the prefix unary `-`
// operator. Asserts the second input `b` and its second-buffer
// signature are ABSENT — vec-neg is single-input. Asserts ` + ` and
// ` * ` (between two `a[i]`/`b[i]` operands) are absent so a future
// binop shape never accidentally falls into the unary branch.

fn _test_vec_neg_emit() -> bool {
    let mut ok = true
    let mod_vn = _build_vec_neg_module()
    let il = codegen_emit_rocm_il(mod_vn)

    println("")
    println("── emitted HIP source (RFC 075 P1++ vec-neg case) ──")
    println(il)

    // F-RFC075-ROCM-EMIT-VEC-NEG substring battery — 15 positive.
    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void vec_neg",                  "kernel name `vec_neg` after void return")
    ok = _check_contains(ok, il, "const float*",                  "read-only pointer parameter typing")
    ok = _check_contains(ok, il, "float*",                        "writable pointer parameter typing")
    ok = _check_contains(ok, il, "int n",                         "element-count `int n` parameter")
    ok = _check_contains(ok, il, "blockIdx.x",                    "HIP built-in `blockIdx.x`")
    ok = _check_contains(ok, il, "blockDim.x",                    "HIP built-in `blockDim.x`")
    ok = _check_contains(ok, il, "threadIdx.x",                   "HIP built-in `threadIdx.x`")
    ok = _check_contains(ok, il, "if (i < n)",                    "out-of-bounds guard")
    ok = _check_contains(ok, il, "c[i]",                          "writable buffer index `c[i]`")
    ok = _check_contains(ok, il, "a[i]",                          "read buffer index `a[i]`")
    ok = _check_contains(ok, il, "-a[i]",                         "prefix unary minus on `a[i]`")
    ok = _check_contains(ok, il, ";",                             "statement terminator")
    // Negative — vec-neg is 2-buffer; must NOT load `b[i]`, must NOT
    // include the rocWMMA header, must NOT call any of the FP32 builtin
    // function names (vec-neg uses prefix `-`, not a call form), and
    // must NOT emit `a[i] + b[i]` / `a[i] * b[i]` between two loaded
    // values (thread-idx expr contains bare `+`/`*` so we match the
    // specific 2-operand pattern).
    ok = _check_not_contains(ok, il, "b[i]",                      "vec-neg should not load `b[i]` (2-buffer guard)")
    ok = _check_not_contains(ok, il, "#include <rocwmma/rocwmma.hpp>", "vec-neg should not include rocWMMA header")
    ok = _check_not_contains(ok, il, "fabsf(",                    "vec-neg should not call `fabsf(` (vec-abs guard)")
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "vec-neg should not emit `a[i] + b[i]` (vec-add guard)")
    ok = _check_not_contains(ok, il, "a[i] * b[i]",               "vec-neg should not emit `a[i] * b[i]` (vec-mul guard)")
    return ok
}

