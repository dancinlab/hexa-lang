// ── Case 9 — F-RFC075-ROCM-EMIT-MATMUL ───────────────────────────────
//
// Synthesise a matmul MIR module, invoke `codegen_emit_rocm_il`, assert
// the emitted HIP source contains the rocWMMA preamble include, the
// 3-buffer + M/N/K kernel signature, the 16x16x16 FP32 fragment
// templates with the canonical row_major(A) + col_major(B) layouts,
// the fill+load+mma+store intrinsic call sequence, and the K-loop.
// Negative guards: transposed-A fragment (matrix_a col_major), B-side
// row_major fragment, vec-add binop fragment.

fn _test_matmul_emit() -> bool {
    let mut ok = true
    let mod_mm = _build_matmul_module()
    let il = codegen_emit_rocm_il(mod_mm)

    println("")
    println("── emitted HIP source (RFC 075 P1++ matmul case) ──")
    println(il)

    // F-RFC075-ROCM-EMIT-MATMUL substring battery — 15 positives.
    ok = _check_contains(ok, il, "#include <hip/hip_runtime.h>", "HIP runtime header include")
    ok = _check_contains(ok, il, "#include <rocwmma/rocwmma.hpp>", "rocWMMA header include")
    ok = _check_contains(ok, il, "__global__",                    "kernel qualifier `__global__`")
    ok = _check_contains(ok, il, "extern \"C\"",                  "C linkage `extern \"C\"`")
    ok = _check_contains(ok, il, "void matmul",                   "kernel name `matmul` after void return")
    ok = _check_contains(ok, il, "int M, int N, int K",           "M/N/K integer dims in signature")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::row_major>", "A fragment row_major 16x16x16 FP32")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::col_major>", "B fragment col_major 16x16x16 FP32")
    ok = _check_contains(ok, il, "rocwmma::fragment<rocwmma::accumulator, 16, 16, 16, float>", "C accumulator fragment 16x16x16 FP32")
    ok = _check_contains(ok, il, "rocwmma::fill_fragment(c_frag, 0.0f)", "accumulator zero-fill")
    ok = _check_contains(ok, il, "rocwmma::load_matrix_sync(a_frag, &a[row_tile * K + k], K)", "A tile load (row-major stride K)")
    ok = _check_contains(ok, il, "rocwmma::load_matrix_sync(b_frag, &b[k * N + col_tile], N)", "B tile load (col-major stride N)")
    ok = _check_contains(ok, il, "rocwmma::mma_sync(c_frag, a_frag, b_frag, c_frag)", "WMMA mma_sync intrinsic")
    ok = _check_contains(ok, il, "rocwmma::store_matrix_sync(&c[row_tile * N + col_tile], c_frag, N, rocwmma::mem_row_major)", "C tile store row-major")
    ok = _check_contains(ok, il, "k += 16",                       "K-loop tile-step 16")
    // Negative guards — matmul (canonical) must NOT carry the transposed
    // layout fragments and must NOT inherit a vec-* binop body fragment.
    ok = _check_not_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::col_major>", "canonical matmul should not emit transposed-A fragment")
    ok = _check_not_contains(ok, il, "rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::row_major>", "canonical matmul should not emit transposed-B fragment")
    ok = _check_not_contains(ok, il, "a[i] + b[i]",               "matmul should not emit vec-add body")
    ok = _check_not_contains(ok, il, "__shfl_xor",                "matmul should not emit reduce-sum butterfly")
    return ok
}

