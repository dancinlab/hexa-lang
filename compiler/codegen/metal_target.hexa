}

// _metal_emit_vec_round_body — emit the MSL kernel body for vec-round.
// Hardcoded: `c[i] = round(a[i]);` with surrounding braces. Calls the
// MSL builtin `round(float)` exposed by `<metal_stdlib>` (§5.10).
// Uses the 2-buffer unary kernel signature.
fn _metal_emit_vec_round_body() -> string {
    let mut out = "{\n"
    out = out + "    c" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN
    out = out + METAL_OP_ROUND + METAL_OP_CALL_OPEN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
