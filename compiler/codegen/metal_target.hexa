// _metal_format_scalar — format a MIR const operand as MSL literal text.
// const_float → uses the `float_val` field (e.g. "2.5"); const_int →
// uses the `int_val` field with `.0` appended so it stays FP32 in MSL.
// Anything else returns "0.0" as the safe fallback (callers should have
// already gated by the shape recogniser).
fn _metal_format_scalar(op: Operand) -> string {
    if op.kind == "const_float" { return to_string(op.float_val) }
    if op.kind == "const_int" { return to_string(op.int_val) + ".0" }
    return "0.0"
}

// codegen_emit_metal_msl — MIR module -> MSL source text.
//
// RFC 075 P3+ LANDED (codegen-only) — emits a full MSL kernel source
// when the first MFunc matches a recognised shape. Otherwise (empty
// module, unrecognised shape) returns `""` honestly, preserving the
// P0 contract the lower_test Case 1 still asserts.
//
// HONEST SCOPE — twenty-two shapes recognised today (vec-add, vec-mul,
// vec-sub, vec-div, vec-max, vec-min, vec-scale, vec-neg, vec-abs,
// vec-sqrt, vec-exp, vec-log, vec-sin, vec-cos, vec-floor, vec-ceil,
// vec-round, reduce-sum, matmul, matmul_NT_a, matmul_NT_b, matmul_bf16).
// All other MIR patterns return "". General MFunc → MSL lowering is
// multi-session work mirroring the NVPTX P3 timeline.
//
//   Shape coverage matrix (RFC 075 P3+):
//     vec-add     `c[i] = a[i] + b[i]`     STMT_LOAD+LOAD+BINOP(add)+STORE
//     vec-mul     `c[i] = a[i] * b[i]`     STMT_LOAD+LOAD+BINOP(mul)+STORE
//     vec-sub     `c[i] = a[i] - b[i]`     STMT_LOAD+LOAD+BINOP(sub)+STORE
//     vec-div     `c[i] = a[i] / b[i]`     STMT_LOAD+LOAD+BINOP(div)+STORE
//     vec-max     `c[i] = max(a[i],b[i])`  STMT_LOAD+LOAD+BINOP(max)+STORE  (call form)
//     vec-min     `c[i] = min(a[i],b[i])`  STMT_LOAD+LOAD+BINOP(min)+STORE  (call form)
//     vec-scale   `c[i] = a[i] * <const>`  STMT_LOAD+BINOP(mul, const)+STORE
//     vec-neg     `c[i] = -a[i]`           STMT_LOAD+UNOP(neg)+STORE   (2-buf)
//     vec-abs     `c[i] = abs(a[i])`       STMT_LOAD+UNOP(abs)+STORE   (2-buf)
//     vec-sqrt    `c[i] = sqrt(a[i])`      STMT_LOAD+UNOP(sqrt)+STORE  (2-buf)
//     vec-exp     `c[i] = exp(a[i])`       STMT_LOAD+UNOP(exp)+STORE   (2-buf)
//     vec-log     `c[i] = log(a[i])`       STMT_LOAD+UNOP(log)+STORE   (2-buf)
//     vec-sin     `c[i] = sin(a[i])`       STMT_LOAD+UNOP(sin)+STORE   (2-buf)
//     vec-cos     `c[i] = cos(a[i])`       STMT_LOAD+UNOP(cos)+STORE   (2-buf)
//     vec-floor   `c[i] = floor(a[i])`     STMT_LOAD+UNOP(floor)+STORE (2-buf)
//     vec-ceil    `c[i] = ceil(a[i])`      STMT_LOAD+UNOP(ceil)+STORE  (2-buf)
//     vec-round   `c[i] = round(a[i])`     STMT_LOAD+UNOP(round)+STORE (2-buf)
//     reduce-sum  `c[g] = simd_sum(a[i])`  STMT_LOAD+UNOP(reduce_sum)+STORE (2-buf, per-SG output)
//     matmul      `C = A · B`              STMT_LOAD+LOAD+BINOP(matmul)+STORE (6-buf MMA)
//     matmul_NT_a `C = A^T · B`            STMT_LOAD+LOAD+BINOP(matmul_NT_a)+STORE (6-buf MMA, Amat transpose=true)
//     matmul_NT_b `C = A · B^T`            STMT_LOAD+LOAD+BINOP(matmul_NT_b)+STORE (6-buf MMA, Bmat transpose=true)
//     matmul_bf16 `C = A · B` (bfloat)     STMT_LOAD+LOAD+BINOP(matmul_bf16)+STORE (6-buf bf16 MMA, FP32 acc)
//
// Dispatch order: vec-add → vec-mul → vec-sub → vec-div → vec-max →
// vec-min → vec-scale → vec-neg → vec-abs → vec-sqrt → vec-exp →
// vec-log → vec-sin → vec-cos → vec-floor → vec-ceil → vec-round →
// reduce-sum → matmul → matmul_NT_a → matmul_NT_b → matmul_bf16 → "".
// Element-wise unary kernels are dispatched AFTER all binop /
// scale shapes so the existing recognisers short-circuit on a second
// STMT_LOAD first; the unary recognisers only see MIR with the 2-stmt
// prefix STMT_LOAD + STMT_UNOP. vec-scale is tried before vec-* unary
// because its recogniser is the most discerning (checks operand kinds)
// on the 3-stmt prefix it shares with the unary family. Within the
// unary family, dispatch order does not matter — all unary recognisers
// are mutually exclusive on the STMT_UNOP op string.
//
// The unary family is the codegen's first 2-buffer kernel shape: input
// `a` + output `c` (NO second input `b`). The signature is emitted by
// `_metal_emit_unary_kernel_signature` and shifts `c`'s buffer binding
// from [[buffer(2)]] (3-buf binops) to [[buffer(1)]].
//
// P4+ insertion points:
//   - TODO RFC 075 P4 — silicon fire via `xcrun -sdk macosx metal`
//     + Metal Performance Shaders runtime + M-series GPU (vec-add
//     landed on Apple M3 commit 4415ec91; vec-mul / vec-sub / vec-div /
//     vec-scale / vec-neg / vec-abs / vec-sqrt / vec-exp / vec-log /
//     vec-sin / vec-cos silicon fires queued for the same cycle once
//     a Mac is available — transcendentals need ULP-tolerance compare
//     against the CPU reference because Apple M-series transcendentals
//     may differ from IEEE by several ULP).
//   - TODO RFC 075 follow-on cycle — general MFunc → MSL emission
//     (replicate `_nvptx_lower_func` shape against MSL statements).
pub fn codegen_emit_metal_msl(module: MModule) -> string {
    // P0 contract: empty module → empty string.
    if len(module.funcs) == 0 { return "" }
    let mfn = module.funcs[0]
    // Shared preamble + signature for any recognised vec-* shape.
    let kname = mfn.name
    // vec-add — STMT_LOAD + STMT_LOAD + STMT_BINOP(add) + STMT_STORE.
    if _metal_mfunc_is_vec_add_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_add_body()
        return out
    }
    // vec-mul — STMT_LOAD + STMT_LOAD + STMT_BINOP(mul) + STMT_STORE.
    if _metal_mfunc_is_vec_mul_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_mul_body()
        return out
    }
    // vec-sub — STMT_LOAD + STMT_LOAD + STMT_BINOP(sub) + STMT_STORE.
    if _metal_mfunc_is_vec_sub_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_sub_body()
        return out
    }
    // vec-div — STMT_LOAD + STMT_LOAD + STMT_BINOP(div) + STMT_STORE.
    if _metal_mfunc_is_vec_div_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_div_body()
        return out
    }
    // vec-max — STMT_LOAD + STMT_LOAD + STMT_BINOP(max) + STMT_STORE.
    // Function-call form `max(a[i], b[i])` (NOT an infix operator).
    if _metal_mfunc_is_vec_max_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_max_body()
        return out
    }
    // vec-min — STMT_LOAD + STMT_LOAD + STMT_BINOP(min) + STMT_STORE.
    // Function-call form `min(a[i], b[i])` (NOT an infix operator).
    if _metal_mfunc_is_vec_min_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_min_body()
        return out
    }
    // vec-scale — STMT_LOAD + STMT_BINOP(mul, const) + STMT_STORE.
    // The scalar literal text is pulled from the BINOP's args[1] const
    // operand and formatted to an MSL FP32 literal.
    if _metal_mfunc_is_vec_scale_shape(mfn) {
        let entry = mfn.blocks[0]
        let scalar = _metal_format_scalar(entry.stmts[1].args[1])
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_kernel_signature(kname)
        out = out + _metal_emit_vec_scale_body(scalar)
        return out
    }
    // vec-neg — STMT_LOAD + STMT_UNOP(neg) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_neg_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_neg_body()
        return out
    }
    // vec-abs — STMT_LOAD + STMT_UNOP(abs) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_abs_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_abs_body()
        return out
    }
    // vec-sqrt — STMT_LOAD + STMT_UNOP(sqrt) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_sqrt_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_sqrt_body()
        return out
    }
    // vec-exp — STMT_LOAD + STMT_UNOP(exp) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_exp_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_exp_body()
        return out
    }
    // vec-log — STMT_LOAD + STMT_UNOP(log) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_log_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_log_body()
        return out
    }
    // vec-sin — STMT_LOAD + STMT_UNOP(sin) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_sin_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_sin_body()
        return out
    }
    // vec-cos — STMT_LOAD + STMT_UNOP(cos) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_cos_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_cos_body()
        return out
    }
    // vec-floor — STMT_LOAD + STMT_UNOP(floor) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_floor_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_floor_body()
        return out
    }
    // vec-ceil — STMT_LOAD + STMT_UNOP(ceil) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_ceil_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_ceil_body()
        return out
    }
    // vec-round — STMT_LOAD + STMT_UNOP(round) + STMT_STORE (2-buffer sig).
    if _metal_mfunc_is_vec_round_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_unary_kernel_signature(kname)
        out = out + _metal_emit_vec_round_body()
        return out
    }
    // reduce-sum — STMT_LOAD + STMT_UNOP(reduce_sum) + STMT_STORE.
    // First NON-element-wise shape; emits Apple `simd_sum` + lane-0 gate.
    if _metal_mfunc_is_reduce_sum_shape(mfn) {
        let mut out = _metal_emit_preamble()
        out = out + _metal_emit_reduce_kernel_signature(kname)
        out = out + _metal_emit_reduce_sum_body()
        return out
    }
    // matmul — STMT_LOAD + STMT_LOAD + STMT_BINOP(matmul) + STMT_STORE.
    // 6-arg MMA kernel signature + simdgroup_matrix<float, 8, 8> tile.
    if _metal_mfunc_is_matmul_shape(mfn) {
        let mut out = _metal_emit_matmul_preamble()
        out = out + _metal_emit_matmul_kernel_signature(kname)
        out = out + _metal_emit_matmul_body()
        return out
    }
    // matmul_NT_a — `C = A^T · B` (A is K×M). Transpose flag on Amat.
    if _metal_mfunc_is_matmul_NT_a_shape(mfn) {
        let mut out = _metal_emit_matmul_preamble()
        out = out + _metal_emit_matmul_kernel_signature(kname)
        out = out + _metal_emit_matmul_NT_a_body()
        return out
    }
    // matmul_NT_b — `C = A · B^T` (B is N×K). Transpose flag on Bmat.
    if _metal_mfunc_is_matmul_NT_b_shape(mfn) {
        let mut out = _metal_emit_matmul_preamble()
        out = out + _metal_emit_matmul_kernel_signature(kname)
        out = out + _metal_emit_matmul_NT_b_body()
        return out
    }
    // matmul_bf16 — bfloat A/B + FP32 accumulator (mixed-precision MMA).
    // Uses the bf16 signature (bfloat input pointers); requires M3+ for
    // hardware bf16 support.
    if _metal_mfunc_is_matmul_bf16_shape(mfn) {
        let mut out = _metal_emit_matmul_preamble()
        out = out + _metal_emit_matmul_kernel_signature_bf16(kname)
        out = out + _metal_emit_matmul_bf16_body()
        return out
    }
    // No recognised shape — honest empty string.
    return ""
}
