// ── RFC 075 P3+ reduce-sum — 2-buffer signature + body ─────────────
//
// FIRST NON-ELEMENT-WISE SHAPE. The reduce-sum kernel writes one
// float per SIMD group (N/32 outputs for N inputs) using Apple's
// `simd_sum` intrinsic + `simd_is_first()` lane-0 gate.

// _metal_emit_reduce_kernel_signature — emit the 2-buffer signature
// for reduce-sum (a, c) + thread-position-in-grid binding. Identical
// to the unary 2-buffer signature today but kept as a separate helper
// in case the future per-group output sizing diverges (e.g. binding
// a second output stride scalar).
fn _metal_emit_reduce_kernel_signature(name: string) -> string {
    let mut out = METAL_OP_KERNEL_DECL + " " + name + "(\n"
    out = out + "    " + METAL_OP_PARAM_DEVICE_CONST_FLOAT_PTR + "a "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "0" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    " + METAL_OP_PARAM_DEVICE_FLOAT_PTR + "c "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "1" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    " + METAL_TYPE_UINT + " i " + METAL_OP_THREAD_POS_GRID + ")\n"
    return out
}

// _metal_emit_reduce_sum_body — emit the MSL kernel body for reduce-sum.
// Per-SIMD-group output pattern:
//   {
//       float v = a[i];
//       v = simd_sum(v);
//       if (simd_is_first()) {
//           uint group_id = i / 32u;
//           c[group_id] = v;
//       }
//   }
fn _metal_emit_reduce_sum_body() -> string {
    let mut out = "{\n"
    out = out + "    " + METAL_TYPE_FLOAT + " v" + METAL_OP_ASSIGN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "    v" + METAL_OP_ASSIGN + METAL_OP_SIMD_SUM + "(v)"
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "    if (" + METAL_OP_SIMD_IS_FIRST + "()) {\n"
    out = out + "        " + METAL_TYPE_UINT + " group_id" + METAL_OP_ASSIGN
    out = out + "i" + METAL_OP_SIMD_GROUP_DIV + METAL_OP_STMT_TERM + "\n"
    out = out + "        c" + METAL_OP_INDEX_OPEN + "group_id" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN + "v" + METAL_OP_STMT_TERM + "\n"
    out = out + "    }\n"
    out = out + "}\n"
    return out
}

// _metal_mfunc_is_reduce_sum_shape — recognise the reduce-sum MIR shape.
//
// SYNTHETIC MIR SHAPE — STMT_LOAD a→va, STMT_UNOP("reduce_sum", va)→vc,
// STMT_STORE vc→c. No HIR / parser produces this opcode today; the
// recogniser is scaffold for the future `sum(array)` lowering.
fn _metal_mfunc_is_reduce_sum_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 3 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_UNOP { return false }
    if stmts[1].op != "reduce_sum" { return false }
    if stmts[2].kind != STMT_STORE { return false }
    return true
}

// ── RFC 075 P3+ MMA family — preamble + signature + bodies ──────────
//
// First multi-buffer (6-arg) signature in the Metal codegen — mirrors
// the NVPTX `gemm` kernel signature but in MSL source-text form.
// Body is hardcoded TG_M=32 · TG_N=32 · TG_K=8 with FP32 simdgroup-MMA;
// general (M, N, K) emit + tile-search is multi-session.

// _metal_emit_matmul_preamble — emit the MSL preamble for MMA shapes:
// stdlib include + simdgroup-matrix include + namespace using.
fn _metal_emit_matmul_preamble() -> string {
    return METAL_OP_PREAMBLE_INCLUDE + "\n"
         + METAL_OP_SIMDGROUP_PREAMBLE_INCLUDE + "\n"
         + METAL_OP_PREAMBLE_USING + "\n\n"
}

// _metal_emit_matmul_kernel_signature — emit `kernel void <name>(...)`
// with the 6-arg matmul signature: 3 device-pointer buffers (a, b, c)
// + 3 scalar dim params (M, N, K) + 4 thread-hierarchy attributes
// (tgid, lid, sgid, slid). Shared across matmul / matmul_NT_a /
// matmul_NT_b / matmul_bf16 — only the body differs.
fn _metal_emit_matmul_kernel_signature(name: string) -> string {
    let mut out = METAL_OP_KERNEL_DECL + " " + name + "(\n"
    out = out + "    " + METAL_OP_PARAM_DEVICE_CONST_FLOAT_PTR + "a "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "0" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    " + METAL_OP_PARAM_DEVICE_CONST_FLOAT_PTR + "b "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "1" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    " + METAL_OP_PARAM_DEVICE_FLOAT_PTR + "c "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "2" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    constant " + METAL_TYPE_UINT + "& M "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "3" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    constant " + METAL_TYPE_UINT + "& N "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "4" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    constant " + METAL_TYPE_UINT + "& K "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "5" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    uint2 tgid " + METAL_OP_THREADGROUP_POS_ATTR + ",\n"
    out = out + "    uint2 lid " + METAL_OP_THREAD_POS_IN_TG_ATTR + ",\n"
    out = out + "    uint sgid " + METAL_OP_SIMDGROUP_IDX_ATTR + ",\n"
    out = out + "    uint slid " + METAL_OP_THREAD_IDX_SIMD_ATTR + ")\n"
    return out
}

// _metal_emit_matmul_kernel_signature_bf16 — emit `kernel void <name>(...)`
// with the bf16-MMA signature. Differs from FP32 sig only in the a/b
// input pointer element type (bfloat instead of float); output c stays
// FP32 (mixed-precision MMA pattern from N30).
fn _metal_emit_matmul_kernel_signature_bf16(name: string) -> string {
    let mut out = METAL_OP_KERNEL_DECL + " " + name + "(\n"
    out = out + "    device const " + METAL_TYPE_BFLOAT + "* a "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "0" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    device const " + METAL_TYPE_BFLOAT + "* b "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "1" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    " + METAL_OP_PARAM_DEVICE_FLOAT_PTR + "c "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "2" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    constant " + METAL_TYPE_UINT + "& M "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "3" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    constant " + METAL_TYPE_UINT + "& N "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "4" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    constant " + METAL_TYPE_UINT + "& K "
    out = out + METAL_OP_BUFFER_BINDING_PREFIX + "5" + METAL_OP_BUFFER_BINDING_SUFFIX + ",\n"
    out = out + "    uint2 tgid " + METAL_OP_THREADGROUP_POS_ATTR + ",\n"
    out = out + "    uint2 lid " + METAL_OP_THREAD_POS_IN_TG_ATTR + ",\n"
    out = out + "    uint sgid " + METAL_OP_SIMDGROUP_IDX_ATTR + ",\n"
    out = out + "    uint slid " + METAL_OP_THREAD_IDX_SIMD_ATTR + ")\n"
    return out
}

// _metal_emit_matmul_body — emit the MSL kernel body for plain matmul
// `C = A · B` using simdgroup-MMA. Verbatim port of N16
// `simdgroup_matmul_32x32_tg` (32×32 output block, 4×4 SG tiling,
// TG_M=32, TG_N=32, TG_K=8). Peak 911.55 GFLOPS @ 768³ on Apple M3,
// 3.4× over the tiled-naive baseline.
fn _metal_emit_matmul_body() -> string {
    let mut out = "{\n"
    out = out + "    const uint TG_M = 32u;\n"
    out = out + "    const uint TG_N = 32u;\n"
    out = out + "    const uint TG_K = 8u;\n"
    out = out + "    const uint block_row_base = tgid.y * TG_M;\n"
    out = out + "    const uint block_col_base = tgid.x * TG_N;\n"
    out = out + "    const uint sg_y = sgid >> 2u;\n"
    out = out + "    const uint sg_x = sgid & 3u;\n"
    out = out + "    const uint row_base = block_row_base + sg_y * 8u;\n"
    out = out + "    const uint col_base = block_col_base + sg_x * 8u;\n"
    out = out + "    threadgroup float As[32 * 8];\n"
    out = out + "    threadgroup float Bs[8 * 32];\n"
    out = out + "    " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Cmat = "
    out = out + METAL_OP_MAKE_FILLED_SIMDGROUP_MATRIX + "<float, 8, 8>(0.0f);\n"
    out = out + "    const uint tid = sgid * 32u + slid;\n"
    out = out + "    const uint K8 = K / 8u;\n"
    out = out + "    for (uint kk = 0u; kk < K8; ++kk) {\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_K;\n"
    out = out + "            const uint cc = tid % TG_K;\n"
    out = out + "            const uint a_row = block_row_base + r;\n"
    out = out + "            const uint a_col = kk * 8u + cc;\n"
    out = out + "            As[r * TG_K + cc] = (a_row < M && a_col < K) ? a[a_row * K + a_col] : 0.0f;\n"
    out = out + "        }\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_N;\n"
    out = out + "            const uint cc = tid % TG_N;\n"
    out = out + "            const uint b_row = kk * 8u + r;\n"
    out = out + "            const uint b_col = block_col_base + cc;\n"
    out = out + "            Bs[r * TG_N + cc] = (b_row < K && b_col < N) ? b[b_row * N + b_col] : 0.0f;\n"
    out = out + "        }\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Amat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Bmat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Amat, As, ulong(TG_K), ulong2(0ul, ulong(sg_y * 8u)), false);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Bmat, Bs, ulong(TG_N), ulong2(ulong(sg_x * 8u), 0ul), false);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MMA + "(Cmat, Amat, Bmat, Cmat);\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "    }\n"
    out = out + "    if (row_base < M && col_base < N) {\n"
    out = out + "        " + METAL_OP_SIMDGROUP_STORE + "(Cmat, c, ulong(N), ulong2(ulong(col_base), ulong(row_base)), false);\n"
    out = out + "    }\n"
    out = out + "}\n"
    return out
}

// _metal_emit_matmul_NT_a_body — emit `C = A^T · B` body. A is K×M.
// As slab holds 8×32 K-band × M-band; transpose flag on the Amat
// simdgroup_load flips into M×K for the MMA primitive.
fn _metal_emit_matmul_NT_a_body() -> string {
    let mut out = "{\n"
    out = out + "    const uint TG_M = 32u;\n"
    out = out + "    const uint TG_N = 32u;\n"
    out = out + "    const uint TG_K = 8u;\n"
    out = out + "    const uint block_row_base = tgid.y * TG_M;\n"
    out = out + "    const uint block_col_base = tgid.x * TG_N;\n"
    out = out + "    const uint sg_y = sgid >> 2u;\n"
    out = out + "    const uint sg_x = sgid & 3u;\n"
    out = out + "    const uint row_base = block_row_base + sg_y * 8u;\n"
    out = out + "    const uint col_base = block_col_base + sg_x * 8u;\n"
    out = out + "    threadgroup float As[8 * 32];\n"
    out = out + "    threadgroup float Bs[8 * 32];\n"
    out = out + "    " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Cmat = "
    out = out + METAL_OP_MAKE_FILLED_SIMDGROUP_MATRIX + "<float, 8, 8>(0.0f);\n"
    out = out + "    const uint tid = sgid * 32u + slid;\n"
    out = out + "    const uint K8 = K / 8u;\n"
    out = out + "    for (uint kk = 0u; kk < K8; ++kk) {\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_M;\n"
    out = out + "            const uint cc = tid % TG_M;\n"
    out = out + "            const uint a_row = kk * 8u + r;\n"
    out = out + "            const uint a_col = block_row_base + cc;\n"
    out = out + "            As[r * TG_M + cc] = (a_row < K && a_col < M) ? a[a_row * M + a_col] : 0.0f;\n"
    out = out + "        }\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_N;\n"
    out = out + "            const uint cc = tid % TG_N;\n"
    out = out + "            const uint b_row = kk * 8u + r;\n"
    out = out + "            const uint b_col = block_col_base + cc;\n"
    out = out + "            Bs[r * TG_N + cc] = (b_row < K && b_col < N) ? b[b_row * N + b_col] : 0.0f;\n"
    out = out + "        }\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Amat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Bmat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Amat, As, ulong(TG_M), ulong2(ulong(sg_y * 8u), 0ul), true);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Bmat, Bs, ulong(TG_N), ulong2(ulong(sg_x * 8u), 0ul), false);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MMA + "(Cmat, Amat, Bmat, Cmat);\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "    }\n"
    out = out + "    if (row_base < M && col_base < N) {\n"
    out = out + "        " + METAL_OP_SIMDGROUP_STORE + "(Cmat, c, ulong(N), ulong2(ulong(col_base), ulong(row_base)), false);\n"
    out = out + "    }\n"
    out = out + "}\n"
    return out
}

// _metal_emit_matmul_NT_b_body — emit `C = A · B^T` body. B is N×K.
// Bs slab holds 32×8 N-band × K-band; transpose flag on Bmat
// simdgroup_load flips into K×N for the MMA primitive.
fn _metal_emit_matmul_NT_b_body() -> string {
    let mut out = "{\n"
    out = out + "    const uint TG_M = 32u;\n"
    out = out + "    const uint TG_N = 32u;\n"
    out = out + "    const uint TG_K = 8u;\n"
    out = out + "    const uint block_row_base = tgid.y * TG_M;\n"
    out = out + "    const uint block_col_base = tgid.x * TG_N;\n"
    out = out + "    const uint sg_y = sgid >> 2u;\n"
    out = out + "    const uint sg_x = sgid & 3u;\n"
    out = out + "    const uint row_base = block_row_base + sg_y * 8u;\n"
    out = out + "    const uint col_base = block_col_base + sg_x * 8u;\n"
    out = out + "    threadgroup float As[32 * 8];\n"
    out = out + "    threadgroup float Bs[32 * 8];\n"
    out = out + "    " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Cmat = "
    out = out + METAL_OP_MAKE_FILLED_SIMDGROUP_MATRIX + "<float, 8, 8>(0.0f);\n"
    out = out + "    const uint tid = sgid * 32u + slid;\n"
    out = out + "    const uint K8 = K / 8u;\n"
    out = out + "    for (uint kk = 0u; kk < K8; ++kk) {\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_K;\n"
    out = out + "            const uint cc = tid % TG_K;\n"
    out = out + "            const uint a_row = block_row_base + r;\n"
    out = out + "            const uint a_col = kk * 8u + cc;\n"
    out = out + "            As[r * TG_K + cc] = (a_row < M && a_col < K) ? a[a_row * K + a_col] : 0.0f;\n"
    out = out + "        }\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_K;\n"
    out = out + "            const uint cc = tid % TG_K;\n"
    out = out + "            const uint b_row = block_col_base + r;\n"
    out = out + "            const uint b_col = kk * 8u + cc;\n"
    out = out + "            Bs[r * TG_K + cc] = (b_row < N && b_col < K) ? b[b_row * K + b_col] : 0.0f;\n"
    out = out + "        }\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Amat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Bmat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Amat, As, ulong(TG_K), ulong2(0ul, ulong(sg_y * 8u)), false);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Bmat, Bs, ulong(TG_K), ulong2(0ul, ulong(sg_x * 8u)), true);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MMA + "(Cmat, Amat, Bmat, Cmat);\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "    }\n"
    out = out + "    if (row_base < M && col_base < N) {\n"
    out = out + "        " + METAL_OP_SIMDGROUP_STORE + "(Cmat, c, ulong(N), ulong2(ulong(col_base), ulong(row_base)), false);\n"
    out = out + "    }\n"
    out = out + "}\n"
    return out
}

// _metal_emit_matmul_bf16_body — emit `C = A · B` body with bfloat
// A/B storage + FP32 accumulator. Mirrors plain matmul body modulo
// the `simdgroup_matrix<bfloat, 8, 8>` element type for Amat / Bmat
// and bfloat threadgroup-mem slabs. Cmat stays `simdgroup_matrix<
// float, 8, 8>` (mixed-precision MMA = ~2× throughput on M3+ silicon
// where bf16 multiplies feed FP32 accumulator).
//   ref: Metal Shading Language Specification §6.7 (simdgroup_matrix
//        bfloat overload). N30 mixed-precision template (FP32
//        accumulator) + N36 bfloat type substitution.
//
// HONEST SCOPE (@D g3) — bf16 support requires Apple silicon M3 or
// later. The codegen emits the kernel source unconditionally; runtime
// gating (host driver decides whether to compile this kernel based
// on `MTLGPUFamily.apple9` feature set) is host-side responsibility.
fn _metal_emit_matmul_bf16_body() -> string {
    let mut out = "{\n"
    out = out + "    const uint TG_M = 32u;\n"
    out = out + "    const uint TG_N = 32u;\n"
    out = out + "    const uint TG_K = 8u;\n"
    out = out + "    const uint block_row_base = tgid.y * TG_M;\n"
    out = out + "    const uint block_col_base = tgid.x * TG_N;\n"
    out = out + "    const uint sg_y = sgid >> 2u;\n"
    out = out + "    const uint sg_x = sgid & 3u;\n"
    out = out + "    const uint row_base = block_row_base + sg_y * 8u;\n"
    out = out + "    const uint col_base = block_col_base + sg_x * 8u;\n"
    // bfloat threadgroup slabs — half the byte footprint of the FP32
    // matmul (each slab 256 elements × 2 B = 512 B vs 1 KiB).
    out = out + "    threadgroup " + METAL_TYPE_BFLOAT + " As[32 * 8];\n"
    out = out + "    threadgroup " + METAL_TYPE_BFLOAT + " Bs[8 * 32];\n"
    // FP32 accumulator (mixed-precision MMA).
    out = out + "    " + METAL_OP_SIMDGROUP_MATRIX + "<float, 8, 8> Cmat = "
    out = out + METAL_OP_MAKE_FILLED_SIMDGROUP_MATRIX + "<float, 8, 8>(0.0f);\n"
    out = out + "    const uint tid = sgid * 32u + slid;\n"
    out = out + "    const uint K8 = K / 8u;\n"
    out = out + "    for (uint kk = 0u; kk < K8; ++kk) {\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_K;\n"
    out = out + "            const uint cc = tid % TG_K;\n"
    out = out + "            const uint a_row = block_row_base + r;\n"
    out = out + "            const uint a_col = kk * 8u + cc;\n"
    out = out + "            As[r * TG_K + cc] = (a_row < M && a_col < K) ? a[a_row * K + a_col] : " + METAL_TYPE_BFLOAT + "(0.0f);\n"
    out = out + "        }\n"
    out = out + "        if (tid < 256u) {\n"
    out = out + "            const uint r = tid / TG_N;\n"
    out = out + "            const uint cc = tid % TG_N;\n"
    out = out + "            const uint b_row = kk * 8u + r;\n"
    out = out + "            const uint b_col = block_col_base + cc;\n"
    out = out + "            Bs[r * TG_N + cc] = (b_row < K && b_col < N) ? b[b_row * N + b_col] : " + METAL_TYPE_BFLOAT + "(0.0f);\n"
    out = out + "        }\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    // bfloat tile MMA operands — element type is bfloat (mixed-precision).
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<" + METAL_TYPE_BFLOAT + ", 8, 8> Amat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MATRIX + "<" + METAL_TYPE_BFLOAT + ", 8, 8> Bmat;\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Amat, As, ulong(TG_K), ulong2(0ul, ulong(sg_y * 8u)), false);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_LOAD + "(Bmat, Bs, ulong(TG_N), ulong2(ulong(sg_x * 8u), 0ul), false);\n"
    out = out + "        " + METAL_OP_SIMDGROUP_MMA + "(Cmat, Amat, Bmat, Cmat);\n"
    out = out + "        " + METAL_OP_THREADGROUP_BARRIER + "(" + METAL_OP_MEM_FLAGS_TG + ");\n"
    out = out + "    }\n"
    out = out + "    if (row_base < M && col_base < N) {\n"
    out = out + "        " + METAL_OP_SIMDGROUP_STORE + "(Cmat, c, ulong(N), ulong2(ulong(col_base), ulong(row_base)), false);\n"
    out = out + "    }\n"
    out = out + "}\n"
    return out
}

// _metal_mfunc_is_matmul_shape — recognise plain matmul MIR shape.
// SYNTHETIC: STMT_LOAD a→va + STMT_LOAD b→vb + STMT_BINOP("matmul")
// (va, vb)→vc + STMT_STORE vc→c.
fn _metal_mfunc_is_matmul_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _metal_mfunc_is_matmul_NT_a_shape — recognise `C = A^T · B`.
// SYNTHETIC: STMT_BINOP("matmul_NT_a"). Drives flame ag_linear
// backward `dW = x^T · dy` lowering scaffold.
fn _metal_mfunc_is_matmul_NT_a_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul_NT_a" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _metal_mfunc_is_matmul_NT_b_shape — recognise `C = A · B^T`.
// SYNTHETIC: STMT_BINOP("matmul_NT_b"). Drives flame ag_linear
// backward `dx = dy · W^T` lowering scaffold.
fn _metal_mfunc_is_matmul_NT_b_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul_NT_b" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _metal_mfunc_is_matmul_bf16_shape — recognise the bf16 matmul MIR
// shape. SYNTHETIC: STMT_LOAD a→va + STMT_LOAD b→vb +
// STMT_BINOP("matmul_bf16") (va, vb)→vc + STMT_STORE vc→c. Discriminated
// from plain matmul by the opcode string. N30 mixed-precision template
// + N36 bfloat type substitution.
fn _metal_mfunc_is_matmul_bf16_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul_bf16" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _metal_mfunc_is_vec_add_shape — recognise the vec-add MIR shape.
// Hardcoded shape check: entry block has exactly STMT_LOAD + STMT_LOAD
// + STMT_BINOP("add") + STMT_STORE (in that order), plus an optional
// STMT_RETURN at the end. Anything else returns false and the emitter
// falls through to the honest empty-string path.
fn _metal_mfunc_is_vec_add_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "add" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _metal_mfunc_is_vec_mul_shape — recognise the vec-mul MIR shape.
// Mirror of `_metal_mfunc_is_vec_add_shape` with the BINOP op string
