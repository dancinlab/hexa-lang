// ── RFC 075 P3+ element-wise extension — vec-max/min (3-buffer binary)
//
// `max(a, b)` / `min(a, b)` are MSL builtins (`<metal_stdlib>` §5.10) —
// function-call form, NOT infix operators. Distinguishes them from
// vec-add/sub/mul/div which use `+`/`-`/`*`/`/`. Emits the same 3-buffer
// kernel signature (a, b, c + thread index) used by the other binops.

// _metal_emit_vec_max_body — emit the MSL kernel body for vec-max.
// Hardcoded: `c[i] = max(a[i], b[i]);` with surrounding braces. Calls
// the MSL builtin `max(float, float)` exposed by `<metal_stdlib>`.
fn _metal_emit_vec_max_body() -> string {
    let mut out = "{\n"
    out = out + "    c" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN
    out = out + METAL_OP_MAX + METAL_OP_CALL_OPEN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + ", "
    out = out + "b" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_CALL_CLOSE
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

// _metal_emit_vec_min_body — emit the MSL kernel body for vec-min.
// Hardcoded: `c[i] = min(a[i], b[i]);` with surrounding braces. Calls
// the MSL builtin `min(float, float)` exposed by `<metal_stdlib>`.
fn _metal_emit_vec_min_body() -> string {
    let mut out = "{\n"
    out = out + "    c" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN
    out = out + METAL_OP_MIN + METAL_OP_CALL_OPEN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + ", "
    out = out + "b" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_CALL_CLOSE
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

// _metal_emit_vec_floor_body — emit the MSL kernel body for vec-floor.
// Hardcoded: `c[i] = floor(a[i]);` with surrounding braces. Calls the
// MSL builtin `floor(float)` exposed by `<metal_stdlib>` (§5.10).
// Uses the 2-buffer unary kernel signature.
fn _metal_emit_vec_floor_body() -> string {
    let mut out = "{\n"
    out = out + "    c" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN
    out = out + METAL_OP_FLOOR + METAL_OP_CALL_OPEN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_CALL_CLOSE
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

// _metal_emit_vec_ceil_body — emit the MSL kernel body for vec-ceil.
// Hardcoded: `c[i] = ceil(a[i]);` with surrounding braces. Calls the
// MSL builtin `ceil(float)` exposed by `<metal_stdlib>` (§5.10).
// Uses the 2-buffer unary kernel signature.
fn _metal_emit_vec_ceil_body() -> string {
    let mut out = "{\n"
    out = out + "    c" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN
    out = out + METAL_OP_CEIL + METAL_OP_CALL_OPEN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_CALL_CLOSE
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "}\n"
