    out = out + "    c" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_ASSIGN
    out = out + METAL_OP_SQRT + METAL_OP_CALL_OPEN
    out = out + "a" + METAL_OP_INDEX_OPEN + "i" + METAL_OP_INDEX_CLOSE
    out = out + METAL_OP_CALL_CLOSE
    out = out + METAL_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

