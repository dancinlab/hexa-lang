// HEXA Native Compiler — RFC 055 055-P0 / NVPTX PTX emit smoke test
//
// @version 0.0.1
// @capabilities [pure]
//
// RFC 055 055-P0 — exercises the PTX text emit pass (`emit_ptx`,
// `codegen_emit_ptx_sm90` / `_sm80`) on hand-built FP64-arithmetic MIR.
// This is the 055-P0 unit/smoke entry point: it stays UNWIRED from the
// compiler's main target dispatch (zero behavior change for CPU codegen
// — falsifier F-RFC055-CPU-CODEGEN-UNTOUCHED). It does NOT fire a GPU,
// does NOT invoke `ptxas` — it only asserts the emitted PTX TEXT shape.
//
// Hand-builds one tiny MIR module:
//   fn fp64_axpb() { t = a * b ; r = t + a ; return }
// — the FP64 arithmetic subset (`mul.f64` + `add.f64` + `ret`) §6.6.
//
// Run:
//   hexa run compiler/codegen/nvptx_emit_test.hexa

import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "./nvptx_target.hexa"
import "./nvptx_ptx_ops.hexa"

// ── MIR construction helpers ─────────────────────────────────

fn _local(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name, precision: "" }
}

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "", precision: "" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local",
        local_id: local_id,
        int_val: 0,
        float_val: 0.0,
        str_val: "",
        global_id: -1
    }
}

fn _stmt_binop(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return Stmt {
        kind: STMT_BINOP,
        dst: dst,
        op: op,
        args: xs,
        target_block: -1,
        target_block_else: -1
    }
}

fn _stmt_return() -> Stmt {
    return Stmt {
        kind: STMT_RETURN,
        dst: _miss_local(),
        op: "",
        args: [],
        target_block: -1,
        target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

// fn fp64_axpb() { t = a * b ; r = t + a ; return }
fn _build_case_axpb() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let t = _local(2, "t")
    let r = _local(3, "r")

    let mut stmts = []
    stmts.push(_stmt_binop(t, "mul", _op_local(a.id), _op_local(b.id)))
    stmts.push(_stmt_binop(r, "add", _op_local(t.id), _op_local(a.id)))
    stmts.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, stmts))

    let mf = MFunc {
        name: "fp64_axpb",
        params: [],
        return_local: _miss_local(),
        locals: [],
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_axpb.hexa", funcs: fns, globals: [] }
}

// ── Text inspection ──────────────────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    return hay.find(needle) >= 0
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  RFC 055 055-P0 — NVPTX PTX emit smoke test")
    println("══════════════════════════════════════════════")

    let mut ok = true
    let m = _build_case_axpb()

    // ── sm_90 ────────────────────────────────────────────────
    let ptx90 = codegen_emit_ptx_sm90(m)
    println("")
    println("── emitted PTX (sm_90) ──")
    println(ptx90)

    if !_contains(ptx90, ".version 7.8") {
        println("  FAIL: sm_90 PTX missing `.version` directive")
        ok = false
    }
    if !_contains(ptx90, ".target sm_90") {
        println("  FAIL: sm_90 PTX missing `.target sm_90`")
        ok = false
    }
    if !_contains(ptx90, ".address_size 64") {
        println("  FAIL: sm_90 PTX missing `.address_size 64`")
        ok = false
    }
    if !_contains(ptx90, ".func fp64_axpb") {
        println("  FAIL: sm_90 PTX missing `.func fp64_axpb`")
        ok = false
    }
    if !_contains(ptx90, ".reg .f64 %fd2;") {
        println("  FAIL: sm_90 PTX missing `.reg .f64 %fd2;` declaration")
        ok = false
    }
    if !_contains(ptx90, ".reg .f64 %fd3;") {
        println("  FAIL: sm_90 PTX missing `.reg .f64 %fd3;` declaration")
        ok = false
    }
    if !_contains(ptx90, "mul.f64 %fd2, %fd0, %fd1;") {
        println("  FAIL: sm_90 PTX missing `mul.f64` line")
        ok = false
    }
    if !_contains(ptx90, "add.f64 %fd3, %fd2, %fd0;") {
        println("  FAIL: sm_90 PTX missing `add.f64` line")
        ok = false
    }
    if !_contains(ptx90, "ret;") {
        println("  FAIL: sm_90 PTX missing `ret;`")
        ok = false
    }

    // ── sm_80 ────────────────────────────────────────────────
    let ptx80 = codegen_emit_ptx_sm80(m)
    if !_contains(ptx80, ".target sm_80") {
        println("  FAIL: sm_80 PTX missing `.target sm_80`")
        ok = false
    }

    println("")
    println("══════════════════════════════════════════════")
    if ok {
        println("PASS: RFC 055 055-P0 emit pass produced valid PTX text")
        println("      (FP64 arithmetic subset; ptxas NOT invoked — text-shape only).")
    } else {
        println("FAIL: RFC 055 055-P0 emit-pass contract not satisfied.")
    }
    println("══════════════════════════════════════════════")
    if !ok { exit(1) }
}
