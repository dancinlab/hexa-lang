// HEXA Native Compiler — Codegen / arm64-apple-darwin (Phase A1)
//
// @version 0.1.0
// @capabilities [pure]
//
// Lowers MIR (SSA CFG) -> LIR (target-specific instructions) for the
// arm64-apple-darwin target.
//
//   pub fn codegen_arm64_darwin(module: MModule) -> LModule
//
// ABI: AAPCS64
//   - Integer args: x0..x7 (overflow on stack — v1 ignored, tiny tests only)
//   - Integer return: x0
//   - Frame pointer: x29 (fp), Link register: x30 (lr)
//   - Stack pointer: 16-byte aligned at function boundaries
//
// Per MFunc layout:
//   prologue:
//       stp x29, x30, [sp, #-16]!
//       mov x29, sp
//   <block instrs>
//   epilogue:
//       ldp x29, x30, [sp], #16
//       ret
//
// v1 register policy:
//   Naive — Local id N -> register x(N % 31).  No spilling, no liveness.
//   Tier-0 tier verification only; tiny test cases fit in <31 locals.
//
// Constraints (from RFC-018 §4):
//   - struct >16B by reference (not handled v1)
//   - hidden first arg for >16B return (not handled v1)

import "../ir/mir.hexa"
import "../ir/lir.hexa"

// ── Local mirror of mir.hexa STMT_* constants ────────────────
// See note in compiler/lower/hir_to_mir.hexa: stage0's interpreter does
// not propagate transitive `pub let` bindings, so STMT_* arrive here as
// the void value. Redeclaring locally keeps codegen dispatch working.
let _STMT_ASSIGN   = "assign"
let _STMT_BINOP    = "binop"
let _STMT_UNOP     = "unop"
let _STMT_CALL     = "call"
let _STMT_RETURN   = "return"
let _STMT_BR       = "br"
let _STMT_BR_COND  = "br_cond"

// ── PReg / LOperand helpers ──────────────────────────────────

fn _preg_gpr(name: string) -> PReg {
    return PReg { name: name, kind: "gpr" }
}

fn _empty_preg() -> PReg {
    return PReg { name: "", kind: "" }
}

fn _op_reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: _preg_gpr(name),
        imm: 0,
        mem_base: _empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _op_imm(value: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: _empty_preg(),
        imm: value,
        mem_base: _empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _op_label(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: _empty_preg(),
        imm: 0,
        mem_base: _empty_preg(),
        mem_offset: 0,
        label: name
    }
}

fn _op_mem(base: string, offset: i64) -> LOperand {
    return LOperand {
        kind: "mem",
        reg: _empty_preg(),
        imm: 0,
        mem_base: _preg_gpr(base),
        mem_offset: offset,
        label: ""
    }
}

fn _instr0(op: string, comment: string) -> LInstr {
    return LInstr { op: op, args: [], comment: comment }
}

fn _instr1(op: string, a: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _instr2(op: string, a: LOperand, b: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _instr3(op: string, a: LOperand, b: LOperand, c: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    xs.push(c)
    return LInstr { op: op, args: xs, comment: comment }
}

// ── Register assignment (naive) ──────────────────────────────

fn _arm64_reg_for_local(local_id: i64) -> string {
    // x0..x7 already serve params per ABI; for simplicity Local id N maps
    // to xN (mod 31) — x31 is sp/zr so we cap at 30.
    let mut idx = local_id
    if idx < 0 { idx = 0 }
    let m = idx - (idx / 31) * 31
    return "x" + to_string(m)
}

// String literal → rodata label map. `keys[i]` is a literal string
// (the const_str payload); `labels[i]` is the assigned ".LCstrN"
// label (without the platform underscore prefix). Built once per
// module before func lowering and threaded into every operand
// resolution. `pub` is required because stage0 cannot resolve struct
// field types across imports without it.
pub struct ArmStrTab {
    keys: [string],
    labels: [string]
}

fn _arm64_strtab_lookup(st: ArmStrTab, s: string) -> string {
    let mut i = 0
    while i < len(st.keys) {
        if st.keys[i] == s { return st.labels[i] }
        i = i + 1
    }
    return ""
}

fn _arm64_op_for_operand_st(o: Operand, st: ArmStrTab) -> LOperand {
    if o.kind == "local" {
        return _op_reg(_arm64_reg_for_local(o.local_id))
    }
    if o.kind == "const_int" {
        return _op_imm(o.int_val)
    }
    if o.kind == "global" {
        return _op_label("g" + to_string(o.global_id))
    }
    if o.kind == "const_str" {
        let lbl = _arm64_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _op_label(lbl) }
        return _op_label(o.str_val)
    }
    // fallback: treat as imm 0
    return _op_imm(0)
}

// Backwards-compatible operand resolver — used where no strtab is
// available (e.g. trivial tests without string literals). Strings
// flow through unchanged (label = literal string), which only
// matters for modules that never produce a const_str operand.
fn _arm64_op_for_operand(o: Operand) -> LOperand {
    let st = ArmStrTab { keys: [], labels: [] }
    return _arm64_op_for_operand_st(o, st)
}

// ── Block label helper ───────────────────────────────────────
//
// Apple ARM64 uses `L<name>` as the conventional local-label form
// for compiler-generated labels within a function. We emit them with
// a leading `_` prefix so the asm-text emit pass leaves them alone
// (its `_fmt_label` skips labels that already begin with '.' or
// '_'). Without this, branch operand references would be re-prefixed
// to `__Lname` while the definition stays bare `Lname:`, breaking
// the branch.
fn _arm64_block_label(fname: string, block_id: i64) -> string {
    return "_L" + fname + "_bb" + to_string(block_id)
}

// ── Binop classification ─────────────────────────────────────
//
// Lower (compiler/lower/hir_to_mir.hexa) carries the source-level
// operator text in `Stmt.op` (e.g. "+", "-", "*", "==", "<"). The
// older codegen path also accepted normalized aliases ("add",
// "sub", ...). We accept both. String concat is recognised as a
// dedicated `concat` op (or `+` over string operands once typed-MIR
// lands — until then, lower must emit `concat` explicitly for
// string + string).

fn _is_arith_add(op: string) -> bool { return op == "add" || op == "+" }
fn _is_arith_sub(op: string) -> bool { return op == "sub" || op == "-" }
fn _is_arith_mul(op: string) -> bool { return op == "mul" || op == "*" }
fn _is_arith_div(op: string) -> bool { return op == "div" || op == "/" }
fn _is_bit_and(op: string) -> bool   { return op == "and" || op == "&" }
fn _is_bit_or(op: string) -> bool    { return op == "or"  || op == "|" }
fn _is_bit_xor(op: string) -> bool   { return op == "xor" || op == "^" }
fn _is_concat(op: string) -> bool    { return op == "concat" }

// arm64 cset condition mnemonic for a source comparison op.
// Returns "" if not a comparison.
fn _arm64_cmp_cond(op: string) -> string {
    if op == "cmp_eq" || op == "==" { return "eq" }
    if op == "cmp_ne" || op == "!=" { return "ne" }
    if op == "cmp_lt" || op == "<"  { return "lt" }
    if op == "cmp_le" || op == "<=" { return "le" }
    if op == "cmp_gt" || op == ">"  { return "gt" }
    if op == "cmp_ge" || op == ">=" { return "ge" }
    return ""
}

// AAPCS64 integer arg sequence.
fn _arm64_arg_reg(idx: i64) -> string {
    if idx == 0 { return "x0" }
    if idx == 1 { return "x1" }
    if idx == 2 { return "x2" }
    if idx == 3 { return "x3" }
    if idx == 4 { return "x4" }
    if idx == 5 { return "x5" }
    if idx == 6 { return "x6" }
    if idx == 7 { return "x7" }
    return "x0" // overflow → stack (TODO: spill)
}

// ── Statement lowering ───────────────────────────────────────

fn _emit_arm64_stmt(out: [LInstr], fname: string, s: Stmt, st: ArmStrTab) -> [LInstr] {
    let mut buf = out
    if s.kind == _STMT_ASSIGN {
        // mov dst, src (single operand expected)
        let dst = _op_reg(_arm64_reg_for_local(s.dst.id))
        if len(s.args) >= 1 {
            let src = _arm64_op_for_operand_st(s.args[0], st)
            buf.push(_instr2("mov", dst, src, "assign L" + to_string(s.dst.id)))
        }
        return buf
    }
    if s.kind == _STMT_BINOP {
        let dst = _op_reg(_arm64_reg_for_local(s.dst.id))
        if len(s.args) >= 2 {
            let a = _arm64_op_for_operand_st(s.args[0], st)
            let b = _arm64_op_for_operand_st(s.args[1], st)

            // String concat → runtime call. Move operands into x0/x1
            // (AAPCS64 first two arg regs) and `bl _hexa_str_concat`.
            // Result lands in x0 → mov into dst.
            if _is_concat(s.op) {
                buf.push(_instr2("mov", _op_reg("x0"), a, "concat arg0"))
                buf.push(_instr2("mov", _op_reg("x1"), b, "concat arg1"))
                buf.push(_instr1("bl", _op_label("hexa_str_concat"),
                                 "call runtime: hexa_str_concat"))
                buf.push(_instr2("mov", dst, _op_reg("x0"), "capture concat result"))
                return buf
            }

            // Comparison → cmp + cset (writes 0/1 into dst).
            let cond = _arm64_cmp_cond(s.op)
            if len(cond) > 0 {
                buf.push(_instr2("cmp", a, b, "binop " + s.op))
                buf.push(_instr2("cset", dst, _op_label(cond),
                                 "binop " + s.op + " → bool"))
                return buf
            }

            // Arithmetic / bitwise.
            let mut mnemonic = "add"
            if _is_arith_add(s.op) { mnemonic = "add" }
            if _is_arith_sub(s.op) { mnemonic = "sub" }
            if _is_arith_mul(s.op) { mnemonic = "mul" }
            if _is_arith_div(s.op) { mnemonic = "sdiv" }
            if s.op == "udiv"      { mnemonic = "udiv" }
            if _is_bit_and(s.op)   { mnemonic = "and" }
            if _is_bit_or(s.op)    { mnemonic = "orr" }
            if _is_bit_xor(s.op)   { mnemonic = "eor" }
            buf.push(_instr3(mnemonic, dst, a, b, "binop " + s.op))
        }
        return buf
    }
    if s.kind == _STMT_CALL {
        // Marshal args into x0..x7 (AAPCS64). Args 9th+ (index >= 8 // @allow-relop-banned
        // in 0-based count) spill to a caller-allocated stack frame
        // per RFC-018 §4 (AAPCS64 §6.4.2): each int/pointer overflow
        // arg occupies an 8-byte slot starting at [sp, #0] for the
        // 9th arg, [sp, #8] for the 10th, etc. Total adjustment is
        // 16-byte aligned (N = 16 * ceil(extra/2)) so sp stays
        // aligned across `bl`.
        //
        // x9 is a caller-saved scratch reg per AAPCS64, used as a
        // marshalling temp so `str` always sees a register source
        // regardless of operand kind (reg | imm | label).
        let n_args = len(s.args)
        let mut extra = n_args - 8
        if extra < 0 { extra = 0 }
        let mut spill_bytes = 0
        if extra > 0 {
            let pairs = (extra + 1) / 2
            spill_bytes = pairs * 16
        }
        if spill_bytes > 0 {
            buf.push(_instr3("sub", _op_reg("sp"), _op_reg("sp"),
                             _op_imm(spill_bytes),
                             "reserve stack for " + to_string(extra) +
                             " spilled args"))
        }
        let mut i = 0
        while i < len(s.args) {
            let src = _arm64_op_for_operand_st(s.args[i], st)
            if i < 8 {
                let dst_reg = _op_reg(_arm64_arg_reg(i))
                buf.push(_instr2("mov", dst_reg, src, "arg " + to_string(i)))
            } else {
                // Int/pointer overflow: mov x9, <src> ; str x9, [sp, #off].
                // Struct-by-value stack args (>16B) are not yet
                // supported — surface a TODO marker so the gap stays
                // greppable.
                if src.kind == "reg" || src.kind == "imm" {
                    let off = (i - 8) * 8
                    buf.push(_instr2("mov", _op_reg("x9"), src,
                                     "load arg " + to_string(i) +
                                     " into scratch"))
                    let slot_label = "[sp, #" + to_string(off) + "]"
                    buf.push(_instr2("str", _op_reg("x9"),
                                     _op_label(slot_label),
                                     "spill arg " + to_string(i) +
                                     " to stack slot"))
                } else {
                    buf.push(_instr0("nop",
                        "TODO: struct-by-value stack arg " +
                        to_string(i)))
                }
            }
            i = i + 1
        }
        let target = s.op // call target name carried in s.op
        buf.push(_instr1("bl", _op_label(target), "call " + target))
        if spill_bytes > 0 {
            buf.push(_instr3("add", _op_reg("sp"), _op_reg("sp"),
                             _op_imm(spill_bytes),
                             "release spilled-args frame"))
        }
        if s.dst.id >= 0 {
            let dst = _op_reg(_arm64_reg_for_local(s.dst.id))
            buf.push(_instr2("mov", dst, _op_reg("x0"), "capture call result"))
        }
        return buf
    }
    if s.kind == _STMT_RETURN {
        if len(s.args) >= 1 {
            let src = _arm64_op_for_operand_st(s.args[0], st)
            buf.push(_instr2("mov", _op_reg("x0"), src, "set return value"))
        }
        // epilogue: ldp x29, x30, [sp], #16  (post-index — symmetric with
        // the prologue's pre-index `stp x29, x30, [sp, #-16]!`)
        buf.push(_instr3("ldp", _op_reg("x29"), _op_reg("x30"),
                         _op_label("[sp], #16"), "epilogue: restore fp/lr"))
        buf.push(_instr0("ret", "return"))
        return buf
    }
    if s.kind == _STMT_BR {
        let lab = _arm64_block_label(fname, s.target_block)
        buf.push(_instr1("b", _op_label(lab), "branch"))
        return buf
    }
    if s.kind == _STMT_BR_COND {
        // cbz <reg>, .Lelse  ; b .Lthen
        // (compact encoding for "branch on zero / non-zero"; equivalent
        //  to the older `cmp x, #0; b.eq`. Both are accepted by `as`.)
        if len(s.args) >= 1 {
            let cond = _arm64_op_for_operand_st(s.args[0], st)
            let else_lab = _arm64_block_label(fname, s.target_block_else)
            buf.push(_instr2("cbz", cond, _op_label(else_lab),
                             "br_cond: zero -> else"))
        }
        let then_lab = _arm64_block_label(fname, s.target_block)
        buf.push(_instr1("b", _op_label(then_lab), "branch -> then"))
        return buf
    }
    if s.kind == "load" {
        // STMT_LOAD: dst <- [base + offset]. Until lower emits
        // explicit LOADs, this path is mostly dormant.
        let dst = _op_reg(_arm64_reg_for_local(s.dst.id))
        if len(s.args) >= 1 {
            let base_op = _arm64_op_for_operand_st(s.args[0], st)
            let mut off = 0
            if len(s.args) >= 2 && s.args[1].kind == "const_int" {
                off = s.args[1].int_val
            }
            buf.push(_instr2("ldr", dst, _op_mem(base_op.reg.name, off),
                             "load"))
        }
        return buf
    }
    if s.kind == "store" {
        // STMT_STORE: [base + offset] <- src. Mirrors load order.
        if len(s.args) >= 2 {
            let base_op = _arm64_op_for_operand_st(s.args[0], st)
            let src = _arm64_op_for_operand_st(s.args[1], st)
            let mut off = 0
            if len(s.args) >= 3 && s.args[2].kind == "const_int" {
                off = s.args[2].int_val
            }
            buf.push(_instr2("str", src, _op_mem(base_op.reg.name, off),
                             "store"))
        }
        return buf
    }
    // Unhandled (arena_*, etc.) — emit a comment-only nop for v1.
    buf.push(_instr0("nop", "unhandled stmt kind " + s.kind))
    return buf
}

// ── Function lowering ────────────────────────────────────────

fn _arm64_lower_func(mf: MFunc, st: ArmStrTab) -> LFunc {
    let mut instrs = []

    // Prologue
    // stp x29, x30, [sp, #-16]!  (pre-index — symmetric with the epilogue's
    // post-index `ldp x29, x30, [sp], #16`)
    instrs.push(_instr3(
        "stp",
        _op_reg("x29"),
        _op_reg("x30"),
        _op_label("[sp, #-16]!"),
        "prologue: save fp/lr"
    ))
    instrs.push(_instr2("mov", _op_reg("x29"), _op_reg("sp"), "prologue: set fp"))

    // Move incoming params x0..x7 into their assigned local registers (if
    // different). v1 naive: param i has Local id i so x_i -> x_i is a no-op,
    // but emit explicit mov to make trace inspection clear.
    let mut p = 0
    while p < len(mf.params) {
        if p < 8 {
            let dst_name = _arm64_reg_for_local(mf.params[p].id)
            let src_name = "x" + to_string(p)
            if dst_name != src_name {
                instrs.push(_instr2("mov", _op_reg(dst_name), _op_reg(src_name), "ingress param"))
            }
        }
        p = p + 1
    }

    // Lower blocks in order. Emit per-block label as a comment-only marker
    // (no LInstr.op label representation in v1).
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        instrs.push(_instr0("label", _arm64_block_label(mf.name, blk.id)))
        let mut si = 0
        while si < len(blk.stmts) {
            instrs = _emit_arm64_stmt(instrs, mf.name, blk.stmts[si], st)
            si = si + 1
        }
        bi = bi + 1
    }

    // Safety epilogue (in case last block lacks _STMT_RETURN)
    let last_is_ret = false
    if len(instrs) > 0 {
        let last = instrs[len(instrs) - 1]
        if last.op == "ret" {
            // already terminated
            return LFunc {
                name: mf.name,
                target: "arm64-apple-darwin",
                instrs: instrs,
                frame_size: 16,
                callee_saved: []
            }
        }
    }
    instrs.push(_instr3("ldp", _op_reg("x29"), _op_reg("x30"),
                        _op_label("[sp], #16"), "epilogue: restore fp/lr"))
    instrs.push(_instr0("ret", "return"))

    return LFunc {
        name: mf.name,
        target: "arm64-apple-darwin",
        instrs: instrs,
        frame_size: 16,
        callee_saved: []
    }
}

// ── String table collection (for rodata emission) ────────────
//
// Walk every Stmt in every Block in every Func looking for
// `const_str` operands and record them in an ArmStrTab. Each unique
// literal gets label ".LCstr<N>" (N = insertion order). Both targets
// share this label scheme so rodata labels remain stable per source
// independently of the chosen target.

fn _collect_strs_from_stmt(st: ArmStrTab, s: Stmt) -> ArmStrTab {
    let mut out = st
    let mut i = 0
    while i < len(s.args) {
        let o = s.args[i]
        if o.kind == "const_str" {
            if len(_arm64_strtab_lookup(out, o.str_val)) == 0 {
                let mut keys = out.keys
                let mut labs = out.labels
                let n = len(keys)
                keys.push(o.str_val)
                labs.push(".LCstr" + to_string(n))
                out = ArmStrTab { keys: keys, labels: labs }
            }
        }
        i = i + 1
    }
    return out
}

fn _build_arm_strtab(module: MModule) -> ArmStrTab {
    let mut st = ArmStrTab { keys: [], labels: [] }
    let mut fi = 0
    while fi < len(module.funcs) {
        let f = module.funcs[fi]
        let mut bi = 0
        while bi < len(f.blocks) {
            let blk = f.blocks[bi]
            let mut si = 0
            while si < len(blk.stmts) {
                st = _collect_strs_from_stmt(st, blk.stmts[si])
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return st
}

// Convert a string into a hex-encoded byte sequence (per-LSection
// payload format defined by lir.hexa). Appends a NUL terminator so
// the rodata entry is C-string compatible.
fn _hex_nibble(n: i64) -> string {
    if n == 0  { return "0" }
    if n == 1  { return "1" }
    if n == 2  { return "2" }
    if n == 3  { return "3" }
    if n == 4  { return "4" }
    if n == 5  { return "5" }
    if n == 6  { return "6" }
    if n == 7  { return "7" }
    if n == 8  { return "8" }
    if n == 9  { return "9" }
    if n == 10 { return "a" }
    if n == 11 { return "b" }
    if n == 12 { return "c" }
    if n == 13 { return "d" }
    if n == 14 { return "e" }
    return "f"
}

fn _byte_to_hex(b: i64) -> string {
    let hi = b / 16
    let lo = b - hi * 16
    return _hex_nibble(hi) + _hex_nibble(lo)
}

// Manual ASCII codepoint lookup. Stage0 hexa has no `ord`/codepoint
// primitive surfaced to user code, so we hard-code the printable
// range that real-world tests touch.
fn _ascii_code(ch: string) -> i64 {
    if ch == " " { return 32 }
    if ch == "!" { return 33 }
    if ch == "\"" { return 34 }
    if ch == "#" { return 35 }
    if ch == "$" { return 36 }
    if ch == "%" { return 37 }
    if ch == "&" { return 38 }
    if ch == "'" { return 39 }
    if ch == "(" { return 40 }
    if ch == ")" { return 41 }
    if ch == "*" { return 42 }
    if ch == "+" { return 43 }
    if ch == "," { return 44 }
    if ch == "-" { return 45 }
    if ch == "." { return 46 }
    if ch == "/" { return 47 }
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == ":" { return 58 }
    if ch == ";" { return 59 }
    if ch == "<" { return 60 }
    if ch == "=" { return 61 }
    if ch == ">" { return 62 }
    if ch == "?" { return 63 }
    if ch == "@" { return 64 }
    if ch == "A" { return 65 }
    if ch == "B" { return 66 }
    if ch == "C" { return 67 }
    if ch == "D" { return 68 }
    if ch == "E" { return 69 }
    if ch == "F" { return 70 }
    if ch == "G" { return 71 }
    if ch == "H" { return 72 }
    if ch == "I" { return 73 }
    if ch == "J" { return 74 }
    if ch == "K" { return 75 }
    if ch == "L" { return 76 }
    if ch == "M" { return 77 }
    if ch == "N" { return 78 }
    if ch == "O" { return 79 }
    if ch == "P" { return 80 }
    if ch == "Q" { return 81 }
    if ch == "R" { return 82 }
    if ch == "S" { return 83 }
    if ch == "T" { return 84 }
    if ch == "U" { return 85 }
    if ch == "V" { return 86 }
    if ch == "W" { return 87 }
    if ch == "X" { return 88 }
    if ch == "Y" { return 89 }
    if ch == "Z" { return 90 }
    if ch == "[" { return 91 }
    if ch == "\\" { return 92 }
    if ch == "]" { return 93 }
    if ch == "^" { return 94 }
    if ch == "_" { return 95 }
    if ch == "`" { return 96 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    if ch == "g" { return 103 }
    if ch == "h" { return 104 }
    if ch == "i" { return 105 }
    if ch == "j" { return 106 }
    if ch == "k" { return 107 }
    if ch == "l" { return 108 }
    if ch == "m" { return 109 }
    if ch == "n" { return 110 }
    if ch == "o" { return 111 }
    if ch == "p" { return 112 }
    if ch == "q" { return 113 }
    if ch == "r" { return 114 }
    if ch == "s" { return 115 }
    if ch == "t" { return 116 }
    if ch == "u" { return 117 }
    if ch == "v" { return 118 }
    if ch == "w" { return 119 }
    if ch == "x" { return 120 }
    if ch == "y" { return 121 }
    if ch == "z" { return 122 }
    if ch == "{" { return 123 }
    if ch == "|" { return 124 }
    if ch == "}" { return 125 }
    if ch == "~" { return 126 }
    if ch == "\n" { return 10 }
    if ch == "\t" { return 9 }
    return 63 // '?' for unknown (non-ASCII / control)
}

fn _str_to_hex_bytes(s: string) -> string {
    let cs = s.chars()
    let mut out = ""
    let mut i = 0
    while i < len(cs) {
        out = out + _byte_to_hex(_ascii_code(cs[i]))
        i = i + 1
    }
    out = out + "00" // NUL terminator
    return out
}

fn _strtab_to_rodata(st: ArmStrTab) -> [LSection] {
    let mut out: [LSection] = []
    let mut i = 0
    while i < len(st.keys) {
        out.push(LSection {
            name: st.labels[i],
            bytes: _str_to_hex_bytes(st.keys[i]),
            align: 0
        })
        i = i + 1
    }
    return out
}

// ── Module entry point ───────────────────────────────────────

pub fn codegen_arm64_darwin(module: MModule) -> LModule {
    let st = _build_arm_strtab(module)
    let mut funcs = []
    let mut i = 0
    while i < len(module.funcs) {
        funcs.push(_arm64_lower_func(module.funcs[i], st))
        i = i + 1
    }
    return LModule {
        file: module.file,
        target: "arm64-apple-darwin",
        funcs: funcs,
        rodata: _strtab_to_rodata(st),
        bss: []
    }
}
