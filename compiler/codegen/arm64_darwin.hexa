// HEXA Native Compiler — Codegen / arm64-apple-darwin (Phase A1)
//
// @version 0.1.0
// @capabilities [pure]
// @allow-relop-banned-file  — codegen path uses `>=`/`<=` for arity
//   guards and signed-id checks; C6 regalloc inherits the same need.
//
// Lowers MIR (SSA CFG) -> LIR (target-specific instructions) for the
// arm64-apple-darwin target.
//
//   pub fn codegen_arm64_darwin(module: MModule) -> LModule
//
// ABI: AAPCS64
//   - Integer args: x0..x7 (overflow on stack — v1 ignored, tiny tests only)
//   - Integer return: x0
//   - Frame pointer: x29 (fp), Link register: x30 (lr)
//   - Stack pointer: 16-byte aligned at function boundaries
//
// Per MFunc layout:
//   prologue:
//       stp x29, x30, [sp, #-16]!
//       mov x29, sp
//   <block instrs>
//   epilogue:
//       ldp x29, x30, [sp], #16
//       ret
//
// v1 register policy:
//   Naive — Local id N -> register x(N % 31).  No spilling, no liveness.
//   Tier-0 tier verification only; tiny test cases fit in <31 locals.
//
// Constraints (from RFC-018 §4):
//   - struct >16B by reference (not handled v1)
//   - hidden first arg for >16B return (not handled v1)
//
// ── RFC 070 G7-A.native scaffold (2026-05-20, comment-only marker) ──
//
// G7-A.flag-wire (C path · landed `66b055c4`) wires `hexa build --shared`
// through to `clang -fPIC -shared`. The native backend below currently
// REFUSES `HEXA_BACKEND=native` + `--shared` at `self/main.hexa::cmd_build`
// L1973-1978 — this scaffold block documents the delta we owe the
// native side before the gate can drop.
//
// Current arm64-darwin addressing baseline (PIE-equivalent, NOT PIC-`.dylib`):
//   - Local symbol/cstring loads: `adrp Xn, sym@PAGE` + `add Xn, Xn, sym@PAGEOFF`
//     (see L1042, L1057, L1067, L1099, L1117, L1377, L1441). PC-relative
//     within ±4 GiB. Mach-O MH_PIE for the executable-shape output.
//   - Extern fn references: today resolved at static-link time via the
//     plt-less path; no GOT indirection emitted.
//
// G7-A.native impl delta (the next sub-cycle):
//   1. Honor `bopts[4]=="1"` (the `shared` flag wired in G7-A.flag-wire)
//      inside `codegen_arm64_darwin` entry — branch addressing-mode
//      selection on it. Plumb `shared: string` through the codegen
//      module-level options struct (currently absent; add one).
//   2. Extern fn refs in shared mode go through the GOT:
//        adrp Xn, sym@GOTPAGE
//        ldr  Xn, [Xn, sym@GOTPAGEOFF]
//      Reloc kinds = `ARM64_RELOC_GOT_LOAD_PAGE21` + `ARM64_RELOC_GOT_LOAD_PAGEOFF12`.
//      Local fn refs stay on `@PAGE/@PAGEOFF` (no change).
//   3. Hidden-visibility default: emit `.private_extern <sym>` directive
//      for every defined fn EXCEPT `<plugin_id>_dispatch`, which alone
//      gets `.globl`. Mach-O export trie then carries exactly 1 entry.
//
// Falsifier hooks for G7-A.native impl (real-limit anchored per `@D g3`):
//   - F-A1: `<plugin_id>_dispatch` symbol address is page-aligned (real-limit
//     = arm64 Darwin 16 KiB page granularity) AFTER `dlopen` at a
//     non-default base — verifies PC-relative emission, not luck.
//   - F-A2: `nm <plugin>.dylib | awk '$2 == "T" || $2 == "D"'` lists
//     exactly 1 symbol matching `<plugin_id>_dispatch`. All others are
//     local (`t`/`d`). Anchor = Mach-O export trie format (`<mach-o/loader.h>`).
//
// Scope marker: THIS commit is scaffold-only (zero behavior change). The
// `codegen_arm64_darwin` body is untouched. See RFC 070 §4.4 for the
// honest scope and `compiler/PLAN.md` for the cycle entry.

import "../ir/mir.hexa"
import "../ir/lir.hexa"

// ── Local mirror of mir.hexa STMT_* constants ────────────────
// See note in compiler/lower/hir_to_mir.hexa: stage0's interpreter does
// not propagate transitive `pub let` bindings, so STMT_* arrive here as
// the void value. Redeclaring locally keeps codegen dispatch working.
let _STMT_ASSIGN   = "assign"
let _STMT_BINOP    = "binop"
let _STMT_UNOP     = "unop"
let _STMT_CALL     = "call"
// RFC closure C3 — local mirror of mir.hexa STMT_CALL_INDIRECT.
let _STMT_CALL_INDIRECT = "call_indirect"
let _STMT_RETURN   = "return"
let _STMT_BR       = "br"
let _STMT_BR_COND  = "br_cond"

// ── PReg / LOperand helpers ──────────────────────────────────

fn _arm64_preg_gpr(name: string) -> PReg {
    return PReg { name: name, kind: "gpr", frag_role: "", frag_dtype: "", frag_layout: "" }
}

fn _arm64_empty_preg() -> PReg {
    return PReg { name: "", kind: "", frag_role: "", frag_dtype: "", frag_layout: "" }
}

fn _arm64_op_reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: _arm64_preg_gpr(name),
        imm: 0,
        mem_base: _arm64_empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _arm64_op_imm(value: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: _arm64_empty_preg(),
        imm: value,
        mem_base: _arm64_empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _arm64_op_label(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: _arm64_empty_preg(),
        imm: 0,
        mem_base: _arm64_empty_preg(),
        mem_offset: 0,
        label: name
    }
}

fn _arm64_op_mem(base: string, offset: i64) -> LOperand {
    return LOperand {
        kind: "mem",
        reg: _arm64_empty_preg(),
        imm: 0,
        mem_base: _arm64_preg_gpr(base),
        mem_offset: offset,
        label: ""
    }
}

fn _arm64_instr0(op: string, comment: string) -> LInstr {
    return LInstr { op: op, args: [], comment: comment }
}

fn _arm64_instr1(op: string, a: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _arm64_instr2(op: string, a: LOperand, b: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _arm64_instr3(op: string, a: LOperand, b: LOperand, c: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    xs.push(c)
    return LInstr { op: op, args: xs, comment: comment }
}

// ── Register assignment (naive fallback) ─────────────────────
//
// Used only when no RegMap is available. Production codegen runs
// through `_arm64_assign_regs` (linear scan, Poletto-Sarkar 1999)
// and `_arm_reg_lookup` below.

fn _arm64_reg_for_local(local_id: i64) -> string {
    let mut idx = local_id
    if idx < 0 { idx = 0 }
    let m = idx - (idx / 31) * 31
    return "x" + to_string(m)
}

// ── C6 — Linear-scan register allocator (arm64) ──────────────
pub struct RegMap {
    ids: [i64],
    regs: [string],
    slots: [i64],
    // C7 — per-fn outgoing-call overflow region (bytes, 16-aligned),
    // pre-allocated at prologue bottom. _arm_spill_offset shifts every
    // SSA spill access above this region so per-call stack-spill stores
    // can use [sp, #(i-8)*8] without disturbing SSA offsets.
    call_overflow_bytes: i64
}

pub struct ArmAllocResult {
    map: RegMap,
    frame_size: i64
}

pub struct ArmIntervals {
    ids: [i64],
    starts: [i64],
    ends: [i64]
}

fn _arm_pool_init() -> [string] {
    let mut p: [string] = []
    p.push("x10")
    p.push("x11")
    p.push("x12")
    p.push("x13")
    p.push("x14")
    p.push("x15")
    p.push("x19")
    p.push("x20")
    p.push("x21")
    p.push("x22")
    p.push("x23")
    p.push("x24")
    p.push("x25")
    p.push("x26")
    p.push("x27")
    p.push("x28")
    return p
}

fn _arm_index_of(ids: [i64], id: i64) -> i64 {
    // O(1) fast path: SSA ids are dense (next_local-allocated) and the
    // id-arrays here (ids / iv.ids / rm.ids) are built in id order, so
    // ids[id] == id is the common case. ids is dedup-built (each id
    // appears once) so when ids[id]==id, `id` is THE unique index —
    // sound. Falls back to the linear scan otherwise. Without this the
    // per-operand lookups in _arm_reg_lookup/_arm_is_spilled/
    // _arm_spill_offset + the live-range/regalloc loops are O(N²) on a
    // huge function (the synthetic `fn main`) — minutes-long stage-1.
    if id >= 0 && id < len(ids) {
        if ids[id] == id { return id }
    }
    let mut i = 0
    while i < len(ids) {
        if ids[i] == id { return i }
        i = i + 1
    }
    return -1
}

fn _arm_compute_live_ranges(mf: MFunc) -> ArmIntervals {
    let mut ids: [i64] = []
    let mut starts: [i64] = []
    let mut ends: [i64] = []

    let mut li = 0
    while li < len(mf.locals) {
        let id = mf.locals[li].id
        if id >= 0 && _arm_index_of(ids, id) < 0 {
            ids.push(id)
            starts.push(-1)
            ends.push(-1)
        }
        li = li + 1
    }

    let mut pi = 0
    while pi < len(mf.params) {
        let pid = mf.params[pi].id
        let idx = _arm_index_of(ids, pid)
        if idx >= 0 {
            if starts[idx] < 0 { starts[idx] = 0 }
            if ends[idx] < 0   { ends[idx] = 0 }
        }
        pi = pi + 1
    }

    let mut pos = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            let s = blk.stmts[si]
            let did = s.dst.id
            if did >= 0 {
                let mut idx = _arm_index_of(ids, did)
                if idx < 0 {
                    ids.push(did)
                    starts.push(pos)
                    ends.push(pos)
                    idx = len(ids) - 1
                } else {
                    if starts[idx] < 0 || pos < starts[idx] { starts[idx] = pos }
                    if pos > ends[idx] { ends[idx] = pos }
                }
            }
            let mut ai = 0
            while ai < len(s.args) {
                let o = s.args[ai]
                if o.kind == "local" {
                    let lid = o.local_id
                    if lid >= 0 {
                        let mut idx2 = _arm_index_of(ids, lid)
                        if idx2 < 0 {
                            ids.push(lid)
                            starts.push(pos)
                            ends.push(pos)
                            idx2 = len(ids) - 1
                        } else {
                            if starts[idx2] < 0 || pos < starts[idx2] {
                                starts[idx2] = pos
                            }
                            if pos > ends[idx2] { ends[idx2] = pos }
                        }
                    }
                }
                ai = ai + 1
            }
            pos = pos + 1
            si = si + 1
        }
        bi = bi + 1
    }
    return ArmIntervals { ids: ids, starts: starts, ends: ends }
}

fn _arm64_assign_regs(mf: MFunc) -> ArmAllocResult {
    let iv = _arm_compute_live_ranges(mf)
    let n = len(iv.ids)
    let mut order: [i64] = []
    let mut k = 0
    while k < n {
        if iv.starts[k] >= 0 { order.push(k) }
        k = k + 1
    }
    // Self-host perf — sort `order` ascending by `iv.starts`. The prior
    // insertion sort was O(order²); on a large function (e.g. the 1209-
    // line _lower_hexpr in the compiler's own lower pass) order grows to
    // thousands of intervals, so O(N²) here is the dominant cost of a
    // multi-minute stage-1 self-compile. `iv.starts` values are `pos`
    // indices — dense, non-negative, bounded by the instruction count —
    // so a counting sort is O(N + maxStart) and STABLE (preserves the
    // first-seen order of equal-start intervals, identical to the strict-
    // `>` insertion sort it replaces). [@cite alg/sort/counting-sort]
    let mut max_start = 0
    let mut ms = 0
    while ms < len(order) {
        let sv = iv.starts[order[ms]]
        if sv > max_start { max_start = sv }
        ms = ms + 1
    }
    let mut cnt: [i64] = []
    let mut ci = 0
    while ci <= max_start {
        cnt.push(0)
        ci = ci + 1
    }
    let mut cp = 0
    while cp < len(order) {
        let sv2 = iv.starts[order[cp]]
        cnt[sv2] = cnt[sv2] + 1
        cp = cp + 1
    }
    // prefix sum → bucket start offsets
    let mut acc = 0
    let mut cp2 = 0
    while cp2 <= max_start {
        let c = cnt[cp2]
        cnt[cp2] = acc
        acc = acc + c
        cp2 = cp2 + 1
    }
    let mut sorted: [i64] = []
    let mut sp = 0
    while sp < len(order) {
        sorted.push(0)
        sp = sp + 1
    }
    let mut cp3 = 0
    while cp3 < len(order) {
        let elem = order[cp3]
        let sv3 = iv.starts[elem]
        sorted[cnt[sv3]] = elem
        cnt[sv3] = cnt[sv3] + 1
        cp3 = cp3 + 1
    }
    order = sorted

    let mut map_ids: [i64] = []
    let mut map_regs: [string] = []
    let mut map_slots: [i64] = []
    let mut j = 0
    while j < n {
        map_ids.push(iv.ids[j])
        map_regs.push("")
        map_slots.push(-1)
        j = j + 1
    }

    let mut p = 0
    while p < len(mf.params) {
        if p < 8 {
            let pid = mf.params[p].id
            let idx = _arm_index_of(iv.ids, pid)
            if idx >= 0 {
                map_regs[idx] = "x" + to_string(p)
            }
        }
        p = p + 1
    }

    let mut pool = _arm_pool_init()
    let mut active_idx: [i64] = []
    let mut next_slot: i64 = 0

    // Self-host perf — precompute `is_param[k]` (k = interval index)
    // once. The expire/spill loops below test "is this interval a
    // param" per active interval per `order` step; the inline
    // `while pp < len(mf.params)` scan made that O(order·active·P).
    // One O(N + params) pre-pass collapses it to an O(1) array read.
    // [@cite alg/regalloc/linear-scan]
    let mut is_param: [i64] = []
    let mut ip = 0
    while ip < n {
        is_param.push(0)
        ip = ip + 1
    }
    let mut ipp = 0
    while ipp < len(mf.params) {
        let pidx = _arm_index_of(iv.ids, mf.params[ipp].id)
        if pidx >= 0 { is_param[pidx] = 1 }
        ipp = ipp + 1
    }

    let mut s = 0
    while s < len(order) {
        let cur = order[s]
        let cur_start = iv.starts[cur]

        let mut keep: [i64] = []
        let mut e = 0
        while e < len(active_idx) {
            let ai = active_idx[e]
            if iv.ends[ai] < cur_start {
                let was = map_regs[ai]
                if is_param[ai] == 0 && len(was) > 0 && map_slots[ai] < 0 {
                    pool.push(was)
                }
            } else {
                keep.push(ai)
            }
            e = e + 1
        }
        active_idx = keep

        if len(map_regs[cur]) > 0 {
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
            s = s + 1
            continue
        }

        if len(pool) > 0 {
            let r = pool[0]
            let mut np: [string] = []
            let mut tt = 1
            while tt < len(pool) {
                np.push(pool[tt])
                tt = tt + 1
            }
            pool = np
            map_regs[cur] = r
            map_slots[cur] = -1
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
        } else {
            let mut victim_pos = len(active_idx) - 1
            while victim_pos >= 0 {
                let v = active_idx[victim_pos]
                if is_param[v] == 0 { break }
                victim_pos = victim_pos - 1
            }

            if victim_pos >= 0 && iv.ends[active_idx[victim_pos]] > iv.ends[cur] {
                let v = active_idx[victim_pos]
                map_regs[cur] = map_regs[v]
                map_slots[cur] = -1
                map_regs[v] = ""
                map_slots[v] = next_slot
                // HexaVal is a 16-byte (tag+union) pair stored via
                // stp/ldp — a spill slot MUST be 16B. The victim-spill
                // path advanced next_slot by only 8, so every slot
                // allocated after a victim-spill overlapped the high
                // 8 bytes of its predecessor. With enough spills the
                // offsets wrapped and aliased low-frame slots: a 24-
                // element [Node] array literal stored element 7+ into
                // slots that collided with early temps, so NODES[7..]
                // read garbage (TAG_MAP with junk map_ptr) → SIGSEGV
                // in hexa_map_get. Matches the +16 used at the other
                // two slot-allocation sites (lines ~448, ~468).
                next_slot = next_slot + 16
                let mut na: [i64] = []
                let mut t = 0
                while t < len(active_idx) {
                    if t != victim_pos { na.push(active_idx[t]) }
                    t = t + 1
                }
                let cur_end = iv.ends[cur]
                let mut na2: [i64] = []
                let mut placed = false
                let mut tt = 0
                while tt < len(na) {
                    if !placed && iv.ends[na[tt]] > cur_end {
                        na2.push(cur)
                        placed = true
                    }
                    na2.push(na[tt])
                    tt = tt + 1
                }
                if !placed { na2.push(cur) }
                active_idx = na2
            } else {
                map_regs[cur] = ""
                map_slots[cur] = next_slot
                next_slot = next_slot + 16  // Path A S1: HexaVal is 16B (tag+union); spill slots are HexaVal-sized. Single-reg str/ldr into the low 8B is harmless until S2 pair-stores the high half.
            }
        }
        s = s + 1
    }

    let mut frame = next_slot
    let rem = frame - (frame / 16) * 16
    if rem != 0 { frame = frame + (16 - rem) }

    // Path A (A′): HexaVal is a 16-byte struct (x0:x1 AAPCS64 pair) —
    // a single register cannot hold one. Force EVERY value memory-
    // resident in a 16B slot (no register residency); the emitter
    // ldp/stp's the pair around each use. This mirrors the proven
    // codegen_c2 memory-resident value model and avoids a pair-aware
    // register allocator. Slower but ABI-correct (optimise post-stage-3).
    let mut fi = 0
    while fi < len(map_ids) {
        if map_slots[fi] < 0 {
            map_slots[fi] = next_slot
            next_slot = next_slot + 16
        }
        map_regs[fi] = ""
        fi = fi + 1
    }
    let mut frame2 = next_slot
    let rem2 = frame2 - (frame2 / 16) * 16
    if rem2 != 0 { frame2 = frame2 + (16 - rem2) }
    frame = frame2

    let map = RegMap {
        ids: map_ids,
        regs: map_regs,
        slots: map_slots,
        call_overflow_bytes: 0   // filled in by _arm64_lower_func once max-overflow is known
    }
    return ArmAllocResult { map: map, frame_size: frame }
}

fn _arm_reg_lookup(rm: RegMap, id: i64) -> string {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return _arm64_reg_for_local(id) }
    if rm.slots[idx] >= 0 { return "x9" }
    if len(rm.regs[idx]) == 0 { return _arm64_reg_for_local(id) }
    return rm.regs[idx]
}

fn _arm_is_spilled(rm: RegMap, id: i64) -> bool {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return false }
    return rm.slots[idx] >= 0
}

fn _arm_spill_offset(rm: RegMap, id: i64) -> i64 {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return rm.call_overflow_bytes }
    return rm.slots[idx] + rm.call_overflow_bytes
}

// String literal → rodata label map. `keys[i]` is a literal string
// (the const_str payload); `labels[i]` is the assigned ".LCstrN"
// label (without the platform underscore prefix). Built once per
// module before func lowering and threaded into every operand
// resolution. `pub` is required because stage0 cannot resolve struct
// field types across imports without it.
pub struct ArmStrTab {
    keys: [string],
    labels: [string],
    // Parallel float-literal pool (const_float Operand → `.LCfltN`).
    // `fkeys` is the parsed f64 (used for de-dup); `flabels` is the
    // emitted `.LCfltN` symbol; `ftexts` is the literal's source
    // text ("0.15415067982725836"). Emit goes through the assembler's
    // `.double <text>` so we sidestep the stage0 lack of a double→
    // bits bitcast AND preserve full literal precision (stage0
    // `to_string(f64)` truncates to ~6 digits — losing ~3e-7 against
    // 17-digit reference literals — so we can't round-trip the
    // parsed f64 back through `to_string`).
    fkeys: [f64],
    flabels: [string],
    ftexts: [string]
}

fn _arm64_float_lookup(st: ArmStrTab, v: f64) -> string {
    let mut i = 0
    while i < len(st.fkeys) {
        if st.fkeys[i] == v {
            let lab = st.flabels[i]
            return lab.substring(0, len(lab))
        }
        i = i + 1
    }
    return ""
}

fn _arm64_float_intern(st: ArmStrTab, v: f64, text: string) -> ArmStrTab {
    let existing = _arm64_float_lookup(st, v)
    if len(existing) > 0 { return st }
    let mut fk = st.fkeys
    let mut fl = st.flabels
    let mut ft = st.ftexts
    let label = ".LCflt" + to_string(len(fk))
    fk.push(v)
    fl.push(label)
    // Empty text falls back to `to_string(v)` at LModule build time.
    ft.push(text.substring(0, len(text)))
    return ArmStrTab {
        keys: st.keys, labels: st.labels,
        fkeys: fk, flabels: fl, ftexts: ft
    }
}


fn _arm64_strtab_lookup(st: ArmStrTab, s: string) -> string {
    let mut i = 0
    while i < len(st.keys) {
        if st.keys[i] == s {
            // F6 P0b — forced copy: the LFunc operand built from this
            // label must not share st.labels' handle, or freeing the
            // LFunc would dangle st (st outlives every streaming
            // iteration). PLAN-stage3-footprint-F6.md.
            let lab = st.labels[i]
            return lab.substring(0, len(lab))
        }
        i = i + 1
    }
    return ""
}

fn _arm64_op_for_operand_st(o: Operand, st: ArmStrTab) -> LOperand {
    if o.kind == "local" {
        return _arm64_op_reg(_arm64_reg_for_local(o.local_id))
    }
    if o.kind == "const_int" {
        return _arm64_op_imm(o.int_val)
    }
    if o.kind == "const_bool" {
        return _arm64_op_imm(o.int_val)
    }
    if o.kind == "global" {
        return _arm64_op_label("g" + to_string(o.global_id))
    }
    if o.kind == "const_str" {
        // lbl is already a fresh copy (F6 P0b in _arm64_strtab_lookup).
        let lbl = _arm64_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _arm64_op_label(lbl) }
        // F6 P0d — strtab-miss fallback (should be unreachable, every
        // const_str is interned first): copy so the LFunc does not share
        // the MFunc operand's string. PLAN-stage3-footprint-F6.md.
        return _arm64_op_label(o.str_val.substring(0, len(o.str_val)))
    }
    // fallback: treat as imm 0
    return _arm64_op_imm(0)
}

// Backwards-compatible operand resolver — used where no strtab is
// available (e.g. trivial tests without string literals). Strings
// flow through unchanged (label = literal string), which only
// matters for modules that never produce a const_str operand.
fn _arm64_op_for_operand(o: Operand) -> LOperand {
    let st = ArmStrTab { keys: [], labels: [], fkeys: [], flabels: [], ftexts: [] }
    return _arm64_op_for_operand_st(o, st)
}

// ── Block label helper ───────────────────────────────────────
//
// Apple ARM64 uses `L<name>` as the conventional local-label form
// for compiler-generated labels within a function. We emit them with
// a leading `_` prefix so the asm-text emit pass leaves them alone
// (its `_fmt_label` skips labels that already begin with '.' or
// '_'). Without this, branch operand references would be re-prefixed
// to `__Lname` while the definition stays bare `Lname:`, breaking
// the branch.
// Stage1 C8 — modhash = first 4 hex of sha256(module.file).
// Disambiguates spliced modules sharing the same fn name.
fn _arm64_modhash(file: string) -> string {
    let h = sha256(file)
    if len(h) > 3 { return h.substring(0, 4) }
    return h
}

fn _arm64_block_label(modhash: string, fname: string, block_id: i64) -> string {
    return "_L" + modhash + "_" + fname + "_bb" + to_string(block_id)
}

// ── Binop classification ─────────────────────────────────────
//
// Lower (compiler/lower/hir_to_mir.hexa) carries the source-level
// operator text in `Stmt.op` (e.g. "+", "-", "*", "==", "<"). The
// older codegen path also accepted normalized aliases ("add",
// "sub", ...). We accept both. String concat is recognised as a
// dedicated `concat` op (or `+` over string operands once typed-MIR
// lands — until then, lower must emit `concat` explicitly for
// string + string).

fn _is_arith_add(op: string) -> bool { return op == "add" || op == "+" }
fn _is_arith_sub(op: string) -> bool { return op == "sub" || op == "-" }
fn _is_arith_mul(op: string) -> bool { return op == "mul" || op == "*" }
fn _is_arith_div(op: string) -> bool { return op == "div" || op == "/" }
fn _is_bit_and(op: string) -> bool   { return op == "and" || op == "&" }
fn _is_bit_or(op: string) -> bool    { return op == "or"  || op == "|" }
fn _is_bit_xor(op: string) -> bool   { return op == "xor" || op == "^" }
fn _is_concat(op: string) -> bool    { return op == "concat" }

// arm64 cset condition mnemonic for a source comparison op.
// Returns "" if not a comparison.
fn _arm64_cmp_cond(op: string) -> string {
    if op == "cmp_eq" || op == "==" { return "eq" }
    if op == "cmp_ne" || op == "!=" { return "ne" }
    if op == "cmp_lt" || op == "<"  { return "lt" }
    if op == "cmp_le" || op == "<=" { return "le" }
    if op == "cmp_gt" || op == ">"  { return "gt" }
    if op == "cmp_ge" || op == ">=" { return "ge" }
    return ""
}

// AAPCS64 integer arg sequence.
fn _arm64_arg_reg(idx: i64) -> string {
    if idx == 0 { return "x0" }
    if idx == 1 { return "x1" }
    if idx == 2 { return "x2" }
    if idx == 3 { return "x3" }
    if idx == 4 { return "x4" }
    if idx == 5 { return "x5" }
    if idx == 6 { return "x6" }
    if idx == 7 { return "x7" }
    return "x0" // overflow handled at call site via stack-spill (C7)
}

// C7 — scan all _STMT_CALL stmts in `mf` and return the maximum number
// of overflow args (args 5+) across all calls. The per-fn outgoing-call
// overflow region is sized once from this maximum and reused at every
// call site, so we don't sub/add sp mid-frame (which would invalidate
// sp-relative SSA spill offsets). NOTE: HexaVal arg ABI uses a register
// PAIR per arg (16B), so only 4 HexaVal args fit in x0..x7 — args 5+
// overflow to the caller's stack region (this matches the call-site
// emit at "C7: stack arg N"). Previously this used the C-int `n > 8`
// boundary and so missed every 5-args-or-more fn, sizing
// call_overflow_bytes to 0 and causing the outgoing arg 5 store at
// [sp, #0] to clobber the caller's own L0 / first param ingress slot
// (silently corrupted nested-array params across recursion — the
// "edges len 5 → 3 → 4" diagnostic from `_pf_tree_build`).
fn _arm64_max_call_overflow(mf: MFunc) -> i64 {
    let mut max_overflow = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            let s = blk.stmts[si]
            if s.kind == _STMT_CALL {
                let n = len(s.args)
                if n > 4 {
                    let overflow = n - 4
                    if overflow > max_overflow { max_overflow = overflow }
                }
            }
            // RFC closure C3 — indirect call: args[0] is the callee, the
            // remaining args[1..] are call arguments. The runtime env-first
            // ABI puts the env in pair 0, so the outgoing pair count is
            // 1 (env) + (len(args) - 1) call args = len(args). Pairs 5+
            // overflow to the caller stack region, same as STMT_CALL.
            if s.kind == _STMT_CALL_INDIRECT {
                let n = len(s.args)
                if n > 4 {
                    let overflow = n - 4
                    if overflow > max_overflow { max_overflow = overflow }
                }
            }
            si = si + 1
        }
        bi = bi + 1
    }
    return max_overflow
}

// Cycle h20 — try/catch jmp_buf region sizing.
// Each STMT_TRY_SETJMP in the function gets its own 192-byte jmp_buf
// slot in the function frame (Darwin arm64 jmp_buf is 192 bytes — see
// /usr/include/setjmp.h: 14*8 bytes for _JBLEN ints + 192-byte align).
// The slots live ABOVE the SSA-spill region: jmp_buf[i] is at
//   [sp, #(call_overflow_bytes + spill_frame + i * 192)]
// after `sub sp, total_frame`. Codegen walks STMT_TRY_SETJMP statements
// in iteration order and assigns slot indices monotonically.
let _ARM64_JMP_BUF_BYTES = 192
fn _arm64_count_try_setjmp(mf: MFunc) -> i64 {
    let mut n = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            if blk.stmts[si].kind == "try_setjmp" { n = n + 1 }
            si = si + 1
        }
        bi = bi + 1
    }
    return n
}

// ── Statement lowering (C6 — RegMap-aware) ───────────────────

fn _arm64_load_spill(buf: [LInstr], rm: RegMap, id: i64, scratch: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out.push(_arm64_instr2("ldr", _arm64_op_reg(scratch), _arm64_op_mem("sp", off),
                     "reload L" + to_string(id) + " from spill slot"))
    return out
}

fn _arm64_store_spill(buf: [LInstr], rm: RegMap, id: i64, src_reg: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out.push(_arm64_instr2("str", _arm64_op_reg(src_reg), _arm64_op_mem("sp", off),
                     "spill L" + to_string(id) + " to slot"))
    return out
}

// Build a >12-bit constant into `reg` via movz + up to 3 movk. ARM64
// cmp immediates are ≤12-bit and mov/movz ≤16-bit; enum/struct __tag
// values are djb2 _path_hash ints far exceeding that — they emitted as
// `cmp xN,#<hash>` / `mov xN,#<hash>` (1945+314 of the 2332 residual
// stage-1-.s assembler errors). Halfwords via /%65536 (callers gate on
// value>4095, always positive). `#h, lsl #N` is one #-prefixed label so
// emit/asm _fmt_label renders it verbatim (no platform prefix).
fn _arm64_emit_imm_to_reg(buf: [LInstr], reg: string, value: i64) -> [LInstr] {
    let mut out = buf
    let h0 = value % 65536
    let h1 = (value / 65536) % 65536
    let h2 = (value / 65536 / 65536) % 65536
    let h3 = (value / 65536 / 65536 / 65536) % 65536
    out.push(_arm64_instr2("movz", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h0)), "imm 0-15"))
    if h1 != 0 {
        out.push(_arm64_instr2("movk", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h1) + ", lsl #16"), "imm 16-31"))
    }
    if h2 != 0 {
        out.push(_arm64_instr2("movk", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h2) + ", lsl #32"), "imm 32-47"))
    }
    if h3 != 0 {
        out.push(_arm64_instr2("movk", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h3) + ", lsl #48"), "imm 48-63"))
    }
    return out
}

fn _arm64_op_rm(buf: [LInstr], o: Operand, st: ArmStrTab, rm: RegMap,
                scratch: string) -> [LInstr] {
    let mut out = buf
    if o.kind == "local" {
        if _arm_is_spilled(rm, o.local_id) {
            out = _arm64_load_spill(out, rm, o.local_id, scratch)
        }
    }
    // Large const_int (e.g. _path_hash __tag) → movz/movk into scratch;
    // _arm64_op_resolve returns reg(scratch). Small (≤4095) stay
    // immediate (valid in cmp/add/mov — unchanged, no regression).
    if o.kind == "const_int" {
        if o.int_val > 4095 {
            out = _arm64_emit_imm_to_reg(out, scratch, o.int_val)
        }
    }
    // const_str / global → PC-relative address materialization. ARM64
    // cannot use a label as a bare mov/cmp operand; the address must be
    // built with adrp(@PAGE) + add(@PAGEOFF) into a register. Without
    // this every string/global ref emitted `mov xN,.LCstrM` /
    // `cmp xN,.LCstrM` — 3368 of the 3578 stage-1-.s assembler errors.
    // _arm64_op_resolve returns reg(scratch) for these (address built
    // here). Labels render verbatim via emit/asm _fmt_label.
    if o.kind == "const_str" {
        let cl = _arm64_strtab_lookup(st, o.str_val)
        let mut nm = cl
        if len(nm) == 0 { nm = o.str_val }
        out.push(_arm64_instr2("adrp", _arm64_op_reg(scratch),
                         _arm64_op_label(nm + "@PAGE"), "addr page: " + nm))
        out.push(_arm64_instr3("add", _arm64_op_reg(scratch),
                         _arm64_op_reg(scratch),
                         _arm64_op_label(nm + "@PAGEOFF"), "addr off: " + nm))
    }
    if o.kind == "global" {
        let gl = "g" + to_string(o.global_id)
        out.push(_arm64_instr2("adrp", _arm64_op_reg(scratch),
                         _arm64_op_label(gl + "@PAGE"), "addr page: " + gl))
        out.push(_arm64_instr3("add", _arm64_op_reg(scratch),
                         _arm64_op_reg(scratch),
                         _arm64_op_label(gl + "@PAGEOFF"), "addr off: " + gl))
    }
    return out
}

fn _arm64_op_resolve(o: Operand, st: ArmStrTab, rm: RegMap,
                     scratch: string) -> LOperand {
    if o.kind == "local" {
        if _arm_is_spilled(rm, o.local_id) {
            return _arm64_op_reg(scratch)
        }
        return _arm64_op_reg(_arm_reg_lookup(rm, o.local_id))
    }
    if o.kind == "const_int" {
        // >4095 was movz/movk-materialized into scratch by _arm64_op_rm
        // (ARM64 cmp imm ≤12-bit); small values stay immediate.
        if o.int_val > 4095 { return _arm64_op_reg(scratch) }
        return _arm64_op_imm(o.int_val)
    }
    if o.kind == "const_bool" {
        // payload 0/1 — always immediate-representable.
        return _arm64_op_imm(o.int_val)
    }
    // global / const_str: address already materialized into `scratch`
    // by _arm64_op_rm (adrp+add). Return the register, not the label —
    // emitting the bare label is invalid ARM64.
    if o.kind == "global"    { return _arm64_op_reg(scratch) }
    if o.kind == "const_str" { return _arm64_op_reg(scratch) }
    return _arm64_op_imm(0)
}

fn _arm64_emit_dst_writeback(buf: [LInstr], rm: RegMap, id: i64) -> [LInstr] {
    let mut out = buf
    if _arm_is_spilled(rm, id) {
        out = _arm64_store_spill(out, rm, id, "x9")
    }
    return out
}

fn _arm64_dst_reg(rm: RegMap, id: i64) -> string {
    if _arm_is_spilled(rm, id) { return "x9" }
    return _arm_reg_lookup(rm, id)
}

// ── Path A (A′) 16-byte HexaVal value helpers ────────────────
// HexaVal occupies a register PAIR (lo = slot+0 = tag+pad, hi =
// slot+8 = union payload). Every value is memory-resident in a 16B
// frame slot (force-spilled in _arm_assign_regs). _hv_load brings a
// value into the (lo,hi) GP pair; _hv_store writes a (lo,hi) pair
// back to a value's slot. TAG_INT=0 TAG_BOOL=2 TAG_STR=3 (runtime.h).
fn _hv_mem(off: i64) -> LOperand {
    return _arm64_op_label("[sp, #" + to_string(off) + "]")
}

// ARM64 ldp/stp (64-bit pair) take a signed scaled imm7 offset: range
// [-512, +504] in steps of 8. Frame slots beyond that need the address
// materialized into a base register (x15 — outside the value-scratch
// x9-x14 and arg x0-x7 sets). Emits into `base`; returns the [base]
// mem operand for offsets out of range, else [sp,#off].
fn _hv_at(buf: [LInstr], off: i64, base: string) -> [LInstr] {
    let mut out = buf
    if off >= 0 && off <= 504 { return out }
    if off <= 4095 {
        out.push(_arm64_instr3("add", _arm64_op_reg(base), _arm64_op_reg("sp"),
                         _arm64_op_label("#" + to_string(off)), "hv frame base"))
    } else {
        out = _arm64_emit_imm_to_reg(out, base, off)
        out.push(_arm64_instr3("add", _arm64_op_reg(base), _arm64_op_reg("sp"),
                         _arm64_op_reg(base), "hv frame base (big)"))
    }
    return out
}

fn _hv_memb(off: i64, base: string) -> LOperand {
    if off >= 0 && off <= 504 { return _arm64_op_label("[sp, #" + to_string(off) + "]") }
    return _arm64_op_label("[" + base + "]")
}

// sp += / -= amount. ARM64 add/sub immediate is ≤4095 (opt. <<12);
// 16B-slot frames exceed that → materialize the amount into `scr`
// (movz/movk) and use the register form. `scr` (x15) is free at
// prologue entry and at epilogue (return value lives in x0:x1).
fn _hv_sp_adj(buf: [LInstr], mnem: string, amount: i64, scr: string) -> [LInstr] {
    let mut out = buf
    if amount <= 4095 {
        out.push(_arm64_instr3(mnem, _arm64_op_reg("sp"), _arm64_op_reg("sp"),
                         _arm64_op_label("#" + to_string(amount)), "sp adj"))
        return out
    }
    out = _arm64_emit_imm_to_reg(out, scr, amount)
    out.push(_arm64_instr3(mnem, _arm64_op_reg("sp"), _arm64_op_reg("sp"),
                     _arm64_op_reg(scr), "sp adj (big frame)"))
    return out
}

fn _hv_load(buf: [LInstr], o: Operand, st: ArmStrTab, rm: RegMap,
            lo: string, hi: string) -> [LInstr] {
    let mut out = buf
    if o.kind == "local" {
        let off = _arm_spill_offset(rm, o.local_id)
        out = _hv_at(out, off, "x15")
        out.push(_arm64_instr3("ldp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                         _hv_memb(off, "x15"), "hv load L" + to_string(o.local_id)))
        return out
    }
    if o.kind == "const_int" {
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#0"), "hv const_int: TAG_INT"))
        if o.int_val >= 0 && o.int_val <= 65535 {
            out.push(_arm64_instr2("movz", _arm64_op_reg(hi),
                             _arm64_op_label("#" + to_string(o.int_val)), "hv const_int val"))
        } else if o.int_val > 65535 {
            out = _arm64_emit_imm_to_reg(out, hi, o.int_val)
        } else {
            // negative: build |n|-1 then mvn (two's complement)
            out = _arm64_emit_imm_to_reg(out, hi, (0 - o.int_val) - 1)
            out.push(_arm64_instr2("mvn", _arm64_op_reg(hi), _arm64_op_reg(hi),
                             "hv const_int: negate"))
        }
        return out
    }
    if o.kind == "const_void" {
        // `nil` literal — TAG_VOID=4, payload 0. Pairs with the
        // _const_void_op() constructor in compiler/lower/hir_to_mir.hexa.
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#4"), "hv const_void: TAG_VOID"))
        out.push(_arm64_instr2("movz", _arm64_op_reg(hi),
                         _arm64_op_label("#0"), "hv const_void payload"))
        return out
    }
    if o.kind == "const_bool" {
        // `true`/`false` literal — TAG_BOOL=2, payload 0/1. literal_bool
        // used to lower to const_int (TAG_INT), so a literal bool never
        // compared equal under hexa_eq to the TAG_BOOL produced by
        // `==` / `!=` / a comparison (hexa_eq returns false on tag
        // mismatch). Mirrors codegen_c2.hexa `true` -> hexa_bool(1).
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#2"), "hv const_bool: TAG_BOOL"))
        out.push(_arm64_instr2("movz", _arm64_op_reg(hi),
                         _arm64_op_label("#" + to_string(o.int_val)), "hv const_bool payload"))
        return out
    }
    if o.kind == "const_str" {
        let cl = _arm64_strtab_lookup(st, o.str_val)
        let mut nm = cl
        if len(nm) == 0 { nm = o.str_val }
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#3"), "hv const_str: TAG_STR"))
        out.push(_arm64_instr2("adrp", _arm64_op_reg(hi),
                         _arm64_op_label(nm + "@PAGE"), "hv str ptr page"))
        out.push(_arm64_instr3("add", _arm64_op_reg(hi), _arm64_op_reg(hi),
                         _arm64_op_label(nm + "@PAGEOFF"), "hv str ptr off"))
        return out
    }
    if o.kind == "const_float" {
        // TAG_FLOAT = 1 (see self/runtime.h `enum { TAG_INT=0, TAG_FLOAT, … }`).
        // Pool: `.LCfltN: .double <text>` emitted in rodata; here we
        // load that 8-byte IEEE-754 value into `hi` and stash the tag
        // in `lo`. Uses x14 as scratch so we don't clash with the
        // x15 scratch used by spill/slot moves.
        let lab = _arm64_float_lookup(st, o.float_val)
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#1"), "hv const_float: TAG_FLOAT"))
        out.push(_arm64_instr2("adrp", _arm64_op_reg("x14"),
                         _arm64_op_label(lab + "@PAGE"), "hv float pool page"))
        out.push(_arm64_instr3("add", _arm64_op_reg("x14"), _arm64_op_reg("x14"),
                         _arm64_op_label(lab + "@PAGEOFF"), "hv float pool off"))
        out.push(_arm64_instr2("ldr", _arm64_op_reg(hi),
                         _arm64_op_label("[x14]"), "hv load f64 bits " + lab))
        return out
    }
    if o.kind == "global" {
        let gl = "g" + to_string(o.global_id)
        out.push(_arm64_instr2("adrp", _arm64_op_reg(lo),
                         _arm64_op_label(gl + "@PAGE"), "hv global page"))
        out.push(_arm64_instr3("add", _arm64_op_reg(lo), _arm64_op_reg(lo),
                         _arm64_op_label(gl + "@PAGEOFF"), "hv global off"))
        out.push(_arm64_instr3("ldp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                         _arm64_op_label("[" + lo + "]"), "hv load global " + gl))
        return out
    }
    // unknown → void (TAG_VOID=4, payload 0)
    out.push(_arm64_instr2("movz", _arm64_op_reg(lo), _arm64_op_label("#4"), "hv void"))
    out.push(_arm64_instr2("movz", _arm64_op_reg(hi), _arm64_op_label("#0"), "hv void"))
    return out
}

fn _hv_store(buf: [LInstr], rm: RegMap, id: i64, lo: string, hi: string) -> [LInstr] {
    let mut out = buf
    if id < 0 { return out }
    let off = _arm_spill_offset(rm, id)
    out = _hv_at(out, off, "x15")
    out.push(_arm64_instr3("stp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                     _hv_memb(off, "x15"), "hv store L" + to_string(id)))
    return out
}

// Dispatch by dst: arena_id == -999 marks a module-level mutable
// global (hir_to_mir _lower_hexpr "assign" branch sentinel). Emits a
// PC-relative store into the `g<id>` data slot. Local-slot dsts fall
// through to the normal frame-spill path.
fn _hv_store_dst(buf: [LInstr], rm: RegMap, dst: Local, lo: string, hi: string) -> [LInstr] {
    if dst.arena_id == -999 {
        let mut out = buf
        let gl = "g" + to_string(dst.id)
        out.push(_arm64_instr2("adrp", _arm64_op_reg("x15"),
                         _arm64_op_label(gl + "@PAGE"), "hv global page (store)"))
        out.push(_arm64_instr3("add", _arm64_op_reg("x15"), _arm64_op_reg("x15"),
                         _arm64_op_label(gl + "@PAGEOFF"), "hv global off (store)"))
        out.push(_arm64_instr3("stp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                         _arm64_op_label("[x15]"), "hv store global " + gl))
        return out
    }
    return _hv_store(buf, rm, dst.id, lo, hi)
}

// Load a const_str's raw char* (the .LCstr address) into `reg` — for
// the map ABI (hexa_map_set/get take `const char* key`, not HexaVal).
fn _hv_cstr(buf: [LInstr], o: Operand, st: ArmStrTab, reg: string) -> [LInstr] {
    let mut out = buf
    let cl = _arm64_strtab_lookup(st, o.str_val)
    let mut nm = cl
    if len(nm) == 0 { nm = o.str_val }
    out.push(_arm64_instr2("adrp", _arm64_op_reg(reg),
                     _arm64_op_label(nm + "@PAGE"), "cstr key page"))
    out.push(_arm64_instr3("add", _arm64_op_reg(reg), _arm64_op_reg(reg),
                     _arm64_op_label(nm + "@PAGEOFF"), "cstr key off"))
    return out
}

fn _hv_ldslot(buf: [LInstr], rm: RegMap, id: i64, lo: string, hi: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out = _hv_at(out, off, "x15")
    out.push(_arm64_instr3("ldp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                     _hv_memb(off, "x15"), "hv reload L" + to_string(id)))
    return out
}

// binop/compare → runtime symbol (codegen_c2-authoritative). "" =
// special-cased (!=, &&, ||, bitwise) by the BINOP emitter.
fn _hv_binop_sym(op: string) -> string {
    if op == "+"  || op == "add" { return "hexa_add_slow" }  // hexa_add is a runtime.h MACRO; the linkable fn is hexa_add_slow
    if op == "-"  || op == "sub" { return "hexa_sub" }
    if op == "*"  || op == "mul" { return "hexa_mul" }
    if op == "/"  || op == "div" || op == "sdiv" { return "hexa_div" }
    if op == "%"  || op == "mod" || op == "rem"  { return "hexa_mod" }
    if op == "==" || op == "eq"  || op == "cmp_eq" { return "hexa_eq" }
    if op == "<"  || op == "lt"  || op == "cmp_lt" { return "hexa_cmp_lt" }
    if op == ">"  || op == "gt"  || op == "cmp_gt" { return "hexa_cmp_gt" }
    if op == "<=" || op == "le"  || op == "cmp_le" { return "hexa_cmp_le" }
    if op == ">=" || op == "ge"  || op == "cmp_ge" { return "hexa_cmp_ge" }
    if op == "concat" { return "hexa_str_concat" }
    return ""
}

// Builtin call target → runtime ABI symbol. Only builtins whose
// runtime.c signature is verified `HexaVal X(HexaVal…)` (i.e. matches
// the new codegen's uniform-HexaVal register ABI, args x0-x7 / return
// x0) are mapped here — for those a pure symbol rename is ABI-correct
// (codegen_c2's hexa_int()/hexa_bool() wrappers are C-expression
// boxing artifacts, irrelevant at the register ABI). Builtins whose
// runtime fn returns int/void (len/contains/starts_with/has_key/
// println), needs cstring-arg conversion (has_key), or has no runtime
// symbol at all (is_alpha/is_alphanumeric — codegen_c2 inline-expands)
// are intentionally NOT mapped: they pass through unchanged (stay
// undefined → link still gated) rather than silently mis-run. That
// residual is the precisely-scoped final builtin-lowering sub-unit.
// Non-builtin (hexa user fn) names pass through → normal mangling.
fn _builtin_runtime_sym(name: string) -> string {
    if name == "append_file"   { return "rt_append_file" }
    if name == "args"          { return "hexa_args" }
    if name == "char_code_at"  { return "hexa_str_char_code_at" }
    if name == "char_code"     { return "hexa_char_code" }
    if name == "lgamma"        { return "hexa_math_lgamma" }
    if name == "env"           { return "hexa_env_var" }
    if name == "env_var"       { return "hexa_env_var" }
    // `now()` — interp alias for `timestamp()` (UNIX-millis). R5 triage.
    if name == "now"           { return "hexa_timestamp" }
    // `.find(needle)` method — generic substring/element search.
    // hir_to_mir lowers `recv.find(x)` to STMT_CALL op="find"
    // args=[recv,x]; runtime hexa_find_poly (runtime.c:7007) dispatches
    // on the receiver shape. R5 CGFAIL triage (repo_taxonomy_audit).
    if name == "find"          { return "hexa_find_poly" }
    if name == "file_size"     { return "rt_file_size" }
    if name == "chars"         { return "hexa_str_chars" }
    if name == "eprintln"      { return "hexa_eprintln" }
    if name == "exit"          { return "hexa_exit" }
    if name == "exec"          { return "hexa_exec" }
    if name == "file_exists"   { return "rt_file_exists" }
    // NOTE: index_of is handled by a dedicated arg-count-aware
    // STMT_CALL branch (string method -> hexa_str_index_of /
    // hexa_str_index_of_from, int-boxed). The old
    // hexa_array_index_of map returned -1 for every string
    // receiver -- a wrong-value miscompile that silently
    // flipped atlas-verifier predicates.
    if name == "join"          { return "hexa_str_join" }
    if name == "push"          { return "hexa_array_push" }
    if name == "pop"           { return "hexa_array_pop" }
    if name == "read_file"     { return "rt_read_file" }
    if name == "replace"       { return "hexa_str_replace" }
    if name == "split"         { return "hexa_str_split" }
    if name == "substring"     { return "hexa_str_substring" }
    if name == "to_int"        { return "hexa_to_int" }
    if name == "to_float"      { return "hexa_to_float" }
    if name == "to_bool"       { return "hexa_to_bool" }
    if name == "to_string"     { return "hexa_to_string" }
    // `chr(N)` byte-level alias — same as `from_char_code` but with
    // raw byte semantics (codegen ABI: name & N & 0xff). The runtime
    // exports both `hexa_chr_byte` (this) and `hexa_from_char_code`
    // (round-trip UTF-8 of codepoint N). For aprime_cc's native path
    // we keep `chr` consistent with the self/* convention. Cycle 33.
    if name == "chr"           { return "hexa_chr_byte" }
    if name == "from_char_code" { return "hexa_from_char_code" }
    if name == "write_bytes"   { return "rt_write_bytes" }
    if name == "bytes"         { return "hexa_str_bytes" }
    // Cycle 34/35: `.truncate(n)` was unmapped → fallthrough returned
    // "truncate" → link resolved to libc's truncate(const char *path,
    // off_t length) → SIGBUS when hexa_array_push later memmove'd into
    // the array whose metadata was clobbered by the bogus path-write.
    // The fix is a single map entry; runtime exports `hexa_array_truncate`
    // (self/runtime.c:`hexa_array_truncate`). Confirms cycle 34's root-
    // cause crash stack: _patch_loop_sentinels → array.truncate(0) →
    // libc-truncate-with-garbage-path → metadata corrupt → next .push
    // memmove SIGBUS.
    if name == "truncate"      { return "hexa_array_truncate" }
    // Interp aliases (bind.hexa accepts them as known names; without
    // a runtime symbol map the link fails on `_str`/`_int`/etc.).
    // `str(x)` is interp's shorthand for `to_string(x)` (see
    // self/hexa_full.hexa: call_builtin "str" -> val_str(val_to_string(args[0]))).
    if name == "str"           { return "hexa_to_string" }
    if name == "int"           { return "hexa_to_int" }
    if name == "float"         { return "hexa_to_float" }
    if name == "bool"          { return "hexa_to_bool" }
    if name == "ln"            { return "hexa_log" }
    // map/dict accessors — runtime returns HexaVal of array (keys,
    // values, entries) or HexaVal scalar (count). All HexaVal-shape
    // so no ret-box needed. `dict_keys` is interp's anima-speak alias
    // for `map_keys` (see hexa_full.hexa § FIX-A); both map to the
    // same runtime fn name family.
    if name == "dict_keys"     { return "hexa_dict_keys" }
    if name == "map_keys"      { return "hexa_map_keys" }
    if name == "map_values"    { return "hexa_map_values" }
    if name == "map_entries"   { return "hexa_map_entries" }
    // math / formatting — HexaVal-in / HexaVal-out, no ret-box needed.
    // Each verified to exist in self/runtime.c before mapping (the
    // unmapped-is-safer-than-mis-mapped policy in this file's header
    // comment still holds for ret-box/cstring shapes that aren't here).
    if name == "abs"           { return "hexa_abs" }
    if name == "argmax"        { return "hexa_argmax" }
    if name == "bin"           { return "hexa_bin" }
    if name == "ceil"          { return "hexa_ceil" }
    if name == "clamp"         { return "hexa_clamp" }
    if name == "cos"           { return "hexa_cos" }
    if name == "exp"           { return "hexa_exp" }
    if name == "floor"         { return "hexa_floor" }
    if name == "format"        { return "hexa_format" }
    if name == "hex"           { return "hexa_hex" }
    if name == "log"           { return "hexa_log" }
    if name == "log2"          { return "hexa_log2" }
    if name == "log10"         { return "hexa_log10" }
    if name == "pad_left"      { return "hexa_pad_left" }
    if name == "pad_right"     { return "hexa_pad_right" }
    if name == "pow"           { return "hexa_pow" }
    if name == "random"        { return "hexa_random" }
    if name == "round"         { return "hexa_round" }
    if name == "sin"           { return "hexa_sin" }
    if name == "sleep"         { return "hexa_sleep" }
    if name == "sqrt"          { return "hexa_sqrt" }
    if name == "tan"           { return "hexa_tan" }
    if name == "tanh"          { return "hexa_tanh" }
    if name == "timestamp"     { return "hexa_timestamp" }
    if name == "utc_iso_now"   { return "hexa_utc_iso_now" }
    if name == "trim"          { return "rt_str_trim" }
    if name == "type_of"       { return "hexa_type_of" }
    if name == "write_file"    { return "rt_write_file" }
    if name == "sha256"        { return "hexa_sha256" }
    if name == "sha256_file"   { return "hexa_sha256_file" }
    // Low-level memory / pointer builtins — name -> runtime symbol.
    // Authoritative mapping mirrored from self/codegen_c2.hexa §G5/B3.
    // All take/return HexaVal pairs so the generic STMT_CALL emit path
    // (arg pairs into x0:x1/x2:x3/x4:x5, bl, x0:x1 → dst) lowers them
    // verbatim — no special branch, no ret-box. `free_raw` is the
    // 1-arg alias of hexa_ptr_free (size arg ignored by the runtime).
    if name == "alloc_raw"     { return "hexa_ptr_alloc" }
    if name == "free_raw"      { return "hexa_ptr_free" }
    if name == "write_f32"     { return "hexa_ptr_write_f32" }
    if name == "write_i32"     { return "hexa_ptr_write_i32" }
    if name == "write_i64"     { return "hexa_ptr_write" }
    if name == "deref_f32"     { return "hexa_ptr_read_f32" }
    if name == "deref_i32"     { return "hexa_ptr_read_i32" }
    if name == "ptr_write_f32" { return "hexa_ptr_write_f32" }
    if name == "ptr_write_i32" { return "hexa_ptr_write_i32" }
    if name == "ptr_write"     { return "hexa_ptr_write" }      // untyped 64-bit — mirror tier-2 codegen_c2
    if name == "ptr_read"      { return "hexa_ptr_read" }       // untyped 64-bit — mirror tier-2 codegen_c2
    if name == "ptr_read_f32"  { return "hexa_ptr_read_f32" }
    if name == "ptr_read_f64"  { return "hexa_ptr_read_f64" }
    if name == "ptr_read_i32"  { return "hexa_ptr_read_i32" }
    if name == "println"       { return "hexa_println" }
    if name == "len"           { return "hexa_len" }            // → int (box)
    if name == "contains"      { return "hexa_str_contains" }   // → int (box bool)
    if name == "starts_with"   { return "rt_str_starts_with" }  // → int (box bool)
    if name == "ends_with"     { return "rt_str_ends_with" }    // → int (box bool)
    if name == "is_alpha"          { return "hexa_is_alpha" }          // shim → HexaVal
    if name == "is_alphanumeric"   { return "hexa_is_alphanumeric" }   // shim → HexaVal
    return name
}

// builtin runtime fn return-shape needing a post-call box into HexaVal:
// "int" → sxtw w0 + hexa_int ; "bool" → uxtw w0 + hexa_bool ; "" → none
// (already HexaVal). has_key is handled by its own STMT_CALL path.
fn _builtin_ret_box(name: string) -> string {
    if name == "len"         { return "int" }
    if name == "contains"    { return "bool" }
    if name == "starts_with" { return "bool" }
    if name == "ends_with"   { return "bool" }
    return ""
}

// Cycle h20: extra params try_buf_bytes (total fn jmp_buf region size)
// and try_slot_idx (this statement's slot index in 0..try_count).
// try_slot_idx is meaningful only for STMT_TRY_SETJMP / STMT_TRY_POP;
// other kinds ignore it.
fn _emit_arm64_stmt(out: [LInstr], modhash: string, fname: string, s: Stmt,
                    st: ArmStrTab, rm: RegMap, spill_frame: i64,
                    try_buf_bytes: i64, try_slot_idx: i64) -> [LInstr] {
    let mut buf = out
    if s.kind == _STMT_ASSIGN {
        // array_lit constructor (mirror of x86_64_linux.hexa 269bb61d;
        // AAPCS64: args x0/x1, call via bl, return x0). dst =
        // hexa_array_new(); per element hexa_array_push(dst, e_i) →
        // recapture x0. Grammar-capped ≤1024 by HX0013 → O(n) bounded.
        // Runtime-call shape mirrors the proven concat idiom below.
        // rebuild-verification DEFERRED (Track-A clang wall) — logic
        // parity with shipped concat emit.
        if s.op == "array_lit" {
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_array_new"),
                             "array_lit: new array"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            let mut i = 0
            while i < len(s.args) {
                buf = _hv_ldslot(buf, rm, s.dst.id, "x0", "x1")
                buf = _hv_load(buf, s.args[i], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_array_push"),
                                 "array_lit: push elem " + to_string(i)))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                i = i + 1
            }
            return buf
        }
        // struct_lit constructor (map-backed; mirror of x86_64 a351b1c9
        // in AAPCS64: x0=map, x1=key const char*, x2=val HexaVal, bl,
        // x0 return). MIR args = [type_str, k0_str, v0, ...] (2a790d85);
        // const_str key → .rodata label = const char* (map_set ABI).
        // type_str ignored in map-backed v1. Runtime-call parity with
        // array_lit/concat; rebuild-verification deferred (Track-A wall).
        if s.op == "struct_lit" && len(s.args) >= 1 {
            // map ABI: m=HexaVal(x0:x1), key=const char*(x2), val=
            // HexaVal(x3:x4). args=[type_str, k0,v0,k1,v1,…].
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_new"),
                             "struct_lit: new map"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            let mut i = 1
            while i + 1 < len(s.args) {
                buf = _hv_ldslot(buf, rm, s.dst.id, "x0", "x1")
                buf = _hv_cstr(buf, s.args[i], st, "x2")
                buf = _hv_load(buf, s.args[i + 1], st, rm, "x3", "x4")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_set"),
                                 "struct_lit: set field"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                i = i + 2
            }
            return buf
        }
        // RFC 074 Phase 4 — multi-cell enum payload constructor.
        // Producer = compiler/lower/hir_to_mir.hexa enum_path arm (>=2 args).
        // Body is byte-equivalent to struct_lit (same key/val pair walk,
        // same hexa_map_new + hexa_map_set ABI) — the op-string split is
        // the semantic marker. A future cycle can swap the storage for a
        // contiguous N-cell layout by replacing the per-cell call loop
        // below WITHOUT touching struct_lit. First arg is the "enum_<path>"
        // type string; pairs [k1,v1] onward are __tag + __p0..__pN-1 slots.
        if s.op == "enum_ctor" && len(s.args) >= 1 {
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_new"),
                             "enum_ctor: new map (multi-cell payload)"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            let mut i = 1
            while i + 1 < len(s.args) {
                buf = _hv_ldslot(buf, rm, s.dst.id, "x0", "x1")
                buf = _hv_cstr(buf, s.args[i], st, "x2")
                buf = _hv_load(buf, s.args[i + 1], st, rm, "x3", "x4")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_set"),
                                 "enum_ctor: set cell"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                i = i + 2
            }
            return buf
        }
        // field access (map-backed; mirror of x86_64 0fe030dd in
        // AAPCS64: x0=base, x1=key const char*, bl hexa_map_get, x0).
        // args = [base, "<name>"_str]; const_str key → .rodata label.
        // Parity with shipped array_lit/struct_lit; rebuild-verification
        // deferred (Track-A clang wall).
        if s.op == "field" && len(s.args) >= 2 {
            // map ABI: base=HexaVal(x0:x1), key=const char*(x2).
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_cstr(buf, s.args[1], st, "x2")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_get"),
                             "field: hexa_map_get"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            return buf
        }
        // RFC closure C3 — closure-value construction. hir_to_mir lowers a
        // closure-expression site to STMT_ASSIGN op="closure_new" with
        //   args = [env_array, lambda_name_str, arity_int]
        // and emits the synthetic `__hexa_lambda_<N>` MFunc separately.
        // Runtime ABI: hexa_closure_new(void* fn_ptr, int arity,
        // HexaVal env_arr) — fn_ptr in x0, arity (C int) in w1, env HexaVal
        // pair in x2:x3, returns the TAG_CLOSURE HexaVal in x0:x1. The
        // fn pointer is the address of the lifted lambda symbol (adrp/add);
        // mirrors self/codegen_c2.hexa::gen2_lambda_expr's
        // `hexa_closure_new((void*)&__hexa_lambda_N, arity, env)`.
        if s.op == "closure_new" && len(s.args) >= 3 {
            let lam_sym = s.args[1].str_val
            let arity = s.args[2].int_val
            // x0 = &__hexa_lambda_N  (PC-relative; symbol mangled by _fmt_label)
            buf.push(_arm64_instr2("adrp", _arm64_op_reg("x0"),
                             _arm64_op_label(lam_sym + "@PAGE"),
                             "closure_new: lambda fn-ptr page"))
            buf.push(_arm64_instr3("add", _arm64_op_reg("x0"),
                             _arm64_op_reg("x0"),
                             _arm64_op_label(lam_sym + "@PAGEOFF"),
                             "closure_new: lambda fn-ptr off"))
            // w1 = arity (C int)
            buf.push(_arm64_instr2("movz", _arm64_op_reg("x1"),
                             _arm64_op_label("#" + to_string(arity)),
                             "closure_new: arity"))
            // x2:x3 = env array HexaVal
            buf = _hv_load(buf, s.args[0], st, rm, "x2", "x3")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_closure_new"),
                             "closure_new: build TAG_CLOSURE"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            return buf
        }
        // array/map subscript: base[idx]. hir_to_mir lowers `a[i]` to
        // STMT_ASSIGN op="index" args=[base, idx]; without a dedicated
        // branch the fall-through below would just copy `base` into
        // dst (every index expr returned the whole container). Route
        // through hexa_index_get(container, key): the runtime
        // dispatches arrays via hexa_array_get and unwraps VALSTRUCT
        // before the array path.
        if s.op == "index" && len(s.args) >= 2 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // base → x0:x1
            buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")  // idx → x2:x3
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_index_get"),
                             "index: hexa_index_get"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            return buf
        }
        // index_set: `arr[i] = v` / `map[k] = v`. The hir_to_mir
        // assign branch lowers index-lhs assignments to STMT_ASSIGN
        // op="index_set" with args = [container, key, value]; no dst
        // local is consumed. Three HexaVal pair args fit in x0..x5
        // (AAPCS64); no overflow.
        //
        // CORRECTNESS: hexa_index_set RETURNS the (possibly new)
        // container HexaVal — it is NOT a pure side effect. The
        // proven C reference path (codegen_c2) emits
        // `container = hexa_index_set(container, key, value)`. The
        // arm64 path previously dropped the return, so a container
        // built by `let mut a = []` + push (e.g. hxc_loader.hexa
        // `dense`) kept a STALE array header in its slot; after the
        // runtime's arena dirty-slot / heapify relocated the backing
        // on a later allocation, `_build_node(dense)` received a
        // dangling/garbage array → non-deterministic "container is
        // not an array (tag=<garbage>)" — the last aprime_cc
        // self-host fixpoint blocker (interp-retirement #18). Mirror
        // hexa_array_push: store the result back into the container
        // lvalue when it is a storable local/global Operand.
        if s.op == "index_set" && len(s.args) >= 3 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // container
            buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")  // key
            buf = _hv_load(buf, s.args[2], st, rm, "x4", "x5")  // value
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_index_set"),
                             "index_set: hexa_index_set"))
            let cont = s.args[0]
            if cont.kind == "local" {
                buf = _hv_store(buf, rm, cont.local_id, "x0", "x1")
            } else if cont.kind == "global" {
                let gl = "g" + to_string(cont.global_id)
                buf.push(_arm64_instr2("adrp", _arm64_op_reg("x15"),
                                 _arm64_op_label(gl + "@PAGE"),
                                 "index_set: container global page (store-back)"))
                buf.push(_arm64_instr3("add", _arm64_op_reg("x15"),
                                 _arm64_op_reg("x15"),
                                 _arm64_op_label(gl + "@PAGEOFF"),
                                 "index_set: container global off (store-back)"))
                buf.push(_arm64_instr3("stp", _arm64_op_reg("x0"),
                                 _arm64_op_reg("x1"),
                                 _arm64_op_label("[x15]"),
                                 "index_set: store-back into global " + gl))
            }
            return buf
        }
        if len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == _STMT_BINOP {
        if len(s.args) >= 2 {
            let sym = _hv_binop_sym(s.op)
            if len(sym) > 0 {
                // a → x0:x1, b → x2:x3, bl _sym (HexaVal→HexaVal→HexaVal
                // or →cmp HexaVal-bool), result x0:x1 → dst slot.
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label(sym), "binop " + s.op))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            if s.op == "!=" || s.op == "ne" || s.op == "cmp_ne" {
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_eq"), "ne: eq"))
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                                 "ne: truthy(eq) → w0"))
                buf.push(_arm64_instr3("eor", _arm64_op_reg("x0"),
                                 _arm64_op_reg("x0"), _arm64_op_label("#1"), "ne: !truthy"))
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                                 "ne: box bool"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            if s.op == "&&" || s.op == "||" || s.op == "and" || s.op == "or" {
                // codegen_c2: && = truthy(a)?b:a ; || = truthy(a)?a:b
                let lb = "hvL" + modhash + "_" + fname + "_" + to_string(s.dst.id)
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                                 "logic: truthy(a) → w0"))
                buf.push(_arm64_instr2("cbz", _arm64_op_reg("x0"),
                                 _arm64_op_label(lb + "_f"), "logic: !truthy → false-arm"))
                // truthy-arm: && → b, || → a
                if s.op == "||" || s.op == "or" {
                    buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                } else {
                    buf = _hv_load(buf, s.args[1], st, rm, "x0", "x1")
                }
                buf.push(_arm64_instr1("b", _arm64_op_label(lb + "_d"), "logic: → done"))
                buf.push(_arm64_instr0("label", lb + "_f"))
                // false-arm: && → a, || → b
                if s.op == "||" || s.op == "or" {
                    buf = _hv_load(buf, s.args[1], st, rm, "x0", "x1")
                } else {
                    buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                }
                buf.push(_arm64_instr0("label", lb + "_d"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            // Bitwise int ops & | ^ << >> — codegen_c2-authoritative:
            //   hexa_int(HX_INT(l) <op> HX_INT(r))   (codegen_c2.hexa:3412)
            // HexaVal pair = (lo=tag, hi=payload); for TAG_INT the int
            // value lives in hi. Operate directly on the payload regs:
            // a->x0:x1, b->x2:x3 => result payload = x1 <op> x3, tag=0.
            // #29 fix: the prior catch-all routed & | ^ through
            // hexa_add_slow ("approx"), so `h & MASK` ran as `h + MASK`
            // — _path_hash produced unmasked djb2 values, making the
            // self-built (ap2) compiler emit garbage enum __tag immediates.
            if _is_bit_and(s.op) || _is_bit_or(s.op) || _is_bit_xor(s.op)
               || s.op == "<<" || s.op == ">>" || s.op == "shl" || s.op == "shr" {
                let mut bw = "and"
                if _is_bit_or(s.op)  { bw = "orr" }
                if _is_bit_xor(s.op) { bw = "eor" }
                if s.op == "<<" || s.op == "shl" { bw = "lsl" }
                if s.op == ">>" || s.op == "shr" { bw = "asr" }
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
                buf.push(_arm64_instr3(bw, _arm64_op_reg("x1"),
                                 _arm64_op_reg("x1"), _arm64_op_reg("x3"),
                                 "bitwise " + s.op + ": payload"))
                buf.push(_arm64_instr2("movz", _arm64_op_reg("x0"),
                                 _arm64_op_label("#0"), "bitwise: TAG_INT"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            // unknown binop — rare; approximate via hexa_add (follow-up
            // if it surfaces at run).
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_add_slow"),
                             "binop " + s.op + " (approx)"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == _STMT_CALL {
        // has_key(m, key) special: runtime ABI is
        // hexa_bool(hexa_map_contains_key(HexaVal m, const char* key))
        // (codegen_c2:4302). key is a HexaVal var → hexa_to_cstring it.
        if s.op == "has_key" && len(s.args) >= 2 {
            buf = _hv_load(buf, s.args[1], st, rm, "x0", "x1")  // key HexaVal
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_to_cstring"),
                             "has_key: key → cstring"))
            buf.push(_arm64_instr2("mov", _arm64_op_reg("x9"),
                             _arm64_op_reg("x0"), "has_key: save key cstr"))
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // map m → x0:x1
            buf.push(_arm64_instr2("mov", _arm64_op_reg("x2"),
                             _arm64_op_reg("x9"), "has_key: key arg (x2)"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_contains_key"),
                             "has_key: map_contains_key → int"))
            buf.push(_arm64_instr2("uxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "has_key: zext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                             "has_key: box bool"))
            if s.dst.id >= 0 { buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1") }
            return buf
        }
        // index_of(recv, sub[, start]) special: `.index_of` is a STRING
        // method (byte offset of first occurrence, or -1). The old
        // _builtin_runtime_sym map routed it to hexa_array_index_of,
        // which returns -1 for every string receiver -- a wrong-VALUE
        // miscompile that silently flipped atlas-verifier predicates
        // (audit scans doing `raw.index_of(token) >= 0`). Mirrors
        // codegen_c2.hexa gen2_method_builtin: 2-arg form ->
        // hexa_str_index_of_from, 1-arg form -> hexa_str_index_of;
        // both return a C int64_t that must be boxed into a HexaVal.
        if s.op == "index_of" && len(s.args) >= 2 {
            let iof_sym = if len(s.args) >= 3 { "hexa_str_index_of_from" } else { "hexa_str_index_of" }
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
            if len(s.args) >= 3 {
                buf = _hv_load(buf, s.args[2], st, rm, "x4", "x5")
            }
            buf.push(_arm64_instr1("bl", _arm64_op_label(iof_sym),
                             "index_of: str index_of"))
            buf.push(_arm64_instr2("sxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "index_of: sign-ext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_int"),
                             "index_of: box to HexaVal"))
            if s.dst.id >= 0 { buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1") }
            return buf
        }
        // ord(s) — first-codepoint code. codegen_c2.hexa:4301 lowers it
        // to hexa_char_code(s, hexa_int(0)); the constant index-0 arg is
        // synthesised here as a TAG_INT 0 pair in x2:x3 (the runtime
        // returns a HexaVal int directly -- no ret-box). 1-arg builtin.
        if s.op == "ord" && len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // string recv
            buf.push(_arm64_instr2("movz", _arm64_op_reg("x2"),
                             _arm64_op_label("#0"), "ord: TAG_INT for index arg"))
            buf.push(_arm64_instr2("movz", _arm64_op_reg("x3"),
                             _arm64_op_label("#0"), "ord: index 0 payload"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_char_code"),
                             "ord: hexa_char_code(s, 0)"))
            if s.dst.id >= 0 { buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1") }
            return buf
        }
        // ptr_from_int(x) — identity. codegen_c2.hexa:4126 returns the
        // arg verbatim (the int already encodes the address under
        // TAG_INT). No call: load arg -> x0:x1, store to dst.
        if s.op == "ptr_from_int" && len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            if s.dst.id >= 0 { buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1") }
            return buf
        }
        // C7 — AAPCS64 arm64 stack spill for args 9+.
        // Args 9+ live at [sp, #0], [sp, #8], ..., with sp held 16-byte
        // aligned at every memory access. Unlike x86_64, SSA spill access
        // is sp-relative, so a per-call sub/add would corrupt SSA offsets.
        // Instead the per-fn outgoing-call overflow region is pre-allocated
        // at the bottom of the frame (rm.call_overflow_bytes is non-zero
        // when this fn has any overflow call), and _arm_spill_offset shifts
        // SSA offsets above it. Here we just `str` into the reserved slots.
        // AAPCS64: each 16B HexaVal arg occupies a register PAIR —
        // arg0→x0:x1, arg1→x2:x3, arg2→x4:x5, arg3→x6:x7 (4 pair-args
        // in the 8 GPRs); args ≥4 go to 16B stack slots [sp,#(i-4)*16].
        // Return is x0:x1 → dst slot.
        let arg_n = len(s.args)
        let mut i = 0
        while i < arg_n {
            if i < 4 {
                let lo = "x" + to_string(i * 2)
                let hi = "x" + to_string(i * 2 + 1)
                buf = _hv_load(buf, s.args[i], st, rm, lo, hi)
            } else {
                buf = _hv_load(buf, s.args[i], st, rm, "x9", "x10")
                let off = (i - 4) * 16
                buf = _hv_at(buf, off, "x15")
                buf.push(_arm64_instr3("stp", _arm64_op_reg("x9"),
                                 _arm64_op_reg("x10"), _hv_memb(off, "x15"),
                                 "C7: stack arg " + to_string(i)))
            }
            i = i + 1
        }
        let target = _builtin_runtime_sym(s.op)
        buf.push(_arm64_instr1("bl", _arm64_op_label(target), "call " + target))
        // Box int/bool-returning runtime builtins into a HexaVal (the
        // callee returns a C int in w0; A′ expects x0:x1 HexaVal).
        let box = _builtin_ret_box(s.op)
        if box == "int" {
            buf.push(_arm64_instr2("sxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "ret int: sign-ext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_int"),
                             "ret int: box → HexaVal"))
        }
        if box == "bool" {
            buf.push(_arm64_instr2("uxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "ret bool: zero-ext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                             "ret bool: box → HexaVal"))
        }
        if s.dst.id >= 0 {
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    // RFC closure C3 — indirect call through a closure VALUE.
    //
    // hir_to_mir lowers a call whose callee is a closure value (a
    // let/param-bound TAG_CLOSURE, or a closure-expression invoked in
    // place) to STMT_CALL_INDIRECT with args[0] = callee value and
    // args[1..] = the call arguments. We replicate the runtime
    // `hexa_callN` static-inline dispatch (self/runtime.c:1147+) directly
    // in asm — those helpers are `static inline` so the direct-asm path
    // cannot `bl` them; the closure layout is small enough to inline.
    //
    // HexaVal is a 16B pair (x_lo = tag, x_hi = payload). For a
    // TAG_CLOSURE the payload is `HexaClo*` (runtime.h:68):
    //   struct HexaClo { void* fn_ptr; int arity; HexaVal* env_box; }
    //   → fn_ptr @0, arity @8, env_box @16.
    // Dispatch ABI is env-first: the lifted `__hexa_lambda_N` takes
    // (__env, a1..aN), so we put `*env_box` (the env array HexaVal) in
    // pair 0 (x0:x1) and the call args in pairs 1.. (x2:x3, x4:x5,
    // x6:x7); pair 5+ overflow to [sp,#…] (C7 region). Every closure
    // value reaching here is TAG_CLOSURE (hir_to_mir's `closure_new`
    // always emits hexa_closure_new — even non-capturing closures get an
    // empty env), so no TAG_FN branch is needed.
    if s.kind == _STMT_CALL_INDIRECT && len(s.args) >= 1 {
        // 1. callee value → x9:x10 ; x10 = HexaClo* payload.
        buf = _hv_load(buf, s.args[0], st, rm, "x9", "x10")
        // 2. fn_ptr = [clo_ptr + 0] → x13 (survives the arg loads, which
        //    only scratch x14/x15).
        buf.push(_arm64_instr2("ldr", _arm64_op_reg("x13"),
                         _arm64_op_mem("x10", 0),
                         "call_indirect: fn_ptr = clo->fn_ptr"))
        // 3. env_box = [clo_ptr + 16] → x12.
        buf.push(_arm64_instr2("ldr", _arm64_op_reg("x12"),
                         _arm64_op_mem("x10", 16),
                         "call_indirect: env_box = clo->env_box"))
        // 4. call args a1.. → pairs x2:x3, x4:x5, x6:x7, then stack.
        //    arg i (1-based over s.args) lands in outgoing pair i:
        //      pair 1 = x2:x3, pair 2 = x4:x5, pair 3 = x6:x7,
        //      pair 4+ = [sp, #(pair-4)*16]   (env occupies pair 0).
        let arg_n = len(s.args)
        let mut ai = 1
        while ai < arg_n {
            if ai < 4 {
                let lo = "x" + to_string(ai * 2)
                let hi = "x" + to_string(ai * 2 + 1)
                buf = _hv_load(buf, s.args[ai], st, rm, lo, hi)
            } else {
                buf = _hv_load(buf, s.args[ai], st, rm, "x9", "x10")
                let off = (ai - 4) * 16
                buf = _hv_at(buf, off, "x15")
                buf.push(_arm64_instr3("stp", _arm64_op_reg("x9"),
                                 _arm64_op_reg("x10"), _hv_memb(off, "x15"),
                                 "call_indirect: stack arg " + to_string(ai)))
            }
            ai = ai + 1
        }
        // 5. env HexaVal = *env_box → x0:x1 (pair 0). Done LAST so the
        //    arg loads above can't clobber it.
        buf.push(_arm64_instr2("ldr", _arm64_op_reg("x0"),
                         _arm64_op_mem("x12", 0),
                         "call_indirect: env tag = env_box->tag"))
        buf.push(_arm64_instr2("ldr", _arm64_op_reg("x1"),
                         _arm64_op_mem("x12", 8),
                         "call_indirect: env payload = env_box->payload"))
        // 6. indirect branch-with-link through the lifted fn pointer.
        buf.push(_arm64_instr1("blr", _arm64_op_reg("x13"),
                         "call_indirect: blr closure fn_ptr"))
        // 7. result HexaVal x0:x1 → dst slot.
        if s.dst.id >= 0 {
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == _STMT_RETURN {
        if len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // AAPCS64 16B return = x0:x1
        } else {
            // #40 — value-less return must hand back a real TAG_VOID
            // HexaVal (x0:x1), not stale call-clobbered registers.
            // Mirrors tier-2 `return hexa_void();` (codegen_c2.hexa) and
            // the const_void load above (TAG_VOID=4, payload 0). Without
            // this, `type_of(returns_void())` reads a garbage tag.
            buf.push(_arm64_instr2("movz", _arm64_op_reg("x0"),
                             _arm64_op_label("#4"), "ret void: TAG_VOID"))
            buf.push(_arm64_instr2("movz", _arm64_op_reg("x1"),
                             _arm64_op_label("#0"), "ret void: payload 0"))
        }
        // C7 + cycle h20 — epilogue frees spill_frame + call-overflow
        // region + try-jmp_buf region (all allocated in a single
        // prologue sub; see _arm64_lower_func).
        let epilogue_total = spill_frame + rm.call_overflow_bytes + try_buf_bytes
        if epilogue_total > 0 {
            buf = _hv_sp_adj(buf, "add", epilogue_total, "x15")
        }
        buf.push(_arm64_instr3("ldp", _arm64_op_reg("x29"), _arm64_op_reg("x30"),
                         _arm64_op_label("[sp], #16"), "epilogue: restore fp/lr"))
        buf.push(_arm64_instr0("ret", "return"))
        return buf
    }
    if s.kind == _STMT_BR {
        let lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_arm64_instr1("b", _arm64_op_label(lab), "branch"))
        return buf
    }
    // ── Cycle h20 — try/catch/throw runtime hooks ────────────
    //
    // jmp_buf slot[i] lives at:
    //   [sp, #(call_overflow_bytes + spill_frame + i * 192)]
    // after the prologue `sub sp, total_frame`.
    if s.kind == "try_setjmp" {
        // Compute &jbuf[slot] -> x0, call _setjmp, branch on w0!=0 to catch.
        // On first call setjmp returns 0; push jbuf onto try-stack, then
        // fall through to the try-body (target_block).
        // On longjmp-resumed setjmp returns 1; branch to target_block_else.
        let off = rm.call_overflow_bytes + spill_frame + try_slot_idx * 192
        buf = _hv_at(buf, off, "x15")
        // x15 now holds (sp + off / 16) * 16; _hv_at builds the immediate
        // offset via the scratch — use the helper that yields a register
        // form: `add x15, sp, #off`.
        buf.push(_arm64_instr3("add", _arm64_op_reg("x0"),
                         _arm64_op_reg("sp"),
                         _arm64_op_label("#" + to_string(off)),
                         "try_setjmp: &jbuf[" + to_string(try_slot_idx) + "]"))
        // libc setjmp — Mach-O sym is `_setjmp` (auto-prefixed by _fmt_label).
        // We pass the C name; _fmt_label injects the Darwin `_` prefix.
        buf.push(_arm64_instr1("bl", _arm64_op_label("setjmp"),
                         "try_setjmp: call libc _setjmp"))
        // Branch to catch on nonzero return. cbnz uses w0 (the C int).
        let catch_lab = _arm64_block_label(modhash, fname, s.target_block_else)
        buf.push(_arm64_instr2("cbnz", _arm64_op_reg("w0"),
                         _arm64_op_label(catch_lab),
                         "try_setjmp: rc!=0 -> catch"))
        // First-call path: push jbuf into runtime try-stack.
        buf.push(_arm64_instr3("add", _arm64_op_reg("x0"),
                         _arm64_op_reg("sp"),
                         _arm64_op_label("#" + to_string(off)),
                         "try_setjmp: &jbuf for push"))
        buf.push(_arm64_instr1("bl", _arm64_op_label("__hexa_try_push"),
                         "try_setjmp: register jbuf"))
        // Fall-through into try-body via explicit branch.
        let try_lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_arm64_instr1("b", _arm64_op_label(try_lab),
                         "try_setjmp: enter try body"))
        return buf
    }
    if s.kind == "try_pop" {
        // Normal exit out of try-body — pop the runtime try-stack frame.
        // The fall-through `b after_id` is emitted as a separate STMT_BR.
        buf.push(_arm64_instr1("bl", _arm64_op_label("__hexa_try_pop"),
                         "try_pop: drop jbuf from try-stack"))
        return buf
    }
    if s.kind == "try_last_err" {
        // Catch-block entry — fetch __hexa_last_error() into dst HexaVal.
        // The runtime function returns the HexaVal in x0:x1.
        buf.push(_arm64_instr1("bl", _arm64_op_label("__hexa_last_error"),
                         "try_last_err: HexaVal __hexa_last_error()"))
        if s.dst.id >= 0 {
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == "throw" {
        // Materialize args[0] HexaVal into x0:x1; call hexa_throw (longjmps
        // to the most-recently-pushed try frame, or exits if none).
        if len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
        }
        buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_throw"),
                         "throw: hexa_throw(err)"))
        // hexa_throw never returns (longjmp or exit). No need to emit
        // a fall-through branch — the lowering set has_returned=true so
        // hir_to_mir already terminated the block.
        return buf
    }
    if s.kind == _STMT_BR_COND {
        if len(s.args) > 0 {
            // cond HexaVal → x0:x1; hexa_truthy → int w0; zero-extend
            // (callee leaves upper x0 unspecified) then cbz to else.
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                             "br_cond: truthy → w0"))
            buf.push(_arm64_instr2("uxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "br_cond: zext w0"))
            let else_lab = _arm64_block_label(modhash, fname, s.target_block_else)
            buf.push(_arm64_instr2("cbz", _arm64_op_reg("x0"),
                             _arm64_op_label(else_lab), "br_cond: !truthy -> else"))
        }
        let then_lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_arm64_instr1("b", _arm64_op_label(then_lab), "branch -> then"))
        return buf
    }
    if s.kind == _STMT_UNOP {
        // Unary minus / boolean negation — previously unhandled (asm
        // emitted `nop ; unhandled stmt kind unop`), so `let x = -1`
        // left x's slot uninitialized and `if x<=0` mis-branched.
        // hexa runtime has no `hexa_neg` shim → lower `-x` as
        // `0 - x` through hexa_sub; `!x` / `not x` mirror the `!=`
        // pattern: truthy → eor 1 → box bool.
        if len(s.args) >= 1 {
            if s.op == "-" || s.op == "neg" {
                buf.push(_arm64_instr2("movz", _arm64_op_reg("x0"),
                                 _arm64_op_label("#0"), "unop -: a.tag=TAG_INT"))
                buf.push(_arm64_instr2("movz", _arm64_op_reg("x1"),
                                 _arm64_op_label("#0"), "unop -: a.val=0"))
                buf = _hv_load(buf, s.args[0], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_sub"),
                                 "unop -: 0 - x"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            if s.op == "!" || s.op == "not" {
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                                 "unop !: truthy → w0"))
                buf.push(_arm64_instr3("eor", _arm64_op_reg("x0"),
                                 _arm64_op_reg("x0"), _arm64_op_label("#1"),
                                 "unop !: !truthy"))
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                                 "unop !: box bool"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            // Unknown unop — pass value through (closer to no-op than
            // an uninitialized slot, and surfaces visibly in output).
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == "load" {
        if len(s.args) >= 1 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x10")
            let base_op = _arm64_op_resolve(s.args[0], st, rm, "x10")
            let mut off = 0
            if len(s.args) >= 2 && s.args[1].kind == "const_int" {
                off = s.args[1].int_val
            }
            let dst = _arm64_op_reg(_arm64_dst_reg(rm, s.dst.id))
            buf.push(_arm64_instr2("ldr", dst, _arm64_op_mem(base_op.reg.name, off),
                             "load"))
            buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == "store" {
        if len(s.args) >= 2 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x10")
            buf = _arm64_op_rm(buf, s.args[1], st, rm, "x11")
            let base_op = _arm64_op_resolve(s.args[0], st, rm, "x10")
            let src = _arm64_op_resolve(s.args[1], st, rm, "x11")
            let mut off = 0
            if len(s.args) >= 3 && s.args[2].kind == "const_int" {
                off = s.args[2].int_val
            }
            buf.push(_arm64_instr2("str", src, _arm64_op_mem(base_op.reg.name, off),
                             "store"))
        }
        return buf
    }
    buf.push(_arm64_instr0("nop", "unhandled stmt kind " + s.kind))
    return buf
}

// ── Function lowering ────────────────────────────────────────

fn _arm64_lower_func(mf: MFunc, st: ArmStrTab, modhash: string) -> LFunc {
    let mut instrs = []

    // #26 self-host fixpoint — forced-copy the MFunc identity fields up
    // front, before the block-emit loop. `mf.name` / `mf.def_line` are
    // read repeatedly (block-def label, every per-stmt `_emit_arm64_stmt`
    // call, the final LFunc literal). Each `_emit_arm64_stmt` returns a
    // TAG_ARRAY routed through `__hexa_fn_arena_return` → the fn-arena
    // rewinds; an arena-resident `mf` map's string storage is then
    // invalidated, so a *later* `mf.name` read returns TAG_VOID and
    // `mf.blocks` / `mf.def_line` become map-misses. Self-compiled ap2
    // showed exactly this: first block label correct (`__L…_main_bb0`)
    // but `.globl void` + "map key 'name'/'blocks'/'def_line' not found".
    // Snapshotting once (string via the F6 forced-copy substring idiom,
    // see _arm64_strtab_lookup P0b / _collect_strs P0a / _lower_fn P0c-2)
    // gives every downstream read an arena-independent handle. ap1 (heap,
    // single-read paths) is byte-identical; only the repeated cross-
    // arena-boundary reads in this fn change source.
    let fn_name = mf.name.substring(0, len(mf.name))
    let fn_def_line = mf.def_line

    // C6 — run linear-scan regalloc up front so the prologue can size
    // the spill frame and the body can resolve operands through the
    // assigned RegMap.
    let alloc = _arm64_assign_regs(mf)
    let spill_frame = alloc.frame_size

    // C7 — pre-allocate the maximum outgoing-call overflow region in
    // bytes (16-aligned). Reused by every call site in this fn so we
    // don't sub/add sp mid-frame. SSA spill offsets are shifted above
    // this region via rm.call_overflow_bytes (see _arm_spill_offset).
    //
    // #27 self-host fixpoint — STRIDE FIX. `max_overflow` is a count of
    // overflow ARGS (n - 4, see _arm64_max_call_overflow). Each overflow
    // arg is a 16-byte HexaVal occupying a full register PAIR, and the
    // C7 call-site emit writes arg i at `[sp, #(i-4)*16]` (16-byte
    // stride, see "C7: stack arg" below). The reserved region must
    // therefore be `max_overflow * 16` bytes. The previous `* 8` sized
    // it for an 8-byte scalar stride — exactly HALF — so the SSA/param
    // spill region was shifted up by only half the overflow span. A
    // saved ingress param (e.g. `module` at [sp,#16] in
    // _collect_item_types) then aliased the outgoing "stack arg 5" slot
    // (`(5-4)*16 = 16`): the call's 6th arg overwrote the caller's own
    // first parameter HexaVal (tag flipped MAP→STR), surfacing as
    // `map key 'items'/'children'/... not found` + a 1032-wide spurious
    // HX2001 cascade when the self-hosted compiler (ap2) compiled the
    // full compiler. ap1 (hexa_v2 C path) computes frames correctly so
    // the bug was masked until the asm codegen self-hosted. Same value-
    // across-call-boundary class as #25/#26, distinct site (frame sizer,
    // not arena runtime). 16-aligned already (max_overflow*16 is a
    // multiple of 16); the round kept for defensive clarity.
    let max_overflow = _arm64_max_call_overflow(mf)
    let mut call_overflow_bytes = 0
    if max_overflow > 0 {
        call_overflow_bytes = ((max_overflow * 16 + 15) / 16) * 16
    }
    let rm = RegMap {
        ids: alloc.map.ids,
        regs: alloc.map.regs,
        slots: alloc.map.slots,
        call_overflow_bytes: call_overflow_bytes
    }
    // Cycle h20 — reserve jmp_buf region above the spill area. Each try
    // gets one 192-byte slot (16-aligned by construction).
    let try_count = _arm64_count_try_setjmp(mf)
    let try_buf_bytes = try_count * _ARM64_JMP_BUF_BYTES
    let total_frame = spill_frame + call_overflow_bytes + try_buf_bytes

    // Prologue
    instrs.push(_arm64_instr3(
        "stp",
        _arm64_op_reg("x29"),
        _arm64_op_reg("x30"),
        _arm64_op_label("[sp, #-16]!"),
        "prologue: save fp/lr"
    ))
    instrs.push(_arm64_instr2("mov", _arm64_op_reg("x29"), _arm64_op_reg("sp"), "prologue: set fp"))

    // Entry argv wiring. `_main` is the C-ABI process entry (Darwin
    // `_start` → `main(argc, argv, envp)`): x0=argc, x1=argv on entry.
    // The hexa `fn main()` takes no params, so x0/x1 are otherwise
    // unused — but `args()` / `hexa_args()` need them stashed. hexa_v2's
    // C path emits `int main(argc,argv){ hexa_set_args(argc,argv); … }`;
    // the direct-asm path must do the same or every aprime_cc-built
    // program sees an empty argv (self-host blocker — the 2nd-gen
    // compiler reported "missing SOURCE.hexa" for every invocation).
    // Insert `bl _hexa_set_args` here, before the frame `sub` and any
    // body code clobbers x0/x1. stp/mov above do not touch x0/x1; bl's
    // x30 clobber is safe (lr already saved, dead until epilogue).
    if fn_name == "main" {
        instrs.push(_arm64_instr1("bl", _arm64_op_label("hexa_set_args"),
                         "entry: wire argc/argv -> hexa_set_args"))
    }

    // Spill-frame allocation (after fp/lr save). Covers both the SSA
    // spill region (top) and the outgoing-call overflow region (bottom).
    if total_frame > 0 {
        instrs = _hv_sp_adj(instrs, "sub", total_frame, "x15")
    }

    // Path A (A′): each 16B HexaVal param arrives in a register PAIR
    // (param0→x0:x1, param1→x2:x3, param2→x4:x5, param3→x6:x7); params
    // ≥4 arrive in caller 16B stack slots above the saved fp/lr at
    // [x29, #16 + (p-4)*16]. Store each into the param's 16B frame slot
    // (all params are force-spilled). x29 set to old sp before the
    // frame `sub`, so [x29,#16+…] reaches the caller's outgoing area.
    let mut p = 0
    while p < len(mf.params) {
        let pid = mf.params[p].id
        let poff = _arm_spill_offset(rm, pid)
        if p < 4 {
            let lo = "x" + to_string(p * 2)
            let hi = "x" + to_string(p * 2 + 1)
            instrs = _hv_at(instrs, poff, "x15")
            instrs.push(_arm64_instr3("stp", _arm64_op_reg(lo),
                             _arm64_op_reg(hi), _hv_memb(poff, "x15"),
                             "ingress param " + to_string(p)))
        } else {
            let inoff = 16 + (p - 4) * 16
            instrs.push(_arm64_instr3("ldp", _arm64_op_reg("x9"),
                             _arm64_op_reg("x10"),
                             _arm64_op_label("[x29, #" + to_string(inoff) + "]"),
                             "ingress stack param " + to_string(p)))
            instrs = _hv_at(instrs, poff, "x15")
            instrs.push(_arm64_instr3("stp", _arm64_op_reg("x9"),
                             _arm64_op_reg("x10"), _hv_memb(poff, "x15"),
                             "store stack param " + to_string(p)))
        }
        p = p + 1
    }

    // #26 — snapshot the block list once. `mf.blocks` is otherwise
    // re-read every loop trip across the `_emit_arm64_stmt` arena-return
    // boundary (same hazard as fn_name/fn_def_line above): an arena-
    // resident `mf` map invalidated by the rewind makes `mf.blocks` a
    // map-miss (len 0) after the first statement, truncating the body.
    let mf_blocks = mf.blocks
    let mut _try_idx = 0
    let mut bi = 0
    while bi < len(mf_blocks) {
        let blk = mf_blocks[bi]
        instrs.push(_arm64_instr0("label", _arm64_block_label(modhash, fn_name, blk.id)))
        let mut si = 0
        while si < len(blk.stmts) {
            // #18 codegen-perf — per-statement delta accumulation. The
            // prior `instrs = _emit_arm64_stmt(instrs,…)` re-returned the
            // whole growing `instrs` array every statement; the runtime's
            // fn-arena return path (__hexa_fn_arena_return → hexa_val_
            // heapify) deep-walks every element of a returned TAG_ARRAY,
            // so threading the accumulator cost Σ O(len instrs) = O(N²)
            // on a large single function. Pass a FRESH `[]` so each call
            // returns only that statement's instructions (~5 elems →
            // O(1) heapify), then append the delta into `instrs`. `instrs`
            // itself is heapified just once, when _arm64_lower_func
            // returns its LFunc — O(total). Byte-identical: same instrs in
            // the same order, only the accumulation cadence changed.
            // Cycle h20: assign monotonic slot indices to STMT_TRY_SETJMP
            // / STMT_TRY_POP pairs so each try has its own jmp_buf slot.
            // STMT_TRY_POP uses the SETJMP's slot, so we don't bump on POP.
            let cur_try_idx = _try_idx
            if blk.stmts[si].kind == "try_setjmp" { _try_idx = _try_idx + 1 }
            let delta = _emit_arm64_stmt([], modhash, fn_name,
                                         blk.stmts[si], st, rm, spill_frame,
                                         try_buf_bytes, cur_try_idx)
            let mut _di = 0
            while _di < len(delta) {
                instrs.push(delta[_di])
                _di = _di + 1
            }
            si = si + 1
        }
        bi = bi + 1
    }

    // Safety epilogue (in case last block lacks _STMT_RETURN)
    let last_is_ret = false
    if len(instrs) > 0 {
        let last = instrs[len(instrs) - 1]
        if last.op == "ret" {
            return LFunc {
                name: fn_name,
                target: "arm64-apple-darwin",
                instrs: instrs,
                frame_size: 16 + total_frame,
                callee_saved: [],
                def_line: fn_def_line
            }
        }
    }
    // #40 — fall-through epilogue also hands back a real TAG_VOID HexaVal
    // (x0:x1), matching the value-less STMT_RETURN path above; a function
    // reaching here without an explicit return yields void.
    instrs.push(_arm64_instr2("movz", _arm64_op_reg("x0"),
                        _arm64_op_label("#4"), "ret void: TAG_VOID"))
    instrs.push(_arm64_instr2("movz", _arm64_op_reg("x1"),
                        _arm64_op_label("#0"), "ret void: payload 0"))
    if total_frame > 0 {
        instrs = _hv_sp_adj(instrs, "add", total_frame, "x15")
    }
    instrs.push(_arm64_instr3("ldp", _arm64_op_reg("x29"), _arm64_op_reg("x30"),
                        _arm64_op_label("[sp], #16"), "epilogue: restore fp/lr"))
    instrs.push(_arm64_instr0("ret", "return"))

    return LFunc {
        name: fn_name,
        target: "arm64-apple-darwin",
        instrs: instrs,
        frame_size: 16 + total_frame,
        callee_saved: [],
        def_line: fn_def_line
    }
}

// ── String table collection (for rodata emission) ────────────
//
// Walk every Stmt in every Block in every Func looking for
// `const_str` operands and record them in an ArmStrTab. Each unique
// literal gets label ".LCstr<N>" (N = insertion order). Both targets
// share this label scheme so rodata labels remain stable per source
// independently of the chosen target.

fn _collect_strs_from_stmt(st: ArmStrTab, s: Stmt) -> ArmStrTab {
    let mut out = st
    let mut i = 0
    while i < len(s.args) {
        let o = s.args[i]
        if o.kind == "const_str" {
            if len(_arm64_strtab_lookup(out, o.str_val)) == 0 {
                let mut keys = out.keys
                let mut labs = out.labels
                let n = len(keys)
                // F6 P0a — forced copy: o.str_val is the MFunc operand's
                // string handle; st outlives every streaming iteration, so
                // it must own its keys independently of any MFunc.
                // PLAN-stage3-footprint-F6.md.
                keys.push(o.str_val.substring(0, len(o.str_val)))
                labs.push(".LCstr" + to_string(n))
                out = ArmStrTab {
                    keys: keys, labels: labs,
                    fkeys: out.fkeys, flabels: out.flabels,
                    ftexts: out.ftexts
                }
            }
        }
        if o.kind == "const_float" {
            out = _arm64_float_intern(out, o.float_val, o.str_val)
        }
        i = i + 1
    }
    return out
}

// F1 (streaming footprint) — per-MFunc string-literal interning. The
// streaming codegen path (compiler/codegen/stream.hexa, PLAN-stage3-
// footprint.md F2) calls this once per function as it is lowered, so
// the ArmStrTab grows incrementally and the whole MModule never has to
// be materialised. Label assignment is insertion-ordered, so the table
// is byte-deterministic regardless of call cadence — incremental and
// whole-module interning produce bit-identical rodata.
fn _arm_strtab_collect_fn(st: ArmStrTab, f: MFunc) -> ArmStrTab {
    let mut acc = st
    let mut bi = 0
    while bi < len(f.blocks) {
        let blk = f.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            acc = _collect_strs_from_stmt(acc, blk.stmts[si])
            si = si + 1
        }
        bi = bi + 1
    }
    return acc
}

// Whole-module strtab — the non-streaming path. Now a thin fold over
// _arm_strtab_collect_fn so both paths share one collector (no drift).
fn _build_arm_strtab(module: MModule) -> ArmStrTab {
    let mut st = ArmStrTab { keys: [], labels: [], fkeys: [], flabels: [], ftexts: [] }
    let mut fi = 0
    while fi < len(module.funcs) {
        st = _arm_strtab_collect_fn(st, module.funcs[fi])
        fi = fi + 1
    }
    return st
}

// Convert a string into a hex-encoded byte sequence (per-LSection
// payload format defined by lir.hexa). Appends a NUL terminator so
// the rodata entry is C-string compatible.
fn _hex_nibble(n: i64) -> string {
    if n == 0  { return "0" }
    if n == 1  { return "1" }
    if n == 2  { return "2" }
    if n == 3  { return "3" }
    if n == 4  { return "4" }
    if n == 5  { return "5" }
    if n == 6  { return "6" }
    if n == 7  { return "7" }
    if n == 8  { return "8" }
    if n == 9  { return "9" }
    if n == 10 { return "a" }
    if n == 11 { return "b" }
    if n == 12 { return "c" }
    if n == 13 { return "d" }
    if n == 14 { return "e" }
    return "f"
}

fn _byte_to_hex(b: i64) -> string {
    let hi = b / 16
    let lo = b - hi * 16
    return _hex_nibble(hi) + _hex_nibble(lo)
}

// Manual ASCII codepoint lookup. Stage0 hexa has no `ord`/codepoint
// primitive surfaced to user code, so we hard-code the printable
// range that real-world tests touch.
fn _ascii_code(ch: string) -> i64 {
    if ch == " " { return 32 }
    if ch == "!" { return 33 }
    if ch == "\"" { return 34 }
    if ch == "#" { return 35 }
    if ch == "$" { return 36 }
    if ch == "%" { return 37 }
    if ch == "&" { return 38 }
    if ch == "'" { return 39 }
    if ch == "(" { return 40 }
    if ch == ")" { return 41 }
    if ch == "*" { return 42 }
    if ch == "+" { return 43 }
    if ch == "," { return 44 }
    if ch == "-" { return 45 }
    if ch == "." { return 46 }
    if ch == "/" { return 47 }
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == ":" { return 58 }
    if ch == ";" { return 59 }
    if ch == "<" { return 60 }
    if ch == "=" { return 61 }
    if ch == ">" { return 62 }
    if ch == "?" { return 63 }
    if ch == "@" { return 64 }
    if ch == "A" { return 65 }
    if ch == "B" { return 66 }
    if ch == "C" { return 67 }
    if ch == "D" { return 68 }
    if ch == "E" { return 69 }
    if ch == "F" { return 70 }
    if ch == "G" { return 71 }
    if ch == "H" { return 72 }
    if ch == "I" { return 73 }
    if ch == "J" { return 74 }
    if ch == "K" { return 75 }
    if ch == "L" { return 76 }
    if ch == "M" { return 77 }
    if ch == "N" { return 78 }
    if ch == "O" { return 79 }
    if ch == "P" { return 80 }
    if ch == "Q" { return 81 }
    if ch == "R" { return 82 }
    if ch == "S" { return 83 }
    if ch == "T" { return 84 }
    if ch == "U" { return 85 }
    if ch == "V" { return 86 }
    if ch == "W" { return 87 }
    if ch == "X" { return 88 }
    if ch == "Y" { return 89 }
    if ch == "Z" { return 90 }
    if ch == "[" { return 91 }
    if ch == "\\" { return 92 }
    if ch == "]" { return 93 }
    if ch == "^" { return 94 }
    if ch == "_" { return 95 }
    if ch == "`" { return 96 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    if ch == "g" { return 103 }
    if ch == "h" { return 104 }
    if ch == "i" { return 105 }
    if ch == "j" { return 106 }
    if ch == "k" { return 107 }
    if ch == "l" { return 108 }
    if ch == "m" { return 109 }
    if ch == "n" { return 110 }
    if ch == "o" { return 111 }
    if ch == "p" { return 112 }
    if ch == "q" { return 113 }
    if ch == "r" { return 114 }
    if ch == "s" { return 115 }
    if ch == "t" { return 116 }
    if ch == "u" { return 117 }
    if ch == "v" { return 118 }
    if ch == "w" { return 119 }
    if ch == "x" { return 120 }
    if ch == "y" { return 121 }
    if ch == "z" { return 122 }
    if ch == "{" { return 123 }
    if ch == "|" { return 124 }
    if ch == "}" { return 125 }
    if ch == "~" { return 126 }
    if ch == "\n" { return 10 }
    if ch == "\t" { return 9 }
    return 63 // '?' for unknown (non-ASCII / control)
}

// Byte-true value of a single-byte string element (as produced by
// `s.chars()` in the hexa runtime, where each entry is one source
// byte regardless of UTF-8 codepoint boundaries). `_ascii_code` only
// covers ASCII printable + a few escapes and returns 63 ('?') for
// anything else, which mangled every non-ASCII rodata byte and made
// `"├── " == "└── "` true (both became `???????? `). Use
// `char_code_at` — the runtime builtin maps to hexa_str_char_code_at
// which returns the underlying byte value 0..255 for high-bit bytes.
fn _byte_code(ch: string) -> i64 {
    if len(ch) == 0 { return 0 }
    return char_code(ch)
}

fn _str_to_hex_bytes(s: string) -> string {
    // Cycle 39: `s.chars()` returns UTF-8 CODEPOINTS (since 2026-05-19
    // parity-gate t45b). _byte_code(cs[i]) only returns the FIRST BYTE
    // of each multi-byte codepoint, dropping continuation bytes. That
    // truncated em-dashes / box-drawing chars / arrows in string
    // literals → gen1.s (aprime via hexa_v2→C→clang) preserved them
    // via clang's static rodata, but gen2.s (hexac via aprime emit-asm
    // → asm path) lost them through this pool. Use `s.bytes()` which
    // returns per-byte i64 entries (raw 0..255), preserving UTF-8.
    let bs = s.bytes()
    let mut out = ""
    let mut i = 0
    while i < len(bs) {
        out = out + _byte_to_hex(bs[i])
        i = i + 1
    }
    out = out + "00" // NUL terminator
    return out
}

fn _strtab_to_rodata(st: ArmStrTab) -> [LSection] {
    let mut out: [LSection] = []
    let mut i = 0
    while i < len(st.keys) {
        out.push(LSection {
            name: st.labels[i],
            bytes: _str_to_hex_bytes(st.keys[i]),
            align: 0
        })
        i = i + 1
    }
    return out
}

// ── Module entry point ───────────────────────────────────────

pub fn codegen_arm64_darwin(module: MModule) -> LModule {
    let st = _build_arm_strtab(module)
    let mut funcs = []
    let mut i = 0
    while i < len(module.funcs) {
        // Stage1 C8 — recompute modhash inline at every call site so
        // stage0's transitive-let binding gap (see _STMT_* mirror at
        // top of this file) cannot hand the lowering pass a void.
        funcs.push(_arm64_lower_func(module.funcs[i], st, _arm64_modhash(module.file)))
        i = i + 1
    }
    // Emit a writable 16-byte slot per module-level mutable global
    // (symbol `g<id>`). Runtime init via the parser's synthetic-main
    // `g<id> = E` assign — see hir_to_mir global resolution.
    // Mach-O user symbols carry a leading `_` prefix; the codegen's
    // `g<id>` references resolve to `_g<id>` (matching `_hexa_…`
    // builtins). Emit the data label with the same prefix so the link
    // resolves to one symbol — without this the linker reports
    // `_g0 undefined` even though `g0:` exists in `__DATA,__data`.
    let mut gnames: [string] = []
    let mut gi = 0
    while gi < len(module.globals) {
        gnames.push("_g" + to_string(module.globals[gi].id))
        gi = gi + 1
    }
    // Float-pool entries from the strtab → LFloat list. `.LC*` is a
    // local label (no `_` prefix needed) per the existing strtab
    // convention; the use-site references it as-is. Prefer the
    // captured source text (full literal precision) over a
    // `to_string(f64)` round-trip which truncates to ~6 digits in
    // stage0 — see the comment on ArmStrTab.ftexts above.
    let mut flts: [LFloat] = []
    let mut fp = 0
    while fp < len(st.fkeys) {
        let mut ftext = st.ftexts[fp]
        if len(ftext) == 0 { ftext = to_string(st.fkeys[fp]) }
        flts.push(LFloat {
            label: st.flabels[fp],
            text: ftext
        })
        fp = fp + 1
    }
    return LModule {
        file: module.file,
        target: "arm64-apple-darwin",
        funcs: funcs,
        rodata: _strtab_to_rodata(st),
        bss: [],
        globals: gnames,
        floats: flts
    }
}
