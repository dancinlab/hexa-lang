// HEXA Native Compiler — Codegen / arm64-apple-darwin (Phase A1)
//
// @version 0.1.0
// @capabilities [pure]
// @allow-relop-banned-file  — codegen path uses `>=`/`<=` for arity
//   guards and signed-id checks; C6 regalloc inherits the same need.
//
// Lowers MIR (SSA CFG) -> LIR (target-specific instructions) for the
// arm64-apple-darwin target.
//
//   pub fn codegen_arm64_darwin(module: MModule) -> LModule
//
// ABI: AAPCS64
//   - Integer args: x0..x7 (overflow on stack — v1 ignored, tiny tests only)
//   - Integer return: x0
//   - Frame pointer: x29 (fp), Link register: x30 (lr)
//   - Stack pointer: 16-byte aligned at function boundaries
//
// Per MFunc layout:
//   prologue:
//       stp x29, x30, [sp, #-16]!
//       mov x29, sp
//   <block instrs>
//   epilogue:
//       ldp x29, x30, [sp], #16
//       ret
//
// v1 register policy:
//   Naive — Local id N -> register x(N % 31).  No spilling, no liveness.
//   Tier-0 tier verification only; tiny test cases fit in <31 locals.
//
// Constraints (from RFC-018 §4):
//   - struct >16B by reference (not handled v1)
//   - hidden first arg for >16B return (not handled v1)

import "../ir/mir.hexa"
import "../ir/lir.hexa"

// ── Local mirror of mir.hexa STMT_* constants ────────────────
// See note in compiler/lower/hir_to_mir.hexa: stage0's interpreter does
// not propagate transitive `pub let` bindings, so STMT_* arrive here as
// the void value. Redeclaring locally keeps codegen dispatch working.
let _STMT_ASSIGN   = "assign"
let _STMT_BINOP    = "binop"
let _STMT_UNOP     = "unop"
let _STMT_CALL     = "call"
let _STMT_RETURN   = "return"
let _STMT_BR       = "br"
let _STMT_BR_COND  = "br_cond"

// ── PReg / LOperand helpers ──────────────────────────────────

fn _preg_gpr(name: string) -> PReg {
    return PReg { name: name, kind: "gpr" }
}

fn _empty_preg() -> PReg {
    return PReg { name: "", kind: "" }
}

fn _op_reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: _preg_gpr(name),
        imm: 0,
        mem_base: _empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _op_imm(value: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: _empty_preg(),
        imm: value,
        mem_base: _empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _op_label(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: _empty_preg(),
        imm: 0,
        mem_base: _empty_preg(),
        mem_offset: 0,
        label: name
    }
}

fn _op_mem(base: string, offset: i64) -> LOperand {
    return LOperand {
        kind: "mem",
        reg: _empty_preg(),
        imm: 0,
        mem_base: _preg_gpr(base),
        mem_offset: offset,
        label: ""
    }
}

fn _instr0(op: string, comment: string) -> LInstr {
    return LInstr { op: op, args: [], comment: comment }
}

fn _instr1(op: string, a: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _instr2(op: string, a: LOperand, b: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _instr3(op: string, a: LOperand, b: LOperand, c: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    xs.push(c)
    return LInstr { op: op, args: xs, comment: comment }
}

// ── Register assignment (naive fallback) ─────────────────────
//
// Used only when no RegMap is available. Production codegen runs
// through `_arm64_assign_regs` (linear scan, Poletto-Sarkar 1999)
// and `_arm_reg_lookup` below.

fn _arm64_reg_for_local(local_id: i64) -> string {
    let mut idx = local_id
    if idx < 0 { idx = 0 }
    let m = idx - (idx / 31) * 31
    return "x" + to_string(m)
}

// ── C6 — Linear-scan register allocator (arm64) ──────────────
pub struct RegMap {
    ids: [i64],
    regs: [string],
    slots: [i64]
}

pub struct ArmAllocResult {
    map: RegMap,
    frame_size: i64
}

pub struct ArmIntervals {
    ids: [i64],
    starts: [i64],
    ends: [i64]
}

fn _arm_pool_init() -> [string] {
    let mut p: [string] = []
    p.push("x10")
    p.push("x11")
    p.push("x12")
    p.push("x13")
    p.push("x14")
    p.push("x15")
    p.push("x19")
    p.push("x20")
    p.push("x21")
    p.push("x22")
    p.push("x23")
    p.push("x24")
    p.push("x25")
    p.push("x26")
    p.push("x27")
    p.push("x28")
    return p
}

fn _arm_index_of(ids: [i64], id: i64) -> i64 {
    let mut i = 0
    while i < len(ids) {
        if ids[i] == id { return i }
        i = i + 1
    }
    return -1
}

fn _arm_compute_live_ranges(mf: MFunc) -> ArmIntervals {
    let mut ids: [i64] = []
    let mut starts: [i64] = []
    let mut ends: [i64] = []

    let mut li = 0
    while li < len(mf.locals) {
        let id = mf.locals[li].id
        if id >= 0 && _arm_index_of(ids, id) < 0 {
            ids.push(id)
            starts.push(-1)
            ends.push(-1)
        }
        li = li + 1
    }

    let mut pi = 0
    while pi < len(mf.params) {
        let pid = mf.params[pi].id
        let idx = _arm_index_of(ids, pid)
        if idx >= 0 {
            if starts[idx] < 0 { starts[idx] = 0 }
            if ends[idx] < 0   { ends[idx] = 0 }
        }
        pi = pi + 1
    }

    let mut pos = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            let s = blk.stmts[si]
            let did = s.dst.id
            if did >= 0 {
                let mut idx = _arm_index_of(ids, did)
                if idx < 0 {
                    ids.push(did)
                    starts.push(pos)
                    ends.push(pos)
                    idx = len(ids) - 1
                } else {
                    if starts[idx] < 0 || pos < starts[idx] { starts[idx] = pos }
                    if pos > ends[idx] { ends[idx] = pos }
                }
            }
            let mut ai = 0
            while ai < len(s.args) {
                let o = s.args[ai]
                if o.kind == "local" {
                    let lid = o.local_id
                    if lid >= 0 {
                        let mut idx2 = _arm_index_of(ids, lid)
                        if idx2 < 0 {
                            ids.push(lid)
                            starts.push(pos)
                            ends.push(pos)
                            idx2 = len(ids) - 1
                        } else {
                            if starts[idx2] < 0 || pos < starts[idx2] {
                                starts[idx2] = pos
                            }
                            if pos > ends[idx2] { ends[idx2] = pos }
                        }
                    }
                }
                ai = ai + 1
            }
            pos = pos + 1
            si = si + 1
        }
        bi = bi + 1
    }
    return ArmIntervals { ids: ids, starts: starts, ends: ends }
}

fn _arm64_assign_regs(mf: MFunc) -> ArmAllocResult {
    let iv = _arm_compute_live_ranges(mf)
    let n = len(iv.ids)
    let mut order: [i64] = []
    let mut k = 0
    while k < n {
        if iv.starts[k] >= 0 { order.push(k) }
        k = k + 1
    }
    let mut a = 1
    while a < len(order) {
        let key = order[a]
        let key_start = iv.starts[key]
        let mut b = a - 1
        while b >= 0 && iv.starts[order[b]] > key_start {
            order[b + 1] = order[b]
            b = b - 1
        }
        order[b + 1] = key
        a = a + 1
    }

    let mut map_ids: [i64] = []
    let mut map_regs: [string] = []
    let mut map_slots: [i64] = []
    let mut j = 0
    while j < n {
        map_ids.push(iv.ids[j])
        map_regs.push("")
        map_slots.push(-1)
        j = j + 1
    }

    let mut p = 0
    while p < len(mf.params) {
        if p < 8 {
            let pid = mf.params[p].id
            let idx = _arm_index_of(iv.ids, pid)
            if idx >= 0 {
                map_regs[idx] = "x" + to_string(p)
            }
        }
        p = p + 1
    }

    let mut pool = _arm_pool_init()
    let mut active_idx: [i64] = []
    let mut next_slot: i64 = 0

    let mut s = 0
    while s < len(order) {
        let cur = order[s]
        let cur_start = iv.starts[cur]

        let mut keep: [i64] = []
        let mut e = 0
        while e < len(active_idx) {
            let ai = active_idx[e]
            if iv.ends[ai] < cur_start {
                let was = map_regs[ai]
                let mut is_param = false
                let mut pp = 0
                while pp < len(mf.params) {
                    if mf.params[pp].id == iv.ids[ai] { is_param = true }
                    pp = pp + 1
                }
                if !is_param && len(was) > 0 && map_slots[ai] < 0 {
                    pool.push(was)
                }
            } else {
                keep.push(ai)
            }
            e = e + 1
        }
        active_idx = keep

        if len(map_regs[cur]) > 0 {
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
            s = s + 1
            continue
        }

        if len(pool) > 0 {
            let r = pool[0]
            let mut np: [string] = []
            let mut tt = 1
            while tt < len(pool) {
                np.push(pool[tt])
                tt = tt + 1
            }
            pool = np
            map_regs[cur] = r
            map_slots[cur] = -1
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
        } else {
            let mut victim_pos = len(active_idx) - 1
            while victim_pos >= 0 {
                let v = active_idx[victim_pos]
                let mut is_param = false
                let mut pp = 0
                while pp < len(mf.params) {
                    if mf.params[pp].id == iv.ids[v] { is_param = true }
                    pp = pp + 1
                }
                if !is_param { break }
                victim_pos = victim_pos - 1
            }

            if victim_pos >= 0 && iv.ends[active_idx[victim_pos]] > iv.ends[cur] {
                let v = active_idx[victim_pos]
                map_regs[cur] = map_regs[v]
                map_slots[cur] = -1
                map_regs[v] = ""
                map_slots[v] = next_slot
                next_slot = next_slot + 8
                let mut na: [i64] = []
                let mut t = 0
                while t < len(active_idx) {
                    if t != victim_pos { na.push(active_idx[t]) }
                    t = t + 1
                }
                let cur_end = iv.ends[cur]
                let mut na2: [i64] = []
                let mut placed = false
                let mut tt = 0
                while tt < len(na) {
                    if !placed && iv.ends[na[tt]] > cur_end {
                        na2.push(cur)
                        placed = true
                    }
                    na2.push(na[tt])
                    tt = tt + 1
                }
                if !placed { na2.push(cur) }
                active_idx = na2
            } else {
                map_regs[cur] = ""
                map_slots[cur] = next_slot
                next_slot = next_slot + 8
            }
        }
        s = s + 1
    }

    let mut frame = next_slot
    let rem = frame - (frame / 16) * 16
    if rem != 0 { frame = frame + (16 - rem) }

    let map = RegMap { ids: map_ids, regs: map_regs, slots: map_slots }
    return ArmAllocResult { map: map, frame_size: frame }
}

fn _arm_reg_lookup(rm: RegMap, id: i64) -> string {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return _arm64_reg_for_local(id) }
    if rm.slots[idx] >= 0 { return "x9" }
    if len(rm.regs[idx]) == 0 { return _arm64_reg_for_local(id) }
    return rm.regs[idx]
}

fn _arm_is_spilled(rm: RegMap, id: i64) -> bool {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return false }
    return rm.slots[idx] >= 0
}

fn _arm_spill_offset(rm: RegMap, id: i64) -> i64 {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return 0 }
    return rm.slots[idx]
}

// String literal → rodata label map. `keys[i]` is a literal string
// (the const_str payload); `labels[i]` is the assigned ".LCstrN"
// label (without the platform underscore prefix). Built once per
// module before func lowering and threaded into every operand
// resolution. `pub` is required because stage0 cannot resolve struct
// field types across imports without it.
pub struct ArmStrTab {
    keys: [string],
    labels: [string]
}

fn _arm64_strtab_lookup(st: ArmStrTab, s: string) -> string {
    let mut i = 0
    while i < len(st.keys) {
        if st.keys[i] == s { return st.labels[i] }
        i = i + 1
    }
    return ""
}

fn _arm64_op_for_operand_st(o: Operand, st: ArmStrTab) -> LOperand {
    if o.kind == "local" {
        return _op_reg(_arm64_reg_for_local(o.local_id))
    }
    if o.kind == "const_int" {
        return _op_imm(o.int_val)
    }
    if o.kind == "global" {
        return _op_label("g" + to_string(o.global_id))
    }
    if o.kind == "const_str" {
        let lbl = _arm64_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _op_label(lbl) }
        return _op_label(o.str_val)
    }
    // fallback: treat as imm 0
    return _op_imm(0)
}

// Backwards-compatible operand resolver — used where no strtab is
// available (e.g. trivial tests without string literals). Strings
// flow through unchanged (label = literal string), which only
// matters for modules that never produce a const_str operand.
fn _arm64_op_for_operand(o: Operand) -> LOperand {
    let st = ArmStrTab { keys: [], labels: [] }
    return _arm64_op_for_operand_st(o, st)
}

// ── Block label helper ───────────────────────────────────────
//
// Apple ARM64 uses `L<name>` as the conventional local-label form
// for compiler-generated labels within a function. We emit them with
// a leading `_` prefix so the asm-text emit pass leaves them alone
// (its `_fmt_label` skips labels that already begin with '.' or
// '_'). Without this, branch operand references would be re-prefixed
// to `__Lname` while the definition stays bare `Lname:`, breaking
// the branch.
// Stage1 C8 — modhash = first 4 hex of sha256(module.file).
// Disambiguates spliced modules sharing the same fn name.
fn _arm64_modhash(file: string) -> string {
    let h = sha256(file)
    if len(h) > 3 { return h.substring(0, 4) }
    return h
}

fn _arm64_block_label(modhash: string, fname: string, block_id: i64) -> string {
    return "_L" + modhash + "_" + fname + "_bb" + to_string(block_id)
}

// ── Binop classification ─────────────────────────────────────
//
// Lower (compiler/lower/hir_to_mir.hexa) carries the source-level
// operator text in `Stmt.op` (e.g. "+", "-", "*", "==", "<"). The
// older codegen path also accepted normalized aliases ("add",
// "sub", ...). We accept both. String concat is recognised as a
// dedicated `concat` op (or `+` over string operands once typed-MIR
// lands — until then, lower must emit `concat` explicitly for
// string + string).

fn _is_arith_add(op: string) -> bool { return op == "add" || op == "+" }
fn _is_arith_sub(op: string) -> bool { return op == "sub" || op == "-" }
fn _is_arith_mul(op: string) -> bool { return op == "mul" || op == "*" }
fn _is_arith_div(op: string) -> bool { return op == "div" || op == "/" }
fn _is_bit_and(op: string) -> bool   { return op == "and" || op == "&" }
fn _is_bit_or(op: string) -> bool    { return op == "or"  || op == "|" }
fn _is_bit_xor(op: string) -> bool   { return op == "xor" || op == "^" }
fn _is_concat(op: string) -> bool    { return op == "concat" }

// arm64 cset condition mnemonic for a source comparison op.
// Returns "" if not a comparison.
fn _arm64_cmp_cond(op: string) -> string {
    if op == "cmp_eq" || op == "==" { return "eq" }
    if op == "cmp_ne" || op == "!=" { return "ne" }
    if op == "cmp_lt" || op == "<"  { return "lt" }
    if op == "cmp_le" || op == "<=" { return "le" }
    if op == "cmp_gt" || op == ">"  { return "gt" }
    if op == "cmp_ge" || op == ">=" { return "ge" }
    return ""
}

// AAPCS64 integer arg sequence.
fn _arm64_arg_reg(idx: i64) -> string {
    if idx == 0 { return "x0" }
    if idx == 1 { return "x1" }
    if idx == 2 { return "x2" }
    if idx == 3 { return "x3" }
    if idx == 4 { return "x4" }
    if idx == 5 { return "x5" }
    if idx == 6 { return "x6" }
    if idx == 7 { return "x7" }
    return "x0" // overflow → stack (TODO: spill)
}

// ── Statement lowering (C6 — RegMap-aware) ───────────────────

fn _arm64_load_spill(buf: [LInstr], rm: RegMap, id: i64, scratch: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out.push(_instr2("ldr", _op_reg(scratch), _op_mem("sp", off),
                     "reload L" + to_string(id) + " from spill slot"))
    return out
}

fn _arm64_store_spill(buf: [LInstr], rm: RegMap, id: i64, src_reg: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out.push(_instr2("str", _op_reg(src_reg), _op_mem("sp", off),
                     "spill L" + to_string(id) + " to slot"))
    return out
}

fn _arm64_op_rm(buf: [LInstr], o: Operand, st: ArmStrTab, rm: RegMap,
                scratch: string) -> [LInstr] {
    let mut out = buf
    if o.kind == "local" {
        if _arm_is_spilled(rm, o.local_id) {
            out = _arm64_load_spill(out, rm, o.local_id, scratch)
        }
    }
    return out
}

fn _arm64_op_resolve(o: Operand, st: ArmStrTab, rm: RegMap,
                     scratch: string) -> LOperand {
    if o.kind == "local" {
        if _arm_is_spilled(rm, o.local_id) {
            return _op_reg(scratch)
        }
        return _op_reg(_arm_reg_lookup(rm, o.local_id))
    }
    if o.kind == "const_int" { return _op_imm(o.int_val) }
    if o.kind == "global"    { return _op_label("g" + to_string(o.global_id)) }
    if o.kind == "const_str" {
        let lbl = _arm64_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _op_label(lbl) }
        return _op_label(o.str_val)
    }
    return _op_imm(0)
}

fn _arm64_emit_dst_writeback(buf: [LInstr], rm: RegMap, id: i64) -> [LInstr] {
    let mut out = buf
    if _arm_is_spilled(rm, id) {
        out = _arm64_store_spill(out, rm, id, "x9")
    }
    return out
}

fn _arm64_dst_reg(rm: RegMap, id: i64) -> string {
    if _arm_is_spilled(rm, id) { return "x9" }
    return _arm_reg_lookup(rm, id)
}

fn _emit_arm64_stmt(out: [LInstr], modhash: string, fname: string, s: Stmt,
                    st: ArmStrTab, rm: RegMap, spill_frame: i64) -> [LInstr] {
    let mut buf = out
    if s.kind == _STMT_ASSIGN {
        if len(s.args) >= 1 {
            let mut src_scratch = "x9"
            if _arm_is_spilled(rm, s.dst.id) { src_scratch = "x10" }
            buf = _arm64_op_rm(buf, s.args[0], st, rm, src_scratch)
            let src = _arm64_op_resolve(s.args[0], st, rm, src_scratch)
            let dst = _op_reg(_arm64_dst_reg(rm, s.dst.id))
            buf.push(_instr2("mov", dst, src, "assign L" + to_string(s.dst.id)))
            buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == _STMT_BINOP {
        if len(s.args) >= 2 {
            let a_scratch = "x10"
            let b_scratch = "x11"
            buf = _arm64_op_rm(buf, s.args[0], st, rm, a_scratch)
            buf = _arm64_op_rm(buf, s.args[1], st, rm, b_scratch)
            let a = _arm64_op_resolve(s.args[0], st, rm, a_scratch)
            let b = _arm64_op_resolve(s.args[1], st, rm, b_scratch)
            let dst = _op_reg(_arm64_dst_reg(rm, s.dst.id))

            if _is_concat(s.op) {
                buf.push(_instr2("mov", _op_reg("x0"), a, "concat arg0"))
                buf.push(_instr2("mov", _op_reg("x1"), b, "concat arg1"))
                buf.push(_instr1("bl", _op_label("hexa_str_concat"),
                                 "call runtime: hexa_str_concat"))
                buf.push(_instr2("mov", dst, _op_reg("x0"), "capture concat result"))
                buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
                return buf
            }

            let cond = _arm64_cmp_cond(s.op)
            if len(cond) > 0 {
                buf.push(_instr2("cmp", a, b, "binop " + s.op))
                buf.push(_instr2("cset", dst, _op_label(cond),
                                 "binop " + s.op + " → bool"))
                buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
                return buf
            }

            let mut mnemonic = "add"
            if _is_arith_add(s.op) { mnemonic = "add" }
            if _is_arith_sub(s.op) { mnemonic = "sub" }
            if _is_arith_mul(s.op) { mnemonic = "mul" }
            if _is_arith_div(s.op) { mnemonic = "sdiv" }
            if s.op == "udiv"      { mnemonic = "udiv" }
            if _is_bit_and(s.op)   { mnemonic = "and" }
            if _is_bit_or(s.op)    { mnemonic = "orr" }
            if _is_bit_xor(s.op)   { mnemonic = "eor" }
            buf.push(_instr3(mnemonic, dst, a, b, "binop " + s.op))
            buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == _STMT_CALL {
        let mut i = 0
        while i < len(s.args) {
            let scratch = _arm64_arg_reg(i)
            if i < 8 {
                buf = _arm64_op_rm(buf, s.args[i], st, rm, scratch)
                let src = _arm64_op_resolve(s.args[i], st, rm, scratch)
                let dst_reg = _op_reg(scratch)
                buf.push(_instr2("mov", dst_reg, src, "arg " + to_string(i)))
            } else {
                buf.push(_instr0("nop",
                    "TODO: spill arg " + to_string(i) + " to stack"))
            }
            i = i + 1
        }
        let target = s.op
        buf.push(_instr1("bl", _op_label(target), "call " + target))
        if s.dst.id >= 0 {
            let dst = _op_reg(_arm64_dst_reg(rm, s.dst.id))
            buf.push(_instr2("mov", dst, _op_reg("x0"), "capture call result"))
            buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == _STMT_RETURN {
        if len(s.args) >= 1 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x9")
            let src = _arm64_op_resolve(s.args[0], st, rm, "x9")
            buf.push(_instr2("mov", _op_reg("x0"), src, "set return value"))
        }
        if spill_frame > 0 {
            buf.push(_instr3("add", _op_reg("sp"), _op_reg("sp"),
                             _op_label("#" + to_string(spill_frame)),
                             "epilogue: free spill frame"))
        }
        buf.push(_instr3("ldp", _op_reg("x29"), _op_reg("x30"),
                         _op_label("[sp], #16"), "epilogue: restore fp/lr"))
        buf.push(_instr0("ret", "return"))
        return buf
    }
    if s.kind == _STMT_BR {
        let lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_instr1("b", _op_label(lab), "branch"))
        return buf
    }
    if s.kind == _STMT_BR_COND {
        if len(s.args) > 0 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x9")
            let cond = _arm64_op_resolve(s.args[0], st, rm, "x9")
            let else_lab = _arm64_block_label(modhash, fname, s.target_block_else)
            buf.push(_instr2("cbz", cond, _op_label(else_lab),
                             "br_cond: zero -> else"))
        }
        let then_lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_instr1("b", _op_label(then_lab), "branch -> then"))
        return buf
    }
    if s.kind == "load" {
        if len(s.args) >= 1 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x10")
            let base_op = _arm64_op_resolve(s.args[0], st, rm, "x10")
            let mut off = 0
            if len(s.args) >= 2 && s.args[1].kind == "const_int" {
                off = s.args[1].int_val
            }
            let dst = _op_reg(_arm64_dst_reg(rm, s.dst.id))
            buf.push(_instr2("ldr", dst, _op_mem(base_op.reg.name, off),
                             "load"))
            buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == "store" {
        if len(s.args) >= 2 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x10")
            buf = _arm64_op_rm(buf, s.args[1], st, rm, "x11")
            let base_op = _arm64_op_resolve(s.args[0], st, rm, "x10")
            let src = _arm64_op_resolve(s.args[1], st, rm, "x11")
            let mut off = 0
            if len(s.args) >= 3 && s.args[2].kind == "const_int" {
                off = s.args[2].int_val
            }
            buf.push(_instr2("str", src, _op_mem(base_op.reg.name, off),
                             "store"))
        }
        return buf
    }
    buf.push(_instr0("nop", "unhandled stmt kind " + s.kind))
    return buf
}

// ── Function lowering ────────────────────────────────────────

fn _arm64_lower_func(mf: MFunc, st: ArmStrTab, modhash: string) -> LFunc {
    let mut instrs = []

    // C6 — run linear-scan regalloc up front so the prologue can size
    // the spill frame and the body can resolve operands through the
    // assigned RegMap.
    let alloc = _arm64_assign_regs(mf)
    let rm = alloc.map
    let spill_frame = alloc.frame_size

    // Prologue
    instrs.push(_instr3(
        "stp",
        _op_reg("x29"),
        _op_reg("x30"),
        _op_label("[sp, #-16]!"),
        "prologue: save fp/lr"
    ))
    instrs.push(_instr2("mov", _op_reg("x29"), _op_reg("sp"), "prologue: set fp"))

    // Spill-frame allocation (after fp/lr save).
    if spill_frame > 0 {
        instrs.push(_instr3("sub", _op_reg("sp"), _op_reg("sp"),
                            _op_label("#" + to_string(spill_frame)),
                            "prologue: alloc spill frame"))
    }

    // Move incoming params x0..x7 into their assigned regs / spill slots.
    let mut p = 0
    while p < len(mf.params) {
        if p < 8 {
            let pid = mf.params[p].id
            let src_name = "x" + to_string(p)
            if _arm_is_spilled(rm, pid) {
                instrs = _arm64_store_spill(instrs, rm, pid, src_name)
            } else {
                let dst_name = _arm_reg_lookup(rm, pid)
                if dst_name != src_name {
                    instrs.push(_instr2("mov", _op_reg(dst_name),
                                        _op_reg(src_name), "ingress param"))
                }
            }
        }
        p = p + 1
    }

    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        instrs.push(_instr0("label", _arm64_block_label(modhash, mf.name, blk.id)))
        let mut si = 0
        while si < len(blk.stmts) {
            instrs = _emit_arm64_stmt(instrs, modhash, mf.name,
                                      blk.stmts[si], st, rm, spill_frame)
            si = si + 1
        }
        bi = bi + 1
    }

    // Safety epilogue (in case last block lacks _STMT_RETURN)
    let last_is_ret = false
    if len(instrs) > 0 {
        let last = instrs[len(instrs) - 1]
        if last.op == "ret" {
            return LFunc {
                name: mf.name,
                target: "arm64-apple-darwin",
                instrs: instrs,
                frame_size: 16 + spill_frame,
                callee_saved: []
            }
        }
    }
    if spill_frame > 0 {
        instrs.push(_instr3("add", _op_reg("sp"), _op_reg("sp"),
                            _op_label("#" + to_string(spill_frame)),
                            "epilogue: free spill frame"))
    }
    instrs.push(_instr3("ldp", _op_reg("x29"), _op_reg("x30"),
                        _op_label("[sp], #16"), "epilogue: restore fp/lr"))
    instrs.push(_instr0("ret", "return"))

    return LFunc {
        name: mf.name,
        target: "arm64-apple-darwin",
        instrs: instrs,
        frame_size: 16 + spill_frame,
        callee_saved: []
    }
}

// ── String table collection (for rodata emission) ────────────
//
// Walk every Stmt in every Block in every Func looking for
// `const_str` operands and record them in an ArmStrTab. Each unique
// literal gets label ".LCstr<N>" (N = insertion order). Both targets
// share this label scheme so rodata labels remain stable per source
// independently of the chosen target.

fn _collect_strs_from_stmt(st: ArmStrTab, s: Stmt) -> ArmStrTab {
    let mut out = st
    let mut i = 0
    while i < len(s.args) {
        let o = s.args[i]
        if o.kind == "const_str" {
            if len(_arm64_strtab_lookup(out, o.str_val)) == 0 {
                let mut keys = out.keys
                let mut labs = out.labels
                let n = len(keys)
                keys.push(o.str_val)
                labs.push(".LCstr" + to_string(n))
                out = ArmStrTab { keys: keys, labels: labs }
            }
        }
        i = i + 1
    }
    return out
}

fn _build_arm_strtab(module: MModule) -> ArmStrTab {
    let mut st = ArmStrTab { keys: [], labels: [] }
    let mut fi = 0
    while fi < len(module.funcs) {
        let f = module.funcs[fi]
        let mut bi = 0
        while bi < len(f.blocks) {
            let blk = f.blocks[bi]
            let mut si = 0
            while si < len(blk.stmts) {
                st = _collect_strs_from_stmt(st, blk.stmts[si])
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return st
}

// Convert a string into a hex-encoded byte sequence (per-LSection
// payload format defined by lir.hexa). Appends a NUL terminator so
// the rodata entry is C-string compatible.
fn _hex_nibble(n: i64) -> string {
    if n == 0  { return "0" }
    if n == 1  { return "1" }
    if n == 2  { return "2" }
    if n == 3  { return "3" }
    if n == 4  { return "4" }
    if n == 5  { return "5" }
    if n == 6  { return "6" }
    if n == 7  { return "7" }
    if n == 8  { return "8" }
    if n == 9  { return "9" }
    if n == 10 { return "a" }
    if n == 11 { return "b" }
    if n == 12 { return "c" }
    if n == 13 { return "d" }
    if n == 14 { return "e" }
    return "f"
}

fn _byte_to_hex(b: i64) -> string {
    let hi = b / 16
    let lo = b - hi * 16
    return _hex_nibble(hi) + _hex_nibble(lo)
}

// Manual ASCII codepoint lookup. Stage0 hexa has no `ord`/codepoint
// primitive surfaced to user code, so we hard-code the printable
// range that real-world tests touch.
fn _ascii_code(ch: string) -> i64 {
    if ch == " " { return 32 }
    if ch == "!" { return 33 }
    if ch == "\"" { return 34 }
    if ch == "#" { return 35 }
    if ch == "$" { return 36 }
    if ch == "%" { return 37 }
    if ch == "&" { return 38 }
    if ch == "'" { return 39 }
    if ch == "(" { return 40 }
    if ch == ")" { return 41 }
    if ch == "*" { return 42 }
    if ch == "+" { return 43 }
    if ch == "," { return 44 }
    if ch == "-" { return 45 }
    if ch == "." { return 46 }
    if ch == "/" { return 47 }
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == ":" { return 58 }
    if ch == ";" { return 59 }
    if ch == "<" { return 60 }
    if ch == "=" { return 61 }
    if ch == ">" { return 62 }
    if ch == "?" { return 63 }
    if ch == "@" { return 64 }
    if ch == "A" { return 65 }
    if ch == "B" { return 66 }
    if ch == "C" { return 67 }
    if ch == "D" { return 68 }
    if ch == "E" { return 69 }
    if ch == "F" { return 70 }
    if ch == "G" { return 71 }
    if ch == "H" { return 72 }
    if ch == "I" { return 73 }
    if ch == "J" { return 74 }
    if ch == "K" { return 75 }
    if ch == "L" { return 76 }
    if ch == "M" { return 77 }
    if ch == "N" { return 78 }
    if ch == "O" { return 79 }
    if ch == "P" { return 80 }
    if ch == "Q" { return 81 }
    if ch == "R" { return 82 }
    if ch == "S" { return 83 }
    if ch == "T" { return 84 }
    if ch == "U" { return 85 }
    if ch == "V" { return 86 }
    if ch == "W" { return 87 }
    if ch == "X" { return 88 }
    if ch == "Y" { return 89 }
    if ch == "Z" { return 90 }
    if ch == "[" { return 91 }
    if ch == "\\" { return 92 }
    if ch == "]" { return 93 }
    if ch == "^" { return 94 }
    if ch == "_" { return 95 }
    if ch == "`" { return 96 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    if ch == "g" { return 103 }
    if ch == "h" { return 104 }
    if ch == "i" { return 105 }
    if ch == "j" { return 106 }
    if ch == "k" { return 107 }
    if ch == "l" { return 108 }
    if ch == "m" { return 109 }
    if ch == "n" { return 110 }
    if ch == "o" { return 111 }
    if ch == "p" { return 112 }
    if ch == "q" { return 113 }
    if ch == "r" { return 114 }
    if ch == "s" { return 115 }
    if ch == "t" { return 116 }
    if ch == "u" { return 117 }
    if ch == "v" { return 118 }
    if ch == "w" { return 119 }
    if ch == "x" { return 120 }
    if ch == "y" { return 121 }
    if ch == "z" { return 122 }
    if ch == "{" { return 123 }
    if ch == "|" { return 124 }
    if ch == "}" { return 125 }
    if ch == "~" { return 126 }
    if ch == "\n" { return 10 }
    if ch == "\t" { return 9 }
    return 63 // '?' for unknown (non-ASCII / control)
}

fn _str_to_hex_bytes(s: string) -> string {
    let cs = s.chars()
    let mut out = ""
    let mut i = 0
    while i < len(cs) {
        out = out + _byte_to_hex(_ascii_code(cs[i]))
        i = i + 1
    }
    out = out + "00" // NUL terminator
    return out
}

fn _strtab_to_rodata(st: ArmStrTab) -> [LSection] {
    let mut out: [LSection] = []
    let mut i = 0
    while i < len(st.keys) {
        out.push(LSection {
            name: st.labels[i],
            bytes: _str_to_hex_bytes(st.keys[i]),
            align: 0
        })
        i = i + 1
    }
    return out
}

// ── Module entry point ───────────────────────────────────────

pub fn codegen_arm64_darwin(module: MModule) -> LModule {
    let st = _build_arm_strtab(module)
    let mut funcs = []
    let mut i = 0
    while i < len(module.funcs) {
        // Stage1 C8 — recompute modhash inline at every call site so
        // stage0's transitive-let binding gap (see _STMT_* mirror at
        // top of this file) cannot hand the lowering pass a void.
        funcs.push(_arm64_lower_func(module.funcs[i], st, _arm64_modhash(module.file)))
        i = i + 1
    }
    return LModule {
        file: module.file,
        target: "arm64-apple-darwin",
        funcs: funcs,
        rodata: _strtab_to_rodata(st),
        bss: []
    }
}
