// HEXA Native Compiler — Codegen / arm64-apple-darwin (Phase A1)
//
// @version 0.1.0
// @capabilities [pure]
// @allow-relop-banned-file  — codegen path uses `>=`/`<=` for arity
//   guards and signed-id checks; C6 regalloc inherits the same need.
//
// Lowers MIR (SSA CFG) -> LIR (target-specific instructions) for the
// arm64-apple-darwin target.
//
//   pub fn codegen_arm64_darwin(module: MModule) -> LModule
//
// ABI: AAPCS64
//   - Integer args: x0..x7 (overflow on stack — v1 ignored, tiny tests only)
//   - Integer return: x0
//   - Frame pointer: x29 (fp), Link register: x30 (lr)
//   - Stack pointer: 16-byte aligned at function boundaries
//
// Per MFunc layout:
//   prologue:
//       stp x29, x30, [sp, #-16]!
//       mov x29, sp
//   <block instrs>
//   epilogue:
//       ldp x29, x30, [sp], #16
//       ret
//
// v1 register policy:
//   Naive — Local id N -> register x(N % 31).  No spilling, no liveness.
//   Tier-0 tier verification only; tiny test cases fit in <31 locals.
//
// Constraints (from RFC-018 §4):
//   - struct >16B by reference (not handled v1)
//   - hidden first arg for >16B return (not handled v1)

import "../ir/mir.hexa"
import "../ir/lir.hexa"

// ── Local mirror of mir.hexa STMT_* constants ────────────────
// See note in compiler/lower/hir_to_mir.hexa: stage0's interpreter does
// not propagate transitive `pub let` bindings, so STMT_* arrive here as
// the void value. Redeclaring locally keeps codegen dispatch working.
let _STMT_ASSIGN   = "assign"
let _STMT_BINOP    = "binop"
let _STMT_UNOP     = "unop"
let _STMT_CALL     = "call"
let _STMT_RETURN   = "return"
let _STMT_BR       = "br"
let _STMT_BR_COND  = "br_cond"

// ── PReg / LOperand helpers ──────────────────────────────────

fn _arm64_preg_gpr(name: string) -> PReg {
    return PReg { name: name, kind: "gpr" }
}

fn _arm64_empty_preg() -> PReg {
    return PReg { name: "", kind: "" }
}

fn _arm64_op_reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: _arm64_preg_gpr(name),
        imm: 0,
        mem_base: _arm64_empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _arm64_op_imm(value: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: _arm64_empty_preg(),
        imm: value,
        mem_base: _arm64_empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _arm64_op_label(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: _arm64_empty_preg(),
        imm: 0,
        mem_base: _arm64_empty_preg(),
        mem_offset: 0,
        label: name
    }
}

fn _arm64_op_mem(base: string, offset: i64) -> LOperand {
    return LOperand {
        kind: "mem",
        reg: _arm64_empty_preg(),
        imm: 0,
        mem_base: _arm64_preg_gpr(base),
        mem_offset: offset,
        label: ""
    }
}

fn _arm64_instr0(op: string, comment: string) -> LInstr {
    return LInstr { op: op, args: [], comment: comment }
}

fn _arm64_instr1(op: string, a: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _arm64_instr2(op: string, a: LOperand, b: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _arm64_instr3(op: string, a: LOperand, b: LOperand, c: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    xs.push(c)
    return LInstr { op: op, args: xs, comment: comment }
}

// ── Register assignment (naive fallback) ─────────────────────
//
// Used only when no RegMap is available. Production codegen runs
// through `_arm64_assign_regs` (linear scan, Poletto-Sarkar 1999)
// and `_arm_reg_lookup` below.

fn _arm64_reg_for_local(local_id: i64) -> string {
    let mut idx = local_id
    if idx < 0 { idx = 0 }
    let m = idx - (idx / 31) * 31
    return "x" + to_string(m)
}

// ── C6 — Linear-scan register allocator (arm64) ──────────────
pub struct RegMap {
    ids: [i64],
    regs: [string],
    slots: [i64],
    // C7 — per-fn outgoing-call overflow region (bytes, 16-aligned),
    // pre-allocated at prologue bottom. _arm_spill_offset shifts every
    // SSA spill access above this region so per-call stack-spill stores
    // can use [sp, #(i-8)*8] without disturbing SSA offsets.
    call_overflow_bytes: i64
}

pub struct ArmAllocResult {
    map: RegMap,
    frame_size: i64
}

pub struct ArmIntervals {
    ids: [i64],
    starts: [i64],
    ends: [i64]
}

fn _arm_pool_init() -> [string] {
    let mut p: [string] = []
    p.push("x10")
    p.push("x11")
    p.push("x12")
    p.push("x13")
    p.push("x14")
    p.push("x15")
    p.push("x19")
    p.push("x20")
    p.push("x21")
    p.push("x22")
    p.push("x23")
    p.push("x24")
    p.push("x25")
    p.push("x26")
    p.push("x27")
    p.push("x28")
    return p
}

fn _arm_index_of(ids: [i64], id: i64) -> i64 {
    // O(1) fast path: SSA ids are dense (next_local-allocated) and the
    // id-arrays here (ids / iv.ids / rm.ids) are built in id order, so
    // ids[id] == id is the common case. ids is dedup-built (each id
    // appears once) so when ids[id]==id, `id` is THE unique index —
    // sound. Falls back to the linear scan otherwise. Without this the
    // per-operand lookups in _arm_reg_lookup/_arm_is_spilled/
    // _arm_spill_offset + the live-range/regalloc loops are O(N²) on a
    // huge function (the synthetic `fn main`) — minutes-long stage-1.
    if id >= 0 && id < len(ids) {
        if ids[id] == id { return id }
    }
    let mut i = 0
    while i < len(ids) {
        if ids[i] == id { return i }
        i = i + 1
    }
    return -1
}

fn _arm_compute_live_ranges(mf: MFunc) -> ArmIntervals {
    let mut ids: [i64] = []
    let mut starts: [i64] = []
    let mut ends: [i64] = []

    let mut li = 0
    while li < len(mf.locals) {
        let id = mf.locals[li].id
        if id >= 0 && _arm_index_of(ids, id) < 0 {
            ids.push(id)
            starts.push(-1)
            ends.push(-1)
        }
        li = li + 1
    }

    let mut pi = 0
    while pi < len(mf.params) {
        let pid = mf.params[pi].id
        let idx = _arm_index_of(ids, pid)
        if idx >= 0 {
            if starts[idx] < 0 { starts[idx] = 0 }
            if ends[idx] < 0   { ends[idx] = 0 }
        }
        pi = pi + 1
    }

    let mut pos = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            let s = blk.stmts[si]
            let did = s.dst.id
            if did >= 0 {
                let mut idx = _arm_index_of(ids, did)
                if idx < 0 {
                    ids.push(did)
                    starts.push(pos)
                    ends.push(pos)
                    idx = len(ids) - 1
                } else {
                    if starts[idx] < 0 || pos < starts[idx] { starts[idx] = pos }
                    if pos > ends[idx] { ends[idx] = pos }
                }
            }
            let mut ai = 0
            while ai < len(s.args) {
                let o = s.args[ai]
                if o.kind == "local" {
                    let lid = o.local_id
                    if lid >= 0 {
                        let mut idx2 = _arm_index_of(ids, lid)
                        if idx2 < 0 {
                            ids.push(lid)
                            starts.push(pos)
                            ends.push(pos)
                            idx2 = len(ids) - 1
                        } else {
                            if starts[idx2] < 0 || pos < starts[idx2] {
                                starts[idx2] = pos
                            }
                            if pos > ends[idx2] { ends[idx2] = pos }
                        }
                    }
                }
                ai = ai + 1
            }
            pos = pos + 1
            si = si + 1
        }
        bi = bi + 1
    }
    return ArmIntervals { ids: ids, starts: starts, ends: ends }
}

fn _arm64_assign_regs(mf: MFunc) -> ArmAllocResult {
    let iv = _arm_compute_live_ranges(mf)
    let n = len(iv.ids)
    let mut order: [i64] = []
    let mut k = 0
    while k < n {
        if iv.starts[k] >= 0 { order.push(k) }
        k = k + 1
    }
    let mut a = 1
    while a < len(order) {
        let key = order[a]
        let key_start = iv.starts[key]
        let mut b = a - 1
        while b >= 0 && iv.starts[order[b]] > key_start {
            order[b + 1] = order[b]
            b = b - 1
        }
        order[b + 1] = key
        a = a + 1
    }

    let mut map_ids: [i64] = []
    let mut map_regs: [string] = []
    let mut map_slots: [i64] = []
    let mut j = 0
    while j < n {
        map_ids.push(iv.ids[j])
        map_regs.push("")
        map_slots.push(-1)
        j = j + 1
    }

    let mut p = 0
    while p < len(mf.params) {
        if p < 8 {
            let pid = mf.params[p].id
            let idx = _arm_index_of(iv.ids, pid)
            if idx >= 0 {
                map_regs[idx] = "x" + to_string(p)
            }
        }
        p = p + 1
    }

    let mut pool = _arm_pool_init()
    let mut active_idx: [i64] = []
    let mut next_slot: i64 = 0

    let mut s = 0
    while s < len(order) {
        let cur = order[s]
        let cur_start = iv.starts[cur]

        let mut keep: [i64] = []
        let mut e = 0
        while e < len(active_idx) {
            let ai = active_idx[e]
            if iv.ends[ai] < cur_start {
                let was = map_regs[ai]
                let mut is_param = false
                let mut pp = 0
                while pp < len(mf.params) {
                    if mf.params[pp].id == iv.ids[ai] { is_param = true }
                    pp = pp + 1
                }
                if !is_param && len(was) > 0 && map_slots[ai] < 0 {
                    pool.push(was)
                }
            } else {
                keep.push(ai)
            }
            e = e + 1
        }
        active_idx = keep

        if len(map_regs[cur]) > 0 {
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
            s = s + 1
            continue
        }

        if len(pool) > 0 {
            let r = pool[0]
            let mut np: [string] = []
            let mut tt = 1
            while tt < len(pool) {
                np.push(pool[tt])
                tt = tt + 1
            }
            pool = np
            map_regs[cur] = r
            map_slots[cur] = -1
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
        } else {
            let mut victim_pos = len(active_idx) - 1
            while victim_pos >= 0 {
                let v = active_idx[victim_pos]
                let mut is_param = false
                let mut pp = 0
                while pp < len(mf.params) {
                    if mf.params[pp].id == iv.ids[v] { is_param = true }
                    pp = pp + 1
                }
                if !is_param { break }
                victim_pos = victim_pos - 1
            }

            if victim_pos >= 0 && iv.ends[active_idx[victim_pos]] > iv.ends[cur] {
                let v = active_idx[victim_pos]
                map_regs[cur] = map_regs[v]
                map_slots[cur] = -1
                map_regs[v] = ""
                map_slots[v] = next_slot
                next_slot = next_slot + 8
                let mut na: [i64] = []
                let mut t = 0
                while t < len(active_idx) {
                    if t != victim_pos { na.push(active_idx[t]) }
                    t = t + 1
                }
                let cur_end = iv.ends[cur]
                let mut na2: [i64] = []
                let mut placed = false
                let mut tt = 0
                while tt < len(na) {
                    if !placed && iv.ends[na[tt]] > cur_end {
                        na2.push(cur)
                        placed = true
                    }
                    na2.push(na[tt])
                    tt = tt + 1
                }
                if !placed { na2.push(cur) }
                active_idx = na2
            } else {
                map_regs[cur] = ""
                map_slots[cur] = next_slot
                next_slot = next_slot + 16  // Path A S1: HexaVal is 16B (tag+union); spill slots are HexaVal-sized. Single-reg str/ldr into the low 8B is harmless until S2 pair-stores the high half.
            }
        }
        s = s + 1
    }

    let mut frame = next_slot
    let rem = frame - (frame / 16) * 16
    if rem != 0 { frame = frame + (16 - rem) }

    // Path A (A′): HexaVal is a 16-byte struct (x0:x1 AAPCS64 pair) —
    // a single register cannot hold one. Force EVERY value memory-
    // resident in a 16B slot (no register residency); the emitter
    // ldp/stp's the pair around each use. This mirrors the proven
    // codegen_c2 memory-resident value model and avoids a pair-aware
    // register allocator. Slower but ABI-correct (optimise post-stage-3).
    let mut fi = 0
    while fi < len(map_ids) {
        if map_slots[fi] < 0 {
            map_slots[fi] = next_slot
            next_slot = next_slot + 16
        }
        map_regs[fi] = ""
        fi = fi + 1
    }
    let mut frame2 = next_slot
    let rem2 = frame2 - (frame2 / 16) * 16
    if rem2 != 0 { frame2 = frame2 + (16 - rem2) }
    frame = frame2

    let map = RegMap {
        ids: map_ids,
        regs: map_regs,
        slots: map_slots,
        call_overflow_bytes: 0   // filled in by _arm64_lower_func once max-overflow is known
    }
    return ArmAllocResult { map: map, frame_size: frame }
}

fn _arm_reg_lookup(rm: RegMap, id: i64) -> string {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return _arm64_reg_for_local(id) }
    if rm.slots[idx] >= 0 { return "x9" }
    if len(rm.regs[idx]) == 0 { return _arm64_reg_for_local(id) }
    return rm.regs[idx]
}

fn _arm_is_spilled(rm: RegMap, id: i64) -> bool {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return false }
    return rm.slots[idx] >= 0
}

fn _arm_spill_offset(rm: RegMap, id: i64) -> i64 {
    let idx = _arm_index_of(rm.ids, id)
    if idx < 0 { return rm.call_overflow_bytes }
    return rm.slots[idx] + rm.call_overflow_bytes
}

// String literal → rodata label map. `keys[i]` is a literal string
// (the const_str payload); `labels[i]` is the assigned ".LCstrN"
// label (without the platform underscore prefix). Built once per
// module before func lowering and threaded into every operand
// resolution. `pub` is required because stage0 cannot resolve struct
// field types across imports without it.
pub struct ArmStrTab {
    keys: [string],
    labels: [string]
}

fn _arm64_strtab_lookup(st: ArmStrTab, s: string) -> string {
    let mut i = 0
    while i < len(st.keys) {
        if st.keys[i] == s {
            // F6 P0b — forced copy: the LFunc operand built from this
            // label must not share st.labels' handle, or freeing the
            // LFunc would dangle st (st outlives every streaming
            // iteration). PLAN-stage3-footprint-F6.md.
            let lab = st.labels[i]
            return lab.substring(0, len(lab))
        }
        i = i + 1
    }
    return ""
}

fn _arm64_op_for_operand_st(o: Operand, st: ArmStrTab) -> LOperand {
    if o.kind == "local" {
        return _arm64_op_reg(_arm64_reg_for_local(o.local_id))
    }
    if o.kind == "const_int" {
        return _arm64_op_imm(o.int_val)
    }
    if o.kind == "global" {
        return _arm64_op_label("g" + to_string(o.global_id))
    }
    if o.kind == "const_str" {
        // lbl is already a fresh copy (F6 P0b in _arm64_strtab_lookup).
        let lbl = _arm64_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _arm64_op_label(lbl) }
        // F6 P0d — strtab-miss fallback (should be unreachable, every
        // const_str is interned first): copy so the LFunc does not share
        // the MFunc operand's string. PLAN-stage3-footprint-F6.md.
        return _arm64_op_label(o.str_val.substring(0, len(o.str_val)))
    }
    // fallback: treat as imm 0
    return _arm64_op_imm(0)
}

// Backwards-compatible operand resolver — used where no strtab is
// available (e.g. trivial tests without string literals). Strings
// flow through unchanged (label = literal string), which only
// matters for modules that never produce a const_str operand.
fn _arm64_op_for_operand(o: Operand) -> LOperand {
    let st = ArmStrTab { keys: [], labels: [] }
    return _arm64_op_for_operand_st(o, st)
}

// ── Block label helper ───────────────────────────────────────
//
// Apple ARM64 uses `L<name>` as the conventional local-label form
// for compiler-generated labels within a function. We emit them with
// a leading `_` prefix so the asm-text emit pass leaves them alone
// (its `_fmt_label` skips labels that already begin with '.' or
// '_'). Without this, branch operand references would be re-prefixed
// to `__Lname` while the definition stays bare `Lname:`, breaking
// the branch.
// Stage1 C8 — modhash = first 4 hex of sha256(module.file).
// Disambiguates spliced modules sharing the same fn name.
fn _arm64_modhash(file: string) -> string {
    let h = sha256(file)
    if len(h) > 3 { return h.substring(0, 4) }
    return h
}

fn _arm64_block_label(modhash: string, fname: string, block_id: i64) -> string {
    return "_L" + modhash + "_" + fname + "_bb" + to_string(block_id)
}

// ── Binop classification ─────────────────────────────────────
//
// Lower (compiler/lower/hir_to_mir.hexa) carries the source-level
// operator text in `Stmt.op` (e.g. "+", "-", "*", "==", "<"). The
// older codegen path also accepted normalized aliases ("add",
// "sub", ...). We accept both. String concat is recognised as a
// dedicated `concat` op (or `+` over string operands once typed-MIR
// lands — until then, lower must emit `concat` explicitly for
// string + string).

fn _is_arith_add(op: string) -> bool { return op == "add" || op == "+" }
fn _is_arith_sub(op: string) -> bool { return op == "sub" || op == "-" }
fn _is_arith_mul(op: string) -> bool { return op == "mul" || op == "*" }
fn _is_arith_div(op: string) -> bool { return op == "div" || op == "/" }
fn _is_bit_and(op: string) -> bool   { return op == "and" || op == "&" }
fn _is_bit_or(op: string) -> bool    { return op == "or"  || op == "|" }
fn _is_bit_xor(op: string) -> bool   { return op == "xor" || op == "^" }
fn _is_concat(op: string) -> bool    { return op == "concat" }

// arm64 cset condition mnemonic for a source comparison op.
// Returns "" if not a comparison.
fn _arm64_cmp_cond(op: string) -> string {
    if op == "cmp_eq" || op == "==" { return "eq" }
    if op == "cmp_ne" || op == "!=" { return "ne" }
    if op == "cmp_lt" || op == "<"  { return "lt" }
    if op == "cmp_le" || op == "<=" { return "le" }
    if op == "cmp_gt" || op == ">"  { return "gt" }
    if op == "cmp_ge" || op == ">=" { return "ge" }
    return ""
}

// AAPCS64 integer arg sequence.
fn _arm64_arg_reg(idx: i64) -> string {
    if idx == 0 { return "x0" }
    if idx == 1 { return "x1" }
    if idx == 2 { return "x2" }
    if idx == 3 { return "x3" }
    if idx == 4 { return "x4" }
    if idx == 5 { return "x5" }
    if idx == 6 { return "x6" }
    if idx == 7 { return "x7" }
    return "x0" // overflow handled at call site via stack-spill (C7)
}

// C7 — scan all _STMT_CALL stmts in `mf` and return the maximum number
// of overflow args (args 9+) across all calls. The per-fn outgoing-call
// overflow region is sized once from this maximum and reused at every
// call site, so we don't sub/add sp mid-frame (which would invalidate
// sp-relative SSA spill offsets).
fn _arm64_max_call_overflow(mf: MFunc) -> i64 {
    let mut max_overflow = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            let s = blk.stmts[si]
            if s.kind == _STMT_CALL {
                let n = len(s.args)
                if n > 8 {
                    let overflow = n - 8
                    if overflow > max_overflow { max_overflow = overflow }
                }
            }
            si = si + 1
        }
        bi = bi + 1
    }
    return max_overflow
}

// ── Statement lowering (C6 — RegMap-aware) ───────────────────

fn _arm64_load_spill(buf: [LInstr], rm: RegMap, id: i64, scratch: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out.push(_arm64_instr2("ldr", _arm64_op_reg(scratch), _arm64_op_mem("sp", off),
                     "reload L" + to_string(id) + " from spill slot"))
    return out
}

fn _arm64_store_spill(buf: [LInstr], rm: RegMap, id: i64, src_reg: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out.push(_arm64_instr2("str", _arm64_op_reg(src_reg), _arm64_op_mem("sp", off),
                     "spill L" + to_string(id) + " to slot"))
    return out
}

// Build a >12-bit constant into `reg` via movz + up to 3 movk. ARM64
// cmp immediates are ≤12-bit and mov/movz ≤16-bit; enum/struct __tag
// values are djb2 _path_hash ints far exceeding that — they emitted as
// `cmp xN,#<hash>` / `mov xN,#<hash>` (1945+314 of the 2332 residual
// stage-1-.s assembler errors). Halfwords via /%65536 (callers gate on
// value>4095, always positive). `#h, lsl #N` is one #-prefixed label so
// emit/asm _fmt_label renders it verbatim (no platform prefix).
fn _arm64_emit_imm_to_reg(buf: [LInstr], reg: string, value: i64) -> [LInstr] {
    let mut out = buf
    let h0 = value % 65536
    let h1 = (value / 65536) % 65536
    let h2 = (value / 65536 / 65536) % 65536
    let h3 = (value / 65536 / 65536 / 65536) % 65536
    out.push(_arm64_instr2("movz", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h0)), "imm 0-15"))
    if h1 != 0 {
        out.push(_arm64_instr2("movk", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h1) + ", lsl #16"), "imm 16-31"))
    }
    if h2 != 0 {
        out.push(_arm64_instr2("movk", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h2) + ", lsl #32"), "imm 32-47"))
    }
    if h3 != 0 {
        out.push(_arm64_instr2("movk", _arm64_op_reg(reg),
                     _arm64_op_label("#" + to_string(h3) + ", lsl #48"), "imm 48-63"))
    }
    return out
}

fn _arm64_op_rm(buf: [LInstr], o: Operand, st: ArmStrTab, rm: RegMap,
                scratch: string) -> [LInstr] {
    let mut out = buf
    if o.kind == "local" {
        if _arm_is_spilled(rm, o.local_id) {
            out = _arm64_load_spill(out, rm, o.local_id, scratch)
        }
    }
    // Large const_int (e.g. _path_hash __tag) → movz/movk into scratch;
    // _arm64_op_resolve returns reg(scratch). Small (≤4095) stay
    // immediate (valid in cmp/add/mov — unchanged, no regression).
    if o.kind == "const_int" {
        if o.int_val > 4095 {
            out = _arm64_emit_imm_to_reg(out, scratch, o.int_val)
        }
    }
    // const_str / global → PC-relative address materialization. ARM64
    // cannot use a label as a bare mov/cmp operand; the address must be
    // built with adrp(@PAGE) + add(@PAGEOFF) into a register. Without
    // this every string/global ref emitted `mov xN,.LCstrM` /
    // `cmp xN,.LCstrM` — 3368 of the 3578 stage-1-.s assembler errors.
    // _arm64_op_resolve returns reg(scratch) for these (address built
    // here). Labels render verbatim via emit/asm _fmt_label.
    if o.kind == "const_str" {
        let cl = _arm64_strtab_lookup(st, o.str_val)
        let mut nm = cl
        if len(nm) == 0 { nm = o.str_val }
        out.push(_arm64_instr2("adrp", _arm64_op_reg(scratch),
                         _arm64_op_label(nm + "@PAGE"), "addr page: " + nm))
        out.push(_arm64_instr3("add", _arm64_op_reg(scratch),
                         _arm64_op_reg(scratch),
                         _arm64_op_label(nm + "@PAGEOFF"), "addr off: " + nm))
    }
    if o.kind == "global" {
        let gl = "g" + to_string(o.global_id)
        out.push(_arm64_instr2("adrp", _arm64_op_reg(scratch),
                         _arm64_op_label(gl + "@PAGE"), "addr page: " + gl))
        out.push(_arm64_instr3("add", _arm64_op_reg(scratch),
                         _arm64_op_reg(scratch),
                         _arm64_op_label(gl + "@PAGEOFF"), "addr off: " + gl))
    }
    return out
}

fn _arm64_op_resolve(o: Operand, st: ArmStrTab, rm: RegMap,
                     scratch: string) -> LOperand {
    if o.kind == "local" {
        if _arm_is_spilled(rm, o.local_id) {
            return _arm64_op_reg(scratch)
        }
        return _arm64_op_reg(_arm_reg_lookup(rm, o.local_id))
    }
    if o.kind == "const_int" {
        // >4095 was movz/movk-materialized into scratch by _arm64_op_rm
        // (ARM64 cmp imm ≤12-bit); small values stay immediate.
        if o.int_val > 4095 { return _arm64_op_reg(scratch) }
        return _arm64_op_imm(o.int_val)
    }
    // global / const_str: address already materialized into `scratch`
    // by _arm64_op_rm (adrp+add). Return the register, not the label —
    // emitting the bare label is invalid ARM64.
    if o.kind == "global"    { return _arm64_op_reg(scratch) }
    if o.kind == "const_str" { return _arm64_op_reg(scratch) }
    return _arm64_op_imm(0)
}

fn _arm64_emit_dst_writeback(buf: [LInstr], rm: RegMap, id: i64) -> [LInstr] {
    let mut out = buf
    if _arm_is_spilled(rm, id) {
        out = _arm64_store_spill(out, rm, id, "x9")
    }
    return out
}

fn _arm64_dst_reg(rm: RegMap, id: i64) -> string {
    if _arm_is_spilled(rm, id) { return "x9" }
    return _arm_reg_lookup(rm, id)
}

// ── Path A (A′) 16-byte HexaVal value helpers ────────────────
// HexaVal occupies a register PAIR (lo = slot+0 = tag+pad, hi =
// slot+8 = union payload). Every value is memory-resident in a 16B
// frame slot (force-spilled in _arm_assign_regs). _hv_load brings a
// value into the (lo,hi) GP pair; _hv_store writes a (lo,hi) pair
// back to a value's slot. TAG_INT=0 TAG_BOOL=2 TAG_STR=3 (runtime.h).
fn _hv_mem(off: i64) -> LOperand {
    return _arm64_op_label("[sp, #" + to_string(off) + "]")
}

// ARM64 ldp/stp (64-bit pair) take a signed scaled imm7 offset: range
// [-512, +504] in steps of 8. Frame slots beyond that need the address
// materialized into a base register (x15 — outside the value-scratch
// x9-x14 and arg x0-x7 sets). Emits into `base`; returns the [base]
// mem operand for offsets out of range, else [sp,#off].
fn _hv_at(buf: [LInstr], off: i64, base: string) -> [LInstr] {
    let mut out = buf
    if off >= 0 && off <= 504 { return out }
    if off <= 4095 {
        out.push(_arm64_instr3("add", _arm64_op_reg(base), _arm64_op_reg("sp"),
                         _arm64_op_label("#" + to_string(off)), "hv frame base"))
    } else {
        out = _arm64_emit_imm_to_reg(out, base, off)
        out.push(_arm64_instr3("add", _arm64_op_reg(base), _arm64_op_reg("sp"),
                         _arm64_op_reg(base), "hv frame base (big)"))
    }
    return out
}

fn _hv_memb(off: i64, base: string) -> LOperand {
    if off >= 0 && off <= 504 { return _arm64_op_label("[sp, #" + to_string(off) + "]") }
    return _arm64_op_label("[" + base + "]")
}

// sp += / -= amount. ARM64 add/sub immediate is ≤4095 (opt. <<12);
// 16B-slot frames exceed that → materialize the amount into `scr`
// (movz/movk) and use the register form. `scr` (x15) is free at
// prologue entry and at epilogue (return value lives in x0:x1).
fn _hv_sp_adj(buf: [LInstr], mnem: string, amount: i64, scr: string) -> [LInstr] {
    let mut out = buf
    if amount <= 4095 {
        out.push(_arm64_instr3(mnem, _arm64_op_reg("sp"), _arm64_op_reg("sp"),
                         _arm64_op_label("#" + to_string(amount)), "sp adj"))
        return out
    }
    out = _arm64_emit_imm_to_reg(out, scr, amount)
    out.push(_arm64_instr3(mnem, _arm64_op_reg("sp"), _arm64_op_reg("sp"),
                     _arm64_op_reg(scr), "sp adj (big frame)"))
    return out
}

fn _hv_load(buf: [LInstr], o: Operand, st: ArmStrTab, rm: RegMap,
            lo: string, hi: string) -> [LInstr] {
    let mut out = buf
    if o.kind == "local" {
        let off = _arm_spill_offset(rm, o.local_id)
        out = _hv_at(out, off, "x15")
        out.push(_arm64_instr3("ldp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                         _hv_memb(off, "x15"), "hv load L" + to_string(o.local_id)))
        return out
    }
    if o.kind == "const_int" {
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#0"), "hv const_int: TAG_INT"))
        if o.int_val >= 0 && o.int_val <= 65535 {
            out.push(_arm64_instr2("movz", _arm64_op_reg(hi),
                             _arm64_op_label("#" + to_string(o.int_val)), "hv const_int val"))
        } else if o.int_val > 65535 {
            out = _arm64_emit_imm_to_reg(out, hi, o.int_val)
        } else {
            // negative: build |n|-1 then mvn (two's complement)
            out = _arm64_emit_imm_to_reg(out, hi, (0 - o.int_val) - 1)
            out.push(_arm64_instr2("mvn", _arm64_op_reg(hi), _arm64_op_reg(hi),
                             "hv const_int: negate"))
        }
        return out
    }
    if o.kind == "const_str" {
        let cl = _arm64_strtab_lookup(st, o.str_val)
        let mut nm = cl
        if len(nm) == 0 { nm = o.str_val }
        out.push(_arm64_instr2("movz", _arm64_op_reg(lo),
                         _arm64_op_label("#3"), "hv const_str: TAG_STR"))
        out.push(_arm64_instr2("adrp", _arm64_op_reg(hi),
                         _arm64_op_label(nm + "@PAGE"), "hv str ptr page"))
        out.push(_arm64_instr3("add", _arm64_op_reg(hi), _arm64_op_reg(hi),
                         _arm64_op_label(nm + "@PAGEOFF"), "hv str ptr off"))
        return out
    }
    if o.kind == "global" {
        let gl = "g" + to_string(o.global_id)
        out.push(_arm64_instr2("adrp", _arm64_op_reg(lo),
                         _arm64_op_label(gl + "@PAGE"), "hv global page"))
        out.push(_arm64_instr3("add", _arm64_op_reg(lo), _arm64_op_reg(lo),
                         _arm64_op_label(gl + "@PAGEOFF"), "hv global off"))
        out.push(_arm64_instr3("ldp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                         _arm64_op_label("[" + lo + "]"), "hv load global " + gl))
        return out
    }
    // unknown → void (TAG_VOID=4, payload 0)
    out.push(_arm64_instr2("movz", _arm64_op_reg(lo), _arm64_op_label("#4"), "hv void"))
    out.push(_arm64_instr2("movz", _arm64_op_reg(hi), _arm64_op_label("#0"), "hv void"))
    return out
}

fn _hv_store(buf: [LInstr], rm: RegMap, id: i64, lo: string, hi: string) -> [LInstr] {
    let mut out = buf
    if id < 0 { return out }
    let off = _arm_spill_offset(rm, id)
    out = _hv_at(out, off, "x15")
    out.push(_arm64_instr3("stp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                     _hv_memb(off, "x15"), "hv store L" + to_string(id)))
    return out
}

// Dispatch by dst: arena_id == -999 marks a module-level mutable
// global (hir_to_mir _lower_hexpr "assign" branch sentinel). Emits a
// PC-relative store into the `g<id>` data slot. Local-slot dsts fall
// through to the normal frame-spill path.
fn _hv_store_dst(buf: [LInstr], rm: RegMap, dst: Local, lo: string, hi: string) -> [LInstr] {
    if dst.arena_id == -999 {
        let mut out = buf
        let gl = "g" + to_string(dst.id)
        out.push(_arm64_instr2("adrp", _arm64_op_reg("x15"),
                         _arm64_op_label(gl + "@PAGE"), "hv global page (store)"))
        out.push(_arm64_instr3("add", _arm64_op_reg("x15"), _arm64_op_reg("x15"),
                         _arm64_op_label(gl + "@PAGEOFF"), "hv global off (store)"))
        out.push(_arm64_instr3("stp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                         _arm64_op_label("[x15]"), "hv store global " + gl))
        return out
    }
    return _hv_store(buf, rm, dst.id, lo, hi)
}

// Load a const_str's raw char* (the .LCstr address) into `reg` — for
// the map ABI (hexa_map_set/get take `const char* key`, not HexaVal).
fn _hv_cstr(buf: [LInstr], o: Operand, st: ArmStrTab, reg: string) -> [LInstr] {
    let mut out = buf
    let cl = _arm64_strtab_lookup(st, o.str_val)
    let mut nm = cl
    if len(nm) == 0 { nm = o.str_val }
    out.push(_arm64_instr2("adrp", _arm64_op_reg(reg),
                     _arm64_op_label(nm + "@PAGE"), "cstr key page"))
    out.push(_arm64_instr3("add", _arm64_op_reg(reg), _arm64_op_reg(reg),
                     _arm64_op_label(nm + "@PAGEOFF"), "cstr key off"))
    return out
}

fn _hv_ldslot(buf: [LInstr], rm: RegMap, id: i64, lo: string, hi: string) -> [LInstr] {
    let mut out = buf
    let off = _arm_spill_offset(rm, id)
    out = _hv_at(out, off, "x15")
    out.push(_arm64_instr3("ldp", _arm64_op_reg(lo), _arm64_op_reg(hi),
                     _hv_memb(off, "x15"), "hv reload L" + to_string(id)))
    return out
}

// binop/compare → runtime symbol (codegen_c2-authoritative). "" =
// special-cased (!=, &&, ||, bitwise) by the BINOP emitter.
fn _hv_binop_sym(op: string) -> string {
    if op == "+"  || op == "add" { return "hexa_add_slow" }  // hexa_add is a runtime.h MACRO; the linkable fn is hexa_add_slow
    if op == "-"  || op == "sub" { return "hexa_sub" }
    if op == "*"  || op == "mul" { return "hexa_mul" }
    if op == "/"  || op == "div" || op == "sdiv" { return "hexa_div" }
    if op == "%"  || op == "mod" || op == "rem"  { return "hexa_mod" }
    if op == "==" || op == "eq"  || op == "cmp_eq" { return "hexa_eq" }
    if op == "<"  || op == "lt"  || op == "cmp_lt" { return "hexa_cmp_lt" }
    if op == ">"  || op == "gt"  || op == "cmp_gt" { return "hexa_cmp_gt" }
    if op == "<=" || op == "le"  || op == "cmp_le" { return "hexa_cmp_le" }
    if op == ">=" || op == "ge"  || op == "cmp_ge" { return "hexa_cmp_ge" }
    if op == "concat" { return "hexa_str_concat" }
    return ""
}

// Builtin call target → runtime ABI symbol. Only builtins whose
// runtime.c signature is verified `HexaVal X(HexaVal…)` (i.e. matches
// the new codegen's uniform-HexaVal register ABI, args x0-x7 / return
// x0) are mapped here — for those a pure symbol rename is ABI-correct
// (codegen_c2's hexa_int()/hexa_bool() wrappers are C-expression
// boxing artifacts, irrelevant at the register ABI). Builtins whose
// runtime fn returns int/void (len/contains/starts_with/has_key/
// println), needs cstring-arg conversion (has_key), or has no runtime
// symbol at all (is_alpha/is_alphanumeric — codegen_c2 inline-expands)
// are intentionally NOT mapped: they pass through unchanged (stay
// undefined → link still gated) rather than silently mis-run. That
// residual is the precisely-scoped final builtin-lowering sub-unit.
// Non-builtin (hexa user fn) names pass through → normal mangling.
fn _builtin_runtime_sym(name: string) -> string {
    if name == "append_file"   { return "rt_append_file" }
    if name == "args"          { return "hexa_args" }
    if name == "char_code_at"  { return "hexa_str_char_code_at" }
    if name == "env"           { return "hexa_env_var" }
    if name == "file_size"     { return "rt_file_size" }
    if name == "chars"         { return "hexa_str_chars" }
    if name == "eprintln"      { return "hexa_eprintln" }
    if name == "exit"          { return "hexa_exit" }
    if name == "exec"          { return "hexa_exec" }
    if name == "file_exists"   { return "rt_file_exists" }
    if name == "index_of"      { return "hexa_array_index_of" }
    if name == "join"          { return "hexa_str_join" }
    if name == "push"          { return "hexa_array_push" }
    if name == "read_file"     { return "rt_read_file" }
    if name == "replace"       { return "hexa_str_replace" }
    if name == "split"         { return "hexa_str_split" }
    if name == "substring"     { return "hexa_str_substring" }
    if name == "to_int"        { return "hexa_to_int" }
    if name == "to_string"     { return "hexa_to_string" }
    if name == "trim"          { return "rt_str_trim" }
    if name == "type_of"       { return "hexa_type_of" }
    if name == "write_file"    { return "rt_write_file" }
    if name == "sha256"        { return "hexa_sha256" }
    if name == "sha256_file"   { return "hexa_sha256_file" }
    if name == "println"       { return "hexa_println" }
    if name == "len"           { return "hexa_len" }            // → int (box)
    if name == "contains"      { return "hexa_str_contains" }   // → int (box bool)
    if name == "starts_with"   { return "rt_str_starts_with" }  // → int (box bool)
    if name == "ends_with"     { return "rt_str_ends_with" }    // → int (box bool)
    if name == "is_alpha"          { return "hexa_is_alpha" }          // shim → HexaVal
    if name == "is_alphanumeric"   { return "hexa_is_alphanumeric" }   // shim → HexaVal
    return name
}

// builtin runtime fn return-shape needing a post-call box into HexaVal:
// "int" → sxtw w0 + hexa_int ; "bool" → uxtw w0 + hexa_bool ; "" → none
// (already HexaVal). has_key is handled by its own STMT_CALL path.
fn _builtin_ret_box(name: string) -> string {
    if name == "len"         { return "int" }
    if name == "contains"    { return "bool" }
    if name == "starts_with" { return "bool" }
    if name == "ends_with"   { return "bool" }
    return ""
}

fn _emit_arm64_stmt(out: [LInstr], modhash: string, fname: string, s: Stmt,
                    st: ArmStrTab, rm: RegMap, spill_frame: i64) -> [LInstr] {
    let mut buf = out
    if s.kind == _STMT_ASSIGN {
        // array_lit constructor (mirror of x86_64_linux.hexa 269bb61d;
        // AAPCS64: args x0/x1, call via bl, return x0). dst =
        // hexa_array_new(); per element hexa_array_push(dst, e_i) →
        // recapture x0. Grammar-capped ≤1024 by HX0013 → O(n) bounded.
        // Runtime-call shape mirrors the proven concat idiom below.
        // rebuild-verification DEFERRED (Track-A clang wall) — logic
        // parity with shipped concat emit.
        if s.op == "array_lit" {
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_array_new"),
                             "array_lit: new array"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            let mut i = 0
            while i < len(s.args) {
                buf = _hv_ldslot(buf, rm, s.dst.id, "x0", "x1")
                buf = _hv_load(buf, s.args[i], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_array_push"),
                                 "array_lit: push elem " + to_string(i)))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                i = i + 1
            }
            return buf
        }
        // struct_lit constructor (map-backed; mirror of x86_64 a351b1c9
        // in AAPCS64: x0=map, x1=key const char*, x2=val HexaVal, bl,
        // x0 return). MIR args = [type_str, k0_str, v0, ...] (2a790d85);
        // const_str key → .rodata label = const char* (map_set ABI).
        // type_str ignored in map-backed v1. Runtime-call parity with
        // array_lit/concat; rebuild-verification deferred (Track-A wall).
        if s.op == "struct_lit" && len(s.args) >= 1 {
            // map ABI: m=HexaVal(x0:x1), key=const char*(x2), val=
            // HexaVal(x3:x4). args=[type_str, k0,v0,k1,v1,…].
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_new"),
                             "struct_lit: new map"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            let mut i = 1
            while i + 1 < len(s.args) {
                buf = _hv_ldslot(buf, rm, s.dst.id, "x0", "x1")
                buf = _hv_cstr(buf, s.args[i], st, "x2")
                buf = _hv_load(buf, s.args[i + 1], st, rm, "x3", "x4")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_set"),
                                 "struct_lit: set field"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                i = i + 2
            }
            return buf
        }
        // field access (map-backed; mirror of x86_64 0fe030dd in
        // AAPCS64: x0=base, x1=key const char*, bl hexa_map_get, x0).
        // args = [base, "<name>"_str]; const_str key → .rodata label.
        // Parity with shipped array_lit/struct_lit; rebuild-verification
        // deferred (Track-A clang wall).
        if s.op == "field" && len(s.args) >= 2 {
            // map ABI: base=HexaVal(x0:x1), key=const char*(x2).
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_cstr(buf, s.args[1], st, "x2")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_get"),
                             "field: hexa_map_get"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
            return buf
        }
        if len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == _STMT_BINOP {
        if len(s.args) >= 2 {
            let sym = _hv_binop_sym(s.op)
            if len(sym) > 0 {
                // a → x0:x1, b → x2:x3, bl _sym (HexaVal→HexaVal→HexaVal
                // or →cmp HexaVal-bool), result x0:x1 → dst slot.
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label(sym), "binop " + s.op))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            if s.op == "!=" || s.op == "ne" || s.op == "cmp_ne" {
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_eq"), "ne: eq"))
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                                 "ne: truthy(eq) → w0"))
                buf.push(_arm64_instr3("eor", _arm64_op_reg("x0"),
                                 _arm64_op_reg("x0"), _arm64_op_label("#1"), "ne: !truthy"))
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                                 "ne: box bool"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            if s.op == "&&" || s.op == "||" || s.op == "and" || s.op == "or" {
                // codegen_c2: && = truthy(a)?b:a ; || = truthy(a)?a:b
                let lb = "hvL" + modhash + "_" + fname + "_" + to_string(s.dst.id)
                buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                                 "logic: truthy(a) → w0"))
                buf.push(_arm64_instr2("cbz", _arm64_op_reg("x0"),
                                 _arm64_op_label(lb + "_f"), "logic: !truthy → false-arm"))
                // truthy-arm: && → b, || → a
                if s.op == "||" || s.op == "or" {
                    buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                } else {
                    buf = _hv_load(buf, s.args[1], st, rm, "x0", "x1")
                }
                buf.push(_arm64_instr1("b", _arm64_op_label(lb + "_d"), "logic: → done"))
                buf.push(_arm64_instr0("label", lb + "_f"))
                // false-arm: && → a, || → b
                if s.op == "||" || s.op == "or" {
                    buf = _hv_load(buf, s.args[1], st, rm, "x0", "x1")
                } else {
                    buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
                }
                buf.push(_arm64_instr0("label", lb + "_d"))
                buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
                return buf
            }
            // bitwise / unknown — rare in compiler self-source. Approximate
            // via hexa_add (correctness follow-up if it surfaces at run).
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf = _hv_load(buf, s.args[1], st, rm, "x2", "x3")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_add_slow"),
                             "binop " + s.op + " (approx)"))
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == _STMT_CALL {
        // has_key(m, key) special: runtime ABI is
        // hexa_bool(hexa_map_contains_key(HexaVal m, const char* key))
        // (codegen_c2:4302). key is a HexaVal var → hexa_to_cstring it.
        if s.op == "has_key" && len(s.args) >= 2 {
            buf = _hv_load(buf, s.args[1], st, rm, "x0", "x1")  // key HexaVal
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_to_cstring"),
                             "has_key: key → cstring"))
            buf.push(_arm64_instr2("mov", _arm64_op_reg("x9"),
                             _arm64_op_reg("x0"), "has_key: save key cstr"))
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // map m → x0:x1
            buf.push(_arm64_instr2("mov", _arm64_op_reg("x2"),
                             _arm64_op_reg("x9"), "has_key: key arg (x2)"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_map_contains_key"),
                             "has_key: map_contains_key → int"))
            buf.push(_arm64_instr2("uxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "has_key: zext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                             "has_key: box bool"))
            if s.dst.id >= 0 { buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1") }
            return buf
        }
        // C7 — AAPCS64 arm64 stack spill for args 9+.
        // Args 9+ live at [sp, #0], [sp, #8], ..., with sp held 16-byte
        // aligned at every memory access. Unlike x86_64, SSA spill access
        // is sp-relative, so a per-call sub/add would corrupt SSA offsets.
        // Instead the per-fn outgoing-call overflow region is pre-allocated
        // at the bottom of the frame (rm.call_overflow_bytes is non-zero
        // when this fn has any overflow call), and _arm_spill_offset shifts
        // SSA offsets above it. Here we just `str` into the reserved slots.
        // AAPCS64: each 16B HexaVal arg occupies a register PAIR —
        // arg0→x0:x1, arg1→x2:x3, arg2→x4:x5, arg3→x6:x7 (4 pair-args
        // in the 8 GPRs); args ≥4 go to 16B stack slots [sp,#(i-4)*16].
        // Return is x0:x1 → dst slot.
        let arg_n = len(s.args)
        let mut i = 0
        while i < arg_n {
            if i < 4 {
                let lo = "x" + to_string(i * 2)
                let hi = "x" + to_string(i * 2 + 1)
                buf = _hv_load(buf, s.args[i], st, rm, lo, hi)
            } else {
                buf = _hv_load(buf, s.args[i], st, rm, "x9", "x10")
                let off = (i - 4) * 16
                buf = _hv_at(buf, off, "x15")
                buf.push(_arm64_instr3("stp", _arm64_op_reg("x9"),
                                 _arm64_op_reg("x10"), _hv_memb(off, "x15"),
                                 "C7: stack arg " + to_string(i)))
            }
            i = i + 1
        }
        let target = _builtin_runtime_sym(s.op)
        buf.push(_arm64_instr1("bl", _arm64_op_label(target), "call " + target))
        // Box int/bool-returning runtime builtins into a HexaVal (the
        // callee returns a C int in w0; A′ expects x0:x1 HexaVal).
        let box = _builtin_ret_box(s.op)
        if box == "int" {
            buf.push(_arm64_instr2("sxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "ret int: sign-ext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_int"),
                             "ret int: box → HexaVal"))
        }
        if box == "bool" {
            buf.push(_arm64_instr2("uxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "ret bool: zero-ext"))
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_bool"),
                             "ret bool: box → HexaVal"))
        }
        if s.dst.id >= 0 {
            buf = _hv_store_dst(buf, rm, s.dst, "x0", "x1")
        }
        return buf
    }
    if s.kind == _STMT_RETURN {
        if len(s.args) >= 1 {
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")  // AAPCS64 16B return = x0:x1
        }
        // C7 — epilogue frees spill_frame + call-overflow region (both
        // allocated in a single prologue sub; see _arm64_lower_func).
        let epilogue_total = spill_frame + rm.call_overflow_bytes
        if epilogue_total > 0 {
            buf = _hv_sp_adj(buf, "add", epilogue_total, "x15")
        }
        buf.push(_arm64_instr3("ldp", _arm64_op_reg("x29"), _arm64_op_reg("x30"),
                         _arm64_op_label("[sp], #16"), "epilogue: restore fp/lr"))
        buf.push(_arm64_instr0("ret", "return"))
        return buf
    }
    if s.kind == _STMT_BR {
        let lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_arm64_instr1("b", _arm64_op_label(lab), "branch"))
        return buf
    }
    if s.kind == _STMT_BR_COND {
        if len(s.args) > 0 {
            // cond HexaVal → x0:x1; hexa_truthy → int w0; zero-extend
            // (callee leaves upper x0 unspecified) then cbz to else.
            buf = _hv_load(buf, s.args[0], st, rm, "x0", "x1")
            buf.push(_arm64_instr1("bl", _arm64_op_label("hexa_truthy"),
                             "br_cond: truthy → w0"))
            buf.push(_arm64_instr2("uxtw", _arm64_op_reg("x0"),
                             _arm64_op_reg("w0"), "br_cond: zext w0"))
            let else_lab = _arm64_block_label(modhash, fname, s.target_block_else)
            buf.push(_arm64_instr2("cbz", _arm64_op_reg("x0"),
                             _arm64_op_label(else_lab), "br_cond: !truthy -> else"))
        }
        let then_lab = _arm64_block_label(modhash, fname, s.target_block)
        buf.push(_arm64_instr1("b", _arm64_op_label(then_lab), "branch -> then"))
        return buf
    }
    if s.kind == "load" {
        if len(s.args) >= 1 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x10")
            let base_op = _arm64_op_resolve(s.args[0], st, rm, "x10")
            let mut off = 0
            if len(s.args) >= 2 && s.args[1].kind == "const_int" {
                off = s.args[1].int_val
            }
            let dst = _arm64_op_reg(_arm64_dst_reg(rm, s.dst.id))
            buf.push(_arm64_instr2("ldr", dst, _arm64_op_mem(base_op.reg.name, off),
                             "load"))
            buf = _arm64_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == "store" {
        if len(s.args) >= 2 {
            buf = _arm64_op_rm(buf, s.args[0], st, rm, "x10")
            buf = _arm64_op_rm(buf, s.args[1], st, rm, "x11")
            let base_op = _arm64_op_resolve(s.args[0], st, rm, "x10")
            let src = _arm64_op_resolve(s.args[1], st, rm, "x11")
            let mut off = 0
            if len(s.args) >= 3 && s.args[2].kind == "const_int" {
                off = s.args[2].int_val
            }
            buf.push(_arm64_instr2("str", src, _arm64_op_mem(base_op.reg.name, off),
                             "store"))
        }
        return buf
    }
    buf.push(_arm64_instr0("nop", "unhandled stmt kind " + s.kind))
    return buf
}

// ── Function lowering ────────────────────────────────────────

fn _arm64_lower_func(mf: MFunc, st: ArmStrTab, modhash: string) -> LFunc {
    let mut instrs = []

    // C6 — run linear-scan regalloc up front so the prologue can size
    // the spill frame and the body can resolve operands through the
    // assigned RegMap.
    let alloc = _arm64_assign_regs(mf)
    let spill_frame = alloc.frame_size

    // C7 — pre-allocate the maximum outgoing-call overflow region in
    // bytes (16-aligned). Reused by every call site in this fn so we
    // don't sub/add sp mid-frame. SSA spill offsets are shifted above
    // this region via rm.call_overflow_bytes (see _arm_spill_offset).
    let max_overflow = _arm64_max_call_overflow(mf)
    let mut call_overflow_bytes = 0
    if max_overflow > 0 {
        call_overflow_bytes = ((max_overflow * 8 + 15) / 16) * 16
    }
    let rm = RegMap {
        ids: alloc.map.ids,
        regs: alloc.map.regs,
        slots: alloc.map.slots,
        call_overflow_bytes: call_overflow_bytes
    }
    let total_frame = spill_frame + call_overflow_bytes

    // Prologue
    instrs.push(_arm64_instr3(
        "stp",
        _arm64_op_reg("x29"),
        _arm64_op_reg("x30"),
        _arm64_op_label("[sp, #-16]!"),
        "prologue: save fp/lr"
    ))
    instrs.push(_arm64_instr2("mov", _arm64_op_reg("x29"), _arm64_op_reg("sp"), "prologue: set fp"))

    // Spill-frame allocation (after fp/lr save). Covers both the SSA
    // spill region (top) and the outgoing-call overflow region (bottom).
    if total_frame > 0 {
        instrs = _hv_sp_adj(instrs, "sub", total_frame, "x15")
    }

    // Path A (A′): each 16B HexaVal param arrives in a register PAIR
    // (param0→x0:x1, param1→x2:x3, param2→x4:x5, param3→x6:x7); params
    // ≥4 arrive in caller 16B stack slots above the saved fp/lr at
    // [x29, #16 + (p-4)*16]. Store each into the param's 16B frame slot
    // (all params are force-spilled). x29 set to old sp before the
    // frame `sub`, so [x29,#16+…] reaches the caller's outgoing area.
    let mut p = 0
    while p < len(mf.params) {
        let pid = mf.params[p].id
        let poff = _arm_spill_offset(rm, pid)
        if p < 4 {
            let lo = "x" + to_string(p * 2)
            let hi = "x" + to_string(p * 2 + 1)
            instrs = _hv_at(instrs, poff, "x15")
            instrs.push(_arm64_instr3("stp", _arm64_op_reg(lo),
                             _arm64_op_reg(hi), _hv_memb(poff, "x15"),
                             "ingress param " + to_string(p)))
        } else {
            let inoff = 16 + (p - 4) * 16
            instrs.push(_arm64_instr3("ldp", _arm64_op_reg("x9"),
                             _arm64_op_reg("x10"),
                             _arm64_op_label("[x29, #" + to_string(inoff) + "]"),
                             "ingress stack param " + to_string(p)))
            instrs = _hv_at(instrs, poff, "x15")
            instrs.push(_arm64_instr3("stp", _arm64_op_reg("x9"),
                             _arm64_op_reg("x10"), _hv_memb(poff, "x15"),
                             "store stack param " + to_string(p)))
        }
        p = p + 1
    }

    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        instrs.push(_arm64_instr0("label", _arm64_block_label(modhash, mf.name, blk.id)))
        let mut si = 0
        while si < len(blk.stmts) {
            instrs = _emit_arm64_stmt(instrs, modhash, mf.name,
                                      blk.stmts[si], st, rm, spill_frame)
            si = si + 1
        }
        bi = bi + 1
    }

    // Safety epilogue (in case last block lacks _STMT_RETURN)
    let last_is_ret = false
    if len(instrs) > 0 {
        let last = instrs[len(instrs) - 1]
        if last.op == "ret" {
            return LFunc {
                name: mf.name,
                target: "arm64-apple-darwin",
                instrs: instrs,
                frame_size: 16 + total_frame,
                callee_saved: []
            }
        }
    }
    if total_frame > 0 {
        instrs = _hv_sp_adj(instrs, "add", total_frame, "x15")
    }
    instrs.push(_arm64_instr3("ldp", _arm64_op_reg("x29"), _arm64_op_reg("x30"),
                        _arm64_op_label("[sp], #16"), "epilogue: restore fp/lr"))
    instrs.push(_arm64_instr0("ret", "return"))

    return LFunc {
        name: mf.name,
        target: "arm64-apple-darwin",
        instrs: instrs,
        frame_size: 16 + total_frame,
        callee_saved: []
    }
}

// ── String table collection (for rodata emission) ────────────
//
// Walk every Stmt in every Block in every Func looking for
// `const_str` operands and record them in an ArmStrTab. Each unique
// literal gets label ".LCstr<N>" (N = insertion order). Both targets
// share this label scheme so rodata labels remain stable per source
// independently of the chosen target.

fn _collect_strs_from_stmt(st: ArmStrTab, s: Stmt) -> ArmStrTab {
    let mut out = st
    let mut i = 0
    while i < len(s.args) {
        let o = s.args[i]
        if o.kind == "const_str" {
            if len(_arm64_strtab_lookup(out, o.str_val)) == 0 {
                let mut keys = out.keys
                let mut labs = out.labels
                let n = len(keys)
                // F6 P0a — forced copy: o.str_val is the MFunc operand's
                // string handle; st outlives every streaming iteration, so
                // it must own its keys independently of any MFunc.
                // PLAN-stage3-footprint-F6.md.
                keys.push(o.str_val.substring(0, len(o.str_val)))
                labs.push(".LCstr" + to_string(n))
                out = ArmStrTab { keys: keys, labels: labs }
            }
        }
        i = i + 1
    }
    return out
}

// F1 (streaming footprint) — per-MFunc string-literal interning. The
// streaming codegen path (compiler/codegen/stream.hexa, PLAN-stage3-
// footprint.md F2) calls this once per function as it is lowered, so
// the ArmStrTab grows incrementally and the whole MModule never has to
// be materialised. Label assignment is insertion-ordered, so the table
// is byte-deterministic regardless of call cadence — incremental and
// whole-module interning produce bit-identical rodata.
fn _arm_strtab_collect_fn(st: ArmStrTab, f: MFunc) -> ArmStrTab {
    let mut acc = st
    let mut bi = 0
    while bi < len(f.blocks) {
        let blk = f.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            acc = _collect_strs_from_stmt(acc, blk.stmts[si])
            si = si + 1
        }
        bi = bi + 1
    }
    return acc
}

// Whole-module strtab — the non-streaming path. Now a thin fold over
// _arm_strtab_collect_fn so both paths share one collector (no drift).
fn _build_arm_strtab(module: MModule) -> ArmStrTab {
    let mut st = ArmStrTab { keys: [], labels: [] }
    let mut fi = 0
    while fi < len(module.funcs) {
        st = _arm_strtab_collect_fn(st, module.funcs[fi])
        fi = fi + 1
    }
    return st
}

// Convert a string into a hex-encoded byte sequence (per-LSection
// payload format defined by lir.hexa). Appends a NUL terminator so
// the rodata entry is C-string compatible.
fn _hex_nibble(n: i64) -> string {
    if n == 0  { return "0" }
    if n == 1  { return "1" }
    if n == 2  { return "2" }
    if n == 3  { return "3" }
    if n == 4  { return "4" }
    if n == 5  { return "5" }
    if n == 6  { return "6" }
    if n == 7  { return "7" }
    if n == 8  { return "8" }
    if n == 9  { return "9" }
    if n == 10 { return "a" }
    if n == 11 { return "b" }
    if n == 12 { return "c" }
    if n == 13 { return "d" }
    if n == 14 { return "e" }
    return "f"
}

fn _byte_to_hex(b: i64) -> string {
    let hi = b / 16
    let lo = b - hi * 16
    return _hex_nibble(hi) + _hex_nibble(lo)
}

// Manual ASCII codepoint lookup. Stage0 hexa has no `ord`/codepoint
// primitive surfaced to user code, so we hard-code the printable
// range that real-world tests touch.
fn _ascii_code(ch: string) -> i64 {
    if ch == " " { return 32 }
    if ch == "!" { return 33 }
    if ch == "\"" { return 34 }
    if ch == "#" { return 35 }
    if ch == "$" { return 36 }
    if ch == "%" { return 37 }
    if ch == "&" { return 38 }
    if ch == "'" { return 39 }
    if ch == "(" { return 40 }
    if ch == ")" { return 41 }
    if ch == "*" { return 42 }
    if ch == "+" { return 43 }
    if ch == "," { return 44 }
    if ch == "-" { return 45 }
    if ch == "." { return 46 }
    if ch == "/" { return 47 }
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == ":" { return 58 }
    if ch == ";" { return 59 }
    if ch == "<" { return 60 }
    if ch == "=" { return 61 }
    if ch == ">" { return 62 }
    if ch == "?" { return 63 }
    if ch == "@" { return 64 }
    if ch == "A" { return 65 }
    if ch == "B" { return 66 }
    if ch == "C" { return 67 }
    if ch == "D" { return 68 }
    if ch == "E" { return 69 }
    if ch == "F" { return 70 }
    if ch == "G" { return 71 }
    if ch == "H" { return 72 }
    if ch == "I" { return 73 }
    if ch == "J" { return 74 }
    if ch == "K" { return 75 }
    if ch == "L" { return 76 }
    if ch == "M" { return 77 }
    if ch == "N" { return 78 }
    if ch == "O" { return 79 }
    if ch == "P" { return 80 }
    if ch == "Q" { return 81 }
    if ch == "R" { return 82 }
    if ch == "S" { return 83 }
    if ch == "T" { return 84 }
    if ch == "U" { return 85 }
    if ch == "V" { return 86 }
    if ch == "W" { return 87 }
    if ch == "X" { return 88 }
    if ch == "Y" { return 89 }
    if ch == "Z" { return 90 }
    if ch == "[" { return 91 }
    if ch == "\\" { return 92 }
    if ch == "]" { return 93 }
    if ch == "^" { return 94 }
    if ch == "_" { return 95 }
    if ch == "`" { return 96 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    if ch == "g" { return 103 }
    if ch == "h" { return 104 }
    if ch == "i" { return 105 }
    if ch == "j" { return 106 }
    if ch == "k" { return 107 }
    if ch == "l" { return 108 }
    if ch == "m" { return 109 }
    if ch == "n" { return 110 }
    if ch == "o" { return 111 }
    if ch == "p" { return 112 }
    if ch == "q" { return 113 }
    if ch == "r" { return 114 }
    if ch == "s" { return 115 }
    if ch == "t" { return 116 }
    if ch == "u" { return 117 }
    if ch == "v" { return 118 }
    if ch == "w" { return 119 }
    if ch == "x" { return 120 }
    if ch == "y" { return 121 }
    if ch == "z" { return 122 }
    if ch == "{" { return 123 }
    if ch == "|" { return 124 }
    if ch == "}" { return 125 }
    if ch == "~" { return 126 }
    if ch == "\n" { return 10 }
    if ch == "\t" { return 9 }
    return 63 // '?' for unknown (non-ASCII / control)
}

fn _str_to_hex_bytes(s: string) -> string {
    let cs = s.chars()
    let mut out = ""
    let mut i = 0
    while i < len(cs) {
        out = out + _byte_to_hex(_ascii_code(cs[i]))
        i = i + 1
    }
    out = out + "00" // NUL terminator
    return out
}

fn _strtab_to_rodata(st: ArmStrTab) -> [LSection] {
    let mut out: [LSection] = []
    let mut i = 0
    while i < len(st.keys) {
        out.push(LSection {
            name: st.labels[i],
            bytes: _str_to_hex_bytes(st.keys[i]),
            align: 0
        })
        i = i + 1
    }
    return out
}

// ── Module entry point ───────────────────────────────────────

pub fn codegen_arm64_darwin(module: MModule) -> LModule {
    let st = _build_arm_strtab(module)
    let mut funcs = []
    let mut i = 0
    while i < len(module.funcs) {
        // Stage1 C8 — recompute modhash inline at every call site so
        // stage0's transitive-let binding gap (see _STMT_* mirror at
        // top of this file) cannot hand the lowering pass a void.
        funcs.push(_arm64_lower_func(module.funcs[i], st, _arm64_modhash(module.file)))
        i = i + 1
    }
    // Emit a writable 16-byte slot per module-level mutable global
    // (symbol `g<id>`). Runtime init via the parser's synthetic-main
    // `g<id> = E` assign — see hir_to_mir global resolution.
    // Mach-O user symbols carry a leading `_` prefix; the codegen's
    // `g<id>` references resolve to `_g<id>` (matching `_hexa_…`
    // builtins). Emit the data label with the same prefix so the link
    // resolves to one symbol — without this the linker reports
    // `_g0 undefined` even though `g0:` exists in `__DATA,__data`.
    let mut gnames: [string] = []
    let mut gi = 0
    while gi < len(module.globals) {
        gnames.push("_g" + to_string(module.globals[gi].id))
        gi = gi + 1
    }
    return LModule {
        file: module.file,
        target: "arm64-apple-darwin",
        funcs: funcs,
        rodata: _strtab_to_rodata(st),
        bss: [],
        globals: gnames
    }
}
