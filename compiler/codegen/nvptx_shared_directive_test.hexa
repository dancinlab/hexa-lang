// compiler/codegen/nvptx_shared_directive_test.hexa
// PR-C piece 4+5 — `@shared` directive + `ld.shared` / `st.shared` falsifier.
//
// @version 0.0.1
// @capabilities [pure]
// @phase("parse_only")
//
// Falsifier for the PR-C @shared landing piece 4+5 (parent PR #1313 piece
// 2+3 merged — Expr.annotations / HExpr.annotations / MLocal.space). This
// fixture hand-builds an MFunc whose body Local carries `space: "shared"`
// (mimicking the post-`@shared let sm: [f64; 256]` MIR shape that
// hir_to_mir would produce in a full source-to-PTX run), drives it
// through `codegen_emit_ptx_sm80`, and substring-checks the resulting
// PTX text for:
//
//   piece 4 — `.shared .align 8 .b8 _hexa_sh_<fn>[2048];` directive emit.
//   piece 4 — `mov.u64 %sh<id>, _hexa_sh_<fn> + 0;` init in kernel prologue.
//   piece 5 — `ld.shared.f64` mnemonic at the IndexGet site (NOT ld.global).
//   piece 5 — `st.shared.f64` mnemonic at the IndexSet site (NOT st.global).
//
// HONEST SCOPE — codegen-only. Real source-to-silicon (a parser-driven
// `@shared let sm: [f64; 256]` kernel through the full HIR→MIR→PTX
// pipeline) is a separate fire (F-GPU-SWEEP-SHARED-REDUCE-NUMERIC on
// ubu-2 RTX 5070). This fixture proves the codegen seam is wired.

import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "./nvptx_target.hexa"

// ── Minimal MIR construction helpers (kept local — mirror of the
//    sibling lower_test helpers so this file stays self-contained). ──

fn _local(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name, precision: "", space: "" }
}

fn _local_shared(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name, precision: "", space: "shared" }
}

fn _local_i64(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 1, name_hint: name, precision: "", space: "" }
}

fn _local_array_f64(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 103, name_hint: name, precision: "", space: "" }
}

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "", precision: "", space: "" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local", local_id: local_id,
        int_val: 0, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _op_const_int(v: i64) -> Operand {
    return Operand {
        kind: "const_int", local_id: -1,
        int_val: v, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _stmt_call(dst: Local, callee: string) -> Stmt {
    return Stmt {
        kind: STMT_CALL, dst: dst, op: callee, args: [],
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_call_with_args(dst: Local, callee: string, xs: [Operand]) -> Stmt {
    return Stmt {
        kind: STMT_CALL, dst: dst, op: callee, args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_index_get(dst: Local, base_id: i64, idx_id: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(base_id))
    xs.push(_op_local(idx_id))
    return Stmt {
        kind: STMT_ASSIGN, dst: dst, op: "index", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_index_set(base_id: i64, idx_id: i64, val_id: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(base_id))
    xs.push(_op_local(idx_id))
    xs.push(_op_local(val_id))
    return Stmt {
        kind: STMT_ASSIGN, dst: _miss_local(), op: "index_set", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_return() -> Stmt {
    return Stmt {
        kind: STMT_RETURN, dst: _miss_local(), op: "", args: [],
        target_block: -1, target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

// ── Text inspection helpers ─────────────────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    return hay.find(needle) >= 0
}

fn _check(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if _contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (missing: `" + needle + "`)")
    return false
}

fn _check_not(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if !_contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (unexpected: `" + needle + "`)")
    return false
}

// ── Fixture: a kernel with `@shared let sm: [f64; 256]` + sm[i] read +
//    sm[i] = v write. The MIR shape mirrors what hir_to_mir would
//    produce when the full source-to-PTX path lands. ─────────────────
//
//   @gpu_kernel
//   fn sweep_pred(a: [f64], partial: [f64], n: i64) {
//       @shared let sm: [f64; 256] = ...     // -> Local id=5, space="shared"
//       let i32 = gpu_thread_id_x()          // -> Local id=6, U32
//       let i   = to_i64(i32)                // -> Local id=7, U64
//       let av  = a[i]                       // -> Local id=8, F64 (ld.global.f64)
//       sm[i]   = av                         // -> st.shared.f64 (piece 5)
//       let sv  = sm[i]                      // -> Local id=9, F64 (ld.shared.f64)
//       partial[i] = sv                      // -> st.global.f64 (UNCHANGED)
//   }

fn _build_case_shared_directive() -> MModule {
    let a       = _local_array_f64(0, "a")
    let partial = _local_array_f64(1, "partial")
    let n_p     = _local_i64(2, "n")
    let i32_l   = _local(3, "i32")     // gpu_thread_id_x → U32
    let i_l     = _local(4, "i")       // to_i64(i32) → U64
    let sm      = _local_shared(5, "sm")   // @shared base — Pass 0.5 → SHARED bank
    let av      = _local(6, "av")      // a[i] → F64
    let sv      = _local(7, "sv")      // sm[i] → F64

    let mut tii = []
    tii.push(_op_local(i32_l.id))

    let mut s0 = []
    s0.push(_stmt_call(i32_l, "gpu_thread_id_x"))
    s0.push(_stmt_call_with_args(i_l, "to_i64", tii))
    s0.push(_stmt_index_get(av, a.id, i_l.id))             // av = a[i]            (ld.global.f64)
    s0.push(_stmt_index_set(sm.id, i_l.id, av.id))         // sm[i] = av           (st.shared.f64)
    s0.push(_stmt_index_get(sv, sm.id, i_l.id))            // sv = sm[i]           (ld.shared.f64)
    s0.push(_stmt_index_set(partial.id, i_l.id, sv.id))    // partial[i] = sv      (st.global.f64)
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a); params.push(partial); params.push(n_p)
    let mut locals = []
    locals.push(a); locals.push(partial); locals.push(n_p)
    locals.push(i32_l); locals.push(i_l); locals.push(sm)
    locals.push(av); locals.push(sv)

    let mf = MFunc {
        name: "sweep_pred",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_shared_directive.hexa", funcs: fns, globals: [] }
}

fn _test_shared_directive() -> bool {
    let mut ok = true
    let mod_sh = _build_case_shared_directive()
    let ptx = codegen_emit_ptx_sm80(mod_sh)

    println("")
    println("── emitted PTX (PR-C piece 4+5 @shared directive + ld/st.shared, sm_80) ──")
    println(ptx)

    // Piece 4 — `.shared` staging-slot directive emit.
    ok = _check(ok, ptx, ".shared .align 8 .b8 _hexa_sh_sweep_pred[2048];",
        "piece 4 — `.shared .align 8 .b8 _hexa_sh_<fn>[2048];` directive emitted")

    // Piece 4 — `.reg .u64 %sh5` declaration (the SHARED base pointer
    // for Local id=5 lands in the .u64 bank since the runtime address
    // is a device pointer).
    ok = _check(ok, ptx, ".reg .u64 %sh5",
        "piece 4 — `.reg .u64 %sh5` SHARED base-pointer reg declared")

    // Piece 4 — `mov.u64 %sh5, _hexa_sh_sweep_pred + 0;` init in the
    // kernel-entry prologue (after the param-load ld.param.u64 lines).
    ok = _check(ok, ptx, "mov.u64 %sh5, _hexa_sh_sweep_pred + 0",
        "piece 4 — `mov.u64 %sh<id>, _hexa_sh_<fn> + <offset>;` init emitted")

    // Piece 5 — IndexGet on SHARED base → `ld.shared.f64`.
    ok = _check(ok, ptx, "ld.shared.f64",
        "piece 5 — IndexGet on @shared base lowers to `ld.shared.f64`")

    // Piece 5 — IndexSet on SHARED base → `st.shared.f64`.
    ok = _check(ok, ptx, "st.shared.f64",
        "piece 5 — IndexSet on @shared base lowers to `st.shared.f64`")

    // Piece 5 negative guard — the SHARED reads/writes must NOT emit
    // the `.global` variant. We emit BOTH a shared (sm[i]) AND a global
    // (partial[i]) IndexSet, so `st.global.f64` IS expected to appear
    // exactly once (for partial[i] = sv). `ld.global.f64` appears for
    // a[i] (once). Substring-counts:
    let n_ld_global = _count_substr(ptx, "ld.global.f64")
    let n_ld_shared = _count_substr(ptx, "ld.shared.f64")
    let n_st_global = _count_substr(ptx, "st.global.f64")
    let n_st_shared = _count_substr(ptx, "st.shared.f64")
    println("  histogram: ld.global.f64=" + to_string(n_ld_global) + " ld.shared.f64=" + to_string(n_ld_shared) +
            " st.global.f64=" + to_string(n_st_global) + " st.shared.f64=" + to_string(n_st_shared))
    if n_ld_global != 1 {
        println("  FAIL: expected exactly 1 ld.global.f64 (a[i] read), got " + to_string(n_ld_global))
        ok = false
    }
    if n_ld_shared != 1 {
        println("  FAIL: expected exactly 1 ld.shared.f64 (sm[i] read), got " + to_string(n_ld_shared))
        ok = false
    }
    if n_st_global != 1 {
        println("  FAIL: expected exactly 1 st.global.f64 (partial[i] write), got " + to_string(n_st_global))
        ok = false
    }
    if n_st_shared != 1 {
        println("  FAIL: expected exactly 1 st.shared.f64 (sm[i] write), got " + to_string(n_st_shared))
        ok = false
    }

    // Sanity: only ONE `.shared .align 8` directive for the single-fn
    // module (the WMMA `.shared .align 16` form is a DIFFERENT family —
    // a non-@shared module should never emit either; this fixture has
    // @shared so the 8-aligned one must appear exactly once).
    let n_shared_8 = _count_substr(ptx, ".shared .align 8 .b8 _hexa_sh_")
    if n_shared_8 != 1 {
        println("  FAIL: expected 1 `.shared .align 8` directive, got " + to_string(n_shared_8))
        ok = false
    }
    // Negative guard: must NOT spuriously emit the WMMA `.shared
    // .align 16` form (no WMMA in this fixture).
    if _contains(ptx, ".shared .align 16 .b8 _hexa_wmma_stage_") {
        println("  FAIL: spurious WMMA staging decl for non-WMMA kernel")
        ok = false
    }

    return ok
}

fn _count_substr(hay: string, needle: string) -> i64 {
    if len(needle) == 0 { return 0 }
    let mut n: i64 = 0
    let mut i: i64 = 0
    let H = len(hay)
    let N = len(needle)
    while i + N <= H {
        if hay.substring(i, i + N) == needle {
            n = n + 1
            i = i + N
        } else {
            i = i + 1
        }
    }
    return n
}

// ── Driver ──────────────────────────────────────────────────────────

fn main() {
    println("══════════════════════════════════════════════")
    println("  PR-C piece 4+5 — @shared directive + ld/st.shared smoke")
    println("══════════════════════════════════════════════")

    let ok_sh = _test_shared_directive()

    println("")
    println("══════════════════════════════════════════════")
    if ok_sh {
        println("PASS: PR-C piece 4+5 — .shared directive + ld.shared / st.shared routing wired")
    } else {
        println("FAIL: PR-C piece 4+5 smoke not satisfied.")
    }
    println("══════════════════════════════════════════════")
    if !ok_sh { exit(1) }
}
