// HEXA Native Compiler — RFC 055 055-P2 / naive FP64 GEMM PTX emit smoke
//
// @version 0.0.1
// @capabilities [pure]
//
// RFC 055 055-P2 smoke entry point — exercises the keystone naive-GEMM
// emitter (`emit_ptx_gemm_module`) and re-checks the `@gpu` subset
// validator (`nvptx_validate_gpu_subset`) on the GEMM kernel shape.
// Mirrors the 055-P1 `nvptx_vec_add_test.hexa` shape (TEXT-shape CONTAINS
// asserts only — no GPU fire, no ptxas invocation; the real-GPU fire is
// `tool/dispatch_r055_p2_gemm.sh`).
//
// 055-P2 falsifier coverage in this file:
//   F-RFC055-PTX-EMIT (partial — text-shape; the ptxas-accept +
//                     F-RFC055-GEMM-FEASIBLE correctness halves live in
//                     the dispatch script).
//   F-RFC055-CPU-CODEGEN-UNTOUCHED — this test never imports a CPU
//                                    codegen module; running it leaves
//                                    the CPU emit path untouched.
//
// Run:
//   hexa build compiler/codegen/nvptx_gemm_test.hexa -o build/nvptx_gemm_test
//   ./build/nvptx_gemm_test

import "./nvptx_target.hexa"
import "./nvptx_ptx_ops.hexa"

// ── Text inspection ──────────────────────────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    return hay.find(needle) >= 0
}

fn _check(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if _contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (missing: `" + needle + "`)")
    return false
}

// ── naive GEMM PTX emit test (sm_80 + sm_90 paths) ───────────────────

fn _test_emit_gemm_module() -> bool {
    let mut ok = true

    // sm_90 emit
    let ptx90 = emit_ptx_gemm_module(NVPTX_TARGET_SM90)
    println("")
    println("── emitted PTX naive GEMM (sm_90) ──")
    println(ptx90)

    // module header
    ok = _check(ok, ptx90, ".version 7.8",         "sm_90 .version directive")
    ok = _check(ok, ptx90, ".target sm_90",        "sm_90 .target directive")
    ok = _check(ok, ptx90, ".address_size 64",     "sm_90 .address_size")
    // kernel header + 6-param bank
    ok = _check(ok, ptx90, ".visible .entry gemm", "sm_90 .visible .entry header")
    ok = _check(ok, ptx90, ".param .u64 gemm_param_0", "sm_90 param 0 (a base)")
    ok = _check(ok, ptx90, ".param .u64 gemm_param_5", "sm_90 param 5 (k extent)")
    // register banks
    ok = _check(ok, ptx90, ".reg .u32 %r17;",      "sm_90 .u32 bank up to %r17")
    ok = _check(ok, ptx90, ".reg .u64 %rd14;",     "sm_90 .u64 bank up to %rd14")
    ok = _check(ok, ptx90, ".reg .pred %p2;",      "sm_90 .pred bank up to %p2")
    ok = _check(ok, ptx90, ".reg .f64 %fd0;",      "sm_90 .f64 bank")
    // 6 param loads
    ok = _check(ok, ptx90, "ld.param.u64 %rd0, [gemm_param_0]", "sm_90 ld.param a base")
    ok = _check(ok, ptx90, "ld.param.u64 %rd5, [gemm_param_5]", "sm_90 ld.param k extent")
    // 2-D thread index — y axis (row) + x axis (col)
    ok = _check(ok, ptx90, "mov.u32 %r0, %ctaid.y", "sm_90 mov %ctaid.y (gpu_block_id_y)")
    ok = _check(ok, ptx90, "mov.u32 %r2, %tid.y",   "sm_90 mov %tid.y   (gpu_thread_id_y)")
    ok = _check(ok, ptx90, "mad.lo.s32 %r3, %r0, %r1, %r2", "sm_90 row compose")
    ok = _check(ok, ptx90, "mov.u32 %r6, %tid.x",   "sm_90 mov %tid.x   (gpu_thread_id_x)")
    ok = _check(ok, ptx90, "mad.lo.s32 %r7, %r4, %r5, %r6", "sm_90 col compose")
    // extent truncation + 2 bounds guards
    ok = _check(ok, ptx90, "cvt.u32.u64 %r8, %rd3",  "sm_90 m truncate")
    ok = _check(ok, ptx90, "setp.lt.s32 %p0, %r3, %r8", "sm_90 row<m compare")
    ok = _check(ok, ptx90, "setp.lt.s32 %p1, %r7, %r9", "sm_90 col<n compare")
    // accumulator init + loop-invariant row*k
    ok = _check(ok, ptx90, "mov.f64 %fd0, 0d0000000000000000", "sm_90 acc zero-init")
    ok = _check(ok, ptx90, "mov.u32 %r11, 0",        "sm_90 kk loop init")
    ok = _check(ok, ptx90, "mul.lo.s32 %r12, %r3, %r10", "sm_90 row*k loop-invariant")
    // contraction loop — label, guard, body, back-edge
    ok = _check(ok, ptx90, "$L_LOOP:",               "sm_90 loop label")
    ok = _check(ok, ptx90, "setp.lt.s32 %p2, %r11, %r10", "sm_90 kk<k loop guard")
    ok = _check(ok, ptx90, "@!%p2 bra $L_LOOPEND",   "sm_90 loop-exit branch")
    ok = _check(ok, ptx90, "add.s32 %r13, %r12, %r11", "sm_90 A index row*k+kk")
    ok = _check(ok, ptx90, "ld.global.f64 %fd1, [%rd8]",  "sm_90 ld a[row*k+kk]")
    ok = _check(ok, ptx90, "mul.lo.s32 %r14, %r11, %r9",  "sm_90 B index kk*n")
    ok = _check(ok, ptx90, "ld.global.f64 %fd2, [%rd11]", "sm_90 ld b[kk*n+col]")
    ok = _check(ok, ptx90, "fma.rn.f64 %fd0, %fd1, %fd2, %fd0", "sm_90 fma accumulate")
    ok = _check(ok, ptx90, "add.s32 %r11, %r11, 1",  "sm_90 kk increment")
    ok = _check(ok, ptx90, "bra $L_LOOP",            "sm_90 loop back-edge")
    // loop exit — C element write
    ok = _check(ok, ptx90, "$L_LOOPEND:",            "sm_90 loop-exit label")
    ok = _check(ok, ptx90, "st.global.f64 [%rd14], %fd0", "sm_90 st c[row*n+col]")
    ok = _check(ok, ptx90, "$L_END:",                "sm_90 common-exit label")
    ok = _check(ok, ptx90, "ret;",                   "sm_90 ret terminator")

    // sm_80 sanity — same body, only the `.target` arch flips.
    let ptx80 = emit_ptx_gemm_module(NVPTX_TARGET_SM80)
    ok = _check(ok, ptx80, ".target sm_80",          "sm_80 .target directive")
    ok = _check(ok, ptx80, ".visible .entry gemm",   "sm_80 .visible .entry header")
    ok = _check(ok, ptx80, "fma.rn.f64 %fd0, %fd1, %fd2, %fd0", "sm_80 fma accumulate")

    return ok
}

// ── GEMM kernel `@gpu` subset validation (gpu/SPEC.md §9) ─────────────

fn _has(codes: [string], needle: string) -> bool {
    let mut i = 0
    while i < len(codes) {
        if codes[i] == needle { return true }
        i = i + 1
    }
    return false
}

fn _test_gemm_validator() -> bool {
    let mut ok = true

    // The naive GEMM kernel is subset-clean — void return, all params on
    // the gpu/SPEC.md §3 allowlist ([f64] farrs + i64 extents), no heap,
    // no recursion, no IO, gpu intrinsics legal inside a @gpu_* body.
    let mut g = nvptx_empty_validate_input()
    g.is_kernel = true
    g.is_gpu_context = true
    g.return_type_name = ""   // void — gpu/SPEC.md §2
    g.param_types = ["[f64]", "[f64]", "[f64]", "i64", "i64", "i64"]
    g.local_types = ["i64", "i64", "f64", "i64"]   // row, col, acc, kk
    g.uses_gpu_intrinsic = true
    let codes = nvptx_validate_gpu_subset(g)
    if len(codes) != 0 {
        println("  FAIL: clean GEMM kernel should produce no GPU0N codes, got " + to_string(len(codes)))
        let mut i = 0
        while i < len(codes) { println("    - " + codes[i]); i = i + 1 }
        ok = false
    }

    // A GEMM that returns its result by value (instead of writing C)
    // trips GPU01 — a PTX `.entry` cannot return a value.
    let mut bad = nvptx_empty_validate_input()
    bad.is_kernel = true
    bad.is_gpu_context = true
    bad.return_type_name = "f64"
    bad.param_types = ["[f64]", "[f64]", "i64", "i64", "i64"]
    let codes_bad = nvptx_validate_gpu_subset(bad)
    if !_has(codes_bad, "GPU01") {
        println("  FAIL: GPU01 should fire on a @gpu_kernel GEMM returning f64")
        ok = false
    }

    return ok
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  RFC 055 055-P2 — naive FP64 GEMM PTX emit smoke")
    println("══════════════════════════════════════════════")

    let ok_emit = _test_emit_gemm_module()
    let ok_val  = _test_gemm_validator()

    println("")
    println("══════════════════════════════════════════════")
    if ok_emit && ok_val {
        println("PASS: RFC 055 055-P2 naive GEMM emit smoke")
        println("      (text-shape only; ptxas + GPU fire = tool/dispatch_r055_p2_gemm.sh)")
    } else {
        println("FAIL: RFC 055 055-P2 GEMM smoke not satisfied.")
        if !ok_emit { println("      GEMM emit FAILED") }
        if !ok_val  { println("      GEMM validator FAILED") }
    }
    println("══════════════════════════════════════════════")
    if !(ok_emit && ok_val) { exit(1) }
}
