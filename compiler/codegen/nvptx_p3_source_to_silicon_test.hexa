// compiler/codegen/nvptx_p3_source_to_silicon_test.hexa
// RFC 071 P3 — source-to-silicon test fixture
//
// @version 0.0.1
// @capabilities [pure]
// @phase("parse_only")
//
// This file is a TEST FIXTURE for F-RFC071-MODULE-LOADER-BRIDGE
// (RFC 071 §4 P3). It contains a single `@gpu_kernel` function with a
// distinctive name (`my_test_kernel`) so the falsifier can verify that
// the PTX emitted by `build_nvptx_emit_driver(<path-to-this-file>,
// "sm_80")` reflects the SOURCE body — not the hardcoded `vadd` from
// the P2.1 hand-MIR fixture in `compiler/cli/build_nvptx.hexa`.
//
// The kernel shape mirrors `gpu/tests/vec_add.hexa` (RFC 055 055-P1
// canonical vec-add: 4 params `[f64] [f64] [f64] i64`, body =
// `c[gid] = a[gid] + b[gid]` with bounds check). The DISTINCTIVE
// difference is the function name — `my_test_kernel` instead of
// `vadd` — so the P3 falsifier substring-checks `.visible .entry
// my_test_kernel` (PASS = source-derived) vs `.visible .entry vadd`
// (FAIL = fell back to hand-MIR fixture).
//
// `@phase("parse_only")` declares this file's role: it is the input to
// the P3 emit-driver, not a standalone test runner. The
// F-RFC071-MODULE-LOADER-BRIDGE assertion lives in
// `compiler/codegen/nvptx_p3_module_loader_bridge_test.hexa`.

// ── The kernel (gpu/SPEC.md §2 — @gpu_kernel must return void) ───────

@gpu_kernel
fn my_test_kernel(a: [f64], b: [f64], c: [f64], n: i64) {
    let gid = gpu_block_id_x() * gpu_block_dim_x() + gpu_thread_id_x()
    if to_i64(gid) < n {
        c[to_i64(gid)] = a[to_i64(gid)] + b[to_i64(gid)]
    }
}
