// HEXA Native Compiler — Codegen / x86_64-linux-gnu (Phase A1)
//
// @version 0.1.0
// @capabilities [pure]
// @allow-relop-banned-file  — codegen path uses `>=`/`<=` for arity
//   guards and signed-id checks; C6 regalloc inherits the same need.
//
// Lowers MIR (SSA CFG) -> LIR (target-specific instructions) for the
// x86_64-linux-gnu target.
//
//   pub fn codegen_x86_64_linux(module: MModule) -> LModule
//
// ABI: System V AMD64
//   - Integer args:    rdi, rsi, rdx, rcx, r8, r9 (overflow on stack)
//   - Integer return:  rax
//   - Frame pointer:   rbp (callee-saved)
//   - Stack alignment: 16 bytes at function boundary (post-call)
//
// Per MFunc layout:
//   prologue:
//       push rbp
//       mov  rbp, rsp
//   <block instrs>
//   epilogue:
//       pop  rbp
//       ret
//
// v1 register policy (naive):
//   Local id N -> physical register from a fixed table:
//     0->rax, 1->rbx, 2->rcx, 3->rdx, 4->r8, 5->r9, 6->r10, 7->r11,
//     8->r12, 9->r13, 10->r14, 11->r15, then wrap.
//   Two-operand x86 form: emit `mov dst, lhs ; <op> dst, rhs`.

import "../ir/mir.hexa"
import "../ir/lir.hexa"

// ── Local mirror of mir.hexa STMT_* constants ────────────────
// See note in compiler/lower/hir_to_mir.hexa: stage0's interpreter does
// not propagate transitive `pub let` bindings, so STMT_* arrive here as
// the void value. Redeclaring locally keeps codegen dispatch working.
let _STMT_ASSIGN   = "assign"
let _STMT_BINOP    = "binop"
let _STMT_UNOP     = "unop"
let _STMT_CALL     = "call"
let _STMT_RETURN   = "return"
let _STMT_BR       = "br"
let _STMT_BR_COND  = "br_cond"

// ── PReg / LOperand helpers ──────────────────────────────────

fn _x86_preg_gpr(name: string) -> PReg {
    return PReg { name: name, kind: "gpr" }
}

fn _x86_empty_preg() -> PReg {
    return PReg { name: "", kind: "" }
}

fn _x86_op_reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: _x86_preg_gpr(name),
        imm: 0,
        mem_base: _x86_empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _x86_op_imm(value: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: _x86_empty_preg(),
        imm: value,
        mem_base: _x86_empty_preg(),
        mem_offset: 0,
        label: ""
    }
}

fn _x86_op_label(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: _x86_empty_preg(),
        imm: 0,
        mem_base: _x86_empty_preg(),
        mem_offset: 0,
        label: name
    }
}

// B5 follow-up — `_op_mem` was defined only in arm64_darwin.hexa but
// called from x86_64 SSA-spill paths via splice. After the B5 backend-
// prefix rename, x86_64's call sites became `_x86_op_mem` with no
// matching definition. Add the mirror here.
fn _x86_op_mem(base: string, offset: i64) -> LOperand {
    return LOperand {
        kind: "mem",
        reg: _x86_empty_preg(),
        imm: 0,
        mem_base: _x86_preg_gpr(base),
        mem_offset: offset,
        label: ""
    }
}

fn _x86_instr0(op: string, comment: string) -> LInstr {
    return LInstr { op: op, args: [], comment: comment }
}

fn _x86_instr1(op: string, a: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    return LInstr { op: op, args: xs, comment: comment }
}

fn _x86_instr2(op: string, a: LOperand, b: LOperand, comment: string) -> LInstr {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return LInstr { op: op, args: xs, comment: comment }
}

// ── Register assignment (naive) ──────────────────────────────

fn _x86_64_reg_for_local(local_id: i64) -> string {
    // 12-slot rotation across general-purpose 64-bit registers.
    let slots = [
        "rax", "rbx", "rcx", "rdx",
        "r8",  "r9",  "r10", "r11",
        "r12", "r13", "r14", "r15"
    ]
    let mut idx = local_id
    if idx < 0 { idx = 0 }
    let m = idx - (idx / 12) * 12
    return slots[m]
}

fn _x86_64_arg_reg(idx: i64) -> string {
    // System V integer arg sequence
    if idx == 0 { return "rdi" }
    if idx == 1 { return "rsi" }
    if idx == 2 { return "rdx" }
    if idx == 3 { return "rcx" }
    if idx == 4 { return "r8"  }
    if idx == 5 { return "r9"  }
    return "rdi" // overflow on stack — v1 stub
}

// ── C6 — Linear-scan register allocator (x86_64) ─────────────
pub struct X86RegMap {
    ids: [i64],
    regs: [string],
    slots: [i64]
}

pub struct X86AllocResult {
    map: X86RegMap,
    frame_size: i64
}

pub struct X86Intervals {
    ids: [i64],
    starts: [i64],
    ends: [i64]
}

fn _x86_pool_init() -> [string] {
    let mut p: [string] = []
    p.push("rax")
    p.push("rbx")
    p.push("r12")
    p.push("r13")
    p.push("r14")
    p.push("r15")
    return p
}

fn _x86_index_of(ids: [i64], id: i64) -> i64 {
    let mut i = 0
    while i < len(ids) {
        if ids[i] == id { return i }
        i = i + 1
    }
    return -1
}

fn _x86_compute_live_ranges(mf: MFunc) -> X86Intervals {
    let mut ids: [i64] = []
    let mut starts: [i64] = []
    let mut ends: [i64] = []

    let mut li = 0
    while li < len(mf.locals) {
        let id = mf.locals[li].id
        if id >= 0 && _x86_index_of(ids, id) < 0 {
            ids.push(id)
            starts.push(-1)
            ends.push(-1)
        }
        li = li + 1
    }

    let mut pi = 0
    while pi < len(mf.params) {
        let pid = mf.params[pi].id
        let idx = _x86_index_of(ids, pid)
        if idx >= 0 {
            if starts[idx] < 0 { starts[idx] = 0 }
            if ends[idx] < 0   { ends[idx] = 0 }
        }
        pi = pi + 1
    }

    let mut pos = 0
    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        let mut si = 0
        while si < len(blk.stmts) {
            let s = blk.stmts[si]
            let did = s.dst.id
            if did >= 0 {
                let mut idx = _x86_index_of(ids, did)
                if idx < 0 {
                    ids.push(did)
                    starts.push(pos)
                    ends.push(pos)
                    idx = len(ids) - 1
                } else {
                    if starts[idx] < 0 || pos < starts[idx] { starts[idx] = pos }
                    if pos > ends[idx] { ends[idx] = pos }
                }
            }
            let mut ai = 0
            while ai < len(s.args) {
                let o = s.args[ai]
                if o.kind == "local" {
                    let lid = o.local_id
                    if lid >= 0 {
                        let mut idx2 = _x86_index_of(ids, lid)
                        if idx2 < 0 {
                            ids.push(lid)
                            starts.push(pos)
                            ends.push(pos)
                            idx2 = len(ids) - 1
                        } else {
                            if starts[idx2] < 0 || pos < starts[idx2] {
                                starts[idx2] = pos
                            }
                            if pos > ends[idx2] { ends[idx2] = pos }
                        }
                    }
                }
                ai = ai + 1
            }
            pos = pos + 1
            si = si + 1
        }
        bi = bi + 1
    }
    return X86Intervals { ids: ids, starts: starts, ends: ends }
}

fn _x86_64_assign_regs(mf: MFunc) -> X86AllocResult {
    let iv = _x86_compute_live_ranges(mf)
    let n = len(iv.ids)
    let mut order: [i64] = []
    let mut k = 0
    while k < n {
        if iv.starts[k] >= 0 { order.push(k) }
        k = k + 1
    }
    let mut a = 1
    while a < len(order) {
        let key = order[a]
        let key_start = iv.starts[key]
        let mut b = a - 1
        while b >= 0 && iv.starts[order[b]] > key_start {
            order[b + 1] = order[b]
            b = b - 1
        }
        order[b + 1] = key
        a = a + 1
    }

    let mut map_ids: [i64] = []
    let mut map_regs: [string] = []
    let mut map_slots: [i64] = []
    let mut j = 0
    while j < n {
        map_ids.push(iv.ids[j])
        map_regs.push("")
        map_slots.push(-1)
        j = j + 1
    }

    let mut p = 0
    while p < len(mf.params) {
        if p < 6 {
            let pid = mf.params[p].id
            let idx = _x86_index_of(iv.ids, pid)
            if idx >= 0 {
                map_regs[idx] = _x86_64_arg_reg(p)
            }
        }
        p = p + 1
    }

    let mut pool = _x86_pool_init()
    let mut active_idx: [i64] = []
    let mut next_slot: i64 = 0

    let mut s = 0
    while s < len(order) {
        let cur = order[s]
        let cur_start = iv.starts[cur]

        let mut keep: [i64] = []
        let mut e = 0
        while e < len(active_idx) {
            let ai = active_idx[e]
            if iv.ends[ai] < cur_start {
                let was = map_regs[ai]
                let mut is_param = false
                let mut pp = 0
                while pp < len(mf.params) {
                    if mf.params[pp].id == iv.ids[ai] { is_param = true }
                    pp = pp + 1
                }
                if !is_param && len(was) > 0 && map_slots[ai] < 0 {
                    pool.push(was)
                }
            } else {
                keep.push(ai)
            }
            e = e + 1
        }
        active_idx = keep

        if len(map_regs[cur]) > 0 {
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
            s = s + 1
            continue
        }

        if len(pool) > 0 {
            let r = pool[0]
            let mut np: [string] = []
            let mut tt = 1
            while tt < len(pool) {
                np.push(pool[tt])
                tt = tt + 1
            }
            pool = np
            map_regs[cur] = r
            map_slots[cur] = -1
            let cur_end = iv.ends[cur]
            let mut na: [i64] = []
            let mut placed = false
            let mut t = 0
            while t < len(active_idx) {
                if !placed && iv.ends[active_idx[t]] > cur_end {
                    na.push(cur)
                    placed = true
                }
                na.push(active_idx[t])
                t = t + 1
            }
            if !placed { na.push(cur) }
            active_idx = na
        } else {
            let mut victim_pos = len(active_idx) - 1
            while victim_pos >= 0 {
                let v = active_idx[victim_pos]
                let mut is_param = false
                let mut pp = 0
                while pp < len(mf.params) {
                    if mf.params[pp].id == iv.ids[v] { is_param = true }
                    pp = pp + 1
                }
                if !is_param { break }
                victim_pos = victim_pos - 1
            }

            if victim_pos >= 0 && iv.ends[active_idx[victim_pos]] > iv.ends[cur] {
                let v = active_idx[victim_pos]
                map_regs[cur] = map_regs[v]
                map_slots[cur] = -1
                map_regs[v] = ""
                map_slots[v] = next_slot
                next_slot = next_slot + 8
                let mut na: [i64] = []
                let mut t = 0
                while t < len(active_idx) {
                    if t != victim_pos { na.push(active_idx[t]) }
                    t = t + 1
                }
                let cur_end = iv.ends[cur]
                let mut na2: [i64] = []
                let mut placed = false
                let mut tt = 0
                while tt < len(na) {
                    if !placed && iv.ends[na[tt]] > cur_end {
                        na2.push(cur)
                        placed = true
                    }
                    na2.push(na[tt])
                    tt = tt + 1
                }
                if !placed { na2.push(cur) }
                active_idx = na2
            } else {
                map_regs[cur] = ""
                map_slots[cur] = next_slot
                next_slot = next_slot + 8
            }
        }
        s = s + 1
    }

    let mut frame = next_slot
    let rem = frame - (frame / 16) * 16
    if rem != 0 { frame = frame + (16 - rem) }

    let map = X86RegMap { ids: map_ids, regs: map_regs, slots: map_slots }
    return X86AllocResult { map: map, frame_size: frame }
}

fn _x86_reg_lookup(rm: X86RegMap, id: i64) -> string {
    let idx = _x86_index_of(rm.ids, id)
    if idx < 0 { return _x86_64_reg_for_local(id) }
    if rm.slots[idx] >= 0 { return "r10" }
    if len(rm.regs[idx]) == 0 { return _x86_64_reg_for_local(id) }
    return rm.regs[idx]
}

fn _x86_is_spilled(rm: X86RegMap, id: i64) -> bool {
    let idx = _x86_index_of(rm.ids, id)
    if idx < 0 { return false }
    return rm.slots[idx] >= 0
}

fn _x86_spill_offset(rm: X86RegMap, id: i64) -> i64 {
    let idx = _x86_index_of(rm.ids, id)
    if idx < 0 { return 0 }
    return rm.slots[idx]
}

// String literal → rodata label map. See arm64_darwin.hexa for the
// equivalent shape; both targets emit ".LCstr<N>" labels in lock-
// step so a fixed source MIR yields the same per-target label index.
pub struct X86StrTab {
    keys: [string],
    labels: [string]
}

fn _x86_strtab_lookup(st: X86StrTab, s: string) -> string {
    let mut i = 0
    while i < len(st.keys) {
        if st.keys[i] == s { return st.labels[i] }
        i = i + 1
    }
    return ""
}

fn _x86_64_op_for_operand_st(o: Operand, st: X86StrTab) -> LOperand {
    if o.kind == "local" {
        return _x86_op_reg(_x86_64_reg_for_local(o.local_id))
    }
    if o.kind == "const_int" {
        return _x86_op_imm(o.int_val)
    }
    if o.kind == "global" {
        return _x86_op_label("g" + to_string(o.global_id))
    }
    if o.kind == "const_str" {
        let lbl = _x86_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _x86_op_label(lbl) }
        return _x86_op_label(o.str_val)
    }
    return _x86_op_imm(0)
}

fn _x86_64_op_for_operand(o: Operand) -> LOperand {
    let st = X86StrTab { keys: [], labels: [] }
    return _x86_64_op_for_operand_st(o, st)
}

// ── Block label helper ───────────────────────────────────────

// Stage1 C8 — modhash = first 4 hex of sha256(module.file).
// Mirrors _arm64_modhash; both targets share the same scheme so the
// per-source disambiguator is stable across an arm64/x86_64 split
// build. Format: .L<modhash>_<fn>_bb<n> (e.g. .Le3a7_main_bb0).
fn _x86_64_modhash(file: string) -> string {
    let h = sha256(file)
    if len(h) > 3 { return h.substring(0, 4) }
    return h
}

fn _x86_64_block_label(modhash: string, fname: string, block_id: i64) -> string {
    return ".L" + modhash + "_" + fname + "_bb" + to_string(block_id)
}

// ── Binop classification (mirror of arm64 helper set) ─────────

fn _x86_is_arith_add(op: string) -> bool { return op == "add" || op == "+" }
fn _x86_is_arith_sub(op: string) -> bool { return op == "sub" || op == "-" }
fn _x86_is_arith_mul(op: string) -> bool { return op == "mul" || op == "*" }
fn _x86_is_arith_div(op: string) -> bool { return op == "div" || op == "/" }
fn _x86_is_bit_and(op: string) -> bool   { return op == "and" || op == "&" }
fn _x86_is_bit_or(op: string) -> bool    { return op == "or"  || op == "|" }
fn _x86_is_bit_xor(op: string) -> bool   { return op == "xor" || op == "^" }
fn _x86_is_concat(op: string) -> bool    { return op == "concat" }

// SETcc suffix for source comparison op. Returns "" if not a
// comparison.
fn _x86_setcc_suffix(op: string) -> string {
    if op == "cmp_eq" || op == "==" { return "e" }
    if op == "cmp_ne" || op == "!=" { return "ne" }
    if op == "cmp_lt" || op == "<"  { return "l" }
    if op == "cmp_le" || op == "<=" { return "le" }
    if op == "cmp_gt" || op == ">"  { return "g" }
    if op == "cmp_ge" || op == ">=" { return "ge" }
    return ""
}

fn _x86_64_arg_reg_seq(idx: i64) -> string {
    if idx == 0 { return "rdi" }
    if idx == 1 { return "rsi" }
    if idx == 2 { return "rdx" }
    if idx == 3 { return "rcx" }
    if idx == 4 { return "r8"  }
    if idx == 5 { return "r9"  }
    return "rdi" // overflow → stack (TODO)
}

// ── Statement lowering (C6 — RegMap-aware) ───────────────────

fn _x86_load_spill(buf: [LInstr], rm: X86RegMap, id: i64, scratch: string) -> [LInstr] {
    let mut out = buf
    let off = _x86_spill_offset(rm, id)
    out.push(_x86_instr2("mov", _x86_op_reg(scratch),
                     _x86_op_mem("rbp", -8 - off),
                     "reload L" + to_string(id) + " from spill slot"))
    return out
}

fn _x86_store_spill(buf: [LInstr], rm: X86RegMap, id: i64, src_reg: string) -> [LInstr] {
    let mut out = buf
    let off = _x86_spill_offset(rm, id)
    out.push(_x86_instr2("mov", _x86_op_mem("rbp", -8 - off),
                     _x86_op_reg(src_reg),
                     "spill L" + to_string(id) + " to slot"))
    return out
}

fn _x86_op_rm(buf: [LInstr], o: Operand, st: X86StrTab, rm: X86RegMap,
              scratch: string) -> [LInstr] {
    let mut out = buf
    if o.kind == "local" {
        if _x86_is_spilled(rm, o.local_id) {
            out = _x86_load_spill(out, rm, o.local_id, scratch)
        }
    }
    return out
}

fn _x86_op_resolve(o: Operand, st: X86StrTab, rm: X86RegMap,
                   scratch: string) -> LOperand {
    if o.kind == "local" {
        if _x86_is_spilled(rm, o.local_id) {
            return _x86_op_reg(scratch)
        }
        return _x86_op_reg(_x86_reg_lookup(rm, o.local_id))
    }
    if o.kind == "const_int" { return _x86_op_imm(o.int_val) }
    if o.kind == "global"    { return _x86_op_label("g" + to_string(o.global_id)) }
    if o.kind == "const_str" {
        let lbl = _x86_strtab_lookup(st, o.str_val)
        if len(lbl) > 0 { return _x86_op_label(lbl) }
        return _x86_op_label(o.str_val)
    }
    return _x86_op_imm(0)
}

fn _x86_emit_dst_writeback(buf: [LInstr], rm: X86RegMap, id: i64) -> [LInstr] {
    let mut out = buf
    if _x86_is_spilled(rm, id) {
        out = _x86_store_spill(out, rm, id, "r10")
    }
    return out
}

fn _x86_dst_reg(rm: X86RegMap, id: i64) -> string {
    if _x86_is_spilled(rm, id) { return "r10" }
    return _x86_reg_lookup(rm, id)
}

fn _emit_x86_64_stmt(out: [LInstr], modhash: string, fname: string, s: Stmt,
                    st: X86StrTab, rm: X86RegMap, spill_frame: i64) -> [LInstr] {
    let mut buf = out
    if s.kind == _STMT_ASSIGN {
        // array_lit constructor: dst = hexa_array_new(); then
        // hexa_array_push(dst, e_i) per element (push returns the array →
        // recapture into dst each step). Element count is grammar-capped
        // at 1024 (parser HX0013 truncates over-cap to 0 children) so this
        // emit is O(n) bounded — no compile-time O(n²). Runtime-call shape
        // mirrors the proven concat idiom in _STMT_BINOP below (the single
        // source of truth for emitting a runtime call in this pass).
        // NOTE: cross-call dst-preservation hardening + full rebuild
        // verification are the rebuild-gated follow (Track-A monolithic-TU
        // clang wall — see COMPILE-ONLY @N loop_closure_consolidation);
        // logic parity with the existing concat/idiv emits.
        if s.op == "array_lit" {
            let dst = _x86_op_reg(_x86_dst_reg(rm, s.dst.id))
            buf.push(_x86_instr1("call", _x86_op_label("hexa_array_new"),
                             "array_lit: new array"))
            buf.push(_x86_instr2("mov", dst, _x86_op_reg("rax"),
                             "array_lit: capture new array"))
            let mut i = 0
            while i < len(s.args) {
                buf = _x86_op_rm(buf, s.args[i], st, rm, "r10")
                let v = _x86_op_resolve(s.args[i], st, rm, "r10")
                buf.push(_x86_instr2("mov", _x86_op_reg("rsi"), v,
                                 "array_lit: elem " + to_string(i)))
                buf.push(_x86_instr2("mov", _x86_op_reg("rdi"), dst,
                                 "array_lit: arr arg"))
                buf.push(_x86_instr1("call", _x86_op_label("hexa_array_push"),
                                 "array_lit: push elem " + to_string(i)))
                buf.push(_x86_instr2("mov", dst, _x86_op_reg("rax"),
                                 "array_lit: recapture array"))
                i = i + 1
            }
            buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
            return buf
        }
        if len(s.args) >= 1 {
            let mut src_scratch = "r10"
            if _x86_is_spilled(rm, s.dst.id) { src_scratch = "r11" }
            buf = _x86_op_rm(buf, s.args[0], st, rm, src_scratch)
            let src = _x86_op_resolve(s.args[0], st, rm, src_scratch)
            let dst = _x86_op_reg(_x86_dst_reg(rm, s.dst.id))
            buf.push(_x86_instr2("mov", dst, src, "assign L" + to_string(s.dst.id)))
            buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == _STMT_BINOP {
        if len(s.args) >= 2 {
            let a_scratch = "r10"
            let b_scratch = "r11"
            buf = _x86_op_rm(buf, s.args[0], st, rm, a_scratch)
            buf = _x86_op_rm(buf, s.args[1], st, rm, b_scratch)
            let a = _x86_op_resolve(s.args[0], st, rm, a_scratch)
            let b = _x86_op_resolve(s.args[1], st, rm, b_scratch)
            let dst_name = _x86_dst_reg(rm, s.dst.id)
            let dst = _x86_op_reg(dst_name)

            if _x86_is_concat(s.op) {
                buf.push(_x86_instr2("mov", _x86_op_reg("rdi"), a, "concat arg0"))
                buf.push(_x86_instr2("mov", _x86_op_reg("rsi"), b, "concat arg1"))
                buf.push(_x86_instr1("call", _x86_op_label("hexa_str_concat"),
                                 "call runtime: hexa_str_concat"))
                if dst.reg.name != "rax" {
                    buf.push(_x86_instr2("mov", dst, _x86_op_reg("rax"), "capture concat result"))
                }
                buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
                return buf
            }

            let suf = _x86_setcc_suffix(s.op)
            if len(suf) > 0 {
                // x86 `cmp` first operand must be reg/mem, not imm. When the
                // LHS lowered to an immediate (const_int operand) we'd emit
                // `cmp 0, 0` which GNU as rejects ("operand type mismatch").
                // Materialize the LHS into a_scratch first. Mirrors the
                // arm64_darwin.hexa fix (fb09d4bf).
                let mut a_real = a
                if s.args[0].kind == "const_int" {
                    buf.push(_x86_instr2("mov", _x86_op_reg(a_scratch), a,
                                     "materialize cmp lhs to reg"))
                    a_real = _x86_op_reg(a_scratch)
                }
                buf.push(_x86_instr2("cmp", a_real, b, "binop " + s.op))
                buf.push(_x86_instr1("set" + suf, _x86_op_reg("al"),
                                 "binop " + s.op + " → al"))
                buf.push(_x86_instr2("movzx", dst, _x86_op_reg("al"),
                                 "zero-extend al into dst"))
                buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
                return buf
            }

            if _x86_is_arith_div(s.op) {
                // x86 idiv is single-operand: dividend in rdx:rax, divisor
                // reg/mem (NOT imm), quotient → rax. The generic 2-operand
                // `idiv dst, b` emit below is invalid on x86 (GNU as rejects
                // "operand type mismatch"). Emit the proper sequence.
                buf.push(_x86_instr2("mov", _x86_op_reg("rax"), a, "idiv dividend → rax"))
                buf.push(_x86_instr0("cqo", "sign-extend rax into rdx:rax"))
                let mut divisor = b
                if s.args[1].kind == "const_int" {
                    buf.push(_x86_instr2("mov", _x86_op_reg(b_scratch), b,
                                     "materialize idiv divisor to reg"))
                    divisor = _x86_op_reg(b_scratch)
                }
                buf.push(_x86_instr1("idiv", divisor, "binop /"))
                buf.push(_x86_instr2("mov", dst, _x86_op_reg("rax"),
                                 "idiv quotient → dst"))
                buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
                return buf
            }
            buf.push(_x86_instr2("mov", dst, a, "binop lhs into dst"))
            let mut mnemonic = "add"
            if _x86_is_arith_add(s.op) { mnemonic = "add" }
            if _x86_is_arith_sub(s.op) { mnemonic = "sub" }
            if _x86_is_arith_mul(s.op) { mnemonic = "imul" }
            if _x86_is_bit_and(s.op)   { mnemonic = "and" }
            if _x86_is_bit_or(s.op)    { mnemonic = "or"  }
            if _x86_is_bit_xor(s.op)   { mnemonic = "xor" }
            buf.push(_x86_instr2(mnemonic, dst, b, "binop " + s.op))
            buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == _STMT_CALL {
        // C7 — System V x86_64 stack spill for args 7+.
        // Push args 7+ right-to-left so the lowest-numbered overflow arg
        // (arg 7) lands at [rsp+0] when `call` executes (matching System V
        // "args 7+ at [rsp+0], [rsp+8], ..."). rsp at fn body is 16-byte
        // aligned (prologue is `push rbp` + 16-aligned `sub rsp`); if the
        // overflow count is odd we pre-`sub rsp, 8` to preserve alignment
        // at the call site. After the call, `add rsp, N` pops the whole
        // region (including any align pad) in one shot.
        let arg_n = len(s.args)
        let mut overflow_n = 0
        if arg_n > 6 { overflow_n = arg_n - 6 }
        let mut align_pad = 0
        if overflow_n > 0 && overflow_n % 2 == 1 {
            align_pad = 8
            buf.push(_x86_instr2("sub", _x86_op_reg("rsp"), _x86_op_imm(8),
                "C7: align rsp to 16 before " + to_string(overflow_n) + " pushes"))
        }
        // Push overflow args right-to-left so arg 7 ends up at [rsp+0].
        let mut k = arg_n - 1
        while k >= 6 {
            buf = _x86_op_rm(buf, s.args[k], st, rm, "r10")
            let src = _x86_op_resolve(s.args[k], st, rm, "r10")
            buf.push(_x86_instr1("push", src,
                "C7: spill arg " + to_string(k) + " (right-to-left)"))
            k = k - 1
        }
        // Place args 0..5 in System V arg regs (rdi/rsi/rdx/rcx/r8/r9).
        let mut i = 0
        while i < arg_n {
            if i < 6 {
                let scratch = _x86_64_arg_reg_seq(i)
                buf = _x86_op_rm(buf, s.args[i], st, rm, scratch)
                let src = _x86_op_resolve(s.args[i], st, rm, scratch)
                let dst_reg = _x86_op_reg(scratch)
                buf.push(_x86_instr2("mov", dst_reg, src, "arg " + to_string(i)))
            }
            i = i + 1
        }
        let target = s.op
        buf.push(_x86_instr1("call", _x86_op_label(target), "call " + target))
        let cleanup = overflow_n * 8 + align_pad
        if cleanup > 0 {
            buf.push(_x86_instr2("add", _x86_op_reg("rsp"), _x86_op_imm(cleanup),
                "C7: pop " + to_string(overflow_n) + " overflow args + pad"))
        }
        if s.dst.id >= 0 {
            let dst_name = _x86_dst_reg(rm, s.dst.id)
            let dst = _x86_op_reg(dst_name)
            if dst.reg.name != "rax" {
                buf.push(_x86_instr2("mov", dst, _x86_op_reg("rax"), "capture call result"))
            }
            buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == _STMT_RETURN {
        if len(s.args) >= 1 {
            buf = _x86_op_rm(buf, s.args[0], st, rm, "r10")
            let src = _x86_op_resolve(s.args[0], st, rm, "r10")
            buf.push(_x86_instr2("mov", _x86_op_reg("rax"), src, "set return value"))
        }
        if spill_frame > 0 {
            buf.push(_x86_instr2("add", _x86_op_reg("rsp"),
                             _x86_op_imm(spill_frame), "epilogue: free spill frame"))
        }
        buf.push(_x86_instr1("pop", _x86_op_reg("rbp"), "epilogue: restore rbp"))
        buf.push(_x86_instr0("ret", "return"))
        return buf
    }
    if s.kind == _STMT_BR {
        let lab = _x86_64_block_label(modhash, fname, s.target_block)
        buf.push(_x86_instr1("jmp", _x86_op_label(lab), "branch"))
        return buf
    }
    if s.kind == _STMT_BR_COND {
        if len(s.args) > 0 {
            buf = _x86_op_rm(buf, s.args[0], st, rm, "r10")
            let cond = _x86_op_resolve(s.args[0], st, rm, "r10")
            // x86 `test` first operand must be reg/mem, not imm. A const_int
            // condition would emit `test 0, 0` (rejected by GNU as).
            // Materialize into r10 first. Mirrors the cmp fix above.
            let mut cond_real = cond
            if s.args[0].kind == "const_int" {
                buf.push(_x86_instr2("mov", _x86_op_reg("r10"), cond,
                                 "materialize test cond to reg"))
                cond_real = _x86_op_reg("r10")
            }
            buf.push(_x86_instr2("test", cond_real, cond_real, "br_cond test"))
            let else_lab = _x86_64_block_label(modhash, fname, s.target_block_else)
            buf.push(_x86_instr1("jz", _x86_op_label(else_lab), "jump-if-zero -> else"))
        }
        let then_lab = _x86_64_block_label(modhash, fname, s.target_block)
        buf.push(_x86_instr1("jmp", _x86_op_label(then_lab), "jump -> then"))
        return buf
    }
    if s.kind == "load" {
        if len(s.args) >= 1 {
            buf = _x86_op_rm(buf, s.args[0], st, rm, "r11")
            let base_op = _x86_op_resolve(s.args[0], st, rm, "r11")
            let dst = _x86_op_reg(_x86_dst_reg(rm, s.dst.id))
            buf.push(_x86_instr2("mov", dst, base_op, "load"))
            buf = _x86_emit_dst_writeback(buf, rm, s.dst.id)
        }
        return buf
    }
    if s.kind == "store" {
        if len(s.args) >= 2 {
            buf = _x86_op_rm(buf, s.args[0], st, rm, "r10")
            buf = _x86_op_rm(buf, s.args[1], st, rm, "r11")
            let base_op = _x86_op_resolve(s.args[0], st, rm, "r10")
            let src = _x86_op_resolve(s.args[1], st, rm, "r11")
            buf.push(_x86_instr2("mov", base_op, src, "store"))
        }
        return buf
    }
    buf.push(_x86_instr0("nop", "unhandled stmt kind " + s.kind))
    return buf
}

// ── Function lowering ────────────────────────────────────────

fn _x86_64_lower_func(mf: MFunc, st: X86StrTab, modhash: string) -> LFunc {
    let mut instrs = []

    // C6 — run linear-scan regalloc up front.
    let alloc = _x86_64_assign_regs(mf)
    let rm = alloc.map
    let spill_frame = alloc.frame_size

    // Prologue
    instrs.push(_x86_instr1("push", _x86_op_reg("rbp"), "prologue: save rbp"))
    instrs.push(_x86_instr2("mov", _x86_op_reg("rbp"), _x86_op_reg("rsp"), "prologue: set rbp"))

    if spill_frame > 0 {
        instrs.push(_x86_instr2("sub", _x86_op_reg("rsp"),
                            _x86_op_imm(spill_frame),
                            "prologue: alloc spill frame"))
    }

    // Move incoming params into assigned regs / spill slots.
    let mut p = 0
    while p < len(mf.params) {
        if p < 6 {
            let pid = mf.params[p].id
            let src_name = _x86_64_arg_reg(p)
            if _x86_is_spilled(rm, pid) {
                instrs = _x86_store_spill(instrs, rm, pid, src_name)
            } else {
                let dst_name = _x86_reg_lookup(rm, pid)
                if dst_name != src_name {
                    instrs.push(_x86_instr2("mov", _x86_op_reg(dst_name),
                                        _x86_op_reg(src_name), "ingress param"))
                }
            }
        }
        p = p + 1
    }

    let mut bi = 0
    while bi < len(mf.blocks) {
        let blk = mf.blocks[bi]
        instrs.push(_x86_instr0("label", _x86_64_block_label(modhash, mf.name, blk.id)))
        let mut si = 0
        while si < len(blk.stmts) {
            instrs = _emit_x86_64_stmt(instrs, modhash, mf.name,
                                       blk.stmts[si], st, rm, spill_frame)
            si = si + 1
        }
        bi = bi + 1
    }

    // Safety epilogue
    if len(instrs) > 0 {
        let last = instrs[len(instrs) - 1]
        if last.op == "ret" {
            return LFunc {
                name: mf.name,
                target: "x86_64-linux-gnu",
                instrs: instrs,
                frame_size: spill_frame,
                callee_saved: []
            }
        }
    }
    if spill_frame > 0 {
        instrs.push(_x86_instr2("add", _x86_op_reg("rsp"),
                            _x86_op_imm(spill_frame),
                            "epilogue: free spill frame"))
    }
    instrs.push(_x86_instr1("pop", _x86_op_reg("rbp"), "epilogue: restore rbp"))
    instrs.push(_x86_instr0("ret", "return"))

    return LFunc {
        name: mf.name,
        target: "x86_64-linux-gnu",
        instrs: instrs,
        frame_size: spill_frame,
        callee_saved: []
    }
}

// ── String table collection ─────────────────────────────────
//
// Mirror of arm64_darwin.hexa _build_arm_strtab. Both targets keep
// independent string tables so the per-target codegen does not need
// cross-target imports, but they use the same label scheme
// (".LCstr<N>") so a shared MIR yields stable labels.

fn _x86_collect_strs_from_stmt(st: X86StrTab, s: Stmt) -> X86StrTab {
    let mut out = st
    let mut i = 0
    while i < len(s.args) {
        let o = s.args[i]
        if o.kind == "const_str" {
            if len(_x86_strtab_lookup(out, o.str_val)) == 0 {
                let mut keys = out.keys
                let mut labs = out.labels
                let n = len(keys)
                keys.push(o.str_val)
                labs.push(".LCstr" + to_string(n))
                out = X86StrTab { keys: keys, labels: labs }
            }
        }
        i = i + 1
    }
    return out
}

fn _build_x86_strtab(module: MModule) -> X86StrTab {
    let mut st = X86StrTab { keys: [], labels: [] }
    let mut fi = 0
    while fi < len(module.funcs) {
        let f = module.funcs[fi]
        let mut bi = 0
        while bi < len(f.blocks) {
            let blk = f.blocks[bi]
            let mut si = 0
            while si < len(blk.stmts) {
                st = _x86_collect_strs_from_stmt(st, blk.stmts[si])
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return st
}

fn _x86_hex_nibble(n: i64) -> string {
    if n == 0  { return "0" }
    if n == 1  { return "1" }
    if n == 2  { return "2" }
    if n == 3  { return "3" }
    if n == 4  { return "4" }
    if n == 5  { return "5" }
    if n == 6  { return "6" }
    if n == 7  { return "7" }
    if n == 8  { return "8" }
    if n == 9  { return "9" }
    if n == 10 { return "a" }
    if n == 11 { return "b" }
    if n == 12 { return "c" }
    if n == 13 { return "d" }
    if n == 14 { return "e" }
    return "f"
}

fn _x86_byte_to_hex(b: i64) -> string {
    let hi = b / 16
    let lo = b - hi * 16
    return _x86_hex_nibble(hi) + _x86_hex_nibble(lo)
}

fn _x86_ascii_code(ch: string) -> i64 {
    if ch == " " { return 32 }
    if ch == "!" { return 33 }
    if ch == "\"" { return 34 }
    if ch == "#" { return 35 }
    if ch == "$" { return 36 }
    if ch == "%" { return 37 }
    if ch == "&" { return 38 }
    if ch == "'" { return 39 }
    if ch == "(" { return 40 }
    if ch == ")" { return 41 }
    if ch == "*" { return 42 }
    if ch == "+" { return 43 }
    if ch == "," { return 44 }
    if ch == "-" { return 45 }
    if ch == "." { return 46 }
    if ch == "/" { return 47 }
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == ":" { return 58 }
    if ch == ";" { return 59 }
    if ch == "<" { return 60 }
    if ch == "=" { return 61 }
    if ch == ">" { return 62 }
    if ch == "?" { return 63 }
    if ch == "@" { return 64 }
    if ch == "A" { return 65 }
    if ch == "B" { return 66 }
    if ch == "C" { return 67 }
    if ch == "D" { return 68 }
    if ch == "E" { return 69 }
    if ch == "F" { return 70 }
    if ch == "G" { return 71 }
    if ch == "H" { return 72 }
    if ch == "I" { return 73 }
    if ch == "J" { return 74 }
    if ch == "K" { return 75 }
    if ch == "L" { return 76 }
    if ch == "M" { return 77 }
    if ch == "N" { return 78 }
    if ch == "O" { return 79 }
    if ch == "P" { return 80 }
    if ch == "Q" { return 81 }
    if ch == "R" { return 82 }
    if ch == "S" { return 83 }
    if ch == "T" { return 84 }
    if ch == "U" { return 85 }
    if ch == "V" { return 86 }
    if ch == "W" { return 87 }
    if ch == "X" { return 88 }
    if ch == "Y" { return 89 }
    if ch == "Z" { return 90 }
    if ch == "[" { return 91 }
    if ch == "\\" { return 92 }
    if ch == "]" { return 93 }
    if ch == "^" { return 94 }
    if ch == "_" { return 95 }
    if ch == "`" { return 96 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    if ch == "g" { return 103 }
    if ch == "h" { return 104 }
    if ch == "i" { return 105 }
    if ch == "j" { return 106 }
    if ch == "k" { return 107 }
    if ch == "l" { return 108 }
    if ch == "m" { return 109 }
    if ch == "n" { return 110 }
    if ch == "o" { return 111 }
    if ch == "p" { return 112 }
    if ch == "q" { return 113 }
    if ch == "r" { return 114 }
    if ch == "s" { return 115 }
    if ch == "t" { return 116 }
    if ch == "u" { return 117 }
    if ch == "v" { return 118 }
    if ch == "w" { return 119 }
    if ch == "x" { return 120 }
    if ch == "y" { return 121 }
    if ch == "z" { return 122 }
    if ch == "{" { return 123 }
    if ch == "|" { return 124 }
    if ch == "}" { return 125 }
    if ch == "~" { return 126 }
    if ch == "\n" { return 10 }
    if ch == "\t" { return 9 }
    return 63
}

fn _x86_str_to_hex_bytes(s: string) -> string {
    let cs = s.chars()
    let mut out = ""
    let mut i = 0
    while i < len(cs) {
        out = out + _x86_byte_to_hex(_x86_ascii_code(cs[i]))
        i = i + 1
    }
    out = out + "00"
    return out
}

fn _x86_strtab_to_rodata(st: X86StrTab) -> [LSection] {
    let mut out: [LSection] = []
    let mut i = 0
    while i < len(st.keys) {
        out.push(LSection {
            name: st.labels[i],
            bytes: _x86_str_to_hex_bytes(st.keys[i]),
            align: 0
        })
        i = i + 1
    }
    return out
}

// ── Module entry point ───────────────────────────────────────

pub fn codegen_x86_64_linux(module: MModule) -> LModule {
    let st = _build_x86_strtab(module)
    // Stage1 C8 — modhash from MModule.file disambiguates spliced
    // modules so block labels never collide across re-imported libs.
    let modhash = _x86_64_modhash(module.file)
    let mut funcs = []
    let mut i = 0
    while i < len(module.funcs) {
        funcs.push(_x86_64_lower_func(module.funcs[i], st, modhash))
        i = i + 1
    }
    return LModule {
        file: module.file,
        target: "x86_64-linux-gnu",
        funcs: funcs,
        rodata: _x86_strtab_to_rodata(st),
        bss: []
    }
}
