// HEXA Native Compiler — RFC 055 055-P3b / generic NVPTX lowering primitives smoke
//
// @version 0.0.1
// @capabilities [pure]
//
// RFC 055 055-P3b — exercises the generic `_nvptx_lower_func` MIR walk
// on stmt kinds beyond the 055-P0 FP64-arithmetic straight-line subset.
// This file's role is the *primitives* gate: each new MIR construct the
// generic lowering learns to handle lands a `_test_<construct>` case
// here, hand-built MIR + substring asserts on the emitted PTX text.
//
// 055-P0 already proved STMT_ASSIGN / STMT_BINOP{add,sub,mul} / STMT_RETURN
// via `nvptx_emit_test.hexa`. 055-P1 / 055-P2 proved the hand-emit form
// (kernel `.visible .entry` + bank + intrinsics + control flow) via
// `nvptx_vec_add_test.hexa` / `nvptx_gemm_test.hexa` + a real GPU fire.
// What this file picks up: the GENERIC MIR-walk lowering of those same
// constructs, one stmt kind at a time, each verified by a tiny synthetic
// MModule the same way `codegen_test.hexa` verifies the CPU codegens.
//
// 055-P3b first slice landed here:
//   STMT_BR — unconditional branch → `bra $L_<target>;`
//
// 055-P3b still TBD (per-Local type tracking required before each):
//   STMT_BR_COND — predicate-register dance (`%p<id>` separate from `%fd<id>`)
//   STMT_CALL    — known gpu intrinsic names → sreg `mov.u32`
//   STMT_LOAD / STMT_STORE — `.global.f64` address-space ops
//
// Run:
//   hexa build compiler/codegen/nvptx_lower_test.hexa -o build/nvptx_lower_test
//   ./build/nvptx_lower_test

import "../parse/ast.hexa"
import "../ir/hir.hexa"
import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "../lower/hir_to_mir.hexa"
import "./nvptx_target.hexa"
import "./nvptx_ptx_ops.hexa"
import "./nvptx_tma_ops.hexa"

// ── MIR construction helpers (mirror of codegen_test.hexa /
//    nvptx_emit_test.hexa — same shape, kept local to keep this file
//    self-contained for the test-harness pattern) ────────────────────

fn _local(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name, precision: "" }
}

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "", precision: "" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local", local_id: local_id,
        int_val: 0, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _stmt_binop(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: op, args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_return() -> Stmt {
    return Stmt {
        kind: STMT_RETURN, dst: _miss_local(), op: "", args: [],
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_br(target: i64) -> Stmt {
    return Stmt {
        kind: STMT_BR, dst: _miss_local(), op: "", args: [],
        target_block: target, target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

// ── Text inspection ──────────────────────────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    return hay.find(needle) >= 0
}

fn _check(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if _contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (missing: `" + needle + "`)")
    return false
}

// ── Case 1 — STMT_BR (unconditional branch) ───────────────────────────
//
// Two-block MFunc: block 0 computes an f64 add then BR's to block 1,
// block 1 returns. Proves the generic `_nvptx_lower_func` emits:
//   - the block-0 label `$L_0:` and an `add.f64` for the binop
//   - an unconditional `bra $L_1;` terminator at the end of block 0
//   - the block-1 label `$L_1:` and a `ret;` terminator
//
// Verifies the 055-P3b STMT_BR primitive lands correctly without
// disturbing the 055-P0 STMT_ASSIGN/BINOP/RETURN handling.

fn _build_case_br() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let r = _local(2, "r")

    // block 0: r = a + b ; br -> block 1
    let mut s0 = []
    s0.push(_stmt_binop(r, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_br(1))

    // block 1: return
    let mut s1 = []
    s1.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(r)

    let mf = MFunc {
        name: "br_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_br.hexa", funcs: fns, globals: [] }
}

fn _test_stmt_br() -> bool {
    let mut ok = true
    let mod_br = _build_case_br()
    let ptx = codegen_emit_ptx_sm80(mod_br)

    println("")
    println("── emitted PTX (STMT_BR case, sm_80) ──")
    println(ptx)

    // 055-P0 carry-over — module header survives the generic path
    ok = _check(ok, ptx, ".version 7.8",    "sm_80 .version directive")
    ok = _check(ok, ptx, ".target sm_80",   "sm_80 .target directive")
    // Block-0 body: label + f64 add
    ok = _check(ok, ptx, "$L_0:",           "block-0 label")
    ok = _check(ok, ptx, "add.f64 %fd2",    "f64 add into result register")
    // 055-P3b STMT_BR primitive — explicit `bra $L_1;` terminator
    ok = _check(ok, ptx, "bra $L_1",        "STMT_BR -> bra $L_1")
    // Block-1 body: label + ret
    ok = _check(ok, ptx, "$L_1:",           "block-1 label")
    ok = _check(ok, ptx, "ret;",            "ret terminator")
    return ok
}

// ── Case 2 — per-Local kind classification (predicate via comparison) ──
//
// 055-P3b second slice: `_nvptx_classify_locals` walks the MIR and
// classifies each Local by its defining stmt. A STMT_BINOP with op="lt"
// (or le/gt/ge/eq/ne) produces a Boolean predicate → the dst Local is
// classified PRED → the `.reg` declaration emits `.reg .pred %p<id>;`
// instead of the 055-P0 default `.reg .f64`. Mixed kinds in one MFunc
// (an arithmetic binop producing f64 + a comparison producing pred)
// must produce the two banks separately.
//
// This test hand-builds:
//   block 0: t  = a + b      // STMT_BINOP "add"  → t is .f64  (%fd2)
//            p  = t < b      // STMT_BINOP "lt"   → p is .pred (%p3)
//            return
//
// The lowering of "lt" itself is still a 055-P0 honest stub in the
// emitted PTX text (the BINOP-mnemonic table only carries add/sub/mul);
// what this test verifies is the CLASSIFICATION + REG-DECL machinery,
// which is the prerequisite for a real `setp` lowering in a later
// cycle. PASS = both `.reg .f64 %fd2;` and `.reg .pred %p3;` appear.

fn _stmt_binop_cmp(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    // Same shape as _stmt_binop — kept as a separate helper to keep the
    // test's intent (a COMPARISON binop) visible at the call site.
    return _stmt_binop(dst, op, a, b)
}

fn _build_case_classify_pred() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let t = _local(2, "t")     // expected .reg .f64 %fd2
    let p = _local(3, "p")     // expected .reg .pred %p3

    let mut s0 = []
    s0.push(_stmt_binop(t, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_binop_cmp(p, "lt", _op_local(t.id), _op_local(b.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(t)
    locals.push(p)

    let mf = MFunc {
        name: "cmp_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_classify.hexa", funcs: fns, globals: [] }
}

fn _test_classify_pred() -> bool {
    let mut ok = true
    let mod_cmp = _build_case_classify_pred()
    let ptx = codegen_emit_ptx_sm80(mod_cmp)

    println("")
    println("── emitted PTX (classification case, sm_80) ──")
    println(ptx)

    // F64 bank — t came from STMT_BINOP "add" → fpr → .reg .f64 %fd2
    ok = _check(ok, ptx, ".reg .f64 %fd2",  "f64 bank for arithmetic-binop dst")
    // PRED bank — p came from STMT_BINOP "lt" → pred → .reg .pred %p3
    ok = _check(ok, ptx, ".reg .pred %p3",  "pred bank for comparison-binop dst")
    // Header carry-over
    ok = _check(ok, ptx, ".target sm_80",   "sm_80 .target directive")
    return ok
}

// ── Case 3 — STMT_BR_COND + setp comparison body ─────────────────────
//
// 055-P3b third slice: paired setp lowering + STMT_BR_COND. A two-block
// MFunc with a predicate-producing comparison binop in block 0 followed
// by a STMT_BR_COND that branches on it, with block 1 = `then` and
// block 2 = `else` (both returning). Verifies:
//   - the comparison binop body emits `setp.<cond>.f64 %p<dst>, <a>, <b>;`
//     (not the stub comment from the prior P3b slice)
//   - STMT_BR_COND emits `@<pred> bra $L_<true>;` + a fall-through
//     `bra $L_<false>;`
//   - the .reg .pred bank carries the predicate Local

fn _stmt_br_cond(pred: Operand, t_block: i64, e_block: i64) -> Stmt {
    let mut xs = []
    xs.push(pred)
    return Stmt {
        kind: STMT_BR_COND, dst: _miss_local(), op: "", args: xs,
        target_block: t_block, target_block_else: e_block
    }
}

fn _build_case_setp_br_cond() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let p = _local(2, "p")     // expected .pred (setp produces predicate)

    // block 0: p = a < b ; br_cond p -> block 1, else block 2
    let mut s0 = []
    s0.push(_stmt_binop(p, "lt", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_br_cond(_op_local(p.id), 1, 2))

    // block 1: then-arm — return
    let mut s1 = []
    s1.push(_stmt_return())
    // block 2: else-arm — return
    let mut s2 = []
    s2.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))
    blocks.push(_block(2, s2))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(p)

    let mf = MFunc {
        name: "br_cond_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_br_cond.hexa", funcs: fns, globals: [] }
}

fn _test_setp_and_br_cond() -> bool {
    let mut ok = true
    let mod_bc = _build_case_setp_br_cond()
    let ptx = codegen_emit_ptx_sm80(mod_bc)

    println("")
    println("── emitted PTX (setp + STMT_BR_COND case, sm_80) ──")
    println(ptx)

    // setp body for `lt`
    ok = _check(ok, ptx, "setp.lt.f64 %p2",     "setp.lt.f64 with pred dst")
    // STMT_BR_COND lowering
    ok = _check(ok, ptx, "@%p2 bra $L_1",       "predicated br -> $L_1 (then)")
    ok = _check(ok, ptx, "bra $L_2",            "fall-through br -> $L_2 (else)")
    // .reg .pred bank
    ok = _check(ok, ptx, ".reg .pred %p2",      "pred bank for the comparison dst")
    // All three blocks present
    ok = _check(ok, ptx, "$L_0:",               "block-0 label")
    ok = _check(ok, ptx, "$L_1:",               "block-1 (then) label")
    ok = _check(ok, ptx, "$L_2:",               "block-2 (else) label")
    return ok
}

// ── Case 4 — STMT_CALL gpu intrinsic body ─────────────────────────────
//
// 055-P3b fourth slice: STMT_CALL with the known gpu thread-index
// intrinsic names lowers to `mov.u32 %r<dst>, <sreg>.<axis>;`. The
// classifier puts the dst into the `.reg .u32` bank; this verifies the
// body emission. Uses three intrinsics across the x axis:
// gpu_block_id_x, gpu_block_dim_x, gpu_thread_id_x — the same three
// the 055-P1 hand-emit vec-add reads as the gid-compose preamble.

fn _stmt_call(dst: Local, callee: string) -> Stmt {
    return Stmt {
        kind: STMT_CALL, dst: dst, op: callee, args: [],
        target_block: -1, target_block_else: -1
    }
}

// _stmt_call_with_args — STMT_CALL with operand arguments. Used by the
// 055-P4+ `gpu_atomic_add(addr, v)` case (mirrors _stmt_load / _stmt_store
// shape — explicit operand carrier for an intrinsic that consumes args).
fn _stmt_call_with_args(dst: Local, callee: string, args: [Operand]) -> Stmt {
    return Stmt {
        kind: STMT_CALL, dst: dst, op: callee, args: args,
        target_block: -1, target_block_else: -1
    }
}

fn _build_case_call_intrinsic() -> MModule {
    let ctaid_x = _local(0, "ctaid_x")
    let ntid_x  = _local(1, "ntid_x")
    let tid_x   = _local(2, "tid_x")

    let mut s0 = []
    s0.push(_stmt_call(ctaid_x, "gpu_block_id_x"))
    s0.push(_stmt_call(ntid_x,  "gpu_block_dim_x"))
    s0.push(_stmt_call(tid_x,   "gpu_thread_id_x"))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(ctaid_x)
    locals.push(ntid_x)
    locals.push(tid_x)

    let mf = MFunc {
        name: "intrin_smoke",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_intrinsics.hexa", funcs: fns, globals: [] }
}

fn _test_call_intrinsic() -> bool {
    let mut ok = true
    let mod_in = _build_case_call_intrinsic()
    let ptx = codegen_emit_ptx_sm80(mod_in)

    println("")
    println("── emitted PTX (STMT_CALL gpu intrinsic body, sm_80) ──")
    println(ptx)

    // .reg .u32 bank for each intrinsic dst
    ok = _check(ok, ptx, ".reg .u32 %r0",                "u32 bank %r0 (ctaid_x)")
    ok = _check(ok, ptx, ".reg .u32 %r1",                "u32 bank %r1 (ntid_x)")
    ok = _check(ok, ptx, ".reg .u32 %r2",                "u32 bank %r2 (tid_x)")
    // mov.u32 from PTX special registers
    ok = _check(ok, ptx, "mov.u32 %r0, %ctaid.x",        "gpu_block_id_x() -> %ctaid.x")
    ok = _check(ok, ptx, "mov.u32 %r1, %ntid.x",         "gpu_block_dim_x() -> %ntid.x")
    ok = _check(ok, ptx, "mov.u32 %r2, %tid.x",          "gpu_thread_id_x() -> %tid.x")
    return ok
}

// ── Case 5 — STMT_LOAD + STMT_STORE generic lowering ──────────────────
//
// 055-P3b fifth (last) slice: memory ops. STMT_LOAD lowers to
// `ld.global.f64 %fd<dst>, [%rd<addr>];` and STMT_STORE lowers to
// `st.global.f64 [%rd<addr>], %fd<value>;`. The classifier's Pass 2
// has propagated the address-operand source Local into the `.u64`
// bank so the emitted PTX renders `%rd<id>` for the address.
//
// Fixture: a one-block MFunc with a STMT_LOAD that loads from address
// Local 0 (a function param treated as a u64 farr base) followed by a
// STMT_STORE that writes a value to the same address. Verifies:
//   - `.reg .u64 %rd0` declared (Pass 2 propagation of the address Local)
//   - `ld.global.f64 %fd1, [%rd0];` for the load
//   - `st.global.f64 [%rd0], %fd1;` for the store

fn _stmt_load(dst: Local, addr: Operand) -> Stmt {
    let mut xs = []
    xs.push(addr)
    return Stmt {
        kind: STMT_LOAD, dst: dst, op: "", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_store(addr: Operand, value: Operand) -> Stmt {
    let mut xs = []
    xs.push(addr)
    xs.push(value)
    return Stmt {
        kind: STMT_STORE, dst: _miss_local(), op: "", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _build_case_load_store() -> MModule {
    let p = _local(0, "p")           // address Local — propagated to U64 by Pass 2
    let v = _local(1, "v")           // STMT_LOAD dst — F64
    let v2 = _local(2, "v2")         // arithmetic intermediate — F64

    // block 0:
    //   v  = *p              (STMT_LOAD)
    //   v2 = v + v           (STMT_BINOP "add" — F64)
    //   *p = v2              (STMT_STORE)
    //   return
    let mut s0 = []
    s0.push(_stmt_load(v, _op_local(p.id)))
    s0.push(_stmt_binop(v2, "add", _op_local(v.id), _op_local(v.id)))
    s0.push(_stmt_store(_op_local(p.id), _op_local(v2.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(p)
    let mut locals = []
    locals.push(p)
    locals.push(v)
    locals.push(v2)

    let mf = MFunc {
        name: "ld_st_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_ld_st.hexa", funcs: fns, globals: [] }
}

fn _test_load_store() -> bool {
    let mut ok = true
    let mod_ls = _build_case_load_store()
    let ptx = codegen_emit_ptx_sm80(mod_ls)

    println("")
    println("── emitted PTX (STMT_LOAD + STMT_STORE case, sm_80) ──")
    println(ptx)

    // Pass 2 retroactive U64 classification of the address Local (param)
    ok = _check(ok, ptx, ".reg .u64 %rd0",                    "u64 bank for address (Pass 2)")
    // STMT_LOAD lowering
    ok = _check(ok, ptx, "ld.global.f64 %fd1, [%rd0]",        "ld.global.f64 dst <- [addr]")
    // F64 bank for the loaded value + the arithmetic intermediate
    ok = _check(ok, ptx, ".reg .f64 %fd1",                    "f64 bank for STMT_LOAD dst")
    ok = _check(ok, ptx, ".reg .f64 %fd2",                    "f64 bank for arithmetic intermediate")
    // STMT_STORE lowering
    ok = _check(ok, ptx, "st.global.f64 [%rd0], %fd2",        "st.global.f64 [addr] <- val")
    return ok
}

// ── Case 6 — 055-P3c MFunc.gpu_kind partition ─────────────────────────
//
// 055-P3c: `_nvptx_codegen` only lowers MFuncs whose gpu_kind !=
// GPU_KIND_CPU. Build a mixed-kind MModule and assert the partition:
//   - cpu_only        — GPU_KIND_CPU    (expected FILTERED OUT)
//   - dev_helper      — GPU_KIND_DEVICE (expected emitted)
//   - kernel_entry    — GPU_KIND_KERNEL (expected emitted)

fn _mfunc_partition(name: string, kind: i64) -> MFunc {
    // Same body across all three fns — the only diff the partition can
    // act on is gpu_kind. Body: `r = a + b ; return`.
    let a = _local(0, "a")
    let b = _local(1, "b")
    let r = _local(2, "r")
    let mut s = []
    s.push(_stmt_binop(r, "add", _op_local(a.id), _op_local(b.id)))
    s.push(_stmt_return())
    let mut blocks = []
    blocks.push(_block(0, s))
    let mut params = []
    params.push(a); params.push(b)
    let mut locals = []
    locals.push(a); locals.push(b); locals.push(r)
    return MFunc {
        name: name, params: params, return_local: _miss_local(),
        locals: locals, blocks: blocks, entry_block: 0,
        arena_root: 1, def_line: 0, gpu_kind: kind
    }
}

fn _build_case_partition() -> MModule {
    let mut fns = []
    fns.push(_mfunc_partition("cpu_only",     GPU_KIND_CPU))
    fns.push(_mfunc_partition("dev_helper",   GPU_KIND_DEVICE))
    fns.push(_mfunc_partition("kernel_entry", GPU_KIND_KERNEL))
    return MModule { file: "case_partition.hexa", funcs: fns, globals: [] }
}

fn _test_partition() -> bool {
    let mut ok = true
    let mod_p = _build_case_partition()
    let ptx = codegen_emit_ptx_sm80(mod_p)
    println("")
    println("── emitted PTX (055-P3c partition case, sm_80) ──")
    println(ptx)
    ok = _check(ok, ptx, ".func dev_helper",   "device fn emitted as .func")
    // 055-P3c — KERNEL emits as `.visible .entry`, not `.func`
    ok = _check(ok, ptx, ".visible .entry kernel_entry", "kernel emitted as .visible .entry")
    // 055-P3c (param-bank sub-slice) — KERNEL renders MFunc.params as
    // `.param .u64 <name>_param_<i>` entries in the kernel header.
    ok = _check(ok, ptx, ".param .u64 kernel_entry_param_0",
        "kernel param 0 in .visible .entry list")
    ok = _check(ok, ptx, ".param .u64 kernel_entry_param_1",
        "kernel param 1 in .visible .entry list")
    // KERNEL must NOT also appear with the `.func` directive nor with
    // the raw prefixed name.
    if _contains(ptx, ".func kernel_entry") {
        println("  FAIL: kernel_entry must NOT appear as .func")
        ok = false
    }
    if _contains(ptx, "__nvptx_kernel__") {
        println("  FAIL: NVPTX_KERNEL_PREFIX must be stripped in emitted PTX")
        ok = false
    }
    if _contains(ptx, ".func cpu_only") {
        println("  FAIL: cpu_only must NOT be emitted (partition filter)")
        ok = false
    }
    // The kernel param list must NOT leak into `.reg` declarations.
    if _contains(ptx, ".reg .param") {
        println("  FAIL: param PRegs must render as kernel param list, not as .reg .param")
        ok = false
    }
    return ok
}

// ── Case 7 — 055-P4 gpu_barrier() intrinsic ───────────────────────────
//
// RFC 055 §12 P4+ — block-wide synchronization. STMT_CALL with
// op="gpu_barrier" lowers to `bar.sync 0;`. Returns void (no dst
// register, no `.reg` decl from this call site). Required for tiled
// `@shared` kernels (gpu/SPEC.md §6) that must synchronize between
// shared-memory writes and cross-thread reads.

fn _build_case_barrier() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let r = _local(2, "r")

    // block 0: r = a + b ; gpu_barrier() ; return
    let mut s0 = []
    s0.push(_stmt_binop(r, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_call(_miss_local(), "gpu_barrier"))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(r)

    let mf = MFunc {
        name: "barrier_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_barrier.hexa", funcs: fns, globals: [] }
}

fn _test_barrier() -> bool {
    let mut ok = true
    let mod_b = _build_case_barrier()
    let ptx = codegen_emit_ptx_sm80(mod_b)

    println("")
    println("── emitted PTX (055-P4 gpu_barrier case, sm_80) ──")
    println(ptx)

    ok = _check(ok, ptx, "bar.sync 0",       "gpu_barrier() -> bar.sync 0")
    // Sandwiched between add (before) and ret (after).
    ok = _check(ok, ptx, "add.f64",          "preceding f64 add still emitted")
    ok = _check(ok, ptx, "ret;",             "ret terminator after barrier")
    // No .reg for the barrier call dst (void return — _miss_local has id=-1
    // which wouldn't classify, but verify no spurious "-1" reg name).
    if _contains(ptx, ".reg .f64 %fd-1") {
        println("  FAIL: void-return barrier must not produce a %fd-1 reg decl")
        ok = false
    }
    return ok
}

// ── Case 8 — 055-P4+ gpu_atomic_add(addr, v) intrinsic ───────────────
//
// RFC 055 §12 P4+ — device-DRAM FP64 atomic add. STMT_CALL with
// op="gpu_atomic_add", args[0]=address (Local in u64 bank), args[1]=value
// (f64) lowers to `atom.add.f64 %fd<dst>, [%rd<addr>], %fd<v>;`. The
// destination Local holds the OLD value at the address (PTX atom-instruction
// semantics) and is classified F64 by the default classifier path. The
// address operand's source Local is propagated to the U64 bank by
// `_nvptx_classify_locals` Pass 2 (extended to recognise this STMT_CALL).
//
// Fixture: a one-block MFunc with a single `r = gpu_atomic_add(p, v)`
// call followed by return. Verifies:
//   - `.reg .u64 %rd0` declared (Pass 2 propagation of the address Local)
//   - `.reg .f64 %fd2` declared (the OLD-value dst — default F64)
//   - `atom.add.f64 %fd2, [%rd0], %fd1;` for the atomic add body

fn _build_case_atomic_add() -> MModule {
    let p = _local(0, "p")           // address Local (param) — propagated to U64 by Pass 2
    let a = _local(1, "a")           // value source (param) — used by binop below
    let v = _local(2, "v")           // value operand — F64 via binop dst (Pass 1)
    let r = _local(3, "r")           // dst (old value) — F64 via default classifier

    // block 0:
    //   v = a + a                   (STMT_BINOP — gets v into the F64 bank)
    //   r = gpu_atomic_add(p, v)    (STMT_CALL — args[0]=addr, args[1]=val)
    //   return
    //
    // The binop intermediate is the same pattern as _test_load_store's v2;
    // it keeps the test focused on the new STMT_CALL lowering + Pass 2
    // address-operand propagation, without depending on whether param
    // Locals get a `.reg` decl (they don't, by design — params render
    // directly via their `%fd<id>` / `%rd<id>` name).
    let mut atom_args = []
    atom_args.push(_op_local(p.id))
    atom_args.push(_op_local(v.id))

    let mut s0 = []
    s0.push(_stmt_binop(v, "add", _op_local(a.id), _op_local(a.id)))
    s0.push(_stmt_call_with_args(r, "gpu_atomic_add", atom_args))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(p)
    params.push(a)
    let mut locals = []
    locals.push(p)
    locals.push(a)
    locals.push(v)
    locals.push(r)

    let mf = MFunc {
        name: "atomic_add_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_atomic_add.hexa", funcs: fns, globals: [] }
}

fn _test_atomic_add() -> bool {
    let mut ok = true
    let mod_aa = _build_case_atomic_add()
    let ptx = codegen_emit_ptx_sm80(mod_aa)

    println("")
    println("-- emitted PTX (055-P4+ gpu_atomic_add case, sm_80) --")
    println(ptx)

    // Pass 2 retroactive U64 classification of the address Local (param)
    ok = _check(ok, ptx, ".reg .u64 %rd0",                    "u64 bank for address (Pass 2)")
    // F64 banks — binop intermediate v + atomic-add dst (old value)
    ok = _check(ok, ptx, ".reg .f64 %fd2",                    "f64 bank for value operand (binop dst)")
    ok = _check(ok, ptx, ".reg .f64 %fd3",                    "f64 bank for atomic-add dst (old value)")
    // STMT_CALL gpu_atomic_add lowering — dst=%fd3, addr=[%rd0], val=%fd2
    ok = _check(ok, ptx, "atom.add.f64 %fd3, [%rd0], %fd2",   "atom.add.f64 dst, [addr], val")
    // ret after the atomic add
    ok = _check(ok, ptx, "ret;",                              "ret terminator after atomic add")
    return ok
}

// ── Case 32 — F-RFC067-NVPTX-TMA-CODEGEN-SCAFFOLD ─────────────────────
//
// RFC 067 N202 — TMA opcode scaffold + sm_120a header emit. Verifies:
//   1. `nvptx_emit_module_header_for_tma("sm_120a")` returns the
//      canonical N196 header (`.target sm_120a` + `.version 8.7` +
//      `.address_size 64`) matching the N200 SMOKE artifact.
//   2. Non-sm_120a sm-tags ("sm_80" / "sm_90" / "sm_120") return ""
//      (fall-through — caller must use the regular header emitter).
//   3. `nvptx_tma_codegen_enabled()` returns false by default — the
//      feature-flag mechanism is in place but defaults OFF, so the
//      existing nvptx_target.hexa emit path stays byte-identical.
//   4. `ptx_tma_ops()` returns a non-empty opcode table; every row
//      pins `requires_arch = "sm_120a"` and `requires_version = "8.7"`.
//
// SCAFFOLD ONLY — no MIR is lowered through this path, no LModule is
// emitted with TMA opcodes. The integration point with N128 WMMA
// matmul is documented in
// `docs/notes/2026-05-22-tma-runtime-builtin-requirements.md`.

fn _test_tma_codegen_scaffold() -> bool {
    let mut ok = true

    println("")
    println("── RFC 067 N202 TMA codegen scaffold ──")

    // (1) sm_120a header — matches N200 SMOKE artifact lines 13-15.
    let header_120a = nvptx_emit_module_header_for_tma("sm_120a")
    println(header_120a)
    ok = _check(ok, header_120a, ".version 8.7",        "TMA header .version 8.7")
    ok = _check(ok, header_120a, ".target sm_120a",     "TMA header .target sm_120a")
    ok = _check(ok, header_120a, ".address_size 64",    "TMA header .address_size 64")

    // (1b) N153-fire finding — bare sm_120 `.version` must be 8.7 (was
    // 8.0, which the RTX 5070 driver-JIT rejected for the matmul/WMMA
    // E2E). sm_120a already 8.7; sm_80 stays 7.0.
    let ver_120  = _nvptx_ptx_version_for_sm_arch("sm_120")
    let ver_120a = _nvptx_ptx_version_for_sm_arch("sm_120a")
    let ver_80   = _nvptx_ptx_version_for_sm_arch("sm_80")
    if ver_120 != "8.7" { println("  FAIL: sm_120 .version → `" + ver_120 + "` want `8.7`"); ok = false }
    else { println("  ok: sm_120 .version -> 8.7") }
    if ver_120a != "8.7" { println("  FAIL: sm_120a .version → `" + ver_120a + "` want `8.7`"); ok = false }
    else { println("  ok: sm_120a .version -> 8.7") }
    if ver_80 != "7.0" { println("  FAIL: sm_80 .version → `" + ver_80 + "` want `7.0`"); ok = false }
    else { println("  ok: sm_80 .version -> 7.0") }

    // (2) Fall-through — non-sm_120a returns "".
    let header_sm80  = nvptx_emit_module_header_for_tma("sm_80")
    let header_sm90  = nvptx_emit_module_header_for_tma("sm_90")
    let header_sm120 = nvptx_emit_module_header_for_tma("sm_120")
    if len(header_sm80)  != 0 { println("  FAIL: sm_80 expected empty fall-through");  ok = false }
    if len(header_sm90)  != 0 { println("  FAIL: sm_90 expected empty fall-through");  ok = false }
    if len(header_sm120) != 0 { println("  FAIL: sm_120 expected empty fall-through (no _a suffix)"); ok = false }

    // (3) Feature-flag defaults OFF — preserves byte-identical existing
    //     emit path (no regression on the 31 existing cases above).
    //
    // N206 — predicate now reads `HEXA_NVPTX_TMA` env via env_var
    // (codegen_c2.hexa:5154). When env is unset the predicate must be
    // false; if env=1 the test is informational (flag is intentionally on).
    if nvptx_tma_codegen_enabled() {
        let env_set = env_var("HEXA_NVPTX_TMA")
        if env_set == "1" {
            println("  INFO: HEXA_NVPTX_TMA=1 detected; default-OFF clause not applicable")
        } else {
            println("  FAIL: nvptx_tma_codegen_enabled() must default to false when env unset (scaffold)")
            ok = false
        }
    }

    // (4) Opcode table — non-empty, every row pins sm_120a + 8.7.
    let ops = ptx_tma_ops()
    if len(ops) == 0 {
        println("  FAIL: ptx_tma_ops() must enumerate at least one TMA opcode")
        ok = false
    }
    let mut i = 0
    while i < len(ops) {
        let row = ops[i]
        if row.requires_arch != NVPTX_ARCH_SM120A {
            println("  FAIL: opcode `" + row.mnemonic + "` requires_arch != sm_120a")
            ok = false
        }
        if row.requires_version != NVPTX_PTX_VERSION_SM120A {
            println("  FAIL: opcode `" + row.mnemonic + "` requires_version != 8.7")
            ok = false
        }
        i = i + 1
    }

    // (5) Required N200-SMOKE opcode constants exist + are non-empty.
    if len(PTX_OP_CP_ASYNC_BULK_TENSOR_2D) == 0    { ok = false; println("  FAIL: PTX_OP_CP_ASYNC_BULK_TENSOR_2D empty") }
    if len(PTX_OP_MBARRIER_INIT) == 0              { ok = false; println("  FAIL: PTX_OP_MBARRIER_INIT empty") }
    if len(PTX_OP_MBARRIER_ARRIVE_EXPECT_TX) == 0  { ok = false; println("  FAIL: PTX_OP_MBARRIER_ARRIVE_EXPECT_TX empty") }
    if len(PTX_OP_MBARRIER_TRY_WAIT_PARITY) == 0   { ok = false; println("  FAIL: PTX_OP_MBARRIER_TRY_WAIT_PARITY empty") }
    if len(PTX_OP_FENCE_PROXY_ASYNC_SHARED_CTA) == 0 { ok = false; println("  FAIL: PTX_OP_FENCE_PROXY_ASYNC_SHARED_CTA empty") }
    if len(PTX_OP_CVTA_PARAM_U64) == 0             { ok = false; println("  FAIL: PTX_OP_CVTA_PARAM_U64 empty") }

    // (6) ABI constants — CUtensorMap is 128 B, alignment 64, max rank 5.
    if NVPTX_TMA_DESC_BYTES != 128     { ok = false; println("  FAIL: NVPTX_TMA_DESC_BYTES must be 128") }
    if NVPTX_TMA_DESC_ALIGNMENT != 64  { ok = false; println("  FAIL: NVPTX_TMA_DESC_ALIGNMENT must be 64") }
    if NVPTX_TMA_MAX_RANK != 5         { ok = false; println("  FAIL: NVPTX_TMA_MAX_RANK must be 5") }

    return ok
}

// ── Case 33 — F-RFC067-NVPTX-TMA-MATMUL-EMIT (N206 TMA dispatch) ─────
//
// RFC 067 N206 — TMA matmul emit dispatch on sm_120a + flag on. Verifies
// the codegen wiring:
//   (a) `_nvptx_emit_matmul_tma_module(name, target, "8.7")` directly
//       emits PTX containing the N196 TMA opcode chain
//       (cp.async.bulk.tensor.2d + mbarrier.init/arrive/try_wait +
//       fence.proxy.async + cvta.param.u64) + sm_120a header.
//   (b) The kernel entry name flows through (parameterised — same
//       MFunc-name path as the N128 WMMA emit).
//   (c) The 2 × .param .align 64 .b8 [128] TMA descriptor param slots
//       are emitted with `tmap_a_param` / `tmap_b_param` + the C global
//       pointer `c_ptr_param` (matches the N200 SMOKE artifact +
//       N202 requirements doc kernel signature).
//   (d) With `nvptx_tma_codegen_enabled()` default-OFF (env HEXA_NVPTX_TMA
//       unset), `codegen_emit_ptx_for_sm(module, "sm_120a")` falls through
//       to the WMMA path (no TMA opcodes emitted) — proves the feature
//       flag actually gates the path (not just sm_120a target).
//
// This is the F-RFC067-NVPTX-TMA-CODEGEN-EMIT falsifier — the codegen
// half of the source-to-silicon E2E. The silicon-fire half lives in
// archive/fires/ + the host-side cuTensorMapEncodeTiled driver.

fn _test_tma_matmul_emit() -> bool {
    let mut ok = true

    println("")
    println("── RFC 067 N206 TMA matmul emit (sm_120a + flag on) ──")

    // (a)+(b)+(c) Direct emit via the public TMA module emitter.
    let ptx_tma = _nvptx_emit_matmul_tma_module("matmul_tma", NVPTX_TARGET_SM120A, NVPTX_PTX_VERSION_SM120A)

    // Header (sm_120a + 8.7 + .address_size 64) — N196 finding gate.
    ok = _check(ok, ptx_tma, ".version 8.7",                   "TMA PTX .version 8.7 (N196)")
    ok = _check(ok, ptx_tma, ".target sm_120a",                "TMA PTX .target sm_120a (N196)")
    ok = _check(ok, ptx_tma, ".address_size 64",               "TMA PTX .address_size 64")
    // Entry directive + param bank (TMA descriptors + C ptr).
    ok = _check(ok, ptx_tma, ".visible .entry matmul_tma",     "TMA entry directive name flowed through")
    ok = _check(ok, ptx_tma, ".param .align 64 .b8 tmap_a_param[128]", "TMA A-descriptor param slot (128 B, align 64)")
    ok = _check(ok, ptx_tma, ".param .align 64 .b8 tmap_b_param[128]", "TMA B-descriptor param slot (128 B, align 64)")
    ok = _check(ok, ptx_tma, ".param .u64 c_ptr_param",        "C global pointer param")
    // Shared memory tiles + mbarrier slot.
    ok = _check(ok, ptx_tma, ".shared .align 16 .b8 smem_a[2048]", "A smem tile (64 rows x 16 cols fp16)")
    ok = _check(ok, ptx_tma, ".shared .align 16 .b8 smem_b[2048]", "B smem tile (16 rows x 64 cols fp16)")
    ok = _check(ok, ptx_tma, ".shared .align 8  .b8 smem_mbar[8]", "mbarrier smem slot (8 B)")
    // TMA descriptor address conversion (PTX ISA 8.7 §9.7.9.6).
    ok = _check(ok, ptx_tma, "cvta.param.u64 %tmap_a_addr",    "A-descriptor param->generic addr conversion")
    ok = _check(ok, ptx_tma, "cvta.param.u64 %tmap_b_addr",    "B-descriptor param->generic addr conversion")
    // mbarrier init + arrive + wait (PTX ISA 8.7 §9.7.12.15).
    ok = _check(ok, ptx_tma, "mbarrier.init.shared.b64",       "mbarrier init opcode")
    ok = _check(ok, ptx_tma, "mbarrier.arrive.expect_tx.release.cta.shared::cta.b64", "mbarrier arrive opcode")
    ok = _check(ok, ptx_tma, "mbarrier.try_wait.parity.shared::cta.b64", "mbarrier try_wait parity opcode")
    // Proxy fence (PTX ISA 8.7 §8.5).
    ok = _check(ok, ptx_tma, "fence.proxy.async.shared::cta",  "proxy fence between TMA async and generic proxy")
    // TMA bulk tensor load (PTX ISA 8.7 §9.7.8.24).
    ok = _check(ok, ptx_tma, "cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes", "cp.async.bulk.tensor.2d TMA load opcode")
    // K-loop (4 iters of 16 cols, M=N=K=64 SMOKE shape).
    ok = _check(ok, ptx_tma, "L_kloop:",                       "K-loop label")
    ok = _check(ok, ptx_tma, "setp.lt.s32 %p0, %k_iter, 4",    "K-loop guard (4 K-tiles)")
    ok = _check(ok, ptx_tma, "add.s32 %k_iter, %k_iter, 1",    "K-loop step")
    ok = _check(ok, ptx_tma, "ret;",                           "kernel return")
    // Negative guards — TMA emit must NOT contain WMMA opcodes (different
    // load/mma path) or the canonical N128 6-param bank (TMA uses 2-desc
    // + 1-C-ptr signature instead).
    if _contains(ptx_tma, "wmma.load.a")               { ok = false; println("  FAIL: TMA path must not emit wmma.load.a (uses cp.async.bulk.tensor)") }
    if _contains(ptx_tma, "wmma.mma.sync")             { ok = false; println("  FAIL: TMA path SMOKE-level does not emit wmma.mma chain (scope-down: load+write-back only)") }
    if _contains(ptx_tma, ".param .u64 matmul_tma_param_5") { ok = false; println("  FAIL: TMA path uses 2-descriptor + C-ptr signature, not the 6 .u64 bank") }

    // (d) Default-OFF behavior — sm_120a target with flag OFF must NOT
    //     take TMA path. Run the public dispatcher and confirm no TMA
    //     opcodes appear. (HEXA_NVPTX_TMA env var must be unset for this
    //     test to be meaningful; if set, the test is informational.)
    let mod_mm = _build_matmul_module_for("matmul_default_off", "matmul")
    let ptx_off = codegen_emit_ptx_for_sm(mod_mm, "sm_120a")
    if nvptx_tma_codegen_enabled() {
        // Env is set — TMA path is taken; verify it.
        println("  INFO: HEXA_NVPTX_TMA=1 detected; default-OFF clause skipped")
    } else {
        // Env is unset — must fall through to WMMA path (no TMA opcodes).
        if _contains(ptx_off, "cp.async.bulk.tensor") {
            ok = false; println("  FAIL: flag OFF + sm_120a must NOT emit TMA opcodes (got cp.async.bulk.tensor)")
        }
        if _contains(ptx_off, "mbarrier.init.shared.b64") {
            ok = false; println("  FAIL: flag OFF + sm_120a must NOT emit mbarrier opcodes")
        }
        // Should still emit something (WMMA-shaped) for the matmul module.
        if !_contains(ptx_off, ".visible .entry matmul_default_off") {
            ok = false; println("  FAIL: flag OFF + sm_120a must still emit a matmul kernel entry (WMMA path)")
        }
    }

    return ok
}

// ── Case — RFC 055 §13 floating-point math intrinsics ─────────────────
//
// Source-level `sqrt(x)` / `max(a,b)` / `min(a,b)` / `exp(x)` / `abs(x)`
// / `rsqrt(x)` lower (hir_to_mir L1048-1245) to STMT_CALL with the bare
// callee name in `s.op` + source args in `s.args` — the SAME shape the
// NVPTX handler now wires. These three cases assert the emitted PTX
// mnemonics for the f32 family (the ML / NN-stack case), the f64 family
// (the EXACT subset), and the operand-kind inheritance path.

// _local_f32_param — a scalar f32 kernel param Local (type_id=4). With
// gpu_kind=GPU_KIND_KERNEL, Pass 0 classifies it into the F32 bank
// (`%fs<id>`), matching how a real `@gpu_kernel fn k(x: f32)` param flows.
fn _local_f32_param(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 4, name_hint: name, precision: "" }
}

fn _math_call(dst: Local, op: string, a: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    return Stmt {
        kind: STMT_CALL, dst: dst, op: op, args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _math_call2(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return Stmt {
        kind: STMT_CALL, dst: dst, op: op, args: xs,
        target_block: -1, target_block_else: -1
    }
}

// Case M1 — f32 math family. Dst Locals carry `.f32` precision tags so
// the classifier routes them to the F32 bank; each math intrinsic emits
// its `.f32` PTX mnemonic. Covers EXACT (sqrt/max/min/abs) + APPROX
// (rsqrt.approx.f32 + exp via mul.f32 premul + ex2.approx.f32).
fn _build_case_math_f32() -> MModule {
    let x  = _local_f32_param(0, "x")    // f32 kernel param source (Pass-0 F32 bank)
    let y  = _local_f32_param(1, "y")
    let r0 = _local_with_precision(2, "r0", ".f32")   // sqrt(x)
    let r1 = _local_with_precision(3, "r1", ".f32")   // max(x,y)
    let r2 = _local_with_precision(4, "r2", ".f32")   // min(x,y)
    let r3 = _local_with_precision(5, "r3", ".f32")   // abs(x)
    let r4 = _local_with_precision(6, "r4", ".f32")   // rsqrt(x)
    let r5 = _local_with_precision(7, "r5", ".f32")   // exp(x)

    let mut s0 = []
    s0.push(_math_call(r0, "sqrt", _op_local(x.id)))
    s0.push(_math_call2(r1, "max", _op_local(x.id), _op_local(y.id)))
    s0.push(_math_call2(r2, "min", _op_local(x.id), _op_local(y.id)))
    s0.push(_math_call(r3, "abs", _op_local(x.id)))
    s0.push(_math_call(r4, "rsqrt", _op_local(x.id)))
    s0.push(_math_call(r5, "exp", _op_local(x.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    let mut params = []
    params.push(x)
    params.push(y)
    let mut locals = []
    locals.push(x)
    locals.push(y)
    locals.push(r0)
    locals.push(r1)
    locals.push(r2)
    locals.push(r3)
    locals.push(r4)
    locals.push(r5)
    let mf = MFunc {
        name: "math_f32_smoke", params: params,
        return_local: _miss_local(), locals: locals, blocks: blocks,
        entry_block: 0, arena_root: 1, def_line: 0, gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_math_f32.hexa", funcs: fns, globals: [] }
}

fn _test_math_f32() -> bool {
    let mut ok = true
    let ptx = codegen_emit_ptx_sm80(_build_case_math_f32())
    println("")
    println("── emitted PTX (RFC 055 §13 math f32 family, sm_80) ──")
    println(ptx)
    // EXACT ops — byte-eq verifiable (operands resolve to the f32 bank)
    ok = _check(ok, ptx, "sqrt.rn.f32 %fs2, %fs0",       "sqrt → sqrt.rn.f32")
    ok = _check(ok, ptx, "max.f32 %fs3, %fs0, %fs1",     "max → max.f32")
    ok = _check(ok, ptx, "min.f32 %fs4, %fs0, %fs1",     "min → min.f32")
    ok = _check(ok, ptx, "abs.f32 %fs5, %fs0",           "abs → abs.f32")
    // APPROX ops
    ok = _check(ok, ptx, "rsqrt.approx.f32 %fs6, %fs0",  "rsqrt → rsqrt.approx.f32")
    ok = _check(ok, ptx, "mul.f32 %fs7, %fs0, 0d3FF71547652B82FE", "exp premul x*log2e")
    ok = _check(ok, ptx, "ex2.approx.f32 %fs7, %fs7",    "exp → ex2.approx.f32")
    // No unsupported-call stub for any wired op
    if _contains(ptx, "unsupported call: sqrt") { println("  FAIL: sqrt left as unsupported stub"); ok = false }
    if _contains(ptx, "unsupported call: max")  { println("  FAIL: max left as unsupported stub"); ok = false }
    if _contains(ptx, "unsupported call: exp")  { println("  FAIL: exp left as unsupported stub"); ok = false }
    if _contains(ptx, "unsupported call: rsqrt"){ println("  FAIL: rsqrt left as unsupported stub"); ok = false }
    return ok
}

// Case M2 — f64 EXACT family + honest stubs for the f64 APPROX cases.
// Plain (untagged) Locals default to F64. sqrt/max/min/abs emit their
// `.f64` mnemonic (EXACT, byte-eq); rsqrt + exp at f64 emit an honest
// stub comment (rsqrt.approx / ex2.approx are f32-only).
fn _build_case_math_f64() -> MModule {
    let x  = _local(0, "x")
    let y  = _local(1, "y")
    let r0 = _local(2, "r0")   // sqrt(x)
    let r1 = _local(3, "r1")   // max(x,y)
    let r2 = _local(4, "r2")   // min(x,y)
    let r3 = _local(5, "r3")   // abs(x)
    let r4 = _local(6, "r4")   // rsqrt(x) — honest stub at f64
    let r5 = _local(7, "r5")   // exp(x)   — honest stub at f64

    let mut s0 = []
    s0.push(_math_call(r0, "sqrt", _op_local(x.id)))
    s0.push(_math_call2(r1, "max", _op_local(x.id), _op_local(y.id)))
    s0.push(_math_call2(r2, "min", _op_local(x.id), _op_local(y.id)))
    s0.push(_math_call(r3, "abs", _op_local(x.id)))
    s0.push(_math_call(r4, "rsqrt", _op_local(x.id)))
    s0.push(_math_call(r5, "exp", _op_local(x.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    let mut params = []
    params.push(x)
    params.push(y)
    let mut locals = []
    locals.push(x)
    locals.push(y)
    locals.push(r0)
    locals.push(r1)
    locals.push(r2)
    locals.push(r3)
    locals.push(r4)
    locals.push(r5)
    let mf = MFunc {
        name: "math_f64_smoke", params: params,
        return_local: _miss_local(), locals: locals, blocks: blocks,
        entry_block: 0, arena_root: 1, def_line: 0, gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_math_f64.hexa", funcs: fns, globals: [] }
}

fn _test_math_f64() -> bool {
    let mut ok = true
    let ptx = codegen_emit_ptx_sm80(_build_case_math_f64())
    println("")
    println("── emitted PTX (RFC 055 §13 math f64 family + honest stubs, sm_80) ──")
    println(ptx)
    ok = _check(ok, ptx, "sqrt.rn.f64 %fd2", "sqrt → sqrt.rn.f64")
    ok = _check(ok, ptx, "max.f64 %fd3",     "max → max.f64")
    ok = _check(ok, ptx, "min.f64 %fd4",     "min → min.f64")
    ok = _check(ok, ptx, "abs.f64 %fd5",     "abs → abs.f64")
    // honest stubs for the f64 APPROX cases — must be present, never a
    // wrong mnemonic, never the generic unsupported-call stub.
    ok = _check(ok, ptx, "rsqrt f64 honest stub", "rsqrt f64 → honest stub")
    ok = _check(ok, ptx, "exp f64 honest stub",   "exp f64 → honest stub")
    if _contains(ptx, "rsqrt.approx.f64") { println("  FAIL: emitted nonexistent rsqrt.approx.f64"); ok = false }
    if _contains(ptx, "ex2.approx.f64")   { println("  FAIL: emitted nonexistent ex2.approx.f64"); ok = false }
    return ok
}

// Case M3 — operand-kind inheritance. The math result dst is UNTAGGED
// (would default F64) but its f32 operand drives the Pass-1 inheritance
// so the result lands in the F32 bank — `sqrt.rn.f32`, not the mixed-bank
// `sqrt.rn.f64 %fd, %fs` that ptxas rejects.
fn _build_case_math_inherit() -> MModule {
    let x  = _local_f32_param(0, "x")  // f32 kernel param source (Pass-0 F32 bank)
    let r0 = _local(1, "r0")            // sqrt(x) — UNTAGGED dst (would default F64)

    let mut s0 = []
    s0.push(_math_call(r0, "sqrt", _op_local(x.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    let mut params = []
    params.push(x)
    let mut locals = []
    locals.push(x)
    locals.push(r0)
    let mf = MFunc {
        name: "math_inherit_smoke", params: params,
        return_local: _miss_local(), locals: locals, blocks: blocks,
        entry_block: 0, arena_root: 1, def_line: 0, gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_math_inherit.hexa", funcs: fns, globals: [] }
}

fn _test_math_inherit() -> bool {
    let mut ok = true
    let ptx = codegen_emit_ptx_sm80(_build_case_math_inherit())
    println("")
    println("── emitted PTX (RFC 055 §13 math operand-kind inheritance, sm_80) ──")
    println(ptx)
    // dst inherits f32 from operand → f32 bank + f32 mnemonic
    ok = _check(ok, ptx, ".reg .f32 %fs1",      "untagged sqrt dst inherits f32 bank")
    ok = _check(ok, ptx, "sqrt.rn.f32 %fs1, %fs0", "sqrt.rn.f32 with f32 operand (no mixed bank)")
    if _contains(ptx, "sqrt.rn.f64 %fd1") { println("  FAIL: mixed-bank f64 dst over f32 operand"); ok = false }
    return ok
}

