// ── Case 9 — 055-P4 gpu_warp_shuffle(v, lane) intrinsic ───────────────
//
// RFC 055 §12 P4+ — warp-lane data exchange. STMT_CALL with
// op="gpu_warp_shuffle" lowers to `shfl.sync.idx.b32 %r<dst>, %r<src>,
// %r<lane>, 0x1f, 0xffffffff;`. The dst Local is classified U32.
// Value + lane operands render via hand-typed `%r<id>` references.

fn _build_case_warp_shuffle() -> MModule {
    let v = _local(0, "v")           // STMT_CALL gpu_thread_id_x -> U32 %r0
    let lane = _local(1, "lane")     // STMT_CALL gpu_thread_id_y -> U32 %r1
    let r = _local(2, "r")           // gpu_warp_shuffle dst — U32 %r2

    let mut shuf_args = []
    shuf_args.push(_op_local(v.id))
    shuf_args.push(_op_local(lane.id))

    let mut s0 = []
    s0.push(_stmt_call(v, "gpu_thread_id_x"))
    s0.push(_stmt_call(lane, "gpu_thread_id_y"))
    s0.push(_stmt_call_with_args(r, "gpu_warp_shuffle", shuf_args))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(v)
    locals.push(lane)
    locals.push(r)

    let mf = MFunc {
        name: "warp_shuffle_smoke",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_warp_shuffle.hexa", funcs: fns, globals: [] }
}

fn _test_warp_shuffle() -> bool {
    let mut ok = true
    let mod_ws = _build_case_warp_shuffle()
    let ptx = codegen_emit_ptx_sm80(mod_ws)

    println("")
    println("-- emitted PTX (055-P4+ gpu_warp_shuffle case, sm_80) --")
    println(ptx)

    ok = _check(ok, ptx, ".reg .u32 %r2",                                      "u32 bank for warp_shuffle dst")
    ok = _check(ok, ptx, "shfl.sync.idx.b32 %r2, %r0, %r1, 0x1f, 0xffffffff",  "shfl.sync.idx.b32 full operand list")
    return ok
}
// ── Case 34 — N71-B (N70/N91 GAP-C) FP64 warp-shuffle composition ──────
//
// PTX `shfl.sync.*.b32` moves only 32 bits, so shuffling an f64 value must
// decompose `%fd<src>` into two `.b32` halves (`mov.b64 {%lo,%hi},%fd<src>`),
// shuffle EACH half with the same mode/mask/clamp/membermask, then recompose
// (`mov.b64 %fd<dst>,{%lo_out,%hi_out}`). The earlier 32-bit-only path
// hardcoded `%r<src>` for the value operand → an undeclared `%r` ref that
// ptxas rejects (`Unknown symbol %r9`). This fixture builds a tiny device
// function that produces an f64 value (binop) then warp-shuffle-xors it,
// and asserts the decompose/shuffle×2/recompose sequence with ZERO
// undeclared `%r` value refs in the shuffle.
//   ref: NVIDIA PTX ISA §9.7.13.4 shfl.sync.
fn _build_case_warp_shuffle_f64() -> MModule {
    let a = _local(0, "a")          // f64 source operand (param-like, default f64)
    let b = _local(1, "b")          // f64 source operand
    let v = _local(2, "v")          // STMT_BINOP add -> F64 %fd2 (the value to shuffle)
    let mask = _local(3, "mask")    // STMT_CALL gpu_thread_id_x -> U32 %r3
    let r = _local(4, "r")          // gpu_warp_shuffle_xor dst — F64 (source is f64) %fd4

    let mut shuf_args = []
    shuf_args.push(_op_local(v.id))
    shuf_args.push(_op_local(mask.id))

    let mut s0 = []
    s0.push(_stmt_binop(v, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_call(mask, "gpu_thread_id_x"))
    s0.push(_stmt_call_with_args(r, "gpu_warp_shuffle_xor", shuf_args))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(v)
    locals.push(mask)
    locals.push(r)

    let mf = MFunc {
        name: "warp_shuffle_f64_smoke",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_warp_shuffle_f64.hexa", funcs: fns, globals: [] }
}

// N71-B note: substring counts use the existing `_count_substr` helper
// (defined further down for the unroll cases) — module-global in the flatten.

fn _test_warp_shuffle_f64() -> bool {
    let mut ok = true
    let mod_ws = _build_case_warp_shuffle_f64()
    let ptx = codegen_emit_ptx_sm80(mod_ws)

    println("")
    println("-- emitted PTX (N71-B FP64 gpu_warp_shuffle_xor case, sm_80) --")
    println(ptx)

    // dst is the f64 bank (recompose target), NOT the 32-bit %r bank.
    ok = _check(ok, ptx, ".reg .f64 %fd4",  "f64 bank for f64 warp_shuffle dst")
    // 4 scratch .b32 halves declared (lo/hi/lo_out/hi_out).
    ok = _check(ok, ptx, ".reg .b32 %shfl_lo_4",     "scratch .b32 %shfl_lo_4 declared")
    ok = _check(ok, ptx, ".reg .b32 %shfl_hi_4",     "scratch .b32 %shfl_hi_4 declared")
    ok = _check(ok, ptx, ".reg .b32 %shfl_lo_out_4", "scratch .b32 %shfl_lo_out_4 declared")
    ok = _check(ok, ptx, ".reg .b32 %shfl_hi_out_4", "scratch .b32 %shfl_hi_out_4 declared")
    // decompose: mov.b64 {%lo, %hi}, %fd2
    ok = _check(ok, ptx, "mov.b64 {%shfl_lo_4, %shfl_hi_4}, %fd2", "decompose mov.b64 {lo,hi}, %fd2")
    // two bfly shuffles, lo + hi, with the same mask/clamp/membermask
    ok = _check(ok, ptx, "shfl.sync.bfly.b32 %shfl_lo_out_4, %shfl_lo_4, %r3, 0x1f, 0xffffffff", "shfl lo half")
    ok = _check(ok, ptx, "shfl.sync.bfly.b32 %shfl_hi_out_4, %shfl_hi_4, %r3, 0x1f, 0xffffffff", "shfl hi half")
    // recompose: mov.b64 %fd4, {%lo_out, %hi_out}
    ok = _check(ok, ptx, "mov.b64 %fd4, {%shfl_lo_out_4, %shfl_hi_out_4}", "recompose mov.b64 %fd4, {lo_out,hi_out}")
    // exactly two shuffle instructions in the f64 path (lo + hi).
    if _count_substr(ptx, "shfl.sync.bfly.b32") != 2 {
        ok = false
        println("  FAIL: expected exactly 2 shfl.sync.bfly.b32 (lo+hi), got " + to_string(_count_substr(ptx, "shfl.sync.bfly.b32")))
    }
    // CRITICAL: ZERO undeclared %r value refs — the shuffle must NOT
    // reference `%r2` (the old hardcoded u32-bank value reg for an f64
    // source). %r3 (the mask) is the only legitimate %r in the shuffle.
    if _count_substr(ptx, "%r2") != 0 {
        ok = false
        println("  FAIL: f64 shuffle must NOT reference the undeclared u32 value reg %r2 (GAP-C bug)")
    }
    return ok
}
// ── Case 35 — N71-B FP64 shuffle with a u64-bank mask (real warp-reduce) ─
//
// The real warp_reduce_sum fixture declares `mask: i32 = 16; mask = mask/2`
// but the classifier lands the mask Local in the u64 bank (`%rd`) via the
// i64-typed div. `shfl.sync.*.b32`'s lane operand must be `.b32`, so the
// lowering must narrow the u64 mask with `cvt.u32.u64 %shfl_mask_<dst>,
// %rd<mask>` before the shuffle — else it would reference an undeclared
// `%r<mask>`. This case pins that narrow.

fn _local_i64(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 1, name_hint: name, precision: "" }
}

fn _stmt_assign(dst: Local, op: string, a: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    return Stmt {
        kind: STMT_ASSIGN, dst: dst, op: op, args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _build_case_warp_shuffle_f64_u64mask() -> MModule {
    let a = _local(0, "a")               // f64 src operand
    let b = _local(1, "b")               // f64 src operand
    let v = _local(2, "v")               // STMT_BINOP add -> F64 %fd2
    let m0 = _local_i64(3, "m0")         // i64 seed -> U64 %rd3
    let mask = _local_i64(4, "mask")     // STMT_ASSIGN i64 div -> U64 %rd4 (mask)
    let r = _local(5, "r")               // gpu_warp_shuffle_xor dst — F64 %fd5

    let mut shuf_args = []
    shuf_args.push(_op_local(v.id))
    shuf_args.push(_op_local(mask.id))

    let mut s0 = []
    s0.push(_stmt_binop(v, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_assign(m0, "assign", _op_local(a.id)))   // m0: i64 -> U64
    s0.push(_stmt_binop(mask, "div", _op_local(m0.id), _op_local(m0.id)))  // i64 div -> U64
    s0.push(_stmt_call_with_args(r, "gpu_warp_shuffle_xor", shuf_args))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(a); locals.push(b); locals.push(v)
    locals.push(m0); locals.push(mask); locals.push(r)

    let mf = MFunc {
        name: "warp_shuffle_f64_u64mask_smoke",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_warp_shuffle_f64_u64mask.hexa", funcs: fns, globals: [] }
}

fn _test_warp_shuffle_f64_u64mask() -> bool {
    let mut ok = true
    let mod_ws = _build_case_warp_shuffle_f64_u64mask()
    let ptx = codegen_emit_ptx_sm80(mod_ws)

    println("")
    println("-- emitted PTX (N71-B FP64 shuffle + u64 mask narrow, sm_80) --")
    println(ptx)

    // The u64 mask (%rd4) must be narrowed to a u32 scratch before the shfl.
    ok = _check(ok, ptx, ".reg .u32 %shfl_mask_5",            "u32 mask-narrow scratch declared")
    ok = _check(ok, ptx, "cvt.u32.u64 %shfl_mask_5, %rd4",   "cvt.u32.u64 narrows u64 mask")
    // both shfl halves use the narrowed %shfl_mask_5 (NOT %r4 — undeclared).
    ok = _check(ok, ptx, "shfl.sync.bfly.b32 %shfl_lo_out_5, %shfl_lo_5, %shfl_mask_5, 0x1f, 0xffffffff", "shfl lo half uses narrowed mask")
    ok = _check(ok, ptx, "shfl.sync.bfly.b32 %shfl_hi_out_5, %shfl_hi_5, %shfl_mask_5, 0x1f, 0xffffffff", "shfl hi half uses narrowed mask")
    ok = _check(ok, ptx, "mov.b64 %fd5, {%shfl_lo_out_5, %shfl_hi_out_5}", "recompose into f64 dst")
    // CRITICAL: NO undeclared `%r4` (the bare-u32 spelling of the u64 mask).
    if _count_substr(ptx, "%r4,") != 0 || _count_substr(ptx, " %r4 ") != 0 {
        ok = false
        println("  FAIL: u64 mask must be narrowed, not spelled as undeclared %r4")
    }
    return ok
}
// ── Case 8 — 055-P4+ _nvptx_unroll_pass (canonical 3-block back-edge) ─
//
// RFC 055 §12 P4+ MVP: the loop-unroll pass clones the body of a
// canonical 3-block back-edge loop `factor` times so the lowered PTX
// has the unrolled instruction stream. Closes the GEMM perf gap noted
// in PR #105 (nvcc unrolls the k-loop ~5×; hexa-emit produces straight
// scalar bodies).
//
// Fixture (3-block back-edge loop):
//   block 0 (header): t = a + b ; p = t < b ; br_cond p -> body, else exit
//   block 1 (body)  : q = a * b               ; br -> header   (back-edge)
//   block 2 (exit)  : return
//
// Apply `_nvptx_unroll_pass(mfn, 2)` BEFORE codegen. Expected effect:
//   - body's STMT_BR target rewritten from header → clone block id
//   - a new clone block inserted with `q' = a * b ; br -> header`,
//     where `q'` is a renumbered Local id (offset = max-local-id + 1)
//   - header (and its setp / br_cond) stays unchanged — only the body
//     is cloned in the §12 P4+ MVP slice
//
// Honest-scope note (g3 over-claim 0): the generic MIR-walk lowering
// only emits FP64 arithmetic mnemonics for STMT_BINOP today (add/sub/mul
// — `_nvptx_binop_mnemonic`); `fma.rn.f64` + `add.s32` are produced
// only by the hand-emit P2 GEMM path (`_nvptx_p2_*` helpers), not by
// the generic lowering. So this MVP test asserts on what the generic
// path actually emits — duplicate counts of `mul.f64` and a single
// preserved `setp.lt.f64` (header NOT cloned). The unroll pass itself
// is opcode-agnostic: when a future cycle teaches the generic lowering
// to emit `fma.rn.f64` for a MIR (mul + add) fusion, the same unroll
// pass will duplicate that fma — the duplication is structural, not
// mnemonic-specific.

// _count_occurrences — count non-overlapping occurrences of `needle`
// in `hay`. Used to assert that the unroll pass produced N copies of
// a given mnemonic in the emitted PTX.
fn _count_occurrences(hay: string, needle: string) -> i64 {
    if len(needle) == 0 { return 0 }
    let mut n = 0
    let mut from = 0
    while from <= len(hay) - len(needle) {
        // `find` has no start-offset overload; slice the suffix.
        let suffix = hay.substring(from, len(hay))
        let pos = suffix.find(needle)
        if pos < 0 { return n }
        n = n + 1
        from = from + pos + len(needle)
    }
    return n
}

fn _check_count(ok_in: bool, hay: string, needle: string, want: i64, label: string) -> bool {
    let got = _count_occurrences(hay, needle)
    if got == want { return ok_in }
    println("  FAIL: " + label + " (want " + to_string(want) + " occurrences of `" + needle + "`, got " + to_string(got) + ")")
    return false
}

fn _build_case_unroll_loop() -> MFunc {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let t = _local(2, "t")     // header: t = a + b   (.f64)
    let p = _local(3, "p")     // header: p = t < b   (.pred)
    let q = _local(4, "q")     // body  : q = a * b   (.f64)

    // block 0 (header): t = a + b ; p = t < b ; br_cond p -> 1, else 2
    let mut s0 = []
    s0.push(_stmt_binop(t, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_binop(p, "lt",  _op_local(t.id), _op_local(b.id)))
    s0.push(_stmt_br_cond(_op_local(p.id), 1, 2))

    // block 1 (body): q = a * b ; br -> 0 (back-edge)
    let mut s1 = []
    s1.push(_stmt_binop(q, "mul", _op_local(a.id), _op_local(b.id)))
    s1.push(_stmt_br(0))

    // block 2 (exit): return
    let mut s2 = []
    s2.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))
    blocks.push(_block(2, s2))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a); locals.push(b)
    locals.push(t); locals.push(p); locals.push(q)

    return MFunc {
        name: "unroll_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
}

fn _test_unroll_pass() -> bool {
    let mut ok = true

    // Build the same MFunc twice — once for the un-unrolled baseline
    // (sanity assert: one `mul.f64`), once for the unrolled output
    // (the §12 P4+ assertion: two `mul.f64`).
    let mfn_baseline = _build_case_unroll_loop()
    let mfn_unrolled = _nvptx_unroll_pass(_build_case_unroll_loop(), 2)

    // Baseline: 1 `mul.f64`, 1 `setp.lt.f64`, 1 `add.f64`.
    let mut funcs_b = []
    funcs_b.push(mfn_baseline)
    let mod_b = MModule { file: "unroll_baseline.hexa", funcs: funcs_b, globals: [] }
    let ptx_b = codegen_emit_ptx_sm80(mod_b)
    println("")
    println("── emitted PTX (baseline, no unroll, sm_80) ──")
    println(ptx_b)
    ok = _check_count(ok, ptx_b, "mul.f64",     1, "baseline body has 1 mul.f64")
    ok = _check_count(ok, ptx_b, "setp.lt.f64", 1, "baseline header has 1 setp.lt.f64")

    // Unrolled: the §12 P4+ assertion. Body cloned once → 2× mul.f64.
    // Header NOT cloned → still 1× setp.lt.f64 and 1× add.f64. Two
    // STMT_BR back-edges (orig body → clone, clone → header) → 2× `bra`
    // emitted from the body chain (in addition to whatever the header
    // / exit emit).
    let mut funcs_u = []
    funcs_u.push(mfn_unrolled)
    let mod_u = MModule { file: "unroll_factor2.hexa", funcs: funcs_u, globals: [] }
    let ptx_u = codegen_emit_ptx_sm80(mod_u)
    println("")
    println("── emitted PTX (unrolled, factor=2, sm_80) ──")
    println(ptx_u)

    // The load-bearing assertion: body's mul appears TWICE post-unroll.
    ok = _check_count(ok, ptx_u, "mul.f64",     2, "unrolled body has 2x mul.f64 (clone inserted)")
    // Header is untouched — exactly one setp.lt and one add.f64.
    ok = _check_count(ok, ptx_u, "setp.lt.f64", 1, "header setp.lt.f64 preserved (header NOT cloned)")
    ok = _check_count(ok, ptx_u, "add.f64",     1, "header add.f64 preserved (header NOT cloned)")
    // The clone's dst is a renumbered Local — distinct from the orig.
    // Original body emits %fd4, clone emits %fd9 (offset = max_local+1
    // = 4+1 = 5; 4+5 = 9). The exact id is implementation detail of
    // the offset arithmetic; the structural property we assert is that
    // both register names appear so the two mul.f64 don't write the
    // same dst (which would be SSA-illegal).
    ok = _check(ok, ptx_u, "%fd4", "original body's mul dst (%fd4) present")
    ok = _check(ok, ptx_u, "%fd9", "cloned body's mul dst (%fd9 = 4+offset) present")

    return ok
}

// ── Case 9 — _nvptx_unroll_pass honest-fallback (no-match CFG) ────────
//
// The unroll pass MUST return MFunc unchanged when the CFG doesn't
// match the canonical 3-block back-edge shape. Builds a single-block
// straight-line MFunc (no STMT_BR_COND, no back-edge) and asserts the
// emitted PTX is byte-identical before/after the pass.

fn _test_unroll_no_match_passthrough() -> bool {
    let mut ok = true
    // Reuse the BR fixture (2-block: a+b then bra then ret). No header
    // → no STMT_BR_COND → no match.
    let mod_pre  = _build_case_br()
    let ptx_pre  = codegen_emit_ptx_sm80(mod_pre)

    // Apply unroll pass to each func and rebuild the module.
    let mut funcs_post = []
    let mut i = 0
    while i < len(mod_pre.funcs) {
        funcs_post.push(_nvptx_unroll_pass(mod_pre.funcs[i], 2))
        i = i + 1
    }
    let mod_post = MModule { file: mod_pre.file, funcs: funcs_post, globals: mod_pre.globals }
    let ptx_post = codegen_emit_ptx_sm80(mod_post)

    if ptx_pre != ptx_post {
        println("  FAIL: unroll pass perturbed non-matching CFG")
        println("    pre  = " + ptx_pre)
        println("    post = " + ptx_post)
        ok = false
    } else {
        println("  ok: non-matching CFG → PTX byte-identical (honest passthrough)")
    }
    return ok
}
// ── Case 12 — RFC 055 §12 P4+ Tensor Core MMA scaffold ─────────────────
//
// SCAFFOLD ONLY — this case proves the new `gpu_wmma_mma` STMT_CALL op
// name is RECOGNIZED by the lowering and that the WMMA mnemonic table
// (`_nvptx_wmma_mnemonic`) is reachable from `_nvptx_lower_stmt`'s
// STMT_CALL branch. It does NOT verify a working WMMA emit; the
// emitted PTX is an honest stub comment line carrying the resolved
// mnemonic. A real WMMA emit needs (see `_nvptx_wmma_mnemonic`'s
// docstring): fragment register-bank allocation (PReg.kind="frag" →
// tile, not scalar), `.shared` staging-area declaration, per-fragment
// data-type tags (.f16 vs .f32 vs .bf16), row/col orientation, and
// tile-loop integration around the 16×16 MMA tile. None of those are
// implemented in this scaffold.
//
// Fixture: a one-block MFunc whose body is a single STMT_CALL with
// op="gpu_wmma_mma" (dst = void via `_miss_local`, args = []). The
// scaffold lowering emits a `// RFC 055 §12 P4+ WMMA (scaffold, not
// yet wired) — gpu_wmma_mma -> wmma.mma.sync...` comment line. The
// surrounding `add.f64` (before) and `ret;` (after) verify the
// scaffold doesn't disturb existing 055-P0 lowering.

fn _build_case_wmma_scaffold() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let r = _local(2, "r")

    // block 0: r = a + b ; gpu_wmma_mma() ; return
    let mut s0 = []
    s0.push(_stmt_binop(r, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_call(_miss_local(), "gpu_wmma_mma"))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(r)

    let mf = MFunc {
        name: "wmma_scaffold_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_wmma_scaffold.hexa", funcs: fns, globals: [] }
}

fn _test_wmma_scaffold() -> bool {
    // RFC 067 INSTR-EMIT — this case originally asserted the "scaffold"
    // comment stub. After RFC 067 instruction-emit landed (PR replacing
    // stub with real wmma.mma.sync... PTX), the assertions are updated
    // to match the real-emit reality. Naming preserved for backward-
    // compat (the case still verifies gpu_wmma_mma routes through the
    // STMT_CALL branch correctly).
    let mut ok = true
    let mod_w = _build_case_wmma_scaffold()
    let ptx = codegen_emit_ptx_sm80(mod_w)

    println("")
    println("── emitted PTX (RFC 067 WMMA real-emit case, sm_80) ──")
    println(ptx)

    // Resolved mnemonic emits as a real PTX instruction now (not a stub
    // comment). The canonical f16×f16→f32 mnemonic from
    // `_nvptx_wmma_mnemonic`.
    ok = _check(ok, ptx, "wmma.mma.sync.aligned.row.col.m16n16k16.f32.f32",
        "wmma.mma mnemonic emitted (real instr, ptxas-legal short f16 form)")
    // The dst fragment tuple starts with `{%fra<id>_e0,` — proves the
    // 8-element curly-braced operand tuple is generated.
    ok = _check(ok, ptx, "_e0,",
        "wmma dst tuple starts with `_e0,` (fragment-vector operand)")
    // The op name `gpu_wmma_mma` still appears in the instruction
    // comment (added via `_nvptx_instr(mnem, args, comment)`), proving
    // STMT_CALL routing intact.
    ok = _check(ok, ptx, "gpu_wmma_mma",
        "gpu_wmma_mma op name preserved in instr comment")
    if _contains(ptx, "RFC 055 055-P0 - unsupported call: gpu_wmma_mma") {
        println("  FAIL: gpu_wmma_mma must be intercepted by the WMMA emit, not fall through to unsupported-call stub")
        ok = false
    }
    if _contains(ptx, "WMMA (scaffold, not yet wired)") {
        println("  FAIL: stub comment still present — real wmma-emit did NOT fire (P4+ regression)")
        ok = false
    }
    // Surrounding 055-P0 instructions still emit (wmma-emit non-disturbing).
    ok = _check(ok, ptx, "add.f64",          "preceding f64 add still emitted")
    ok = _check(ok, ptx, "ret;",             "ret terminator after wmma")
    return ok
}

// ── Case 13 — RFC 055 §12 P4+ mixed-precision PTX types SCAFFOLD ──────
//
// SCAFFOLD-ONLY: this case proves the CLASSIFIER + REG-DECL pipeline
// can route mixed-precision Locals to the right PTX register bank
// (.reg .f16 / .reg .bf16 / .reg .f32) once the upstream MIR emits
// the matching binop opcodes (`add_f16` / `add_bf16` / `add_f32`).
//
// The opcodes themselves are ASPIRATIONAL — the lowering layer that
// would PRODUCE them is a future cycle (hir_to_mir.hexa would need
// per-Local precision tags). The body of each binop in the emitted
// PTX text is therefore an honest 055-P0-style stub (the binop
// mnemonic table only carries f64 add/sub/mul); what this scaffold
// test verifies is the CLASSIFICATION + REG-DECL machinery, which
// is the prerequisite for a real `add.f16` / `add.bf16` / `add.f32`
// lowering in a later cycle.
//
// Single-block MFunc:
//   block 0: t16  = a + b   // STMT_BINOP "add_f16"  → .f16  (%fh3)
//            tbf  = a + b   // STMT_BINOP "add_bf16" → .bf16 (%fb4)
//            t32  = a + b   // STMT_BINOP "add_f32"  → .f32  (%fs5)
//            return
//
// PASS = all three `.reg .f16 %fh3;` + `.reg .bf16 %fb4;` +
// `.reg .f32 %fs5;` DECLARATIONS appear in the emitted PTX text.
//
// Honest scope (per RFC 055 g3):
//   - SCAFFOLD does NOT add the MIR layer that produces mixed-precision
//     binop opcodes (future hir_to_mir cycle).
//   - SCAFFOLD does NOT add body lowering for mixed-precision binops
//     (`add.f16 %fh<dst>, %fh<a>, %fh<b>` etc. — future cycle).
//   - SCAFFOLD does NOT handle Tensor-Core paired BF16 (MMA cycle).
// What the scaffold makes REACHABLE: once a future MIR layer emits
// the new opcodes, the classifier + reg-decl side is ready.

fn _stmt_binop_mp(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    // Same shape as _stmt_binop — separate helper so the call site reads
    // as a MIXED-PRECISION binop (aspirational opcode).
    return _stmt_binop(dst, op, a, b)
}

fn _build_case_mixed_precision_scaffold() -> MModule {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let t16 = _local(3, "t16")   // expected .reg .f16  %fh3
    let tbf = _local(4, "tbf")   // expected .reg .bf16 %fb4
    let t32 = _local(5, "t32")   // expected .reg .f32  %fs5

    let mut s0 = []
    s0.push(_stmt_binop_mp(t16, "add_f16",  _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_binop_mp(tbf, "add_bf16", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_binop_mp(t32, "add_f32",  _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(t16)
    locals.push(tbf)
    locals.push(t32)

    let mf = MFunc {
        name: "mixed_precision_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_mixed_precision_scaffold.hexa", funcs: fns, globals: [] }
}

fn _test_mixed_precision_scaffold() -> bool {
    let mut ok = true
    let mod_mp = _build_case_mixed_precision_scaffold()
    let ptx = codegen_emit_ptx_sm80(mod_mp)

    println("")
    println("── emitted PTX (RFC 055 §12 P4+ mixed-precision scaffold, sm_80) ──")
    println(ptx)

    // SCAFFOLD verification — the three new reg banks declare cleanly.
    ok = _check(ok, ptx, ".reg .f16 %fh3",   "f16 bank for add_f16 dst")
    ok = _check(ok, ptx, ".reg .bf16 %fb4",  "bf16 bank for add_bf16 dst")
    ok = _check(ok, ptx, ".reg .f32 %fs5",   "f32 bank for add_f32 dst")
    // Header carry-over — sm_80 target intact under mixed-kind classification.
    ok = _check(ok, ptx, ".target sm_80",    "sm_80 .target directive")
    // 055-P0 F64 default still intact — params + ext temps stay %fd.
    // (Params aren't classified by an assignment but show up as %fd in
    // body operand text via the F64 fallback. No %fd-N reg for invalid
    // ids; the scaffold reuses ids 0/1 for params + 3/4/5 for assigned
    // Locals so id=2 deliberately stays unassigned.)
    return ok
}


// ── Case 14 — RFC 069 P1 `F-RFC069-FACTOR-N` ──────────────────────────
//
// Re-uses the canonical 3-block back-edge fixture from `_build_case_unroll_loop`
// (PR #117 Case 10) and exercises factor=2 (PR #117 byte-eq regression),
// factor=3 (3 body bodies + 2 forward links), factor=4 (4 bodies +
// 3 forward links), and factor=100 (out-of-range clamp → passthrough
// byte-identical to factor=1).
//
// Per RFC 069 §3 P1 `F-RFC069-FACTOR-N` + §4 falsifier battery. Does NOT
// fire GPU silicon (text-shape only); F4 NUMERIC-EQ is the closure-cycle
// falsifier.

fn _count_substr(hay: string, needle: string) -> i64 {
    // Tiny utility — count non-overlapping occurrences of `needle` in `hay`.
    // Useful for counting cloned body instances in the unrolled PTX text.
    let mut n: i64 = 0
    let mut i: i64 = 0
    let hlen = len(hay)
    let nlen = len(needle)
    if nlen == 0 { return 0 }
    while i + nlen <= hlen {
        if substring(hay, i, i + nlen) == needle {
            n = n + 1
            i = i + nlen
        } else {
            i = i + 1
        }
    }
    return n
}

fn _test_unroll_factor_n() -> bool {
    let mut ok = true

    // -- Sub-case A — factor=3 (2 clones, 3 total body iterations) -------
    let mfn_f3 = _nvptx_unroll_pass(_build_case_unroll_loop(), 3)
    let ptx_f3 = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn_f3))
    let mul_count_f3 = _count_substr(ptx_f3, "mul.f64")   // body has one mul.f64
    if mul_count_f3 != 3 {
        println("  FAIL: factor=3 expected 3× mul.f64, got " + to_string(mul_count_f3))
        ok = false
    } else {
        println("  ok: factor=3 → 3 body iterations (3× mul.f64)")
    }

    // -- Sub-case B — factor=4 (3 clones, 4 total body iterations) -------
    let mfn_f4 = _nvptx_unroll_pass(_build_case_unroll_loop(), 4)
    let ptx_f4 = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn_f4))
    let mul_count_f4 = _count_substr(ptx_f4, "mul.f64")
    if mul_count_f4 != 4 {
        println("  FAIL: factor=4 expected 4× mul.f64, got " + to_string(mul_count_f4))
        ok = false
    } else {
        println("  ok: factor=4 → 4 body iterations (4× mul.f64)")
    }

    // -- Sub-case C — factor=100 out-of-range → clamp to passthrough ----
    // (factor > _nvptx_unroll_max_factor returns mfn unchanged; PTX is
    // identical to running the pass with factor=1 i.e. no unroll.)
    let mfn_baseline = _build_case_unroll_loop()
    let mfn_f100 = _nvptx_unroll_pass(_build_case_unroll_loop(), 100)
    let ptx_baseline = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn_baseline))
    let ptx_f100 = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn_f100))
    if ptx_baseline != ptx_f100 {
        println("  FAIL: factor=100 (out-of-range) should be byte-identical to no-unroll baseline")
        ok = false
    } else {
        println("  ok: factor=100 → clamp passthrough (PTX byte-identical to baseline)")
    }

    // -- Sub-case D — factor=2 byte-eq with PR #117 (regression guard) --
    // PR #117 landed factor=2 as a single clone; RFC 069 P1 must keep
    // that path byte-identical (the generalized loop runs once for N=2,
    // so the output equals what PR #117 emitted).
    let mfn_f2 = _nvptx_unroll_pass(_build_case_unroll_loop(), 2)
    let ptx_f2 = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn_f2))
    let mul_count_f2 = _count_substr(ptx_f2, "mul.f64")
    if mul_count_f2 != 2 {
        println("  FAIL: factor=2 expected 2× mul.f64, got " + to_string(mul_count_f2))
        ok = false
    } else {
        println("  ok: factor=2 → 2 body iterations (PR #117 byte-eq regression guard)")
    }

    return ok
}

// _wrap_single_mfn — small helper. Wrap a single MFunc into an MModule
// so it goes through `codegen_emit_ptx_sm80` as a complete unit. The
// generic test fixtures only build MFunc-level objects; the emit pass
// takes MModule.
fn _wrap_single_mfn(mf: MFunc) -> MModule {
    let mut fns = []
    fns.push(mf)
    return MModule { file: "rfc069_factor_n_test.hexa", funcs: fns, globals: [] }
}

// ── Case 15 — RFC 068 P1 `F-RFC068-PRECISION-PROPAGATE` ───────────────
//
// Verifies that an explicit precision tag on a Local routes the classifier
// to the matching NVPTX_RKIND_* bank BEFORE the op-name rules apply. The
// HIR-side annotation propagation (`@f16 a + b` source grammar) is a
// follow-on cycle — this case exercises only the codegen-side read of
// `Local.precision`. Three sub-cases (.f16 / .bf16 / .f32) verify the
// new banks are reachable via the explicit tag.
//
// Honest scope (`@D g3`): this is the data-plumbing falsifier for P1.
// Real source-level `@f16` annotation grammar lands in a separate cycle.

fn _local_with_precision(id: i64, name: string, precision: string) -> Local {
    return Local {
        id: id,
        arena_id: 1,
        type_id: 0,
        name_hint: name,
        precision: precision
    }
}

fn _build_case_precision_propagate() -> MModule {
    // Two params (a, b) + three precision-tagged temps. The dst Locals
    // carry .f16/.bf16/.f32 tags; the op names are plain "add" so the
    // classifier's op-name rules DON'T fire — only the precision tag
    // does. This isolates the new behavior from #123's existing scaffold
    // (which routes via op-name "add_f16" etc.).
    let a = _local(0, "a")
    let b = _local(1, "b")
    let t_f16  = _local_with_precision(3, "t_f16",  ".f16")
    let t_bf16 = _local_with_precision(4, "t_bf16", ".bf16")
    let t_f32  = _local_with_precision(5, "t_f32",  ".f32")

    let mut s0 = []
    // Op name "add" (NOT "add_f16") — proves the precision-tag short-
    // circuit wins over the op-name rules.
    s0.push(_stmt_binop(t_f16,  "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_binop(t_bf16, "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_binop(t_f32,  "add", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(t_f16)
    locals.push(t_bf16)
    locals.push(t_f32)

    let mf = MFunc {
        name: "precision_propagate_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_precision_propagate.hexa", funcs: fns, globals: [] }
}

fn _test_precision_propagate() -> bool {
    let mut ok = true
    let mod_pp = _build_case_precision_propagate()
    let ptx = codegen_emit_ptx_sm80(mod_pp)

    println("")
    println("── emitted PTX (RFC 068 P1 precision-tag propagate, sm_80) ──")
    println(ptx)

    // The 3 explicit-tag Locals should declare in their respective banks.
    ok = _check(ok, ptx, ".reg .f16 %fh3",  "precision .f16 → .reg .f16 %fh3")
    ok = _check(ok, ptx, ".reg .bf16 %fb4", "precision .bf16 → .reg .bf16 %fb4")
    ok = _check(ok, ptx, ".reg .f32 %fs5",  "precision .f32 → .reg .f32 %fs5")
    // CRITICAL: the op name "add" (without _f16/_bf16/_f32 suffix) MUST
    // have produced these banks via the PRECISION-TAG path, NOT the
    // op-name rules. If the classifier had fallen through to F64 default
    // (op="add" → NVPTX_RKIND_F64), we'd see ".reg .f64 %fd<n>" instead.
    // The substring guard:
    if _contains(ptx, ".reg .f64 %fd3") || _contains(ptx, ".reg .f64 %fd4") || _contains(ptx, ".reg .f64 %fd5") {
        println("  FAIL: precision-tagged Locals fell through to F64 default — classifier short-circuit broken")
        ok = false
    } else {
        println("  ok: precision tag wins over op-name fallthrough (no .f64 for precision-tagged dsts)")
    }
    return ok
}

// ── Case 16 — RFC 067 P1 `F-RFC067-FRAG-WIDTH` ────────────────────────
//
// Verifies that a Local classified as NVPTX_RKIND_FRAG emits 8 PTX
// register declarations (`.reg .b32 %fra<id>_e0` .. `_e7`) per the
// NVIDIA canonical sm_80 m16n16k16 layout (256 elements / 32-thread
// warp = 8 32-bit-packed values per thread).
//
// Fixture: a one-block MFunc with STMT_CALL `gpu_wmma_load_a` whose
// dst is a real (non-miss) Local. The classifier routes the dst kind
// to NVPTX_RKIND_FRAG, and the reg-decl loop in `_emit_ptx_func` emits
// the 8-element vector form.
//
// Honest scope (`@D g3`): this is the reg-bank seam falsifier for P1.
// Body lowering (actual `wmma.load.a.sync...` PTX instruction emit)
// + `.shared` staging decl + per-fragment dtype/role are P2/P3.

fn _build_case_frag_width() -> MModule {
    // Dst of the gpu_wmma_load_a call — classifier sets kind=FRAG.
    let frag_dst = _local(7, "frag_a")

    let mut s0 = []
    // STMT_CALL with op=gpu_wmma_load_a and a real dst Local.
    s0.push(_stmt_call(frag_dst, "gpu_wmma_load_a"))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(frag_dst)

    let mf = MFunc {
        name: "frag_width_smoke",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_frag_width.hexa", funcs: fns, globals: [] }
}

fn _test_frag_width() -> bool {
    let mut ok = true
    let mod_fw = _build_case_frag_width()
    let ptx = codegen_emit_ptx_sm80(mod_fw)

    println("")
    println("── emitted PTX (RFC 067 P1 fragment-width = 8, sm_80) ──")
    println(ptx)

    // The fragment dst (id=7) should produce 8 `.reg .b32 %fra7_e<i>`
    // declarations, one per element of the canonical sm_80 m16n16k16
    // fragment layout.
    let mut ei = 0
    while ei < 8 {
        ok = _check(ok, ptx, ".reg .b32 %fra7_e" + to_string(ei),
            "fragment element %fra7_e" + to_string(ei) + " emitted")
        ei = ei + 1
    }
    // CRITICAL guard: the FRAG dst MUST NOT emit a single scalar `.reg
    // .f16 %fh7` (the PR #121 SCAFFOLD placeholder). If it did, the
    // P1 vector-emit path didn't fire.
    if _contains(ptx, ".reg .f16 %fh7") || _contains(ptx, ".reg .f64 %fd7") {
        println("  FAIL: FRAG dst fell back to scalar reg — P1 vector-emit path broken")
        ok = false
    } else {
        println("  ok: FRAG dst routed to vector emit (no scalar .reg fallback)")
    }
    return ok
}

// ── Case 17 — RFC 067 P2 `F-RFC067-SHARED-DECL` ───────────────────────
//
// Verifies that an MFunc containing a WMMA fragment (a callee_saved
// entry with kind=FRAG, produced when STMT_CALL gpu_wmma_load_a/_b/_mma
// runs through the classifier) emits a `.shared .align 16 .b8` staging
// declaration in the PTX function header. The slot-name carries the
// kernel name so multiple WMMA kernels in one module don't collide.
//
// Honest scope: P2 lands the staging-area decl. P3 will introduce
// per-fragment role + dtype tags so the staging-slot SIZE adapts to
// the fragment family (today: hard-coded 2048 B for the canonical
// f16×f16→f32 family).

fn _test_shared_decl() -> bool {
    let mut ok = true
    let mod_sd = _build_case_frag_width()      // re-uses the P1 fixture
    let ptx = codegen_emit_ptx_sm80(mod_sd)

    println("")
    println("── emitted PTX (RFC 067 P2 .shared staging, sm_80) ──")
    println(ptx)

    // The MFunc is named "frag_width_smoke" (from _build_case_frag_width).
    // The .shared decl uses the kernel basename (NVPTX_KERNEL_PREFIX
    // stripped if present; for non-kernel device fns the name is used
    // verbatim).
    ok = _check(ok, ptx, ".shared .align 16 .b8 _hexa_wmma_stage_frag_width_smoke[2048]",
        "`.shared` staging decl emitted with stable per-fn name")
    // Sanity: only ONE staging decl in this single-fn module.
    let n_shared = _count_substr(ptx, ".shared .align 16 .b8 _hexa_wmma_stage_")
    if n_shared != 1 {
        println("  FAIL: expected 1 staging decl, got " + to_string(n_shared))
        ok = false
    } else {
        println("  ok: single staging decl per WMMA-containing kernel")
    }
    // Negative guard: a non-WMMA MFunc must NOT emit a staging decl
    // (re-use the unroll fixture from PR #117 / RFC 069 P1 — no FRAG).
    let mod_no_wmma = _wrap_single_mfn(_build_case_unroll_loop())
    let ptx_no_wmma = codegen_emit_ptx_sm80(mod_no_wmma)
    if _contains(ptx_no_wmma, ".shared .align 16 .b8 _hexa_wmma_stage_") {
        println("  FAIL: non-WMMA kernel emitted spurious staging decl")
        ok = false
    } else {
        println("  ok: non-WMMA kernel emits zero staging decls (no false-positive)")
    }
    return ok
}

// ── Case 18 — RFC 069 P2 `F-RFC069-MULTI-EXIT-MATCH` ──────────────────
//
// Verifies the unroll pass accepts a body whose terminator is STMT_BR_COND
// (multi-exit / break-bearing body), not just STMT_BR (canonical
// single-exit). The cloner rewrites ONLY the back-edge arm per clone; the
// early-exit arm stays verbatim so each unrolled instance preserves its
// break path.
//
// CFG shape (3 blocks):
//   header (block 0): cond, BR_COND(body=1, exit=2)
//   body   (block 1): t = a + b
//                     early_cond = a < b
//                     BR_COND(exit=2, header=0)   # break path = "true" arm
//   exit   (block 2): return
//
// edge_kind on body terminator = "br_cond_else" (header is in the
// target_block_else slot). After unroll factor=3:
//   - body's else-arm → first_clone (header) becomes else-arm → block 3
//   - clone_1 (block 3): same shape, else-arm → block 4
//   - clone_2 (block 4): same shape, else-arm → header (back-edge)
//   - the TRUE arm of each (exit=2) stays untouched → break preserved.

fn _build_case_multi_exit_loop() -> MFunc {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let cond = _local(2, "cond")
    let t = _local(3, "t")
    let brk = _local(4, "brk")

    // block 0 (header): BR_COND(cond, body=1, exit=2)
    let mut s0 = []
    s0.push(_stmt_binop(cond, "lt", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_br_cond(_op_local(cond.id), 1, 2))

    // block 1 (body): t = a + b ; brk = a < b ; BR_COND(brk, exit=2, header=0)
    let mut s1 = []
    s1.push(_stmt_binop(t,   "add", _op_local(a.id), _op_local(b.id)))
    s1.push(_stmt_binop(brk, "lt",  _op_local(a.id), _op_local(b.id)))
    s1.push(_stmt_br_cond(_op_local(brk.id), 2, 0))   // true→exit, else→header

    // block 2 (exit): return
    let mut s2 = []
    s2.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))
    blocks.push(_block(2, s2))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(cond)
    locals.push(t)
    locals.push(brk)

    return MFunc {
        name: "multi_exit_loop_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
}

fn _test_multi_exit_match() -> bool {
    let mut ok = true

    // factor=3 unroll on multi-exit fixture.
    let mfn = _nvptx_unroll_pass(_build_case_multi_exit_loop(), 3)
    let ptx = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn))

    println("")
    println("── emitted PTX (RFC 069 P2 multi-exit factor=3, sm_80) ──")
    println(ptx)

    // Sub-case A — body iterations: 3× add.f64 + 3× setp.lt.f64.
    // Each clone replicates the full body (the binop + the break-cond
    // computation + the BR_COND).
    let add_count = _count_substr(ptx, "add.f64")
    if add_count != 3 {
        println("  FAIL: factor=3 expected 3× add.f64, got " + to_string(add_count))
        ok = false
    } else {
        println("  ok: factor=3 multi-exit → 3 body iterations (add.f64)")
    }
    let setp_count = _count_substr(ptx, "setp.lt.f64")
    // header has 1 setp, each body has 1 setp → 1 + 3 = 4
    if setp_count != 4 {
        println("  FAIL: factor=3 expected 4× setp.lt.f64 (1 header + 3 bodies), got " + to_string(setp_count))
        ok = false
    } else {
        println("  ok: 4 setp.lt.f64 (header + 3 body break-checks)")
    }

    // Sub-case B — early-exit (break) path PRESERVED per clone instance:
    // each of the 3 body instances must still BR_COND to exit (block 2).
    // PTX uses `bra $L_2` for the exit destination — count = 3 ×
    // (true-arm `bra $L_2`) + 1 (header's `bra $L_2` for exit-direct).
    // The exact bra count depends on emit lowering; rather than counting
    // we assert the LABEL $L_2 receives at least 3 incoming branches
    // by looking for "bra $L_2" occurrences.
    let bra2_count = _count_substr(ptx, "bra $L_2")
    if bra2_count < 3 {
        println("  FAIL: factor=3 expected ≥3 break-edges to $L_2, got " + to_string(bra2_count))
        ok = false
    } else {
        println("  ok: ≥3 break-edges to exit $L_2 (each clone preserves its break)")
    }

    // Sub-case C — passthrough on single-block (no loop) MFunc is
    // unchanged. Re-uses the FRAG-width fixture which has no back-edge.
    // RFC 069 F7 PASSTHROUGH-PRESERVED — strict regression gate.
    let mod_no_loop = _build_case_frag_width()
    let mfn_no_loop = mod_no_loop.funcs[0]
    let ptx_no_unroll = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn_no_loop))
    let ptx_unrolled  = codegen_emit_ptx_sm80(_wrap_single_mfn(_nvptx_unroll_pass(mfn_no_loop, 3)))
    if ptx_no_unroll != ptx_unrolled {
        println("  FAIL: passthrough broken — non-loop MFunc perturbed by unroll pass")
        ok = false
    } else {
        println("  ok: F7 PASSTHROUGH-PRESERVED — non-loop MFunc byte-identical")
    }

    return ok
}

// ── Case 19 — RFC 069 P3 `F-RFC069-NESTED-PRESERVE` ───────────────────
//
// Verifies that an MFunc carrying a nested-loop CFG triggers the
// unroll pass's early-return (P3 honest-preservation) — the MFunc
// is returned UNCHANGED so the inner loop is semantically intact.
//
// CFG shape (nested loop, canonical 5-block layout):
//   block 0 (outer header):  cond, BR_COND(body=1, exit=4)
//   block 1 (outer body):    setup, BR(inner_header=2)   ← BRANCHES INTO INNER
//   block 2 (inner header):  cond, BR_COND(inner_body=3, outer_header=0)
//   block 3 (inner body):    stmt, BR(inner_header=2)    ← inner back-edge
//   block 4 (exit):          return
//
// The pattern matcher finds (outer_header=0, body=1) as the outer
// loop seed. Block 1's terminator is BR(2) — that target (block 2,
// inner header) has a terminator BR_COND with target_block_else=0,
// pointing to a block with id (0) < its own id (2). This is the
// back-edge marker, so `_nvptx_unroll_contains_inner_loop` returns
// true and the unroll pass returns the MFunc unchanged.
//
// Honest scope: P3 lands DETECTION + EARLY-RETURN. Full nested
// unroll (multi-block-region cloning with renumbered inner-loop
// blocks per outer clone) is P5.

fn _build_case_nested_loop() -> MFunc {
    let a = _local(0, "a")
    let b = _local(1, "b")
    let oc = _local(2, "oc")    // outer cond
    let ic = _local(3, "ic")    // inner cond
    let t = _local(4, "t")

    // block 0 (outer header)
    let mut s0 = []
    s0.push(_stmt_binop(oc, "lt", _op_local(a.id), _op_local(b.id)))
    s0.push(_stmt_br_cond(_op_local(oc.id), 1, 4))

    // block 1 (outer body): just enter the inner loop
    let mut s1 = []
    s1.push(_stmt_br(2))

    // block 2 (inner header): BR_COND(inner_body=3, outer_header=0)
    let mut s2 = []
    s2.push(_stmt_binop(ic, "lt", _op_local(a.id), _op_local(b.id)))
    s2.push(_stmt_br_cond(_op_local(ic.id), 3, 0))

    // block 3 (inner body): stmt, BR(inner_header=2) → back-edge
    let mut s3 = []
    s3.push(_stmt_binop(t, "add", _op_local(a.id), _op_local(b.id)))
    s3.push(_stmt_br(2))

    // block 4 (exit)
    let mut s4 = []
    s4.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))
    blocks.push(_block(2, s2))
    blocks.push(_block(3, s3))
    blocks.push(_block(4, s4))

    let mut params = []
    params.push(a)
    params.push(b)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(oc)
    locals.push(ic)
    locals.push(t)

    return MFunc {
        name: "nested_loop_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
}

fn _test_nested_preserve() -> bool {
    let mut ok = true

    let baseline = _build_case_nested_loop()
    let after = _nvptx_unroll_pass(_build_case_nested_loop(), 4)

    let ptx_before = codegen_emit_ptx_sm80(_wrap_single_mfn(baseline))
    let ptx_after  = codegen_emit_ptx_sm80(_wrap_single_mfn(after))

    println("")
    println("── emitted PTX (RFC 069 P3 nested-preserve, baseline) ──")
    println(ptx_before)

    // Sub-case A — byte-eq guarantee: nested-loop MFunc is unchanged by
    // the unroll pass (factor=4 attempted; detection short-circuits).
    if ptx_before != ptx_after {
        println("  FAIL: nested-loop MFunc was perturbed by unroll pass (P3 detection broken)")
        ok = false
    } else {
        println("  ok: P3 nested-preserve — unroll(nested, 4) byte-identical to baseline")
    }

    // Sub-case B — inner loop's PTX SIGNATURE present (setp.lt.f64 +
    // bra) confirming the inner loop survived the pass.
    let setp_count = _count_substr(ptx_after, "setp.lt.f64")
    if setp_count < 2 {
        println("  FAIL: expected ≥2 setp.lt.f64 (outer + inner header), got " + to_string(setp_count))
        ok = false
    } else {
        println("  ok: inner+outer loop conditions intact (" + to_string(setp_count) + "× setp.lt.f64)")
    }
    let bra_count = _count_substr(ptx_after, "bra ")
    if bra_count < 3 {
        println("  FAIL: expected ≥3 bra instructions (inner back-edge + others), got " + to_string(bra_count))
        ok = false
    } else {
        println("  ok: inner back-edge + branches preserved (" + to_string(bra_count) + "× bra)")
    }

    // Sub-case C — direct helper assertion: `_nvptx_unroll_contains_inner_loop`
    // returns true for the body block of this MFunc, false for the
    // non-nested fixture from PR #117 Case 10.
    let nested = _build_case_nested_loop()
    let body_nested = nested.blocks[1]   // block 1 = outer body
    if !_nvptx_unroll_contains_inner_loop(body_nested, nested) {
        println("  FAIL: detection helper missed nested-loop body")
        ok = false
    } else {
        println("  ok: _nvptx_unroll_contains_inner_loop(nested.body) = true")
    }
    // Negative guard: PR #117 fixture (canonical single-loop) has no
    // inner loop in its body.
    let canonical = _build_case_unroll_loop()
    // Locate the body block in canonical fixture via the pattern matcher.
    let pat = _nvptx_unroll_find_pattern(canonical)
    if pat[1] >= 0 {
        let body_canonical = canonical.blocks[pat[1]]
        if _nvptx_unroll_contains_inner_loop(body_canonical, canonical) {
            println("  FAIL: detection helper false-positive on PR #117 canonical fixture")
            ok = false
        } else {
            println("  ok: _nvptx_unroll_contains_inner_loop(canonical.body) = false (no false-positive)")
        }
    }

    return ok
}

// ── Case 20 — RFC 068 P2 `F-RFC068-OPCODE-SUFFIX` ─────────────────────
//
// Verifies that an f16/bf16/f32-typed HIR binop propagates its precision
// onto the resulting MIR STMT_BINOP — both as the dst Local's
// `precision` tag (P1, already landed via PR #148) AND as the op-name
// suffix (P2, this commit). The classifier's existing op-name rules
// (`add_f16` → NVPTX_RKIND_F16, PR #123) and precision-tag short-
// circuit (PR #148) BOTH route the dst to the matching reg bank, so
// the emitted PTX shows the `.reg .f16 / .bf16 / .f32` declaration.
//
// Honest scope (`@D g3`): P2 closure does NOT enable body lowering
// (`add.f16 %fh<dst>, %fh<a>, %fh<b>` instruction emit) — that's P3.
// P2 ONLY threads source-level type → MIR opcode + precision tag.
// The body still emits the 055-P0-style "unsupported binop" stub.

// HIR builders local to Case 20 (distinct from Case 15's MIR `_block`).
fn _hir_span() -> Span {
    return Span { file: "", line: 0, col: 0, len: 0 }
}

fn _hir_def() -> DefId { return DefId { module: "", index: -1 } }

fn _hir_atlas_binding() -> AtlasBinding {
    return AtlasBinding { ref_kind: "", id: "", atlas_index: -1, atlas_hash: "" }
}

fn _hir_t(kind: string) -> Type {
    return Type {
        kind: kind, def: _hir_def(),
        args: [], ret: [],
        domain: "", unit: ""
    }
}

fn _hir_node(kind: string, typ: Type, text: string, kids: [HExpr]) -> HExpr {
    return HExpr {
        kind: kind,
        span: _hir_span(),
        typ: typ,
        text: text,
        children: kids,
        atlas: _hir_atlas_binding(),
        def: _hir_def()
    }
}

fn _hir_ident(name: string, typ: Type) -> HExpr {
    return _hir_node("ident", typ, name, [])
}

fn _hir_binop(op: string, lhs: HExpr, rhs: HExpr, typ: Type) -> HExpr {
    let mut k = []
    k.push(lhs)
    k.push(rhs)
    return _hir_node("binop", typ, op, k)
}

fn _hir_ret(value: HExpr) -> HExpr {
    let mut k = []
    k.push(value)
    return _hir_node("return", _hir_t("unit"), "", k)
}

fn _hir_blk(kids: [HExpr]) -> HExpr {
    return _hir_node("block", _hir_t("unit"), "", kids)
}

fn _hir_fn(name: string, pnames: [string], ptypes: [Type], ret: Type, body: HExpr) -> HItem {
    let mut anns: [Annotation] = []
    let mut name_args: [Expr] = []
    let mut p = 0
    while p < len(pnames) {
        name_args.push(Expr {
            kind: ExprKind::Ident,
            span: _hir_span(),
            text: pnames[p],
            children: [],
            atlas_ref: AtlasRef { kind: "", id: "", span: _hir_span() }
        })
        p = p + 1
    }
    anns.push(Annotation { name: "param_names", args: name_args, span: _hir_span() })
    return HItem {
        kind: "ITEM_FN",
        def: _hir_def(),
        name: name,
        span: _hir_span(),
        annotations: anns,
        sig_params: ptypes,
        sig_return: ret,
        body: body,
        is_pub: false,
        discoverable: false,
        proof_hash: "",
        verifier_version: ""
    }
}

// Build a single-fn HModule: fn f(a: <dtype>, b: <dtype>) -> <dtype> { return a + b }
fn _build_case_opcode_suffix_one(dtype_kind: string) -> HModule {
    let t = _hir_t(dtype_kind)
    let a = _hir_ident("a", t)
    let b = _hir_ident("b", t)
    let plus = _hir_binop("+", a, b, t)
    let body = _hir_blk([_hir_ret(plus)])
    let mut pn: [string] = []
    pn.push("a")
    pn.push("b")
    let mut pt: [Type] = []
    pt.push(t)
    pt.push(t)
    let it = _hir_fn("op_suffix_" + dtype_kind, pn, pt, t, body)
    let mut items: [HItem] = []
    items.push(it)
    return HModule { file: "case_op_suffix_" + dtype_kind + ".hexa", items: items }
}

// Walk the MModule and find the first STMT_BINOP — return its op string +
// dst.precision tag. Empty string means "not found".
fn _find_first_binop_op(m: MModule) -> string {
    let mut fi = 0
    while fi < len(m.funcs) {
        let mf = m.funcs[fi]
        let mut bi = 0
        while bi < len(mf.blocks) {
            let b = mf.blocks[bi]
            let mut si = 0
            while si < len(b.stmts) {
                let s = b.stmts[si]
                if s.kind == STMT_BINOP { return s.op }
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return ""
}

fn _find_first_binop_precision(m: MModule) -> string {
    let mut fi = 0
    while fi < len(m.funcs) {
        let mf = m.funcs[fi]
        let mut bi = 0
        while bi < len(mf.blocks) {
            let b = mf.blocks[bi]
            let mut si = 0
            while si < len(b.stmts) {
                let s = b.stmts[si]
                if s.kind == STMT_BINOP { return s.dst.precision }
                si = si + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }
    return ""
}

fn _check_eq_str(ok_in: bool, got: string, want: string, label: string) -> bool {
    if got == want { return ok_in }
    println("  FAIL: " + label + " — got `" + got + "`, want `" + want + "`")
    return false
}

fn _test_opcode_suffix() -> bool {
    let mut ok = true

    // Sub-case A — f16 typed binop → op "add_f16" + precision ".f16".
    let m_f16 = lower_hir(_build_case_opcode_suffix_one("f16"))
    let op_f16 = _find_first_binop_op(m_f16)
    let pr_f16 = _find_first_binop_precision(m_f16)
    println("")
    println("── RFC 068 P2 F-RFC068-OPCODE-SUFFIX (f16) ──")
    println("  lowered first-binop op       = `" + op_f16 + "`")
    println("  lowered first-binop dst.prec = `" + pr_f16 + "`")
    ok = _check_eq_str(ok, op_f16, "add_f16", "f16 binop op suffix")
    ok = _check_eq_str(ok, pr_f16, ".f16",   "f16 binop dst.precision tag")

    // Sub-case B — bf16 typed binop → op "add_bf16" + precision ".bf16".
    let m_bf16 = lower_hir(_build_case_opcode_suffix_one("bf16"))
    let op_bf16 = _find_first_binop_op(m_bf16)
    let pr_bf16 = _find_first_binop_precision(m_bf16)
    println("── RFC 068 P2 F-RFC068-OPCODE-SUFFIX (bf16) ──")
    println("  lowered first-binop op       = `" + op_bf16 + "`")
    println("  lowered first-binop dst.prec = `" + pr_bf16 + "`")
    ok = _check_eq_str(ok, op_bf16, "add_bf16", "bf16 binop op suffix")
    ok = _check_eq_str(ok, pr_bf16, ".bf16",    "bf16 binop dst.precision tag")

    // Sub-case C — f32 typed binop → op "add_f32" + precision ".f32".
    let m_f32 = lower_hir(_build_case_opcode_suffix_one("f32"))
    let op_f32 = _find_first_binop_op(m_f32)
    let pr_f32 = _find_first_binop_precision(m_f32)
    println("── RFC 068 P2 F-RFC068-OPCODE-SUFFIX (f32) ──")
    println("  lowered first-binop op       = `" + op_f32 + "`")
    println("  lowered first-binop dst.prec = `" + pr_f32 + "`")
    ok = _check_eq_str(ok, op_f32, "add_f32", "f32 binop op suffix")
    ok = _check_eq_str(ok, pr_f32, ".f32",    "f32 binop dst.precision tag")

    // Sub-case D — f64 byte-eq guard: plain `add`, empty precision.
    // The classifier-driven default path stays unchanged (precision-tag
    // short-circuit is "" → falls through to op-name rules → falls
    // through to F64 default). This protects the F-RFC068-OPCODE-
    // SUFFIX honest scope: P2 ONLY perturbs f16/bf16/f32 binops.
    let m_f64 = lower_hir(_build_case_opcode_suffix_one("f64"))
    let op_f64 = _find_first_binop_op(m_f64)
    let pr_f64 = _find_first_binop_precision(m_f64)
    println("── RFC 068 P2 F-RFC068-OPCODE-SUFFIX (f64 byte-eq guard) ──")
    println("  lowered first-binop op       = `" + op_f64 + "`")
    println("  lowered first-binop dst.prec = `" + pr_f64 + "`")
    ok = _check_eq_str(ok, op_f64, "+", "f64 binop op stays plain `+` (frontend symbol, byte-eq)")
    ok = _check_eq_str(ok, pr_f64, "", "f64 binop dst.precision empty (classifier-default fallback)")

    // Sub-case E — end-to-end: f16 lowering → PTX → .reg .f16 bank.
    // Wires P1 + P2 + the codegen reg-bank routing together. The body
    // text is still the P0-stub (P3 will emit `add.f16`), but the bank
    // decl proves the precision tag flows all the way through.
    //
    // We have to convert the f16 lowered module to a GPU-eligible
    // MFunc (gpu_kind = GPU_KIND_DEVICE) so `_nvptx_codegen` includes
    // it. The synthetic HIR doesn't carry an @gpu_device annotation,
    // so the resulting MFunc has gpu_kind = 0. Re-wrap the first MFunc
    // with gpu_kind = GPU_KIND_DEVICE for the PTX emission only.
    let mfn_f16 = m_f16.funcs[0]
    let mfn_f16_gpu = MFunc {
        name: mfn_f16.name,
        params: mfn_f16.params,
        return_local: mfn_f16.return_local,
        locals: mfn_f16.locals,
        blocks: mfn_f16.blocks,
        entry_block: mfn_f16.entry_block,
        arena_root: mfn_f16.arena_root,
        def_line: mfn_f16.def_line,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut gpu_funcs = []
    gpu_funcs.push(mfn_f16_gpu)
    let mod_gpu = MModule { file: mfn_f16.name + ".gpu", funcs: gpu_funcs, globals: [] }
    let ptx_f16 = codegen_emit_ptx_sm80(mod_gpu)
    println("── emitted PTX (RFC 068 P2 f16 end-to-end, sm_80) ──")
    println(ptx_f16)
    // The dst Local of the f16 binop carries precision=".f16" — the
    // classifier short-circuits to NVPTX_RKIND_F16 → `%fh<id>` reg name
    // + `.reg .f16` bank decl. Specific id depends on local-numbering;
    // assert the bank-decl prefix appears.
    ok = _check(ok, ptx_f16, ".reg .f16 %fh", "f16 reg bank declared (end-to-end P1+P2)")
    return ok
}

// ── Case 21 — RFC 067 P3 `F-RFC067-DTYPE-FAMILY` ──────────────────────
//
// Verifies that the new `_nvptx_wmma_mnemonic_family(op, role, dtype,
// layout)` re-keyed mnemonic table resolves the correct PTX wmma mnemonic
// for three canonical sm_80 m16n16k16 fragment families per NVIDIA PTX
// ISA §9.7.13.4:
//
//   (1) canonical f16×f16→f32  (role=*, dtype=.f16/.f32, layout=.row/.col)
//   (2) bf16×bf16→f32          (role=*, dtype=.bf16/.f32, layout=.row/.col)
//   (3) f16×f16→f16            (role=d,  dtype=.f16,      layout=.row)
//
// Honest scope (@D g3): this test exercises the METADATA-ATTACHING and
// MNEMONIC-RE-KEYING seams only. The PReg roster carries the new
// frag_role/frag_dtype/frag_layout fields, and the re-keyed mnemonic
// helper resolves family-specific PTX strings — but the lowering site
// in `_nvptx_lower_stmt` still emits the SCAFFOLD comment, NOT a real
// `wmma.mma.sync...` instruction. Real wmma instruction-emit (referencing
// the FRAG vector regs + .shared slot via the family-aware mnemonic)
// is a follow-on cycle. NO GPU FIRE.
//
// Sub-case A — pure mnemonic-helper assertions on three families
// (verifies `_nvptx_wmma_mnemonic_family` table correctness).
//
// Sub-case B — fixture-based PReg metadata round-trip: synthesize a
// FRAG-classified Local via STMT_CALL gpu_wmma_load_a/_b/_mma and
// verify the classifier stamps the expected role/dtype/layout on the
// emitted PReg.

fn _test_dtype_family() -> bool {
    let mut ok = true

    println("")
    println("── RFC 067 P3 F-RFC067-DTYPE-FAMILY (mnemonic + metadata seams, sm_80) ──")

    // ─── Sub-case A — mnemonic-helper assertions (3 families) ────────────

    // Family 1 — canonical f16×f16→f32 (default empty inputs → backward-
    // compat fallthrough to PR #150's `_nvptx_wmma_mnemonic`).
    let mnem_canonical = _nvptx_wmma_mnemonic_family("gpu_wmma_mma", "", "", "")
    let expect_canonical = "wmma.mma.sync.aligned.row.col.m16n16k16.f32.f32"
    if mnem_canonical != expect_canonical {
        println("  FAIL: canonical f16×f16→f32 family mnemonic mismatch")
        println("        got:  " + mnem_canonical)
        println("        want: " + expect_canonical)
        ok = false
    } else {
        println("  ok: canonical f16xf16 -> f32  -> " + mnem_canonical)
    }

    // Family 2 — bf16×bf16→f32 (dtype=.bf16 routes to the bf16 table).
    let mnem_bf16 = _nvptx_wmma_mnemonic_family("gpu_wmma_mma", "d", ".bf16", ".row")
    let expect_bf16 = "wmma.mma.sync.aligned.row.col.m16n16k16.f32.bf16.bf16.f32"
    if mnem_bf16 != expect_bf16 {
        println("  FAIL: bf16xbf16 -> f32 family mnemonic mismatch")
        println("        got:  " + mnem_bf16)
        println("        want: " + expect_bf16)
        ok = false
    } else {
        println("  ok: bf16xbf16 -> f32     -> " + mnem_bf16)
    }

    // Family 3 — f16×f16→f16 (dtype=.f16 + role=d routes to the f16-acc
    // mma instruction; verifies the role discriminator on _mma).
    let mnem_f16acc = _nvptx_wmma_mnemonic_family("gpu_wmma_mma", "d", ".f16", ".row")
    let expect_f16acc = "wmma.mma.sync.aligned.row.col.m16n16k16.f16.f16"
    if mnem_f16acc != expect_f16acc {
        println("  FAIL: f16xf16 -> f16 family mnemonic mismatch")
        println("        got:  " + mnem_f16acc)
        println("        want: " + expect_f16acc)
        ok = false
    } else {
        println("  ok: f16xf16 -> f16       -> " + mnem_f16acc)
    }

    // ─── Sub-case A2 — integer div/rem mnemonics (N71-C) ───────────────
    // Integer `/` and `%` on a u32/u64 dst bank must resolve to signed
    // integer PTX (`div.s32`/`div.s64`/`rem.s32`/`rem.s64`), NOT fall
    // through to the FP64 `div.rn.f64` (ptxas-illegal on int regs).
    let int_cases = [
        ["div", NVPTX_RKIND_U32, "div.s32"],
        ["/",   NVPTX_RKIND_U32, "div.s32"],
        ["rem", NVPTX_RKIND_U32, "rem.s32"],
        ["div", NVPTX_RKIND_U64, "div.s64"],
        ["%",   NVPTX_RKIND_U64, "rem.s64"],
        // bitwise/shift (same fall-through-to-FP64 risk as div had)
        ["&",   NVPTX_RKIND_U32, "and.b32"],
        ["|",   NVPTX_RKIND_U32, "or.b32"],
        ["^",   NVPTX_RKIND_U32, "xor.b32"],
        ["<<",  NVPTX_RKIND_U32, "shl.b32"],
        [">>",  NVPTX_RKIND_U32, "shr.s32"],
        ["&",   NVPTX_RKIND_U64, "and.b64"],
        ["|",   NVPTX_RKIND_U64, "or.b64"],
        ["^",   NVPTX_RKIND_U64, "xor.b64"],
        ["<<",  NVPTX_RKIND_U64, "shl.b64"],
        [">>",  NVPTX_RKIND_U64, "shr.s64"],
    ]
    for c in int_cases {
        let got = _nvptx_binop_mnemonic_for_kind(c[0], c[1])
        if got != c[2] {
            println("  FAIL: int binop " + c[0] + " on " + c[1] + " → got `" + got + "` want `" + c[2] + "`")
            ok = false
        } else {
            println("  ok: int " + c[0] + " (" + c[1] + ") -> " + got)
        }
    }

    // ─── Sub-case A3 — FP32 division mnemonic ──────────────────────────
    // `div_f32` (from hir_to_mir `_op_with_precision`) → `div.rn.f32`
    // (the "future codegen-side div row"). f16/bf16 div has no native PTX
    // mnemonic → honest "" stub (SAFE, not a wrong-mnemonic miscompile).
    let div_f32 = _nvptx_binop_mnemonic("div_f32")
    if div_f32 != "div.rn.f32" { println("  FAIL: div_f32 → `" + div_f32 + "` want `div.rn.f32`"); ok = false }
    else { println("  ok: fp div_f32 -> div.rn.f32") }
    let div_f16 = _nvptx_binop_mnemonic("div_f16")
    if div_f16 != "" { println("  FAIL: div_f16 should be honest-stub (no native PTX f16 div), got `" + div_f16 + "`"); ok = false }
    else { println("  ok: fp div_f16 -> honest stub (no native mnemonic)") }

    // ─── Sub-case B — PReg metadata round-trip via classifier ──────────

    // Synthesize an MFunc whose first STMT_CALL is gpu_wmma_load_a so the
    // classifier sees the op-name + stamps the metadata on its PReg.
    let frag_a = _local(10, "frag_a")
    let frag_b = _local(11, "frag_b")
    let frag_d = _local(12, "frag_d")

    let mut s0 = []
    s0.push(_stmt_call(frag_a, "gpu_wmma_load_a"))
    s0.push(_stmt_call(frag_b, "gpu_wmma_load_b"))
    s0.push(_stmt_call(frag_d, "gpu_wmma_mma"))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(frag_a)
    locals.push(frag_b)
    locals.push(frag_d)

    let mfn_meta = MFunc {
        name: "dtype_family_meta",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }

    let regs = _nvptx_classify_locals(mfn_meta)

    // Scan the roster for the three FRAG entries; verify each carries
    // the expected role/dtype/layout per `_nvptx_frag_{role,dtype,layout}_for_op`.
    let mut found_a = false
    let mut found_b = false
    let mut found_d = false
    let mut ri = 0
    while ri < len(regs) {
        let r = regs[ri]
        if r.kind == NVPTX_RKIND_FRAG {
            if r.frag_role == "a" && r.frag_dtype == ".f16" && r.frag_layout == ".row" {
                found_a = true
            }
            if r.frag_role == "b" && r.frag_dtype == ".f16" && r.frag_layout == ".col" {
                found_b = true
            }
            if r.frag_role == "d" && r.frag_dtype == ".f32" && r.frag_layout == ".row" {
                found_d = true
            }
        }
        ri = ri + 1
    }
    if !found_a {
        println("  FAIL: gpu_wmma_load_a FRAG metadata mismatch — expected role=a dtype=.f16 layout=.row")
        ok = false
    } else {
        println("  ok: gpu_wmma_load_a -> role=a, dtype=.f16, layout=.row")
    }
    if !found_b {
        println("  FAIL: gpu_wmma_load_b FRAG metadata mismatch — expected role=b dtype=.f16 layout=.col")
        ok = false
    } else {
        println("  ok: gpu_wmma_load_b -> role=b, dtype=.f16, layout=.col")
    }
    if !found_d {
        println("  FAIL: gpu_wmma_mma FRAG metadata mismatch — expected role=d dtype=.f32 layout=.row")
        ok = false
    } else {
        println("  ok: gpu_wmma_mma    -> role=d, dtype=.f32, layout=.row")
    }

    // Non-FRAG PReg sanity — a F64 binop's roster entry must keep all
    // three metadata fields empty (no leakage from the wmma fragments).
    let scalar = _local(20, "scalar")
    let a = _local(21, "a")
    let b = _local(22, "b")
    let mut s_scalar = []
    s_scalar.push(_stmt_binop(scalar, "add", _op_local(a.id), _op_local(b.id)))
    s_scalar.push(_stmt_return())
    let mut sb = []
    sb.push(_block(0, s_scalar))
    let mut sl = []
    sl.push(a)
    sl.push(b)
    sl.push(scalar)
    let mfn_scalar = MFunc {
        name: "dtype_family_scalar",
        params: [],
        return_local: _miss_local(),
        locals: sl,
        blocks: sb,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let scalar_regs = _nvptx_classify_locals(mfn_scalar)
    let mut leaked = false
    let mut si = 0
    while si < len(scalar_regs) {
        let r = scalar_regs[si]
        if r.frag_role != "" || r.frag_dtype != "" || r.frag_layout != "" {
            leaked = true
        }
        si = si + 1
    }
    if leaked {
        println("  FAIL: non-FRAG PReg leaked frag_* metadata — default-empty invariant broken")
        ok = false
    } else {
        println("  ok: non-FRAG PRegs keep frag_* = \"\" (default invariant)")
    }

    return ok
}

// ── Case 22 — RFC 068 P3 `F-RFC068-BODY-MNEMONIC` ─────────────────────
//
// Verifies that STMT_BINOP `add_f16/_bf16/_f32` opcodes emit real
// PTX `add.f16/.bf16/.f32` body instructions (not the "unsupported
// binop" stub the P1+P2-only path produced).
//
// Re-uses Case 13's mixed-precision fixture (3 binops with op-name
// suffixes already emitted by the classifier op-name rules from
// PR #123 + PR #170). The new P3 mnemonic dispatch makes the BODY
// also emit correctly.

fn _test_body_mnemonic() -> bool {
    let mut ok = true
    let mod_mp = _build_case_mixed_precision_scaffold()   // re-use Case 13
    let ptx = codegen_emit_ptx_sm80(mod_mp)

    println("")
    println("── emitted PTX (RFC 068 P3 body-mnemonic, sm_80) ──")
    println(ptx)

    // Body must now contain the real PTX mnemonics — NOT the stub.
    ok = _check(ok, ptx, "add.f16 ",  "add.f16 body mnemonic emitted")
    ok = _check(ok, ptx, "add.bf16 ", "add.bf16 body mnemonic emitted")
    ok = _check(ok, ptx, "add.f32 ",  "add.f32 body mnemonic emitted")
    // Negative guard — the old "unsupported binop" stub for these ops
    // MUST NOT appear (would mean the P3 dispatch didn't fire).
    if _contains(ptx, "unsupported binop: add_f16") ||
       _contains(ptx, "unsupported binop: add_bf16") ||
       _contains(ptx, "unsupported binop: add_f32") {
        println("  FAIL: P3 mnemonic dispatch didn't fire — body still stub")
        ok = false
    } else {
        println("  ok: no stub fallthrough for add_f16/_bf16/_f32 (P3 dispatch live)")
    }
    return ok
}

// ── Case 23 — RFC 067 wmma INSTR-EMIT (post-scaffold) ─────────────────
//
// Verifies the full WMMA emit path lands real PTX instructions for all
// 4 op-names (gpu_wmma_load_a/_b/_mma/_store_c). Each is asserted via
// its canonical PTX mnemonic prefix + operand-tuple `_e0,` substring.

fn _build_case_wmma_full() -> MModule {
    let frag_a = _local(7, "fa")
    let frag_b = _local(8, "fb")
    let frag_d = _local(9, "fd")

    let mut s0 = []
    // gpu_wmma_load_a → load into frag_a (FRAG kind)
    s0.push(_stmt_call(frag_a, "gpu_wmma_load_a"))
    // gpu_wmma_load_b → load into frag_b (FRAG kind)
    s0.push(_stmt_call(frag_b, "gpu_wmma_load_b"))
    // gpu_wmma_mma → frag_d = mma(frag_a, frag_b, <c>). With s.args
    // empty in this fixture, the placeholder operand tuples appear.
    s0.push(_stmt_call(frag_d, "gpu_wmma_mma"))
    // gpu_wmma_store_c → store. Dst is _miss (void).
    s0.push(_stmt_call(_miss_local(), "gpu_wmma_store_c"))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut locals = []
    locals.push(frag_a)
    locals.push(frag_b)
    locals.push(frag_d)

    let mf = MFunc {
        name: "wmma_full_smoke",
        params: [],
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_wmma_full.hexa", funcs: fns, globals: [] }
}

fn _test_wmma_instr_emit() -> bool {
    let mut ok = true
    let mod_w = _build_case_wmma_full()
    let ptx = codegen_emit_ptx_sm80(mod_w)

    println("")
    println("── emitted PTX (RFC 067 WMMA full 4-op emit, sm_80) ──")
    println(ptx)

    // 4 real PTX wmma mnemonics emit.
    ok = _check(ok, ptx, "wmma.load.a.sync.aligned.row.m16n16k16.shared.f16",
        "wmma.load.a real instr (ptxas-legal state-space.type order)")
    ok = _check(ok, ptx, "wmma.load.b.sync.aligned.col.m16n16k16.shared.f16",
        "wmma.load.b real instr (ptxas-legal state-space.type order)")
    ok = _check(ok, ptx, "wmma.mma.sync.aligned.row.col.m16n16k16.f32.f32",
        "wmma.mma real instr (ptxas-legal short f16 form)")
    ok = _check(ok, ptx, "wmma.store.d.sync.aligned.row.m16n16k16.shared.f32",
        "wmma.store.d real instr (ptxas-legal state-space.type order)")
    // Per-op staging offsets (proves the lowering threads them
    // correctly).
    ok = _check(ok, ptx, "[_hexa_wmma_stage+0]",    "load.a staging offset 0")
    ok = _check(ok, ptx, "[_hexa_wmma_stage+512]",  "load.b staging offset 512")
    ok = _check(ok, ptx, "[_hexa_wmma_stage+1024]", "store.d staging offset 1024")
    // Fragment operand tuple — each FRAG dst expands to 8 elements.
    ok = _check(ok, ptx, "%fra7_e0",  "frag_a element 0 reachable")
    ok = _check(ok, ptx, "%fra7_e7",  "frag_a element 7 reachable")
    ok = _check(ok, ptx, "%fra8_e0",  "frag_b element 0 reachable")
    ok = _check(ok, ptx, "%fra9_e0",  "frag_d (mma dst) element 0 reachable")
    // Negative guard — no stub comment leakage.
    if _contains(ptx, "WMMA (scaffold, not yet wired)") {
        println("  FAIL: stub comment leaked — instr-emit didn't fire")
        ok = false
    } else {
        println("  ok: no scaffold-stub leak across all 4 op-names")
    }
    return ok
}

// ── Case 24 — RFC 069 wiring + GEMM K-loop fixture ────────────────────
//
// Verifies the RFC 069 wiring path: a GEMM-K-loop-shaped MIR with the
// canonical 3-block back-edge passes through `codegen_emit_ptx_sm80`
// AND the matcher recognises it. With env unset (HEXA_NVPTX_UNROLL_FACTOR
// not set or = 1), the wiring is passthrough — emitted PTX has 1× the
// K-loop body. The presence of the K-loop body in the emitted PTX
// (one `add.f64` for the accumulator chain) proves the lowering path
// integrates with the unroll-pass seam without disturbing default emit.
//
// To exercise the WIRED unroll path: set HEXA_NVPTX_UNROLL_FACTOR=N in
// the environment when invoking the test binary. The codegen will then
// apply `_nvptx_unroll_pass(mfn, N)` per GPU MFunc; canonical-loop
// fixtures see N× their body, multi-exit fixtures see N× with
// preserved early-exit arms, nested-loop fixtures pass through
// unchanged (RFC 069 P3 detection).
//
// Honest scope: Case 24 only verifies the codegen-side WIRING and a
// GEMM-K-loop-shaped MIR fixture's recognition. The real-silicon
// numeric falsifier F4 (`F-RFC069-NUMERIC-EQ`) remains a separate
// cycle requiring ubu-2 toolchain bootstrap + ptxas + driver JIT.

fn _build_case_gemm_k_loop() -> MFunc {
    // Canonical 3-block GEMM K-loop:
    //   block 0 (k-header):    k < K ? body=1 : exit=2
    //   block 1 (k-body):       acc = acc + a*b ; BR(header=0)
    //   block 2 (k-exit):       return
    //
    // Matches the matcher's canonical 3-block back-edge pattern, so
    // env-gated unroll will fire when set.
    let k     = _local(0, "k")
    let kmax  = _local(1, "kmax")
    let cond  = _local(2, "cond")
    let acc   = _local(3, "acc")
    let a_val = _local(4, "a_val")
    let b_val = _local(5, "b_val")
    let prod  = _local(6, "prod")

    // block 0 — header (cond)
    let mut s0 = []
    s0.push(_stmt_binop(cond, "lt", _op_local(k.id), _op_local(kmax.id)))
    s0.push(_stmt_br_cond(_op_local(cond.id), 1, 2))

    // block 1 — body (acc += a*b)
    let mut s1 = []
    s1.push(_stmt_binop(prod, "mul", _op_local(a_val.id), _op_local(b_val.id)))
    s1.push(_stmt_binop(acc,  "add", _op_local(acc.id),   _op_local(prod.id)))
    s1.push(_stmt_br(0))   // back-edge to header

    // block 2 — exit
    let mut s2 = []
    s2.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))
    blocks.push(_block(2, s2))

    let mut params = []
    params.push(kmax)
    params.push(a_val)
    params.push(b_val)
    let mut locals = []
    locals.push(k)
    locals.push(kmax)
    locals.push(cond)
    locals.push(acc)
    locals.push(a_val)
    locals.push(b_val)
    locals.push(prod)

    return MFunc {
        name: "gemm_k_loop_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
}

fn _test_gemm_k_loop_wiring() -> bool {
    let mut ok = true
    let mfn = _build_case_gemm_k_loop()
    let ptx = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn))

    println("")
    println("── emitted PTX (RFC 069 wiring — GEMM K-loop fixture, sm_80) ──")
    println(ptx)

    // Default-env passthrough: the matcher recognises the canonical
    // 3-block shape but factor=1 → passthrough. PTX has the K-loop
    // body with one `mul.f64` + one `add.f64` instruction.
    ok = _check(ok, ptx, "mul.f64", "K-loop body mul.f64 emitted")
    ok = _check(ok, ptx, "add.f64", "K-loop body add.f64 emitted")
    // The pattern matcher itself works (verified independently — feeds
    // the wiring's potential). The fixture's CFG shape is matchable.
    let pat = _nvptx_unroll_find_pattern(_build_case_gemm_k_loop())
    if pat[0] < 0 || pat[1] < 0 {
        println("  FAIL: _nvptx_unroll_find_pattern missed the GEMM K-loop shape")
        ok = false
    } else {
        println("  ok: matcher recognises GEMM K-loop (header=" + to_string(pat[0]) + ", body=" + to_string(pat[1]) + ")")
    }
    // Wiring presence — the env-reader helper exists and returns 1 by
    // default (passthrough). Asserted by code-path reachability.
    let f = _nvptx_codegen_read_unroll_factor()
    if f != 1 {
        // Could happen if env is set externally. Just inform.
        println("  note: HEXA_NVPTX_UNROLL_FACTOR is set in env → factor=" + to_string(f))
    } else {
        println("  ok: env unset → factor=1 (default passthrough)")
    }
    return ok
}

// ── Case 25 — RFC 068 P4 f16 ld.global / st.global mnemonic ──────────
//
// Verifies that STMT_LOAD / STMT_STORE emit the correct
// `ld.global.<ty>` / `st.global.<ty>` mnemonic based on the dst (load)
// or source-value (store) Local's classified kind.
//
// Fixture: 1-block MFunc with a single LOAD into an f16-tagged Local
// + a single STORE from another f16-tagged Local. Negative guards:
// the f64 mnemonics must NOT appear for these ops.

fn _build_case_f16_ld_st() -> MFunc {
    // Address local (u64) — caller-provided addr.
    let addr_a = _local_with_precision(10, "addr_a", "")
    let addr_c = _local_with_precision(11, "addr_c", "")
    // Value locals carry precision=".f16" → classifier short-circuits
    // to NVPTX_RKIND_F16.
    let val_loaded = _local_with_precision(12, "v_in",  ".f16")
    let val_to_store = _local_with_precision(13, "v_out", ".f16")

    let mut s0 = []
    // Load: dst (val_loaded) gets f16 value from addr_a.
    s0.push(_stmt_load(val_loaded, _op_local(addr_a.id)))
    // Pass-through: produce val_to_store via an add to itself (forces
    // f16-precision dst). We just re-use val_loaded for simplicity —
    // synthesize a no-op move via a binop add+0 isn't easy; use a
    // direct STMT_STORE on the loaded value directly to keep the test
    // surgical. The body store uses val_loaded as the source value.
    s0.push(_stmt_store(_op_local(addr_c.id), _op_local(val_loaded.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(addr_a)
    params.push(addr_c)
    let mut locals = []
    locals.push(addr_a)
    locals.push(addr_c)
    locals.push(val_loaded)
    locals.push(val_to_store)

    return MFunc {
        name: "f16_ld_st_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
}

fn _test_f16_load_store() -> bool {
    let mut ok = true
    let mfn = _build_case_f16_ld_st()
    let ptx = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn))

    println("")
    println("── emitted PTX (RFC 068 P4 f16 ld/st, sm_80) ──")
    println(ptx)

    // The f16-precision-tagged Local should drive ld.global.b16 emit
    // (silicon-canonical: ptxas rejects ld.global.f16 + accepts .b16
    // storage with .reg .f16 operand via PTX type-cast — see PR #189
    // silicon-fire finding).
    ok = _check(ok, ptx, "ld.global.b16",  "ld.global.b16 mnemonic emitted (silicon-canonical f16 LOAD)")
    ok = _check(ok, ptx, "st.global.b16",  "st.global.b16 mnemonic emitted (silicon-canonical f16 STORE)")
    // Negative guards — neither the legacy f64-only path NOR the
    // spec-but-not-silicon ld.global.f16 form should fire.
    if _contains(ptx, "ld.global.f64 %fh") || _contains(ptx, "st.global.f64 %fh") {
        println("  FAIL: f64 mnemonic emitted on f16-tagged Locals — kind dispatch broken")
        ok = false
    } else {
        println("  ok: no f64 mnemonic on f16-tagged ld/st (kind dispatch live)")
    }
    if _contains(ptx, "ld.global.f16") || _contains(ptx, "st.global.f16") {
        println("  FAIL: ld.global.f16 / st.global.f16 emitted — ptxas would reject (silicon mismatch)")
        ok = false
    } else {
        println("  ok: no .f16 storage mnemonic (silicon-canonical .b16 only)")
    }
    return ok
}

// ── Case 26 — RFC 068 §3 fp8 e4m3 scaffold (ld/st round-trip) ─────────
//
// Verifies that an fp8 e4m3-tagged Local (`Local.precision = ".f8_e4m3"`)
// routes through the codegen pipeline end-to-end:
//   - classifier short-circuits to NVPTX_RKIND_F8_E4M3
//   - `.reg .b8 %fe3<id>` directive is emitted (PTX has no native
//     `.e4m3` reg type tag — `.b8` raw container is silicon-canonical)
//   - `ld.global.b8` / `st.global.b8` mnemonics dispatch
//
// Honest scope (`@D g3`): codegen-only scaffold. No silicon fire — fp8
// sub-byte ABI (kernel-arg packing, addr alignment) + the matching
// `wmma.mma.sync...e4m3.e4m3.f32` mnemonic family are follow-on cycles.
// Parser-side grammar for the `@f8_e4m3` named-type primitive is also
// follow-on; this test hand-builds the precision tag the same way
// Case 25 (f16) hand-builds `.f16`.

fn _build_case_f8_e4m3_ld_st() -> MFunc {
    let addr_a = _local_with_precision(20, "addr_a", "")
    let addr_c = _local_with_precision(21, "addr_c", "")
    let val_loaded = _local_with_precision(22, "v_in",  ".f8_e4m3")
    let val_to_store = _local_with_precision(23, "v_out", ".f8_e4m3")

    let mut s0 = []
    s0.push(_stmt_load(val_loaded, _op_local(addr_a.id)))
    s0.push(_stmt_store(_op_local(addr_c.id), _op_local(val_loaded.id)))
    s0.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))

    let mut params = []
    params.push(addr_a)
    params.push(addr_c)
    let mut locals = []
    locals.push(addr_a)
    locals.push(addr_c)
    locals.push(val_loaded)
    locals.push(val_to_store)

    return MFunc {
        name: "f8_e4m3_ld_st_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
}

fn _test_f8_e4m3_load_store() -> bool {
    let mut ok = true
    let mfn = _build_case_f8_e4m3_ld_st()
    let ptx = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn))

    println("")
    println("── emitted PTX (RFC 068 §3 fp8 e4m3 ld/st scaffold, sm_80) ──")
    println(ptx)

    // Positive: silicon-canonical `.b8` storage mnemonics fire.
    ok = _check(ok, ptx, "ld.global.b8",  "ld.global.b8 mnemonic emitted (silicon-canonical fp8 e4m3 LOAD)")
    ok = _check(ok, ptx, "st.global.b8",  "st.global.b8 mnemonic emitted (silicon-canonical fp8 e4m3 STORE)")
    // Positive: `%fe3<id>` reg-bank prefix (distinct from f16 `%fh`,
    // bf16 `%fb`, f32 `%fs`).
    ok = _check(ok, ptx, "%fe3", "%fe3<id> reg-bank prefix emitted (RFC 068 §3 e4m3 bank)")
    // Positive: `.reg .b8` directive (PTX has no native `.e4m3` type).
    ok = _check(ok, ptx, ".reg .b8", ".reg .b8 directive emitted (silicon-canonical fp8 container)")
    // Negative guards — neither the f64 default NOR the spec-but-not-
    // silicon `.f8_e4m3` storage form should fire.
    if _contains(ptx, "ld.global.f64 %fe3") || _contains(ptx, "st.global.f64 %fe3") {
        println("  FAIL: f64 mnemonic emitted on fp8-tagged Locals — kind dispatch broken")
        ok = false
    } else {
        println("  ok: no f64 mnemonic on fp8 e4m3-tagged ld/st (kind dispatch live)")
    }
    if _contains(ptx, "ld.global.e4m3") || _contains(ptx, "st.global.e4m3") {
        println("  FAIL: ld.global.e4m3 / st.global.e4m3 emitted — ptxas would reject (silicon mismatch)")
        ok = false
    } else {
        println("  ok: no .e4m3 storage mnemonic (silicon-canonical .b8 only)")
    }
    return ok
}

