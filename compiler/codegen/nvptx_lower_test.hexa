fn _test_f8_e5m2_load_store() -> bool {
    let mut ok = true
    let mfn = _build_case_f8_e5m2_ld_st()
    let ptx = codegen_emit_ptx_sm80(_wrap_single_mfn(mfn))

    println("")
    println("── emitted PTX (RFC 068 §3 fp8 e5m2 ld/st scaffold, sm_80) ──")
    println(ptx)

    // Positive: silicon-canonical `.b8` storage mnemonics fire.
    ok = _check(ok, ptx, "ld.global.b8",  "ld.global.b8 mnemonic emitted (silicon-canonical fp8 e5m2 LOAD)")
    ok = _check(ok, ptx, "st.global.b8",  "st.global.b8 mnemonic emitted (silicon-canonical fp8 e5m2 STORE)")
    // Positive: `%fe5<id>` reg-bank prefix (distinct from e4m3 `%fe3`
    // and from f16 `%fh`, bf16 `%fb`, f32 `%fs`).
    ok = _check(ok, ptx, "%fe5", "%fe5<id> reg-bank prefix emitted (RFC 068 §3 e5m2 bank)")
    // Positive: `.reg .b8` directive (shared with e4m3 — storage type
    // is identical; only the consumer opcode differentiates).
    ok = _check(ok, ptx, ".reg .b8", ".reg .b8 directive emitted (silicon-canonical fp8 container)")
    // Negative guards.
    if _contains(ptx, "ld.global.f64 %fe5") || _contains(ptx, "st.global.f64 %fe5") {
        println("  FAIL: f64 mnemonic emitted on fp8-tagged Locals — kind dispatch broken")
        ok = false
    } else {
        println("  ok: no f64 mnemonic on fp8 e5m2-tagged ld/st (kind dispatch live)")
    }
    if _contains(ptx, "ld.global.e5m2") || _contains(ptx, "st.global.e5m2") {
        println("  FAIL: ld.global.e5m2 / st.global.e5m2 emitted — ptxas would reject (silicon mismatch)")
        ok = false
    } else {
        println("  ok: no .e5m2 storage mnemonic (silicon-canonical .b8 only)")
    }
    // Negative guard: the e4m3 bank prefix MUST NOT appear in an
    // e5m2-only fixture (verifies bank isolation).
    if _contains(ptx, "%fe3") {
        println("  FAIL: %fe3 (e4m3 bank) appeared in e5m2-only fixture — bank crosstalk")
        ok = false
    } else {
        println("  ok: no %fe3 (e4m3 bank) in e5m2-only fixture (banks are disjoint)")
    }
    return ok
}

// ── Case 28 — RFC 071 P3+ to_i64 + integer setp + bounds-check ───────
//
// Closes the three NVPTX lowering gaps that surfaced when N13's
// source-to-silicon driver lowered `my_test_kernel` (a vec-add kernel
// with `if to_i64(gid) < n { c[to_i64(gid)] = a[...] + b[...] }`):
//
//   1. `to_i64` STMT_CALL  → `cvt.s64.s32 %rd<d>, %r<s>;`  (s32 → s64
//                                                          sign-extend)
//   2. `<` STMT_BINOP with U64 operands → `setp.lt.s64 %p<d>, %rd<a>,
//                                                              %rd<b>;`
//   3. `@<pred> bra $L_<t>; bra $L_<f>;` — already-wired STMT_BR_COND
//      path verified to consume the integer-predicate output.
//
// The fixture mirrors the relevant slice of `my_test_kernel`:
//   block 0:
//     gid32 = gpu_thread_id_x()          // STMT_CALL → U32 %r0
//     gid64 = to_i64(gid32)              // STMT_CALL → U64 %rd1
//     p     = gid64 < n_param            // STMT_BINOP "lt" → pred %p2
//     br_cond p -> block 1, else block 2
//   block 1: return
//   block 2: return
//
// `n_param` is a function param (Local id=3, name "n"). Because the
// classifier's Pass 1 doesn't see a defining stmt for `n_param`, the
// lookup_kind for `n_param` returns the F64 default — to keep the
// cmp_operand_type_suffix returning `.s64` regardless of the param's
// classification gap, the first operand of the cmp is `gid64` (which
// IS classified U64 via the new `to_i64` rule). The first-non-default-
// wins rule then picks `.s64`. (A wider param-type-propagation pass
// is the follow-on RFC 071 cycle — out of scope here.)

fn _build_case_to_i64_and_int_cmp() -> MModule {
    let gid32 = _local(0, "gid32")     // STMT_CALL gpu_thread_id_x → U32 %r0
    let gid64 = _local(1, "gid64")     // STMT_CALL to_i64(gid32)   → U64 %rd1
    let p     = _local(2, "p")         // STMT_BINOP "lt"           → pred %p2
    let n_p   = _local(3, "n")         // function param (unclassified default → F64 fallback)

    // block 0
    let mut to_i64_args = []
    to_i64_args.push(_op_local(gid32.id))

    let mut s0 = []
    s0.push(_stmt_call(gid32, "gpu_thread_id_x"))
    s0.push(_stmt_call_with_args(gid64, "to_i64", to_i64_args))
    s0.push(_stmt_binop(p, "lt", _op_local(gid64.id), _op_local(n_p.id)))
    s0.push(_stmt_br_cond(_op_local(p.id), 1, 2))

    // block 1: return
    let mut s1 = []
    s1.push(_stmt_return())
    // block 2: return
    let mut s2 = []
    s2.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s0))
    blocks.push(_block(1, s1))
    blocks.push(_block(2, s2))

    let mut params = []
    params.push(n_p)
    let mut locals = []
    locals.push(gid32); locals.push(gid64); locals.push(p); locals.push(n_p)

    let mf = MFunc {
        name: "to_i64_cmp_smoke",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_DEVICE
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "case_to_i64_and_int_cmp.hexa", funcs: fns, globals: [] }
}

fn _test_to_i64_and_int_cmp() -> bool {
    let mut ok = true
    let mod_in = _build_case_to_i64_and_int_cmp()
    let ptx = codegen_emit_ptx_sm80(mod_in)

    println("")
    println("── emitted PTX (RFC 071 P3+ to_i64 + int cmp + br_cond, sm_80) ──")
    println(ptx)

    // GAP 1 — to_i64 lowering. The dst (gid64) must declare in the
    // U64 bank (`.reg .u64 %rd1;`) and the body must emit
    // `cvt.s64.s32 %rd1, %r0;` (s32→s64 sign-extend; `to_i64(gid32)`
    // where gid32 is U32 from the thread-id intrinsic).
    ok = _check(ok, ptx, ".reg .u64 %rd1",        "to_i64 dst classified U64 (%rd1)")
    ok = _check(ok, ptx, "cvt.s64.s32 %rd1, %r0", "cvt.s64.s32 emitted for to_i64(u32)")

    // GAP 2 — integer setp. The dst (p) is .pred; both operands are
    // i64-bank (%rd1 + the f64-default %fd3 fallback for the unclassified
    // n_param). The first-non-default-wins rule picks `.s64` because
    // %rd1 classifies U64.
    ok = _check(ok, ptx, ".reg .pred %p2",        "cmp dst classified .pred (%p2)")
    ok = _check(ok, ptx, "setp.lt.s64 %p2",       "setp.lt.s64 emitted for U64-operand cmp")

    // GAP 3 — STMT_BR_COND consumes the integer predicate. The existing
    // STMT_BR_COND path emits `@<pred> bra $L_<t>; bra $L_<f>;` — we
    // verify it works with the new integer-predicate dst.
    ok = _check(ok, ptx, "@%p2 bra $L_1",         "predicated bra -> $L_1 (then)")
    ok = _check(ok, ptx, "bra $L_2",              "fall-through bra -> $L_2 (else)")

    // Honest-stub negative guard — none of the three gaps should leave
    // an `unsupported` comment in the emitted PTX. The N13-era source-
    // derived PTX had `// RFC 055 055-P0 - unsupported call: to_i64` and
    // `// RFC 055 055-P0 - unsupported binop: <` markers; both must
    // disappear after this cycle.
    if _contains(ptx, "unsupported call: to_i64") {
        println("  FAIL: `unsupported call: to_i64` marker still present")
        ok = false
    } else {
        println("  ok: no `unsupported call: to_i64` marker (gap 1 closed)")
    }
    if _contains(ptx, "unsupported binop: lt") || _contains(ptx, "unsupported binop: <") {
        println("  FAIL: `unsupported binop: lt|<` marker still present")
        ok = false
    } else {
        println("  ok: no `unsupported binop: lt|<` marker (gap 2 closed)")
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// RFC 071 P5+ — matmul + matmul_NT_a + matmul_NT_b codegen cases
// ════════════════════════════════════════════════════════════════════
//
// Mirrors the ROCm lane's Cases 9/10/11 (`_test_matmul_emit` /
// `_test_matmul_NT_a_emit` / `_test_matmul_NT_b_emit`) in
// rocm_lower_test.hexa (4d858589 / 3a885837) and the Metal lane's
// equivalent N41 codegen cases (23b70a2a). Each test builds a synthetic
// STMT_LOAD + STMT_LOAD + STMT_BINOP(<matmul-family-op>) + STMT_STORE
// MIR fixture, drives it through `codegen_emit_ptx_for_sm`, and
// substring-checks the emitted PTX text for the WMMA kernel skeleton.
//
// HONEST SCOPE — codegen-only. Source-to-silicon E2E (real `fn matmul`
// source → PTX → SASS → silicon) is multi-cycle follow-on. WMMA family
// chosen: `m16n16k16.f16.f16.f32` (matches the existing
// `_nvptx_wmma_mnemonic` table + the hand-emitted HGEMM gemm_test
// baseline; see RFC 071 P5+ comment block in `nvptx_target.hexa`).

// _check_not — sibling of `_check` for negative-guard substring asserts.
fn _check_not(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if !_contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (unexpected: `" + needle + "`)")
    return false
}

// _stmt_load_local — matmul-shape STMT_LOAD on a Local operand source.
// Mirror of `_stmt_load` (which already takes an Operand) — kept as a
// thin convenience wrapper here so the matmul fixture call sites read
// like the ROCm lane's `_stmt_load(va, a.id)` style.
fn _stmt_load_local(dst: Local, src_local: i64) -> Stmt {
    return _stmt_load(dst, _op_local(src_local))
}

// _stmt_store_local — matmul-shape STMT_STORE writing a Local value to
// a Local address. The shape recogniser only inspects `kind` /
// `op` / position, not operand semantics, so this minimal helper
// suffices for the synthetic fixture.
fn _stmt_store_local(value_local: i64, addr_local: i64) -> Stmt {
    return _stmt_store(_op_local(addr_local), _op_local(value_local))
}

// _stmt_binop_op — STMT_BINOP with explicit op string + two Local args.
// Used by all three matmul fixtures to carry "matmul" / "matmul_NT_a" /
// "matmul_NT_b" — the strings the recognisers key on.
fn _stmt_binop_op(dst: Local, op: string, lhs: i64, rhs: i64) -> Stmt {
    return _stmt_binop(dst, op, _op_local(lhs), _op_local(rhs))
}

// _build_matmul_module_for — synthesise a 4-stmt STMT_LOAD + STMT_LOAD +
// STMT_BINOP(op) + STMT_STORE MIR fixture for the given matmul-family
// op string + kernel name. Parameter shape (a, b, c) + private locals
// (va, vb, vc) mirrors the ROCm lane's `_build_matmul*_module`.
fn _build_matmul_module_for(kname: string, binop: string) -> MModule {
    let a  = _local(0, "a")
    let b  = _local(1, "b")
    let c  = _local(2, "c")
    let va = _local(3, "va")
    let vb = _local(4, "vb")
    let vc = _local(5, "vc")

    let mut s = []
    s.push(_stmt_load_local(va, a.id))
    s.push(_stmt_load_local(vb, b.id))
    s.push(_stmt_binop_op(vc, binop, va.id, vb.id))
    s.push(_stmt_store_local(vc.id, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: kname,
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "nvptx_" + kname + ".hexa", funcs: fns, globals: [] }
}

// ── Case 29 — F-RFC071-NVPTX-MATMUL-CODEGEN-EMIT (canonical matmul) ──
//
// Canonical matmul `c = a · b` (per N122 4-bug remediation):
//   * A fragment uses `.row` (row-major MxK), stride K
//   * B fragment uses `.row` (row-major KxN — nn.Linear convention),
//     stride N (bug 4 fix)
//   * C accumulator is f32 row-major, stride N
//   * `wmma.mma.sync.aligned.row.row.m16n16k16.f32.f32` (bug 2 + bug 4
//     fix: short type spec + row.row layout)
//   * state-space `.global` leading, NOT trailing `.shared` (bug 1 fix)
//   * `wmma.store.d` operand order `[addr], {regs}, stride` (bug 3 fix)
// Negative guards: must NOT emit the transposed-A `.col` A-load, the
// transposed-B `.col` B-load (NT_b emit), or any vec-add / gemm-FP64-fma
// residue. Must NOT emit the old `.shared` trailing form (the 4-bug
// catalog before N86 fix).
fn _test_matmul_emit() -> bool {
    let mut ok = true
    let mod_mm = _build_matmul_module_for("matmul", "matmul")
    let ptx = codegen_emit_ptx_for_sm(mod_mm, "sm_90")

    println("")
    println("── emitted PTX (RFC 071 P5+ matmul case, sm_90) ──")
    println(ptx)

    // PTX header — .version / .target / .address_size + the entry directive.
    ok = _check(ok, ptx, ".version 7.8",                            "PTX version 7.8 (sm_90)")
    ok = _check(ok, ptx, ".target sm_90",                           "PTX target sm_90")
    ok = _check(ok, ptx, ".address_size 64",                        "PTX address_size 64")
    ok = _check(ok, ptx, ".visible .entry matmul",                  "kernel entry directive `.visible .entry matmul`")
    // Param bank — 6 .u64 (a, b, c, M, N, K).
    ok = _check(ok, ptx, ".param .u64 matmul_param_0",              "param 0 (a base ptr)")
    ok = _check(ok, ptx, ".param .u64 matmul_param_5",              "param 5 (K extent)")
    ok = _check(ok, ptx, "ld.param.u64 %rd0, [matmul_param_0]",     "ld.param a base")
    ok = _check(ok, ptx, "ld.param.u64 %rd5, [matmul_param_5]",     "ld.param K extent")
    // Tile compose — row_tile/col_tile from ctaid.y / ctaid.x.
    ok = _check(ok, ptx, "mov.u32 %r0, %ctaid.y",                   "block row index from ctaid.y")
    ok = _check(ok, ptx, "mov.u32 %r1, %ctaid.x",                   "block col index from ctaid.x")
    ok = _check(ok, ptx, "mul.lo.s32 %r2, %r0, 16",                 "row_tile = ctaid.y * 16")
    ok = _check(ok, ptx, "mul.lo.s32 %r3, %r1, 16",                 "col_tile = ctaid.x * 16")
    // K-loop guard + back-edge.
    ok = _check(ok, ptx, "setp.lt.s32 %p0, %r7, %r6",               "loop guard kk < K")
    ok = _check(ok, ptx, "add.s32 %r7, %r7, 16",                    "loop step kk += 16 (WMMA tile-K)")
    ok = _check(ok, ptx, "bra $L_LOOP",                             "loop back-edge")
    // WMMA load + mma + store — canonical row.row m16n16k16 family.
    ok = _check(ok, ptx, "wmma.load.a.sync.aligned.row.m16n16k16.global.f16", "wmma.load.a row-major A .global (canonical, N122 bug 1 fix)")
    ok = _check(ok, ptx, "wmma.load.b.sync.aligned.row.m16n16k16.global.f16", "wmma.load.b row-major B .global (canonical, N122 bug 1+4 fix)")
    ok = _check(ok, ptx, "wmma.mma.sync.aligned.row.row.m16n16k16.f32.f32", "wmma.mma row.row f32.f32 short form (canonical, N122 bug 2+4 fix)")
    ok = _check(ok, ptx, "wmma.store.d.sync.aligned.row.m16n16k16.global.f32", "wmma.store.d row-major C .global (N122 bug 3 fix)")
    // Negative guards — canonical matmul must NOT carry transposed-A
    // layouts, NOT inherit any earlier-shape body fragment, NOT emit
    // the pre-N86-fix `.shared` trailing form or `.f32.f16.f16.f32` long form.
    ok = _check_not(ok, ptx, "wmma.load.a.sync.aligned.col.m16n16k16", "canonical matmul should not emit transposed-A `.col` A-load")
    ok = _check_not(ok, ptx, "wmma.load.b.sync.aligned.col.m16n16k16", "canonical matmul should not emit transposed-B `.col` B-load")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.col.col.m16n16k16", "canonical matmul should not emit `.col.col` mma")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.row.col.m16n16k16", "canonical matmul should not emit `.row.col` mma (NT_b shape)")
    ok = _check_not(ok, ptx, ".f16.shared",                            "canonical matmul should not emit pre-N86 `.shared` trailing form (N122 bug 1)")
    ok = _check_not(ok, ptx, ".f32.shared",                            "canonical matmul should not emit pre-N86 `.f32.shared` store form (N122 bug 3)")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.row.row.m16n16k16.f32.f16.f16.f32", "canonical matmul should not emit invalid long-form mma (N122 bug 2)")
    ok = _check_not(ok, ptx, "fma.rn.f64",                             "canonical matmul should not emit FP64 fma (HGEMM-only residue)")
    return ok
}

// ── Case 30 — F-RFC071-NVPTX-MATMUL-NT-A-CODEGEN-EMIT ────────────────
//
// matmul_NT_a `c = a^T · b` (per N122 4-bug remediation):
//   * A fragment uses `.col` (column-major, transposed-A interpretation)
//   * A-load address stride switches from K to M
//   * B stays row-major (`.row`) + stride N (canonical, N122 bug 4)
//   * mma source layouts become `.col.row`
//   * state-space `.global` leading, short type spec `.f32.f32`, store
//     operand order `[addr], {regs}, stride` (N122 bug 1+2+3 fixes)
// Negative guards: must NOT emit canonical `.row` A-load, transposed-B
// `.col` B-load, canonical `.row.row` mma, or pre-N86 `.shared` form.
fn _test_matmul_NT_a_emit() -> bool {
    let mut ok = true
    let mod_mt = _build_matmul_module_for("matmul_NT_a", "matmul_NT_a")
    let ptx = codegen_emit_ptx_for_sm(mod_mt, "sm_90")

    println("")
    println("── emitted PTX (RFC 071 P5+ matmul_NT_a case, sm_90) ──")
    println(ptx)

    ok = _check(ok, ptx, ".version 7.8",                            "PTX version 7.8 (sm_90)")
    ok = _check(ok, ptx, ".target sm_90",                           "PTX target sm_90")
    ok = _check(ok, ptx, ".visible .entry matmul_NT_a",             "kernel entry directive `.visible .entry matmul_NT_a`")
    ok = _check(ok, ptx, ".param .u64 matmul_NT_a_param_0",         "param 0 (a base ptr)")
    ok = _check(ok, ptx, ".param .u64 matmul_NT_a_param_5",         "param 5 (K extent)")
    // Tile compose — same prologue as canonical.
    ok = _check(ok, ptx, "mov.u32 %r0, %ctaid.y",                   "block row index from ctaid.y")
    ok = _check(ok, ptx, "mul.lo.s32 %r2, %r0, 16",                 "row_tile = ctaid.y * 16")
    // K-loop.
    ok = _check(ok, ptx, "setp.lt.s32 %p0, %r7, %r6",               "loop guard kk < K")
    ok = _check(ok, ptx, "add.s32 %r7, %r7, 16",                    "loop step kk += 16")
    ok = _check(ok, ptx, "bra $L_LOOP",                             "loop back-edge")
    // WMMA — A `.col`, B stays `.row` (row-major canonical), mma `.col.row`.
    ok = _check(ok, ptx, "wmma.load.a.sync.aligned.col.m16n16k16.global.f16", "wmma.load.a col-major A .global (transposed-A, N122 bug 1 fix)")
    ok = _check(ok, ptx, "wmma.load.b.sync.aligned.row.m16n16k16.global.f16", "wmma.load.b row-major B .global (canonical, N122 bug 1+4 fix)")
    ok = _check(ok, ptx, "wmma.mma.sync.aligned.col.row.m16n16k16.f32.f32", "wmma.mma col.row f32.f32 short form (transposed-A, N122 bug 2+4 fix)")
    ok = _check(ok, ptx, "wmma.store.d.sync.aligned.row.m16n16k16.global.f32", "wmma.store.d row-major C .global (N122 bug 3 fix)")
    // A-load address arithmetic — stride M (not K). The address compose
    // emits `mul.lo.s32 ... %r4` (M) instead of `... %r6` (K) in the
    // A-tile compose. We verify via the comment marker the emit pass
    // attaches to the instruction.
    ok = _check(ok, ptx, "kk * M",                                  "A-tile address arithmetic uses stride M (transposed-A)")
    // Negative guards — matmul_NT_a must NOT emit canonical A `.row`
    // or transposed-B `.col` B-load or canonical `.row.row` mma or
    // pre-N86 `.shared` form.
    ok = _check_not(ok, ptx, "wmma.load.a.sync.aligned.row.m16n16k16", "matmul_NT_a should not emit canonical `.row` A-load")
    ok = _check_not(ok, ptx, "wmma.load.b.sync.aligned.col.m16n16k16", "matmul_NT_a should not emit transposed-B `.col` B-load")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.row.col.m16n16k16", "matmul_NT_a should not emit pre-fix `.row.col` mma")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.row.row.m16n16k16", "matmul_NT_a should not emit `.row.row` mma (canonical shape)")
    ok = _check_not(ok, ptx, ".f16.shared",                            "matmul_NT_a should not emit pre-N86 `.shared` trailing form")
    ok = _check_not(ok, ptx, ".f32.shared",                            "matmul_NT_a should not emit pre-N86 `.f32.shared` store form")
    return ok
}

// ── Case 31 — F-RFC071-NVPTX-MATMUL-NT-B-CODEGEN-EMIT ────────────────
//
// matmul_NT_b `c = a · b^T` (per N122 4-bug remediation):
//   * A stays `.row` (canonical row-major MxK, stride K)
//   * B fragment uses `.col` (col-major; transposed-B interpretation
//     flips the canonical row-major default to col-major)
//   * B-load address stride switches from N to K
//   * mma source layouts become `.row.col`
//   * state-space `.global` leading, short type spec `.f32.f32`, store
//     operand order `[addr], {regs}, stride` (N122 bug 1+2+3 fixes)
// Negative guards: must NOT emit canonical `.row` B-load (canonical
// shape after bug 4 fix), transposed-A `.col` A-load, canonical
// `.row.row` mma, or pre-N86 `.shared` form.
fn _test_matmul_NT_b_emit() -> bool {
    let mut ok = true
    let mod_mt = _build_matmul_module_for("matmul_NT_b", "matmul_NT_b")
    let ptx = codegen_emit_ptx_for_sm(mod_mt, "sm_90")

    println("")
    println("── emitted PTX (RFC 071 P5+ matmul_NT_b case, sm_90) ──")
    println(ptx)

    ok = _check(ok, ptx, ".version 7.8",                            "PTX version 7.8 (sm_90)")
    ok = _check(ok, ptx, ".target sm_90",                           "PTX target sm_90")
    ok = _check(ok, ptx, ".visible .entry matmul_NT_b",             "kernel entry directive `.visible .entry matmul_NT_b`")
    ok = _check(ok, ptx, ".param .u64 matmul_NT_b_param_0",         "param 0 (a base ptr)")
    ok = _check(ok, ptx, ".param .u64 matmul_NT_b_param_5",         "param 5 (K extent)")
    ok = _check(ok, ptx, "mov.u32 %r0, %ctaid.y",                   "block row index from ctaid.y")
    ok = _check(ok, ptx, "mul.lo.s32 %r2, %r0, 16",                 "row_tile = ctaid.y * 16")
    ok = _check(ok, ptx, "setp.lt.s32 %p0, %r7, %r6",               "loop guard kk < K")
    ok = _check(ok, ptx, "add.s32 %r7, %r7, 16",                    "loop step kk += 16")
    ok = _check(ok, ptx, "bra $L_LOOP",                             "loop back-edge")
    // WMMA — A stays `.row`, B switches to `.col`, mma `.row.col`.
    ok = _check(ok, ptx, "wmma.load.a.sync.aligned.row.m16n16k16.global.f16", "wmma.load.a row-major A .global (matmul_NT_b stays canonical A, N122 bug 1 fix)")
    ok = _check(ok, ptx, "wmma.load.b.sync.aligned.col.m16n16k16.global.f16", "wmma.load.b col-major B .global (transposed-B, N122 bug 1+4 fix)")
    ok = _check(ok, ptx, "wmma.mma.sync.aligned.row.col.m16n16k16.f32.f32", "wmma.mma row.col f32.f32 short form (transposed-B, N122 bug 2+4 fix)")
    ok = _check(ok, ptx, "wmma.store.d.sync.aligned.row.m16n16k16.global.f32", "wmma.store.d row-major C .global (N122 bug 3 fix)")
    // B-load address arithmetic — stride K (not N).
    ok = _check(ok, ptx, "col_tile * K",                            "B-tile address arithmetic uses stride K (transposed-B)")
    // Negative guards — matmul_NT_b must NOT emit canonical B `.row`
    // (canonical shape post-bug-4) or transposed-A `.col` A-load or
    // canonical `.row.row` mma or pre-N86 `.shared` form.
    ok = _check_not(ok, ptx, "wmma.load.b.sync.aligned.row.m16n16k16", "matmul_NT_b should not emit canonical `.row` B-load")
    ok = _check_not(ok, ptx, "wmma.load.a.sync.aligned.col.m16n16k16", "matmul_NT_b should not emit transposed-A `.col` A-load")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.row.row.m16n16k16", "matmul_NT_b should not emit canonical `.row.row` mma")
    ok = _check_not(ok, ptx, "wmma.mma.sync.aligned.col.col.m16n16k16", "matmul_NT_b should not emit `.col.col` mma")
    ok = _check_not(ok, ptx, ".f16.shared",                            "matmul_NT_b should not emit pre-N86 `.shared` trailing form")
    ok = _check_not(ok, ptx, ".f32.shared",                            "matmul_NT_b should not emit pre-N86 `.f32.shared` store form")
    return ok
}
