// ── matmul MIR fixture (Case 16) ─────────────────────────────────────
//
// Synthetic MMA matmul MIR shape — STMT_LOAD a→va + STMT_LOAD b→vb +
// STMT_BINOP("matmul") (va, vb)→vc + STMT_STORE vc→c. Drives the
// `_metal_mfunc_is_matmul_shape` recogniser and the MMA emit path
// (`_metal_emit_matmul_preamble` + `_metal_emit_matmul_kernel_signature`
// + `_metal_emit_matmul_body`). No HIR / parser produces this opcode
// today; the fixture is hand-built scaffold paired with the synthetic
// recogniser so the codegen text-emit verifier can exercise the MSL
// emit independently of the future operator-form lowering.

fn _build_matmul_module() -> MModule {
    // Three kernel-buffer params (a, b, c) + three private Locals
    // (va, vb, vc). Stmt sequence: STMT_LOAD a→va, STMT_LOAD b→vb,
    // STMT_BINOP_MATMUL (va, vb)→vc, STMT_STORE vc→c. Mirrors the
    // vec-add fixture shape modulo the BINOP op string.
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_matmul(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "matmul",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "metal_matmul.hexa", funcs: fns, globals: [] }
}

// ── Case 16 — F-RFC075-METAL-EMIT-MATMUL ─────────────────────────────
//
// Synthesise a matmul MIR module (`c = a @ b` via 32×32 simdgroup-MMA),
// invoke `codegen_emit_metal_msl`, and assert the emitted MSL kernel
// source uses the MMA preamble + 6-buffer kernel signature + the
// simdgroup-MMA body (verbatim port of N16 commit `31d729a4`
// `simdgroup_matmul_32x32_tg` — peak 911.55 GFLOPS @ 768³ on Apple M3,
// 3.4× over the tiled-naive matmul baseline from commit `19e83c2b`).
//
// Substring battery (positive + negative):
//   - simdgroup-MMA preamble `<metal_simdgroup_matrix>`
//   - kernel-decl + 6-arg signature (a, b, c, M, N, K)
//   - thread-hierarchy attributes (sgid + slid + tgid + lid)
//   - MMA intrinsics (`simdgroup_matrix`, `simdgroup_load`,
//     `simdgroup_multiply_accumulate`, `simdgroup_store`,
//     `make_filled_simdgroup_matrix`)
//   - threadgroup-mem A/B staging (`threadgroup float As[`,
//     `threadgroup float Bs[`, `threadgroup_barrier`)
//   - K-loop scaffolding (`for (uint kk`, `K8`)
//   - Negative guards — must NOT emit element-wise patterns
//     (`b[i]`, `c[i] = a[i] + b[i]`) that would indicate dispatch
//     fell into vec-add / vec-mul branches instead of matmul.

fn _test_matmul_emit() -> bool {
    let mut ok = true
    let mod_mm = _build_matmul_module()
    let msl = codegen_emit_metal_msl(mod_mm)

    println("")
    println("── emitted MSL (RFC 075 P3+ matmul / MMA case) ──")
    println(msl)

    // F-RFC075-METAL-EMIT-MATMUL substring battery — positives.
    ok = _check_contains(ok, msl, "#include <metal_stdlib>",          "MSL preamble include")
    ok = _check_contains(ok, msl, "#include <metal_simdgroup_matrix>","MMA simdgroup-matrix header include")
    ok = _check_contains(ok, msl, "using namespace metal;",           "MSL namespace using-directive")
    ok = _check_contains(ok, msl, "kernel void",                      "kernel declaration `kernel void`")
    ok = _check_contains(ok, msl, "matmul",                           "kernel name from MFunc.name")
    ok = _check_contains(ok, msl, "device const float*",              "read-only device pointer parameter")
    ok = _check_contains(ok, msl, "device float*",                    "writable device pointer parameter")
    ok = _check_contains(ok, msl, "[[buffer(0)]]",                    "buffer(0) binding (a)")
    ok = _check_contains(ok, msl, "[[buffer(1)]]",                    "buffer(1) binding (b)")
    ok = _check_contains(ok, msl, "[[buffer(2)]]",                    "buffer(2) binding (c)")
    ok = _check_contains(ok, msl, "[[buffer(3)]]",                    "buffer(3) binding (M dim)")
    ok = _check_contains(ok, msl, "[[buffer(4)]]",                    "buffer(4) binding (N dim)")
    ok = _check_contains(ok, msl, "[[buffer(5)]]",                    "buffer(5) binding (K dim)")
    ok = _check_contains(ok, msl, "constant uint& M",                 "constant scalar M param")
    ok = _check_contains(ok, msl, "constant uint& N",                 "constant scalar N param")
    ok = _check_contains(ok, msl, "constant uint& K",                 "constant scalar K param")
    ok = _check_contains(ok, msl, "[[simdgroup_index_in_threadgroup]]","sgid attribute")
    ok = _check_contains(ok, msl, "[[thread_index_in_simdgroup]]",    "slid attribute")
    ok = _check_contains(ok, msl, "[[threadgroup_position_in_grid]]", "tgid attribute")
    ok = _check_contains(ok, msl, "[[thread_position_in_threadgroup]]","lid attribute")
    ok = _check_contains(ok, msl, "simdgroup_matrix<float, 8, 8>",    "MMA tile type")
    ok = _check_contains(ok, msl, "make_filled_simdgroup_matrix",     "MMA accumulator constructor")
    ok = _check_contains(ok, msl, "simdgroup_load",                   "MMA load intrinsic")
    ok = _check_contains(ok, msl, "simdgroup_multiply_accumulate",    "MMA multiply-accumulate intrinsic")
    ok = _check_contains(ok, msl, "simdgroup_store",                  "MMA store intrinsic")
    ok = _check_contains(ok, msl, "threadgroup float As[",            "threadgroup-mem A slab")
    ok = _check_contains(ok, msl, "threadgroup float Bs[",            "threadgroup-mem B slab")
    ok = _check_contains(ok, msl, "threadgroup_barrier",              "threadgroup barrier (sync)")
    ok = _check_contains(ok, msl, "mem_flags::mem_threadgroup",       "threadgroup-mem fence flag")
    ok = _check_contains(ok, msl, "for (uint kk",                     "K-loop control")
    ok = _check_contains(ok, msl, "K8",                               "K/8 derived loop bound")
    ok = _check_contains(ok, msl, ";",                                "statement terminator")

    // Negative guards — must NOT emit element-wise patterns that would
    // indicate dispatch fell into vec-add / vec-mul instead of matmul.
    ok = _check_not_contains(ok, msl, "b[i]",                         "matmul should not emit `b[i]` (element-wise guard)")
    ok = _check_not_contains(ok, msl, "c[i] = a[i] + b[i]",           "matmul should not emit vec-add body")
    ok = _check_not_contains(ok, msl, "c[i] = a[i] * b[i]",           "matmul should not emit vec-mul body")
    return ok
}

// ── matmul_NT_a MIR fixture (Case 17) ────────────────────────────────
//
// Synthetic MMA matmul_NT_a (A transposed) MIR shape — STMT_LOAD a→va
// + STMT_LOAD b→vb + STMT_BINOP("matmul_NT_a") (va, vb)→vc + STMT_STORE
// vc→c. Drives the `_metal_mfunc_is_matmul_NT_a_shape` recogniser and
// the MMA-NT-A emit path (`_metal_emit_matmul_preamble` +
// `_metal_emit_matmul_kernel_signature` + `_metal_emit_matmul_NT_a_body`).
// No HIR / parser produces this opcode today; the fixture is hand-built
// scaffold paired with the synthetic recogniser so the codegen text-
// emit verifier can exercise the simdgroup_load transpose=true path
// independently of the future operator-form lowering.

fn _build_matmul_NT_a_module() -> MModule {
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_matmul_NT_a(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
