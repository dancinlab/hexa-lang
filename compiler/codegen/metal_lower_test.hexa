    ok = _check_contains(ok, msl, "exp(a[i])",                   "full MSL call form `exp(a[i])`")
    ok = _check_contains(ok, msl, ";",                           "statement terminator")
    ok = _check_contains(ok, msl, "uint i",                      "thread-index parameter declaration")
    // Negative — vec-exp is 2-buffer, must NOT name `b[i]` or bind buffer(2),
    // and must not emit binop add/mul fragments.
    ok = _check_not_contains(ok, msl, "b[i]",                    "vec-exp should not name `b[i]` (2-buffer guard)")
