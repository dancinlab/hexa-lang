    let mut fns = []
    fns.push(mf)
    return MModule { file: "metal_matmul_NT_b.hexa", funcs: fns, globals: [] }
}

// ── Case 18 — F-RFC075-METAL-EMIT-MATMUL-NT-B ────────────────────────
//
// Synthesise a matmul_NT_b MIR module (`C = A · B^T`, B is N×K
// row-major), invoke `codegen_emit_metal_msl`, and assert the emitted
// MSL kernel source uses the MMA preamble + 6-buffer signature + the
// simdgroup-MMA body with B-side transpose-load (`simdgroup_load(...,
// true)` for Bmat). Used by flame ag_linear backward `dx = dy · W^T`.

fn _test_matmul_NT_b_emit() -> bool {
    let mut ok = true
    let mod_mm = _build_matmul_NT_b_module()
    let msl = codegen_emit_metal_msl(mod_mm)

