// ── vec-neg / vec-abs / vec-sqrt MIR fixtures (Cases 9-11) ──────────
//
// Element-wise unary kernels: 2-buffer signature (a + c only, NO `b`).
// Stmt sequence: STMT_LOAD a→va, STMT_UNOP(op_name) va→vc, STMT_STORE
// vc→c (optional STMT_RETURN tail). The op_name discriminates which
// shape recogniser fires ("neg" / "abs" / "sqrt"). All three share the
// same fixture skeleton; the lone difference is the UNOP op string.

fn _build_vec_unary_module(op_name: string, kname: string, file: string) -> MModule {
    // Two kernel-buffer params (a, c) + two private Locals (va, vc).
    // Stmt sequence: STMT_LOAD a→va, STMT_UNOP(op_name) (va)→vc,
    // STMT_STORE vc→c. Matches `_metal_mfunc_is_unary_shape_with_op`.
    let a  = _kern_local(0, "a")
    let c  = _kern_local(1, "c")
    let va = _priv_local(2, "va")
    let vc = _priv_local(3, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_unop(vc, va.id, op_name))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(c)
    locals.push(va)
    locals.push(vc)

    let mf = MFunc {
        name: kname,
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: file, funcs: fns, globals: [] }
}

fn _build_vec_neg_module() -> MModule {
    return _build_vec_unary_module("neg", "vec_neg", "metal_vec_neg.hexa")
}

fn _build_vec_abs_module() -> MModule {
    return _build_vec_unary_module("abs", "vec_abs", "metal_vec_abs.hexa")
}

fn _build_vec_sqrt_module() -> MModule {
    return _build_vec_unary_module("sqrt", "vec_sqrt", "metal_vec_sqrt.hexa")
}

fn _build_vec_exp_module() -> MModule {
    return _build_vec_unary_module("exp", "vec_exp", "metal_vec_exp.hexa")
}

fn _build_vec_log_module() -> MModule {
    return _build_vec_unary_module("log", "vec_log", "metal_vec_log.hexa")
}

fn _build_vec_sin_module() -> MModule {
    return _build_vec_unary_module("sin", "vec_sin", "metal_vec_sin.hexa")
}

fn _build_vec_cos_module() -> MModule {
    return _build_vec_unary_module("cos", "vec_cos", "metal_vec_cos.hexa")
}

// ── Case 9 — F-RFC075-METAL-EMIT-VEC-NEG ─────────────────────────────
//
// Synthesise a vec-neg MIR module (`c[i] = -a[i]`), invoke
// `codegen_emit_metal_msl`, and assert the emitted MSL kernel source
// uses the 2-buffer signature (a + c only) and the prefix unary `-`
// operator. Asserts the second input `b` and its [[buffer(2)]] binding
// are ABSENT — vec-neg is single-input. Asserts ` + ` and ` * ` are
// also absent so a future binop shape never accidentally falls into
// the unary branch.

fn _test_vec_neg_emit() -> bool {
    let mut ok = true
    let mod_vn = _build_vec_neg_module()
    let msl = codegen_emit_metal_msl(mod_vn)

    println("")
    println("── emitted MSL (RFC 075 P3+ vec-neg case) ──")
    println(msl)

    // F-RFC075-METAL-EMIT-VEC-NEG substring battery — 15 positive.
    ok = _check_contains(ok, msl, "#include <metal_stdlib>",     "MSL preamble include")
    ok = _check_contains(ok, msl, "using namespace metal;",      "MSL namespace using-directive")
    ok = _check_contains(ok, msl, "kernel void",                 "kernel declaration `kernel void`")
    ok = _check_contains(ok, msl, "vec_neg",                     "kernel name from MFunc.name")
    ok = _check_contains(ok, msl, "device const float*",         "read-only device pointer parameter")
    ok = _check_contains(ok, msl, "device float*",               "writable device pointer parameter")
    ok = _check_contains(ok, msl, "[[buffer(0)]]",               "buffer(0) binding attribute (a)")
    ok = _check_contains(ok, msl, "[[buffer(1)]]",               "buffer(1) binding attribute (c)")
    ok = _check_contains(ok, msl, "[[thread_position_in_grid]]", "thread-position attribute")
    ok = _check_contains(ok, msl, "c[i]",                        "writable buffer index `c[i]`")
    ok = _check_contains(ok, msl, "a[i]",                        "read buffer index `a[i]`")
    ok = _check_contains(ok, msl, "-a[i]",                       "prefix unary minus on `a[i]`")
    ok = _check_contains(ok, msl, "=",                           "assignment operator")
    ok = _check_contains(ok, msl, ";",                           "statement terminator")
    ok = _check_contains(ok, msl, "uint i",                      "thread-index parameter declaration")
    // Negative — vec-neg is 2-buffer, must NOT name `b[i]` or bind buffer(2),
    // and must not emit binop add/mul fragments.
    ok = _check_not_contains(ok, msl, "b[i]",                    "vec-neg should not name `b[i]` (2-buffer guard)")
    ok = _check_not_contains(ok, msl, "[[buffer(2)]]",           "vec-neg should not bind `[[buffer(2)]]` (2-buffer guard)")
    ok = _check_not_contains(ok, msl, " + ",                     "vec-neg should not emit ` + ` (binop guard)")
    ok = _check_not_contains(ok, msl, " * ",                     "vec-neg should not emit ` * ` (binop guard)")
    return ok
}

