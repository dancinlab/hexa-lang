// HEXA Native Compiler — RFC 075 P1+P2+P3+ / Metal lowering smoke (codegen-only)
//
// @version 0.0.4
// @capabilities [pure]
//
// RFC 075 P1+P2+P3+ codegen-only smoke. The codegen entry
// `codegen_emit_metal_msl` now recognises SIX MIR shapes (vec-add,
// vec-mul, vec-sub, vec-div, vec-scale, reduce-sum) and emits real MSL
// kernel source for each. Empty / unrecognised modules continue to
// return `""` honestly (P0 contract preserved — Case 1 still PASS).
// reduce-sum is the FIRST non-element-wise shape (uses Apple's
// SIMD-group `simd_sum` intrinsic + 2-buffer signature).
//
// Case roster:
//   Case 1 — P0 empty-module emit returns `""`
//   Case 2 — target enum + MSL syntax-fragment constants + new P1
//            kernel-decl / device-pointer / thread-pos constants
//   Case 3 — F-RFC075-METAL-EMIT-VEC-ADD: synthesize vec-add MIR,
//            invoke `codegen_emit_metal_msl`, assert emitted string
//            contains `kernel void`, `device const float*`,
//            `device float*`, `[[thread_position_in_grid]]`, and
//            `c[i]` / `a[i]` / `b[i]` substring patterns.
//   Case 4 — P2 classifier helpers `_metal_local_address_space` /
//            `_metal_local_precision` return expected defaults for
//            a kernel-buffer Local and a thread-private Local.
//   Case 5 — F-RFC075-METAL-EMIT-VEC-MUL: synthesize vec-mul MIR
//            (STMT_BINOP("mul") sibling of vec-add), invoke
//            `codegen_emit_metal_msl`, assert the same 15-substring
//            battery as vec-add but with ` * ` replacing ` + `.
//   Case 6 — F-RFC075-METAL-EMIT-VEC-SCALE: synthesize vec-scale MIR
//            (STMT_LOAD + STMT_BINOP("mul", const_float) + STMT_STORE),
//            invoke `codegen_emit_metal_msl`, assert emitted string
//            contains the scalar literal and ` * `, NOT ` + ` and NOT
//            `b[i]` (vec-scale has no second device buffer load).
//   Case 7 — F-RFC075-METAL-EMIT-VEC-SUB: synthesize vec-sub MIR
//            (STMT_BINOP("sub") sibling of vec-add), invoke
//            `codegen_emit_metal_msl`, assert the same 15-substring
//            battery as vec-add but with ` - ` replacing ` + `. Also
//            asserts ` + ` and ` * ` are ABSENT — vec-sub must not
//            accidentally inherit vec-add's `+` or vec-mul's `*`.
//   Case 8 — F-RFC075-METAL-EMIT-VEC-DIV: synthesize vec-div MIR
//            (STMT_BINOP("div") sibling of vec-add), invoke
//            `codegen_emit_metal_msl`, assert the same 15-substring
//            battery as vec-add but with ` / ` replacing ` + `. Also
//            asserts ` + ` and ` * ` are ABSENT — vec-div must not
//            accidentally inherit vec-add's `+` or vec-mul's `*`.
//   Case 9 — F-RFC075-METAL-EMIT-REDUCE-SUM: synthesize the FIRST
//            non-element-wise MIR shape (STMT_LOAD + STMT_UNOP
//            ("reduce_sum") + STMT_STORE), invoke
//            `codegen_emit_metal_msl`, assert the emitted MSL contains
//            the Apple-canonical `simd_sum` + `simd_is_first`
//            intrinsics, the group-id index, `c[group_id]` write, and
//            the 2-buffer signature. Asserts `b[i]`, `[[buffer(2)]]`,
//            ` + ` and ` * ` are ABSENT (single-input unary reduction).
//
// Run:
//   hexa build compiler/codegen/metal_lower_test.hexa -o build/metal_lower_test
//   ./build/metal_lower_test

import "../ir/mir.hexa"
import "../ir/lir.hexa"
import "./metal_target.hexa"

// ── MIR construction helpers (minimum needed for the empty MModule).
//    P1+ will share the Local/Operand/Stmt helpers shape from
//    nvptx_lower_test.hexa; P0 only needs an empty module ──

fn _empty_mmodule() -> MModule {
    return MModule { file: "metal_p0_smoke.hexa", funcs: [], globals: [] }
}

// ── Text inspection ──────────────────────────────────────────────────

fn _check_empty(ok_in: bool, text: string, label: string) -> bool {
    if len(text) == 0 { return ok_in }
    println("  FAIL: " + label + " (expected empty, got " + to_string(len(text)) + " chars)")
    return false
}

// ── Case 1 — P0 emit stub returns empty string ───────────────────────
//
// The P0 contract: `codegen_emit_metal_msl` is wired to the scaffold and
// honestly returns `""` until P3 fills in real MSL source text emit.
// This case verifies (a) the entry is callable, (b) the return type
// compiles against `string`, (c) the return value matches the P0
// placeholder. Falsifier F-RFC075-METAL-EMIT-VEC-ADD intentionally
// FAILS today; that is the point of a stub assertion.

fn _test_p0_empty_emit() -> bool {
    let mut ok = true
    let mod_empty = _empty_mmodule()
    let msl = codegen_emit_metal_msl(mod_empty)

    println("")
    println("── emitted MSL (RFC 075 P0 empty-emit case) ──")
    println("  [empty string, length=" + to_string(len(msl)) + "]")

    ok = _check_empty(ok, msl, "P0 stub returns empty string")
    return ok
}

// ── Case 2 — target enum + MSL syntax-fragment constants verified ────
//
// Sanity-checks the Apple-GPU target tags and the MSL syntax fragments
// land at their documented strings. In P1 this evolves into
// F-RFC075-METAL-TARGET-ACCEPT.

fn _test_target_constants() -> bool {
    let mut ok = true
    if METAL_TARGET_APPLE_GPU != "air64-apple-macos-applegpu" {
        println("  FAIL: METAL_TARGET_APPLE_GPU mismatch (got '" + METAL_TARGET_APPLE_GPU + "')")
        ok = false
    }
    if METAL_SIMD_GROUP_SIZE != 32 {
        println("  FAIL: METAL_SIMD_GROUP_SIZE expected 32, got " + to_string(METAL_SIMD_GROUP_SIZE))
        ok = false
    }
    if METAL_KW_KERNEL != "kernel" {
        println("  FAIL: METAL_KW_KERNEL expected 'kernel', got '" + METAL_KW_KERNEL + "'")
        ok = false
    }
    if METAL_SPACE_DEVICE != "device" {
        println("  FAIL: METAL_SPACE_DEVICE expected 'device', got '" + METAL_SPACE_DEVICE + "'")
        ok = false
    }
    // RFC 075 P1 constants — drives F-RFC075-METAL-TARGET-ACCEPT.
    if METAL_OP_KERNEL_DECL != "kernel void" {
        println("  FAIL: METAL_OP_KERNEL_DECL expected 'kernel void', got '" + METAL_OP_KERNEL_DECL + "'")
        ok = false
    }
    if METAL_OP_PARAM_DEVICE_CONST_FLOAT_PTR != "device const float* " {
        println("  FAIL: METAL_OP_PARAM_DEVICE_CONST_FLOAT_PTR mismatch")
        ok = false
    }
    if METAL_OP_PARAM_DEVICE_FLOAT_PTR != "device float* " {
        println("  FAIL: METAL_OP_PARAM_DEVICE_FLOAT_PTR mismatch")
        ok = false
    }
    if METAL_OP_THREAD_POS_GRID != "[[thread_position_in_grid]]" {
        println("  FAIL: METAL_OP_THREAD_POS_GRID mismatch")
        ok = false
    }
    if METAL_AS_DEVICE != "device" {
        println("  FAIL: METAL_AS_DEVICE expected 'device', got '" + METAL_AS_DEVICE + "'")
        ok = false
    }
    if ok {
        println("  ok: Apple-GPU target tag + SIMD-group=32 + P1 kernel-decl + buffer-pointer + thread-pos constants verified")
    }
    return ok
}

// ── Text inspection (substring CONTAINS helper) ────────────────────

fn _contains(hay: string, needle: string) -> bool {
    return hay.find(needle) >= 0
}

fn _check_contains(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if _contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (missing: `" + needle + "`)")
    return false
}

fn _check_not_contains(ok_in: bool, hay: string, needle: string, label: string) -> bool {
    if !_contains(hay, needle) { return ok_in }
    println("  FAIL: " + label + " (unexpected: `" + needle + "`)")
    return false
}

// ── MIR construction helpers for the vec-add MIR fixture ─────────────

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "", precision: "" }
}

fn _kern_local(id: i64, name: string) -> Local {
    // arena_id 0 = kernel buffer (mirrors `_metal_local_address_space`'s
    // device-memory branch).
    return Local { id: id, arena_id: 0, type_id: 0, name_hint: name, precision: ".f32" }
}

fn _priv_local(id: i64, name: string) -> Local {
    // arena_id > 0 = function-local thread-private (mirrors the
    // _metal_local_address_space "thread" branch).
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name, precision: ".f32" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local", local_id: local_id,
        int_val: 0, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _stmt_load(dst: Local, src_local: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(src_local))
    return Stmt {
        kind: STMT_LOAD, dst: dst, op: "load", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_store(src: Local, dst_local: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(src.id))
    xs.push(_op_local(dst_local))
    return Stmt {
        kind: STMT_STORE, dst: _miss_local(), op: "store", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_binop_add(dst: Local, lhs: i64, rhs: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(lhs))
    xs.push(_op_local(rhs))
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: "add", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_binop_mul(dst: Local, lhs: i64, rhs: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(lhs))
    xs.push(_op_local(rhs))
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: "mul", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_binop_sub(dst: Local, lhs: i64, rhs: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(lhs))
    xs.push(_op_local(rhs))
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: "sub", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_binop_div(dst: Local, lhs: i64, rhs: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(lhs))
    xs.push(_op_local(rhs))
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: "div", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _op_const_float(v: f64) -> Operand {
    return Operand {
        kind: "const_float", local_id: -1,
        int_val: 0, float_val: v, str_val: "", global_id: -1
    }
}

// vec-scale BINOP: args[0] = local (lhs), args[1] = const_float (rhs).
fn _stmt_binop_mul_scalar(dst: Local, lhs: i64, scalar: f64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(lhs))
    xs.push(_op_const_float(scalar))
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: "mul", args: xs,
        target_block: -1, target_block_else: -1
    }
}

// reduce-sum UNOP: args[0] = local (input value loaded from a[i]).
// Synthetic MIR shape for the FIRST non-element-wise codegen recogniser
// (no real parser/lowering produces this today — see
// `_metal_mfunc_is_reduce_sum_shape` docstring for the scaffold note).
fn _stmt_unop_reduce_sum(dst: Local, src: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(src))
    return Stmt {
        kind: STMT_UNOP, dst: dst, op: "reduce_sum", args: xs,
        target_block: -1, target_block_else: -1
    }
}

fn _stmt_return() -> Stmt {
    return Stmt {
        kind: STMT_RETURN, dst: _miss_local(), op: "", args: [],
        target_block: -1, target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

fn _build_vec_add_module() -> MModule {
    // Three kernel-buffer params (a, b, c) + three load/binop/store
    // Locals (va, vb, vc). The exact stmt sequence the P3 emitter
    // recognises: STMT_LOAD a→va, STMT_LOAD b→vb, STMT_BINOP_ADD
    // (va, vb)→vc, STMT_STORE vc→c.
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_add(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "vec_add",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "metal_vec_add.hexa", funcs: fns, globals: [] }
}

// ── Case 3 — F-RFC075-METAL-EMIT-VEC-ADD ─────────────────────────────
//
// Synthesise a vec-add MIR module, invoke `codegen_emit_metal_msl`, and
// assert the emitted MSL kernel source contains the load-bearing source-
// text fragments (kernel decl, device pointer typing, thread-position
// attribute, c[i] / a[i] / b[i] index expressions, addition operator).
//
// This is the RFC 075 §5 falsifier F-RFC075-METAL-EMIT-VEC-ADD — the
// counterpart of the NVPTX vec-add emit smoke. P3 (codegen-only)
// closes this falsifier; P4 silicon-fire stays on `[ ]` until the
// follow-on USER-LOCAL Mac cycle.

fn _test_vec_add_emit() -> bool {
    let mut ok = true
    let mod_va = _build_vec_add_module()
    let msl = codegen_emit_metal_msl(mod_va)

    println("")
    println("── emitted MSL (RFC 075 P3 vec-add case) ──")
    println(msl)

    // F-RFC075-METAL-EMIT-VEC-ADD substring battery —
    ok = _check_contains(ok, msl, "#include <metal_stdlib>",     "MSL preamble include")
    ok = _check_contains(ok, msl, "using namespace metal;",      "MSL namespace using-directive")
    ok = _check_contains(ok, msl, "kernel void",                 "kernel declaration `kernel void`")
    ok = _check_contains(ok, msl, "vec_add",                     "kernel name from MFunc.name")
    ok = _check_contains(ok, msl, "device const float*",         "read-only device pointer parameter")
    ok = _check_contains(ok, msl, "device float*",               "writable device pointer parameter")
    ok = _check_contains(ok, msl, "[[buffer(0)]]",               "buffer(0) binding attribute")
    ok = _check_contains(ok, msl, "[[buffer(1)]]",               "buffer(1) binding attribute")
    ok = _check_contains(ok, msl, "[[buffer(2)]]",               "buffer(2) binding attribute")
    ok = _check_contains(ok, msl, "[[thread_position_in_grid]]", "thread-position attribute")
    ok = _check_contains(ok, msl, "c[i]",                        "writable buffer index `c[i]`")
    ok = _check_contains(ok, msl, "a[i]",                        "read buffer index `a[i]`")
    ok = _check_contains(ok, msl, "b[i]",                        "read buffer index `b[i]`")
    ok = _check_contains(ok, msl, " + ",                         "addition operator between loaded values")
    ok = _check_contains(ok, msl, ";",                           "statement terminator")
    return ok
}

// ── Case 4 — P2 classifier helpers ──────────────────────────────────
//
// `_metal_local_address_space` returns METAL_AS_DEVICE for arena_id 0
// (kernel buffer) and METAL_AS_THREAD otherwise. `_metal_local_precision`
// honours the per-Local precision tag (.f32 / .f16 / etc.) and falls
// back to FP32.

fn _test_classifier_helpers() -> bool {
    let mut ok = true
    let kbuf = _kern_local(0, "kbuf")
    let pvar = _priv_local(1, "pvar")
    let untag = Local { id: 2, arena_id: 1, type_id: 0, name_hint: "untag", precision: "" }

    if _metal_local_address_space(kbuf) != METAL_AS_DEVICE {
        println("  FAIL: kernel-buffer Local should classify as device (got '" + _metal_local_address_space(kbuf) + "')")
        ok = false
    }
    if _metal_local_address_space(pvar) != METAL_AS_THREAD {
        println("  FAIL: function-local Local should classify as thread (got '" + _metal_local_address_space(pvar) + "')")
        ok = false
    }
    if _metal_local_precision(kbuf) != METAL_PRECISION_F32 {
        println("  FAIL: .f32-tagged Local should classify as float (got '" + _metal_local_precision(kbuf) + "')")
        ok = false
    }
    if _metal_local_precision(untag) != METAL_PRECISION_F32 {
        println("  FAIL: untagged Local should default to FP32 (got '" + _metal_local_precision(untag) + "')")
        ok = false
    }
    if ok {
        println("  ok: P2 classifier helpers — device/thread address-space + FP32 default")
    }
    return ok
}

// ── vec-mul MIR fixture (Case 5) ─────────────────────────────────────

fn _build_vec_mul_module() -> MModule {
    // Mirror of `_build_vec_add_module` with the BINOP op switched to
    // "mul". Three kernel-buffer params (a, b, c) + three load/binop/
    // store Locals (va, vb, vc). Stmt sequence: STMT_LOAD a→va,
    // STMT_LOAD b→vb, STMT_BINOP_MUL (va, vb)→vc, STMT_STORE vc→c.
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_mul(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "vec_mul",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "metal_vec_mul.hexa", funcs: fns, globals: [] }
}

// ── Case 5 — F-RFC075-METAL-EMIT-VEC-MUL ─────────────────────────────
//
// Synthesise a vec-mul MIR module, invoke `codegen_emit_metal_msl`, and
// assert the emitted MSL kernel source contains the same load-bearing
// source-text fragments as vec-add (kernel decl, device pointer typing,
// thread-position attribute, c[i] / a[i] / b[i] index expressions),
// PLUS the multiplication operator. Also asserts the addition operator
// is ABSENT — vec-mul must not accidentally inherit vec-add's `+`.

fn _test_vec_mul_emit() -> bool {
    let mut ok = true
    let mod_vm = _build_vec_mul_module()
    let msl = codegen_emit_metal_msl(mod_vm)

    println("")
    println("── emitted MSL (RFC 075 P3+ vec-mul case) ──")
    println(msl)

    // F-RFC075-METAL-EMIT-VEC-MUL substring battery —
    ok = _check_contains(ok, msl, "#include <metal_stdlib>",     "MSL preamble include")
    ok = _check_contains(ok, msl, "using namespace metal;",      "MSL namespace using-directive")
    ok = _check_contains(ok, msl, "kernel void",                 "kernel declaration `kernel void`")
    ok = _check_contains(ok, msl, "vec_mul",                     "kernel name from MFunc.name")
    ok = _check_contains(ok, msl, "device const float*",         "read-only device pointer parameter")
    ok = _check_contains(ok, msl, "device float*",               "writable device pointer parameter")
    ok = _check_contains(ok, msl, "[[buffer(0)]]",               "buffer(0) binding attribute")
    ok = _check_contains(ok, msl, "[[buffer(1)]]",               "buffer(1) binding attribute")
    ok = _check_contains(ok, msl, "[[buffer(2)]]",               "buffer(2) binding attribute")
    ok = _check_contains(ok, msl, "[[thread_position_in_grid]]", "thread-position attribute")
    ok = _check_contains(ok, msl, "c[i]",                        "writable buffer index `c[i]`")
    ok = _check_contains(ok, msl, "a[i]",                        "read buffer index `a[i]`")
    ok = _check_contains(ok, msl, "b[i]",                        "read buffer index `b[i]`")
    ok = _check_contains(ok, msl, " * ",                         "multiplication operator between loaded values")
    ok = _check_contains(ok, msl, ";",                           "statement terminator")
    // Negative — vec-mul must NOT carry vec-add's plus operator.
    ok = _check_not_contains(ok, msl, " + ",                     "vec-mul should not emit ` + ` (vec-add inheritance check)")
    return ok
}

// ── vec-scale MIR fixture (Case 6) ───────────────────────────────────

fn _build_vec_scale_module() -> MModule {
    // Two kernel-buffer params (a, c) + two load/store Locals (va, vc).
    // Stmt sequence: STMT_LOAD a→va, STMT_BINOP_MUL (va, const_float
    // 2.5)→vc, STMT_STORE vc→c. The const operand sits at args[1],
    // matching `_metal_mfunc_is_vec_scale_shape`'s lhs-local · rhs-const
    // expectation.
    let a  = _kern_local(0, "a")
    let c  = _kern_local(1, "c")
    let va = _priv_local(2, "va")
    let vc = _priv_local(3, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_binop_mul_scalar(vc, va.id, 2.5))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(c)
    locals.push(va)
    locals.push(vc)

    let mf = MFunc {
        name: "vec_scale",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "metal_vec_scale.hexa", funcs: fns, globals: [] }
}

// ── Case 6 — F-RFC075-METAL-EMIT-VEC-SCALE ───────────────────────────
//
// Synthesise a vec-scale MIR module (a[i] * 2.5 → c[i]), invoke
// `codegen_emit_metal_msl`, and assert the emitted MSL kernel source
// contains the scalar literal, the `*` operator, `a[i]` and `c[i]`,
// and the preamble + signature. Asserts the addition operator is
// ABSENT and `b[i]` index does NOT appear inside the body (vec-scale
// has no second device buffer load — single-input kernel). Reuses the
// same signature emitter as vec-add / vec-mul today; future cycles may
// emit a 2-buffer signature when the shape demands it.

fn _test_vec_scale_emit() -> bool {
    let mut ok = true
    let mod_vs = _build_vec_scale_module()
    let msl = codegen_emit_metal_msl(mod_vs)

    println("")
    println("── emitted MSL (RFC 075 P3+ vec-scale case) ──")
    println(msl)

    // F-RFC075-METAL-EMIT-VEC-SCALE substring battery —
    ok = _check_contains(ok, msl, "#include <metal_stdlib>",     "MSL preamble include")
    ok = _check_contains(ok, msl, "using namespace metal;",      "MSL namespace using-directive")
    ok = _check_contains(ok, msl, "kernel void",                 "kernel declaration `kernel void`")
    ok = _check_contains(ok, msl, "vec_scale",                   "kernel name from MFunc.name")
    ok = _check_contains(ok, msl, "[[thread_position_in_grid]]", "thread-position attribute")
    ok = _check_contains(ok, msl, "c[i]",                        "writable buffer index `c[i]`")
    ok = _check_contains(ok, msl, "a[i]",                        "read buffer index `a[i]`")
    ok = _check_contains(ok, msl, " * ",                         "multiplication operator between load + scalar")
    ok = _check_contains(ok, msl, "2.5",                         "scalar literal 2.5 in emitted body")
    ok = _check_contains(ok, msl, ";",                           "statement terminator")
    // Negative — vec-scale must NOT emit `+`.
    ok = _check_not_contains(ok, msl, " + ",                     "vec-scale should not emit ` + ` (binop guard)")
    return ok
}

// ── vec-sub MIR fixture (Case 7) ─────────────────────────────────────

fn _build_vec_sub_module() -> MModule {
    // Mirror of `_build_vec_add_module` with the BINOP op switched to
    // "sub". Three kernel-buffer params (a, b, c) + three load/binop/
    // store Locals (va, vb, vc). Stmt sequence: STMT_LOAD a→va,
    // STMT_LOAD b→vb, STMT_BINOP_SUB (va, vb)→vc, STMT_STORE vc→c.
    let a  = _kern_local(0, "a")
    let b  = _kern_local(1, "b")
    let c  = _kern_local(2, "c")
    let va = _priv_local(3, "va")
    let vb = _priv_local(4, "vb")
    let vc = _priv_local(5, "vc")

    let mut s = []
    s.push(_stmt_load(va, a.id))
    s.push(_stmt_load(vb, b.id))
    s.push(_stmt_binop_sub(vc, va.id, vb.id))
    s.push(_stmt_store(vc, c.id))
    s.push(_stmt_return())

    let mut blocks = []
    blocks.push(_block(0, s))

    let mut params = []
    params.push(a)
    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "vec_sub",
        params: params,
        return_local: _miss_local(),
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1,
        def_line: 0,
        gpu_kind: GPU_KIND_KERNEL
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "metal_vec_sub.hexa", funcs: fns, globals: [] }
}

// ── Case 7 — F-RFC075-METAL-EMIT-VEC-SUB ─────────────────────────────
//
// Synthesise a vec-sub MIR module, invoke `codegen_emit_metal_msl`, and
// assert the emitted MSL kernel source contains the same load-bearing
// source-text fragments as vec-add (kernel decl, device pointer typing,
// thread-position attribute, c[i] / a[i] / b[i] index expressions),
// PLUS the subtraction operator. Also asserts the addition and
// multiplication operators are ABSENT — vec-sub must not accidentally
// inherit vec-add's `+` or vec-mul's `*`.

fn _test_vec_sub_emit() -> bool {
    let mut ok = true
    let mod_vs = _build_vec_sub_module()
    let msl = codegen_emit_metal_msl(mod_vs)

