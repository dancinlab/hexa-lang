    ok = _check_not_contains(ok, msl, "b_row = kk * 8u + r",          "matmul_NT_b must not use plain-matmul B K-band row")
    return ok
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  RFC 075 P1+P2+P3+ — Metal codegen smoke")
    println("══════════════════════════════════════════════")

    let ok_emit   = _test_p0_empty_emit()
    let ok_tgt    = _test_target_constants()
    let ok_vec    = _test_vec_add_emit()
    let ok_class  = _test_classifier_helpers()
    let ok_vmul   = _test_vec_mul_emit()
    let ok_vscale = _test_vec_scale_emit()
    let ok_vsub   = _test_vec_sub_emit()
    let ok_vdiv   = _test_vec_div_emit()
    let ok_vneg   = _test_vec_neg_emit()
    let ok_vabs   = _test_vec_abs_emit()
    let ok_vsqrt  = _test_vec_sqrt_emit()
    let ok_vexp   = _test_vec_exp_emit()
    let ok_vlog   = _test_vec_log_emit()
    let ok_vsin   = _test_vec_sin_emit()
    let ok_vcos   = _test_vec_cos_emit()
    let ok_mm     = _test_matmul_emit()
    let ok_mm_nta = _test_matmul_NT_a_emit()
    let ok_mm_ntb = _test_matmul_NT_b_emit()

    println("")
    if ok_emit && ok_tgt && ok_vec && ok_class && ok_vmul && ok_vscale && ok_vsub && ok_vdiv && ok_vneg && ok_vabs && ok_vsqrt && ok_vexp && ok_vlog && ok_vsin && ok_vcos && ok_mm && ok_mm_nta && ok_mm_ntb {
        println("  PASS: RFC 075 P1+P2+P3+ Metal codegen smoke (vec-add + vec-mul + vec-sub + vec-div + vec-scale + vec-neg + vec-abs + vec-sqrt + vec-exp + vec-log + vec-sin + vec-cos + matmul + matmul_NT_a + matmul_NT_b)")
    } else {
        println("  FAIL: RFC 075 P1+P2+P3+ Metal codegen smoke")
    }
}
