    return MModule { file: "metal_matmul_NT_a.hexa", funcs: fns, globals: [] }
}

// ── Case 17 — F-RFC075-METAL-EMIT-MATMUL-NT-A ────────────────────────
//
// Synthesise a matmul_NT_a MIR module (`C = A^T · B`, A is K×M
// row-major), invoke `codegen_emit_metal_msl`, and assert the emitted
// MSL kernel source uses the MMA preamble + 6-buffer signature + the
// simdgroup-MMA body with A-side transpose-load (`simdgroup_load(...,
// true)` for Amat). Used by flame ag_linear backward `dW = x^T · dy`.
//
// Substring battery (positive + negative):
//   - All N24 baseline positives (MMA preamble, 6-arg sig, MMA
//     intrinsics, threadgroup-mem staging, K-loop scaffolding).
//   - Kernel name "matmul_NT_a".
//   - At least one `simdgroup_load(... , true)` invocation (transpose
//     flag on A path).
//   - At least one `simdgroup_load(... , false)` invocation (B path
//     remains identical to plain matmul).
//   - Negative guards: must NOT emit element-wise patterns; must NOT
//     emit the plain-matmul A indexing `a_col = kk * 8u + cc` (the
//     NT-A A path uses `a_col = block_row_base + cc`).

fn _test_matmul_NT_a_emit() -> bool {
    let mut ok = true
    let mod_mm = _build_matmul_NT_a_module()
    let msl = codegen_emit_metal_msl(mod_mm)

    println("")
    println("── emitted MSL (RFC 075 P3+ matmul_NT_a / MMA case) ──")
    println(msl)

    // F-RFC075-METAL-EMIT-MATMUL-NT-A substring battery — positives.
    ok = _check_contains(ok, msl, "#include <metal_stdlib>",          "MSL preamble include")
    ok = _check_contains(ok, msl, "#include <metal_simdgroup_matrix>","MMA simdgroup-matrix header include")
    ok = _check_contains(ok, msl, "using namespace metal;",           "MSL namespace using-directive")
    ok = _check_contains(ok, msl, "kernel void",                      "kernel declaration `kernel void`")
    ok = _check_contains(ok, msl, "matmul_NT_a",                      "kernel name from MFunc.name")
    ok = _check_contains(ok, msl, "device const float*",              "read-only device pointer parameter")
    ok = _check_contains(ok, msl, "device float*",                    "writable device pointer parameter")
    ok = _check_contains(ok, msl, "[[buffer(0)]]",                    "buffer(0) binding (a)")
    ok = _check_contains(ok, msl, "[[buffer(1)]]",                    "buffer(1) binding (b)")
    ok = _check_contains(ok, msl, "[[buffer(2)]]",                    "buffer(2) binding (c)")
    ok = _check_contains(ok, msl, "[[buffer(3)]]",                    "buffer(3) binding (M dim)")
    ok = _check_contains(ok, msl, "[[buffer(4)]]",                    "buffer(4) binding (N dim)")
    ok = _check_contains(ok, msl, "[[buffer(5)]]",                    "buffer(5) binding (K dim)")
    ok = _check_contains(ok, msl, "constant uint& M",                 "constant scalar M param")
    ok = _check_contains(ok, msl, "constant uint& N",                 "constant scalar N param")
    ok = _check_contains(ok, msl, "constant uint& K",                 "constant scalar K param")
    ok = _check_contains(ok, msl, "[[simdgroup_index_in_threadgroup]]","sgid attribute")
    ok = _check_contains(ok, msl, "[[thread_index_in_simdgroup]]",    "slid attribute")
    ok = _check_contains(ok, msl, "[[threadgroup_position_in_grid]]", "tgid attribute")
    ok = _check_contains(ok, msl, "[[thread_position_in_threadgroup]]","lid attribute")
    ok = _check_contains(ok, msl, "simdgroup_matrix<float, 8, 8>",    "MMA tile type")
    ok = _check_contains(ok, msl, "make_filled_simdgroup_matrix",     "MMA accumulator constructor")
    ok = _check_contains(ok, msl, "simdgroup_load",                   "MMA load intrinsic")
    ok = _check_contains(ok, msl, "simdgroup_multiply_accumulate",    "MMA multiply-accumulate intrinsic")
    ok = _check_contains(ok, msl, "simdgroup_store",                  "MMA store intrinsic")
    ok = _check_contains(ok, msl, "threadgroup float As[",            "threadgroup-mem A slab")
    ok = _check_contains(ok, msl, "threadgroup float Bs[",            "threadgroup-mem B slab")
    ok = _check_contains(ok, msl, "threadgroup_barrier",              "threadgroup barrier (sync)")
    ok = _check_contains(ok, msl, "mem_flags::mem_threadgroup",       "threadgroup-mem fence flag")
    ok = _check_contains(ok, msl, "for (uint kk",                     "K-loop control")
    ok = _check_contains(ok, msl, "K8",                               "K/8 derived loop bound")
    // NT-A specific: simdgroup_load(Amat, As, ulong(TG_M), ..., true)
    // — the transpose=true flag on the A path is the defining feature.
    ok = _check_contains(ok, msl, "(Amat, As, ulong(TG_M)",           "NT-A: Amat loads from As with TG_M row-stride")
    ok = _check_contains(ok, msl, ", true);",                         "NT-A: at least one transpose=true simdgroup_load")
    // NT-A specific: B path is unchanged (Bmat with transpose=false).
    ok = _check_contains(ok, msl, "(Bmat, Bs, ulong(TG_N)",           "NT-A: Bmat loads from Bs with TG_N row-stride (plain)")
    ok = _check_contains(ok, msl, ", false);",                        "NT-A: B path uses transpose=false")
    // NT-A specific: A cooperative load uses transposed-natural indexing
    // — `a_col = block_row_base + cc` (M-band) instead of plain
    // matmul's `a_col = kk * 8u + cc` (K-band).
    ok = _check_contains(ok, msl, "a_col = block_row_base + cc",      "NT-A: A cooperative-load col indexes M-band")
    ok = _check_contains(ok, msl, "a_row = kk * 8u + r",              "NT-A: A cooperative-load row indexes K-band")
    ok = _check_contains(ok, msl, "a[a_row * M + a_col]",             "NT-A: A read uses K×M row-major stride M")

    // Negative guards.
    ok = _check_not_contains(ok, msl, "b[i]",                         "matmul_NT_a should not emit `b[i]` (element-wise guard)")
    ok = _check_not_contains(ok, msl, "c[i] = a[i] + b[i]",           "matmul_NT_a should not emit vec-add body")
    ok = _check_not_contains(ok, msl, "c[i] = a[i] * b[i]",           "matmul_NT_a should not emit vec-mul body")
    // Must NOT use the plain matmul A indexing (a_col = kk * 8u + cc).
    ok = _check_not_contains(ok, msl, "a_col = kk * 8u + cc",         "matmul_NT_a must not use plain-matmul A K-band col")
    return ok
}

// ── matmul_NT_b MIR fixture (Case 18) ────────────────────────────────
//
// Synthetic MMA matmul_NT_b (B transposed) MIR shape — STMT_LOAD a→va
// + STMT_LOAD b→vb + STMT_BINOP("matmul_NT_b") (va, vb)→vc + STMT_STORE
// vc→c. Drives the `_metal_mfunc_is_matmul_NT_b_shape` recogniser and
