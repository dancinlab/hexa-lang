    ok = _check_not_contains(ok, msl, " + ",                     "vec-exp should not emit ` + ` (binop guard)")
    ok = _check_not_contains(ok, msl, " * ",                     "vec-exp should not emit ` * ` (binop guard)")
    return ok
}

