    params.push(b)
    params.push(c)
    let mut locals = []
    locals.push(a)
    locals.push(b)
    locals.push(c)
    locals.push(va)
    locals.push(vb)
    locals.push(vc)

    let mf = MFunc {
        name: "matmul_NT_a",
        params: params,
