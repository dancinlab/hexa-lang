// ── RFC 075 P1++ — matmul kernel signature + body helpers ───────────
//
// AMD lane WMMA matmul. The kernel signature for the matmul shape is
// distinct from the vec-* shapes: three FP32 device buffers (a, b, c)
// PLUS three integer dimensions (M, N, K) — no element-count `n`
// because the iteration domain is the (M,N) output tile space, not a
// flat 1-D length.
//
// HARDWARE COMPAT (cited above on ROCM_OP_PREAMBLE_ROCWMMA): the emitted
// `rocwmma::fragment<..., 16, 16, 16, float, ...>` requires CDNA2+
// (gfx90a / MI200+) or RDNA3+ (gfx1100+) at runtime — `hipcc` will
// accept the source against earlier targets only if the host falls back
// to the rocwmma emulated path. The emit pass does NOT enforce a target
// gate (codegen-only); the LModule target enum constants above already
// reflect this baseline (gfx1100+ scaffold).

// _rocm_emit_matmul_kernel_signature — emit
//   extern "C" __global__ void <name>(const float* a, const float* b,
//                                     float* c, int M, int N, int K)
// 3-buffer + 3-dim signature used by all three matmul shapes. Mirrors
// the canonical cuBLAS / hipBLAS SGEMM-style kernel-argument layout
// (A, B, C, M, N, K — the inner dims for hipBLASLt + rocWMMA examples).
fn _rocm_emit_matmul_kernel_signature(name: string) -> string {
    let mut out = ROCM_OP_KERNEL_DECL + " " + name + "("
    out = out + ROCM_OP_PARAM_CONST_FLOAT_PTR + "a, "
    out = out + ROCM_OP_PARAM_CONST_FLOAT_PTR + "b, "
    out = out + ROCM_OP_PARAM_FLOAT_PTR + "c, "
    out = out + ROCM_OP_PARAM_INT + "M, "
    out = out + ROCM_OP_PARAM_INT + "N, "
    out = out + ROCM_OP_PARAM_INT + "K)\n"
    return out
}

// _rocm_emit_matmul_body — emit the HIP/rocWMMA kernel body for the
// canonical matmul `c = a · b` (A row-major MxK, B col-major KxN, C
// row-major MxN). The block layout is one 16x16 output tile per
// wavefront — block coordinates (blockIdx.y, blockIdx.x) pick the
// (row_tile, col_tile) and the wavefront cooperatively executes the
// K-loop using `rocwmma::mma_sync`.
//
// Hardcoded shape: `c = a · b` with the canonical row_major(A) +
// col_major(B) layout pair. This is the layout the rocwmma tutorial
// uses; matmul_NT_a (A transposed → col_major) and matmul_NT_b (B
// transposed → row_major) are separate emit paths below.
//
// Emitted body (illustrative):
//   {
//       int row_tile = blockIdx.y * 16;
//       int col_tile = blockIdx.x * 16;
//       rocwmma::fragment<rocwmma::matrix_a, 16, 16, 16, float, rocwmma::row_major> a_frag;
//       rocwmma::fragment<rocwmma::matrix_b, 16, 16, 16, float, rocwmma::col_major> b_frag;
//       rocwmma::fragment<rocwmma::accumulator, 16, 16, 16, float> c_frag;
//       rocwmma::fill_fragment(c_frag, 0.0f);
//       for (int k = 0; k < K; k += 16) {
//           rocwmma::load_matrix_sync(a_frag, &a[row_tile * K + k], K);
//           rocwmma::load_matrix_sync(b_frag, &b[k * N + col_tile], N);
//           rocwmma::mma_sync(c_frag, a_frag, b_frag, c_frag);
//       }
//       rocwmma::store_matrix_sync(&c[row_tile * N + col_tile], c_frag, N, rocwmma::mem_row_major);
//   }
fn _rocm_emit_matmul_body() -> string {
    let mut out = "{\n"
    out = out + "    " + ROCM_TYPE_INT + " row_tile" + ROCM_OP_ASSIGN
    out = out + "blockIdx.y * " + ROCM_WMMA_TILE_M_LIT + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_TYPE_INT + " col_tile" + ROCM_OP_ASSIGN
    out = out + "blockIdx.x * " + ROCM_WMMA_TILE_N_LIT + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_A_ROW + " a_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_B_COL + " b_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_C     + " c_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FILL + "(c_frag, 0.0f)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    for (" + ROCM_TYPE_INT + " k = 0; k < K; k += " + ROCM_WMMA_TILE_K_LIT + ") {\n"
    out = out + "        " + ROCM_OP_WMMA_LOAD + "(a_frag, &a[row_tile * K + k], K)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "        " + ROCM_OP_WMMA_LOAD + "(b_frag, &b[k * N + col_tile], N)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "        " + ROCM_OP_WMMA_MMA + "(c_frag, a_frag, b_frag, c_frag)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    }\n"
    out = out + "    " + ROCM_OP_WMMA_STORE + "(&c[row_tile * N + col_tile], c_frag, N, " + ROCM_OP_WMMA_MEM_ROW + ")" + ROCM_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

// _rocm_emit_matmul_NT_a_body — emit the HIP/rocWMMA kernel body for
// `c = a^T · b`. A is column-major (transposed-A interpretation), B is
// column-major. Mirror of `_rocm_emit_matmul_body` with the A fragment
// layout swapped from row_major to col_major, and the A-load address
// arithmetic swapped to column-major indexing (`&a[k * M + row_tile]`,
// stride M instead of K). B stays col_major.
fn _rocm_emit_matmul_NT_a_body() -> string {
    let mut out = "{\n"
    out = out + "    " + ROCM_TYPE_INT + " row_tile" + ROCM_OP_ASSIGN
    out = out + "blockIdx.y * " + ROCM_WMMA_TILE_M_LIT + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_TYPE_INT + " col_tile" + ROCM_OP_ASSIGN
    out = out + "blockIdx.x * " + ROCM_WMMA_TILE_N_LIT + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_A_COL + " a_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_B_COL + " b_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_C     + " c_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FILL + "(c_frag, 0.0f)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    for (" + ROCM_TYPE_INT + " k = 0; k < K; k += " + ROCM_WMMA_TILE_K_LIT + ") {\n"
    out = out + "        " + ROCM_OP_WMMA_LOAD + "(a_frag, &a[k * M + row_tile], M)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "        " + ROCM_OP_WMMA_LOAD + "(b_frag, &b[k * N + col_tile], N)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "        " + ROCM_OP_WMMA_MMA + "(c_frag, a_frag, b_frag, c_frag)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    }\n"
    out = out + "    " + ROCM_OP_WMMA_STORE + "(&c[row_tile * N + col_tile], c_frag, N, " + ROCM_OP_WMMA_MEM_ROW + ")" + ROCM_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

// _rocm_emit_matmul_NT_b_body — emit the HIP/rocWMMA kernel body for
// `c = a · b^T`. A is row-major, B is row-major (transposed-B
// interpretation flips the canonical col_major default to row_major).
// Mirror of `_rocm_emit_matmul_body` with the B fragment layout swapped
// from col_major to row_major, and the B-load address arithmetic
// swapped to row-major indexing (`&b[col_tile * K + k]`, stride K
// instead of N). A stays row_major.
fn _rocm_emit_matmul_NT_b_body() -> string {
    let mut out = "{\n"
    out = out + "    " + ROCM_TYPE_INT + " row_tile" + ROCM_OP_ASSIGN
    out = out + "blockIdx.y * " + ROCM_WMMA_TILE_M_LIT + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_TYPE_INT + " col_tile" + ROCM_OP_ASSIGN
    out = out + "blockIdx.x * " + ROCM_WMMA_TILE_N_LIT + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_A_ROW + " a_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_B_ROW + " b_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FRAG_C     + " c_frag" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    " + ROCM_OP_WMMA_FILL + "(c_frag, 0.0f)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    for (" + ROCM_TYPE_INT + " k = 0; k < K; k += " + ROCM_WMMA_TILE_K_LIT + ") {\n"
    out = out + "        " + ROCM_OP_WMMA_LOAD + "(a_frag, &a[row_tile * K + k], K)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "        " + ROCM_OP_WMMA_LOAD + "(b_frag, &b[col_tile * K + k], K)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "        " + ROCM_OP_WMMA_MMA + "(c_frag, a_frag, b_frag, c_frag)" + ROCM_OP_STMT_TERM + "\n"
    out = out + "    }\n"
    out = out + "    " + ROCM_OP_WMMA_STORE + "(&c[row_tile * N + col_tile], c_frag, N, " + ROCM_OP_WMMA_MEM_ROW + ")" + ROCM_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
}

// _rocm_mfunc_is_vec_add_shape — recognise the vec-add MIR shape.
// Hardcoded shape check: entry block has exactly STMT_LOAD + STMT_LOAD
// + STMT_BINOP("add") + STMT_STORE (in that order), plus an optional
// STMT_RETURN at the end. Anything else returns false and the emitter
// falls through to the honest empty-string path. Same shape signature
// as `_metal_mfunc_is_vec_add_shape` in the Metal codegen — both
// vendors decode the same canonical vec-add MIR pattern.
fn _rocm_mfunc_is_vec_add_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "add" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _rocm_mfunc_is_vec_mul_shape — recognise the vec-mul MIR shape.
// Mirror of `_rocm_mfunc_is_vec_add_shape` with the BINOP op string
// switched to "mul". Same STMT_LOAD + STMT_LOAD + STMT_BINOP("mul") +
// STMT_STORE skeleton (with optional STMT_RETURN tail). NOTE: this
// recogniser fires AFTER the vec-scale recogniser to avoid catching
// the const-rhs `a[i] * <scalar>` pattern (vec-scale has only ONE
// STMT_LOAD); on a 4-stmt 2-LOAD prefix vec-scale never matches.
fn _rocm_mfunc_is_vec_mul_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "mul" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _rocm_mfunc_is_vec_sub_shape — recognise the vec-sub MIR shape.
// Mirror of `_rocm_mfunc_is_vec_add_shape` with the BINOP op string
// switched to "sub".
fn _rocm_mfunc_is_vec_sub_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "sub" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _rocm_mfunc_is_vec_div_shape — recognise the vec-div MIR shape.
// Mirror of `_rocm_mfunc_is_vec_add_shape` with the BINOP op string
// switched to "div".
fn _rocm_mfunc_is_vec_div_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "div" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _rocm_mfunc_is_vec_scale_shape — recognise the vec-scale MIR shape.
// Skeleton: STMT_LOAD a→va, STMT_BINOP("mul") with operands
// (Operand{kind="local"}, Operand{kind="const_float"|"const_int"}),
// STMT_STORE vc→c (optional STMT_RETURN tail). The const operand
// position is fixed at args[1] (lhs local · rhs const) — the canonical
// `a[i] * <scalar>` lowering order. Anything else falls through.
// Mirror of `_metal_mfunc_is_vec_scale_shape`.
fn _rocm_mfunc_is_vec_scale_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 3 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_BINOP { return false }
    if stmts[1].op != "mul" { return false }
    if stmts[2].kind != STMT_STORE { return false }
    // BINOP args[0] = lhs local, args[1] = rhs const literal.
    let binop_args = stmts[1].args
    if len(binop_args) < 2 { return false }
    if binop_args[0].kind != "local" { return false }
    let rhs_kind = binop_args[1].kind
    if rhs_kind != "const_float" {
        if rhs_kind != "const_int" { return false }
    }
    return true
}

// _rocm_mfunc_is_reduce_sum_shape — recognise the reduce-sum MIR shape.
//
// SYNTHETIC MIR SHAPE — STMT_LOAD a→va, STMT_UNOP("reduce_sum", va)→vc,
// STMT_STORE vc→c. Mirror of `_metal_mfunc_is_reduce_sum_shape`. No
// HIR / parser produces this opcode today; the recogniser is scaffold
// for the future `sum(array)` lowering on the AMD lane.
fn _rocm_mfunc_is_reduce_sum_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 3 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_UNOP { return false }
    if stmts[1].op != "reduce_sum" { return false }
    if stmts[2].kind != STMT_STORE { return false }
    return true
}

// ── RFC 075 P1++ — matmul MIR shape recognisers ─────────────────────
//
// SYNTHETIC MIR SHAPE — STMT_LOAD a→va, STMT_LOAD b→vb,
// STMT_BINOP("matmul"/"matmul_NT_a"/"matmul_NT_b")(va, vb)→vc,
// STMT_STORE vc→c. Mirrors the Metal lane's matmul shape recogniser
// pattern (synthetic — no HIR/parser produces these op strings today;
// they are scaffold for the future `a @ b` / `a.T @ b` / `a @ b.T`
// lowering on the AMD lane). The matmul recognisers fire AFTER vec-add /
// vec-mul / vec-sub / vec-div because all four share the 4-stmt
// LOAD+LOAD+BINOP+STORE prefix; the BINOP op string is the per-shape
// discriminator.

// _rocm_mfunc_is_matmul_shape — recognise the matmul MIR shape.
// STMT_LOAD + STMT_LOAD + STMT_BINOP("matmul") + STMT_STORE skeleton.
fn _rocm_mfunc_is_matmul_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _rocm_mfunc_is_matmul_NT_a_shape — recognise the matmul-NT-a MIR
// shape (A transposed; `c = a^T · b`). STMT_LOAD + STMT_LOAD +
// STMT_BINOP("matmul_NT_a") + STMT_STORE.
fn _rocm_mfunc_is_matmul_NT_a_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul_NT_a" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// _rocm_mfunc_is_matmul_NT_b_shape — recognise the matmul-NT-b MIR
// shape (B transposed; `c = a · b^T`). STMT_LOAD + STMT_LOAD +
// STMT_BINOP("matmul_NT_b") + STMT_STORE.
fn _rocm_mfunc_is_matmul_NT_b_shape(mfn: MFunc) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 4 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_LOAD { return false }
    if stmts[2].kind != STMT_BINOP { return false }
    if stmts[2].op != "matmul_NT_b" { return false }
    if stmts[3].kind != STMT_STORE { return false }
    return true
}

// ── RFC 075 P1++ unary — vec-neg/abs/sqrt/exp/log/sin/cos shape recognisers ──
//
// 2-buffer element-wise unary MIR shape: STMT_LOAD a→va, STMT_UNOP(op)
// (va)→vc, STMT_STORE vc→c (optional STMT_RETURN tail). The unary op
// string ("neg" / "abs" / "sqrt" / "exp" / "log" / "sin" / "cos") is
// the per-shape discriminator; the load-unop-store skeleton is
// identical across the seven variants. Element-wise unary; not invoked
// when the MIR has a second STMT_LOAD (binop / scale / matmul dispatch
// wins first). The reduce-sum recogniser ALSO keys on STMT_UNOP but
// uses op string "reduce_sum" — mutually exclusive on the op string.
// Mirrors `_metal_mfunc_is_unary_shape_with_op` row-for-row.

// _rocm_mfunc_is_unary_shape_with_op — shared recogniser for the
// 2-buffer unary element-wise MIR shape. STMT_LOAD + STMT_UNOP(op_name)
// + STMT_STORE skeleton with a single local UNOP operand at args[0].
fn _rocm_mfunc_is_unary_shape_with_op(mfn: MFunc, op_name: string) -> bool {
    if len(mfn.blocks) == 0 { return false }
    let entry = mfn.blocks[0]
    let stmts = entry.stmts
    if len(stmts) < 3 { return false }
    if stmts[0].kind != STMT_LOAD { return false }
    if stmts[1].kind != STMT_UNOP { return false }
    if stmts[1].op != op_name { return false }
    if stmts[2].kind != STMT_STORE { return false }
    // UNOP carries a single local operand (no rhs).
    let unop_args = stmts[1].args
    if len(unop_args) < 1 { return false }
    if unop_args[0].kind != "local" { return false }
    return true
}

// _rocm_mfunc_is_vec_neg_shape — recognise vec-neg MIR shape.
// STMT_LOAD a→va + STMT_UNOP("neg") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_neg_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "neg")
}

// _rocm_mfunc_is_vec_abs_shape — recognise vec-abs MIR shape.
// STMT_LOAD a→va + STMT_UNOP("abs") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_abs_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "abs")
}

// _rocm_mfunc_is_vec_sqrt_shape — recognise vec-sqrt MIR shape.
// STMT_LOAD a→va + STMT_UNOP("sqrt") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_sqrt_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "sqrt")
}

// _rocm_mfunc_is_vec_exp_shape — recognise vec-exp MIR shape.
// STMT_LOAD a→va + STMT_UNOP("exp") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_exp_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "exp")
}

// _rocm_mfunc_is_vec_log_shape — recognise vec-log MIR shape.
// STMT_LOAD a→va + STMT_UNOP("log") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_log_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "log")
}

// _rocm_mfunc_is_vec_sin_shape — recognise vec-sin MIR shape.
// STMT_LOAD a→va + STMT_UNOP("sin") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_sin_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "sin")
}

// _rocm_mfunc_is_vec_cos_shape — recognise vec-cos MIR shape.
// STMT_LOAD a→va + STMT_UNOP("cos") va→vc + STMT_STORE vc→c.
fn _rocm_mfunc_is_vec_cos_shape(mfn: MFunc) -> bool {
    return _rocm_mfunc_is_unary_shape_with_op(mfn, "cos")
}

// _rocm_format_scalar — format a MIR const operand as HIP FP32 literal.
// const_float → uses the `float_val` field (e.g. "2.5"); const_int →
// uses the `int_val` field with `.0f` appended so it stays FP32 in
// HIP. Anything else returns "0.0f" as the safe fallback (callers
// should have already gated by the shape recogniser).
//
// `.0f` suffix is the HIP/C++ FP32 literal form (mirrors Metal's `.0`
// suffix but explicitly FP32 — HIP's default float-literal type is
// `double`, so the `f` suffix prevents implicit FP64 promotion in
// `a[i] * 2.0` style multiplies).
fn _rocm_format_scalar(op: Operand) -> string {
    if op.kind == "const_float" { return to_string(op.float_val) + "f" }
    if op.kind == "const_int" { return to_string(op.int_val) + ".0f" }
    return "0.0f"
}

// codegen_emit_rocm_il — MIR module -> HIP source text.
//
// RFC 075 P1++ LANDED (codegen-only) — emits a full HIP kernel source
// when the first MFunc matches a recognised shape. Otherwise (empty
// module, unrecognised shape) returns `""` honestly, preserving the
// P0 contract the lower_test Case 1 still asserts.
//
// HONEST SCOPE — SIXTEEN shapes recognised today (vec-add, vec-mul,
// vec-sub, vec-div, vec-scale, reduce-sum, matmul, matmul_NT_a,
// matmul_NT_b, vec-neg, vec-abs, vec-sqrt, vec-exp, vec-log, vec-sin,
// vec-cos). All other MIR patterns return `""`. Remaining unary family
// (vec-floor / vec-ceil / vec-round) + bf16 matmul land in
// multi-session follow-on cycles on the AMD lane (mirrors the RFC 075
// plan that staged the Apple Metal lane shape-by-shape across many
// cycles). AMD GPU pool currently empty (N10/N14/N22 BLOCKED) —
// silicon fire deferred until pool stock returns.
//
//   Shape coverage matrix (RFC 075 P1++):
//     vec-add       `c[i] = a[i] + b[i]`     STMT_LOAD+LOAD+BINOP(add)+STORE
//     vec-mul       `c[i] = a[i] * b[i]`     STMT_LOAD+LOAD+BINOP(mul)+STORE
//     vec-sub       `c[i] = a[i] - b[i]`     STMT_LOAD+LOAD+BINOP(sub)+STORE
//     vec-div       `c[i] = a[i] / b[i]`     STMT_LOAD+LOAD+BINOP(div)+STORE
//     vec-scale     `c[i] = a[i] * <const>`  STMT_LOAD+BINOP(mul, const)+STORE
//     reduce-sum    `c[g] = __shfl_xor(...)` STMT_LOAD+UNOP(reduce_sum)+STORE  (2-buf, per-wavefront output)
//     matmul        `c = a · b`              STMT_LOAD+LOAD+BINOP(matmul)+STORE       (rocWMMA 16x16x16 FP32)
//     matmul_NT_a   `c = a^T · b`            STMT_LOAD+LOAD+BINOP(matmul_NT_a)+STORE  (A col_major)
//     matmul_NT_b   `c = a · b^T`            STMT_LOAD+LOAD+BINOP(matmul_NT_b)+STORE  (B row_major)
//     vec-neg       `c[i] = -a[i]`           STMT_LOAD+UNOP(neg)+STORE   (2-buf, prefix `-`)
//     vec-abs       `c[i] = fabsf(a[i])`     STMT_LOAD+UNOP(abs)+STORE   (2-buf)
//     vec-sqrt      `c[i] = sqrtf(a[i])`     STMT_LOAD+UNOP(sqrt)+STORE  (2-buf)
//     vec-exp       `c[i] = expf(a[i])`      STMT_LOAD+UNOP(exp)+STORE   (2-buf)
//     vec-log       `c[i] = logf(a[i])`      STMT_LOAD+UNOP(log)+STORE   (2-buf)
//     vec-sin       `c[i] = sinf(a[i])`      STMT_LOAD+UNOP(sin)+STORE   (2-buf)
//     vec-cos       `c[i] = cosf(a[i])`      STMT_LOAD+UNOP(cos)+STORE   (2-buf)
//
// Dispatch order: vec-add → vec-mul → vec-sub → vec-div → vec-scale →
// reduce-sum → matmul → matmul_NT_a → matmul_NT_b → vec-neg → vec-abs
// → vec-sqrt → vec-exp → vec-log → vec-sin → vec-cos → "". The matmul
// recognisers fire AFTER the binop quartet because all four 4-stmt
// LOAD+LOAD+BINOP+STORE recognisers key on the BINOP op string —
// "add"/"mul"/"sub"/"div" vs "matmul"/"matmul_NT_a"/"matmul_NT_b" are
// mutually exclusive, so ordering inside the BINOP family is for
// readability only. vec-scale is tried before the unary family because
// its recogniser is the most discerning (checks operand kinds) on the
// 3-stmt prefix it shares with the unary family. The element-wise
// unary family is dispatched last (most-discerning last because each
// keys on a distinct STMT_UNOP op string; reduce-sum's "reduce_sum"
// op string keeps it mutually exclusive with the seven unary shapes).
//
// P2+ insertion points:
//   - TODO RFC 075 P2 — remaining unary family (vec-floor / vec-ceil /
//     vec-round, mirror metal_target.hexa next-cycle buildout) + bf16
//     matmul variants.
//   - TODO RFC 075 P3 — silicon fire via `hipcc` + AMD GPU pool host
//     (queued behind AMD pool stock return per N10/N14/N22).
//   - TODO RFC 075 follow-on cycle — general MFunc → HIP emission
//     (replicate `_metal_emit_*` shape against general MIR).
//
// The compiled-path entry name (`codegen_emit_rocm_il`) keeps the
// existing P0 stub signature so `rocm_lower_test.hexa` Case 1
// (empty-module → "") continues to work byte-identically.
pub fn codegen_emit_rocm_il(module: MModule) -> string {
    // P0 contract: empty module → empty string.
    if len(module.funcs) == 0 { return "" }
    let mfn = module.funcs[0]
    let kname = mfn.name
    // vec-add — STMT_LOAD + STMT_LOAD + STMT_BINOP(add) + STMT_STORE.
    if _rocm_mfunc_is_vec_add_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_kernel_signature(kname)
        out = out + _rocm_emit_vec_add_body()
        return out
    }
    // vec-mul — STMT_LOAD + STMT_LOAD + STMT_BINOP(mul) + STMT_STORE.
    if _rocm_mfunc_is_vec_mul_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_kernel_signature(kname)
        out = out + _rocm_emit_vec_mul_body()
        return out
    }
    // vec-sub — STMT_LOAD + STMT_LOAD + STMT_BINOP(sub) + STMT_STORE.
    if _rocm_mfunc_is_vec_sub_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_kernel_signature(kname)
        out = out + _rocm_emit_vec_sub_body()
        return out
    }
    // vec-div — STMT_LOAD + STMT_LOAD + STMT_BINOP(div) + STMT_STORE.
    if _rocm_mfunc_is_vec_div_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_kernel_signature(kname)
        out = out + _rocm_emit_vec_div_body()
        return out
    }
    // vec-scale — STMT_LOAD + STMT_BINOP(mul, const) + STMT_STORE.
    // 2-buffer signature (no `b`), scalar literal embedded inline.
    if _rocm_mfunc_is_vec_scale_shape(mfn) {
        let entry = mfn.blocks[0]
        let scalar = _rocm_format_scalar(entry.stmts[1].args[1])
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_scale_body(scalar)
        return out
    }
    // reduce-sum — STMT_LOAD + STMT_UNOP(reduce_sum) + STMT_STORE.
    // First NON-element-wise shape; emits HIP `__shfl_xor` butterfly
    // reduction + lane-0 gate (analog of Apple `simd_sum`+`simd_is_first`).
    if _rocm_mfunc_is_reduce_sum_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_reduce_sum_body()
        return out
    }
    // matmul — STMT_LOAD + STMT_LOAD + STMT_BINOP(matmul) + STMT_STORE.
    // First non-pointwise shape on the AMD lane; emits rocWMMA
    // `rocwmma::fragment<>` 16x16x16 FP32 WMMA kernel with the canonical
    // row_major(A) + col_major(B) layout pair. Includes the rocwmma
    // header in the preamble. 3-buffer signature + M/N/K dims.
    if _rocm_mfunc_is_matmul_shape(mfn) {
        let mut out = _rocm_emit_matmul_preamble()
        out = out + _rocm_emit_matmul_kernel_signature(kname)
        out = out + _rocm_emit_matmul_body()
        return out
    }
    // matmul_NT_a — STMT_LOAD + STMT_LOAD + STMT_BINOP(matmul_NT_a) +
    // STMT_STORE. A-transposed matmul (`c = a^T · b`); A fragment is
    // col_major + A-load stride switches from K to M.
    if _rocm_mfunc_is_matmul_NT_a_shape(mfn) {
        let mut out = _rocm_emit_matmul_preamble()
        out = out + _rocm_emit_matmul_kernel_signature(kname)
        out = out + _rocm_emit_matmul_NT_a_body()
        return out
    }
    // matmul_NT_b — STMT_LOAD + STMT_LOAD + STMT_BINOP(matmul_NT_b) +
    // STMT_STORE. B-transposed matmul (`c = a · b^T`); B fragment is
    // row_major + B-load stride switches from N to K.
    if _rocm_mfunc_is_matmul_NT_b_shape(mfn) {
        let mut out = _rocm_emit_matmul_preamble()
        out = out + _rocm_emit_matmul_kernel_signature(kname)
        out = out + _rocm_emit_matmul_NT_b_body()
        return out
    }
    // vec-neg — STMT_LOAD + STMT_UNOP(neg) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_neg_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_neg_body()
        return out
    }
    // vec-abs — STMT_LOAD + STMT_UNOP(abs) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_abs_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_abs_body()
        return out
    }
    // vec-sqrt — STMT_LOAD + STMT_UNOP(sqrt) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_sqrt_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_sqrt_body()
        return out
    }
    // vec-exp — STMT_LOAD + STMT_UNOP(exp) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_exp_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_exp_body()
        return out
    }
    // vec-log — STMT_LOAD + STMT_UNOP(log) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_log_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_log_body()
        return out
    }
    // vec-sin — STMT_LOAD + STMT_UNOP(sin) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_sin_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_sin_body()
        return out
    }
    // vec-cos — STMT_LOAD + STMT_UNOP(cos) + STMT_STORE (2-buffer sig).
    if _rocm_mfunc_is_vec_cos_shape(mfn) {
        let mut out = _rocm_emit_preamble()
        out = out + _rocm_emit_unary_kernel_signature(kname)
        out = out + _rocm_emit_vec_cos_body()
        return out
    }
    // No recognised shape — honest empty string.
    return ""
}
