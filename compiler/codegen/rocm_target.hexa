// _rocm_emit_vec_cos_body — emit the HIP kernel body for vec-cos.
// Hardcoded `c[i] = cosf(a[i]);` with surrounding braces. Calls
// the HIP FP32 cosine scalar builtin from `<math.h>`.
fn _rocm_emit_vec_cos_body() -> string {
    let mut out = "{\n"
    out = out + "    " + ROCM_TYPE_UINT + " i" + ROCM_OP_ASSIGN
    out = out + ROCM_OP_THREAD_IDX + ROCM_OP_STMT_TERM + "\n"
    out = out + "    if (i < n) "
    out = out + "c" + ROCM_OP_INDEX_OPEN + "i" + ROCM_OP_INDEX_CLOSE
    out = out + ROCM_OP_ASSIGN
    out = out + ROCM_OP_COS + ROCM_OP_CALL_OPEN
    out = out + "a" + ROCM_OP_INDEX_OPEN + "i" + ROCM_OP_INDEX_CLOSE
    out = out + ROCM_OP_CALL_CLOSE
    out = out + ROCM_OP_STMT_TERM + "\n"
    out = out + "}\n"
    return out
