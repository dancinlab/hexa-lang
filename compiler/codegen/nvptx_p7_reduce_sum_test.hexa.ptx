// RFC 055 055-P0 - hexa-native NVPTX emit | target=nvptx64-nvidia-cuda-sm80
.version 7.0
.target sm_80
.address_size 64

.visible .entry reduce_sum (
    .param .u64 reduce_sum_param_0,
    .param .u64 reduce_sum_param_1,
    .param .u64 reduce_sum_param_2
)
{
    .reg .f64 %fd3;
    .reg .f64 %fd4;
    .reg .f64 %fd5;
    .reg .u64 %rd6;
    .reg .f64 %fd7;
    .reg .f64 %fd8;
    .reg .f64 %fd9;
    .reg .f64 %fd10;
    .reg .f64 %fd11;
    .reg .u64 %rd12;
$L_0:
    mov.f64 %fd3, 0.0;  // assign
    mov.f64 %fd4, 0;  // assign
    bra $L_1;  // br -> $L_1
$L_1:
    // RFC 055 055-P0 - unsupported binop: <
    @%fd5 bra $L_2;  // br_cond true -> $L_2
    bra $L_3;  // br_cond false -> $L_3
$L_2:
    mov.b64 %rd6, 0;  // to_i64(imm)
    mov.f64 %fd7, %fd0;  // assign
    add.f64 %fd8, 0, %fd7;  // binop +
    mov.f64 %fd9, %fd8;  // assign
    add.f64 %fd10, 0, 1;  // binop +
    mov.f64 %fd11, %fd10;  // assign
    bra $L_1;  // br -> $L_1
$L_3:
    mov.b64 %rd12, 0;  // to_i64(imm)
    mov.f64 %fd-1, %fd1;  // assign
    ret;  // return
}
