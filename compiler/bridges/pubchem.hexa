// HEXA Native Compiler — Phase 4 bridge: pubchem
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ adapter for PubChem chemical compound database.
// Source:   ~/core/nexus/tool/pubchem_bridge.hexa (663 LOC)
// Live:     https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/cid/<cid>/property/...
// Fallback: water (CID=962, real API response captured) + caffeine
//           (CID=2519, curated anchor).
//
// Frozen cache for CID=962:
//   source:   https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/cid/962/property/MolecularFormula,IUPACName,MolecularWeight/JSON
//   fetched:  2026-05-13T09:18Z
//   size:     194 bytes
//   sha256:   1e4679f68c9194af90aaae1a0e7b4458ab97d3bda724d19c09fc71b960d0fd8a
//   note:     PubChem v2026-05 renamed CanonicalSMILES → ConnectivitySMILES.
//             Re-fetched with IUPACName field (richer identification surface)
//             in place of CanonicalSMILES per Phase 5 cache enrichment.
// See also: compiler/bridges/_cache/pubchem.frozen.json

import "./_common.hexa"

fn _pubchem_frozen(cid: string) -> string {
    if cid == "962" {
        // Real PubChem PUG-REST response (water, CID 962), captured
        // 2026-05-13. Schema note: ConnectivitySMILES is the new name
        // for what older callers expect as CanonicalSMILES.
        return "{\"cid\":962,\"name\":\"Water\",\"formula\":\"H2O\",\"molecular_weight\":18.015,\"connectivity_smiles\":\"O\",\"canonical_smiles\":\"O\",\"raw_property_table\":{\"PropertyTable\":{\"Properties\":[{\"CID\":962,\"MolecularFormula\":\"H2O\",\"MolecularWeight\":\"18.015\",\"ConnectivitySMILES\":\"O\"}]}}}"
    }
    if cid == "2519" {
        return "{\"cid\":2519,\"name\":\"Caffeine\",\"formula\":\"C8H10N4O2\",\"molecular_weight\":194.19,\"canonical_smiles\":\"CN1C=NC2=C1C(=O)N(C(=O)N2C)C\"}"
    }
    return "{\"cid\":\"" + cid + "\",\"fallback_unavailable\":true,\"todo\":\"cache-population\"}"
}

pub fn pubchem_live(cid: string) -> array {
    if !http_available() { return fail_body("http unavailable") }
    let c = if cid.len() > 0 { cid } else { "962" }
    let url = "https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/cid/" + c + "/property/MolecularWeight,MolecularFormula,CanonicalSMILES/JSON"
    let r = http_get(url, 8192)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"pubchem\",\"source\":\"live:pubchem.ncbi.nlm.nih.gov\",\"cid\":\"" + c + "\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn pubchem_fallback(cid: string) -> array {
    return ok_body("{\"tool\":\"pubchem\",\"source\":\"fallback:frozen-cache\",\"data\":" + _pubchem_frozen(cid) + "}")
}

pub fn pubchem_run(args: [string]) -> array {
    let cid = if len(args) > 0 { args[0] } else { "962" }
    if http_available() {
        let r = pubchem_live(cid)
        if cli_ok(r) { return r }
    }
    return pubchem_fallback(cid)
}

// ── CLI entry ─────────────────────────────────────────────────────
// `hexa pubchem "<cid>"` queries the PubChem PUG-REST API for one CID
// (e.g. 962 = water, 2519 = caffeine). δ: live HTTP first, frozen JSON
// cache on failure.

use "compiler/_cli_args/parse"

fn main() {
    let av = cli_args()
    let q = cli_find_flag(av, "--query", cli_positional(av, 0, ""))
    let mut passthru: [string] = []
    if len(q) > 0 { passthru.push(q) }
    let r = pubchem_run(passthru)
    let mut out = "{"
    out = out + "\"ok\":" + (if cli_ok(r) { "true" } else { "false" })
    out = out + ",\"stdout\":\"" + cli_stdout(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"stderr\":\"" + cli_stderr(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"exit_code\":" + to_string(cli_exit(r))
    out = out + "}"
    println(out)
}
