// Live:     https://api.openalex.org/works?search=<q>
// Fallback: real OpenAlex search response captured for the
//           "perfect+number" anchor query.
//
// Frozen cache:
//   source:   https://api.openalex.org/works?search=perfect+number&per_page=1&select=id,doi,title,publication_year,authorships
//   fetched:  2026-05-13
//   size:     926 bytes (raw); ~400 bytes embedded subset
//   sha256:   6850ea1f86a795fbe2712c07ff0a00a319480804c9e50f5e04bb061f16642ef3
// See also: compiler/bridges/_cache/openalex.frozen.json

import "./_common.hexa"

fn _openalex_frozen() -> string {
    return "{\"tool\":\"openalex\",\"source\":\"fallback:frozen-cache\",\"query\":\"perfect+number\",\"meta\":{\"count\": 1904022, \"page\": 1, \"per_page\": 1},\"results\":[{\"id\": \"https://openalex.org/W2164731628\", \"doi\": \"https://doi.org/10.1017/s1446788700028251\", \"title\": \"On the largest component of an odd perfect number\", \"publication_year\": 1987, \"author\": \"Graeme L. Cohen\"}]}"
}

pub fn openalex_live(query: string) -> array {
    if !http_available() { return fail_body("http unavailable") }
    let q = if query.len() > 0 { query } else { "perfect+number" }
    let url = "https://api.openalex.org/works?search=" + q + "&per-page=5"
    let r = http_get(url, 32768)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"openalex\",\"source\":\"live:api.openalex.org\",\"query\":\"" + q + "\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn openalex_fallback() -> array { return ok_body(_openalex_frozen()) }

pub fn openalex_run(args: [string]) -> array {
    let q = if len(args) > 0 { args[0] } else { "perfect+number" }
    if http_available() {
        let r = openalex_live(q)
        if cli_ok(r) { return r }
    }
    return openalex_fallback()
}
