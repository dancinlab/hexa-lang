// HEXA Native Compiler — Phase 4 bridge: openalex
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ adapter for OpenAlex scholarly graph.
// Source:   ~/core/nexus/tool/openalex_bridge.hexa (559 LOC)
// Live:     https://api.openalex.org/works?search=<q>
// Fallback: real OpenAlex search response captured for the
//           "perfect+number" anchor query.
//
// Frozen cache:
//   source:   https://api.openalex.org/works?search=hexagonal+number&per_page=2&select=id,doi,title,publication_year,cited_by_count,relevance_score
//   fetched:  2026-05-13T09:17Z
//   size:     631 bytes (raw); embedded constant below retains the
//             "perfect+number" anchor so the δ fallback envelope is stable.
//   sha256:   2dfb3bd3f2dc57d8b077c8314bb040ab6dbf799049ebb2fc0f108914c0a9a108
// See also: compiler/bridges/_cache/openalex.frozen.json

import "./_common.hexa"

fn _openalex_frozen() -> string {
    return "{\"tool\":\"openalex\",\"source\":\"fallback:frozen-cache\",\"query\":\"perfect+number\",\"meta\":{\"count\": 1904022, \"page\": 1, \"per_page\": 1},\"results\":[{\"id\": \"https://openalex.org/W2164731628\", \"doi\": \"https://doi.org/10.1017/s1446788700028251\", \"title\": \"On the largest component of an odd perfect number\", \"publication_year\": 1987, \"author\": \"Graeme L. Cohen\"}]}"
}

pub fn openalex_live(query: string) -> array {
    if !http_available() { return fail_body("http unavailable") }
    let q = if query.len() > 0 { query } else { "perfect+number" }
    let url = "https://api.openalex.org/works?search=" + q + "&per-page=5"
    let r = http_get(url, 32768)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"openalex\",\"source\":\"live:api.openalex.org\",\"query\":\"" + q + "\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn openalex_fallback() -> array { return ok_body(_openalex_frozen()) }

pub fn openalex_run(args: [string]) -> array {
    let q = if len(args) > 0 { args[0] } else { "perfect+number" }
    if http_available() {
        let r = openalex_live(q)
        if cli_ok(r) { return r }
    }
    return openalex_fallback()
}

// ── CLI entry ─────────────────────────────────────────────────────
// `hexa openalex "<query>"` searches the OpenAlex scholarly graph
// (works/<search>). δ: live HTTP first, frozen "perfect+number" anchor
// on failure.

use "compiler/_cli_args/parse"

fn main() {
    let av = cli_args()
    let q = cli_find_flag(av, "--query", cli_positional(av, 0, ""))
    let mut passthru: [string] = []
    if len(q) > 0 { passthru.push(q) }
    let r = openalex_run(passthru)
    let mut out = "{"
    out = out + "\"ok\":" + (if cli_ok(r) { "true" } else { "false" })
    out = out + ",\"stdout\":\"" + cli_stdout(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"stderr\":\"" + cli_stderr(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"exit_code\":" + to_string(cli_exit(r))
    out = out + "}"
    println(out)
}
