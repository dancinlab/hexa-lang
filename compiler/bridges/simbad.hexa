// HEXA Native Compiler — Phase 4 bridge: simbad
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ adapter for the SIMBAD astronomical database (CDS/Strasbourg).
// Source:   ~/core/nexus/tool/simbad_bridge.hexa (516 LOC)
// Live:     http://simbad.u-strasbg.fr/simbad/sim-id?Ident=<obj>&output.format=ASCII
// Fallback: SgrA* enriched from a live SIMBAD ASCII capture; Sirius and
//           Polaris remain curated anchors.
//
// Frozen cache for SgrA*:
//   source:   https://simbad.u-strasbg.fr/simbad/sim-id?Ident=SgrA*&output.format=ASCII
//   fetched:  2026-05-13
//   size:     107734 bytes (raw); 3500 bytes trimmed copy in _cache/
//   sha256:   54b6a57fb1cf9c4b554b0af4759def3d315a7d72b6883a5ca123c6da6aed3db1
// See also: compiler/bridges/_cache/simbad.frozen.txt

import "./_common.hexa"

fn _simbad_frozen(obj: string) -> string {
    if obj == "SgrA*" || obj == "Sgr A*" {
        return "{\"object\":\"Sgr A*\",\"oid\":\"@2419046\",\"ra_j2000\":\"17 45 40.03599\",\"dec_j2000\":\"-29 00 28.1699\",\"coords_gal\":\"359.94423568 -00.04616002\",\"otype\":\"X(SuperMassive BH)\",\"distance_kpc\":8.178,\"identifiers\":[\"NAME Sagittarius A*\",\"NAME Sgr A*\",\"CXOGC J174540.0-290027\",\"AX J1745.6-2900\",\"SWIFT J1746.3-2850A\"],\"bibcode_count\":4979,\"simbad_release\":\"SIMBAD4 rel 1.8\"}"
    }
    if obj == "Sirius" {
        return "{\"object\":\"Sirius\",\"ra_j2000\":\"06 45 08.917\",\"dec_j2000\":\"-16 42 58.02\",\"otype\":\"**A (binary star)\",\"distance_pc\":2.637}"
    }
    if obj == "Polaris" {
        return "{\"object\":\"Polaris\",\"ra_j2000\":\"02 31 49.09\",\"dec_j2000\":\"+89 15 50.79\",\"otype\":\"V*\",\"distance_pc\":132.6}"
    }
    return "{\"object\":\"" + obj + "\",\"fallback_unavailable\":true,\"todo\":\"cache-population\"}"
}

pub fn simbad_live(obj: string) -> array {
    if !http_available() { return fail_body("http unavailable") }
    let url = "http://simbad.u-strasbg.fr/simbad/sim-id?Ident=" + obj.replace(" ", "+") + "&output.format=ASCII"
    let r = http_get(url, 16384)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"simbad\",\"source\":\"live:simbad.u-strasbg.fr\",\"object\":\"" + obj + "\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn simbad_fallback(obj: string) -> array {
    return ok_body("{\"tool\":\"simbad\",\"source\":\"fallback:frozen-cache\",\"data\":" + _simbad_frozen(obj) + "}")
}

pub fn simbad_run(args: [string]) -> array {
    let obj = if len(args) > 0 { args[0] } else { "SgrA*" }
    if http_available() {
        let r = simbad_live(obj)
        if cli_ok(r) { return r }
    }
    return simbad_fallback(obj)
}

// ── CLI entry ─────────────────────────────────────────────────────
// `hexa simbad "<object>"` queries the SIMBAD astronomical database
// (e.g. SgrA*, Sirius, Polaris). δ: live HTTP first, frozen ASCII
// capture on failure.

use "compiler/_cli_args/parse"

fn main() {
    let av = cli_args()
    let q = cli_find_flag(av, "--query", cli_positional(av, 0, ""))
    let mut passthru: [string] = []
    if len(q) > 0 { passthru.push(q) }
    let r = simbad_run(passthru)
    let mut out = "{"
    out = out + "\"ok\":" + (if cli_ok(r) { "true" } else { "false" })
    out = out + ",\"stdout\":\"" + cli_stdout(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"stderr\":\"" + cli_stderr(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"exit_code\":" + to_string(cli_exit(r))
    out = out + "}"
    println(out)
}
