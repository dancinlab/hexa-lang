// HEXA Native Compiler — Phase 4 bridge: uniprot
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ adapter for UniProt protein knowledgebase.
// Source:   ~/core/nexus/tool/uniprot_bridge.hexa (513 LOC)
// Live:     https://rest.uniprot.org/uniprotkb/<accession>.json
// Fallback: insulin (P01308, real API response captured) + hemoglobin
//           alpha (P69905, curated anchor).
//
// Frozen cache for P01308:
//   source:   https://rest.uniprot.org/uniprotkb/P01308.json?fields=accession,id,protein_name,organism_name,length,sequence
//   fetched:  2026-05-13
//   size:     873 bytes
//   sha256:   6e36d213bb3cf10563cd2ecef035cf05b8e0dad2b2598ad30e3217d7efbd031f
// See also: compiler/bridges/_cache/uniprot.frozen.json

import "./_common.hexa"

fn _uniprot_frozen(acc: string) -> string {
    if acc == "P01308" {
        return "{\"accession\":\"P01308\",\"uniProtkbId\":\"INS_HUMAN\",\"name\":\"Insulin\",\"organism\":\"Homo sapiens\",\"taxonId\":9606,\"length\":110,\"molWeight\":11981,\"sequence\":\"MALWMRLLPLLALLALWGPDPAAAFVNQHLCGSHLVEALYLVCGERGFFYTPKTRREAEDLQVGQVELGGGPGAGSLQPLALEGSLQKRGIVEQCCTSICSLYQLENYCN\",\"sequence_prefix\":\"MALWMRLLPLLALLALWGPDPAAAFVNQHLCGSHLVEALYLVCGERGFFYTPKT\",\"crc64\":\"C2C3B23B85E520E5\",\"uniParcId\":\"UPI00000017EA\",\"entryType\":\"UniProtKB reviewed (Swiss-Prot)\"}"
    }
    if acc == "P69905" {
        return "{\"accession\":\"P69905\",\"name\":\"Hemoglobin subunit alpha\",\"organism\":\"Homo sapiens\",\"length\":142,\"sequence_prefix\":\"MVLSPADKTNVKAAWGKVGAHAGEYGAEALERMFLSFPTTKTYFPHFDLSHGSAQ\"}"
    }
    return "{\"accession\":\"" + acc + "\",\"fallback_unavailable\":true,\"todo\":\"cache-population\"}"
}

pub fn uniprot_live(acc: string) -> array {
    if !http_available() { return fail_body("http unavailable") }
    let a = if acc.len() > 0 { acc } else { "P01308" }
    let url = "https://rest.uniprot.org/uniprotkb/" + a + ".json"
    let r = http_get(url, 32768)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"uniprot\",\"source\":\"live:rest.uniprot.org\",\"accession\":\"" + a + "\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn uniprot_fallback(acc: string) -> array {
    return ok_body("{\"tool\":\"uniprot\",\"source\":\"fallback:frozen-cache\",\"data\":" + _uniprot_frozen(acc) + "}")
}

pub fn uniprot_run(args: [string]) -> array {
    let acc = if len(args) > 0 { args[0] } else { "P01308" }
    if http_available() {
        let r = uniprot_live(acc)
        if cli_ok(r) { return r }
    }
    return uniprot_fallback(acc)
}
