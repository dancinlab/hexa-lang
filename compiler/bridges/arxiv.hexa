// HEXA Native Compiler — Phase 4 bridge: arxiv
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ adapter for arXiv preprint metadata.
// Source:   ~/core/nexus/tool/arxiv_realtime_bridge.hexa (310 LOC)
// Live:     http://export.arxiv.org/api/query?search_query=<q>&max_results=<n>
// Fallback: one real arXiv API entry captured for the "cat:physics.gen-ph"
//           anchor query (1 result extracted from the Atom feed).
//
// Frozen cache:
//   source:   http://export.arxiv.org/api/query?search_query=ti:hexagon+number+theory&max_results=2
//   fetched:  2026-05-13T09:16Z
//   size:     4024 bytes (raw Atom XML); compact JSON embedded below still
//             reflects the earlier physics.gen-ph anchor (kept stable so the
//             δ fallback envelope and downstream tests don't churn).
//   sha256:   14f0b5935dafde5796d2d920e4d261f4e93b78247229482a3ee34f268396b739
//   note:     arXiv enforces a strict rate limit (~3 calls/sec global IP)
//             and returns HTTP 429 aggressively; expect bursty failures.
// See also: compiler/bridges/_cache/arxiv.frozen.xml

import "./_common.hexa"

fn _arxiv_frozen() -> string {
    return "{\"tool\":\"arxiv\",\"source\":\"fallback:frozen-cache\",\"query\":\"cat:physics.gen-ph\",\"total_results\":10826,\"items_per_page\":1,\"results\":[{\"id\":\"http://arxiv.org/abs/1905.02587v1\",\"title\":\"Vapor Pressure in a Paramagnetic Solid?\",\"author\":\"Manuel Malaver\",\"published\":\"2019-05-06T02:33:11Z\",\"updated\":\"2019-05-06T02:33:11Z\",\"category\":\"physics.gen-ph\",\"comment\":\"14 pages\",\"summary\":\"In this paper, we obtain an analytical expression for the vapor pressure of a paramagnetic solid for high temperatures. We have considered the behavior of magnetic materials in the presence of an external magnetic field using the thermodynamical analysis and the elements of statistical mechanics in microscopic systems. We found that the vapor pressure depends on the magnetic susceptibility of material and the external field applied.\"}]}"
}

pub fn arxiv_live(query: string, max_results: i64) -> array {
    if !http_available() { return fail_body("http unavailable") }
    let n = if max_results > 0 { max_results } else { 5 }
    let q = if query.len() > 0 { query } else { "cat:physics.gen-ph" }
    let url = "http://export.arxiv.org/api/query?search_query=" + q.replace(" ", "+") + "&max_results=" + to_string(n)
    let r = http_get(url, 32768)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"arxiv\",\"source\":\"live:export.arxiv.org\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn arxiv_fallback() -> array { return ok_body(_arxiv_frozen()) }

pub fn arxiv_run(args: [string]) -> array {
    let q = if len(args) > 0 { args[0] } else { "cat:physics.gen-ph" }
    let n: i64 = if len(args) > 1 { to_int(args[1]) } else { 5 }
    if http_available() {
        let r = arxiv_live(q, n)
        if cli_ok(r) { return r }
    }
    return arxiv_fallback()
}
