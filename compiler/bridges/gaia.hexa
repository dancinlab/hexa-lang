// HEXA Native Compiler — Phase 4 bridge: gaia
//
// @version 0.1.0
// @capabilities [exec, env]
//
// δ adapter for ESA Gaia astrometric catalog.
// Source:   ~/core/nexus/tool/gaia_bridge.hexa (478 LOC)
// Live:     https://gea.esac.esa.int/tap-server/tap/sync   (ADQL queries)
// Fallback: Gaia DR3 anchor summary stats.

import "./_common.hexa"

fn _gaia_frozen() -> string {
    return "{\"tool\":\"gaia\",\"source\":\"fallback:Gaia-DR3-summary\"," +
        "\"data_release\":\"Gaia DR3\"," +
        "\"release_date\":\"2022-06-13\"," +
        "\"total_sources\":1811709771," +
        "\"with_parallax_pct\":78.0," +
        "\"epoch\":\"J2016.0\"}"
}

pub fn gaia_live() -> array {
    if !http_available() { return fail_body("http unavailable") }
    // ADQL-via-GET probe; in practice ADQL needs POST so this only
    // verifies reachability for the smoke. δ semantics still hold.
    let url = "https://gea.esac.esa.int/tap-server/tap/tables"
    let r = http_get(url, 4096)
    if !cli_ok(r) { return r }
    return ok_body("{\"tool\":\"gaia\",\"source\":\"live:gea.esac.esa.int\",\"raw\":\"" + cli_stdout(r).replace("\"", "\\\"").replace("\n", "\\n") + "\"}")
}

pub fn gaia_fallback() -> array { return ok_body(_gaia_frozen()) }

pub fn gaia_run(_args: [string]) -> array {
    if http_available() {
        let r = gaia_live()
        if cli_ok(r) { return r }
    }
    return gaia_fallback()
}

// ── CLI entry ─────────────────────────────────────────────────────
// `hexa gaia` probes the ESA Gaia ADQL TAP server (reachability only).
// δ: live HTTP first, Gaia DR3 anchor summary on failure.

use "compiler/_cli_args/parse"

fn main() {
    let av = cli_args()
    let q = cli_find_flag(av, "--query", cli_positional(av, 0, ""))
    let mut passthru: [string] = []
    if len(q) > 0 { passthru.push(q) }
    let r = gaia_run(passthru)
    let mut out = "{"
    out = out + "\"ok\":" + (if cli_ok(r) { "true" } else { "false" })
    out = out + ",\"stdout\":\"" + cli_stdout(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"stderr\":\"" + cli_stderr(r).replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") + "\""
    out = out + ",\"exit_code\":" + to_string(cli_exit(r))
    out = out + "}"
    println(out)
}
