// HEXA Native Compiler — Wave 1 absorption: drill_dod smoke

use "compiler/drill_dod/embed"
use "compiler/drill_dod/embedded.gen"
use "compiler/drill_dod/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 drill_dod embed smoke")
    println("  hash:         " + DRILL_DOD_HASH)
    println("  generated_at: " + DRILL_DOD_GENERATED_AT)
    println("  source_count: " + to_string(DRILL_DOD_SOURCE_COUNT))
    println("  track:        " + DRILL_DOD_TRACK)
    println("  entries:      " + to_string(len(DRILL_DOD)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(DRILL_DOD_HASH),                       fails)
    _check("generated_at non-empty",     len(DRILL_DOD_GENERATED_AT) > 0,                 fails)
    _check("source_count > 0",           DRILL_DOD_SOURCE_COUNT > 0,                      fails)
    _check("entries match source_count", len(DRILL_DOD) == DRILL_DOD_SOURCE_COUNT,        fails)
    _check("track == drill",             DRILL_DOD_TRACK == "drill",                      fails)

    let scaffold = drill_dod_tier("scaffold_done")
    _check("tier scaffold_done resolves",  scaffold.name == "scaffold_done",              fails)
    _check("scaffold_done has required",   len(scaffold.required) > 0,                    fails)

    let miss = drill_dod_tier("not-a-tier")
    _check("miss → name == \"\"",        miss.name == "",                                 fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(DRILL_DOD)) + "/" + to_string(DRILL_DOD_SOURCE_COUNT) + " entries, hash=" + DRILL_DOD_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
