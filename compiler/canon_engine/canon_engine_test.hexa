// canon_engine smoke — hermetic, redirects HEXA_CANON_SEAL_PATH.

use "compiler/atlas/overlay"
use "compiler/canon_engine/canon_engine"

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn _setup_sandbox() -> string {
    let base = "/tmp/hexa_canon_engine_smoke"
    exec("rm -rf '" + base + "' 2>/dev/null; mkdir -p '" + base + "/.hx/data'")
    setenv("HOME", base)
    let seal_path = base + "/.hx/data/canon_seal.jsonl"
    setenv("HEXA_CANON_SEAL_PATH", seal_path)
    // No skin file — canon falls back to defaults.
    setenv("HEXA_MOLT_SKIN_FILE", base + "/no_such_skin.json")
    return base
}

fn main() {
    println("phase-3 canon_engine smoke")
    let sandbox = _setup_sandbox()
    overlay_reset_cache()
    let fails = []
    let mut pass: i64 = 0
    let mut total: i64 = 0

    // 0) seal path lands under HOME/.hx/data (rule 5 redirect).
    total = total + 1
    let expected_path = sandbox + "/.hx/data/canon_seal.jsonl"
    let got_path = canon_seal_path()
    if got_path == expected_path { pass = pass + 1; _check("seal path redirected to HOME/.hx/data", true, fails) }
    else { _check("seal path mismatch — got " + got_path, false, fails) }

    // 1) first seal — appended, total=1
    total = total + 1
    let r1 = canon_seal("seed-1", "first canon seal")
    if r1.appended && r1.total_seals == 1 { pass = pass + 1; _check("first seal appended, total=1", true, fails) }
    else { _check("first seal: appended=" + (if r1.appended { "T" } else { "F" }) + " total=" + to_string(r1.total_seals), false, fails) }

    // 2) seal file actually exists at the redirected path
    total = total + 1
    if file_exists(expected_path) { pass = pass + 1; _check("canon_seal.jsonl exists at HOME/.hx/data", true, fails) }
    else { _check("canon_seal.jsonl missing at " + expected_path, false, fails) }

    // 3) second seal — total=2
    total = total + 1
    let r2 = canon_seal("seed-2", "second seal")
    if r2.total_seals == 2 { pass = pass + 1; _check("second seal total=2", true, fails) }
    else { _check("second seal total expected 2 got " + to_string(r2.total_seals), false, fails) }

    // 4) overlay annotated for each seal
    total = total + 1
    let loaded = overlay_load()
    if len(loaded) >= 2 { pass = pass + 1; _check("overlay holds >=2 canon notes", true, fails) }
    else { _check("overlay expected >=2 got " + to_string(len(loaded)), false, fails) }

    // 5) JSON entry contains expected fields
    total = total + 1
    let raw = read_file(expected_path)
    if raw.find("sealed_by") >= 0 && raw.find("atlas_overlay") >= 0 && raw.find("seed-2") >= 0 {
        pass = pass + 1
        _check("seal entry contains sealed_by/atlas_overlay/seed-2", true, fails)
    } else { _check("seal entry missing expected fields: " + raw.substring(0, 80), false, fails) }

    println("")
    println(to_string(pass) + "/" + to_string(total) + " PASS")
    if len(fails) == 0 {
        println("RESULT: PASS")
        exec("rm -rf '" + sandbox + "' 2>/dev/null")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/canon_engine_test.hexa") { return true }
    if s == "canon_engine_test.hexa" { return true }
    return false
}
if _is_main() { main() }
