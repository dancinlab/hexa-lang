// HEXA Native Compiler — Phase 3 chain spine: chain smoke
//
// @version 0.1.0
// @capabilities [fs_read, fs_write, env_read]
//
// Smoke for A19 chain. Verifies:
//   1. CSV parsing of --engines list.
//   2. Two-engine pipeline (mk9, mk10) runs and aggregates totals.
//   3. Foreign engine id (e.g. "anima") goes to `deferred`, not crash.
//   4. Hermetic — HOME relocated, overlay starts clean.
//
// Run:
//   hexa run compiler/chain/chain_test.hexa

use "compiler/atlas/overlay"
use "compiler/chain/chain"
use "compiler/drill/drill"

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn _setup_sandbox() -> string {
    let base = "/tmp/chain_test_smoke"
    exec("rm -rf '" + base + "' 2>/dev/null; mkdir -p '" + base + "/.hx/data'")
    setenv("HOME", base)
    return base
}

fn main() {
    println("phase-3 chain smoke (A19)")

    let sandbox = _setup_sandbox()
    overlay_reset_cache()

    let fails = []
    let mut pass: i64 = 0
    let mut total: i64 = 0

    println("")
    println("sandbox HOME: " + sandbox)

    // ─── Scenario 1: CSV parsing ───
    println("")
    println("scenario 1: parse_engines_csv")
    let lst = parse_engines_csv("mk9, mk10 , anima")
    total = total + 1
    if len(lst) == 3 {
        pass = pass + 1
        _check("parse_engines_csv returns 3 entries", true, fails)
    } else {
        _check("parse_engines_csv (got " + to_string(len(lst)) + ")", false, fails)
    }
    total = total + 1
    if to_string(lst[0]) == "mk9" && to_string(lst[1]) == "mk10" && to_string(lst[2]) == "anima" {
        pass = pass + 1
        _check("parse_engines_csv trims and preserves order", true, fails)
    } else {
        _check("parse_engines_csv trim/order — got [" + to_string(lst[0]) + "," + to_string(lst[1]) + "," + to_string(lst[2]) + "]", false, fails)
    }

    // ─── Scenario 2: two-engine pipeline ───
    println("")
    println("scenario 2: mk9 + mk10 chain")
    let seed = "Hodge conjecture rational cohomology absorbed"
    let mut opts = drill_default_opts()
    opts.max_rounds = 1
    opts.depth_smash = 2
    opts.depth_free = 2
    opts.depth_res = 1
    opts.fresh = true
    opts.quiet = true
    let cr = chain_run(seed, "mk9,mk10", opts)
    println("  per_engine: " + to_string(len(cr.per_engine)) + " · unified=" + to_string(cr.unified_total) + " · consensus=" + to_string(cr.consensus_count))

    total = total + 1
    if len(cr.per_engine) == 2 {
        pass = pass + 1
        _check("two-engine pipeline dispatched 2 drills", true, fails)
    } else {
        _check("two-engine pipeline (got " + to_string(len(cr.per_engine)) + " engines)", false, fails)
    }

    total = total + 1
    if cr.unified_total >= 0 {
        pass = pass + 1
        _check("unified_total computed (>= 0)", true, fails)
    } else {
        _check("unified_total negative — accounting bug", false, fails)
    }

    // ─── Scenario 3: foreign engine deferred ───
    println("")
    println("scenario 3: foreign engine 'anima' deferred (not crash)")
    let cr2 = chain_run(seed, "mk9,anima", opts)
    total = total + 1
    if len(cr2.deferred) == 1 && to_string(cr2.deferred[0]) == "anima" {
        pass = pass + 1
        _check("foreign engine 'anima' marked deferred", true, fails)
    } else {
        _check("foreign engine deferred — got " + to_string(len(cr2.deferred)) + " deferred", false, fails)
    }
    total = total + 1
    if len(cr2.per_engine) == 1 {
        pass = pass + 1
        _check("only the supported engine ran (1)", true, fails)
    } else {
        _check("per_engine count after foreign deferral (got " + to_string(len(cr2.per_engine)) + ")", false, fails)
    }

    // ─── Scenario 4: Mk.X stage 7 is additive (tc_n ≥ 0) ───
    // After the mkx port (compiler/drill/mkx.hexa), mk10 total =
    // mk9 total + tc_n where tc_n ≥ 0. So mk10 total ≥ mk9 total
    // always. When tc_n == 0 we get consensus=2; when tc_n > 0 we get
    // consensus=1 (mk10 alone at max). We assert the monotonic shape.
    println("")
    println("scenario 4: Mk.X additive — mk10 total >= mk9 total")
    let cr3 = chain_run(seed, "mk9,mk10", opts)
    total = total + 1
    let mut mk9_total: i64 = 0
    let mut mk10_total: i64 = 0
    let mut pe_i = 0
    while pe_i < len(cr3.per_engine) {
        let pe = cr3.per_engine[pe_i]
        if pe.engine == "mk9" { mk9_total = pe.total }
        if pe.engine == "mk10" { mk10_total = pe.total }
        pe_i = pe_i + 1
    }
    if mk10_total >= mk9_total {
        pass = pass + 1
        _check("scenario 4: mk10 (" + to_string(mk10_total) + ") >= mk9 (" + to_string(mk9_total) + ")", true, fails)
    } else {
        _check("scenario 4: mk10 (" + to_string(mk10_total) + ") < mk9 (" + to_string(mk9_total) + ") — Mk.X must be additive", false, fails)
    }
    total = total + 1
    if cr3.consensus_count >= 1 && cr3.consensus_count <= 2 {
        pass = pass + 1
        _check("scenario 4: consensus_count in {1,2} (got " + to_string(cr3.consensus_count) + ")", true, fails)
    } else {
        _check("scenario 4: consensus_count out of range (got " + to_string(cr3.consensus_count) + ")", false, fails)
    }

    println("")
    println(to_string(pass) + "/" + to_string(total) + " PASS")
    if len(fails) == 0 {
        println("RESULT: PASS")
        exec("rm -rf '" + sandbox + "' 2>/dev/null")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        let mut k = 0
        while k < len(fails) {
            println("  - " + to_string(fails[k]))
            k = k + 1
        }
        exit(1)
    }
}

// is_main guard
let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/chain_test.hexa") { return true }
    if s == "chain_test.hexa" { return true }
    return false
}
if _is_main() { main() }
