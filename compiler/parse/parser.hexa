// HEXA Native Compiler — Parser (Phase A1)
//
// Recursive-descent. Tokens (TokenKind enum) → Module/Item/Expr from ast.hexa.
//
// State lives at module level (`pub let mut`) the same way self/parser.hexa
// does — stage0 cannot return tuples or mutate struct fields cheaply, and
// thread-state is overkill for this single-pass parser.
//
// Error policy: we never panic. On a mismatch we emit a placeholder Item /
// Expr (kind preserved, fields zero-valued) and skip to the next plausible
// sync point so the rest of the module still parses. The checker (S0) is
// what surfaces HX0xxx diagnostics.

import "../lex/tokens.hexa"
import "./ast.hexa"
import "../diag/catalog.hexa"
import "../diag/builder.hexa"

// ── Mutable parse state ────────────────────────────────────────

pub let mut p_tokens = []
pub let mut p_pos = 0
pub let mut p_file = ""
pub let mut p_pending_annotations = []
// Stage1 punch list Gap 5 — parser-stage diagnostics. Filled by the
// `expect_brace_*` helpers when a `{`/`}` is missing. Drained by
// `parse_diags()` so main.hexa can fold them into the master diag list
// ahead of S1+ checks. Reset on every `parse()` entry.
pub let mut p_diags: array = []
// While true, an ident-followed-by-LBrace is *not* parsed as a struct literal
// (so `if cond { body }` doesn't read `cond { ... }` as `StructLit`). The
// guard parsing functions toggle this around their condition expressions.
pub let mut p_suppress_struct_lit = false

// ── Span / placeholder helpers ─────────────────────────────────

fn empty_span() -> Span {
    return Span { file: "", line: 0, col: 0, len: 0 }
}

fn empty_atlas() -> AtlasRef {
    return AtlasRef { kind: "", id: "", span: empty_span() }
}

fn empty_type() -> TypeRef {
    return TypeRef { kind: "", name: "", args: [], span: empty_span() }
}

fn empty_expr() -> Expr {
    return Expr {
        kind: ExprKind::Ident,
        span: empty_span(),
        text: "",
        children: [],
        atlas_ref: empty_atlas()
    }
}

// ── Token cursor ───────────────────────────────────────────────

fn peek() -> Token {
    return p_tokens[p_pos]
}

fn peek_at(off: i64) -> Token {
    let idx = p_pos + off
    if idx < len(p_tokens) { return p_tokens[idx] }
    return p_tokens[len(p_tokens) - 1]
}

fn advance() -> Token {
    let t = p_tokens[p_pos]
    if p_pos + 1 < len(p_tokens) {
        p_pos = p_pos + 1
    }
    return t
}

fn check_kind(k: TokenKind) -> bool {
    let t = peek()
    return same_kind(t.kind, k)
}

fn same_kind(a: TokenKind, b: TokenKind) -> bool {
    // stage0 cannot derive Eq for enums automatically, so we string-compare
    // through the deterministic match below. Cheap because both sides are
    // payload-free variants — no allocation.
    return tag_of(a) == tag_of(b)
}

fn tag_of(k: TokenKind) -> string {
    return match k {
        TokenKind::Ident -> "Ident",
        TokenKind::Number -> "Number",
        TokenKind::String -> "String",
        TokenKind::Char -> "Char",
        TokenKind::LParen -> "LParen",
        TokenKind::RParen -> "RParen",
        TokenKind::LBrace -> "LBrace",
        TokenKind::RBrace -> "RBrace",
        TokenKind::LBracket -> "LBracket",
        TokenKind::RBracket -> "RBracket",
        TokenKind::Comma -> "Comma",
        TokenKind::Semicolon -> "Semicolon",
        TokenKind::Colon -> "Colon",
        TokenKind::ColonColon -> "ColonColon",
        TokenKind::Arrow -> "Arrow",
        TokenKind::FatArrow -> "FatArrow",
        TokenKind::Eq -> "Eq",
        TokenKind::EqEq -> "EqEq",
        TokenKind::Neq -> "Neq",
        TokenKind::PlusEq -> "PlusEq",
        TokenKind::MinusEq -> "MinusEq",
        TokenKind::StarEq -> "StarEq",
        TokenKind::SlashEq -> "SlashEq",
        TokenKind::Lt -> "Lt",
        TokenKind::Le -> "Le",
        TokenKind::Gt -> "Gt",
        TokenKind::Ge -> "Ge",
        TokenKind::Plus -> "Plus",
        TokenKind::Minus -> "Minus",
        TokenKind::Star -> "Star",
        TokenKind::Slash -> "Slash",
        TokenKind::Percent -> "Percent",
        TokenKind::At -> "At",
        TokenKind::Dot -> "Dot",
        TokenKind::KwFn -> "KwFn",
        TokenKind::KwLet -> "KwLet",
        TokenKind::KwMut -> "KwMut",
        TokenKind::KwReturn -> "KwReturn",
        TokenKind::KwIf -> "KwIf",
        TokenKind::KwElse -> "KwElse",
        TokenKind::KwWhile -> "KwWhile",
        TokenKind::KwFor -> "KwFor",
        TokenKind::KwIn -> "KwIn",
        TokenKind::KwStruct -> "KwStruct",
        TokenKind::KwEnum -> "KwEnum",
        TokenKind::KwMatch -> "KwMatch",
        TokenKind::KwPub -> "KwPub",
        TokenKind::KwImport -> "KwImport",
        TokenKind::KwAs -> "KwAs",
        TokenKind::KwTrue -> "KwTrue",
        TokenKind::KwFalse -> "KwFalse",
        TokenKind::PNode -> "PNode",
        TokenKind::CNode -> "CNode",
        TokenKind::LNode -> "LNode",
        TokenKind::ENode -> "ENode",
        TokenKind::Newline -> "Newline",
        TokenKind::Eof -> "Eof"
    }
}

fn eat(k: TokenKind) -> bool {
    if check_kind(k) {
        advance()
        return true
    }
    return false
}

fn expect(k: TokenKind) -> Token {
    // Best-effort: if the expected token is missing, fabricate one with the
    // same span as `peek` so downstream code (which only reads .text/.span)
    // keeps working. The actual stream pointer does NOT advance.
    if check_kind(k) {
        return advance()
    }
    let t = peek()
    return Token { kind: k, text: "", span: t.span }
}

// ── Parser-stage diagnostic helpers (Gap 5) ──────────────────────
// `expect_brace_open` / `expect_brace_close` wrap `expect` for the common
// `{`/`}` case. On a token mismatch they push a Diagnostic into `p_diags`
// AND ADVANCE one token (open case) so the parser stays in sync. The
// previous behavior — silent `eat(LBrace)` / `eat(RBrace)` — let the
// block loop swallow the next top-level fn into the prior body without
// any visible diagnostic.
fn _push_parse_diag(code: string, span: Span, found: string) {
    let mut b = diag_new(code)
    b = diag_span(b, span)
    b = diag_arg(b, "found", found)
    p_diags.push(diag_emit(b))
}

fn expect_brace_open() -> Token {
    if check_kind(TokenKind::LBrace) {
        return advance()
    }
    let t = peek()
    _push_parse_diag("HX0011", t.span, tag_of(t.kind))
    // Advance one token so the block loop doesn't deadlock on the same
    // misshapen token. Skip when at EOF — caller's loop handles that.
    if !at_eof() { advance() }
    return Token { kind: TokenKind::LBrace, text: "{", span: t.span }
}

fn expect_brace_close() -> Token {
    if check_kind(TokenKind::RBrace) {
        return advance()
    }
    let t = peek()
    _push_parse_diag("HX0012", t.span, tag_of(t.kind))
    // No synthetic advance here: the block loop already exited on EOF or
    // on a non-RBrace it could not consume; advancing now would skip an
    // item the caller has yet to see.
    return Token { kind: TokenKind::RBrace, text: "}", span: t.span }
}

fn at_eof() -> bool {
    return check_kind(TokenKind::Eof)
}

// ── Atlas refs ────────────────────────────────────────────────

fn is_atlas_kind(k: TokenKind) -> bool {
    if same_kind(k, TokenKind::PNode) { return true }
    if same_kind(k, TokenKind::CNode) { return true }
    if same_kind(k, TokenKind::LNode) { return true }
    if same_kind(k, TokenKind::ENode) { return true }
    return false
}

fn atlas_kind_str(k: TokenKind) -> string {
    if same_kind(k, TokenKind::PNode) { return "P" }
    if same_kind(k, TokenKind::CNode) { return "C" }
    if same_kind(k, TokenKind::LNode) { return "L" }
    if same_kind(k, TokenKind::ENode) { return "E" }
    return ""
}

// ── Type parser ───────────────────────────────────────────────
// Phase A1 supports: Name, Name<Args,...>, [T] sugar (becomes named "Array").

fn parse_type() -> TypeRef {
    let t = peek()
    if check_kind(TokenKind::LBracket) {
        advance()
        let inner = parse_type()
        eat(TokenKind::RBracket)
        let mut args = []
        args.push(inner)
        return TypeRef { kind: "generic", name: "Array", args: args, span: t.span }
    }
    if check_kind(TokenKind::Ident) {
        let id = advance()
        if check_kind(TokenKind::Lt) {
            advance()
            let mut args = []
            if !check_kind(TokenKind::Gt) {
                args.push(parse_type())
                while check_kind(TokenKind::Comma) {
                    advance()
                    args.push(parse_type())
                }
            }
            eat(TokenKind::Gt)
            return TypeRef { kind: "generic", name: id.text, args: args, span: id.span }
        }
        return TypeRef { kind: "named", name: id.text, args: [], span: id.span }
    }
    // missing type — return a placeholder, do not advance
    return TypeRef { kind: "named", name: "", args: [], span: t.span }
}

// ── Expression parser ─────────────────────────────────────────
// Pratt-ish layered descent: equality > comparison > additive > multiplicative > unary > primary
// followed by a postfix loop for ., (), [].

fn parse_expr() -> Expr {
    return parse_assignment()
}

// Assignment is lowest precedence and right-associative. Both `x = rhs` and
// the compound forms `x += rhs` / `-=` / `*=` / `/=` produce ExprKind::Assign
// with `text` set to the operator literal so the checker can distinguish a
// pure assignment from a read-modify-write later (RFC-018 §A1).
fn parse_assignment() -> Expr {
    let lhs = parse_equality()
    if check_kind(TokenKind::Eq) || check_kind(TokenKind::PlusEq) || check_kind(TokenKind::MinusEq) || check_kind(TokenKind::StarEq) || check_kind(TokenKind::SlashEq) {
        let op = advance()
        let rhs = parse_assignment()
        let mut kids = []
        kids.push(lhs)
        kids.push(rhs)
        return Expr {
            kind: ExprKind::Assign,
            span: op.span,
            text: op.text,
            children: kids,
            atlas_ref: empty_atlas()
        }
    }
    return lhs
}

fn parse_equality() -> Expr {
    let mut left = parse_comparison()
    while check_kind(TokenKind::EqEq) || check_kind(TokenKind::Neq) {
        let op = advance()
        let right = parse_comparison()
        let mut kids = []
        kids.push(left)
        kids.push(right)
        left = Expr {
            kind: ExprKind::BinOp,
            span: op.span,
            text: op.text,
            children: kids,
            atlas_ref: empty_atlas()
        }
    }
    return left
}

fn parse_comparison() -> Expr {
    let mut left = parse_additive()
    while check_kind(TokenKind::Lt) || check_kind(TokenKind::Le) || check_kind(TokenKind::Gt) || check_kind(TokenKind::Ge) {
        let op = advance()
        let right = parse_additive()
        let mut kids = []
        kids.push(left)
        kids.push(right)
        left = Expr {
            kind: ExprKind::BinOp,
            span: op.span,
            text: op.text,
            children: kids,
            atlas_ref: empty_atlas()
        }
    }
    return left
}

fn parse_additive() -> Expr {
    let mut left = parse_multiplicative()
    while check_kind(TokenKind::Plus) || check_kind(TokenKind::Minus) {
        let op = advance()
        let right = parse_multiplicative()
        let mut kids = []
        kids.push(left)
        kids.push(right)
        left = Expr {
            kind: ExprKind::BinOp,
            span: op.span,
            text: op.text,
            children: kids,
            atlas_ref: empty_atlas()
        }
    }
    return left
}

fn parse_multiplicative() -> Expr {
    let mut left = parse_unary()
    while check_kind(TokenKind::Star) || check_kind(TokenKind::Slash) || check_kind(TokenKind::Percent) {
        let op = advance()
        let right = parse_unary()
        let mut kids = []
        kids.push(left)
        kids.push(right)
        left = Expr {
            kind: ExprKind::BinOp,
            span: op.span,
            text: op.text,
            children: kids,
            atlas_ref: empty_atlas()
        }
    }
    return left
}

fn parse_unary() -> Expr {
    if check_kind(TokenKind::Minus) {
        let op = advance()
        let inner = parse_unary()
        let mut kids = []
        kids.push(inner)
        return Expr {
            kind: ExprKind::UnOp,
            span: op.span,
            text: "-",
            children: kids,
            atlas_ref: empty_atlas()
        }
    }
    return parse_postfix()
}

fn parse_postfix() -> Expr {
    let mut e = parse_primary()
    let mut go = true
    while go {
        if check_kind(TokenKind::Dot) {
            advance()
            let name_tok = expect(TokenKind::Ident)
            let mut kids = []
            kids.push(e)
            e = Expr {
                kind: ExprKind::Field,
                span: name_tok.span,
                text: name_tok.text,
                children: kids,
                atlas_ref: empty_atlas()
            }
        } else if check_kind(TokenKind::LParen) {
            advance()
            let mut kids = []
            kids.push(e)
            if !check_kind(TokenKind::RParen) {
                kids.push(parse_expr())
                while check_kind(TokenKind::Comma) {
                    advance()
                    if check_kind(TokenKind::RParen) { break }
                    kids.push(parse_expr())
                }
            }
            let close = peek()
            eat(TokenKind::RParen)
            e = Expr {
                kind: ExprKind::Call,
                span: close.span,
                text: "",
                children: kids,
                atlas_ref: empty_atlas()
            }
        } else if check_kind(TokenKind::LBracket) {
            advance()
            let idx = parse_expr()
            let close = peek()
            eat(TokenKind::RBracket)
            let mut kids = []
            kids.push(e)
            kids.push(idx)
            e = Expr {
                kind: ExprKind::Index,
                span: close.span,
                text: "",
                children: kids,
                atlas_ref: empty_atlas()
            }
        } else {
            go = false
        }
    }
    return e
}

fn parse_primary() -> Expr {
    let t = peek()
    if check_kind(TokenKind::Number) {
        advance()
        let chars = t.text.chars()
        let mut is_float = false
        let mut i = 0
        while i < len(chars) {
            if chars[i] == '.' || chars[i] == 'e' || chars[i] == 'E' { is_float = true }
            i = i + 1
        }
        let mut k = ExprKind::LiteralInt
        if is_float { k = ExprKind::LiteralFloat }
        return Expr {
            kind: k,
            span: t.span,
            text: t.text,
            children: [],
            atlas_ref: empty_atlas()
        }
    }
    if check_kind(TokenKind::String) {
        advance()
        return Expr {
            kind: ExprKind::LiteralString,
            span: t.span,
            text: t.text,
            children: [],
            atlas_ref: empty_atlas()
        }
    }
    if check_kind(TokenKind::Char) {
        advance()
        // text holds the (already escape-decoded) single character body so
        // the checker can read it verbatim — no re-escape pass needed.
        return Expr {
            kind: ExprKind::LiteralChar,
            span: t.span,
            text: t.text,
            children: [],
            atlas_ref: empty_atlas()
        }
    }
    if check_kind(TokenKind::KwTrue) || check_kind(TokenKind::KwFalse) {
        advance()
        return Expr {
            kind: ExprKind::LiteralBool,
            span: t.span,
            text: t.text,
            children: [],
            atlas_ref: empty_atlas()
        }
    }
    if is_atlas_kind(t.kind) {
        advance()
        let kind_s = atlas_kind_str(t.kind)
        let aref = AtlasRef { kind: kind_s, id: t.text, span: t.span }
        return Expr {
            kind: ExprKind::AtlasRef,
            span: t.span,
            text: t.text,
            children: [],
            atlas_ref: aref
        }
    }
    if check_kind(TokenKind::Ident) {
        advance()
        // EnumName::Variant — also allow Variant(payload) as an Expr.
        if check_kind(TokenKind::ColonColon) {
            advance()
            let v_tok = expect(TokenKind::Ident)
            let mut kids = []
            if check_kind(TokenKind::LParen) {
                advance()
                if !check_kind(TokenKind::RParen) {
                    kids.push(parse_expr())
                    while check_kind(TokenKind::Comma) {
                        advance()
                        if check_kind(TokenKind::RParen) { break }
                        kids.push(parse_expr())
                    }
                }
                eat(TokenKind::RParen)
            }
            // text encodes the Enum::Variant path so a single field captures
            // both halves without needing a dedicated payload struct.
            return Expr {
                kind: ExprKind::EnumPath,
                span: t.span,
                text: t.text + "::" + v_tok.text,
                children: kids,
                atlas_ref: empty_atlas()
            }
        }
        // Foo { x: 1, y: 2 } — only when struct-lit context is permitted, so
        // `if cond { body }` still reads `cond` as a bare Ident.
        if check_kind(TokenKind::LBrace) && !p_suppress_struct_lit && is_struct_lit_lookahead() {
            return parse_struct_lit_after_name(t)
        }
        return Expr {
            kind: ExprKind::Ident,
            span: t.span,
            text: t.text,
            children: [],
            atlas_ref: empty_atlas()
        }
    }
    if check_kind(TokenKind::LParen) {
        advance()
        let inner = parse_expr()
        eat(TokenKind::RParen)
        return inner
    }
    if check_kind(TokenKind::LBrace) {
        return parse_block_expr()
    }
    if check_kind(TokenKind::KwIf) {
        return parse_if_expr()
    }
    if check_kind(TokenKind::KwWhile) {
        return parse_while_expr()
    }
    if check_kind(TokenKind::KwFor) {
        return parse_for_expr()
    }
    if check_kind(TokenKind::KwMatch) {
        return parse_match_expr()
    }
    if check_kind(TokenKind::KwReturn) {
        return parse_return_expr()
    }
    if check_kind(TokenKind::KwLet) {
        return parse_let_expr()
    }
    // unrecognized — placeholder Ident with the literal text so callers can
    // still emit a half-decent diagnostic later.
    advance()
    return Expr {
        kind: ExprKind::Ident,
        span: t.span,
        text: t.text,
        children: [],
        atlas_ref: empty_atlas()
    }
}

// Detect `Ident { Ident :` or `Ident { }` — the empty-fields literal — so we
// don't accidentally swallow a control-flow body. Position-preserving; the
// caller has already consumed the leading Ident.
fn is_struct_lit_lookahead() -> bool {
    if !check_kind(TokenKind::LBrace) { return false }
    let n1 = peek_at(1)
    if same_kind(n1.kind, TokenKind::RBrace) { return true }
    if !same_kind(n1.kind, TokenKind::Ident) { return false }
    let n2 = peek_at(2)
    return same_kind(n2.kind, TokenKind::Colon)
}

// Caller has already consumed the leading Ident `name_tok`. We're at LBrace.
// Each field is encoded as a child Expr (kind=Ident, text=field_name,
// children=[value_expr]) — same shape used for struct decls in self/parser.
fn parse_struct_lit_after_name(name_tok: Token) -> Expr {
    eat(TokenKind::LBrace)
    let mut kids = []
    while !check_kind(TokenKind::RBrace) && !at_eof() {
        let f_name = expect(TokenKind::Ident)
        eat(TokenKind::Colon)
        let f_val = parse_expr()
        let mut f_kids = []
        f_kids.push(f_val)
        kids.push(Expr {
            kind: ExprKind::Ident,
            span: f_name.span,
            text: f_name.text,
            children: f_kids,
            atlas_ref: empty_atlas()
        })
        if check_kind(TokenKind::Comma) { advance() }
    }
    eat(TokenKind::RBrace)
    return Expr {
        kind: ExprKind::StructLit,
        span: name_tok.span,
        text: name_tok.text,
        children: kids,
        atlas_ref: empty_atlas()
    }
}

// for NAME in ITER { BODY }
// children layout: [iter_expr, body]; binding name is stashed on `text`.
fn parse_for_expr() -> Expr {
    let kw = peek()
    advance()
    let name_tok = expect(TokenKind::Ident)
    eat(TokenKind::KwIn)
    let prev = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let it = parse_expr()
    p_suppress_struct_lit = prev
    let body = parse_block_expr()
    let mut kids = []
    kids.push(it)
    kids.push(body)
    return Expr {
        kind: ExprKind::For,
        span: kw.span,
        text: name_tok.text,
        children: kids,
        atlas_ref: empty_atlas()
    }
}

// match SCRUTINEE { PATTERN -> BODY, ... }
// children layout: [scrutinee, pat0, body0, pat1, body1, ...].
fn parse_match_expr() -> Expr {
    let kw = peek()
    advance()
    let prev = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let scrut = parse_expr()
    p_suppress_struct_lit = prev
    eat(TokenKind::LBrace)
    let mut kids = []
    kids.push(scrut)
    while !check_kind(TokenKind::RBrace) && !at_eof() {
        let pat = parse_match_pattern()
        eat(TokenKind::Arrow)
        let body = parse_expr()
        kids.push(pat)
        kids.push(body)
        if check_kind(TokenKind::Comma) { advance() }
    }
    eat(TokenKind::RBrace)
    return Expr {
        kind: ExprKind::Match,
        span: kw.span,
        text: "",
        children: kids,
        atlas_ref: empty_atlas()
    }
}

// Patterns: wildcard `_`, literal, ident binding, EnumName::Variant, and
// EnumName::Variant(binding). The binding form reuses ExprKind::EnumPath
// with one child Ident expression that names the bound variable.
fn parse_match_pattern() -> Expr {
    let t = peek()
    if check_kind(TokenKind::Ident) && t.text == "_" {
        advance()
        return Expr {
            kind: ExprKind::Wildcard,
            span: t.span,
            text: "_",
            children: [],
            atlas_ref: empty_atlas()
        }
    }
    // literal patterns / arbitrary expressions delegate to parse_expr below
    if check_kind(TokenKind::Number) || check_kind(TokenKind::String) || check_kind(TokenKind::Char) || check_kind(TokenKind::KwTrue) || check_kind(TokenKind::KwFalse) {
        return parse_expr()
    }
    // EnumName::Variant patterns are handled via parse_expr's EnumPath path.
    return parse_expr()
}

fn parse_block_expr() -> Expr {
    let open = peek()
    // Gap 5 (stage1 punch list): replace silent `eat(LBrace)`/`eat(RBrace)`
    // with `expect_brace_open`/`expect_brace_close` — emit HX0011/HX0012 on
    // miss + advance to keep parsing in sync. Previously a missing `{` would
    // let the loop below absorb the next top-level fn into the current body
    // without any visible diagnostic; a missing `}` would silently terminate.
    expect_brace_open()
    let mut kids = []
    while !check_kind(TokenKind::RBrace) && !at_eof() {
        let e = parse_stmt()
        kids.push(e)
        // optional ;
        if check_kind(TokenKind::Semicolon) { advance() }
    }
    expect_brace_close()
    return Expr {
        kind: ExprKind::Block,
        span: open.span,
        text: "",
        children: kids,
        atlas_ref: empty_atlas()
    }
}

fn parse_if_expr() -> Expr {
    let kw = peek()
    advance()
    let prev = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev
    let then_b = parse_block_expr()
    let mut kids = []
    kids.push(cond)
    kids.push(then_b)
    if check_kind(TokenKind::KwElse) {
        advance()
        if check_kind(TokenKind::KwIf) {
            kids.push(parse_if_expr())
        } else {
            kids.push(parse_block_expr())
        }
    }
    return Expr {
        kind: ExprKind::If,
        span: kw.span,
        text: "",
        children: kids,
        atlas_ref: empty_atlas()
    }
}

fn parse_while_expr() -> Expr {
    let kw = peek()
    advance()
    let prev = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev
    let body = parse_block_expr()
    let mut kids = []
    kids.push(cond)
    kids.push(body)
    return Expr {
        kind: ExprKind::While,
        span: kw.span,
        text: "",
        children: kids,
        atlas_ref: empty_atlas()
    }
}

fn parse_return_expr() -> Expr {
    let kw = peek()
    advance()
    let mut kids = []
    // return may be value-less; in practice we always emit a child here so
    // resolve doesn't have to special-case empty-return.
    if !check_kind(TokenKind::RBrace) && !check_kind(TokenKind::Semicolon) && !at_eof() {
        kids.push(parse_expr())
    }
    return Expr {
        kind: ExprKind::Return,
        span: kw.span,
        text: "",
        children: kids,
        atlas_ref: empty_atlas()
    }
}

fn parse_let_expr() -> Expr {
    let kw = peek()
    advance()
    let is_mut = eat(TokenKind::KwMut)
    let name_tok = expect(TokenKind::Ident)
    // optional `: Type` (we encode it in text as "name:Type" — skip a real
    // ascription struct until A2 since LetExpr is rarely produced inside
    // function bodies; module-level `let` items are handled in parse_item.
    if check_kind(TokenKind::Colon) {
        advance()
        parse_type()
    }
    let mut kids = []
    if check_kind(TokenKind::Eq) {
        advance()
        kids.push(parse_expr())
    }
    let mut text = name_tok.text
    if is_mut { text = "mut:" + name_tok.text }
    return Expr {
        kind: ExprKind::Let,
        span: kw.span,
        text: text,
        children: kids,
        atlas_ref: empty_atlas()
    }
}

// statement-as-expr: anything legal inside a block. Returns an Expr.
fn parse_stmt() -> Expr {
    return parse_expr()
}

// ── Annotation parser ─────────────────────────────────────────
// `@name(arg, arg)` or bare `@name`. Arguments parse as full Exprs.

fn parse_annotation() -> Annotation {
    let at = peek()
    eat(TokenKind::At)
    let name_tok = expect(TokenKind::Ident)
    let mut args = []
    if check_kind(TokenKind::LParen) {
        advance()
        if !check_kind(TokenKind::RParen) {
            args.push(parse_expr())
            while check_kind(TokenKind::Comma) {
                advance()
                if check_kind(TokenKind::RParen) { break }
                args.push(parse_expr())
            }
        }
        eat(TokenKind::RParen)
    }
    return Annotation { name: name_tok.text, args: args, span: at.span }
}

// ── Top-level item parsers ────────────────────────────────────

fn parse_param() -> Param {
    let name_tok = expect(TokenKind::Ident)
    eat(TokenKind::Colon)
    let ty = parse_type()
    return Param { name: name_tok.text, typ: ty, span: name_tok.span }
}

fn parse_fn_item(is_pub: bool, anns: [Annotation]) -> Item {
    let kw = peek()
    eat(TokenKind::KwFn)
    let name_tok = expect(TokenKind::Ident)
    eat(TokenKind::LParen)
    let mut params = []
    if !check_kind(TokenKind::RParen) {
        params.push(parse_param())
        while check_kind(TokenKind::Comma) {
            advance()
            if check_kind(TokenKind::RParen) { break }
            params.push(parse_param())
        }
    }
    eat(TokenKind::RParen)
    let mut ret_ty = empty_type()
    if check_kind(TokenKind::Arrow) {
        advance()
        ret_ty = parse_type()
    }
    let body = parse_block_expr()
    return Item {
        kind: ItemKind::Fn,
        name: name_tok.text,
        span: kw.span,
        annotations: anns,
        params: params,
        return_type: ret_ty,
        body: body,
        is_pub: is_pub
    }
}

fn parse_let_item(is_pub: bool, anns: [Annotation]) -> Item {
    let kw = peek()
    eat(TokenKind::KwLet)
    // Stage1 punch list Gap 7: split `let name` (immutable) vs `let mut name`
    // (mutable). Previously `eat(KwMut)` accepted `mut` unconditionally and
    // discarded the result — the parser had no way to tell the two forms
    // apart. We now capture the flag explicitly. AST `Item` has no `is_mut`
    // field yet (would ripple through every Item literal in the tree), so
    // we encode mutability into `name` with a `mut:` prefix mirroring
    // `parse_let_expr`'s convention. Default — when `mut` is absent — is
    // immutable, no diagnostic (matches RFC-019 §2 silent-default policy).
    let is_mut = eat(TokenKind::KwMut)
    let name_tok = expect(TokenKind::Ident)
    let mut item_name = name_tok.text
    if is_mut { item_name = "mut:" + name_tok.text }
    let mut ty = empty_type()
    if check_kind(TokenKind::Colon) {
        advance()
        ty = parse_type()
    }
    let mut body = empty_expr()
    if check_kind(TokenKind::Eq) {
        advance()
        body = parse_expr()
    }
    return Item {
        kind: ItemKind::Let,
        name: item_name,
        span: kw.span,
        annotations: anns,
        params: [],
        return_type: ty,
        body: body,
        is_pub: is_pub
    }
}

fn parse_struct_item(is_pub: bool, anns: [Annotation]) -> Item {
    let kw = peek()
    eat(TokenKind::KwStruct)
    let name_tok = expect(TokenKind::Ident)
    eat(TokenKind::LBrace)
    // Stage A1: capture fields as Param-like entries in `params`. Promotion to
    // a dedicated Field struct can wait until A2 when checker needs more
    // metadata (visibility per-field, default values).
    let mut fields = []
    while !check_kind(TokenKind::RBrace) && !at_eof() {
        let f_name = expect(TokenKind::Ident)
        eat(TokenKind::Colon)
        let f_ty = parse_type()
        fields.push(Param { name: f_name.text, typ: f_ty, span: f_name.span })
        if check_kind(TokenKind::Comma) { advance() }
    }
    eat(TokenKind::RBrace)
    return Item {
        kind: ItemKind::Struct,
        name: name_tok.text,
        span: kw.span,
        annotations: anns,
        params: fields,
        return_type: empty_type(),
        body: empty_expr(),
        is_pub: is_pub
    }
}

// enum Name { Variant1, Variant2(Type), Variant3 }
// Each variant is stored as a Param entry — name=variant name, type carries
// the (optional, single-field) payload type. Multi-field payload deferred per
// RFC-020 until the checker can model tuple variants.
fn parse_enum_item(is_pub: bool, anns: [Annotation]) -> Item {
    let kw = peek()
    eat(TokenKind::KwEnum)
    let name_tok = expect(TokenKind::Ident)
    eat(TokenKind::LBrace)
    let mut variants = []
    while !check_kind(TokenKind::RBrace) && !at_eof() {
        let v_name = expect(TokenKind::Ident)
        let mut v_ty = empty_type()
        if check_kind(TokenKind::LParen) {
            advance()
            if !check_kind(TokenKind::RParen) {
                v_ty = parse_type()
                // RFC-020: multi-field payload deferred — drain trailing
                // arguments so the brace stream stays balanced.
                while check_kind(TokenKind::Comma) {
                    advance()
                    if check_kind(TokenKind::RParen) { break }
                    parse_type()
                }
            }
            eat(TokenKind::RParen)
        }
        variants.push(Param { name: v_name.text, typ: v_ty, span: v_name.span })
        if check_kind(TokenKind::Comma) { advance() }
    }
    eat(TokenKind::RBrace)
    return Item {
        kind: ItemKind::Enum,
        name: name_tok.text,
        span: kw.span,
        annotations: anns,
        params: variants,
        return_type: empty_type(),
        body: empty_expr(),
        is_pub: is_pub
    }
}

fn parse_import_item(is_pub: bool, anns: [Annotation]) -> Item {
    let kw = peek()
    eat(TokenKind::KwImport)
    let path_tok = expect(TokenKind::String)
    return Item {
        kind: ItemKind::Import,
        name: path_tok.text,
        span: kw.span,
        annotations: anns,
        params: [],
        return_type: empty_type(),
        body: empty_expr(),
        is_pub: is_pub
    }
}

fn parse_item() -> Item {
    // accumulate annotations first
    let mut anns = []
    while check_kind(TokenKind::At) {
        anns.push(parse_annotation())
    }
    let mut is_pub = false
    if check_kind(TokenKind::KwPub) {
        advance()
        is_pub = true
    }
    if check_kind(TokenKind::KwFn) {
        return parse_fn_item(is_pub, anns)
    }
    if check_kind(TokenKind::KwLet) {
        return parse_let_item(is_pub, anns)
    }
    if check_kind(TokenKind::KwStruct) {
        return parse_struct_item(is_pub, anns)
    }
    if check_kind(TokenKind::KwEnum) {
        return parse_enum_item(is_pub, anns)
    }
    if check_kind(TokenKind::KwImport) {
        return parse_import_item(is_pub, anns)
    }
    // unknown leader — drop one token to avoid an infinite loop and emit a
    // skeletal Let item so summary tooling still has something to print.
    let t = advance()
    return Item {
        kind: ItemKind::Let,
        name: "<unknown:" + t.text + ">",
        span: t.span,
        annotations: anns,
        params: [],
        return_type: empty_type(),
        body: empty_expr(),
        is_pub: is_pub
    }
}

// ── Module entry ──────────────────────────────────────────────

fn item_is_import(k: ItemKind) -> bool {
    return match k {
        ItemKind::Import -> true,
        ItemKind::Fn -> false,
        ItemKind::Let -> false,
        ItemKind::Struct -> false,
        ItemKind::Enum -> false
    }
}

pub fn parse(tokens: [Token], file: string) -> Module {
    p_tokens = tokens
    p_pos = 0
    p_file = file
    p_diags = []
    let mut items = []
    let mut imports = []
    while !at_eof() {
        let before = p_pos
        let it = parse_item()
        items.push(it)
        if item_is_import(it.kind) {
            imports.push(it.name)
        }
        // safety net: if parse_item failed to consume, advance one token to
        // guarantee progress and avoid an infinite loop on malformed input.
        if p_pos == before {
            advance()
        }
    }
    return Module { file: file, items: items, imports: imports }
}

// Drain parser-stage diagnostics emitted during the most recent parse().
// Stage1 punch list Gap 5 — main.hexa folds these into the master diag
// list before S1+ runs so block-shape errors surface as HX0011/HX0012
// rather than as a downstream type-cascade.
pub fn parse_diags() -> array {
    return p_diags
}
