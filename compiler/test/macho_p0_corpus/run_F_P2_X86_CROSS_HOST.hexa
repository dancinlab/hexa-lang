// F-P2-X86-CROSS-HOST — cycle 31-b. Same ELF, two Linux hosts (ubu-1
// + ubu-2), same exit code. Portability oracle for the cycle 22-30
// encoder + walker output.
//
// Failure modes this catches:
//   - host-specific syscall ABI drift (shouldn't happen for sys_exit
//     but worth measuring)
//   - kernel security flag (W^X / ASLR / mprotect) differences that
//     would refuse a "fake" hand-assembled ELF on one host but not
//     another
//   - ld-linux fallback that one host has and the other doesn't (our
//     ELFs are static so this should be a no-op, again worth measuring)

import "../../emit/elf_x86_64.hexa"

struct Probe { name: string, path: string, expected_rc: i64 }

fn _launch(host: string, path: string) -> i64 {
    let cmd = "ssh " + host + " 'chmod +x " + path + " && " + path + "; echo REMOTE_RC=$?' 2>&1"
    let r = exec_capture(cmd)
    let out = to_string(r[0])
    // Parse `REMOTE_RC=N` out of stdout.
    let m = out.find("REMOTE_RC=")
    if m < 0 { return -1 }
    let tail = out.substring(m + 10, len(out))
    return tail.to_int()
}

fn main() {
    let probes: [Probe] = [
        Probe { name: "c25_countdown", path: "/tmp/p2_c25_countdown.elf", expected_rc: 0  },
        Probe { name: "c26_rex64",     path: "/tmp/p2_c26_rex64.elf",     expected_rc: 42 },
        Probe { name: "c27_div",       path: "/tmp/p2_c27_div.elf",       expected_rc: 42 },
        Probe { name: "c28_setg",      path: "/tmp/p2_c28_setg.elf",      expected_rc: 1  },
        Probe { name: "c29_walker",    path: "/tmp/p2_c29_walker.elf",    expected_rc: 42 },
        Probe { name: "c30_frame",     path: "/tmp/p2_c30_frame.elf",     expected_rc: 42 },
    ]

    // Ship each ELF to both hosts (once per host).
    let mut i = 0
    while i < len(probes) {
        let p = probes[i]
        let s1 = exec_capture("scp " + p.path + " ubu-1:" + p.path + " 2>&1")
        let s2 = exec_capture("scp " + p.path + " ubu-2:" + p.path + " 2>&1")
        if to_int(s1[2]) != 0 { println("FAIL scp " + p.name + " → ubu-1"); exit(1) }
        if to_int(s2[2]) != 0 { println("FAIL scp " + p.name + " → ubu-2"); exit(2) }
        i = i + 1
    }
    println("[scp] 6 ELFs synced to ubu-1 + ubu-2")

    // Launch each on both hosts, compare against expected_rc.
    let mut all_ok = true
    i = 0
    while i < len(probes) {
        let p = probes[i]
        let rc1 = _launch("ubu-1", p.path)
        let rc2 = _launch("ubu-2", p.path)
        let ok1 = rc1 == p.expected_rc
        let ok2 = rc2 == p.expected_rc
        let cross = rc1 == rc2
        let m1 = if ok1 { "✅" } else { "❌" }
        let m2 = if ok2 { "✅" } else { "❌" }
        let mc = if cross { "✅" } else { "❌" }
        println("  " + p.name + " expect=" + to_string(p.expected_rc) +
                " · ubu-1=" + to_string(rc1) + " " + m1 +
                " · ubu-2=" + to_string(rc2) + " " + m2 +
                " · cross-host " + mc)
        if !ok1 || !ok2 || !cross { all_ok = false }
        i = i + 1
    }

    if !all_ok {
        println("FAIL: at least one corpus probe diverged")
        exit(3)
    }
    println("🎉 F-P2-X86-CROSS-HOST FULL PASS — 6 ELFs × 2 Linux hosts (ubu-1, ubu-2) byte-identical exits")
    exit(0)
}
