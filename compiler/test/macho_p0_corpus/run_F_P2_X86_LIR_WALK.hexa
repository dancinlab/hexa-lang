// F-P2-X86-LIR-WALK — verify pack_lir_x86_64 walks a synthetic LModule
// into runnable ELF bytes, with label-based intra-fn branches resolved.
//
// Synthetic LIR — equivalent C:
//   _start:
//     int n = 10;
//   .loop:
//     n = n - 1;
//     if (n != 0) goto .loop;
//     // n now 0
//     // Compute (7 > 3) ? 1 : 0 in eax via cmp+setg+movzx.
//     int p = (7 > 3);              // p = 1
//     // Sum n + p + 41 = 0 + 1 + 41 = 42  → into rdi (exit code).
//     int x = n + p + 41;
//     exit(x);                       // rax=60, rdi=x, syscall
//
// Walker contract under test:
//   - label op → records text-offset, emits zero bytes
//   - jne to label (backward, REL8) → patched with delta = -14 (0xF2)
//   - cmp r32, r32 → 39 c8
//   - setg al → 0f 9f c0
//   - movzx edi, al → 0f b6 f8
//   - intra-fn computation routes through encoder by op-string

import "../../ir/lir.hexa"
import "../../emit/elf_x86_64.hexa"

fn _hex(v: Int) -> string {
    let hi = (v >> 4) & 0xF; let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}
fn _bs(bs: [Int]) -> string {
    let mut s = ""; let mut i = 0
    while i < len(bs) {
        if i > 0 { s = s + " " }
        s = s + _hex(bs[i] & 0xFF)
        i = i + 1
    }
    return s
}

// LIR operand constructors (mirror compiler/codegen/x86_64_linux.hexa).
fn _reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: PReg { name: name, kind: "gpr" },
        imm: 0,
        mem_base: PReg { name: "", kind: "" },
        mem_offset: 0,
        label: ""
    }
}
fn _imm(v: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: PReg { name: "", kind: "" },
        imm: v,
        mem_base: PReg { name: "", kind: "" },
        mem_offset: 0,
        label: ""
    }
}
fn _lab(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: PReg { name: "", kind: "" },
        imm: 0,
        mem_base: PReg { name: "", kind: "" },
        mem_offset: 0,
        label: name
    }
}

fn _ins0(op: string) -> LInstr {
    return LInstr { op: op, args: [], comment: "" }
}
fn _ins1(op: string, a: LOperand) -> LInstr {
    let xs: [LOperand] = []; xs.push(a)
    return LInstr { op: op, args: xs, comment: "" }
}
fn _ins2(op: string, a: LOperand, b: LOperand) -> LInstr {
    let xs: [LOperand] = []; xs.push(a); xs.push(b)
    return LInstr { op: op, args: xs, comment: "" }
}
fn _lbl(name: string) -> LInstr {
    // label op carries the name in args[0].label.
    let xs: [LOperand] = []; xs.push(_lab(name))
    return LInstr { op: "label", args: xs, comment: name }
}

fn main() {
    // Build the LFunc.
    let instrs: [LInstr] = []
    instrs.push(_ins2("mov", _reg("eax"), _imm(10)))      // n = 10
    instrs.push(_lbl("loop"))
    instrs.push(_ins2("sub", _reg("eax"), _imm(1)))       // n -= 1
    instrs.push(_ins2("cmp", _reg("eax"), _imm(0)))       // cmp n, 0
    instrs.push(_ins1("jne", _lab("loop")))               // backward REL8
    // Now eax = 0. Compute (7 > 3) → 1 in al.
    instrs.push(_ins2("mov", _reg("ecx"), _imm(7)))
    instrs.push(_ins2("mov", _reg("edx"), _imm(3)))
    instrs.push(_ins2("cmp", _reg("ecx"), _reg("edx")))   // cmp ecx, edx
    instrs.push(_ins1("setg", _reg("al")))                // al = 1
    instrs.push(_ins2("movzx", _reg("edi"), _reg("al")))  // edi = 1
    // Add n (eax=0) + p (edi=1) + 41 = 42 — `setg al` clobbered AL so
    // EAX is now 1 (not 0); use `mov eax, 41` to reset cleanly, then
    // add edi + eax = 1 + 41 = 42. This explicitly exercises both
    // intra-fn MOV (r32 imm) + ADD (r32 r32) post-SETcc contamination.
    instrs.push(_ins2("mov", _reg("eax"), _imm(41)))       // eax = 41 (reset)
    instrs.push(_ins2("add", _reg("edi"), _reg("eax")))    // edi = 42
    // exit(edi)
    instrs.push(_ins2("mov", _reg("eax"), _imm(60)))
    instrs.push(_ins0("syscall"))

    let f = LFunc {
        name: "_start",
        target: "x86_64-linux-gnu",
        instrs: instrs,
        frame_size: 0,
        callee_saved: [],
        def_line: 0,
    }
    let lm = LModule {
        file: "synthetic",
        target: "x86_64-linux-gnu",
        funcs: [f],
        rodata: [],
        bss: [],
        globals: [],
        floats: [],
    }

    let obj = pack_lir_x86_64(lm)
    println("[pack_lir_x86_64] text " + to_string(len(obj.text)) +
            " B, " + to_string(len(obj.symbols)) + " symbol(s)")
    println("  " + _bs(obj.text))

    // Spot-check critical instructions are present where expected.
    //   bytes 5  - label "loop" anchor (after `mov eax, 10`)
    //   bytes 5+0..6 = sub eax, 1 = 81 e8 01 00 00 00
    //   bytes 11..17 = cmp eax, 0 = 81 f8 00 00 00 00
    //   bytes 17..19 = jne rel8   = 75 f2  (delta = -14)
    let txt = obj.text
    let mut ok = true
    if (txt[0] & 0xFF) != 0xB8 || (txt[1] & 0xFF) != 0x0A {
        println("FAIL: mov eax,10 not at offset 0"); ok = false
    }
    if (txt[5] & 0xFF) != 0x81 || (txt[6] & 0xFF) != 0xE8 {
        println("FAIL: sub eax,1 not at offset 5 (label loop anchor)"); ok = false
    }
    if (txt[17] & 0xFF) != 0x75 || (txt[18] & 0xFF) != 0xF2 {
        println("FAIL: jne rel8 with delta=-14 not at offset 17 (got " +
                _hex(txt[17] & 0xFF) + " " + _hex(txt[18] & 0xFF) + ")")
        ok = false
    }
    if !ok { exit(1) }
    println("✅ byte-eq spot checks PASS (mov / sub / jne 0xF2 patch)")

    // Build standalone exec ELF and launch on ubu-2.
    let elf = serialize_elf_exec_x86_64(obj.text)
    let elf_path = "/tmp/p2_c29_walker.elf"
    write_bytes(elf_path, elf)
    let scp = exec_capture("scp " + elf_path + " ubu-2:/tmp/p2_c29_walker.elf 2>&1")
    if to_int(scp[2]) != 0 { println("FAIL scp"); exit(2) }
    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c29_walker.elf && /tmp/p2_c29_walker.elf; echo REMOTE_RC=$?' 2>&1")
    let rout = to_string(r[0])
    println("ubu-2: " + rout)
    if rout.find("REMOTE_RC=42") < 0 {
        println("FAIL: synthetic LIR program did not exit 42")
        exit(3)
    }

    println("🎉 F-P2-X86-LIR-WALK FULL PASS — pack_lir_x86_64 walks synthetic LModule → ELF → ubu-2 exit 42")
    exit(0)
}
