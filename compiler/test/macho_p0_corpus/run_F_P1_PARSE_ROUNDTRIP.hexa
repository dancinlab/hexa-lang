// F-P1-PARSE-ROUNDTRIP — P1 cycle 1 falsifier.
//
// Re-parse our own cycle 7 corpus_*.ours.o files via
// `tool/hexa_ld.hexa::parse_macho_obj` and check the ParsedObj
// invariants. This is the parser's correctness contract: anything
// hexa-side `serialize()` emits, hexa-side `parse_macho_obj()` reads
// back faithfully.

import "../../../tool/hexa_ld.hexa"

fn _expect_eq(label: string, got: Int, want: Int) {
    if got != want {
        println("FAIL: " + label + ": got " + to_string(got) + " want " + to_string(want))
        exit(1)
    }
}

fn _expect_eqs(label: string, got: string, want: string) {
    if got != want {
        println("FAIL: " + label + ": got \"" + got + "\" want \"" + want + "\"")
        exit(2)
    }
}

fn main() {
    // ─── trivial.hexa: 48-B __text, 1 defined (_main), 2 externs (_hexa_set_args, _hexa_exit), 2 BR26
    let t = parse_macho_obj("/tmp/corpus_trivial.ours.o")
    _expect_eq("trivial.text.len", len(t.text), 48)
    _expect_eq("trivial.defined.len", len(t.defined), 1)
    _expect_eqs("trivial.defined[0].name", t.defined[0].name, "_main")
    _expect_eq("trivial.defined[0].offset", t.defined[0].offset, 0)
    _expect_eq("trivial.extern_refs.len", len(t.extern_refs), 2)
    // extern order = pack order. _hexa_set_args 는 set_args 의 reloc 시 처음 등장.
    _expect_eqs("trivial.extern[0].name", t.extern_refs[0].name, "_hexa_set_args")
    _expect_eqs("trivial.extern[1].name", t.extern_refs[1].name, "_hexa_exit")
    _expect_eq("trivial.relocs.len", len(t.relocs), 2)
    // First BL @ 0x8 → _hexa_set_args, second @ 0x18 → _hexa_exit.
    _expect_eq("trivial.reloc[0].offset", t.relocs[0].offset, 8)
    _expect_eqs("trivial.reloc[0].sym",   t.relocs[0].sym_name, "_hexa_set_args")
    _expect_eq("trivial.reloc[0].kind",   t.relocs[0].kind, 2)         // BRANCH26
    _expect_eq("trivial.reloc[0].pcrel",  t.relocs[0].pcrel, 1)
    _expect_eq("trivial.reloc[0].length", t.relocs[0].length, 2)
    _expect_eq("trivial.reloc[1].offset", t.relocs[1].offset, 0x18)
    _expect_eqs("trivial.reloc[1].sym",   t.relocs[1].sym_name, "_hexa_exit")
    println("trivial.ours.o parsed: text=" + to_string(len(t.text)) +
            " defined=" + to_string(len(t.defined)) +
            " extern=" + to_string(len(t.extern_refs)) +
            " relocs=" + to_string(len(t.relocs)))

    // ─── fib.hexa: 2 defined (_fib, _main), 6 externs (_hexa_*), 10 relocs
    let f = parse_macho_obj("/tmp/corpus_fib.ours.o")
    _expect_eq("fib.defined.len", len(f.defined), 2)
    _expect_eqs("fib.defined[0].name", f.defined[0].name, "_fib")
    _expect_eq("fib.defined[0].offset", f.defined[0].offset, 0)
    _expect_eqs("fib.defined[1].name", f.defined[1].name, "_main")
    _expect_eq("fib.defined[1].offset", f.defined[1].offset, 0xa8)
    _expect_eq("fib.relocs.len", len(f.relocs), 10)
    println("fib.ours.o parsed: text=" + to_string(len(f.text)) +
            " defined=" + to_string(len(f.defined)) +
            " extern=" + to_string(len(f.extern_refs)) +
            " relocs=" + to_string(len(f.relocs)))

    println("F-P1-PARSE-ROUNDTRIP PASS — parser reads back hexa-side .o output")
    exit(0)
}
