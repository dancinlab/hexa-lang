// F-P1-CODESIGN — P1 cycle 5 falsifier.
//
// After link_macho_arm64 integrates `codesign -s -`, the exec carries
// an ad-hoc CMS signature. `codesign -dvv` recognises it. Attempted
// launch returns rc=137 (SIGKILL) — dyld kills the process when it
// can't resolve `_hexa_set_args` / `_hexa_exit`. The kill is the
// expected next-blocker, NOT a regression: cycle 6 (lazy-bind) is
// what teaches dyld where those symbols live.

import "../../../tool/hexa_ld.hexa"

fn main() {
    let p = parse_macho_obj("/tmp/corpus_trivial.ours.o")
    let out_path = "/tmp/p1_c5_codesigned.exec"
    let objs: [ParsedObj] = [p]
    let rc = link_macho_arm64(objs, out_path, "_main", 0)
    if rc != 0 { println("FAIL: link rc=" + to_string(rc)); exit(1) }

    let cs = exec_capture("codesign -dvv " + out_path + " 2>&1")
    let cs_out = to_string(cs[0])
    println("=== codesign -dvv ===")
    println(cs_out)

    let mut ok = true
    if cs_out.find("Format=Mach-O thin (arm64)") < 0 {
        println("FAIL: codesign couldn't parse our Mach-O")
        ok = false
    }
    if cs_out.find("adhoc") < 0 {
        println("FAIL: expected 'adhoc' Signature in codesign output")
        ok = false
    }
    if cs_out.find("Authority=") >= 0 {
        println("FAIL: ad-hoc sign should have no Authority")
        ok = false
    }

    // Attempt launch — expect rc=137 (SIGKILL from dyld unresolved-symbol
    // protection). cycle 6 fixes by emitting lazy-bind stubs.
    let run = exec_capture(out_path + " 2>&1")
    let run_rc = to_int(run[2])
    println("=== launch attempt ===")
    println("  rc=" + to_string(run_rc))
    println("  (cycle 6 baton: rc=137 = SIGKILL from dyld unresolved symbols —")
    println("   _hexa_set_args / _hexa_exit lazy-bind path missing.)")
    if run_rc != 137 {
        println("NOTE: unexpected rc " + to_string(run_rc) + " (expected 137 for unresolved-extern kill)")
        // Not a fail — informative.  Different macOS versions may differ.
    }

    if !ok { exit(2) }

    println("F-P1-CODESIGN PASS — exec ad-hoc signed; dyld unresolved-extern kill = cycle 6 baton")
    exit(0)
}
