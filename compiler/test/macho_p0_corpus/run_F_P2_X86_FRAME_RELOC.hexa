// F-P2-X86-FRAME-RELOC — cycle 30. Verify pack_lir_x86_64 handles:
//   (a) mem operands `[rbp - 8]` / `[rsp + N]` with ModR/M+SIB+disp
//   (b) PUSH64/POP64/LEA64 for real frame setup
//   (c) intra-module CALL → pre-patched delta + R_X86_64_PLT32 reloc
//
// Synthetic LIR — two functions:
//
//   compute(a, b):              # a in rdi, b in rsi (System V ABI)
//     push rbp
//     mov rbp, rsp
//     sub rsp, 16
//     mov [rbp - 8], rdi        # save a
//     mov [rbp - 16], rsi       # save b
//     mov rax, [rbp - 8]
//     add rax, [rbp - 16]       # rax = a + b   (cycle-30 needs add r64, mem
//                               #  — not implemented this cycle; use mov+add)
//     # Workaround: mov rcx, [rbp-16]; add rax, rcx
//     leave-equiv:
//     mov rsp, rbp
//     pop rbp
//     ret
//
//   _start:
//     mov rdi, #20
//     mov rsi, #22
//     call compute              # intra-module → pre-patch + PLT32 reloc
//     mov rdi, rax              # 42
//     mov rax, #60
//     syscall

import "../../ir/lir.hexa"
import "../../emit/elf_x86_64.hexa"

fn _hex(v: Int) -> string {
    let hi = (v >> 4) & 0xF; let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}
fn _bs(bs: [Int]) -> string {
    let mut s = ""; let mut i = 0
    while i < len(bs) {
        if i > 0 { s = s + " " }
        s = s + _hex(bs[i] & 0xFF)
        i = i + 1
    }
    return s
}

fn _reg(name: string) -> LOperand {
    return LOperand {
        kind: "reg",
        reg: PReg { name: name, kind: "gpr" },
        imm: 0,
        mem_base: PReg { name: "", kind: "" },
        mem_offset: 0,
        label: ""
    }
}
fn _imm(v: i64) -> LOperand {
    return LOperand {
        kind: "imm",
        reg: PReg { name: "", kind: "" },
        imm: v,
        mem_base: PReg { name: "", kind: "" },
        mem_offset: 0,
        label: ""
    }
}
fn _lab(name: string) -> LOperand {
    return LOperand {
        kind: "label",
        reg: PReg { name: "", kind: "" },
        imm: 0,
        mem_base: PReg { name: "", kind: "" },
        mem_offset: 0,
        label: name
    }
}
fn _mem(base: string, off: i64) -> LOperand {
    return LOperand {
        kind: "mem",
        reg: PReg { name: "", kind: "" },
        imm: 0,
        mem_base: PReg { name: base, kind: "gpr" },
        mem_offset: off,
        label: ""
    }
}

fn _ins0(op: string) -> LInstr {
    return LInstr { op: op, args: [], comment: "" }
}
fn _ins1(op: string, a: LOperand) -> LInstr {
    let xs: [LOperand] = []; xs.push(a)
    return LInstr { op: op, args: xs, comment: "" }
}
fn _ins2(op: string, a: LOperand, b: LOperand) -> LInstr {
    let xs: [LOperand] = []; xs.push(a); xs.push(b)
    return LInstr { op: op, args: xs, comment: "" }
}

fn main() {
    // --- compute(a, b) = a + b -------------------------------------
    let compute_instrs: [LInstr] = []
    compute_instrs.push(_ins1("push", _reg("rbp")))
    compute_instrs.push(_ins2("mov",  _reg("rbp"), _reg("rsp")))
    compute_instrs.push(_ins2("sub",  _reg("rsp"), _imm(16)))
    compute_instrs.push(_ins2("mov",  _mem("rbp", -8),  _reg("rdi")))   // save a
    compute_instrs.push(_ins2("mov",  _mem("rbp", -16), _reg("rsi")))   // save b
    compute_instrs.push(_ins2("mov",  _reg("rax"),     _mem("rbp", -8)))  // rax = a
    compute_instrs.push(_ins2("mov",  _reg("rcx"),     _mem("rbp", -16))) // rcx = b
    compute_instrs.push(_ins2("add",  _reg("rax"),     _reg("rcx")))      // rax = a + b
    compute_instrs.push(_ins2("mov",  _reg("rsp"),     _reg("rbp")))      // leave
    compute_instrs.push(_ins1("pop",  _reg("rbp")))
    compute_instrs.push(_ins0("ret"))

    // --- _start ----------------------------------------------------
    let start_instrs: [LInstr] = []
    start_instrs.push(_ins2("mov",  _reg("rdi"), _imm(20)))
    start_instrs.push(_ins2("mov",  _reg("rsi"), _imm(22)))
    start_instrs.push(_ins1("call", _lab("compute")))      // intra-module
    start_instrs.push(_ins2("mov",  _reg("rdi"), _reg("rax")))
    start_instrs.push(_ins2("mov",  _reg("rax"), _imm(60)))
    start_instrs.push(_ins0("syscall"))

    let f_start = LFunc {
        name: "_start", target: "x86_64-linux-gnu",
        instrs: start_instrs, frame_size: 0, callee_saved: [], def_line: 0,
    }
    let f_compute = LFunc {
        name: "compute", target: "x86_64-linux-gnu",
        instrs: compute_instrs, frame_size: 16, callee_saved: [], def_line: 0,
    }
    let lm = LModule {
        file: "frame_reloc",
        target: "x86_64-linux-gnu",
        funcs: [f_start, f_compute],         // _start FIRST so ELF entry==0
        rodata: [], bss: [], globals: [], floats: [],
    }

    let obj = pack_lir_x86_64(lm)
    println("[pack_lir_x86_64] text " + to_string(len(obj.text)) +
            " B, " + to_string(len(obj.symbols)) + " symbol(s), " +
            to_string(len(obj.relocs)) + " reloc(s)")
    println("  " + _bs(obj.text))

    // Reloc oracle: cycle-30 should have emitted ONE R_X86_64_PLT32 reloc
    // for `call compute` even though it's intra-module (linker contract).
    if len(obj.relocs) != 1 {
        println("FAIL: expected 1 reloc record, got " + to_string(len(obj.relocs)))
        exit(1)
    }
    let r = obj.relocs[0]
    if r.kind != 4 {  // R_X86_64_PLT32
        println("FAIL: reloc kind " + to_string(r.kind) + " != 4 (PLT32)")
        exit(2)
    }
    if r.addend != -4 {
        println("FAIL: reloc addend " + to_string(r.addend) + " != -4")
        exit(3)
    }
    println("✅ reloc record OK — PLT32 with addend=-4 at offset " + to_string(r.offset))

    // Byte-eq spot checks:
    //   _start at offset 0:
    //     48 c7 c7 14 00 00 00     mov rdi, 20        (7 B)
    //     48 c7 c6 16 00 00 00     mov rsi, 22        (7 B)
    //     e8 ?? ?? ?? ??           call compute       (5 B, imm32=patched)
    //     48 89 c7                 mov rdi, rax       (3 B)
    //     48 c7 c0 3c 00 00 00     mov rax, 60        (7 B)
    //     0f 05                    syscall            (2 B)
    //   = 31 B total for _start
    //
    // compute starts at offset 31:
    //     55                       push rbp
    //     48 89 e5                 mov rbp, rsp
    //     48 81 ec 10 00 00 00     sub rsp, 16
    //     48 89 7d f8              mov [rbp-8], rdi       (4 B: 48 89 7D F8)
    //     48 89 75 f0              mov [rbp-16], rsi
    //     48 8b 45 f8              mov rax, [rbp-8]
    //     48 8b 4d f0              mov rcx, [rbp-16]
    //     48 01 c8                 add rax, rcx
    //     48 89 ec                 mov rsp, rbp
    //     5d                       pop rbp
    //     c3                       ret
    let txt = obj.text
    let mut ok = true
    // Check `mov rdi, 20` at offset 0
    if (txt[0] & 0xFF) != 0x48 || (txt[1] & 0xFF) != 0xC7 || (txt[2] & 0xFF) != 0xC7 {
        println("FAIL: mov rdi, 20 not at offset 0"); ok = false
    }
    // Check `call compute` at offset 14 (start of E8)
    if (txt[14] & 0xFF) != 0xE8 {
        println("FAIL: call compute opcode not at offset 14"); ok = false
    }
    // CALL imm32 should be pre-patched: target=31, call_off=14, next_pc=14+5=19
    //   delta = 31 - 19 = 12 = 0x0C
    if (txt[15] & 0xFF) != 0x0C {
        println("FAIL: call delta " + _hex(txt[15] & 0xFF) + " != 0c")
        ok = false
    }
    // compute at offset 31: push rbp = 55
    if (txt[31] & 0xFF) != 0x55 {
        println("FAIL: push rbp not at offset 31 (compute start)"); ok = false
    }
    // mov [rbp-8], rdi at offset 31+1+3+7 = 42: 48 89 7d f8
    if (txt[42] & 0xFF) != 0x48 || (txt[43] & 0xFF) != 0x89 ||
       (txt[44] & 0xFF) != 0x7D || (txt[45] & 0xFF) != 0xF8 {
        println("FAIL: mov [rbp-8], rdi not at expected offset (got " +
                _hex(txt[42] & 0xFF) + " " + _hex(txt[43] & 0xFF) + " " +
                _hex(txt[44] & 0xFF) + " " + _hex(txt[45] & 0xFF) + ")")
        ok = false
    }
    if !ok { exit(4) }
    println("✅ byte-eq spot checks PASS (call delta=0x0c · push rbp · mov [rbp-8],rdi)")

    // Build standalone exec ELF and run on ubu-2.
    let elf = serialize_elf_exec_x86_64(obj.text)
    let elf_path = "/tmp/p2_c30_frame.elf"
    write_bytes(elf_path, elf)
    let scp = exec_capture("scp " + elf_path + " ubu-2:/tmp/p2_c30_frame.elf 2>&1")
    if to_int(scp[2]) != 0 { println("FAIL scp"); exit(5) }
    let r2 = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c30_frame.elf && /tmp/p2_c30_frame.elf; echo REMOTE_RC=$?' 2>&1")
    let rout = to_string(r2[0])
    println("ubu-2: " + rout)
    if rout.find("REMOTE_RC=42") < 0 {
        println("FAIL: frame+call did not exit 42")
        exit(6)
    }

    println("🎉 F-P2-X86-FRAME-RELOC FULL PASS — frame setup + intra-module call + PLT32 reloc record · exit 42")
    exit(0)
}
