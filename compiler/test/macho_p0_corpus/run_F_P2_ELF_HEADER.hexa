// F-P2-ELF-HEADER — P2 cycle 1 falsifier.
//
// Build an empty ELF x86_64 relocatable object via serialize_elf_x86_64
// and verify the byte stream's structural invariants:
//   - 4-byte magic: 0x7F 'E' 'L' 'F'
//   - ELFCLASS64 = 2
//   - ELFDATA2LSB = 1
//   - EV_CURRENT = 1
//   - e_type = ET_REL (1)
//   - e_machine = EM_X86_64 (0x3E)
//   - e_ehsize = 64, e_shentsize = 64, e_shnum = 5
//   - section header table offset valid

import "../../emit/elf_x86_64.hexa"

fn _expect(label: string, got: Int, want: Int) -> bool {
    if got != want {
        println("FAIL: " + label + ": got " + to_string(got) + " want " + to_string(want))
        return false
    }
    return true
}

fn main() {
    let obj: ElfX86Obj = ElfX86Obj {
        text:    [],
        relocs:  [],
        symbols: [],
        strtab:  [],
    }
    let bytes = serialize_elf_x86_64(obj)
    let n = len(bytes)
    println("F-P2-ELF-HEADER: serialized " + to_string(n) + " bytes")

    let mut ok = true
    ok = _expect("EI_MAG0", bytes[0], 0x7F) && ok
    ok = _expect("EI_MAG1", bytes[1], 0x45) && ok        // 'E'
    ok = _expect("EI_MAG2", bytes[2], 0x4C) && ok        // 'L'
    ok = _expect("EI_MAG3", bytes[3], 0x46) && ok        // 'F'
    ok = _expect("EI_CLASS=ELFCLASS64", bytes[4], 2) && ok
    ok = _expect("EI_DATA=ELFDATA2LSB", bytes[5], 1) && ok
    ok = _expect("EI_VERSION", bytes[6], 1) && ok

    // e_type @ offset 16, u16 LE
    let e_type = bytes[16] | (bytes[17] << 8)
    ok = _expect("e_type=ET_REL", e_type, 1) && ok

    // e_machine @ offset 18, u16 LE
    let e_machine = bytes[18] | (bytes[19] << 8)
    ok = _expect("e_machine=EM_X86_64", e_machine, 0x3E) && ok

    // e_ehsize @ offset 52, u16 LE
    let e_ehsize = bytes[52] | (bytes[53] << 8)
    ok = _expect("e_ehsize", e_ehsize, 64) && ok

    // e_shentsize @ offset 58, u16 LE
    let e_shentsize = bytes[58] | (bytes[59] << 8)
    ok = _expect("e_shentsize", e_shentsize, 64) && ok

    // e_shnum @ offset 60, u16 LE
    let e_shnum = bytes[60] | (bytes[61] << 8)
    ok = _expect("e_shnum", e_shnum, 5) && ok

    // e_shstrndx @ offset 62, u16 LE
    let e_shstrndx = bytes[62] | (bytes[63] << 8)
    ok = _expect("e_shstrndx", e_shstrndx, 4) && ok

    write_bytes("/tmp/p2_c1_empty.elf.o", bytes)
    println("  wrote " + to_string(n) + " bytes to /tmp/p2_c1_empty.elf.o")

    // External oracle — `file` command should recognize ELF.
    let f = exec_capture("file /tmp/p2_c1_empty.elf.o 2>&1")
    let f_out = to_string(f[0])
    println("=== file ===")
    println(f_out)
    if f_out.find("ELF") < 0 {
        println("FAIL: `file` did not recognize output as ELF")
        ok = false
    }
    if f_out.find("64-bit") < 0 {
        println("FAIL: `file` did not see 64-bit")
        ok = false
    }
    if f_out.find("x86-64") < 0 && f_out.find("x86_64") < 0 {
        println("FAIL: `file` did not see x86-64 machine")
        ok = false
    }
    if f_out.find("relocatable") < 0 {
        println("FAIL: `file` did not see relocatable (ET_REL)")
        ok = false
    }

    if !ok { exit(1) }

    println("F-P2-ELF-HEADER PASS — ELF64 x86_64 relocatable object well-formed")
    exit(0)
}
