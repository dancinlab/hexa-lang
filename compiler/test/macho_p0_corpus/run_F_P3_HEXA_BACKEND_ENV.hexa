// F-P3-HEXA-BACKEND-ENV — verify HEXA_BACKEND env var is honored.
//
// Resolution chain test:
//   1. HEXA_BACKEND=system + no --backend flag  → system (legacy as)
//   2. HEXA_BACKEND=native + no --backend       → native
//   3. HEXA_BACKEND unset + no --backend        → auto-flip native
//      (for target=arm64-darwin + emit=obj)
//   4. --backend=system + HEXA_BACKEND=native   → CLI flag wins
//
// Test case (2): HEXA_BACKEND=native with stripped PATH should produce
// Mach-O .o without forking clang/as.

import "../../../tool/hexa_ld.hexa"

fn main() {
    let aprime = "/tmp/aprime_s7"
    let src = "compiler/test/macho_p0_corpus/trivial.hexa"
    let out_path = "/tmp/p3_env_native.o"

    // Case (2): HEXA_BACKEND=native + stripped PATH (no clang/as).
    //   No --backend= flag — env should set backend_kind.
    let cmd = "env -i HEXA_BACKEND=native PATH=/usr/bin:/bin " + aprime +
              " _drv.hexa --target=arm64-apple-darwin --emit=obj " +
              "-o " + out_path + " " + src + " 2>&1"
    let r = exec_capture(cmd)
    let r_rc = to_int(r[2])
    println("=== HEXA_BACKEND=native, no --backend flag, stripped PATH ===")
    println(to_string(r[0]))
    println("rc=" + to_string(r_rc))

    if r_rc != 0 {
        println("FAIL: HEXA_BACKEND=native env var not honored (rc=" + to_string(r_rc) + ")")
        exit(1)
    }
    let f = exec_capture("file " + out_path + " 2>&1")
    let f_out = to_string(f[0])
    println(f_out)
    if f_out.find("Mach-O") < 0 {
        println("FAIL: output not Mach-O")
        exit(2)
    }

    println("✅ F-P3-HEXA-BACKEND-ENV PASS — HEXA_BACKEND env var honored (native = no clang/as fork)")
    exit(0)
}
