// F-P2-LINUX-EXIT — P2 cycle 3 falsifier.
//
// Build a static ELF exec on macOS (via hexa_ld's serialize_elf_exec
// _x86_64) + sync to ubu-2 (Linux x86_64) + launch + check exit 42.
//
// Linux analog of P1 cycle 7's arm64 SVC syscall exec — proves the
// ELF emitter path works end-to-end without lazy-bind / dyld /
// codesign (Linux has none of those).

import "../../emit/elf_x86_64.hexa"

fn main() {
    // 12-byte exit(42) via Linux x86_64 BSD syscall:
    //   B8 3C 00 00 00   mov eax, #60   (sys_exit)
    //   BF 2A 00 00 00   mov edi, #42   (exit code)
    //   0F 05            syscall
    let mov_eax = encode_x86_64_insn("MOV", ["eax", "#60"])
    let mov_edi = encode_x86_64_insn("MOV", ["edi", "#42"])
    let syscall = encode_x86_64_insn("SYSCALL", [])

    let text: [Int] = []
    let mut i = 0
    while i < len(mov_eax) { text.push(mov_eax[i]); i = i + 1 }
    i = 0
    while i < len(mov_edi) { text.push(mov_edi[i]); i = i + 1 }
    i = 0
    while i < len(syscall) { text.push(syscall[i]); i = i + 1 }

    println("encoded 12-byte exit(42): len=" + to_string(len(text)))

    let bytes = serialize_elf_exec_x86_64(text)
    let out_path = "/tmp/p2_c3_linux_exit.elf"
    write_bytes(out_path, bytes)

    let n = len(bytes)
    println("wrote " + to_string(n) + " bytes to " + out_path)

    let f = exec_capture("file " + out_path + " 2>&1")
    println("=== file ===")
    println(to_string(f[0]))

    // Sync to ubu-2 and launch.
    println("=== scp to ubu-2 ===")
    let scp = exec_capture("scp " + out_path + " ubu-2:/tmp/p2_c3_linux_exit.elf 2>&1")
    if to_int(scp[2]) != 0 {
        println("FAIL: scp rc=" + to_string(to_int(scp[2])))
        println(to_string(scp[1]))
        exit(2)
    }

    println("=== launch on ubu-2 ===")
    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c3_linux_exit.elf && /tmp/p2_c3_linux_exit.elf; echo \"REMOTE_RC=$?\"' 2>&1")
    let r_out = to_string(r[0])
    println(r_out)

    if r_out.find("REMOTE_RC=42") < 0 {
        println("FAIL: exec did not exit(42) on Linux x86_64")
        exit(3)
    }

    println("🛸 F-P2-LINUX-EXIT FULL PASS — hexa-ld-built ELF exec runs on Linux + exits 42")
    exit(0)
}
