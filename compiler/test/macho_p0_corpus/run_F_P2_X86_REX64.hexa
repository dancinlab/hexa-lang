// F-P2-X86-REX64 — x86_64 r64 (REX.W) encoding verification + native
// 64-bit exit(42) program on Linux ubu-2.
//
// Expected encoding (Intel manual / objdump):
//   MOV RAX, #60        48 c7 c0 3c 00 00 00
//   MOV RDI, #42        48 c7 c7 2a 00 00 00
//   MOV RDI, RAX        48 89 c7
//   ADD RAX, #1         48 81 c0 01 00 00 00
//   SUB RAX, #1         48 81 e8 01 00 00 00
//   ADD RAX, RBX        48 01 d8
//   SUB RAX, RBX        48 29 d8
//   MOV R8,  #1         49 c7 c0 01 00 00 00   (REX.B for r8)
//   MOV RAX, R8         4c 89 c0               (REX.R for src=r8)

import "../../emit/elf_x86_64.hexa"

fn _hex(v: Int) -> string {
    let hi = (v >> 4) & 0xF; let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}
fn _bs(bs: [Int]) -> string {
    let mut s = ""; let mut i = 0
    while i < len(bs) { if i > 0 { s = s + " " }; s = s + _hex(bs[i] & 0xFF); i = i + 1 }
    return s
}
fn _eq(label: string, got: [Int], want: [Int]) -> bool {
    if len(got) != len(want) { println("FAIL " + label + ": len " + to_string(len(got)) + " vs " + to_string(len(want))); return false }
    let mut i = 0
    while i < len(got) {
        if (got[i] & 0xFF) != want[i] {
            println("FAIL " + label + " byte " + to_string(i) + ": " + _hex(got[i] & 0xFF) + " vs " + _hex(want[i]))
            return false
        }
        i = i + 1
    }
    return true
}

fn main() {
    let mut ok = true

    let cases: [string] = [
        "MOV64 RAX,#60", "MOV64 RDI,#42", "MOV64 RDI,RAX",
        "ADD64 RAX,#1", "SUB64 RAX,#1",
        "ADD64 RAX,RBX", "SUB64 RAX,RBX",
        "MOV64 R8,#1", "MOV64 RAX,R8",
    ]
    let want: [[Int]] = [
        [0x48, 0xC7, 0xC0, 0x3C, 0x00, 0x00, 0x00],
        [0x48, 0xC7, 0xC7, 0x2A, 0x00, 0x00, 0x00],
        [0x48, 0x89, 0xC7],
        [0x48, 0x81, 0xC0, 0x01, 0x00, 0x00, 0x00],
        [0x48, 0x81, 0xE8, 0x01, 0x00, 0x00, 0x00],
        [0x48, 0x01, 0xD8],
        [0x48, 0x29, 0xD8],
        [0x49, 0xC7, 0xC0, 0x01, 0x00, 0x00, 0x00],
        [0x4C, 0x89, 0xC0],
    ]
    let got: [[Int]] = [
        encode_x86_64_insn("MOV64", ["rax", "#60"]),
        encode_x86_64_insn("MOV64", ["rdi", "#42"]),
        encode_x86_64_insn("MOV64", ["rdi", "rax"]),
        encode_x86_64_insn("ADD64", ["rax", "#1"]),
        encode_x86_64_insn("SUB64", ["rax", "#1"]),
        encode_x86_64_insn("ADD64", ["rax", "rbx"]),
        encode_x86_64_insn("SUB64", ["rax", "rbx"]),
        encode_x86_64_insn("MOV64", ["r8",  "#1"]),
        encode_x86_64_insn("MOV64", ["rax", "r8"]),
    ]
    let mut i = 0
    while i < len(cases) {
        println(cases[i] + " → " + _bs(got[i]))
        if !_eq(cases[i], got[i], want[i]) { ok = false }
        i = i + 1
    }
    if !ok { exit(1) }

    // Genuine 64-bit exit(42) program:
    //   mov rax, #60        48 c7 c0 3c 00 00 00     (7 B)
    //   mov rdi, #42        48 c7 c7 2a 00 00 00     (7 B)
    //   syscall             0f 05                     (2 B)
    // Total: 16 bytes (vs 12-byte 32-bit version)
    let prog: [Int] = []
    let m_rax = encode_x86_64_insn("MOV64", ["rax", "#60"])
    let mut k = 0
    while k < len(m_rax) { prog.push(m_rax[k]); k = k + 1 }
    let m_rdi = encode_x86_64_insn("MOV64", ["rdi", "#42"])
    k = 0
    while k < len(m_rdi) { prog.push(m_rdi[k]); k = k + 1 }
    let sc = encode_x86_64_insn("SYSCALL", [])
    k = 0
    while k < len(sc) { prog.push(sc[k]); k = k + 1 }
    println("\n[64-bit exit(42) program: " + to_string(len(prog)) + " B]")
    println("  " + _bs(prog))

    let elf = serialize_elf_exec_x86_64(prog)
    let elf_path = "/tmp/p2_c26_rex64.elf"
    write_bytes(elf_path, elf)
    let scp = exec_capture("scp " + elf_path + " ubu-2:/tmp/p2_c26_rex64.elf 2>&1")
    if to_int(scp[2]) != 0 { println("FAIL scp"); exit(2) }
    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c26_rex64.elf && /tmp/p2_c26_rex64.elf; echo REMOTE_RC=$?' 2>&1")
    let rout = to_string(r[0])
    println("ubu-2: " + rout)
    if rout.find("REMOTE_RC=42") < 0 {
        println("FAIL: 64-bit exit did not return 42")
        exit(3)
    }

    println("🎉 F-P2-X86-REX64 FULL PASS — 9 r64 ops byte-eq + native 64-bit exit on Linux")
    exit(0)
}
