// F-P1-LINKEXEC — RFC 063 § P1 linker run-equivalence falsifier.
//
// HEXA_BACKEND flip · chunk-B phase-H first increment.
//
// Proves the hexa-native Mach-O linker (`tool/hexa_ld.hexa`) merges
// TWO `MH_OBJECT` `.o` files into ONE runnable `MH_EXECUTE` with NO
// `clang`/`ld`/`as` in the LINK step, resolving a cross-object
// `ARM64_RELOC_BRANCH26` (`bl` to a symbol defined in the OTHER object).
//
// SCOPE (honest, g3): single-`__text` + BRANCH26-only. The two input
// `.o`s are produced by `clang -c` (a CONTROL oracle — explicitly
// allowed as INPUT; the runtime C→hexa + multi-section/PAGE21 reloc
// support are separate chunks). The LINKER is 100% hexa-native.
//
// Program modeled (exit-code-bearing, syscall-only — mirrors the
// runtime's `svc #0x80` model so the produced exe needs NO function
// imports, `nm -u` == empty):
//
//   _start: bl _rt_answer ; bl _rt_exit         (object A: user.o)
//   _rt_answer: mov x0,#42 ; ret                 (object B: rt.o)
//   _rt_exit:   mov x16,#1 ; svc #0x80           (object B: rt.o)
//
// Falsifier: the linked binary must run to exit(42). A non-42 exit (or
// a SIGKILL=137 / SIGBUS=138) FALSIFIES the hexa-native link.

fn _wf(path: string, body: string) {
    write_file(path, body)
}

fn main() {
    let repo = env("HEXA_LANG")
    if len(repo) == 0 {
        eprintln("F-P1-LINKEXEC: HEXA_LANG unset — skip")
        exit(0)
    }
    let tmp = exec_capture("mktemp -d -t hxld_linkexec.XXXXXX")[0].trim()
    if len(tmp) == 0 {
        eprintln("F-P1-LINKEXEC: mktemp failed")
        exit(2)
    }

    // ── object A — user.s: _start / _main both call into object B ──
    let user_s =
        ".section __TEXT,__text,regular,pure_instructions\n" +
        ".globl _start\n.p2align 2\n_start:\n" +
        "    bl _rt_answer\n    bl _rt_exit\n" +
        ".globl _main\n.p2align 2\n_main:\n" +
        "    bl _rt_answer\n    bl _rt_exit\n"
    _wf(tmp + "/user.s", user_s)

    // ── object B — rt.s: answer()=42, exit() = svc #0x80 SYS_exit ──
    let rt_s =
        ".section __TEXT,__text,regular,pure_instructions\n" +
        ".globl _rt_answer\n.p2align 2\n_rt_answer:\n" +
        "    mov x0, #42\n    ret\n" +
        ".globl _rt_exit\n.p2align 2\n_rt_exit:\n" +
        "    mov x16, #1\n    svc #0x80\n"
    _wf(tmp + "/rt.s", rt_s)

    // CONTROL oracle: assemble each `.s` to a `.o` (allowed as INPUT).
    let a1 = exec_capture("clang -c -arch arm64 " + tmp + "/user.s -o " + tmp + "/user.o 2>&1")
    if to_int(a1[2]) != 0 {
        eprintln("F-P1-LINKEXEC: assemble user.s failed:\n" + a1[0] + a1[1])
        exit(2)
    }
    let a2 = exec_capture("clang -c -arch arm64 " + tmp + "/rt.s -o " + tmp + "/rt.o 2>&1")
    if to_int(a2[2]) != 0 {
        eprintln("F-P1-LINKEXEC: assemble rt.s failed:\n" + a2[0] + a2[1])
        exit(2)
    }

    // ── THE LINK — 100% hexa-native (no clang/ld/as) ──
    let out_exe = tmp + "/prog"
    let lk = exec_capture(
        "HEXA_LANG=" + repo + " hexa run " + repo +
        "/tool/hexa_ld.hexa -o " + out_exe +
        " --lc-main _start " + tmp + "/user.o " + tmp + "/rt.o 2>&1")
    if to_int(lk[2]) != 0 {
        eprintln("F-P1-LINKEXEC: hexa_ld link failed (rc=" + lk[2] + "):\n" + lk[0])
        exit(3)
    }

    // ── ASSERT: produced exe runs to exit(42) ──
    let run = exec_capture(out_exe + "; echo RC=$?")
    let rc_line = run[0].trim()
    // Parse the trailing "RC=<n>".
    let mut got = -1
    if rc_line.contains("RC=") {
        let parts = rc_line.split("RC=")
        got = to_int(parts[len(parts) - 1].trim())
    }
    if got != 42 {
        eprintln("F-P1-LINKEXEC FAIL — produced exe exit=" + to_string(got) +
                 " (expected 42)\n" + rc_line)
        exit(1)
    }

    // ── structural sanity: no undefined imports (fully self-contained) ──
    let nmu = exec_capture("nm -u " + out_exe + " 2>/dev/null")
    let undef = nmu[0].trim()
    if len(undef) != 0 {
        eprintln("F-P1-LINKEXEC WARN — unexpected imports (nm -u):\n" + undef)
    }

    println("F-P1-LINKEXEC PASS — hexa-native link merged 2 .o → runnable")
    println("  exit=42 · BRANCH26 cross-object reloc resolved · nm -u empty")
    exit(0)
}
