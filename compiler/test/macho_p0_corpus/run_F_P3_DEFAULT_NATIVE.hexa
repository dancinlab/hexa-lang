// F-P3-DEFAULT-NATIVE — verify backend=native is default for
// arm64-apple-darwin obj emit (RFC 063 § P3 flip).
//
// Without `--backend=` flag, `aprime_cc --emit=obj` must produce a
// hexa-native Mach-O .o (forks 0 external tools). The legacy
// `--backend=system` path remains as opt-out.

import "../../../tool/hexa_ld.hexa"

fn main() {
    let aprime = "/tmp/aprime_s7"
    let src = "compiler/test/macho_p0_corpus/trivial.hexa"
    let out_path = "/tmp/p3_default_native.o"

    // Build WITHOUT --backend= flag — should default to native via P3 flip.
    // Use stripped PATH to prove no clang/as fork can happen.
    let cmd = "env -i PATH=/usr/bin:/bin " + aprime +
              " _drv.hexa --target=arm64-apple-darwin --emit=obj " +
              "-o " + out_path + " " + src + " 2>&1"
    let r = exec_capture(cmd)
    let r_rc = to_int(r[2])
    println("=== aprime_cc --emit=obj (no --backend=, stripped PATH) ===")
    println(to_string(r[0]))
    println("rc=" + to_string(r_rc))

    if r_rc != 0 {
        println("FAIL: default-native path did not work (rc=" + to_string(r_rc) + ")")
        println("  This means the P3 flip is not active OR aprime_s7 is stale.")
        exit(1)
    }

    let f = exec_capture("file " + out_path + " 2>&1")
    let f_out = to_string(f[0])
    println(f_out)
    if f_out.find("Mach-O") < 0 {
        println("FAIL: output is not Mach-O")
        exit(2)
    }

    let sz = exec_capture("wc -c < " + out_path + " 2>&1 | tr -d ' '")
    let sz_n = to_int(to_string(sz[0]).trim())

    println("✅ F-P3-DEFAULT-NATIVE PASS — backend=native is default for arm64-darwin obj emit")
    println("   " + out_path + ": " + to_string(sz_n) + " B Mach-O · no clang/as in PATH")
    exit(0)
}
