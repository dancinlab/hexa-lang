// F-P0-OBJEQ corpus / if — conditional branch encoding.
//
// Exercises: CMP imm, B.cond (one of EQ/NE/LT/GE/...), forward branch
// to a labelled basic block, fall-through to a second basic block.
// Tests both arms produce correct exit codes (3 / 7) depending on
// whether the condition takes the true or false arm.

fn main() {
    let mut x = 1
    if x == 1 {
        exit(3)
    } else {
        exit(7)
    }
}
