// F-P1-RUNEQ — P1 cycle 8 falsifier — corpus runtime equivalence via
// static link with synthetic runtime stub.
//
// Strategy: instead of going through the full chained-fixups dyld
// lazy-bind path (extreme complexity, multi-cycle), we statically
// link a tiny runtime stub that satisfies `_hexa_set_args` (no-op
// `ret`) and `_hexa_exit` (`mov x0, x1; mov x16, #1; svc #0x80` —
// trivial.hexa's `exit(42)` LIR passes value in x1 with the TAG
// marker in x0, so the stub forwards x1 to x0 for the kernel exit
// syscall).
//
// This proves RFC 063 § P1 closure for the static-link case: real
// corpus .o + synthetic runtime stub → hexa_ld → exec → exit 42.
// Dynamic lazy-bind path remains as a follow-up.

import "../../../tool/hexa_ld.hexa"

fn main() {
    // Parse the real corpus output.
    let p_trivial = parse_macho_obj("/tmp/corpus_trivial.ours.o")
    println("trivial.ours.o: text=" + to_string(len(p_trivial.text)) +
            " defined=" + to_string(len(p_trivial.defined)) +
            " extern=" + to_string(len(p_trivial.extern_refs)))

    // Hand-build runtime stub ParsedObj.
    //
    //   _hexa_set_args:      (4 B)
    //     ret                = 0xD65F03C0  → c0 03 5f d6
    //
    //   _hexa_exit:          (12 B)
    //     mov x0, x1         = 0xAA0103E0  → e0 03 01 aa
    //     mov x16, #1        = 0xD2800030  → 30 00 80 d2
    //     svc #0x80          = 0xD4001001  → 01 10 00 d4
    //
    // Total 16 bytes. _hexa_set_args at offset 0, _hexa_exit at offset 4.
    let rt_text: [Int] = [
        0xC0, 0x03, 0x5F, 0xD6,    // _hexa_set_args: ret
        0xE0, 0x03, 0x01, 0xAA,    // _hexa_exit: mov x0, x1
        0x30, 0x00, 0x80, 0xD2,    //             mov x16, #1
        0x01, 0x10, 0x00, 0xD4,    //             svc #0x80
    ]
    let runtime: ParsedObj = ParsedObj {
        path:        "synthetic_runtime_stub",
        text:        rt_text,
        defined: [
            LinkSym { name: "_hexa_set_args", offset: 0, scope: 0 },
            LinkSym { name: "_hexa_exit",     offset: 4, scope: 0 },
        ],
        extern_refs: [],
        relocs:      [],
        dwarf_line:  [],
    }
    println("runtime stub: text=16 defined=[_hexa_set_args@0, _hexa_exit@4]")

    let out_path = "/tmp/p1_c8_runeq.exec"
    let objs: [ParsedObj] = [p_trivial, runtime]
    let rc = link_macho_arm64(objs, out_path, "_main", 0)
    if rc != 0 { println("FAIL: link rc=" + to_string(rc)); exit(1) }

    // Sanity — verify the externs got resolved (text bytes patched).
    let dis = exec_capture("xcrun otool -tv " + out_path + " 2>&1")
    println("=== otool -tv ===")
    println(to_string(dis[0]))

    let n = exec_capture("xcrun nm " + out_path + " 2>&1")
    println("=== nm ===")
    println(to_string(n[0]))

    // The acid test.
    let r = exec_capture(out_path)
    let r_rc = to_int(r[2])
    println("=== launch ===")
    println("  rc=" + to_string(r_rc) + " (expected 42 — corpus_trivial.ours.o is `exit(42)`)")

    if r_rc != 42 {
        println("FAIL: launched exec did not exit(42); got rc=" + to_string(r_rc))
        exit(2)
    }

    println("🛸 F-P1-RUNEQ FULL PASS — real corpus runs via static-link with hexa_ld")
    exit(0)
}
