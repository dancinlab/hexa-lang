// F-P0-OBJEQ-HEADER — cycle 1 sub-falsifier (RFC 063 § P0).
//
// Checks the `LC_SEGMENT_64` + `__text` section structure of our
// `compiler/emit/macho_arm64.hexa::serialize()` output against the
// `clang -c -arch arm64` oracle on an empty `.s`. Per RFC 063 § P0
// `strip-nondet`, `LC_BUILD_VERSION` is excluded from the comparison
// (clang emits it; our writer does not yet, by design).
//
// Cycle 1 scope: header + 4 load commands + empty section data.
// Sections that follow (code bytes, symbol records, relocations) are
// falsified in subsequent cycles.
//
// hexa-native runner — no shell wrapper. Build with:
//
//     hexa build compiler/test/macho_p0_corpus/run_F_P0_OBJEQ_HEADER.hexa \
//         -o /tmp/run_F_P0_OBJEQ_HEADER && /tmp/run_F_P0_OBJEQ_HEADER
//
// Exit code: 0 = PASS, non-zero = FAIL.

import "../../emit/macho_arm64.hexa"

// Slice the `otool -l` listing to just `Load command 0` (the
// LC_SEGMENT_64 segment + its single section_64). Skips the
// `Load command 0` header line itself so the rest of the structure
// can be compared verbatim.
fn _slice_seg0(otool_out: string) -> string {
    let lines = otool_out.split("\n")
    let mut buf: [string] = []
    let mut in_seg = false
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln == "Load command 0" {
            in_seg = true
            i = i + 1
            continue
        }
        if in_seg && len(ln) >= 12 && ln.substring(0, 13) == "Load command " {
            break
        }
        if in_seg { buf.push(ln) }
        i = i + 1
    }
    let mut out = ""
    let mut j = 0
    while j < len(buf) {
        if j > 0 { out = out + "\n" }
        out = out + buf[j]
        j = j + 1
    }
    return out
}

// `s.replace_all(from, to)` mini — hexa-lang has `replace` on string
// but we keep this self-contained so the falsifier has zero external
// dependencies beyond `import "../../emit/macho_arm64.hexa"`.
fn _replace_all(s: string, from: string, to: string) -> string {
    let flen = len(from)
    if flen == 0 { return s }
    let mut out = ""
    let mut i = 0
    let n = len(s)
    while i + flen <= n {
        if s.substring(i, i + flen) == from {
            out = out + to
            i = i + flen
        } else {
            out = out + s.substring(i, i + 1)
            i = i + 1
        }
    }
    if i < n { out = out + s.substring(i, n) }
    return out
}

fn _check_exec(label: string, r: array) -> bool {
    let ec = to_int(r[2])
    if ec != 0 {
        println("FAIL: " + label + " — exit=" + to_string(ec))
        let err = to_string(r[1])
        if len(err) > 0 { println(err) }
        return false
    }
    return true
}

fn main() {
    // 1. Build our empty serializer and run it to produce `.ours.o`.
    //    The build command needs `HEXA_MAC_BUILD_OK=1` set; we set it
    //    in the shell prefix so the env carries through.
    let build = exec_capture("HEXA_MAC_BUILD_OK=1 hexa build compiler/test/macho_p0_corpus/emit_empty.hexa -o /tmp/macho_p0_cycle1_emit_bin 2>&1")
    if !_check_exec("hexa build emit_empty.hexa", build) { exit(2) }

    let run = exec_capture("/tmp/macho_p0_cycle1_emit_bin 2>&1")
    if !_check_exec("run emit_empty", run) { exit(3) }

    // 2. clang oracle on an empty `.s`.
    let oracle = exec_capture(": > /tmp/empty.s && xcrun clang -c -arch arm64 /tmp/empty.s -o /tmp/macho_p0_cycle1.ref.o 2>&1")
    if !_check_exec("clang oracle", oracle) { exit(4) }

    // 3. otool listings, sliced to the LC_SEGMENT_64 region.
    let ours_raw = exec_capture("xcrun otool -l /tmp/macho_p0_cycle1.ours.o")
    if !_check_exec("otool -l ours", ours_raw) { exit(5) }
    let ref_raw = exec_capture("xcrun otool -l /tmp/macho_p0_cycle1.ref.o")
    if !_check_exec("otool -l ref", ref_raw) { exit(6) }

    let ours_seg = _slice_seg0(to_string(ours_raw[0]))
    let mut ref_seg = _slice_seg0(to_string(ref_raw[0]))

    // Strip the 24-byte LC_BUILD_VERSION shift — clang's fileoff/offset
    // are header + 280 (=304? actually 312 in observed), ours are
    // header + 256. Normalize the observed +24 delta.
    ref_seg = _replace_all(ref_seg, "fileoff 312", "fileoff 288")
    ref_seg = _replace_all(ref_seg, "offset 312", "offset 288")

    if ours_seg == ref_seg {
        let ours_sz = exec_capture("wc -c < /tmp/macho_p0_cycle1.ours.o | tr -d ' '")
        let ref_sz  = exec_capture("wc -c < /tmp/macho_p0_cycle1.ref.o  | tr -d ' '")
        println("F-P0-OBJEQ-HEADER PASS — LC_SEGMENT_64 + __text section byte-eq")
        println("  ours: " + to_string(ours_sz[0]).trim() + " bytes (/tmp/macho_p0_cycle1.ours.o)")
        println("  ref:  " + to_string(ref_sz[0]).trim()  + " bytes (/tmp/macho_p0_cycle1.ref.o) — delta = LC_BUILD_VERSION + 1 placeholder symbol")
        exit(0)
    }

    println("F-P0-OBJEQ-HEADER FAIL — segment structure differs.")
    println("===== ours =====")
    println(ours_seg)
    println("===== ref (normalised) =====")
    println(ref_seg)
    exit(1)
}
