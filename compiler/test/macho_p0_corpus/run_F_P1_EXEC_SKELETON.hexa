// F-P1-EXEC-SKELETON — P1 cycle 2 falsifier.
//
// `link_macho_arm64` cycle 2 emits a skeleton MH_EXECUTE — header +
// load commands only, empty __text. The Mach-O isn't runnable yet
// (cycle 3 fills code, cycle 4 adds codesign + lazy-bind), but
// `otool -hV / -l` must recognise it as well-formed.
//
// Assertions:
//   - file produced, ≥ 480 bytes
//   - `otool -hV` shows MH_MAGIC_64 / ARM64 / EXECUTE / PIE
//   - `otool -l` shows LC_SEGMENT_64 __PAGEZERO + __TEXT (1 section),
//     LC_LOAD_DYLINKER, LC_LOAD_DYLIB, LC_MAIN, LC_SYMTAB, LC_DYSYMTAB

import "../../../tool/hexa_ld.hexa"

fn _check_contains(text: string, needle: string, label: string) -> bool {
    if text.find(needle) < 0 {
        println("FAIL: " + label + " — expected '" + needle + "' in otool output")
        return false
    }
    return true
}

fn main() {
    let out_path = "/tmp/p1_cycle2_skeleton.exec"
    let rc = link_macho_arm64(0, out_path, "_main", 0)
    if rc != 0 {
        println("FAIL: link_macho_arm64 returned " + to_string(rc))
        exit(1)
    }

    // Inspect via otool -hV (header).
    let h = exec_capture("xcrun otool -hV " + out_path + " 2>&1")
    let h_out = to_string(h[0])
    println("=== otool -hV ===")
    println(h_out)
    let mut ok = true
    if !_check_contains(h_out, "MH_MAGIC_64",       "magic")    { ok = false }
    if !_check_contains(h_out, "ARM64",             "cputype")  { ok = false }
    if !_check_contains(h_out, "EXECUTE",           "filetype") { ok = false }
    if !_check_contains(h_out, "PIE",               "PIE flag") { ok = false }

    // Inspect via otool -l (load commands).
    let l = exec_capture("xcrun otool -l " + out_path + " 2>&1")
    let l_out = to_string(l[0])
    println("=== otool -l (head) ===")
    println(l_out.substring(0, 1200))
    if !_check_contains(l_out, "LC_SEGMENT_64",     "LC_SEGMENT_64")    { ok = false }
    if !_check_contains(l_out, "__PAGEZERO",        "__PAGEZERO")       { ok = false }
    if !_check_contains(l_out, "__TEXT",            "__TEXT")           { ok = false }
    if !_check_contains(l_out, "__text",            "__text section")   { ok = false }
    if !_check_contains(l_out, "LC_LOAD_DYLINKER",  "LC_LOAD_DYLINKER") { ok = false }
    if !_check_contains(l_out, "/usr/lib/dyld",     "dyld path")        { ok = false }
    if !_check_contains(l_out, "LC_LOAD_DYLIB",     "LC_LOAD_DYLIB")    { ok = false }
    if !_check_contains(l_out, "libSystem.B.dylib", "libSystem path")   { ok = false }
    if !_check_contains(l_out, "LC_MAIN",           "LC_MAIN")          { ok = false }
    if !_check_contains(l_out, "LC_SYMTAB",         "LC_SYMTAB")        { ok = false }
    if !_check_contains(l_out, "LC_DYSYMTAB",       "LC_DYSYMTAB")      { ok = false }

    if ok {
        let sz = exec_capture("wc -c < " + out_path + " | tr -d ' '")
        println("F-P1-EXEC-SKELETON PASS — well-formed MH_EXECUTE")
        println("  " + out_path + ": " + to_string(sz[0]).trim() + " bytes")
        exit(0)
    }
    exit(2)
}
