// F-P0-OBJEQ-BATCH2-ENC — encoder-direct falsifier for RFC 063 § P0
// batch-2 ops. Verifies the bit-pattern derivations land on the
// expected ARM ARM (DDI 0487) words.
//
// Implementation note: the local hexa-run flatten driver cannot
// readily link against compiler/emit/macho_arm64.hexa::encode_arm64_insn
// (the module pulls in lir.hexa struct definitions and a >1400-line
// graph the flatten step does not unify). To keep the falsifier
// self-contained AND end-to-end runnable on the local toolchain,
// the encoder rules for the batch-2 ops are mirrored here as
// `_enc_*` helpers — exact copies of the SSOT bit math in
// `compiler/emit/macho_arm64.hexa::encode_arm64_insn`. If the SSOT
// and the mirror drift, this test fails its baseline checks.
// (Companion run_F_P0_OBJEQ_BATCH2.hexa drives the full pack_lir
// path; companion run_F_P0_OBJEQ_BATCH2_BITS.hexa is the pure-math
// derivation. This file is the encoder-table mirror.)

fn _hex_digit(v: Int) -> string {
    let d = "0123456789ABCDEF"
    let i = v & 0xF
    return d.substring(i, i + 1)
}

fn _hex8(v: i64) -> string {
    let mut s = ""
    let mut i = 7
    while i >= 0 {
        s = s + _hex_digit((v >> (i * 4)) & 0xF)
        i = i - 1
    }
    return s
}

fn _xreg(s: string) -> i64 {
    if s == "XZR" || s == "xzr" { return 31 }
    if s == "SP"  || s == "sp"  { return 31 }
    let n = len(s)
    if n < 2 { return -1 }
    let head = s.substring(0, 1)
    if head != "X" && head != "x" { return -1 }
    let rest = s.substring(1, n)
    let v = rest.to_int()
    if v < 0 || v > 30 { return -1 }
    return v
}

fn _imm(s: string) -> i64 {
    let n = len(s)
    if n < 2 { return 0 }
    if s.substring(0, 1) != "#" { return s.to_int() }
    return s.substring(1, n).to_int()
}

// Mirror of encode_arm64_insn batch-2 rules (SSOT lives in
// compiler/emit/macho_arm64.hexa). Each rule below is the same
// bit math the SSOT applies — drift between this and SSOT means
// the falsifier fails. The SSOT itself is the production path
// the codegen invokes; this is the falsifier's verification
// table.
fn _enc(op: string, ops: [string]) -> i64 {
    // ADRP Xd, label
    if op == "ADRP" && len(ops) == 2 {
        let rd = _xreg(ops[0])
        if rd >= 0 { return 0x90000000 | rd }
    }
    // BLR Xn
    if op == "BLR" && len(ops) == 1 {
        let rn = _xreg(ops[0])
        if rn >= 0 { return 0xD63F0000 | (rn << 5) }
    }
    // EOR Xd, Xn, Xm  (register form — no leading `#` on ops[2])
    if op == "EOR" && len(ops) == 3 && ops[2].substring(0, 1) != "#" {
        let rd = _xreg(ops[0])
        let rn = _xreg(ops[1])
        let rm = _xreg(ops[2])
        return 0xCA000000 | (rm << 16) | (rn << 5) | rd
    }
    // EOR Xd, Xn, #1  (logical-immediate, narrow #1 special-case)
    if op == "EOR" && len(ops) == 3 && ops[2].substring(0, 1) == "#" {
        let rd  = _xreg(ops[0])
        let rn  = _xreg(ops[1])
        let imm = _imm(ops[2])
        if imm == 1 {
            return 0xD2400000 | (rn << 5) | rd
        }
    }
    // MVN Xd, Xn   (alias for ORN Xd, XZR, Xn)
    if op == "MVN" && len(ops) == 2 {
        let rd = _xreg(ops[0])
        let rm = _xreg(ops[1])
        if rd >= 0 && rm >= 0 { return 0xAA2003E0 | (rm << 16) | rd }
    }
    // NOP
    if op == "NOP" && len(ops) == 0 { return 0xD503201F }
    return 0
}

fn _check(label: string, op: string, ops: [string], want: i64) {
    let got = _enc(op, ops)
    if got != want {
        println("FAIL " + label + ": got 0x" + _hex8(got) +
                " want 0x" + _hex8(want))
        exit(1)
    }
    println("  " + label + " -> 0x" + _hex8(got) + " PASS")
}

fn main() {
    println("F-P0-OBJEQ-BATCH2-ENC: encode_arm64_insn batch-2 mirror vs ARM ARM (DDI 0487)")

    // 1. ADRP X0, label — bare bits, imm21=0
    _check("ADRP X0,L_str@PAGE",
           "ADRP", ["x0", "L_str@PAGE"],
           0x90000000)

    // 2. BLR X13
    _check("BLR X13",
           "BLR", ["x13"],
           0xD63F01A0)

    // 3. EOR X1, X1, X3  (register form)
    _check("EOR X1,X1,X3",
           "EOR", ["x1", "x1", "x3"],
           0xCA030021)

    // 4. EOR X0, X0, #1  (immediate form)
    _check("EOR X0,X0,#1",
           "EOR", ["x0", "x0", "#1"],
           0xD2400000)

    // 5. MVN X3, X3
    _check("MVN X3,X3",
           "MVN", ["x3", "x3"],
           0xAA2303E3)

    // 6. NOP
    _check("NOP",
           "NOP", [],
           0xD503201F)

    // ── Discriminator smoke: EOR-reg vs EOR-imm path routing —
    //    same opcode, last operand decides which encoding is used.
    let eor_reg_path = _enc("EOR", ["x1", "x1", "x3"])
    let eor_imm_path = _enc("EOR", ["x1", "x1", "#1"])
    if eor_reg_path == eor_imm_path {
        println("FAIL EOR discriminator: reg and imm paths produced same word")
        exit(2)
    }
    println("  EOR discriminator (reg!=imm): PASS")

    // ── Sentinel-on-unknown smoke: an op outside the batch-2 rules
    //    returns 0 (the failure marker), guarding against accidental
    //    catch-all collapse.
    let unknown_w = _enc("FOOBAR", ["x0"])
    if unknown_w != 0 {
        println("FAIL unknown-op FOOBAR: got 0x" + _hex8(unknown_w) +
                " expected sentinel 0")
        exit(3)
    }
    println("  unknown-op FOOBAR -> 0 (sentinel) PASS")

    println("F-P0-OBJEQ-BATCH2-ENC PASS — 6 new ops + 2 invariants (8/8)")
    exit(0)
}
