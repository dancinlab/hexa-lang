// F-P2-X86-ENCODE — P2 cycle 2 falsifier.
//
// Verify 3 x86_64 instructions encode to expected bytes:
//   mov eax, #60     → B8 3C 00 00 00         (Linux exit syscall #60)
//   mov edi, #42     → BF 2A 00 00 00         (exit code arg)
//   syscall          → 0F 05                  (kernel trap)
//
// 12-byte direct exit(42) sequence — Linux x86_64 analog of cycle 6's
// arm64 SVC syscall (mov x16,#1; mov x0,#42; svc #0x80).

import "../../emit/elf_x86_64.hexa"

fn _hex8(v: Int) -> string {
    let hi = (v >> 4) & 0xF
    let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}

fn _bytes_to_hex(bs: [Int]) -> string {
    let mut s = ""
    let mut i = 0
    while i < len(bs) {
        if i > 0 { s = s + " " }
        s = s + _hex8(bs[i] & 0xFF)
        i = i + 1
    }
    return s
}

fn _expect_bytes(label: string, got: [Int], want: [Int]) -> bool {
    if len(got) != len(want) {
        println("FAIL: " + label + ": len got=" + to_string(len(got)) +
                " want=" + to_string(len(want)))
        return false
    }
    let mut i = 0
    while i < len(got) {
        if (got[i] & 0xFF) != want[i] {
            println("FAIL: " + label + ": byte " + to_string(i) +
                    " got 0x" + _hex8(got[i] & 0xFF) + " want 0x" + _hex8(want[i]))
            return false
        }
        i = i + 1
    }
    return true
}

fn main() {
    let mut ok = true

    // mov eax, #60  (Linux x86_64 sys_exit = 60)
    let mov_eax = encode_x86_64_insn("MOV", ["eax", "#60"])
    let mov_eax_want: [Int] = [0xB8, 0x3C, 0x00, 0x00, 0x00]
    println("mov eax, #60  → " + _bytes_to_hex(mov_eax))
    ok = _expect_bytes("MOV EAX,#60", mov_eax, mov_eax_want) && ok

    // mov edi, #42  (exit code)
    let mov_edi = encode_x86_64_insn("MOV", ["edi", "#42"])
    let mov_edi_want: [Int] = [0xBF, 0x2A, 0x00, 0x00, 0x00]
    println("mov edi, #42  → " + _bytes_to_hex(mov_edi))
    ok = _expect_bytes("MOV EDI,#42", mov_edi, mov_edi_want) && ok

    // syscall
    let sc = encode_x86_64_insn("SYSCALL", [])
    let sc_want: [Int] = [0x0F, 0x05]
    println("syscall       → " + _bytes_to_hex(sc))
    ok = _expect_bytes("SYSCALL", sc, sc_want) && ok

    // ret
    let r = encode_x86_64_insn("RET", [])
    let r_want: [Int] = [0xC3]
    println("ret           → " + _bytes_to_hex(r))
    ok = _expect_bytes("RET", r, r_want) && ok

    if !ok { exit(1) }

    // Assemble full exit(42) into an ElfX86Obj.
    let text: [Int] = []
    let mut i = 0
    while i < len(mov_eax) { text.push(mov_eax[i]); i = i + 1 }
    i = 0
    while i < len(mov_edi) { text.push(mov_edi[i]); i = i + 1 }
    i = 0
    while i < len(sc) { text.push(sc[i]); i = i + 1 }
    println("\nfull 12-byte exit(42): " + _bytes_to_hex(text))

    let obj: ElfX86Obj = ElfX86Obj {
        text:    text,
        relocs:  [],
        symbols: [],
        strtab:  [],
    }
    let bytes = serialize_elf_x86_64(obj)
    write_bytes("/tmp/p2_c2_exit42.elf.o", bytes)

    let f = exec_capture("file /tmp/p2_c2_exit42.elf.o 2>&1")
    println("\n=== file ===")
    println(to_string(f[0]))

    println("F-P2-X86-ENCODE PASS — 3 x86_64 instructions byte-eq + ELF .o emit")
    exit(0)
}
