// F-P2-X86-DIV — verify NOP/TEST64/CQO/IDIV64 + signed division program
// 84/2=42 → exit 42 on Linux x86_64.
//
// Expected encoding:
//   NOP             90
//   CQO             48 99
//   TEST64 RAX,RAX  48 85 c0
//   IDIV64 RCX      48 f7 f9
//   IDIV64 R10      49 f7 fa  (REX.B for r10)
//
// Composite program (signed division 84 / 2 = 42):
//   mov rax, #84       48 c7 c0 54 00 00 00
//   mov rcx, #2        48 c7 c1 02 00 00 00
//   cqo                48 99
//   idiv rcx           48 f7 f9
//   mov rdi, rax       48 89 c7         (quotient → exit code)
//   mov rax, #60       48 c7 c0 3c 00 00 00
//   syscall            0f 05

import "../../emit/elf_x86_64.hexa"

fn _hex(v: Int) -> string {
    let hi = (v >> 4) & 0xF; let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}
fn _bs(bs: [Int]) -> string {
    let mut s = ""; let mut i = 0
    while i < len(bs) { if i > 0 { s = s + " " }; s = s + _hex(bs[i] & 0xFF); i = i + 1 }
    return s
}
fn _eq(label: string, got: [Int], want: [Int]) -> bool {
    if len(got) != len(want) { println("FAIL " + label + ": len " + to_string(len(got)) + " vs " + to_string(len(want))); return false }
    let mut i = 0
    while i < len(got) {
        if (got[i] & 0xFF) != want[i] {
            println("FAIL " + label + " byte " + to_string(i) + ": " + _hex(got[i] & 0xFF) + " vs " + _hex(want[i]))
            return false
        }
        i = i + 1
    }
    return true
}

fn main() {
    let mut ok = true

    let cases: [string] = [
        "NOP", "CQO", "TEST64 RAX,RAX", "IDIV64 RCX", "IDIV64 R10",
    ]
    let want: [[Int]] = [
        [0x90], [0x48, 0x99],
        [0x48, 0x85, 0xC0],
        [0x48, 0xF7, 0xF9],
        [0x49, 0xF7, 0xFA],
    ]
    let got: [[Int]] = [
        encode_x86_64_insn("NOP", []),
        encode_x86_64_insn("CQO", []),
        encode_x86_64_insn("TEST64", ["rax", "rax"]),
        encode_x86_64_insn("IDIV64", ["rcx"]),
        encode_x86_64_insn("IDIV64", ["r10"]),
    ]
    let mut i = 0
    while i < len(cases) {
        println(cases[i] + " → " + _bs(got[i]))
        if !_eq(cases[i], got[i], want[i]) { ok = false }
        i = i + 1
    }
    if !ok { exit(1) }

    // Division program: 84 / 2 = 42.
    let prog: [Int] = []
    let mut k = 0
    let m_84 = encode_x86_64_insn("MOV64", ["rax", "#84"])
    k = 0; while k < len(m_84) { prog.push(m_84[k]); k = k + 1 }
    let m_2 = encode_x86_64_insn("MOV64", ["rcx", "#2"])
    k = 0; while k < len(m_2) { prog.push(m_2[k]); k = k + 1 }
    let cqo = encode_x86_64_insn("CQO", [])
    k = 0; while k < len(cqo) { prog.push(cqo[k]); k = k + 1 }
    let idiv = encode_x86_64_insn("IDIV64", ["rcx"])
    k = 0; while k < len(idiv) { prog.push(idiv[k]); k = k + 1 }
    let m_q = encode_x86_64_insn("MOV64", ["rdi", "rax"])
    k = 0; while k < len(m_q) { prog.push(m_q[k]); k = k + 1 }
    let m_60 = encode_x86_64_insn("MOV64", ["rax", "#60"])
    k = 0; while k < len(m_60) { prog.push(m_60[k]); k = k + 1 }
    let sc = encode_x86_64_insn("SYSCALL", [])
    k = 0; while k < len(sc) { prog.push(sc[k]); k = k + 1 }
    println("\n[84/2=42 division program: " + to_string(len(prog)) + " B]")
    println("  " + _bs(prog))

    let elf = serialize_elf_exec_x86_64(prog)
    let elf_path = "/tmp/p2_c27_div.elf"
    write_bytes(elf_path, elf)
    let scp = exec_capture("scp " + elf_path + " ubu-2:/tmp/p2_c27_div.elf 2>&1")
    if to_int(scp[2]) != 0 { println("FAIL scp"); exit(2) }
    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c27_div.elf && /tmp/p2_c27_div.elf; echo REMOTE_RC=$?' 2>&1")
    let rout = to_string(r[0])
    println("ubu-2: " + rout)
    if rout.find("REMOTE_RC=42") < 0 {
        println("FAIL: 84/2 did not yield 42 exit")
        exit(3)
    }

    println("🎉 F-P2-X86-DIV FULL PASS — 5 rules + signed-division program runs on Linux")
    exit(0)
}
