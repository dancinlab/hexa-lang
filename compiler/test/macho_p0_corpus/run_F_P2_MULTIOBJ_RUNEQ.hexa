// F-P2-MULTIOBJ-RUNEQ — P2 cycle 4 falsifier.
//
// Linux analog of P1 cycle 8 (static-link with synthetic runtime stub).
// 2 synthetic ElfX86Obj inputs:
//   main_obj:
//     _main:  E8 imm32 (CALL _exit_helper, imm32 patched by linker)
//   runtime_obj:
//     _exit_helper:  mov eax,#60; mov edi,#42; syscall
//
// link_elf_x86_64 concats text + patches CALL reloc → ELF exec
// → scp ubu-2 → ssh launch → exit 42.

import "../../emit/elf_x86_64.hexa"

fn _build_strtab(names: [string]) -> [Int] {
    let st: [Int] = []
    st.push(0)                                       // index 0 = NUL
    let mut i = 0
    while i < len(names) {
        let nm = names[i]
        let mut k = 0
        while k < len(nm) { st.push(char_code(nm, k) & 0xFF); k = k + 1 }
        st.push(0)
        i = i + 1
    }
    return st
}

fn main() {
    // ── main_obj ──
    //
    // Text (5 bytes):  E8 00 00 00 00     CALL _exit_helper (imm32 patched)
    let main_text: [Int] = [0xE8, 0x00, 0x00, 0x00, 0x00]
    let main_strtab = _build_strtab(["_main", "_exit_helper"])
    // _main offset in strtab = 1, _exit_helper = 1 + len("_main") + 1 = 7
    let main_obj: ElfX86Obj = ElfX86Obj {
        text:    main_text,
        relocs: [
            ElfRel {
                offset:  1,                          // imm32 field of CALL
                sym_idx: 1,                          // symbols[1] = _exit_helper
                kind:    4,                          // R_X86_64_PLT32
                addend:  -4,
            },
        ],
        symbols: [
            ElfSym {
                name_offset: 1,                      // "_main"
                section:     1,                      // .text
                value:       0,                      // offset within .text
                size:        5,
                bind:        1,                      // STB_GLOBAL
                type_:       2,                      // STT_FUNC
            },
            ElfSym {
                name_offset: 7,                      // "_exit_helper"
                section:     0,                      // UNDEF
                value:       0,
                size:        0,
                bind:        1,                      // STB_GLOBAL
                type_:       0,                      // STT_NOTYPE
            },
        ],
        strtab: main_strtab,
    }

    // ── runtime_obj ──
    //
    // Text (12 bytes):
    //   B8 3C 00 00 00     mov eax, #60   (sys_exit)
    //   BF 2A 00 00 00     mov edi, #42   (code)
    //   0F 05              syscall
    let rt_text: [Int] = [
        0xB8, 0x3C, 0x00, 0x00, 0x00,
        0xBF, 0x2A, 0x00, 0x00, 0x00,
        0x0F, 0x05,
    ]
    let rt_strtab = _build_strtab(["_exit_helper"])
    let rt_obj: ElfX86Obj = ElfX86Obj {
        text:    rt_text,
        relocs:  [],
        symbols: [
            ElfSym {
                name_offset: 1,
                section:     1,
                value:       0,
                size:        12,
                bind:        1,                      // STB_GLOBAL
                type_:       2,                      // STT_FUNC
            },
        ],
        strtab: rt_strtab,
    }

    let out_path = "/tmp/p2_c4_multiobj.elf"
    let objs: [ElfX86Obj] = [main_obj, rt_obj]
    let rc = link_elf_x86_64(objs, out_path, "_main")
    if rc != 0 { println("FAIL: link rc=" + to_string(rc)); exit(1) }

    let f = exec_capture("file " + out_path + " 2>&1")
    println("=== file ===")
    println(to_string(f[0]))

    // Sync to ubu-2 + launch.
    let scp = exec_capture("scp " + out_path + " ubu-2:/tmp/p2_c4_multiobj.elf 2>&1")
    if to_int(scp[2]) != 0 {
        println("FAIL: scp rc=" + to_string(to_int(scp[2])))
        println(to_string(scp[1]))
        exit(2)
    }

    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c4_multiobj.elf && /tmp/p2_c4_multiobj.elf; echo REMOTE_RC=$?' 2>&1")
    let r_out = to_string(r[0])
    println("=== launch on ubu-2 ===")
    println(r_out)

    if r_out.find("REMOTE_RC=42") < 0 {
        println("FAIL: exec did not exit(42) on Linux x86_64")
        exit(3)
    }

    println("🛸 F-P2-MULTIOBJ-RUNEQ FULL PASS — ELF multi-obj static-link + CALL reloc works on Linux")
    exit(0)
}
