// F-P2-X86-CTRLFLOW — verify x86_64 control-flow encoding (cycle 25).
//
// 11 new rules byte-eq vs Intel manual + countdown loop program test.
//
// Expected encoding:
//   MOV EDI, EAX    89 c7
//   PUSH EAX        50
//   POP EAX         58
//   JMP_REL8        eb 00 (imm8 placeholder)
//   JMP_REL32       e9 00 00 00 00
//   JE_REL8         74 00
//   JNE_REL8        75 00
//   JL_REL8         7c 00
//   JGE_REL8        7d 00
//   JLE_REL8        7e 00
//   JG_REL8         7f 00
//
// Composite countdown program (Linux x86_64):
//   _start:
//     mov eax, #10              ; counter
//   .loop:
//     sub eax, #1               ; counter -= 1
//     cmp eax, #0               ; reached 0?
//     jne .loop                 ; if not, loop
//     mov edi, eax              ; exit code = 0
//     mov eax, #60              ; sys_exit
//     syscall

import "../../emit/elf_x86_64.hexa"

fn _hex(v: Int) -> string {
    let hi = (v >> 4) & 0xF; let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}
fn _bs(bs: [Int]) -> string {
    let mut s = ""; let mut i = 0
    while i < len(bs) { if i > 0 { s = s + " " }; s = s + _hex(bs[i] & 0xFF); i = i + 1 }
    return s
}
fn _eq(label: string, got: [Int], want: [Int]) -> bool {
    if len(got) != len(want) {
        println("FAIL " + label + ": len " + to_string(len(got)) + " vs " + to_string(len(want)))
        return false
    }
    let mut i = 0
    while i < len(got) {
        if (got[i] & 0xFF) != want[i] {
            println("FAIL " + label + " byte " + to_string(i) + ": " + _hex(got[i] & 0xFF) + " vs " + _hex(want[i]))
            return false
        }
        i = i + 1
    }
    return true
}

fn main() {
    let mut ok = true

    // 11 individual byte-eq checks.
    let cases: [string] = [
        "MOV EDI,EAX", "PUSH EAX", "POP EAX",
        "JMP_REL8", "JMP_REL32",
        "JE_REL8", "JNE_REL8", "JL_REL8", "JGE_REL8", "JLE_REL8", "JG_REL8",
    ]
    let want: [[Int]] = [
        [0x89, 0xC7], [0x50], [0x58],
        [0xEB, 0x00], [0xE9, 0x00, 0x00, 0x00, 0x00],
        [0x74, 0x00], [0x75, 0x00], [0x7C, 0x00], [0x7D, 0x00], [0x7E, 0x00], [0x7F, 0x00],
    ]
    let got: [[Int]] = [
        encode_x86_64_insn("MOV",  ["edi", "eax"]),
        encode_x86_64_insn("PUSH", ["eax"]),
        encode_x86_64_insn("POP",  ["eax"]),
        encode_x86_64_insn("JMP_REL8",  ["x"]),
        encode_x86_64_insn("JMP_REL32", ["x"]),
        encode_x86_64_insn("JE_REL8",  ["x"]),
        encode_x86_64_insn("JNE_REL8", ["x"]),
        encode_x86_64_insn("JL_REL8",  ["x"]),
        encode_x86_64_insn("JGE_REL8", ["x"]),
        encode_x86_64_insn("JLE_REL8", ["x"]),
        encode_x86_64_insn("JG_REL8",  ["x"]),
    ]
    let mut i = 0
    while i < len(cases) {
        println(cases[i] + " → " + _bs(got[i]))
        if !_eq(cases[i], got[i], want[i]) { ok = false }
        i = i + 1
    }
    if !ok { exit(1) }

    // Composite countdown loop program:
    //   mov eax, #10           B8 0A 00 00 00         (5 bytes)
    //   .loop (offset 5):
    //   sub eax, #1            81 E8 01 00 00 00      (6 bytes)
    //   cmp eax, #0            81 F8 00 00 00 00      (6 bytes)
    //   jne .loop              75 imm8                 (2 bytes)
    //                          imm8 = -(2 + 6 + 6) = -14 = 0xF2
    //   mov edi, eax           89 C7                   (2 bytes)
    //   mov eax, #60           B8 3C 00 00 00         (5 bytes)
    //   syscall                0F 05                   (2 bytes)
    //   Total: 28 bytes
    //
    // After loop: eax counted down to 0, edi = 0, exit syscall → exit 0.
    let prog: [Int] = []
    let m_eax_10 = encode_x86_64_insn("MOV", ["eax", "#10"])
    let mut k = 0
    while k < len(m_eax_10) { prog.push(m_eax_10[k]); k = k + 1 }
    let loop_start = len(prog)
    let s_1 = encode_x86_64_insn("SUB", ["eax", "#1"])
    k = 0; while k < len(s_1) { prog.push(s_1[k]); k = k + 1 }
    let c_0 = encode_x86_64_insn("CMP", ["eax", "#0"])
    k = 0; while k < len(c_0) { prog.push(c_0[k]); k = k + 1 }
    let jne = encode_x86_64_insn("JNE_REL8", ["loop"])
    k = 0; while k < len(jne) { prog.push(jne[k]); k = k + 1 }
    // Patch the JNE imm8: target = loop_start, jne_end = current len(prog).
    let jne_end = len(prog)
    let delta = loop_start - jne_end
    prog[jne_end - 1] = delta & 0xFF
    println("\n[countdown program assembly]")
    let m_edi_eax = encode_x86_64_insn("MOV", ["edi", "eax"])
    k = 0; while k < len(m_edi_eax) { prog.push(m_edi_eax[k]); k = k + 1 }
    let m_eax_60 = encode_x86_64_insn("MOV", ["eax", "#60"])
    k = 0; while k < len(m_eax_60) { prog.push(m_eax_60[k]); k = k + 1 }
    let sc = encode_x86_64_insn("SYSCALL", [])
    k = 0; while k < len(sc) { prog.push(sc[k]); k = k + 1 }
    println("  bytes (" + to_string(len(prog)) + " B): " + _bs(prog))

    // Build + sync + launch.
    let elf = serialize_elf_exec_x86_64(prog)
    let elf_path = "/tmp/p2_c25_countdown.elf"
    write_bytes(elf_path, elf)
    let scp = exec_capture("scp " + elf_path + " ubu-2:/tmp/p2_c25_countdown.elf 2>&1")
    if to_int(scp[2]) != 0 { println("FAIL scp"); exit(2) }
    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c25_countdown.elf && /tmp/p2_c25_countdown.elf; echo REMOTE_RC=$?' 2>&1")
    let rout = to_string(r[0])
    println("ubu-2: " + rout)
    if rout.find("REMOTE_RC=0") < 0 {
        println("FAIL: countdown did not exit 0")
        exit(3)
    }

    println("🎉 F-P2-X86-CTRLFLOW FULL PASS — 11 rules byte-eq + 10→0 countdown loop runs on Linux")
    exit(0)
}
