// F-P2-X86-ARITH — verify x86_64 ADD/SUB/CMP encoding (cycle 24 add).
//
// Expected (Intel manual / objdump):
//   ADD EAX, #1     81 c0 01 00 00 00
//   SUB EAX, #1     81 e8 01 00 00 00
//   CMP EAX, #1     81 f8 01 00 00 00
//   ADD EAX, EBX    01 d8
//   SUB EAX, EBX    29 d8
//   CMP EAX, EBX    39 d8

import "../../emit/elf_x86_64.hexa"

fn _hex(v: Int) -> string {
    let hi = (v >> 4) & 0xF; let lo = v & 0xF
    let d = "0123456789abcdef"
    return d.substring(hi, hi + 1) + d.substring(lo, lo + 1)
}
fn _bs(bs: [Int]) -> string {
    let mut s = ""; let mut i = 0
    while i < len(bs) { if i > 0 { s = s + " " }; s = s + _hex(bs[i] & 0xFF); i = i + 1 }
    return s
}
fn _eq(label: string, got: [Int], want: [Int]) -> bool {
    if len(got) != len(want) { println("FAIL " + label + ": len " + to_string(len(got)) + " vs " + to_string(len(want))); return false }
    let mut i = 0
    while i < len(got) {
        if (got[i] & 0xFF) != want[i] {
            println("FAIL " + label + " byte " + to_string(i) + ": " + _hex(got[i] & 0xFF) + " vs " + _hex(want[i]))
            return false
        }
        i = i + 1
    }
    return true
}

fn main() {
    let mut ok = true
    let cases: [string] = ["ADD EAX,#1", "SUB EAX,#1", "CMP EAX,#1",
                            "ADD EAX,EBX", "SUB EAX,EBX", "CMP EAX,EBX"]
    let expected: [[Int]] = [
        [0x81, 0xC0, 0x01, 0x00, 0x00, 0x00],
        [0x81, 0xE8, 0x01, 0x00, 0x00, 0x00],
        [0x81, 0xF8, 0x01, 0x00, 0x00, 0x00],
        [0x01, 0xD8],
        [0x29, 0xD8],
        [0x39, 0xD8],
    ]
    let results: [[Int]] = [
        encode_x86_64_insn("ADD", ["eax", "#1"]),
        encode_x86_64_insn("SUB", ["eax", "#1"]),
        encode_x86_64_insn("CMP", ["eax", "#1"]),
        encode_x86_64_insn("ADD", ["eax", "ebx"]),
        encode_x86_64_insn("SUB", ["eax", "ebx"]),
        encode_x86_64_insn("CMP", ["eax", "ebx"]),
    ]
    let mut i = 0
    while i < len(cases) {
        let got = results[i]
        println(cases[i] + " → " + _bs(got))
        if !_eq(cases[i], got, expected[i]) { ok = false }
        i = i + 1
    }
    if !ok { exit(1) }

    // Compose a small program that uses ADD: exit(20+22):
    //   mov eax, #20
    //   add eax, #22
    //   mov edi, eax  → as mov edi, eax = 89 c7
    //   mov eax, #60
    //   syscall
    // 5 + 6 + 2 + 5 + 2 = 20 bytes
    println("\n[program assembly]")
    let prog: [Int] = []
    let m_eax_20 = encode_x86_64_insn("MOV", ["eax", "#20"])
    let mut k = 0
    while k < len(m_eax_20) { prog.push(m_eax_20[k]); k = k + 1 }
    let a_22 = encode_x86_64_insn("ADD", ["eax", "#22"])
    k = 0
    while k < len(a_22) { prog.push(a_22[k]); k = k + 1 }
    // mov edi, eax (89 c7) — hardcoded since reg-reg MOV not in encoder yet
    prog.push(0x89); prog.push(0xC7)
    let m_eax_60 = encode_x86_64_insn("MOV", ["eax", "#60"])
    k = 0
    while k < len(m_eax_60) { prog.push(m_eax_60[k]); k = k + 1 }
    let sc = encode_x86_64_insn("SYSCALL", [])
    k = 0
    while k < len(sc) { prog.push(sc[k]); k = k + 1 }
    println("  bytes (" + to_string(len(prog)) + " B): " + _bs(prog))

    // Build + ship to ubu-2 + launch — exit code should be 42 (= 20+22).
    let elf = serialize_elf_exec_x86_64(prog)
    let elf_path = "/tmp/p2_c24_arith.elf"
    write_bytes(elf_path, elf)
    let scp = exec_capture("scp " + elf_path + " ubu-2:/tmp/p2_c24_arith.elf 2>&1")
    if to_int(scp[2]) != 0 { println("FAIL scp"); exit(2) }
    let r = exec_capture("ssh ubu-2 'chmod +x /tmp/p2_c24_arith.elf && /tmp/p2_c24_arith.elf; echo REMOTE_RC=$?' 2>&1")
    let rout = to_string(r[0])
    println("ubu-2: " + rout)
    if rout.find("REMOTE_RC=42") < 0 {
        println("FAIL: did not exit 42 (20+22 should = 42)")
        exit(3)
    }

    println("🎉 F-P2-X86-ARITH FULL PASS — 6 rules byte-eq + add-then-exit program runs on Linux")
    exit(0)
}
