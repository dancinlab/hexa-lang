// F-P0-OBJEQ-RELOC — cycle 4 sub-falsifier (RFC 063 § P0).
//
// 2-fn LModule:
//   fn caller():  bl _callee; ret    -> 2 instrs (8 bytes)
//   fn callee():  mov x0,#42; ret     -> 2 instrs (8 bytes)
//
// Expected after pack_lir:
//   obj.text.length == 16          // 4 instrs × 4 bytes
//   obj.symbols.length == 2        // _caller, _callee
//   obj.relocs.length  == 1        // BL @ offset 0 → _callee (sym idx 1)
//   obj.relocs[0].kind == ARM64_RELOC_BRANCH26 (2)
//   obj.relocs[0].pcrel == 1, length == 2
//
// Then serialize the .o and verify `otool -rV` shows the relocation
// pointing to `_callee` with ARM64_RELOC_BRANCH26 type.

import "../../emit/macho_arm64.hexa"
import "../../ir/lir.hexa"

fn main() {
    let x0 = PReg { name: "x0", kind: "gpr" }

    // caller(): bl _callee; ret
    // LIR uses raw label names (no prefix); the darwin "_" comes from
    // mangling on emit. So the LIR target is "_callee" (matching what
    // arm64_darwin.hexa does for cross-fn calls — fn names go through
    // _fmt_label which prepends "_" on darwin).
    let bl_target = LOperand {
        kind: "label", reg: x0, imm: 0, mem_base: x0, mem_offset: 0,
        label: "_callee",
    }
    let bl_ins  = LInstr { op: "bl",  args: [bl_target], comment: "" }
    let ret_ins = LInstr { op: "ret", args: [], comment: "" }
    let caller = LFunc {
        name:         "caller",
        target:       "arm64-apple-darwin",
        instrs:       [bl_ins, ret_ins],
        frame_size:   0,
        callee_saved: [],
        def_line:     0,
    }

    // callee(): mov x0, #42; ret
    let mov_args: [LOperand] = [
        LOperand { kind: "reg", reg: x0, imm: 0, mem_base: x0, mem_offset: 0, label: "" },
        LOperand { kind: "imm", reg: x0, imm: 42, mem_base: x0, mem_offset: 0, label: "" },
    ]
    let mov_ins = LInstr { op: "mov", args: mov_args, comment: "" }
    let callee = LFunc {
        name:         "callee",
        target:       "arm64-apple-darwin",
        instrs:       [mov_ins, ret_ins],
        frame_size:   0,
        callee_saved: [],
        def_line:     0,
    }

    let lm = LModule {
        file: "two_fns.hexa", target: "arm64-apple-darwin",
        funcs: [caller, callee], rodata: [], bss: [], globals: [], floats: [],
    }

    let obj = pack_lir(lm)

    let nt = len(obj.text)
    if nt != 16 { println("FAIL: text len = " + to_string(nt) + " (expected 16)"); exit(1) }
    let ns = len(obj.symbols)
    if ns != 2 { println("FAIL: nsym = " + to_string(ns) + " (expected 2)"); exit(2) }
    let nr = len(obj.relocs)
    if nr != 1 { println("FAIL: nreloc = " + to_string(nr) + " (expected 1)"); exit(3) }

    let r = obj.relocs[0]
    if r.offset != 0 { println("FAIL: r.offset = " + to_string(r.offset) + " (expected 0)"); exit(4) }
    if r.sym_idx != 1 { println("FAIL: r.sym_idx = " + to_string(r.sym_idx) + " (expected 1 = _callee)"); exit(5) }
    if r.kind != 2 { println("FAIL: r.kind = " + to_string(r.kind) + " (expected 2 = ARM64_RELOC_BRANCH26)"); exit(6) }
    if r.pcrel != 1 { println("FAIL: r.pcrel = " + to_string(r.pcrel) + " (expected 1)"); exit(7) }
    if r.length != 2 { println("FAIL: r.length = " + to_string(r.length) + " (expected 2)"); exit(8) }

    let bytes = serialize(obj)
    write_bytes("/tmp/macho_p0_cycle4.ours.o", bytes)

    println("F-P0-OBJEQ-RELOC PASS — relocation record structural")
    println("  obj.text    = " + to_string(nt) + " B (caller 8B + callee 8B)")
    println("  obj.symbols = " + to_string(ns) + " (_caller @ 0, _callee @ 8)")
    println("  obj.relocs  = " + to_string(nr) + " (BL @ 0 → sym 1 _callee, BRANCH26 pcrel L2)")
    println("  wrote " + to_string(len(bytes)) + " bytes to /tmp/macho_p0_cycle4.ours.o")
    exit(0)
}
