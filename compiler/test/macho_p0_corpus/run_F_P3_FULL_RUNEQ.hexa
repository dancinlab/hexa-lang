// F-P3-FULL-RUNEQ — P3 full closure falsifier.
//
// End-to-end: `.hexa → aprime_cc (P0) → .o → hexa_ld (P1) → exec
// → launch → exit code`. **외부 clang/as/ld fork 0건**.
//
// 단 macOS 의 codesign 는 RFC 063 § P1 명시된 OS Gatekeeper exception.

import "../../../tool/hexa_ld.hexa"

fn main() {
    // 1. aprime_cc 가 trivial.hexa → .o 를 stripped PATH 에서 emit.
    let stripped = "/usr/bin:/bin"
    let aprime = "/tmp/aprime_s7"
    let src = "compiler/test/macho_p0_corpus/trivial.hexa"
    let o_path = "/tmp/p3_full_trivial.o"
    let cmd1 = "env -i PATH=" + stripped + " " + aprime +
               " _drv.hexa --target=arm64-apple-darwin --emit=obj --backend=native " +
               "-o " + o_path + " " + src + " 2>&1"
    let r1 = exec_capture(cmd1)
    if to_int(r1[2]) != 0 {
        println("FAIL: aprime_cc --emit=obj rc=" + to_string(to_int(r1[2])))
        println(to_string(r1[0]))
        exit(1)
    }
    println("step 1: aprime_cc --emit=obj --backend=native (stripped PATH) PASS")

    // 2. parse the produced .o + hand-build runtime stub + link via hexa_ld.
    let p_main = parse_macho_obj(o_path)
    let rt_text: [Int] = [
        0xC0, 0x03, 0x5F, 0xD6,         // _hexa_set_args: ret
        0xE0, 0x03, 0x01, 0xAA,         // _hexa_exit: mov x0, x1
        0x30, 0x00, 0x80, 0xD2,         //             mov x16, #1
        0x01, 0x10, 0x00, 0xD4,         //             svc #0x80
    ]
    let runtime: ParsedObj = ParsedObj {
        path: "synthetic_runtime",
        text: rt_text,
        defined: [
            LinkSym { name: "_hexa_set_args", offset: 0, scope: 0 },
            LinkSym { name: "_hexa_exit",     offset: 4, scope: 0 },
        ],
        extern_refs: [],
        relocs:      [],
        dwarf_line:  [],
    }
    let exec_path = "/tmp/p3_full_exec"
    let objs: [ParsedObj] = [p_main, runtime]
    let rc = link_macho_arm64(objs, exec_path, "_main", 0)
    if rc != 0 {
        println("FAIL: hexa_ld rc=" + to_string(rc))
        exit(2)
    }
    println("step 2: hexa_ld static-link (codesign external OS exception) PASS")

    // 3. Launch the exec.
    let r3 = exec_capture(exec_path)
    let r3_rc = to_int(r3[2])
    println("step 3: launch — rc=" + to_string(r3_rc) + " (expected 42)")
    if r3_rc != 42 {
        println("FAIL: exec did not exit(42)")
        exit(3)
    }

    println("🛸 F-P3-FULL-RUNEQ PASS — `.hexa → aprime_cc (P0) → .o → hexa_ld (P1)")
    println("   → exec → exit 42` with NO external clang/as/ld fork.")
    println("   (codesign external fork 1건은 RFC 063 § P1 명시 OS Gatekeeper exception.)")
    exit(0)
}
