// compiler/intrinsics/intrinsics_test.hexa
//
// Smoke test for compiler/intrinsics/intrinsics.hexa.
//
// v0 expectations (host: any POSIX shell):
//   - now_ns() returns a positive i64 not earlier than 2024-01-01 in nanos
//     (1704067200_000000000) and not absurdly far in the future.
//   - host_target() returns one of the four canonical strings:
//       arm64-darwin, x86_64-darwin, arm64-linux, x86_64-linux
//   - mkdir_p(/tmp/_hexa_intrinsics_test_dir/a/b/c) returns 0 and the
//     directory exists afterwards.
//
// English-only. No DiagBuilder. No commits.

import "compiler/intrinsics/intrinsics.hexa"

fn assert(cond: bool, label: string) {
    if cond {
        println("ok  - " + label)
    } else {
        println("FAIL - " + label)
    }
}

fn test_now_ns() {
    let t = now_ns()
    assert(t > 1704067200000000000, "now_ns >= 2024-01-01")
    assert(t < 4102444800000000000, "now_ns < 2100-01-01")
}

fn test_host_target() {
    let h = host_target()
    let ok = (h == "arm64-darwin")
          || (h == "x86_64-darwin")
          || (h == "arm64-linux")
          || (h == "x86_64-linux")
    assert(ok, "host_target canonical (" + h + ")")
    // Cached: second call must equal first.
    let h2 = host_target()
    assert(h == h2, "host_target cached identical")
}

fn test_mkdir_p() {
    let path = "/tmp/_hexa_intrinsics_test_dir/a/b/c"
    let rc = mkdir_p(path)
    assert(rc == 0, "mkdir_p rc==0")
    // Idempotent: a second call must also succeed.
    let rc2 = mkdir_p(path)
    assert(rc2 == 0, "mkdir_p idempotent")
    // Empty path is rejected.
    let rc3 = mkdir_p("")
    assert(rc3 != 0, "mkdir_p('') rejected")
    // Cleanup is best-effort; we leave the dir behind so a manual rm -rf
    // can confirm. Test does not require teardown.
}

fn test_rm_file() {
    // Write a file, rm it, verify gone. We use exec() here only because
    // the stdlib write_file wrapper isn't reachable from this module yet
    // in stage0; the point under test is rm_file, not the writer.
    let path = "/tmp/_hexa_intrinsics_rm_file.txt"
    let _ = exec("printf hello > '" + path + "' 2>/dev/null")
    assert(path_exists(path), "rm_file: file written")
    let rc = rm_file(path)
    assert(rc == 0, "rm_file rc==0")
    assert(!path_exists(path), "rm_file: file gone")
    // Idempotent — removing a missing file is success.
    let rc2 = rm_file(path)
    assert(rc2 == 0, "rm_file idempotent on missing")
    // Empty path rejected.
    let rc3 = rm_file("")
    assert(rc3 != 0, "rm_file('') rejected")
}

fn test_getenv() {
    // HOME is set in every POSIX shell session.
    let h = getenv("HOME")
    assert(h != "", "getenv(HOME) non-empty")
    // A name that almost certainly does not exist.
    let none = getenv("HEXA_DEFINITELY_UNSET_VAR_XYZ")
    assert(none == "", "getenv(unset) empty")
    // Shell-injection guard — illegal chars must short-circuit to "".
    let bad = getenv("FOO; rm -rf /")
    assert(bad == "", "getenv rejects metacharacters")
    // Lowercase also rejected by the strict charset.
    let lower = getenv("home")
    assert(lower == "", "getenv rejects lowercase")
}

fn test_path_exists_and_is_dir() {
    // /tmp exists and is a directory on every POSIX host we target.
    assert(path_exists("/tmp"), "path_exists(/tmp)")
    assert(path_is_dir("/tmp"), "path_is_dir(/tmp)")
    // A path that should not exist.
    let phantom = "/tmp/_hexa_nonexistent_xyz_zzz"
    assert(!path_exists(phantom), "path_exists(phantom) false")
    assert(!path_is_dir(phantom), "path_is_dir(phantom) false")
    // Empty path uniformly false.
    assert(!path_exists(""), "path_exists('') false")
    assert(!path_is_dir(""), "path_is_dir('') false")
}

fn test_getcwd() {
    let d = getcwd()
    assert(d != "", "getcwd non-empty")
    assert(d[0] == "/", "getcwd absolute (starts with /)")
    // cwd() alias must agree.
    let d2 = cwd()
    assert(d == d2, "cwd() alias agrees with getcwd()")
}

fn test_list_dir() {
    // /tmp exists on every POSIX host and is non-empty after the mkdir_p
    // test above created /tmp/_hexa_intrinsics_test_dir.
    let _ = exec("mkdir -p /tmp/_hexa_list_dir_test/x /tmp/_hexa_list_dir_test/y 2>/dev/null")  // @allow-bare-exec
    let entries = list_dir("/tmp/_hexa_list_dir_test")
    assert(len(entries) == 2, "list_dir counts two entries")
    var saw_x = false
    var saw_y = false
    for e in entries {
        if e == "x" { saw_x = true }
        if e == "y" { saw_y = true }
    }
    assert(saw_x && saw_y, "list_dir returns both x and y")
    // Missing directory -> empty array (not an error).
    let none = list_dir("/tmp/_hexa_no_such_dir_zzz")
    assert(len(none) == 0, "list_dir(missing) is []")
    // Empty path -> empty array.
    let empty = list_dir("")
    assert(len(empty) == 0, "list_dir('') is []")
}

pub fn main() {
    println("# compiler/intrinsics smoke test (v0)")
    test_now_ns()
    test_host_target()
    test_mkdir_p()
    test_rm_file()
    test_getenv()
    test_path_exists_and_is_dir()
    test_getcwd()
    test_list_dir()
    println("# done")
}
