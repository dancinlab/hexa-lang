// HEXA Native Compiler — Wave 1 absorption: hexad smoke
//
// @version 0.1.0
// @capabilities [pure]
//
// Run:
//   hexa run compiler/hexad/static_index_test.hexa

use "compiler/hexad/embed"
use "compiler/hexad/embedded.gen"
use "compiler/hexad/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 hexad embed smoke")
    println("  hash:         " + HEXAD_HASH)
    println("  generated_at: " + HEXAD_GENERATED_AT)
    println("  source_count: " + to_string(HEXAD_SOURCE_COUNT))
    println("  entries:      " + to_string(len(HEXAD_CONSTANTS)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(HEXAD_HASH),                              fails)
    _check("generated_at non-empty",     len(HEXAD_GENERATED_AT) > 0,                        fails)
    _check("source_count > 0",           HEXAD_SOURCE_COUNT > 0,                             fails)
    _check("entries match source_count", len(HEXAD_CONSTANTS) == HEXAD_SOURCE_COUNT,         fails)
    _check("entries > 0",                len(HEXAD_CONSTANTS) > 0,                           fails)

    let sigma_n6 = hexad_lookup("sigma", "sigma_n6")
    _check("lookup(sigma, sigma_n6).kind == i64", sigma_n6.kind == "i64",                    fails)
    _check("lookup(sigma, sigma_n6).value_i64 == 12", sigma_n6.value_i64 == 12,              fails)

    let alpha = hexad_lookup("psi", "alpha")
    _check("lookup(psi, alpha).kind == f64", alpha.kind == "f64",                            fails)

    let ch = hexad_lookup("channels", "names")
    _check("lookup(channels, names).kind == string_list", ch.kind == "string_list",          fails)
    _check("channels.names has 6 entries", len(ch.value_str_list) == 6,                      fails)

    let miss = hexad_lookup("nope", "nope")
    _check("lookup miss → group == \"\"", miss.group == "",                                  fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(HEXAD_CONSTANTS)) + "/" + to_string(HEXAD_SOURCE_COUNT) + " entries, hash=" + HEXAD_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
