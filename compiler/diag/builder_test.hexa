// HEXA Native Compiler — Diagnostic Builder + Renderer Smoke Test
//
// @version 0.1.0
// @capabilities [pure]
//
// Three cases per RFC-019 §4.B / §7:
//   (a) HX1042 atlas node not found — args (atlas_hash, kind, node_id)
//       + suggest + fix-it (Replace).
//   (b) HX2001 undefined name — single arg (name), no suggest.
//   (c) HX3001 type mismatch — two args (expected, actual).
//
// For each case we render all four output modes (pretty, short, json,
// github), print them, and assert the salient strings appear.

import "../lex/tokens.hexa"
import "./catalog.hexa"
import "./builder.hexa"
import "./render.hexa"

// ── Helpers ──────────────────────────────────────────────────

fn _span(file: string, line: i64, col: i64, length: i64) -> Span {
    return Span { file: file, line: line, col: col, len: length }
}

// `string.contains(needle)` is not a stage0 builtin, so do a tiny
// substring search by hand. Returns true iff `needle` is a contiguous
// substring of `hay`.
fn _contains(hay: string, needle: string) -> bool {
    let h = hay.chars()
    let n = needle.chars()
    let hn = len(h)
    let nn = len(n)
    if nn == 0 { return true }
    if nn > hn { return false }
    let mut i = 0
    while i + nn <= hn {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if h[i + j] != n[j] {
                ok = false
                break
            }
            j = j + 1
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

fn _assert(label: string, cond: bool, ok: bool) -> bool {
    if !cond {
        println("  FAIL: " + label)
        return false
    }
    println("  ok:   " + label)
    return ok
}

fn _print_block(title: string, pretty: string, short: string, json: string, github: string) {
    println("─── " + title + " ───")
    println("[pretty]")
    println(pretty)
    println("[short]  " + short)
    println("[json]   " + json)
    println("[github] " + github)
    println("")
}

// ── Cases ────────────────────────────────────────────────────

fn _case_a() -> bool {
    println("=== case (a): HX1042 atlas node not found ===")
    let sp = _span("example/foo.hexa", 42, 11, 17)  // 17 = len("einstien-mass") ish
    let mut b = diag_new("HX1042")
    b = diag_span(b, sp)
    b = diag_arg(b, "atlas_hash", "abc123")
    b = diag_arg(b, "kind", "P")
    b = diag_arg(b, "node_id", "einstien")
    b = diag_suggest(b, "einstein")
    b = diag_fixit(b, FixItKind::Replace, sp, "einstein")
    let d = diag_emit(b)

    let p = render_pretty(d)
    let s = render_short(d)
    let j = render_json(d)
    let g = render_github(d)
    _print_block("case (a)", p, s, j, g)

    let mut ok = true
    ok = _assert("pretty contains HX1042", _contains(p, "HX1042"), ok)
    ok = _assert("pretty contains 'cause:'", _contains(p, "cause:"), ok)
    ok = _assert("pretty contains 'suggest:'", _contains(p, "suggest:"), ok)
    ok = _assert("pretty contains 'fix:'", _contains(p, "fix:"), ok)
    ok = _assert("pretty contains 'explain:'", _contains(p, "explain:"), ok)
    ok = _assert("pretty interpolates atlas_hash", _contains(p, "abc123"), ok)
    ok = _assert("pretty interpolates node_id", _contains(p, "einstien"), ok)
    ok = _assert("pretty has English HexaError header", _contains(p, "HexaError"), ok)
    ok = _assert("short single line w/ HX1042", _contains(s, "HX1042"), ok)
    ok = _assert("short carries [suggest=einstein]", _contains(s, "suggest=einstein"), ok)
    ok = _assert("json has \"code\":\"HX1042\"", _contains(j, "\"code\":\"HX1042\""), ok)
    ok = _assert("json has \"severity\":\"error\"", _contains(j, "\"severity\":\"error\""), ok)
    ok = _assert("json has \"stage\":\"S1\"", _contains(j, "\"stage\":\"S1\""), ok)
    ok = _assert("json has line:42", _contains(j, "\"line\":42"), ok)
    ok = _assert("json has suggest=einstein", _contains(j, "\"suggest\":\"einstein\""), ok)
    ok = _assert("github starts with ::error", _contains(g, "::error"), ok)
    ok = _assert("github carries file=example/foo.hexa", _contains(g, "file=example/foo.hexa"), ok)
    ok = _assert("github body mentions HX1042", _contains(g, "HX1042"), ok)
    return ok
}

fn _case_b() -> bool {
    println("=== case (b): HX2001 undefined name (no suggest) ===")
    let sp = _span("example/bar.hexa", 7, 5, 3)
    let mut b = diag_new("HX2001")
    b = diag_span(b, sp)
    b = diag_arg(b, "name", "zzz")
    let d = diag_emit(b)

    let p = render_pretty(d)
    let s = render_short(d)
    let j = render_json(d)
    let g = render_github(d)
    _print_block("case (b)", p, s, j, g)

    let mut ok = true
    ok = _assert("pretty contains HX2001", _contains(p, "HX2001"), ok)
    ok = _assert("pretty interpolates name=zzz", _contains(p, "`zzz`"), ok)
    ok = _assert("pretty omits suggest line (none set)", !_contains(p, "suggest:"), ok)
    ok = _assert("short has HX2001", _contains(s, "HX2001"), ok)
    ok = _assert("short has no [suggest=...] block", !_contains(s, "suggest="), ok)
    ok = _assert("json code=HX2001", _contains(j, "\"code\":\"HX2001\""), ok)
    ok = _assert("json suggest empty", _contains(j, "\"suggest\":\"\""), ok)
    ok = _assert("json stage S2", _contains(j, "\"stage\":\"S2\""), ok)
    ok = _assert("github file=example/bar.hexa", _contains(g, "file=example/bar.hexa"), ok)
    return ok
}

fn _case_c() -> bool {
    println("=== case (c): HX3001 type mismatch (two args) ===")
    let sp = _span("example/baz.hexa", 13, 9, 1)
    let mut b = diag_new("HX3001")
    b = diag_span(b, sp)
    b = diag_arg(b, "expected", "i64")
    b = diag_arg(b, "actual", "string")
    let d = diag_emit(b)

    let p = render_pretty(d)
    let s = render_short(d)
    let j = render_json(d)
    let g = render_github(d)
    _print_block("case (c)", p, s, j, g)

    let mut ok = true
    ok = _assert("pretty contains HX3001", _contains(p, "HX3001"), ok)
    ok = _assert("pretty mentions expected i64", _contains(p, "`i64`"), ok)
    ok = _assert("pretty mentions got string", _contains(p, "`string`"), ok)
    ok = _assert("short carries both types", _contains(s, "i64") && _contains(s, "string"), ok)
    ok = _assert("json code=HX3001", _contains(j, "\"code\":\"HX3001\""), ok)
    ok = _assert("json stage S3", _contains(j, "\"stage\":\"S3\""), ok)
    ok = _assert("github body has HX3001", _contains(g, "HX3001"), ok)
    return ok
}

// ── Main ─────────────────────────────────────────────────────

fn main() {
    println("══════════════════════════════════════════════")
    println("  HEXA Compiler — Diag Builder + Render Test")
    println("══════════════════════════════════════════════")
    println("")

    let a = _case_a()
    println("")
    let b = _case_b()
    println("")
    let c = _case_c()
    println("")

    if a && b && c {
        println("PASS: builder + 4-format renderer green across 3 cases.")
    } else {
        println("FAIL: see assertions above.")
        exit(1)
    }
    println("══════════════════════════════════════════════")
}
