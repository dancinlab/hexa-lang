        template: "wrong number of arguments to `{name}`: expected {expected}, got {actual}",
        explain: "The call site supplies a different number of arguments than the callee's signature declares. Add or remove arguments to match the function definition.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX3003",
