        severity: Severity::Error,
        stage: "S3",
        template: "argument {pos} of `{name}`: expected `{expected}`, got `{actual}`",
        explain: "A call argument's static type does not match the corresponding parameter type. Fix the argument expression or change the call target.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX3004",
        title: "return type mismatch",
