        stage: "S5",
        template: "argument {pos} of `{name}`: expected unit `{expected}`, got `{actual}`",
        explain: "A call argument's dimensional unit does not match the corresponding parameter unit declared on the callee's `@units` annotation. Convert the argument or fix the callee declaration.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX8001",
