        title: "atlas node not found",
        severity: Severity::Error,
        stage: "S1",
        template: "atlas {atlas_hash} has no {kind} node `{node_id}`",
        explain: "The identifier was used as a P/C/L/E token, but no such node exists in the atlas snapshot pinned by hexa.toml. This is usually a typo or a missing atlas update.",
