// HEXA Native Compiler — Diagnostic Catalog (Phase A0 skeleton)
//
// All compiler errors and warnings are described here. Per RFC-019:
//   - error code = HX[CCCC] (4 digits)
//   - groups by stage:
//       HX0xxx parse/lex     (S0)
//       HX1xxx atlas resolve (S1)
//       HX2xxx bind/scope    (S2)
//       HX3xxx type          (S3)
//       HX4xxx domain        (S4)
//       HX5xxx units         (S5)
//       HX6xxx equational    (S6)
//       HX7xxx proof         (S7)
//       HX8xxx citation      (S8)
//       HX9xxx codegen/link/runtime
//
// English only (Decision 3). No i18n. messages.hexa holds templates.
//
// Severity is a payload-free enum (`Severity`). Stage and code remain strings:
// stage tags are open-ended ("S0".."S8" | "codegen" | "link" | "runtime") and
// codes are HX-prefixed numerics that grow with each phase.

import "../lex/tokens.hexa"

// ── Severity ──────────────────────────────────────────────────

pub enum Severity {
    Error,
    Warning,
    Note
}

// ── FixIt action ──────────────────────────────────────────────

pub enum FixItKind {
    Replace,
    Insert,
    Delete,
    Multi,
    None
}

pub struct FixIt {
    kind: FixItKind,
    span: Span,
    new_text: string
}

// ── Diagnostic instance (per error site) ─────────────────────

pub struct Diagnostic {
    code: string,        // "HX1042"
    severity: Severity,
    stage: string,       // "S0".."S8" | "codegen" | "link" | "runtime"
    span: Span,
    message: string,     // rendered template (English)
    note: string,
    suggest: string,     // did-you-mean candidate
    fixit: FixIt,
    related: [string]    // other HX codes
}

// ── Catalog entry (compile-time table) ────────────────────────

pub struct DiagSpec {
    code: string,
    title: string,        // "atlas node not found"
    severity: Severity,
    stage: string,
    template: string,     // "atlas {atlas_hash} has no {kind} node `{node_id}`"
    explain: string,      // long form for `hexa explain`
    fix_it_kind: FixItKind
}

// ── Initial catalog (will grow with each phase) ──────────────

pub let CATALOG: [DiagSpec] = [
