        stage: "S3",
        template: "match arms have different types: expected `{expected}`, got `{actual}` on arm {pos}",
        explain: "All arms of a `match` used as an expression must produce the same type. Adjust the divergent arm to match the first arm's result type.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX4001",
        title: "integer division domain narrow",
        severity: Severity::Warning,
        stage: "S4",
        template: "integer division narrows the real domain to integers; use `//` (floor) or cast to f64 to silence",
        explain: "Dividing two integer operands with `/` silently truncates the real-number result. RFC-017 S4 surfaces this as a domain hint so the author confirms the narrowing was intentional.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX5001",
        title: "unit mismatch in arithmetic",
        severity: Severity::Error,
        stage: "S5",
        template: "unit mismatch in `{op}`: lhs is `{lhs}`, rhs is `{rhs}`",
        explain: "Addition, subtraction, and comparison operators require both sides to share the same dimensional unit (RFC-017 §3.1 S5). Multiplication and division compose units; only +/-/comparisons require equality. Lenient v1: an untyped operand is compatible with any unit.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX5002",
        title: "fn return unit mismatch",
        severity: Severity::Error,
        stage: "S5",
        template: "return unit mismatch: function `{name}` declares `{expected}`, body produces `{actual}`",
        explain: "A `return` expression (or a fn's trailing block value) yields a value whose dimensional unit does not match the unit declared in the fn's `@units` annotation.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX5003",
        title: "call argument unit mismatch",
