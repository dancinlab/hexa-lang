        template: "atlas {atlas_hash} has no L node `{node_id}` cited by @implements",
        explain: "An `@implements(L[id])` annotation refers to an L node that is not present in the merged atlas snapshot. Either add the L node to atlas.n6 (or an append shard), or fix the citation id.",
        fix_it_kind: FixItKind::Replace
    },
    DiagSpec {
        code: "HX8002",
        title: "@implements points at non-L node kind",
        severity: Severity::Error,
        stage: "S8",
        template: "@implements({kind}[{node_id}]) points at a {kind} node; only L nodes may be implemented",
        explain: "The `@implements` annotation is reserved for citing an L (law) node from the atlas. Citing a P/C/E node is a kind error — use the appropriate annotation or cite the law that governs the node.",
        fix_it_kind: FixItKind::None
    },
    DiagSpec {
        code: "HX8003",
        title: "fn uses atlas L refs but has no @implements citation",
        severity: Severity::Warning,
