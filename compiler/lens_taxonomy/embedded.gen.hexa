    LensEntry { name: "qcoh_robustness", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — robustness lower bound C_l1/(d-1)", derived_from: "" },
    LensEntry { name: "qcoh_fisher_info", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — quantum Fisher information F_Q = 4 Var(H)", derived_from: "" },
    LensEntry { name: "qcoh_linear_entropy", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — linear entropy S_L = 1 - Tr(rho_diag^2)", derived_from: "" },
    LensEntry { name: "qcoh_number", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — coherence number |{i : p_i > eps}| (Schmidt rank analog)", derived_from: "" },
    LensEntry { name: "qcoh_geometric", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — geometric coherence C_g = 1 - max_i p_i", derived_from: "" },
    LensEntry { name: "qcoh_skew_info", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — Wigner-Yanase skew information I(rho,K) = Var(K) on pure real amps", derived_from: "" },
    LensEntry { name: "qcoh_asymmetry", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — asymmetry imbalance |P(lo) - P(hi)| across probability halves", derived_from: "" },
    LensEntry { name: "qcoh_renyi2", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — Renyi-2 entropy C_R2 = -ln(sum p_i^2) = -ln(purity)", derived_from: "" },
    LensEntry { name: "qcoh_min_entropy", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — min-entropy H_min = -ln(max p_i)", derived_from: "" },
    LensEntry { name: "qcoh_participation", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — inverse participation ratio PR = 1/sum p_i^2 (effective dimension)", derived_from: "" },
    LensEntry { name: "qcoh_log_l1", file: "shared/blowup/lens/telescope_quantum.hexa", category: "physics", status: "implemented", description: "quantum coherence — log-bounded l1-norm C_log_l1 = log_2(1 + C_l1)", derived_from: "" },
