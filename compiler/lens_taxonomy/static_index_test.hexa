// HEXA Native Compiler — Wave 1 absorption: lens_taxonomy smoke

use "compiler/lens_taxonomy/embed"
use "compiler/lens_taxonomy/embedded.gen"
use "compiler/lens_taxonomy/static_index"

fn _is_hex64(s: string) -> bool {
    if len(s) != 64 { return false }
    let mut i = 0
    while i < 64 {
        let c = s.substring(i, i + 1)
        let ok = (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
        if !ok { return false }
        i = i + 1
    }
    return true
}

fn _check(label: string, ok: bool, fails: array) {
    if ok { println("  PASS  " + label) }
    else { println("  FAIL  " + label); fails.push(label) }
}

fn main() {
    println("wave1 lens_taxonomy embed smoke")
    println("  hash:         " + LENS_TAXONOMY_HASH)
    println("  generated_at: " + LENS_TAXONOMY_GENERATED_AT)
    println("  source_count: " + to_string(LENS_TAXONOMY_SOURCE_COUNT))
    println("  entries:      " + to_string(len(LENS_TAXONOMY)))

    let fails = []
    println("")
    println("checks:")
    _check("hash is 64-char hex",        _is_hex64(LENS_TAXONOMY_HASH),                       fails)
    _check("generated_at non-empty",     len(LENS_TAXONOMY_GENERATED_AT) > 0,                 fails)
    _check("source_count > 0",           LENS_TAXONOMY_SOURCE_COUNT > 0,                      fails)
    _check("entries match source_count", len(LENS_TAXONOMY) == LENS_TAXONOMY_SOURCE_COUNT,    fails)
    _check("entries >= 4000",            len(LENS_TAXONOMY) >= 4000,                          fails)

    let l = lens_lookup("acoustic")
    _check("lens_lookup(acoustic).name", l.name == "acoustic",                                fails)
    _check("acoustic category non-empty", len(l.category) > 0,                                fails)

    let phys = lenses_by_category("physics")
    _check("category physics non-empty", len(phys) > 0,                                       fails)

    let implemented = lenses_by_status("implemented")
    _check("status implemented non-empty", len(implemented) > 0,                              fails)

    let miss = lens_lookup("not-a-real-lens-zz")
    _check("lookup miss → name == \"\"", miss.name == "",                                     fails)

    println("")
    if len(fails) == 0 {
        println("RESULT: PASS (" + to_string(len(LENS_TAXONOMY)) + "/" + to_string(LENS_TAXONOMY_SOURCE_COUNT) + " entries, hash=" + LENS_TAXONOMY_HASH.substring(0, 12) + "...)")
        exit(0)
    } else {
        println("RESULT: FAIL — " + to_string(len(fails)) + " check(s) failed")
        exit(1)
    }
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/static_index_test.hexa") { return true }
    if s == "static_index_test.hexa" { return true }
    return false
}
if _is_main() { main() }
