// scripts/native_build.hexa — P7-6c zero-tool native build driver
//
// Hexa → native binary. NO clang, NO cargo, NO external toolchain.
// Uses self/codegen/{arm64,x86_64,elf,macho}.hexa directly.
//
// Usage:
//   hexa scripts/native_build.hexa INPUT.hexa [OUTPUT] [--target=TARGET]
//
// Targets (default = host):
//   darwin-arm64   → Mach-O MH_EXECUTE, ARM64
//   linux-x86_64   → ELF64 EXEC, x86_64
//   linux-arm64    → ELF64 EXEC, ARM64
//
// Examples:
//   # Build for current machine (Mac → Mach-O, Linux → ELF)
//   hexa scripts/native_build.hexa self/rt/test_syscall.hexa
//
//   # Cross-compile from Mac to Linux (ubu unblock)
//   hexa scripts/native_build.hexa self/rt/test_syscall.hexa \
//        --target=linux-x86_64 -o build/test_syscall_linux
//
//   # Scale check: full compiler
//   hexa scripts/native_build.hexa self/hexa_full.hexa \
//        --target=darwin-arm64 -o build/hexa_new

// ═══════════════════════════════════════════════════════════════════
// Target descriptor
// ═══════════════════════════════════════════════════════════════════

struct Target {
    arch: int,     // 0 = arm64, 1 = x86_64
    os: int,       // 0 = darwin, 1 = linux
    format: int    // 0 = mach-o, 1 = elf
}

fn target_from_string(s: string) -> Target {
    if s == "darwin-arm64" { return Target{arch: 0, os: 0, format: 0} }
    if s == "linux-x86_64" { return Target{arch: 1, os: 1, format: 1} }
    if s == "linux-arm64"  { return Target{arch: 0, os: 1, format: 1} }
    eprintln("unknown --target: " + s)
    exit(2)
    return Target{arch: 0, os: 0, format: 0}
}

fn detect_host_target() -> Target {
    let uname = exec("uname -s").trim()
    let arch  = exec("uname -m").trim()
    if uname == "Darwin" {
        return Target{arch: 0, os: 0, format: 0}
    }
    if arch == "x86_64" || arch == "amd64" {
        return Target{arch: 1, os: 1, format: 1}
    }
    return Target{arch: 0, os: 1, format: 1}
}

fn target_to_string(t: Target) -> string {
    if t.os == 0 { return "darwin-arm64" }
    if t.arch == 1 { return "linux-x86_64" }
    return "linux-arm64"
}

// ═══════════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════════

fn main() {
    let av = argv()
    if len(av) < 3 {
        eprintln("usage: hexa scripts/native_build.hexa INPUT.hexa [OUTPUT] [--target=TARGET]")
        exit(1)
    }

    let mut input = ""
    let mut output = ""
    let mut target = detect_host_target()
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a.starts_with("--target=") {
            target = target_from_string(a.slice(9, len(a)))
        } else if a == "-o" && i + 1 < len(av) {
            output = av[i + 1]
            i = i + 1
        } else if input == "" {
            input = a
        } else if output == "" {
            output = a
        }
        i = i + 1
    }

    if input == "" {
        eprintln("no input file")
        exit(1)
    }
    if output == "" {
        let base = exec("basename " + input + " .hexa").trim()
        output = "build/" + base + "_" + target_to_string(target)
    }

    println("[native_build] " + input + " → " + output)
    println("[native_build] target: " + target_to_string(target))

    // ── Parse + lower to IR ────────────────────────────────────────
    //
    // parse_and_lower returns an IRModule. This is the scaled-up path
    // (P7-6a) — until it compiles hexa_full.hexa end-to-end, the call
    // stays a stub and this script only works for small programs.
    let src = read_file(input)
    let ir_mod = parse_and_lower(src, input)

    // ── Codegen ────────────────────────────────────────────────────
    let code_bytes = codegen_module(ir_mod, target)

    // ── Wrap in executable format ──────────────────────────────────
    let bin_bytes = []
    if target.format == 0 {
        bin_bytes = macho_wrap(code_bytes, target.arch)
    } else {
        bin_bytes = elf_wrap(code_bytes, target.arch)
    }

    // ── Write + chmod ──────────────────────────────────────────────
    write_bytes(output, bin_bytes)
    exec("chmod +x " + output)

    // ── Darwin ad-hoc codesign (skip when cross-compiling to Darwin from Linux) ──
    if target.os == 0 {
        let uname = exec("uname -s").trim()
        if uname == "Darwin" {
            exec("codesign -s - " + output)
        } else {
            eprintln("[native_build] WARN: skipping codesign (cross-compile to Darwin from non-Mac host — binary may not run on SIP-enforced macOS)")
        }
    }

    let sz = file_size(output)
    println("[native_build] OK: " + output + " (" + str(sz) + " bytes)")
}

// ═══════════════════════════════════════════════════════════════════
// Hooks — must be provided by the compiler at link time
// ═══════════════════════════════════════════════════════════════════
