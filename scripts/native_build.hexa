// modules. Until P7-6a lands (hexa_full.hexa scale), parse_and_lower
// is a placeholder.

fn parse_and_lower(src: string, path: string) -> any {
    // TODO(P7-6a): call self/parser.hexa::parse_file →
    // self/ir/lowering.hexa::lower_module. Returns IRModule.
    eprintln("[native_build] parse_and_lower: NOT YET IMPLEMENTED (P7-6a)")
    exit(3)
    return 0
