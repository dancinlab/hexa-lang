// Exhaustive D(n)-zero-locus sweep — ω-zero-density theorem.
//
//   D(n) = sigma(n)*euler_phi(n) - n*tau(n)
//
// Uses the SAME stdlib primitives `hexa verify --expr {sigma,phi,tau}` blesses
// 🔵 SUPPORTED-FORMAL. This is the falsifier run for F-OMEGA-ZERO-DENSITY:
//   ∃ n ∉ {1,6} with D(n)=0  ⟹  theorem FALSIFIED.
// A clean sweep (zeros ONLY at n∈{1,6}) = falsifier survives.

use "stdlib/core/math"

fn D(n: int) -> int {
    sigma(n) * euler_phi(n) - n * tau(n)
}

fn main() -> int {
    let zeros = 0
    let z1 = 0
    let z6 = 0
    let other_zero = 0
    let n = 1
    while n <= 200 {
        let d = D(n)
        if d == 0 {
            zeros = zeros + 1
            if n == 1 { z1 = 1 }
            else { if n == 6 { z6 = 1 } else { other_zero = other_zero + 1 } }
            println("ZERO  D(" + to_string(n) + ") = 0")
        }
        n = n + 1
    }
    println("--- sweep n=1..200 ---")
    println("total zeros  = " + to_string(zeros))
    println("D(1)=0       = " + to_string(z1))
    println("D(6)=0       = " + to_string(z6))
    println("OTHER zeros  = " + to_string(other_zero) + "  (falsifier: must be 0)")

    // Primorial / large samples (ω stratified): each must be NONZERO.
    println("--- primorial / large samples (must all be != 0) ---")
    println("D(30)   = " + to_string(D(30)))
    println("D(210)  = " + to_string(D(210)))
    println("D(2310) = " + to_string(D(2310)))

    if other_zero == 0 {
        if z1 == 1 {
            if z6 == 1 {
                println("RESULT: PASS  zero-locus == {1,6}  (F-OMEGA-ZERO-DENSITY survives)")
                return 0
            }
        }
    }
    println("RESULT: FAIL  zero-locus != {1,6}")
    return 1
}
