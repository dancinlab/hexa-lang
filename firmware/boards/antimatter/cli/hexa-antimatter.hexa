#!hexa strict
// hexa-antimatter/cli/hexa-antimatter.hexa — standalone hexa-antimatter CLI
//
// 3-verb antimatter substrate (HEXA family) router:
//   factory        — CERN-scale antimatter factory       (WIRED, v1.0.0)
//   tabletop       — desktop 1.7e12 p̄/s candidate        (WIRED, v1.0.0)
//   pet_cyclotron  — ¹⁸F β⁺ on-site regeneration         (WIRED, v1.0.0)
//
// Plus utility subcmds:
//   status      — verb status table (3/3 wired computational)
//   verify      — verify/all orchestrator (n6 + docs + ladder + selftest)
//                 sub-targets: n6 / docs / ladder / all (default: all)
//   compute     — derived n=6 number calculator (sigma·tau / sigma² / σ-φ / ...)
//   selftest    — 3-verb sentinel sweep
//   help        — this help
//   --version   — print version
//
// Status: spec-first SSOT; computational scaffolding wired through
//   factory/tabletop/pet_cyclotron .hexa modules + verify/ analyzers.
//   Empirical antimatter operation remains out of scope (raw#10 honest C3).
//
// Constraints:
//   raw#9   — hexa-only orchestration; no python bridge
//   raw#15  — write-confined (audit log only)
//   raw#10  — honest C3: 3/3 verbs wired computationally; 0/3 wired empirically
//
// Cost: $0 (Mac local; pure arithmetic + SSOT text scans).

let VERSION = "1.0.0"

// ─── env / path resolve ───

let HOME = env("HOME")
let HEXA_ANTIMATTER_ROOT_ENV = env("HEXA_ANTIMATTER_ROOT")

fn hexa_antimatter_root() -> str {
    if HEXA_ANTIMATTER_ROOT_ENV.len() > 0 { return HEXA_ANTIMATTER_ROOT_ENV }
    let inferred = exec("dirname \"$(dirname \"$0\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return HOME + "/.hexa-antimatter"
}

let HA = hexa_antimatter_root()

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn has_flag(a: [str], flag: str) -> bool {
    for x in a {
        if x == flag { return true }
    }
    return false
}

fn json_mode(a: [str]) -> bool {
    return has_flag(a, "--json")
}

// ─── caveat printer (raw#10 honest C3) ───

fn _print_caveats() {
    println("")
    println("--- caveats (raw#10 C3) ---")
    println("  1. 3/3 verbs wired COMPUTATIONALLY (n=6 arithmetic + SSOT text scan)")
    println("     0/3 verbs wired EMPIRICALLY (no apparatus, no clinical operation).")
    println("  2. n=6 Dirac-mirror lattice (sigma=12, tau=4, phi=2, J2=24) is proven")
    println("     algebraically (verify/n6_arithmetic.hexa, 12/12 PASS) but its")
    println("     EMPIRICAL projection onto antimatter is a candidate, not a result.")
    println("  3. PET-cyclotron 18F beta+ regeneration is a design proposal; no")
    println("     clinical operation is performed by this repo.")
    println("  4. tabletop 1.7e12 p-bar/s and factory 1e12 p-bar/hr are candidate")
    println("     numbers from declarative .md SSOT — academia-unproven.")
    println("  5. Cross-link: hexa-cern (accelerator cousin), hexa-ufo (Stage-3")
    println("     propulsion fuel dependency — hexa-antimatter is its substrate).")
}

