        let mut js = "{\"hexa_antimatter\":\"" + VERSION + "\",\"subcmd\":\"status\","
        js = js + "\"verbs_total\":3,\"verbs_wired_computational\":3,\"verbs_wired_empirical\":0,"
        js = js + "\"verdict\":\"COMPUTATIONAL_WIRED\","
        js = js + "\"verbs\":[\"factory:wired\",\"tabletop:wired\",\"pet_cyclotron:wired\"],"
        js = js + "\"verifiers\":[\"n6_arithmetic\",\"cross_doc_audit\",\"release_ladder\",\"calc_factory\",\"calc_tabletop\",\"calc_pet_cyclotron\",\"numerics_factory\",\"numerics_tabletop\",\"numerics_pet_cyclotron\",\"numerics_factory_parity\",\"numerics_tabletop_parity\",\"numerics_pet_cyclotron_parity\",\"numerics_factory_solver\",\"numerics_tabletop_solver\",\"numerics_pet_cyclotron_solver\",\"numerics_cross_pillar\",\"numerics_lattice_arithmetic\",\"falsifier_check\",\"lint_numerics\",\"calc_break_even\",\"numerics_break_even\",\"numerics_break_even_parity\",\"numerics_break_even_solver\",\"saturation_check\",\"empirical_pet_inspire\",\"empirical_tabletop_inspire\",\"empirical_dirac_inspire\",\"empirical_break_even_inspire\",\"numerics_pet_realistic\",\"numerics_tabletop_relativistic\",\"numerics_dirac_precision\",\"numerics_break_even_thrust\",\"firmware_cyclotron_trigger\",\"firmware_penning_rf\",\"firmware_atomic_clock\",\"firmware_thrust_acquisition\"],"
        js = js + "\"n6_lattice_verified\":\"algebra:12/12\""
