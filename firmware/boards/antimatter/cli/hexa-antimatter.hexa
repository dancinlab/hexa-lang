// ─── subcommand stubs (placeholder verbs) ───

fn _dispatch_module(rel_path: str, json: bool) {
    let path = HA + "/" + rel_path
    let mut cmd = "hexa run \"" + path + "\""
    if json { cmd = cmd + " --json" }
    cmd = cmd + " 2>&1"
    let out = exec(cmd)
    println(out.trim())
}

fn cmd_factory(a: [str]) {
    _dispatch_module("factory/factory.hexa", json_mode(a))
}

fn cmd_tabletop(a: [str]) {
    _dispatch_module("tabletop/tabletop.hexa", json_mode(a))
}

fn cmd_pet_cyclotron(a: [str]) {
    _dispatch_module("pet_cyclotron/pet_cyclotron.hexa", json_mode(a))
}

fn cmd_selftest(a: [str]) {
    let path = HA + "/selftest/selftest.hexa"
    let out = exec("hexa run \"" + path + "\" 2>&1")
    println(out.trim())
    if json_mode(a) {
        let pass_str = "{\"hexa_antimatter\":\"" + VERSION + "\",\"subcmd\":\"selftest\",\"verdict\":\"PASS\"}"
        let fail_str = "{\"hexa_antimatter\":\"" + VERSION + "\",\"subcmd\":\"selftest\",\"verdict\":\"FAIL\"}"
        if out.contains("__HEXA_ANTIMATTER_SELFTEST__ PASS") {
            println(pass_str)
        } else {
            println(fail_str)
            exit(1)
        }
    }
    _print_caveats()
}

// ─── new subcommand: verify ───
fn cmd_verify(a: [str]) {
    let mut target = "all"
    let mut i = 3              // a[2] == "verify"; user args start at 3
    while i < len(a) {
        if !a[i].starts_with("-") { target = a[i]; break }
        i = i + 1
    }
    let mut path = HA + "/verify/all.hexa"
    if target == "n6"           { path = HA + "/verify/n6_arithmetic.hexa" }
    if target == "docs"         { path = HA + "/verify/cross_doc_audit.hexa" }
    if target == "ladder"       { path = HA + "/verify/release_ladder.hexa" }
    if target == "calc-factory"       { path = HA + "/verify/calc_factory.hexa" }
    if target == "calc-tabletop"      { path = HA + "/verify/calc_tabletop.hexa" }
    if target == "calc-pet-cyclotron" { path = HA + "/verify/calc_pet_cyclotron.hexa" }
    if target == "numerics-factory"   { path = HA + "/verify/numerics_factory.hexa" }
    if target == "numerics-tabletop"      { path = HA + "/verify/numerics_tabletop.hexa" }
    if target == "numerics-pet-cyclotron" { path = HA + "/verify/numerics_pet_cyclotron.hexa" }
    if target == "numerics-factory-parity"  { path = HA + "/verify/numerics_factory_parity.hexa" }
    if target == "numerics-tabletop-parity"      { path = HA + "/verify/numerics_tabletop_parity.hexa" }
    if target == "numerics-pet-cyclotron-parity" { path = HA + "/verify/numerics_pet_cyclotron_parity.hexa" }
    if target == "numerics-factory-solver"        { path = HA + "/verify/numerics_factory_solver.hexa" }
    if target == "numerics-tabletop-solver"       { path = HA + "/verify/numerics_tabletop_solver.hexa" }
    if target == "numerics-pet-cyclotron-solver"  { path = HA + "/verify/numerics_pet_cyclotron_solver.hexa" }
    if target == "numerics-cross-pillar"          { path = HA + "/verify/numerics_cross_pillar.hexa" }
    if target == "numerics-lattice-arithmetic"    { path = HA + "/verify/numerics_lattice_arithmetic.hexa" }
    if target == "falsifier"                      { path = HA + "/verify/falsifier_check.hexa" }
    if target == "lint-numerics"                  { path = HA + "/verify/lint_numerics.hexa" }
    if target == "calc-break-even"                { path = HA + "/verify/calc_break_even.hexa" }
    if target == "numerics-break-even"            { path = HA + "/verify/numerics_break_even.hexa" }
    if target == "numerics-break-even-parity"     { path = HA + "/verify/numerics_break_even_parity.hexa" }
    if target == "numerics-break-even-solver"     { path = HA + "/verify/numerics_break_even_solver.hexa" }
    if target == "saturation"                     { path = HA + "/verify/saturation_check.hexa" }
    if target == "empirical-pet"                  { path = HA + "/verify/empirical_pet_inspire.hexa" }
    if target == "empirical-tabletop"             { path = HA + "/verify/empirical_tabletop_inspire.hexa" }
    if target == "empirical-dirac"                { path = HA + "/verify/empirical_dirac_inspire.hexa" }
    if target == "empirical-break-even"           { path = HA + "/verify/empirical_break_even_inspire.hexa" }
    if target == "numerics-pet-realistic"         { path = HA + "/verify/numerics_pet_realistic.hexa" }
    if target == "numerics-tabletop-relativistic" { path = HA + "/verify/numerics_tabletop_relativistic.hexa" }
    if target == "numerics-dirac-precision"       { path = HA + "/verify/numerics_dirac_precision.hexa" }
    if target == "numerics-break-even-thrust"     { path = HA + "/verify/numerics_break_even_thrust.hexa" }
    if target == "firmware-cyclotron"             { path = HA + "/firmware/sim/cyclotron_trigger.hexa" }
    if target == "firmware-penning"               { path = HA + "/firmware/sim/penning_rf.hexa" }
    if target == "firmware-atomic-clock"          { path = HA + "/firmware/sim/atomic_clock_counter.hexa" }
    if target == "firmware-thrust"                { path = HA + "/firmware/sim/thrust_acquisition.hexa" }
    if target == "firmware-phase-d"               { path = HA + "/verify/firmware_phase_d_lint.hexa" }
    let out = exec("hexa run \"" + path + "\" 2>&1")
    println(out.trim())
    if !out.contains(" PASS") {
        exit(1)
    }
}

// ─── new subcommand: compute ───
fn cmd_compute(a: [str]) {
    let mut what = "n6"
    let mut i = 3
    while i < len(a) {
        if !a[i].starts_with("-") { what = a[i]; break }
        i = i + 1
    }
    if what == "n6" || what == "lattice" {
        let path = HA + "/verify/n6_arithmetic.hexa"
        let out = exec("hexa run \"" + path + "\" 2>&1")
        println(out.trim())
        return
    }
    if what == "factory"       { _dispatch_module("factory/factory.hexa", false); return }
    if what == "tabletop"      { _dispatch_module("tabletop/tabletop.hexa", false); return }
    if what == "pet_cyclotron" { _dispatch_module("pet_cyclotron/pet_cyclotron.hexa", false); return }
    eprintln("hexa-antimatter compute: unknown target '" + what + "'")
    eprintln("  available: n6 | factory | tabletop | pet_cyclotron")
    exit(2)
}

fn cmd_version() {
    println("hexa-antimatter " + VERSION)
    println("standalone Antimatter Substrate (HEXA family — extracted from canon 2026-05-06)")
    println("license: MIT")
    println("repo:    https://github.com/dancinlab/hexa-antimatter")
}

fn cmd_help() {
    println("hexa-antimatter " + VERSION + " — standalone Antimatter Substrate CLI")
    println("")
    println("usage: hexa-antimatter <subcmd> [flags...]")
    println("")
    println("verb subcommands (HEXA family — n=6 Dirac-mirror lattice):")
    println("  factory          CERN-scale antimatter factory          [WIRED]")
    println("  tabletop         desktop 1.7e12 p-bar/s candidate         [WIRED]")
    println("  pet_cyclotron    18F beta+ on-site regeneration           [WIRED]")
    println("")
    println("utility subcommands:")
    println("  status           3/3 wired verb table + verdict + caveats")
    println("  verify [target]  run verifier(s); target ∈ all|n6|docs|ladder|calc-{factory,tabletop,pet-cyclotron}|numerics-{factory,tabletop,pet-cyclotron}")
    println("  compute <name>   show derived numbers; name ∈ n6|factory|tabletop|pet_cyclotron")
    println("  selftest         3-verb sentinel sweep + n=6 algebra check")
    println("")
    println("global flags:")
    println("  --version        show version")
    println("  --json           machine-parseable JSON tail")
    println("  --help, -h       this help")
    println("")
    println("env:")
    println("  HEXA_ANTIMATTER_ROOT     override repo root (default: inferred from $0)")
    println("")
    println("cost estimate (Mac local): $0 — pure n=6 arithmetic + SSOT text scan.")
}

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_antimatter_cli", "hexa_antimatter_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        cmd_help()
        return
    }

    if sub == "help" { cmd_help(); return }

    if sub == "status" {
        cmd_status(a)
    } else if sub == "factory" {
        cmd_factory(a)
    } else if sub == "tabletop" {
        cmd_tabletop(a)
    } else if sub == "pet_cyclotron" {
        cmd_pet_cyclotron(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else if sub == "verify" {
        cmd_verify(a)
    } else if sub == "compute" {
        cmd_compute(a)
    } else {
        eprintln("hexa-antimatter: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-antimatter help' for usage")
        exit(2)
    }
}
