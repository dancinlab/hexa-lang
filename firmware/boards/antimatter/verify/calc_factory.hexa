let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_ANTIMATTER_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-antimatter"
}

let ROOT = _root()
let DOC_FACTORY = ROOT + "/factory/antimatter-factory.md"

fn _read(p: str) -> str {
    return exec("cat \"" + p + "\" 2>/dev/null")
}

fn _has(t: str, s: str) -> bool {
    if t.len() == 0 { return false }
    return t.contains(s)
}

fn _int_str(x: int) -> str {
    return "" + x
}

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("  [FAIL] " + label)
    }
    if detail.len() > 0 { println("         · " + detail) }
}

// ── n=6 lattice (computed, not declared) ─────────────────────────────────

fn divisors_of(n: int) -> [int] {
    let mut out: [int] = []
    let mut k = 1
    while k <= n {
        if n % k == 0 { out = out + [k] }
        k = k + 1
    }
    return out
}

fn sigma_of(n: int) -> int {
    let ds = divisors_of(n)
    let mut s = 0
    for d in ds { s = s + d }
    return s
}

fn tau_of(n: int) -> int {
    return len(divisors_of(n))
}

fn gcd_int(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

fn euler_phi_of(n: int) -> int {
    let mut c = 0
    let mut k = 1
    while k <= n {
        if gcd_int(k, n) == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr_of(n: int) -> int {
    // Sum of prime factors with multiplicity. sopfr(6) = 2 + 3 = 5.
    let mut s = 0
    let mut k = n
    let mut p = 2
    while p <= k {
        while k % p == 0 {
            s = s + p
            k = k / p
        }
        p = p + 1
    }
    return s
}

let N      = 6
let SIGMA  = sigma_of(N)        // 12
let TAU    = tau_of(N)          // 4
let PHI    = euler_phi_of(N)    // 2
let SOPFR  = sopfr_of(N)        // 5
let J2     = 2 * SIGMA          // 24

// ── factory-pillar derived ledger ────────────────────────────────────────

let DOF              = N
let CHANNELS         = SIGMA
let GATES            = SIGMA * SIGMA              // 144
let REDUNDANCY       = N / PHI                    // 3
let FBW_COUNT        = TAU                        // 4
let B_FIELD_T        = SIGMA * TAU                // 48
let MACH_PRECISION   = SIGMA - PHI                // 10
let GOLAY_DISTANCE   = SIGMA - TAU                // 8
let LIFETIME_MO      = SIGMA * TAU                // 48
let PROT_TIERS       = SOPFR                      // 5
let CREW             = N                          // 6
let STORAGE_HORIZON  = SIGMA * TAU * TAU          // 192 mo = 16 yr
let COST_REDUCE      = SIGMA * SIGMA * SIGMA      // 1728
let PAIR_PROD_UNIT   = SIGMA * J2                 // 288  (BT-401)
let VAC_SUPPRESS     = SIGMA * SIGMA * TAU        // 576
let ANTIPARTICLES    = SIGMA                      // 12
let DIRAC_DICHOTOMY  = PHI                        // 2
let TRAP_STATES      = TAU                        // 4
let CPT_GENERATORS   = SIGMA * PHI                // 24 = J₂

let FALSIFIERS = [
    "F-AM-3: σ·φ ≠ J₂ → master identity broken → Dirac-mirror n=6 closed-form retract",
    "F-AM-3: σ ≠ 12 antiparticle bins → channel multiplicity claim retract",
    "F-AM-3: φ ≠ 2 matter/antimatter dichotomy → Dirac mirror bit retract",
    "F-AM-3: τ ≠ 4 trap states (capture/cool/store/extract) → Penning sequence retract",
    "F-AM-3: σ·φ ≠ 24 CPT generators → octahedral O mirror symmetry retract",
    "F-AM-1: σ·τ ≠ 48 T Penning B-field → BT-401 RT-SC trap ladder retract",
    "factory pillar: σ² ≠ 144 production gain → BT-90 GPU SM closure retract",
    "factory pillar: σ³ ≠ 1728 cost reduction → 1/σ³ vs NASA-99 chain retract",
]

