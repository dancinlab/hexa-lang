    println("")
    println("  -- factory pillar design parameters --")
    check_factory_design_params()

    println("")
    println("  -- antimatter-specific Dirac-mirror locks --")
    check_antimatter_locks()

    println("")
    println("  -- SSOT spec-anchor cross-check --")
    check_spec_anchors()

    println("")
    println("  FALSIFIERS (" + _int_str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + _int_str(pass_n) + "/" + _int_str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_ANTIMATTER_CALC_FACTORY__ FAIL")
        exit(1)
    }
    println("__HEXA_ANTIMATTER_CALC_FACTORY__ PASS")
    exit(0)
