    println("")
    println("  ┌─ factory-pillar n=6 ledger (computed from divisor arithmetic) ─┐")
    println("  │  DOF                 = n     = " + _int_str(DOF))
    println("  │  channels            = σ     = " + _int_str(CHANNELS))
    println("  │  gates / SM          = σ²    = " + _int_str(GATES))
    println("  │  redundancy          = n/φ   = " + _int_str(REDUNDANCY))
    println("  │  FBW + FT count      = τ     = " + _int_str(FBW_COUNT))
    println("  │  B-field (RT-SC) [T] = σ·τ   = " + _int_str(B_FIELD_T))
    println("  │  Mach / precision    = σ-φ   = " + _int_str(MACH_PRECISION))
    println("  │  Golay distance      = σ-τ   = " + _int_str(GOLAY_DISTANCE))
    println("  │  J₂ minimal vector   = 2σ    = " + _int_str(J2))
    println("  │  lifetime [months]   = σ·τ   = " + _int_str(LIFETIME_MO))
