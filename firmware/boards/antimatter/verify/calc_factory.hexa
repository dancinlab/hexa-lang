    println("  │  trap states         = τ     = " + _int_str(TRAP_STATES))
    println("  │  CPT generators      = σ·φ   = " + _int_str(CPT_GENERATORS))
    println("  └────────────────────────────────────────────────────────────────┘")
    println("")
}

// ── algebraic identity checks ────────────────────────────────────────────

fn check_lattice_primitives() {
    _check(SIGMA == 12, "σ(6) = 12  (divisor sum 1+2+3+6)", "")
    _check(TAU   == 4,  "τ(6) = 4   (divisor count |{1,2,3,6}|)", "")
    _check(PHI   == 2,  "φ(6) = 2   (Euler totient |{1,5}|)", "")
    _check(SOPFR == 5,  "sopfr(6) = 5  (prime-factor sum 2+3)", "")
    _check(J2    == 24, "J₂ = 2σ = 24  (Leech/Mathieu min vector)", "")
}

fn check_master_identity() {
    _check(SIGMA * PHI == J2,    "σ·φ = J₂ = 24  (master identity LHS)", "")
    _check(N * TAU     == J2,    "n·τ = J₂ = 24  (master identity RHS)", "")
    _check(SIGMA * PHI == N * TAU, "σ·φ = n·τ  (master identity)", "")
    _check(SIGMA == 2 * N,         "σ(6) = 2·n  (Euclid-Euler perfect-number)", "")
    _check(PHI + TAU == N,         "φ(6) + τ(6) = n  (lattice depth)", "")
}

fn check_factory_design_params() {
    _check(B_FIELD_T == 48,       "B-field σ·τ = 48 T  (BT-401 Penning trap)", "")
    _check(GATES == 144,          "gate count σ² = 144  (BT-90 GPU SM)", "")
    _check(REDUNDANCY == 3,       "redundancy n/φ = 3  (BT-276 triple-FBW)", "")
    _check(MACH_PRECISION == 10,  "precision gain σ-φ = 10×  (BT-127 kissing cap)", "")
    _check(GOLAY_DISTANCE == 8,   "Golay [24,12,8] distance σ-τ = 8  (ECC)", "")
    _check(LIFETIME_MO == 48,     "lifetime σ·τ = 48 months  (RT-SC R=0)", "")
    _check(STORAGE_HORIZON == 192, "storage σ·τ² = 192 mo = 16 yr  (TABLETOP split)", "")
    _check(COST_REDUCE == 1728,   "cost reduction σ³ = 1728  (1/σ³ vs NASA-99)", "")
    _check(PROT_TIERS == 5,       "protection tiers sopfr = 5  (C Z=6 Diamond)", "")
    _check(CREW == 6,             "crew / env-vars n = 6  (BT-273)", "")
}

fn check_antimatter_locks() {
    _check(ANTIPARTICLES == 12,    "antiparticle bins σ = 12  (e⁺/p̄/n̄/Λ̄/Σ̄/Ξ̄/Ω̄ × Dirac)", "")
    _check(DIRAC_DICHOTOMY == 2,   "Dirac mirror dichotomy φ = 2  (matter/antimatter bit)", "")
    _check(TRAP_STATES == 4,       "Penning trap states τ = 4  (capture/cool/store/extract)", "")
    _check(CPT_GENERATORS == J2,   "CPT generators σ·φ = J₂ = 24  (octahedral O ⊂ I)", "")
    _check(PAIR_PROD_UNIT == 288,  "pair-production unit σ·J₂ = 288  (BT-401 closure)", "")
    _check(VAC_SUPPRESS == 576,    "vacuum suppression σ²·τ = 576  (vs medical 10⁻³ Torr)", "")
}

// ── SSOT spec-anchor checks (factory/antimatter-factory.md) ──────────────

fn check_spec_anchors() {
    let txt = _read(DOC_FACTORY)
    if txt.len() == 0 {
        _check(false, "factory SSOT readable", "missing: " + DOC_FACTORY)
        return
    }
    _check(true, "factory SSOT readable (" + _int_str(len(txt)) + " bytes)", DOC_FACTORY)

    _check(_has(txt, "sigma(6)=12") || _has(txt, "sigma=12") || _has(txt, "σ=12"),
           "SSOT cites σ(6) = 12", "")
    _check(_has(txt, "tau(6)=4") || _has(txt, "tau=4") || _has(txt, "τ=4"),
           "SSOT cites τ(6) = 4", "")
    _check(_has(txt, "phi=2") || _has(txt, "phi(6)=2") || _has(txt, "φ=2"),
           "SSOT cites φ(6) = 2", "")
    _check(_has(txt, "sigma*tau=48") || _has(txt, "sigma*tau = 48") || _has(txt, "σ·τ=48") || _has(txt, "48 T"),
           "SSOT cites B = σ·τ = 48 T", "")
    _check(_has(txt, "sigma^2 = 144") || _has(txt, "sigma^2=144") || _has(txt, "144x") || _has(txt, "144 "),
           "SSOT cites gates = σ² = 144", "")
    _check(_has(txt, "sigma-phi=10") || _has(txt, "sigma-phi = 10") || _has(txt, "σ-φ=10") || _has(txt, "10x") || _has(txt, "Mach"),
           "SSOT cites σ-φ = 10  (Mach / precision)", "")
    _check(_has(txt, "sopfr=5") || _has(txt, "sopfr(6)=5") || _has(txt, "sopfr = 5"),
           "SSOT cites sopfr(6) = 5", "")
    _check(_has(txt, "J_2=24") || _has(txt, "J_2 = 24") || _has(txt, "2*sigma = 24") || _has(txt, "J₂=24"),
           "SSOT cites J₂ = 24", "")
    _check(_has(txt, "Penning") || _has(txt, "penning"),
           "SSOT invokes Penning trap (BT-401)", "")
    _check(_has(txt, "10^12") || _has(txt, "1e12") || _has(txt, "1·10¹²"),
           "SSOT declares 1e12 p̄/hr throughput candidate", "")
    _check(_has(txt, "24-month") || _has(txt, "24 month") || _has(txt, "sigma*tau=48 months"),
           "SSOT declares 24-month / σ·τ-month storage candidate", "")
    _check(_has(txt, "Dirac") || _has(txt, "phi=2") || _has(txt, "antimatter") || _has(txt, "antiproton"),
           "SSOT invokes matter/antimatter dichotomy (Dirac mirror)", "")
}

