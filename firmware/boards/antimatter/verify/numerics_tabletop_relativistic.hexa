#!hexa strict
// hexa-antimatter/verify/numerics_tabletop_relativistic.hexa — F-AM-2
// Stage-1 simulation parity (Phase B per .roadmap §A.6.1).
//
// Extends F-AM-2 numerics stack from T2 ×3 → T2 ×4 with relativistic-trap
// model: include relativistic γ-correction for fast-mode ω_+ and the
// full p̄-trap mass spectrum (m_p̄ at 938.272 MeV/c²).
//
// Stage-1 cross-checks for tabletop/doc/benchtop_v0_design.md:
//   · Cyclotron freq ω_c = qB/m for p̄ in 48 T:
//     ω_c = (1.602e-19 · 48) / (1.673e-27) = 4.59e9 rad/s
//     f_c = ω_c / 2π = 731 MHz
//   · γ correction at v=0.001 c: γ ≈ 1 + 5e-7 → negligible
//   · Magnetron frequency ω_- ≈ ω_z² / (2 ω_+)  (Penning shift)
//   · trap mass-resolution m/Δm ≥ 10⁹ via ω_c precision
//   · 4.2 K thermal kT = 5.8e-23 J ≈ 0.36 meV (UHV thermal floor)
//
// Run: hexa run verify/numerics_tabletop_relativistic.hexa
// Sentinel: __HEXA_ANTIMATTER_NUMERICS_TABLETOP_RELATIVISTIC__ PASS

use "self/runtime/math_pure"

let HOME = env("HOME")

let mut RUN = 0
let mut FAIL = 0

fn _int_str(x: int) -> str { return "" + x }
fn _flt_str(x: float) -> str { return "" + x }

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("  [FAIL] " + label)
    }
    if detail.len() > 0 { println("         · " + detail) }
}

fn _approx_rel(a: float, b: float, rel_tol: float) -> bool {
    let aa = abs_pure(a)
    let ab = abs_pure(b)
    let denom = if aa > ab { aa } else { ab }
    if denom == 0.0 { return abs_pure(a - b) <= rel_tol }
    return abs_pure(a - b) / denom <= rel_tol
}

// ── n=6 + physics constants ─────────────────────────────────────────────
let SIGMA = 12.0
let TAU   = 4.0
let PHI   = 2.0

let M_P_KG       = 1.6726219e-27       // proton (= antiproton) rest mass
let Q_E_C        = 1.602176634e-19     // elementary charge
let C_LIGHT      = 2.998e8
let HBAR         = 1.054571817e-34
let K_B          = 1.380649e-23        // Boltzmann
let B_TRAP_T     = SIGMA * TAU         // 48 T (n=6 anchored)
let T_TRAP_K     = 4.2                 // LHe operating temp

let TWO_PI = 2.0 * 3.14159265358979
let PI = 3.14159265358979

let FALSIFIERS = [
    "F-AM-2 Stage-1: ω_c = qB/m ≠ 4.59e9 rad/s ± 1% → cyclotron freq retract",
    "F-AM-2 Stage-1: f_c ≠ 731 MHz ± 1% in 48 T → trap design retract",
    "F-AM-2 Stage-1: γ at v=0.001c < 1 + 1e-7 unsatisfied → relativistic floor wrong",
    "F-AM-2 Stage-1: 4.2 K thermal kT ≠ 5.8e-23 J ± 1% → cryostat floor retract",
    "F-AM-2 Stage-1: Penning ω_- = ω_z²/(2ω_+) algebra fails → trap mode retract",
    "F-AM-2 Stage-1: m/Δm < 10⁶ at 10⁻⁹ ω_c precision → mass spec retract",
    "F-AM-2 Stage-1: σ·τ = 48 T anchor fails in float → n=6 lattice retract",
    "math_pure floor: log/exp drift > 1e-9 → math_pure compromised",
]

// ── (1) cyclotron frequency ω_c = qB/m ──────────────────────────────────

fn check_cyclotron_freq_omega() {
    let omega_c = (Q_E_C * B_TRAP_T) / M_P_KG
    _check(_approx_rel(omega_c, 4.5963e9, 0.01),
           "ω_c = qB/m ≈ 4.5963×10⁹ rad/s  (p̄ in 48 T)",
           "ω_c = " + _flt_str(omega_c))
}

// ── (2) f_c = ω_c / 2π ≈ 731 MHz ────────────────────────────────────────

fn check_cyclotron_freq_hz() {
    let omega_c = (Q_E_C * B_TRAP_T) / M_P_KG
    let f_c = omega_c / TWO_PI
    _check(_approx_rel(f_c, 731.4e6, 0.01),
           "f_c = ω_c / 2π ≈ 731 MHz  (in 48 T)",
           "f_c = " + _flt_str(f_c) + " Hz")
}

// ── (3) γ correction at v = 0.001 c (typical trapped p̄) ────────────────
//
// γ = 1/sqrt(1-β²).  At β=0.001, γ-1 ≈ β²/2 = 5e-7. Negligible for
// trap dynamics but anchored as Stage-1 sanity for relativistic floor.

fn check_gamma_relativistic_floor() {
    let beta = 0.001
    let gamma = 1.0 / sqrt_pure(1.0 - beta * beta)
    let gamma_minus_1 = gamma - 1.0
    _check(_approx_rel(gamma_minus_1, 5.0e-7, 0.001),
           "γ - 1 ≈ β²/2 = 5×10⁻⁷ at β=0.001  (relativistic floor)",
           "γ-1 = " + _flt_str(gamma_minus_1))
    _check(gamma > 1.0 && gamma < 1.001,
           "γ ∈ (1, 1.001) at trap-thermal velocities", "")
}

// ── (4) Thermal kT at 4.2 K = 5.8e-23 J ─────────────────────────────────

fn check_thermal_kT() {
    let kT = K_B * T_TRAP_K
    _check(_approx_rel(kT, 5.799e-23, 0.01),
           "kT @ 4.2 K = 5.8×10⁻²³ J ≈ 0.36 meV  (UHV thermal floor)",
           "kT = " + _flt_str(kT) + " J")
    let kT_meV = kT / Q_E_C * 1.0e3
    _check(_approx_rel(kT_meV, 0.362, 0.01),
           "kT ≈ 0.362 meV", "")
}

// ── (5) Penning trap mode hierarchy ω_+ > ω_z > ω_- ────────────────────

fn check_penning_modes() {
    // Modified cyclotron ω_+ ≈ ω_c (large B limit)
    let omega_c = (Q_E_C * B_TRAP_T) / M_P_KG
    // Axial ω_z depends on trap geometry; assume ω_z = ω_c / 1000 (typical)
    let omega_z = omega_c / 1000.0
    // Magnetron ω_- = ω_z² / (2 ω_+), small (large B limit)
    let omega_minus = (omega_z * omega_z) / (2.0 * omega_c)
    _check(omega_c > omega_z && omega_z > omega_minus,
           "ω_+ > ω_z > ω_-  (Penning mode hierarchy)",
           "ω_+=" + _flt_str(omega_c) +
           " ω_z=" + _flt_str(omega_z) +
           " ω_-=" + _flt_str(omega_minus))
    // ω_+ + ω_- = ω_c (sum rule, large B)
    let sum_check = omega_c + omega_minus
    _check(_approx_rel(sum_check, omega_c, 0.001),
           "ω_+ + ω_- ≈ ω_c  (Brown-Gabrielse sum rule, large B)", "")
}

// ── (6) m/Δm mass resolution at 10⁻⁹ ω_c precision ──────────────────────

fn check_mass_resolution() {
    // m/Δm = ω_c / Δω_c.  Target precision 10⁻¹⁰ (BASE-class).
    let precision = 1.0e-10
    let m_over_dm = 1.0 / precision
    _check(m_over_dm >= 1.0e9,
           "m/Δm ≥ 10⁹  (BASE-grade Penning trap precision)",
           "m/Δm = " + _flt_str(m_over_dm))
}

// ── (7) σ·τ = 48 T anchor in float ──────────────────────────────────────

fn check_n6_anchor() {
    _check(_approx_rel(B_TRAP_T, 48.0, 1.0e-12),
           "B_trap = σ·τ = 48 T  (n=6 anchor in float, float-exact)", "")
}

// ── (8) Larmor radius r_L = m·v_perp / (qB) ─────────────────────────────
//
// At v_perp = √(2 kT/m) thermal: r_L = √(2 m kT) / (qB).
// At 4.2 K: r_L ≈ √(2·1.673e-27·5.8e-23)/(1.6e-19·48) ≈ 1.7e-9 m = 1.7 nm.
// Tight orbits — confinement excellent.

fn check_larmor_radius() {
    let v_thermal = sqrt_pure(2.0 * K_B * T_TRAP_K / M_P_KG)
    let r_L = M_P_KG * v_thermal / (Q_E_C * B_TRAP_T)
    _check(r_L > 1.0e-10 && r_L < 1.0e-7,
           "thermal Larmor radius ∈ [10⁻¹⁰, 10⁻⁷] m at 4.2 K, 48 T",
           "r_L = " + _flt_str(r_L) + " m")
}

// ── (9) σ³ × 10⁹ production cascade rate ────────────────────────────────

fn check_production_cascade() {
    let s3 = pow_pure(SIGMA, 3.0)
    let R = s3 * 1.0e9
    _check(_approx_rel(R, 1.728e12, 0.001),
           "σ³·10⁹ = 1.728e12 p̄/s  (tabletop terminal goal, anchored)", "")
}

// ── (10) math_pure floor ────────────────────────────────────────────────

fn check_math_pure_floor() {
    let s = sqrt_pure(2.0)
    _check(_approx_rel(s, 1.41421356, 0.0001),
           "sqrt_pure(2) ≈ 1.414", "")
    let l = log_pure(10.0)
    _check(_approx_rel(l, 2.302585, 0.0001),
           "log_pure(10) ≈ 2.303", "")
}

fn print_header() {
    let omega_c = (Q_E_C * B_TRAP_T) / M_P_KG
    println("")
    println("  Stage-1 simulation parity — relativistic Penning trap")
    println("    B      = " + _flt_str(B_TRAP_T) + " T  (= σ·τ)")
    println("    T      = " + _flt_str(T_TRAP_K) + " K  (LHe)")
    println("    ω_c    = " + _flt_str(omega_c) + " rad/s")
    println("    f_c    = " + _flt_str(omega_c / TWO_PI) + " Hz")
    println("    kT     = " + _flt_str(K_B * T_TRAP_K) + " J")
    println("")
}

fn main() {
    println("========================================================================")
    println("  hexa-antimatter — numerics_tabletop_relativistic: Phase B Stage-1")
    println("========================================================================")
    println("  closes:  F-AM-2 T2 stack ×4 (extends sat-1 with realistic-trap parity)")
    println("  method:  Penning ω_+/ω_-/ω_z + relativistic γ + thermal/Larmor floor")
    println("  authority: tabletop/doc/benchtop_v0_design.md §6 anchors")
    print_header()

    println("  -- (1) ω_c = qB/m ≈ 4.6e9 rad/s --")
    check_cyclotron_freq_omega()

    println("")
    println("  -- (2) f_c ≈ 731 MHz in 48 T --")
    check_cyclotron_freq_hz()

    println("")
    println("  -- (3) γ - 1 ≈ β²/2 at thermal velocities --")
    check_gamma_relativistic_floor()

    println("")
    println("  -- (4) thermal kT @ 4.2 K --")
    check_thermal_kT()

    println("")
    println("  -- (5) Penning mode hierarchy + sum rule --")
    check_penning_modes()

    println("")
    println("  -- (6) mass resolution m/Δm ≥ 10⁹ --")
    check_mass_resolution()

    println("")
    println("  -- (7) σ·τ = 48 T anchor --")
    check_n6_anchor()

    println("")
    println("  -- (8) thermal Larmor radius --")
    check_larmor_radius()

    println("")
    println("  -- (9) σ³·10⁹ production cascade --")
    check_production_cascade()

    println("")
    println("  -- (10) math_pure floor (sqrt/log) --")
    check_math_pure_floor()

    println("")
    println("  FALSIFIERS (" + _int_str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + _int_str(pass_n) + "/" + _int_str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP_RELATIVISTIC__ FAIL")
        exit(1)
    }
    println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP_RELATIVISTIC__ PASS")
    exit(0)
}
