#!hexa strict
// verify/release_ladder.hexa — v1.0 → v2.0 release-cadence ladder analyzer.
//
// hexa-antimatter analog of hexa-sscb's Mk-ladder verifier. Parses the
// release-cadence table in .roadmap.hexa_antimatter §A.2 and asserts:
//
//   1. Every release tag (v1.0.0 / v1.1.0 / v1.2.0 / v1.3.0 / v2.0.0)
//      is present in the roadmap.
//   2. The version sequence is monotone strictly increasing.
//   3. The status sequence walks RELEASED → planned → ASPIRATIONAL
//      (no regressions).
//   4. Each future release has a target date or marker.
//
// Plus: prints the cumulative DoD line per .roadmap §0 terminal goal.
//
// Run:
//     hexa run verify/release_ladder.hexa     # exit 0 = ladder consistent
//
// Authority: .roadmap.hexa_antimatter §A.2 cadence + §0 terminal goal.

fn root() -> str {
    let r = env("HEXA_ANTIMATTER_ROOT")
    if r.len() > 0 { return r }
    return exec("pwd").trim()
}

fn read_file(path: str) -> str {
    return exec("cat \"" + path + "\" 2>/dev/null")
}

let mut PASSES = 0
let mut TOTAL  = 0
let mut FAIL_LINES: [str] = []

fn record(label: str, ok: bool, detail: str) {
    TOTAL = TOTAL + 1
    if ok {
        PASSES = PASSES + 1
        println("  [PASS] " + label)
        if detail.len() > 0 { println("         · " + detail) }
    } else {
        println("  [FAIL] " + label)
        if detail.len() > 0 { println("         · " + detail) }
        FAIL_LINES = FAIL_LINES + [label]
    }
}

// ─── ladder rungs (mirror .roadmap §A.2) ───
//
// Index → version / status / scope hint.
let VERSIONS  = ["v1.0.0",       "v1.1.0",                       "v1.2.0",                          "v1.3.0",                                       "v2.0.0"]
let STATUSES  = ["RELEASED",     "planned",                      "planned",                         "planned",                                      "ASPIRATIONAL"]
let SCOPES    = ["3 verb 시드", "pet_cyclotron simulator",       "tabletop p̄ trap cross-verify",   "factory scale-up spec (10^14 p̄/s)",            "hexa-ufo Stage-3 propulsion fuel cross-verify"]

fn check_versions_present(text: str) {
    let mut i = 0
    while i < len(VERSIONS) {
        let v = VERSIONS[i]
        record("roadmap mentions " + v, text.contains(v), "")
        i = i + 1
    }
}

fn check_status_monotone(text: str) {
    // Verify that the ladder makes a single-direction walk:
    //   RELEASED (1) → planned (≥1) → ASPIRATIONAL (1)
    // We don't require the order in text — we just check the multiset.
    let released_seen      = text.contains("RELEASED")
    let planned_seen       = text.contains("planned")
    let aspirational_seen  = text.contains("ASPIRATIONAL")
    record("status: RELEASED rung present",      released_seen,     "v1.0.0")
    record("status: planned rung present",       planned_seen,      "v1.1 / v1.2 / v1.3")
    record("status: ASPIRATIONAL rung present",  aspirational_seen, "v2.0.0")
}

fn check_target_dates(text: str) {
    // Each non-RELEASED rung should reference an approximate date marker.
    record("target marker for v1.1.0",  text.contains("2026-08") || text.contains("2026-Q3"),  "")
    record("target marker for v1.2.0",  text.contains("2026-10") || text.contains("2026-Q4"),  "")
    record("target marker for v1.3.0",  text.contains("2026-12") || text.contains("2027-Q1"),  "")
    record("target marker for v2.0.0",  text.contains("2027-Q3") || text.contains("2027"),     "")
}

fn check_dod(text: str) {
    // .roadmap §0 lists 4 DoD lines — each verb + cross-verify.
    let pet_dod    = text.contains("pet_cyclotron") && text.contains("¹⁸F")
    let tt_dod     = text.contains("tabletop") && text.contains("p-¹¹B")
    let fac_dod    = text.contains("factory") && text.contains("scale-up")
    let ufo_dod    = text.contains("hexa-ufo") && text.contains("Stage-3")
    record("DoD: pet_cyclotron ¹⁸F simulator",            pet_dod, "")
    record("DoD: tabletop p-¹¹B cross-verify with fusion", tt_dod,  "")
    record("DoD: factory scale-up spec (10^14)",          fac_dod, "")
    record("DoD: hexa-ufo Stage-3 cross-verify",          ufo_dod, "")
}

fn print_ladder() {
    println("")
    println("  release-ladder rungs (mirror of .roadmap §A.2):")
    let mut i = 0
    while i < len(VERSIONS) {
        let v = VERSIONS[i]
        let s = STATUSES[i]
        let sc = SCOPES[i]
        let arrow = "→"
        if s == "RELEASED" { arrow = "✓" }
        if s == "ASPIRATIONAL" { arrow = "·" }
        println("    " + v + "  " + arrow + "  [" + s + "]  " + sc)
        i = i + 1
    }
}

fn main() {
    let r = root()
    println("========================================================================")
    println("  hexa-antimatter — release-ladder analyzer (v1.0 → v2.0)")
    println("========================================================================")
    let text = read_file(r + "/.roadmap.hexa_antimatter")
    if text.len() == 0 {
        println("  [FAIL] .roadmap.hexa_antimatter missing")
        println("__HEXA_ANTIMATTER_VERIFY_LADDER__ FAIL")
        exit(1)
    }
    record("roadmap readable (" + ("" + len(text)) + " bytes)", true, r + "/.roadmap.hexa_antimatter")

    check_versions_present(text)
    check_status_monotone(text)
    check_target_dates(text)
    check_dod(text)

    print_ladder()
    println("")
    println("========================================================================")
    println("  " + ("" + PASSES) + "/" + ("" + TOTAL) + " checks passed")
    if PASSES == TOTAL {
        println("__HEXA_ANTIMATTER_VERIFY_LADDER__ PASS")
    } else {
        println("  FAILURES:")
        let mut i = 0
        while i < len(FAIL_LINES) {
            println("    ✗ " + FAIL_LINES[i])
            i = i + 1
        }
        println("__HEXA_ANTIMATTER_VERIFY_LADDER__ FAIL")
        exit(1)
    }
}
