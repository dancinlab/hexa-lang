#!hexa strict
// hexa-antimatter/verify/numerics_tabletop.hexa вЂ” tabletop-pillar numerical
// re-derivation via math_pure.
//
// T2 (numerical) closure for F-AM-2 (tabletop pМ„ density ПѓВ·Jв‚‚=288 fit
// vs CERN AEgIS / ALPHA / GBAR ref).  Companion to verify/calc_tabletop.hexa.
// Where the calc_ file proved every identity in integer divisor arithmetic,
// this file re-derives the same numbers through math_pure (sqrt/exp/log/pow)
// AND closes a handful of float-only chains the calc_ file could not touch:
//
//   В· ПѓВ·Jв‚‚ = 288  (BT-401 closure unit, F-AM-2 anchor)
//   В· ПѓВі Г— 10вЃ№ в‰€ 1.7Г—10В№ВІ pМ„/s  (terminal-goal production candidate)
//   В· ПѓвЃ¶ = 2,985,984  (1/ПѓвЃ¶ cost-reduction chain)
//   В· ПѓВ·П„ВІ = 192 months = 16 yr   (192/12 = 16 exact)
//   В· О“_loss = 10вЃ»Ві / (ПѓВІВ·П„) в‰€ 1.736Г—10вЃ»вЃ¶ /s   (trap leakage rate)
//   В· Volume V_TT = V_0 В· (Пѓ-П†) / (ПѓВІ В· ПѓВ·П„) в‰€ 0.289 mВі
//                = 200 Г— 10 / (144 Г— 48) mВі  (V_0 = 200 mВі CERN AD/ELENA)
//   В· compact-ring p = 0.3В·BВ·R = 1.44 GeV/c   (float, path-b)
//   В· cost = $_factory / ПѓвЃ¶ в‰€ $2.094Г—10вЃґ /mg   (в‰€ $2.1e4/mg SSOT spec)
//   В· ПѓвЃ¶ = ПѓВі В· ПѓВі   (factory Г— PET cost-split closure)
//   В· log-log scaling ПѓвЃ¶ vs Пѓ в†’ slope 6.0 (math_pure power-law floor)
//
// Plus the standard math_pure floor (sqrt/exp/log/pow self-inverse).
//
// Run:
//     hexa run verify/numerics_tabletop.hexa     # exit 0 = identity holds
//
// Sentinel: __HEXA_ANTIMATTER_NUMERICS_TABLETOP__ PASS
//
// Authority: tabletop/tabletop-antimatter.md В§1 WHY + В§4 STRUCT + В§5 FLOW В·
//   .roadmap.hexa_antimatter В§A.4 F-AM-2 + В§0 terminal-goal 1.7e12 pМ„/s.
// hexa-only В· honest C3: closed-form numerical agreement only вЂ”
//   parity vs published CERN data lives in numerics_tabletop_parity.hexa
//   (next chunk), empirical Stage-1+ TBD.

use "self/runtime/math_pure"

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_ANTIMATTER_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-antimatter"
}

let ROOT = _root()

fn _int_str(x: int) -> str { return "" + x }

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("  [FAIL] " + label)
    }
    if detail.len() > 0 { println("         В· " + detail) }
}

fn _approx_eq(a: float, b: float, tol: float) -> bool {
    let diff = a - b
    let abs_d = abs_pure(diff)
    return abs_d <= tol
}

fn _approx_rel(a: float, b: float, rel_tol: float) -> bool {
    // Relative tolerance: |a - b| / max(|a|, |b|) <= rel_tol.
    let aa = abs_pure(a)
    let ab = abs_pure(b)
    let denom = if aa > ab { aa } else { ab }
    if denom == 0.0 { return abs_pure(a - b) <= rel_tol }
    let rel = abs_pure(a - b) / denom
    return rel <= rel_tol
}

// в”Ђв”Ђ n=6 lattice (float-domain copy) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let SIGMA_F = 12.0
let TAU_F   = 4.0
let PHI_F   = 2.0
let N_F     = 6.0
let J2_F    = 24.0
let TOL     = 0.000000001       // 1e-9 absolute
let REL_TOL = 0.001              // 1e-3 relative вЂ” enough to absorb SSOT
                                 // round-off (e.g. 1.728e12 vs cited 1.7e12).

let FALSIFIERS = [
    "F-AM-2 T2: pow_pure ПѓВ·Jв‚‚ в‰  288 в†’ BT-401 density-unit closure broken",
    "F-AM-2 T2: ПѓВі Г— 1e9 в‰  1.7e12 В± 2% в†’ terminal-goal production retract",
    "F-AM-2 T2: pow_pure ПѓвЃ¶ в‰  2,985,984 в†’ 1/ПѓвЃ¶ cost chain retract",
    "F-AM-2 T2: ПѓВ·П„ВІ в‰  192 mo OR 192/12 в‰  16 yr в†’ storage horizon retract",
    "F-AM-2 T2: О“_loss = 1/(ПѓВІВ·П„) Г— 1e-3 в‰  1.7e-6 В± 5% в†’ trap leakage retract",
    "F-AM-2 T2: V_TT = 200В·(Пѓ-П†)/(ПѓВІВ·ПѓВ·П„) в‰  0.289 mВі В± 5% в†’ tabletop volume retract",
    "F-AM-2 T2: ПѓвЃ¶ в‰  ПѓВіВ·ПѓВі в†’ factory Г— PET cost-split closure breaks",
    "tabletop T2: compact ring p = 0.3В·BВ·R в‰  1.44 GeV/c В± 1e-9 в†’ path-b retract",
    "tabletop T2: $_factory/ПѓвЃ¶ в‰  $2.1e4/mg В± 1% в†’ cost-reduction final $/mg retract",
    "tabletop T2: log-log ПѓвЃ¶ vs Пѓ slope в‰  6.0 В± 0.05 в†’ math_pure power-law floor lost",
    "math_pure floor: sqrt(144) в‰  12 В± 1e-9 OR pow(2,10) в‰  1024 в†’ stability breach",
]

// в”Ђв”Ђ F-AM-2 anchor: ПѓВ·Jв‚‚ = 288 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_f_am_2_anchor() {
    let v = SIGMA_F * J2_F
    _check(_approx_eq(v, 288.0, TOL),
           "ПѓВ·Jв‚‚ = 288  (F-AM-2 BT-401 density-unit closure)",
           "ПѓВ·Jв‚‚ = " + ("" + v))
}

// в”Ђв”Ђ ПѓВі Г— 10вЃ№ = production candidate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_production_cascade() {
    let s3 = pow_pure(SIGMA_F, 3.0)
    _check(_approx_eq(s3, 1728.0, TOL),
           "pow_pure(Пѓ, 3) = ПѓВі = 1728  (production cascade base)", "")

    // ПѓВі Г— 10вЃ№ = 1.728 Г— 10В№ВІ.  SSOT cites 1.7Г—10В№ВІ (one-sig-fig round).
    // Use relative tolerance of 2% to absorb the SSOT round.
    let prod_per_s = s3 * 1000000000.0   // 1.728e12
    _check(_approx_rel(prod_per_s, 1700000000000.0, 0.02),
           "ПѓВі Г— 10вЃ№ в‰€ 1.7Г—10В№ВІ pМ„/s  (.roadmap В§0 terminal goal, В±2%)",
           "ПѓВіВ·10вЃ№ = " + ("" + prod_per_s) + " В· cited = 1.7e12")
}

// в”Ђв”Ђ ПѓвЃ¶ cost-reduction chain в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_sigma_sixth_chain() {
    let s3 = pow_pure(SIGMA_F, 3.0)
    let s6 = pow_pure(SIGMA_F, 6.0)
    _check(_approx_eq(s6, 2985984.0, TOL),
           "pow_pure(Пѓ, 6) = ПѓвЃ¶ = 2,985,984", "")
    _check(_approx_eq(s6, s3 * s3, TOL),
           "ПѓвЃ¶ = ПѓВі В· ПѓВі  (factory Г— PET cost-split closure)",
           "s6 = " + ("" + s6) + " В· s3ВІ = " + ("" + (s3 * s3)))

    // log-log slope of [ПѓВ№..ПѓвЃ¶] vs Пѓ should equal 6.0 by definition;
    // single-pair log ratio: log(ПѓвЃ¶) / log(Пѓ) = 6.
    let r = log_pure(s6) / log_pure(SIGMA_F)
    _check(_approx_eq(r, 6.0, 0.0001),
           "log(ПѓвЃ¶) / log(Пѓ) = 6.0  (math_pure power-law floor)",
           "ratio = " + ("" + r))
}

// в”Ђв”Ђ ПѓВ·П„ВІ = 192 months = 16 yr в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_storage_horizon() {
    let st2 = SIGMA_F * TAU_F * TAU_F
    _check(_approx_eq(st2, 192.0, TOL),
           "ПѓВ·П„ВІ = 192 months  (cryo-free storage horizon)", "")

    let yrs = st2 / 12.0
    _check(_approx_eq(yrs, 16.0, TOL),
           "192 months / 12 = 16 yr  (HEXA-TABLETOP storage candidate)", "")
}

// в”Ђв”Ђ О“_loss trap leakage rate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_gamma_loss() {
    // SSOT В§5: О“_loss = 10вЃ»Ві / (ПѓВІВ·П„) /s  в†’  1/(144В·4) Г— 10вЃ»Ві = 1/576 Г— 10вЃ»Ві
    //                                       = 1.7361Г—10вЃ»вЃ¶ /s
    let g = (1.0 / (SIGMA_F * SIGMA_F * TAU_F)) * 0.001
    _check(_approx_rel(g, 0.0000017361, 0.001),
           "О“_loss = 1/(ПѓВІВ·П„) Г— 10вЃ»Ві в‰€ 1.7361Г—10вЃ»вЃ¶ /s",
           "О“_loss = " + ("" + g))
    // SSOT cites 1.7Г—10вЃ»вЃ¶ вЂ” agree within 5% relative.
    _check(_approx_rel(g, 0.0000017, 0.05),
           "О“_loss matches SSOT '1.7Г—10вЃ»вЃ¶ /s' within 5%", "")
}

// в”Ђв”Ђ Volume formula V_TT = 200В·(Пѓ-П†)/(ПѓВІВ·ПѓВ·П„) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_volume_formula() {
    // V_TT = V_0 Г— (Пѓ-П†)/ПѓВІ Г— 1/(ПѓВ·П„)
    //      = 200 Г— 10/144 Г— 1/48
    //      = 2000 / 6912
    //      = 0.28935..
    let V0  = 200.0
    let sp  = SIGMA_F - PHI_F            // 10
    let s2  = SIGMA_F * SIGMA_F           // 144
    let st  = SIGMA_F * TAU_F             // 48
    let V_TT = V0 * (sp / s2) * (1.0 / st)
    _check(_approx_rel(V_TT, 0.2894, 0.001),
           "V_TT = 200В·(Пѓ-П†)/(ПѓВІВ·ПѓВ·П„) в‰€ 0.2894 mВі  (closed-form derivation)",
           "V_TT = " + ("" + V_TT))
    _check(_approx_rel(V_TT, 0.29, 0.05),
           "V_TT matches SSOT '0.29 mВі' within 5%", "")
}

// в”Ђв”Ђ compact-ring momentum p = 0.3В·BВ·R в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_compact_ring_momentum_float() {
    // p[GeV/c] = 0.3 В· B[T] В· R[m]
    let B = SIGMA_F * TAU_F                // 48 T
    let R_m = (SIGMA_F - PHI_F) / 100.0    // 10 cm = 0.1 m
    let p = 0.3 * B * R_m                   // 0.3 В· 48 В· 0.1 = 1.44
    _check(_approx_eq(p, 1.44, TOL),
           "compact-ring p = 0.3В·BВ·R = 1.44 GeV/c  (path-b float)", "")
}

// в”Ђв”Ђ tabletop cost reduction в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_cost_reduction() {
    // Factory cost candidate: $6.25 Г— 10В№вЃ° /mg.  Tabletop = factory / ПѓвЃ¶.
    let factory_per_mg = 62500000000.0       // 6.25e10
    let s6 = pow_pure(SIGMA_F, 6.0)
    let tabletop_per_mg = factory_per_mg / s6
    // Expected в‰€ 6.25e10 / 2.985984e6 = 2.0928e4
    _check(_approx_rel(tabletop_per_mg, 20928.0, 0.001),
           "tabletop cost = $_factory/ПѓвЃ¶ в‰€ $2.093Г—10вЃґ/mg",
           "tabletop = $" + ("" + tabletop_per_mg) + "/mg")
    // SSOT cites $2.1Г—10вЃґ/mg вЂ” agree within 1% relative.
    _check(_approx_rel(tabletop_per_mg, 21000.0, 0.01),
           "cost matches SSOT '$2.1Г—10вЃґ/mg' within 1%", "")
}

// в”Ђв”Ђ math_pure stability floor в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn check_math_pure_floor() {
    let r12 = sqrt_pure(144.0)
    _check(_approx_eq(r12, 12.0, TOL),
           "sqrt_pure(144) = 12 В± 1e-9", "got " + ("" + r12))
    let p = pow_pure(2.0, 10.0)
    _check(_approx_eq(p, 1024.0, TOL),
           "pow_pure(2, 10) = 1024  (binary canonical)", "")
    let log_e = log_pure(e_pure())
    _check(_approx_eq(log_e, 1.0, TOL),
           "log_pure(e) = 1  (self-inverse)", "")
}

fn main() {
    println("========================================================================")
    println("  hexa-antimatter вЂ” numerics_tabletop: tabletop-pillar T2 numerics")
    println("========================================================================")
    println("  closes:  F-AM-2 (tabletop ПѓВ·Jв‚‚=288 fit) T2 вЂ” first numerical closure")
    println("  path:    math_pure (sqrt/exp/log/pow) + closed-form chains")
    println("  abs tol: " + ("" + TOL) + "  В· rel tol: " + ("" + REL_TOL))
    println("")

    println("  -- F-AM-2 anchor (ПѓВ·Jв‚‚ = 288) --")
    check_f_am_2_anchor()

    println("")
    println("  -- production cascade (ПѓВі Г— 10вЃ№ в‰€ 1.7Г—10В№ВІ pМ„/s) --")
    check_production_cascade()

    println("")
    println("  -- ПѓвЃ¶ cost-reduction chain --")
    check_sigma_sixth_chain()

    println("")
    println("  -- storage horizon (ПѓВ·П„ВІ = 192 mo = 16 yr) --")
    check_storage_horizon()

    println("")
    println("  -- trap leakage rate (О“_loss) --")
    check_gamma_loss()

    println("")
    println("  -- volume formula (0.289 mВі) --")
    check_volume_formula()

    println("")
    println("  -- compact-ring momentum (path-b 1.44 GeV/c) --")
    check_compact_ring_momentum_float()

    println("")
    println("  -- cost reduction ($2.1e4/mg) --")
    check_cost_reduction()

    println("")
    println("  -- math_pure stability floor --")
    check_math_pure_floor()

    println("")
    println("  FALSIFIERS (" + _int_str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    вњ— " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + _int_str(pass_n) + "/" + _int_str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP__ FAIL")
        exit(1)
    }
    println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP__ PASS")
    exit(0)
}
