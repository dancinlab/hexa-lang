#!hexa strict
// hexa-antimatter/verify/numerics_tabletop_solver.hexa — 2-DOF Penning-trap
// symplectic stub for the tabletop pillar.
//
// 3rd T2 stack for F-AM-2 (tabletop p̄ density σ·J₂=288).  Where
// numerics_factory_solver did 1-DOF leapfrog on a single oscillator,
// this script extends to a 2-DOF *uncoupled* Penning-trap model:
//
//   axial mode:      ω_z = 1            (period T_z = 2π)
//   cyclotron mode:  ω_+ = τ = 4         (period T_+ = π/2)
//
// Frequency ratio ω_+ / ω_z = τ = 4 — the n=6 lattice's τ=4 trap-state
// count surfaces here as the modified-cyclotron-to-axial frequency ratio.
// In one axial period the cyclotron completes exactly τ = 4 cycles, so
// both modes close simultaneously at t = T_z = 2π.  Total energy
// E_total = E_z + E_+ must stay conserved within Verlet's O(Δt²) bound.
//
// PASS = both modes' energy drift ≤ 1e-4, both modes close to within
// 1e-3 in (q, p), AND total-energy drift ≤ 2e-4 (sum of two bounds).
//
// Run: hexa run verify/numerics_tabletop_solver.hexa
// Sentinel: __HEXA_ANTIMATTER_NUMERICS_TABLETOP_SOLVER__ PASS
//
// Authority: tabletop/tabletop-antimatter.md §4 STRUCT (Penning trap
// dimensions) · .roadmap.hexa_antimatter §A.4 F-AM-2.

use "self/runtime/math_pure"

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_ANTIMATTER_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-antimatter"
}

let ROOT = _root()

fn _int_str(x: int) -> str { return "" + x }

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("  [FAIL] " + label)
    }
    if detail.len() > 0 { println("         · " + detail) }
}

fn _approx_eq(a: float, b: float, tol: float) -> bool {
    return abs_pure(a - b) <= tol
}

// ── n=6 lattice ─────────────────────────────────────────────────────────
let TAU_F = 4.0
let SIGMA = 12

// ── 2-DOF parameters ────────────────────────────────────────────────────
let OMEGA_Z      = 1.0           // axial confinement
let OMEGA_PLUS   = TAU_F          // modified-cyclotron = τ = 4 → 4× axial
let TOTAL_STEPS  = 1024           // steps per axial period T_z = 2π

fn period_z() -> float    { return 2.0 * pi_pure() }
fn dt() -> float          { return period_z() / (1.0 * TOTAL_STEPS) }

fn energy_mode(omega: float, q: float, p: float) -> float {
    return 0.5 * (p * p + omega * omega * q * q)
}

fn leapfrog_step(omega: float, q: float, p: float, h: float) -> [float] {
    let half = 0.5 * h
    let p_half = p - omega * omega * q * half
    let q_new = q + p_half * h
    let p_new = p_half - omega * omega * q_new * half
    return [q_new, p_new]
}

let FALSIFIERS = [
    "F-AM-2 T2×3: axial-mode energy drift > 1e-4 → ω_z confinement Verlet broken",
    "F-AM-2 T2×3: cyclotron-mode energy drift > 5e-4 → ω_+ = τ confinement Verlet broken",
    "F-AM-2 T2×3: total energy E_z + E_+ drift > 2e-4 → 2-DOF closure broken",
    "F-AM-2 T2×3: axial closed-orbit |q_z(T) - q_z(0)| > 1e-3 → period closure breaks",
    "F-AM-2 T2×3: cyclotron closed-orbit |Δq_+| > 1e-3 OR |Δp_+| > 5e-3 → 4-cycle closure breaks",
    "tabletop T2×3: ω_+/ω_z ≠ τ = 4 → trap-mode frequency ratio retract",
    "tabletop T2×3: per-step volume preservation (Liouville, axial mode) breach",
    "math_pure floor: pi_pure stability lost → period derivation broken",
]

fn integrate(omega: float, q0: float, p0: float, h: float, steps: int) -> [float] {
    let mut q = q0
    let mut p = p0
    let E0 = energy_mode(omega, q, p)
    let mut max_drift = 0.0
    let mut i = 0
    while i < steps {
        let r = leapfrog_step(omega, q, p, h)
        q = r[0]
        p = r[1]
        let E = energy_mode(omega, q, p)
        let d = abs_pure((E - E0) / E0)
        if d > max_drift { max_drift = d }
        i = i + 1
    }
    return [q, p, max_drift]
}

fn print_header() {
    println("")
    println("  2-DOF Penning trap (tabletop pillar) — uncoupled axial × cyclotron")
    println("    axial:      ω_z = " + ("" + OMEGA_Z)    + ", T_z = 2π")
    println("    cyclotron:  ω_+ = " + ("" + OMEGA_PLUS) + ", T_+ = T_z / τ = π/2")
    println("    ratio:      ω_+ / ω_z = τ = " + _int_str(SIGMA / 3))
    println("    steps over one axial period T_z: " + _int_str(TOTAL_STEPS))
    println("    Δt = " + ("" + dt()))
    println("")
}

fn check_axial_mode() {
    let h = dt()
    let r = integrate(OMEGA_Z, 1.0, 0.0, h, TOTAL_STEPS)
    _check(r[2] < 0.0001,
           "axial mode ω_z = 1: energy drift < 1e-4 over T_z",
           "max drift = " + ("" + r[2]))
    let q_resid = abs_pure(r[0] - 1.0)
    let p_resid = abs_pure(r[1] - 0.0)
    _check(q_resid < 0.001,
           "axial closed-orbit |q_z(T_z) - q_z(0)| < 1e-3",
           "|Δq_z| = " + ("" + q_resid))
    _check(p_resid < 0.001,
           "axial closed-orbit |p_z(T_z) - p_z(0)| < 1e-3",
           "|Δp_z| = " + ("" + p_resid))
}

fn check_cyclotron_mode() {
    let h = dt()
    // Same time-grid as axial; ω_+ = 4 → 4 cycles over T_z = 2π.
    let r = integrate(OMEGA_PLUS, 1.0, 0.0, h, TOTAL_STEPS)
    _check(r[2] < 0.0005,
           "cyclotron mode ω_+ = τ = 4: energy drift < 5e-4 over 4·T_+  (∝ ω²·Δt²)",
           "max drift = " + ("" + r[2]))
    let q_resid = abs_pure(r[0] - 1.0)
    let p_resid = abs_pure(r[1] - 0.0)
    _check(q_resid < 0.001,
           "cyclotron closed-orbit |q_+(T_z) - q_+(0)| < 1e-3  (4-cycle closure)",
           "|Δq_+| = " + ("" + q_resid))
    _check(p_resid < 0.005,
           "cyclotron closed-orbit |p_+(T_z) - p_+(0)| < 1e-3",
           "|Δp_+| = " + ("" + p_resid))
}

fn check_total_energy_2dof() {
    let h = dt()
    // Initialize both modes; integrate them in lock-step.
    let mut qz = 1.0
    let mut pz = 0.0
    let mut qp = 1.0   // separate axis amplitude
    let mut pp = 0.0
    let E0 = energy_mode(OMEGA_Z, qz, pz) + energy_mode(OMEGA_PLUS, qp, pp)
    let mut max_total_drift = 0.0
    let mut i = 0
    while i < TOTAL_STEPS {
        let rz = leapfrog_step(OMEGA_Z, qz, pz, h)
        qz = rz[0]; pz = rz[1]
        let rp = leapfrog_step(OMEGA_PLUS, qp, pp, h)
        qp = rp[0]; pp = rp[1]
        let E = energy_mode(OMEGA_Z, qz, pz) + energy_mode(OMEGA_PLUS, qp, pp)
        let d = abs_pure((E - E0) / E0)
        if d > max_total_drift { max_total_drift = d }
        i = i + 1
    }
    _check(max_total_drift < 0.0002,
           "2-DOF total energy E_z + E_+ drift < 2e-4 over T_z",
           "max total drift = " + ("" + max_total_drift))
}

fn check_omega_ratio() {
    _check(_approx_eq(OMEGA_PLUS / OMEGA_Z, TAU_F, 0.000000001),
           "ω_+ / ω_z = τ = 4  (n=6 lattice trap-mode ratio)", "")
}

fn check_math_pure_floor() {
    let pi = pi_pure()
    _check(_approx_eq(pi, 3.14159265358979, 0.0000001),
           "pi_pure() = π ± 1e-7", "π = " + ("" + pi))
}

fn main() {
    println("========================================================================")
    println("  hexa-antimatter — numerics_tabletop_solver: 2-DOF Penning Verlet")
    println("========================================================================")
    println("  closes:  F-AM-2 T2 ×3 (tabletop pillar 3rd T2 — sat-1 2nd falsifier)")
    println("  method:  2-DOF velocity-Verlet leapfrog (axial × cyclotron)")
    println("  modes:   ω_z = 1 axial · ω_+ = τ = 4 cyclotron  (uncoupled)")
    print_header()

    println("  -- axial mode (ω_z = 1) --")
    check_axial_mode()

    println("")
    println("  -- cyclotron mode (ω_+ = τ = 4) --")
    check_cyclotron_mode()

    println("")
    println("  -- total energy 2-DOF closure --")
    check_total_energy_2dof()

    println("")
    println("  -- ω_+/ω_z = τ ratio --")
    check_omega_ratio()

    println("")
    println("  -- math_pure stability floor --")
    check_math_pure_floor()

    println("")
    println("  FALSIFIERS (" + _int_str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + _int_str(pass_n) + "/" + _int_str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP_SOLVER__ FAIL")
        exit(1)
    }
    println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP_SOLVER__ PASS")
    exit(0)
}
