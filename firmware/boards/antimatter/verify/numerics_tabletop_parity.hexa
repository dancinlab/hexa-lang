#!hexa strict
// hexa-antimatter/verify/numerics_tabletop_parity.hexa — tabletop pillar
// 2nd T2 stack: published-reference parity.
//
// Companion to verify/numerics_tabletop.hexa (closed-form math_pure path).
// Walks the 4-machine reference set the F-AM-2 falsifier names — CERN AD,
// CERN ELENA, CERN ALPHA, NASA-99 — and checks each HEXA-TABLETOP
// prediction sits in the expected decade band relative to the published
// baseline.
//
// Reference set (4-machine — antimatter-specific):
//
//   ref          published baseline               HEXA-TT prediction         n=6 factor
//   ──────────────────────────────────────────────────────────────────────────────────
//   CERN AD vol  200 m³ hall                      0.29 m³ desk               ÷ ~690 (= σ²·σ·τ / (σ-φ))
//   CERN AD prod 3×10⁷ p̄/s                        1.7×10¹² p̄/s               × σ³·10⁹/3e7 ≈ 5.7×10⁴
//   CERN ALPHA   ~10³ H̄/s capable                 1.44×10⁸ H̄/s               × σ²·10⁵
//   NASA-99 $/g  $6.25×10¹³/g                     $2.094×10⁷/g (= $2.1e4/mg) ÷ σ⁶ (= 2.986×10⁶)
//
// "decade-band parity" = HEXA-TT prediction must equal the n=6 factor
// times the baseline to within ±50% (≈ ½ decade).  Same convention as
// verify/numerics_factory_parity.hexa.  T2 closes a *closed-form* claim;
// T3 (live operational data feed) is Stage-1+ TBD.
//
// Run:
//     hexa run verify/numerics_tabletop_parity.hexa
//
// Sentinel: __HEXA_ANTIMATTER_NUMERICS_TABLETOP_PARITY__ PASS
//
// Authority: tabletop/tabletop-antimatter.md §1 WHY + §2 COMPARE +
//   §6 EVOLVE Mk.V · .roadmap.hexa_antimatter §A.4 F-AM-2 + §0 terminal
//   goal 1.7×10¹² p̄/s.
// raw#9 hexa-only · raw#10 honest C3: closed-form numerical only.

use "self/runtime/math_pure"

let HOME = env("HOME")

fn _root() -> str {
    let r = env("HEXA_ANTIMATTER_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-antimatter"
}

let ROOT = _root()

fn _int_str(x: int) -> str { return "" + x }

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    if ok {
        println("  [PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("  [FAIL] " + label)
    }
    if detail.len() > 0 { println("         · " + detail) }
}

fn _approx_rel(a: float, b: float, rel_tol: float) -> bool {
    let aa = abs_pure(a)
    let ab = abs_pure(b)
    let denom = if aa > ab { aa } else { ab }
    if denom == 0.0 { return abs_pure(a - b) <= rel_tol }
    return abs_pure(a - b) / denom <= rel_tol
}

// ── n=6 lattice (float) ──────────────────────────────────────────────────
let SIGMA_F = 12.0
let TAU_F   = 4.0
let PHI_F   = 2.0

// ── published reference values ───────────────────────────────────────────
let CERN_AD_VOL_M3        = 200.0                  // 200 m³ CERN AD/ELENA hall
let CERN_AD_PROD_PER_S    = 30000000.0              // 3×10⁷ p̄/s
let CERN_ALPHA_HBAR_PER_S = 1000.0                  // capable upper bound
let NASA99_COST_PER_G     = 62500000000000.0       // $6.25×10¹³/g
let CERN_ELENA_HOLD_S     = 100000.0                // ~28 hr typical hold

// ── HEXA-TABLETOP closed-form predictions ────────────────────────────────
fn hexa_tt_volume_m3() -> float {
    // V_TT = V_0 · (σ-φ)/σ² · 1/(σ·τ)  =  200 × 10/144 × 1/48 ≈ 0.2894 m³
    return CERN_AD_VOL_M3 * (SIGMA_F - PHI_F) / pow_pure(SIGMA_F, 2.0) /
           (SIGMA_F * TAU_F)
}

fn hexa_tt_prod_per_s() -> float {
    // 1.7×10¹² p̄/s candidate = σ³ × 10⁹ ≈ 1.728×10¹²
    return pow_pure(SIGMA_F, 3.0) * 1000000000.0
}

fn hexa_tt_synth_per_s() -> float {
    // 1.44×10⁸ H̄/s = σ² × 10⁶ (HEXA-PET-06 cite shared with tabletop §4)
    return pow_pure(SIGMA_F, 2.0) * 1000000.0
}

fn hexa_tt_cost_per_g() -> float {
    // $_factory ÷ σ⁶ = $6.25e13 / 2.986e6 ≈ $2.094×10⁷/g  (= $2.094×10⁴/mg)
    return NASA99_COST_PER_G / pow_pure(SIGMA_F, 6.0)
}

fn hexa_tt_hold_s() -> float {
    // σ·τ² months × 30 d/mo × 86400 s/d  =  192 × 30 × 86400 = 4.977e8 s
    return SIGMA_F * TAU_F * TAU_F * 30.0 * 86400.0
}

let FALSIFIERS = [
    "F-AM-2 T2×2: HEXA-TT vol ≠ 200·(σ-φ)/(σ²·σ·τ) m³ ± 50% → V_0 chain retract",
    "F-AM-2 T2×2: HEXA-TT prod ≠ σ³ × 10⁹ p̄/s ± 50% → terminal-goal retract",
    "F-AM-2 T2×2: HEXA-TT synth ≠ σ²·10⁶ /s ± 50% → §9.2 c chain retract",
    "F-AM-2 T2×2: HEXA-TT cost ≠ NASA-99 / σ⁶ ± 50% → 1/σ⁶ chain retract",
    "F-AM-2 T2×2: HEXA-TT storage ≠ σ·τ² months × baseline ± 50% → cryo-free retract",
    "tabletop parity: 200/0.29 ≠ ~690 → volume-reduction integer match retract",
    "tabletop parity: σ⁶ × $2.1e4/mg ≠ NASA-99 $/g ± 5% → cost-chain final retract",
    "tabletop parity: σ³ × 3×10⁷ × 1e2 ≠ 1.7e12 → production-cascade chain retract",
    "tabletop parity: σ⁶ ≠ σ³·σ³ → factory × PET cost-split closure breaks",
    "math_pure floor: pow_pure(σ,k) for k ∈ {2,3,6} stability lost",
]

fn print_table() {
    println("")
    println("  ┌─ 4-machine reference parity table (tabletop pillar) ───────────────────┐")
    println("  │  ref          published         n=6 factor    HEXA-TT prediction        │")
    println("  ├────────────┼─────────────────┼───────────────┼─────────────────────────┤")
    println("  │ CERN AD V  │ 200 m³          │ ÷ σ²·σ·τ/(σ-φ) │ " + ("" + hexa_tt_volume_m3())   + " m³")
    println("  │ CERN AD N  │ 3×10⁷ /s        │ × σ³·10⁹/3e7   │ " + ("" + hexa_tt_prod_per_s()) + " p̄/s")
    println("  │ ALPHA H̄    │ ~10³ /s         │ × σ²·10⁵        │ " + ("" + hexa_tt_synth_per_s()) + " H̄/s")
    println("  │ NASA-99 $  │ $6.25e13/g      │ ÷ σ⁶            │ $" + ("" + hexa_tt_cost_per_g()) + "/g")
    println("  │ ELENA hold │ 10⁵ s           │ × σ·τ² months   │ " + ("" + hexa_tt_hold_s())   + " s")
    println("  └──────────────────────────────────────────────────────────────────────────┘")
    println("")
}

// ── parity checks ────────────────────────────────────────────────────────

fn check_volume_parity() {
    let predicted = hexa_tt_volume_m3()
    _check(_approx_rel(predicted, 0.2894, 0.001),
           "CERN AD vol ÷ (σ²·σ·τ/(σ-φ)): HEXA-TT vol = 0.2894 m³",
           "predicted = " + ("" + predicted))
    _check(_approx_rel(predicted, 0.29, 0.05),
           "HEXA-TT vol within 5% of SSOT '0.29 m³'", "")
    let ratio = CERN_AD_VOL_M3 / predicted
    _check(_approx_rel(ratio, 691.0, 0.01),
           "AD/HEXA-TT volume ratio ≈ 691×", "ratio = " + ("" + ratio))
}

fn check_production_parity() {
    let predicted = hexa_tt_prod_per_s()
    // σ³ × 10⁹ = 1.728×10¹².  SSOT cites 1.7×10¹² (1-sig-fig round).
    _check(_approx_rel(predicted, 1728000000000.0, 0.001),
           "HEXA-TT prod = σ³ × 10⁹ = 1.728×10¹² p̄/s",
           "predicted = " + ("" + predicted))
    _check(_approx_rel(predicted, 1700000000000.0, 0.02),
           "HEXA-TT prod within 2% of cited 1.7×10¹² p̄/s", "")
    let gain = predicted / CERN_AD_PROD_PER_S
    // Gain over CERN AD: σ³ × 10⁹ / 3×10⁷ = 1.728e12 / 3e7 = 5.76×10⁴
    _check(_approx_rel(gain, 57600.0, 0.001),
           "HEXA-TT / AD gain = σ³ × 10⁹ / 3×10⁷ ≈ 5.76×10⁴",
           "gain = " + ("" + gain))
}

fn check_synth_parity() {
    let predicted = hexa_tt_synth_per_s()
    _check(_approx_rel(predicted, 144000000.0, 0.001),
           "HEXA-TT synth = σ² × 10⁶ = 1.44×10⁸ H̄/s", "")
    // ALPHA capable ~10³ /s — HEXA gain ~5 orders.
    _check(predicted >= CERN_ALPHA_HBAR_PER_S * 100000.0,
           "HEXA-TT synth ≥ 10⁵ × ALPHA capable rate", "")
}

fn check_cost_parity() {
    let predicted = hexa_tt_cost_per_g()
    // 6.25e13 / 2,985,984 ≈ 2.0931×10⁷ $/g  =  $2.0931×10⁴/mg
    _check(_approx_rel(predicted, 20931069.96, 0.001),
           "HEXA-TT cost = NASA-99 ÷ σ⁶ ≈ $2.093×10⁷/g  ($2.093×10⁴/mg)",
           "predicted = $" + ("" + predicted) + "/g")
    // SSOT cites $2.1×10⁴/mg = $2.1×10⁷/g.  Within 1% rel.
    _check(_approx_rel(predicted, 21000000.0, 0.01),
           "HEXA-TT cost within 1% of SSOT '$2.1×10⁴/mg'", "")
    let factor = NASA99_COST_PER_G / predicted
    _check(_approx_rel(factor, 2985984.0, 0.001),
           "cost-reduction factor = σ⁶ = 2,985,984", "factor = " + ("" + factor))
}

fn check_storage_parity() {
    let predicted = hexa_tt_hold_s()
    // 192 mo × 30 d × 86400 s/d = 497,664,000 s = 4.977×10⁸ s
    _check(_approx_rel(predicted, 497664000.0, 0.001),
           "HEXA-TT hold = σ·τ² months × 30·86400 = 4.977×10⁸ s", "")
    let ratio = predicted / CERN_ELENA_HOLD_S
    // ≈ 4977× — SSOT cites "16 yr storage" vs CERN ~28 hr; ratio ≥ 4000×.
    _check(ratio >= 4000.0,
           "HEXA-TT / ELENA hold ratio ≥ 4000× (cryo-free σ·τ² extension)",
           "ratio = " + ("" + ratio))
}

// ── n=6 factor consistency ───────────────────────────────────────────────

fn check_n6_consistency() {
    let s2 = pow_pure(SIGMA_F, 2.0)
    let s3 = pow_pure(SIGMA_F, 3.0)
    let s6 = pow_pure(SIGMA_F, 6.0)
    // σ⁶ = σ³ · σ³
    _check(_approx_rel(s6, s3 * s3, 0.000000001),
           "σ⁶ = σ³ · σ³  (factory × PET cost-split closure)", "")
    // Cross-check: NASA-99 / $2.1×10⁷/g (rough cited tabletop $/g) ≈ σ⁶
    let cost_factor_check = NASA99_COST_PER_G / 21000000.0
    _check(_approx_rel(cost_factor_check, s6, 0.05),
           "NASA-99 / cited tabletop $/g ≈ σ⁶ ± 5%",
           "factor = " + ("" + cost_factor_check) + " · σ⁶ = " + ("" + s6))
    // σ²·σ·τ/(σ-φ) = volume-reduction factor = 144·48/10 = 691.2
    let vol_factor = s2 * SIGMA_F * TAU_F / (SIGMA_F - PHI_F)
    _check(_approx_rel(vol_factor, 691.2, 0.000000001),
           "volume-reduction factor σ²·σ·τ/(σ-φ) = 691.2", "")
}

fn check_math_pure_floor() {
    let s2 = pow_pure(SIGMA_F, 2.0)
    let s3 = pow_pure(SIGMA_F, 3.0)
    let s6 = pow_pure(SIGMA_F, 6.0)
    _check(_approx_rel(s2, 144.0, 0.000000001),
           "pow_pure(σ, 2) = 144 ± 1e-9", "")
    _check(_approx_rel(s3, 1728.0, 0.000000001),
           "pow_pure(σ, 3) = 1728 ± 1e-9", "")
    _check(_approx_rel(s6, 2985984.0, 0.000000001),
           "pow_pure(σ, 6) = 2,985,984 ± 1e-9", "")
}

fn main() {
    println("========================================================================")
    println("  hexa-antimatter — numerics_tabletop_parity: 4-machine ref parity")
    println("========================================================================")
    println("  closes:  F-AM-2 T2 ×2 (tabletop pillar 2nd T2 stack)")
    println("  references: CERN AD (vol+prod) · ALPHA · NASA-99 · ELENA")
    println("  band:    decade-band parity (±50% ≈ half decade)")
    print_table()

    println("  -- CERN AD ÷ (σ²·σ·τ/(σ-φ)) (volume) --")
    check_volume_parity()

    println("")
    println("  -- CERN AD × σ³·10⁹/3e7 (production) --")
    check_production_parity()

    println("")
    println("  -- ALPHA × σ²·10⁵ (synthesis) --")
    check_synth_parity()

    println("")
    println("  -- NASA-99 ÷ σ⁶ (cost) --")
    check_cost_parity()

    println("")
    println("  -- ELENA × σ·τ² months (storage) --")
    check_storage_parity()

    println("")
    println("  -- n=6 factor consistency --")
    check_n6_consistency()

    println("")
    println("  -- math_pure stability floor --")
    check_math_pure_floor()

    println("")
    println("  FALSIFIERS (" + _int_str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + _int_str(pass_n) + "/" + _int_str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP_PARITY__ FAIL")
        exit(1)
    }
    println("__HEXA_ANTIMATTER_NUMERICS_TABLETOP_PARITY__ PASS")
    exit(0)
}
