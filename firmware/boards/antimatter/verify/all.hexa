                "__HEXA_ANTIMATTER_NUMERICS_PET_CYCLOTRON__ PASS", q) {
        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/numerics_pet_cyclotron  (T2 numerical, F-AM-1)"]
