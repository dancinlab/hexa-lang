        pass_count = pass_count + 1
        summary = summary + ["  [PASS] firmware/sim/cyclotron_trigger  (Phase C sim, F-AM-1)"]
    } else {
        summary = summary + ["  [FAIL] firmware/sim/cyclotron_trigger"]
    }

    tot = tot + 1
    if run_step("firmware_penning_rf", r + "/firmware/sim/penning_rf.hexa",
