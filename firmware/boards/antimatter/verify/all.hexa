        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/numerics_break_even  (T2 numerical, F-AM-4)"]
    } else {
        summary = summary + ["  [FAIL] verify/numerics_break_even"]
    }

    tot = tot + 1
    if run_step("numerics_break_even_parity", r + "/verify/numerics_break_even_parity.hexa",
