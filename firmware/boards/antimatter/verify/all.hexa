        summary = summary + ["  [PASS] verify/empirical_tabletop_inspire  (T3 paper-feed, F-AM-2)"]
    } else {
        summary = summary + ["  [FAIL] verify/empirical_tabletop_inspire"]
    }

    tot = tot + 1
    if run_step("empirical_dirac_inspire", r + "/verify/empirical_dirac_inspire.hexa",
