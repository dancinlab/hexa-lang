        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/numerics_break_even_parity  (T2×2, F-AM-4 4-program parity)"]
    } else {
        summary = summary + ["  [FAIL] verify/numerics_break_even_parity"]
    }

    tot = tot + 1
    if run_step("numerics_break_even_solver", r + "/verify/numerics_break_even_solver.hexa",
                "__HEXA_ANTIMATTER_NUMERICS_BREAK_EVEN_SOLVER__ PASS", q) {
