        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/numerics_pet_cyclotron_solver  (T2×3, F-AM-1 ¹⁸F decay)"]
    } else {
        summary = summary + ["  [FAIL] verify/numerics_pet_cyclotron_solver"]
    }

    tot = tot + 1
    if run_step("numerics_cross_pillar", r + "/verify/numerics_cross_pillar.hexa",
                "__HEXA_ANTIMATTER_NUMERICS_CROSS_PILLAR__ PASS", q) {
        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/numerics_cross_pillar  (T2 cross-cutter, F-AM-1/2/3/4)"]
    } else {
        summary = summary + ["  [FAIL] verify/numerics_cross_pillar"]
    }

    tot = tot + 1
    if run_step("numerics_lattice_arithmetic", r + "/verify/numerics_lattice_arithmetic.hexa",
                "__HEXA_ANTIMATTER_NUMERICS_LATTICE_ARITHMETIC__ PASS", q) {
        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/numerics_lattice_arithmetic  (math_pure stability floor)"]
    } else {
        summary = summary + ["  [FAIL] verify/numerics_lattice_arithmetic"]
    }

    tot = tot + 1
    if run_step("falsifier_check", r + "/verify/falsifier_check.hexa",
                "__HEXA_ANTIMATTER_FALSIFIER__ PASS", q) {
        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/falsifier_check  (4/4 F-AM closure tracker)"]
    } else {
        summary = summary + ["  [FAIL] verify/falsifier_check"]
    }

    tot = tot + 1
    if run_step("lint_numerics", r + "/verify/lint_numerics.hexa",
                "__HEXA_ANTIMATTER_LINT_NUMERICS__ PASS", q) {
        pass_count = pass_count + 1
        summary = summary + ["  [PASS] verify/lint_numerics  (5-invariant grep-lint)"]
