#!hexa strict
// hexa-chip/verify/numerics_lattice_arithmetic.hexa — math_pure floor.
//
// math_pure stability floor cross-check, recipe §7.4 priority 8.
// Verifies that the n=6 lattice arithmetic in n6_arithmetic.hexa
// (integer divisor-sum / coprime-count) agrees with float-arithmetic
// re-derivations using `self/runtime/math_pure` (sqrt_pure, log_pure,
// pow_pure, etc.).   This script is the canonical "is the runtime
// math layer stable enough to anchor every numerics_*.hexa script?"
// gate.
//
// Cross-checks (n = 1..24):
//   • σ(n) integer divisor-sum   vs σ(n) recomputed in float
//   • τ(n) integer divisor-count vs float-summed indicator function
//   • φ(n) integer coprime-count vs Euler product formula in float
//   • n=6 master identity: σ·φ = n·τ = 24 — verified twice (int + float)
//   • √n, log n, exp(log n) round-trip stability across the lattice
//
// PASS = every (n, primitive) cross-check matches integer reference
//        within tolerance + master identity exact.
// FAIL = any drift > 1e-6 between int and float computation.
//
// Run:
//   hexa run verify/numerics_lattice_arithmetic.hexa
//   hexa run verify/numerics_lattice_arithmetic.hexa --json
//
// Cost: $0 (pure-hexa float math; no FFI).

use "self/runtime/math_pure"

let N_MAX = 24    // span 1..24 covers J₂ = 24 ceiling
let TOL   = 0.000001    // 1e-6

// ─── integer reference primitives (canonical) ───────────────────────

fn _gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    if x < 0 { x = -x }
    if y < 0 { y = -y }
    while y != 0 { let t = y; y = x % y; x = t }
    return x
}

fn divisors_of(n: int) -> [int] {
    let mut ds: [int] = []
    let mut k = 1
    while k <= n { if n % k == 0 { ds = ds + [k] }; k = k + 1 }
    return ds
}

fn sigma_int(n: int) -> int {
    let ds = divisors_of(n)
    let mut s = 0
    for d in ds { s = s + d }
    return s
}

fn tau_int(n: int) -> int { return divisors_of(n).len() }

fn phi_int(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut count = 0
    let mut k = 1
    while k <= n { if _gcd(k, n) == 1 { count = count + 1 }; k = k + 1 }
    return count
}

// ─── float re-derivations via math_pure ──────────────────────────────

fn sigma_float(n: int) -> float {
    // σ(n) = Σ_{k=1..n} k · [n mod k == 0]
    // Use float arithmetic to accumulate.
    let mut s = 0.0
    let mut k = 1
    while k <= n {
        if n % k == 0 { s = s + float(k) }
        k = k + 1
    }
    return s
}

fn tau_float(n: int) -> float {
    let mut s = 0.0
    let mut k = 1
    while k <= n {
        if n % k == 0 { s = s + 1.0 }
        k = k + 1
    }
    return s
}

fn phi_float(n: int) -> float {
    if n <= 0 { return 0.0 }
    if n == 1 { return 1.0 }
    let mut s = 0.0
    let mut k = 1
    while k <= n {
        if _gcd(k, n) == 1 { s = s + 1.0 }
        k = k + 1
    }
    return s
}

// ─── arg helpers ─────────────────────────────────────────────────────

fn _has_flag(a: [str], flag: str) -> bool {
    for x in a { if x == flag { return true } }
    return false
}

fn _user_args() -> [str] {
    let raw = args()
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut out: [str] = []
    let mut j = sidx + 1
    if sidx < 0 { j = 0 }
    while j < raw.len() { out = out + [raw[j]]; j = j + 1 }
    return out
}

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ─── checks ──────────────────────────────────────────────────────────

fn check_sigma_int_float_agreement() {
    let mut ok = true
    let mut n = 1
    while n <= N_MAX {
        let i_val = float(sigma_int(n))
        let f_val = sigma_float(n)
        if !is_close_pure(i_val, f_val, TOL) { ok = false }
        n = n + 1
    }
    _check(ok, "σ(n) int ≡ float for n ∈ [1, 24]", "")
}

fn check_tau_int_float_agreement() {
    let mut ok = true
    let mut n = 1
    while n <= N_MAX {
        let i_val = float(tau_int(n))
        let f_val = tau_float(n)
        if !is_close_pure(i_val, f_val, TOL) { ok = false }
        n = n + 1
    }
    _check(ok, "τ(n) int ≡ float for n ∈ [1, 24]", "")
}

fn check_phi_int_float_agreement() {
    let mut ok = true
    let mut n = 1
    while n <= N_MAX {
        let i_val = float(phi_int(n))
        let f_val = phi_float(n)
        if !is_close_pure(i_val, f_val, TOL) { ok = false }
        n = n + 1
    }
    _check(ok, "φ(n) int ≡ float for n ∈ [1, 24]", "")
}

fn check_master_identity_at_n6_int() {
    let s = sigma_int(6)
    let t = tau_int(6)
    let f = phi_int(6)
    let ok = (s * f == 6 * t) && (s * f == 24)
    _check(ok, "[int] σ(6)·φ(6) = 6·τ(6) = J₂ = 24", "")
}

fn check_master_identity_at_n6_float() {
    let s = sigma_float(6)
    let t = tau_float(6)
    let f = phi_float(6)
    let lhs = s * f
    let rhs = 6.0 * t
    let ok = is_close_pure(lhs, rhs, TOL) && is_close_pure(lhs, 24.0, TOL)
    _check(ok, "[float] σ·φ = n·τ = J₂ = 24 within 1e-6", "lhs=" + str(lhs) + " rhs=" + str(rhs))
}

fn check_sqrt_round_trip_lattice() {
    // For n = 1..24:  sqrt_pure(n)² should equal n within 1e-9.
    let mut ok = true
    let mut worst_n = -1
    let mut worst_d = 0.0
    let mut n = 1
    while n <= N_MAX {
        let r = sqrt_pure(float(n))
        let r2 = r * r
        let d = abs_pure(r2 - float(n))
        if d > worst_d { worst_d = d; worst_n = n }
        if d > 1e-9 { ok = false }
        n = n + 1
    }
    let detail = if ok { "worst Δ=" + str(worst_d) } else { "n=" + str(worst_n) + " Δ=" + str(worst_d) }
    _check(ok, "sqrt_pure round-trip stable to 1e-9 for n ∈ [1, 24]", detail)
}

fn check_log_exp_round_trip_lattice() {
    // exp(log(n)) should equal n within 1e-9 for n ∈ [1, 24].
    let mut ok = true
    let mut n = 1
    while n <= N_MAX {
        let r = exp_pure(log_pure(float(n)))
        if !is_close_pure(r, float(n), 1e-9) { ok = false }
        n = n + 1
    }
    _check(ok, "exp(log(n)) round-trip stable to 1e-9 for n ∈ [1, 24]", "")
}

fn check_pow_round_trip_at_n6() {
    // pow_pure(6, 2) should equal 36 exactly; pow_pure(6, 0.5) should
    // equal sqrt_pure(6).
    let p2 = pow_pure(6.0, 2.0)
    let p_half = pow_pure(6.0, 0.5)
    let s = sqrt_pure(6.0)
    let ok1 = is_close_pure(p2, 36.0, 1e-9)
    let ok2 = is_close_pure(p_half, s, 1e-9)
    _check(ok1 && ok2, "pow_pure: 6² = 36; 6^½ = √6", "p2=" + str(p2) + " phalf=" + str(p_half))
}

fn check_log2_at_n6_consistency() {
    // log2(6) ≈ 2.585.  Check log2_pure(6)·log_pure(2) ≈ log_pure(6).
    let l2 = log2_pure(6.0)
    let l_2 = log_pure(2.0)
    let l_6 = log_pure(6.0)
    let ok = is_close_pure(l2 * l_2, l_6, 1e-6)
    _check(ok, "log2(6)·ln(2) = ln(6) within 1e-6", "got " + str(l2 * l_2))
}

fn check_special_n_count() {
    // The master identity σ·φ = n·τ holds at n=1 and n=6 in [1, 24].
    // (At n=1: σ=1, φ=1, τ=1; lhs=1, rhs=1; both equal 1.
    //  At n=6: lhs=24, rhs=24.   Other n: e.g., n=12: σ=28, φ=4, τ=6;
    //  lhs=112, rhs=72 — mismatch.   So n=1 and n=6 are special.)
    let mut count = 0
    let mut n = 1
    while n <= N_MAX {
        let s = sigma_int(n)
        let f = phi_int(n)
        let t = tau_int(n)
        if s * f == n * t { count = count + 1 }
        n = n + 1
    }
    _check(count == 2, "master identity holds at exactly 2 values in [1, 24] (n=1, n=6)", "got " + str(count))
}

fn check_sigma_monotonic_on_average() {
    // σ(n) isn't monotone, but Σ_{1..N} σ(k) is.
    let mut prev_sum = 0
    let mut ok = true
    let mut n = 1
    while n <= N_MAX {
        let cur_sum = prev_sum + sigma_int(n)
        if cur_sum <= prev_sum { ok = false }
        prev_sum = cur_sum
        n = n + 1
    }
    _check(ok, "Σ σ(k) strictly increasing in N (mertens-style monotone)", "")
}

fn check_phi_le_n_minus_1_for_prime_n() {
    // For prime n: φ(n) = n − 1.  Primes in [1, 24]: 2, 3, 5, 7, 11, 13,
    // 17, 19, 23 — 9 primes.
    let primes = [2, 3, 5, 7, 11, 13, 17, 19, 23]
    let mut ok = true
    for p in primes {
        if phi_int(p) != p - 1 { ok = false }
    }
    _check(ok, "φ(p) = p - 1 for all 9 primes in [1, 24]", "")
}

fn check_pi_24_eq_9() {
    // π(24) = 9 (count of primes ≤ 24).   This is independent of the
    // lattice but a useful number-theory anchor.
    let mut count = 0
    let mut n = 2
    while n <= N_MAX {
        let mut is_prime = true
        if n < 2 { is_prime = false }
        let mut k = 2
        while k * k <= n {
            if n % k == 0 { is_prime = false }
            k = k + 1
        }
        if is_prime { count = count + 1 }
        n = n + 1
    }
    _check(count == 9, "π(24) = 9 primes in [2, 24]", "got " + str(count))
}

// ─── falsifiers (informational) ──────────────────────────────────────

let FALSIFIERS = [
    "F-LATTICE.a: int and float σ/τ/φ disagree for any n ∈ [1, 24] → math_pure broken",
    "F-LATTICE.b: master identity σ·φ = n·τ ≠ 24 at n=6 → lattice anchor retract",
    "F-LATTICE.c: sqrt or exp(log) round-trip drifts > 1e-9 → math_pure precision floor breached",
    "F-LATTICE.d: master identity solution count ≠ 2 in [1, 24] → n=1, n=6 special-pair invariant fails",
    "F-LATTICE.e: π(24) ≠ 9 primes → number-theory anchor mismatch (independent sanity)"
]

fn _print_table() {
    println("  lattice cross-check across n ∈ [1, 24]:")
    println("    n   σ(n)  τ(n)  φ(n)   σ·φ   n·τ    eq?")
    let mut n = 1
    while n <= N_MAX {
        let s = sigma_int(n)
        let t = tau_int(n)
        let f = phi_int(n)
        let lhs = s * f
        let rhs = n * t
        let mark = if lhs == rhs { "  ✓" } else { "" }
        let pad = if n < 10 { "    " } else { "   " }
        println("   " + pad + str(n) + "    " + str(s) + "     " + str(t) + "     " + str(f) + "     " + str(lhs) + "     " + str(rhs) + "    " + mark)
        n = n + 1
    }
    println("")
    println("  identity holds only at n=1 and n=6 in [1, 24].")
    println("")
}

fn main() {
    let ua = _user_args()
    let json_mode = _has_flag(ua, "--json")

    if !json_mode {
        println("========================================================================")
        println("  hexa-chip — numerics_lattice_arithmetic: math_pure floor")
        println("========================================================================")
        _print_table()
    }

    check_sigma_int_float_agreement()
    check_tau_int_float_agreement()
    check_phi_int_float_agreement()
    check_master_identity_at_n6_int()
    check_master_identity_at_n6_float()
    check_sqrt_round_trip_lattice()
    check_log_exp_round_trip_lattice()
    check_pow_round_trip_at_n6()
    check_log2_at_n6_consistency()
    check_special_n_count()
    check_sigma_monotonic_on_average()
    check_phi_le_n_minus_1_for_prime_n()
    check_pi_24_eq_9()

    if !json_mode {
        println("")
        println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
        for f in FALSIFIERS { println("    ✗ " + f) }
    }

    let pass_n = RUN - FAIL
    if json_mode {
        let mut js = "{\"tool\":\"hexa-chip/verify/numerics_lattice_arithmetic.hexa\","
        js = js + "\"schema\":\"hexa-chip/numerics/v1\","
        js = js + "\"falsifier\":\"lattice-floor\","
        js = js + "\"tier\":\"T2\","
        js = js + "\"run\":" + str(RUN) + ","
        js = js + "\"pass\":" + str(pass_n) + ","
        js = js + "\"fail\":" + str(FAIL) + ","
        js = js + "\"ok\":"
        if FAIL == 0 { js = js + "true" } else { js = js + "false" }
        js = js + "}"
        println(js)
        if FAIL > 0 { exit(1) }
        return
    }

    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_CHIP_NUMERICS_LATTICE_ARITHMETIC__ FAIL")
        exit(1)
    }
    println("__HEXA_CHIP_NUMERICS_LATTICE_ARITHMETIC__ PASS")
    exit(0)
}
