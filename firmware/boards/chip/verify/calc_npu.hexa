#!hexa strict
// hexa-chip/verify/calc_npu.hexa — F-CHIP-2 T1 algebraic.
//
// NPU-pillar n=6 derivation (정수 산술).
// Closes the T1 (algebraic) tier of falsifier F-CHIP-2
// (NPU n=6 dataflow τ=4 stage decomposition, .roadmap §A.4).
//
// Claim (closed-form, integer-arithmetic):
//
//   τ(6) =  4  → 4-stage NPU dataflow pipeline
//                (load → MAC → activate → store)
//   σ(6) = 12  → 12-lane MAC array width target
//                (= σ(6) lanes; matches process-pillar σ slot count)
//   φ(6) =  2  → INT8 / FP16 verdict bit  (precision dichotomy)
//   J₂   = 24  → σ·φ ceiling = 24 macroblocks per τ-stage budget
//
// 4-stage pipeline cardinality also matches Eyeriss-taxonomy quartet
// (weight-stationary / output-stationary / input-stationary /
//  row-stationary), giving an independent τ=4 anchor.
//
// PASS = σ/τ/φ identities hold + 4 dataflow stages + 4 dataflow
//        patterns + 12 MAC lanes + macroblock budget = J₂.
// FAIL = any algebraic mismatch.
//
// Run:
//   hexa run verify/calc_npu.hexa
//   hexa run verify/calc_npu.hexa --json
//
// Cost: $0 (pure integer arithmetic).

// ─── n=6 lattice primitives (mirrored from n6_arithmetic.hexa) ───────

fn _gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    if x < 0 { x = -x }
    if y < 0 { y = -y }
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

fn divisors_of(n: int) -> [int] {
    let mut ds: [int] = []
    let mut k = 1
    while k <= n {
        if n % k == 0 { ds = ds + [k] }
        k = k + 1
    }
    return ds
}

fn sigma_n(n: int) -> int {
    let ds = divisors_of(n)
    let mut s = 0
    for d in ds { s = s + d }
    return s
}

fn tau_n(n: int) -> int { return divisors_of(n).len() }

fn euler_phi(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut count = 0
    let mut k = 1
    while k <= n {
        if _gcd(k, n) == 1 { count = count + 1 }
        k = k + 1
    }
    return count
}

// ─── NPU n=6 lattice anchors ─────────────────────────────────────────

let DATAFLOW_STAGES = [
    "load",          // 1: weight + activation fetch (DMA / SRAM hit)
    "MAC",           // 2: multiply-accumulate (systolic / SIMD)
    "activate",      // 3: nonlinearity (ReLU / GELU / softmax)
    "store"          // 4: writeback + accumulator drain
]

let EYERISS_PATTERNS = [
    "weight-stationary",
    "output-stationary",
    "input-stationary",
    "row-stationary"
]

let PRECISION_VERDICTS = ["INT8", "FP16"]   // φ(6)=2 dichotomy

// ─── arg helpers ─────────────────────────────────────────────────────

fn _has_flag(a: [str], flag: str) -> bool {
    for x in a { if x == flag { return true } }
    return false
}

fn _user_args() -> [str] {
    let raw = args()
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut out: [str] = []
    let mut j = sidx + 1
    if sidx < 0 { j = 0 }
    while j < raw.len() { out = out + [raw[j]]; j = j + 1 }
    return out
}

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ─── checks ──────────────────────────────────────────────────────────

fn check_tau_eq_4() {
    let t = tau_n(6)
    _check(t == 4, "τ(6) =  4 (divisors {1,2,3,6})", "got τ(6) = " + str(t))
}

fn check_sigma_eq_12() {
    let s = sigma_n(6)
    _check(s == 12, "σ(6) = 12 (MAC lane count target)", "got σ(6) = " + str(s))
}

fn check_phi_eq_2() {
    let p = euler_phi(6)
    _check(p == 2, "φ(6) =  2 (precision dichotomy)", "got φ(6) = " + str(p))
}

fn check_master_identity() {
    let s = sigma_n(6)
    let p = euler_phi(6)
    let t = tau_n(6)
    let lhs = s * p
    let rhs = 6 * t
    let ok = (lhs == rhs) && (lhs == 24)
    _check(ok, "σ·φ = n·τ = J₂ = 24 (macroblock budget)", "σ·φ=" + str(lhs) + ", n·τ=" + str(rhs))
}

fn check_pipeline_stage_count_eq_tau() {
    let n = DATAFLOW_STAGES.len()
    let t = tau_n(6)
    _check(n == t, "4 dataflow stages enumerated == τ(6)", "got " + str(n) + " stages")
}

fn check_pipeline_stages_distinct() {
    let mut ok = true
    let mut details: [str] = []
    let mut i = 0
    while i < DATAFLOW_STAGES.len() {
        let mut j = i + 1
        while j < DATAFLOW_STAGES.len() {
            if DATAFLOW_STAGES[i] == DATAFLOW_STAGES[j] {
                ok = false
                details = details + ["dup at " + str(i) + "/" + str(j)]
            }
            j = j + 1
        }
        i = i + 1
    }
    let detail = if ok { "" } else { details.len().str() + " dup pairs" }
    _check(ok, "pipeline stages strictly distinct (no dup labels)", detail)
}

fn check_eyeriss_pattern_count_eq_tau() {
    let n = EYERISS_PATTERNS.len()
    let t = tau_n(6)
    _check(n == t, "4 Eyeriss dataflow patterns == τ(6)", "got " + str(n))
}

fn check_eyeriss_independent_of_pipeline() {
    // Patterns and stages are different concept-axes — assert no leakage.
    let mut overlap = 0
    for s in DATAFLOW_STAGES {
        for p in EYERISS_PATTERNS { if s == p { overlap = overlap + 1 } }
    }
    _check(overlap == 0, "pipeline stages ⊥ Eyeriss patterns (independent τ axes)", "overlap=" + str(overlap))
}

fn check_mac_lane_target_eq_sigma() {
    let target_lanes = 12
    let s = sigma_n(6)
    _check(target_lanes == s, "MAC array lane target == σ(6)", "lanes=" + str(target_lanes))
}

fn check_precision_verdict_eq_phi() {
    let n = PRECISION_VERDICTS.len()
    let p = euler_phi(6)
    _check(n == p, "precision verdicts {INT8, FP16} == φ(6)", "got " + str(n))
}

fn check_macroblock_budget_eq_j2() {
    // macroblock budget per τ-stage = σ·φ = 24.  Total budget across τ
    // stages = 24·τ = 96 — keep both as sanity invariants.
    let s = sigma_n(6)
    let p = euler_phi(6)
    let t = tau_n(6)
    let per_stage = s * p
    let total = per_stage * t
    let ok = (per_stage == 24) && (total == 96)
    _check(ok, "macroblock budget: 24/stage, 96 total = σ·φ·τ", "per_stage=" + str(per_stage) + ", total=" + str(total))
}

// ─── falsifiers (informational) ──────────────────────────────────────

let FALSIFIERS = [
    "F-CHIP-2.a: NPU pipeline-stage count ≠ 4 in published Exynos/ANE → τ(6)=4 retract",
    "F-CHIP-2.b: Eyeriss pattern count ≠ 4 in canonical taxonomy → τ second-anchor falls",
    "F-CHIP-2.c: MAC lane width can't divide σ(6)=12 cleanly → σ-lane mapping breaks",
    "F-CHIP-2.d: precision modes ≠ {INT8, FP16} pair in commercial NPUs → φ(6)=2 retract"
]

fn _print_table() {
    println("  τ(6)=4 dataflow stages:")
    let mut i = 0
    while i < DATAFLOW_STAGES.len() {
        println("    [" + str(i + 1) + "] " + DATAFLOW_STAGES[i])
        i = i + 1
    }
    println("")
    println("  τ(6)=4 Eyeriss-taxonomy dataflow patterns:")
    let mut j = 0
    while j < EYERISS_PATTERNS.len() {
        println("    [" + str(j + 1) + "] " + EYERISS_PATTERNS[j])
        j = j + 1
    }
    println("")
    println("  σ(6)=12 → 12-lane MAC array target (mirrors process σ slots)")
    println("  φ(6)=2  → { INT8, FP16 } precision dichotomy")
    println("  J₂=24   → 24 macroblocks / τ-stage budget   (96 total across pipeline)")
    println("")
}

fn main() {
    let ua = _user_args()
    let json_mode = _has_flag(ua, "--json")

    if !json_mode {
        println("========================================================================")
        println("  hexa-chip — calc_npu: F-CHIP-2 T1 algebraic (n=6 NPU dataflow)")
        println("========================================================================")
        _print_table()
    }

    check_tau_eq_4()
    check_sigma_eq_12()
    check_phi_eq_2()
    check_master_identity()
    check_pipeline_stage_count_eq_tau()
    check_pipeline_stages_distinct()
    check_eyeriss_pattern_count_eq_tau()
    check_eyeriss_independent_of_pipeline()
    check_mac_lane_target_eq_sigma()
    check_precision_verdict_eq_phi()
    check_macroblock_budget_eq_j2()

    if !json_mode {
        println("")
        println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
        for f in FALSIFIERS { println("    ✗ " + f) }
    }

    let pass_n = RUN - FAIL
    if json_mode {
        let mut js = "{\"tool\":\"hexa-chip/verify/calc_npu.hexa\","
        js = js + "\"schema\":\"hexa-chip/calc/v1\","
        js = js + "\"falsifier\":\"F-CHIP-2\","
        js = js + "\"tier\":\"T1\","
        js = js + "\"run\":" + str(RUN) + ","
        js = js + "\"pass\":" + str(pass_n) + ","
        js = js + "\"fail\":" + str(FAIL) + ","
        js = js + "\"ok\":"
        if FAIL == 0 { js = js + "true" } else { js = js + "false" }
        js = js + "}"
        println(js)
        if FAIL > 0 { exit(1) }
        return
    }

    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_CHIP_CALC_NPU__ FAIL")
        exit(1)
    }
    println("__HEXA_CHIP_CALC_NPU__ PASS")
    exit(0)
}
