#!hexa strict
// hexa-chip/firmware/mcu/thermal_coord.hexa — Phase D iter 4.
//
// Host MCU controller for F-CHIP-3 (HBM σ-φ=10 thermal ceiling).
// Target board: HEXA-CHIP-FW-03 = STM32H7 + ADS1115 thermal coordinator
// driving the FPGA top-level firmware/hdl/hbm_thermal_top.v over an
// AXI4-Lite control bridge for DVFS issue + CATTRIP escalation, with
// 16-layer T-sensor poll over I²C (in-stack sensors + ADS1115 ext).
//
// Falsifier: F-CHIP-3.D (host-side thermal control loop)
// Board ID:  HEXA-CHIP-FW-03
// Phase:     D iter 4 — first .hexa MCU consumer of stdlib/hal v0.0.1.
//
// stdlib/hal modules used:
//   core   — sentinel + exit + str/float runtime
//   gpio   — DVFS strobe + CATTRIP latch line + ADS1115 ALERT input
//   i2c    — 16-layer in-stack T-sensor poll @ 100 kHz + ADS1115 (0x48)
//   intr   — cattrip vector @ HIGH priority + ALERT-pin EXTI
//   timer  — 100 ms thermal-poll tick
//   uart   — telemetry log @ 115200 baud
//
// Logic mirrors firmware/sim/hbm_thermal_controller.hexa but as the
// host-side controller: poll 16 sensors over I²C (matching the sim's
// SENSORS array), run 5 Jacobi iterations, verify monotone profile,
// count DVFS triggers (T ≥ 90°C), assert no CATTRIP fired (T < 105°C).

use "stdlib/hal/core"
use "stdlib/hal/gpio"
use "stdlib/hal/i2c"
use "stdlib/hal/intr"
use "stdlib/hal/timer"
use "stdlib/hal/uart"

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

let LAYERS = 16
let T_BOT = 25.0
let T_TOP = 95.0
let T_DVFS_THRESHOLD = 90.0
let T_CATTRIP = 105.0

// ── synthetic per-layer thermal sensor readout (matches the sim) ──────
let SENSORS = [
    "25.0", "30.0", "35.0", "40.5", "45.5", "50.5", "55.5", "60.5",
    "70.5", "75.5", "80.5", "85.5", "90.5", "92.0", "93.5", "95.0"
]

fn _f(s: str) -> float { return float(s) }

// ── poll all 16 layer sensors over I²C (sim) ──────────────────────────
fn poll_sensors(i2c_h: int) -> [float] {
    // Layer addresses 0x40..0x4F on bus0 + 0x48 ADS1115 mux for ext
    // overlay.  Real HW: read in-stack thermal diodes; sim: use SENSORS.
    let mut out: [float] = []
    let mut i = 0
    while i < LAYERS {
        let _rx = i2c_read(i2c_h, 0x40 + i, 2)
        out = out + [_f(SENSORS[i])]
        i = i + 1
    }
    return out
}

// ── Jacobi step (interior 1-D Laplace) ────────────────────────────────
fn jacobi_step(t: [float]) -> [float] {
    let n = t.len()
    let mut tn: [float] = []
    let mut i = 0
    while i < n {
        if i == 0 || i == n - 1 {
            tn = tn + [t[i]]
        } else {
            tn = tn + [(t[i-1] + t[i+1]) / 2.0]
        }
        i = i + 1
    }
    return tn
}

fn count_dvfs_triggers(t: [float]) -> int {
    let mut n = 0
    for x in t {
        if x >= T_DVFS_THRESHOLD { n = n + 1 }
    }
    return n
}

fn count_cattrip_triggers(t: [float]) -> int {
    let mut n = 0
    for x in t {
        if x >= T_CATTRIP { n = n + 1 }
    }
    return n
}

// ── checks ────────────────────────────────────────────────────────────
fn check_sensor_count(t: [float]) {
    _check(t.len() == LAYERS,
           "I²C poll returned 16 layer readings (HBM4 16-Hi)",
           "got " + str(t.len()))
}

fn check_boundary_temperatures(t: [float]) {
    _check(t[0] <= T_BOT + 1.0,
           "L0 (bottom) ≈ 25°C ± 1 (interposer-coupled)",
           "got " + str(t[0]))
    _check(t[t.len() - 1] >= T_TOP - 1.0,
           "L_top ≈ 95°C ± 1 (top heatsink-facing)",
           "got " + str(t[t.len() - 1]))
}

fn check_monotone_profile(t: [float]) {
    let mut bad = 0
    let mut i = 1
    while i < t.len() {
        if t[i] < t[i-1] { bad = bad + 1 }
        i = i + 1
    }
    _check(bad == 0,
           "thermal profile monotonically increasing L0 → L15",
           "regressions = " + str(bad))
}

fn check_dvfs_engagement(t: [float], gpio_dvfs: int) {
    let n = count_dvfs_triggers(t)
    if n > 0 {
        gpio_write(gpio_dvfs, true)   // host issues DVFS pulldown to FPGA
    }
    _check(n >= 1 && n <= 5,
           "DVFS triggers ∈ [1, 5] layers (T ≥ 90°C threshold)",
           "triggers = " + str(n))
}

fn check_no_cattrip(t: [float], gpio_trip: int) {
    let n = count_cattrip_triggers(t)
    if n > 0 {
        gpio_write(gpio_trip, true)   // host latches CATTRIP escalation
    }
    _check(n == 0,
           "no CATTRIP fired in nominal fixture (T < 105°C all layers)",
           "trips = " + str(n))
}

fn check_jacobi_5_iterations(t: [float]) {
    // Run 5 Jacobi iterations; verify max deviation from input bounded.
    let mut s = t
    let mut k = 0
    while k < 5 {
        s = jacobi_step(s)
        k = k + 1
    }
    // After 5 iters, interior smoothes but boundaries pinned, so max
    // deviation from the linear ramp should still be within 10°C.
    let step = (T_TOP - T_BOT) / float(LAYERS - 1)
    let mut max_dev = 0.0
    let mut i = 0
    while i < s.len() {
        let pred = T_BOT + float(i) * step
        let dev = if s[i] > pred { s[i] - pred } else { pred - s[i] }
        if dev > max_dev { max_dev = dev }
        i = i + 1
    }
    _check(max_dev <= 10.0,
           "Jacobi 5-iter max deviation from linear ≤ 10°C (host smoother)",
           "max dev = " + str(max_dev) + "°C")
}

fn check_jacobi_iter_envelope() {
    let lo = LAYERS * LAYERS              // 256
    let hi = LAYERS * LAYERS * 6          // 1536
    _check(lo == 256 && hi == 1536,
           "HBM4 (N=16) Jacobi envelope [N², N²·n] = [256, 1536]",
           "")
}

let FALSIFIERS = [
    "F-CHIP-3.D.a: I²C bus stalls during 16-layer poll → host cannot read FPGA thermal sensors",
    "F-CHIP-3.D.b: thermal profile non-monotone → heat path inverted (heatsink/board failure)",
    "F-CHIP-3.D.c: DVFS triggers outside [1, 5] layers → host control loop drift vs FPGA",
    "F-CHIP-3.D.d: CATTRIP fires in nominal fixture → STM32H7 escalation path mis-armed",
    "F-CHIP-3.D.e: Jacobi 5-iter max-dev > 10°C → host smoother diverges from FPGA solver"
]

fn main() {
    println("========================================================================")
    println("  hexa-chip — Phase D MCU host: thermal_coord (F-CHIP-3, HEXA-CHIP-FW-03)")
    println("========================================================================")
    println("")
    println("  Target HW: STM32H7 + ADS1115 thermal coordinator")
    println("  FPGA peer: firmware/hdl/hbm_thermal_top.v (16-layer DVFS + CATTRIP)")
    println("  Scope: 16-sensor I²C poll, 5-iter Jacobi, DVFS issue + CATTRIP guard")
    println("")

    // ── stdlib/hal handshake ─────────────────────────────────────────
    println("  [hal] opening stdlib/hal peripheral handles ...")
    let i2c_h     = i2c_open(0, 100000)                     // 100 kHz standard mode
    let gpio_dvfs = gpio_open(13, MODE_OUTPUT)              // DVFS strobe to FPGA
    let gpio_trip = gpio_open(14, MODE_OUTPUT)              // CATTRIP latch line
    let gpio_alrt = gpio_open(15, MODE_INPUT_PULLUP)        // ADS1115 ALERT in
    let intr_h    = intr_open(2, PRIO_HIGH, "cattrip")      // FPGA cattrip vector
    let timer_h   = timer_open(0, MODE_PERIODIC, 100000)    // 100 ms poll tick
    let uart_h    = uart_open(2, 115200)                    // telemetry log
    _check(i2c_h     >= 0, "stdlib/hal i2c_open OK",  "h=" + str(i2c_h))
    _check(gpio_dvfs >= 0, "stdlib/hal gpio_open (DVFS strobe) OK", "h=" + str(gpio_dvfs))
    _check(gpio_trip >= 0, "stdlib/hal gpio_open (CATTRIP latch) OK", "h=" + str(gpio_trip))
    _check(gpio_alrt >= 0, "stdlib/hal gpio_open (ADS1115 ALERT) OK", "h=" + str(gpio_alrt))
    _check(intr_h    >= 0, "stdlib/hal intr_open OK", "h=" + str(intr_h))
    _check(timer_h   >= 0, "stdlib/hal timer_open OK", "h=" + str(timer_h))
    _check(uart_h    >= 0, "stdlib/hal uart_open OK",  "h=" + str(uart_h))
    println("")

    let t = poll_sensors(i2c_h)

    check_sensor_count(t)
    check_boundary_temperatures(t)
    check_monotone_profile(t)
    check_dvfs_engagement(t, gpio_dvfs)
    check_no_cattrip(t, gpio_trip)
    check_jacobi_5_iterations(t)
    check_jacobi_iter_envelope()

    // Emit one telemetry line per layer.
    let mut i = 0
    while i < t.len() {
        let _ok = uart_write(uart_h, [0x54, 0x3A, 0x0A])   // "T:\n" stub
        i = i + 1
    }

    let pass_n = RUN - FAIL

    println("")
    println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }
    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_CHIP_MCU_THERMAL_COORD__ FAIL")
        exit(1)
    }
    println("__HEXA_CHIP_MCU_THERMAL_COORD__ PASS — STM32H7+ADS1115 thermal coordinator OK")
    exit(0)
}
