    println("                       | numerics-se3 | numerics-cross | numerics-lhc | numerics-lwfa")
    println("                       | numerics-lattice | lint-numerics | saturation")
    println("                       | empirical-lhc | empirical-lwfa | empirical-classical")
    println("                       | falsifier | firmware-timing | firmware-dac | firmware-adc | firmware-control")
    println("")
