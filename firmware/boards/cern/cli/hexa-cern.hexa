    println("")
    println("backend specs: " + PC)
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_cern_cli", "hexa_cern_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    // Only trigger global --help when the FIRST token is --help/-h.
    // Sub-positioned flags (e.g. `verify --help`) are forwarded to the
    // subcommand's own help handler.
    if sub == "--help" || sub == "-h" {
        cmd_help()
        return
    }

    if sub == "help" { cmd_help(); return }

    if sub == "status" {
        cmd_status(a)
    } else if sub == "mini" {
        cmd_mini(a)
    } else if sub == "parent" {
        cmd_parent(a)
    } else if sub == "classical" {
        cmd_classical(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else if sub == "verify" {
        cmd_verify(a)
    } else {
        eprintln("hexa-cern: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-cern help' for usage")
        _audit(sub, "", 2)
        exit(2)
    }
}
