#!hexa strict
// hexa-cern/verify/numerics_cross_pillar.hexa — cross-pillar numerical consistency.
//
// The 3 per-pillar numerical stubs (numerics_wakefield, numerics_sigma_cascade,
// numerics_classical) each verify their own physics in isolation. This script
// adds a CROSS-LINK: do their numerical outputs agree where they share an
// anchor?
//
// Shared anchors:
//   1. mini target energy E_1_mini = 100 MeV  ==  parent cascade stage E_1 = 100 MeV
//      ⇒ same scalar across pillars, no drift allowed
//   2. γ at 100 MeV (any pillar) is a sanity check —
//      γ = 1 + 100/0.511 ≈ 196.69
//   3. classical 1-DOF phase-space (numerics_classical stub uses dim 2)
//      must be ⊆ Hamilton σ = 12  (SE(3) full)
//   4. plasma reduced wavelength λ_p = 2π c / ω_p at mini's n_e
//      should fall in the LWFA-bubble regime (a few µm to ~30 µm),
//      consistent with the 800 nm laser λ but >> it (driver/wakelength
//      separation is what defines the bubble regime).
//
// PASS = all cross-pillar anchors agree numerically.
// FAIL = any pair disagrees.
//
// Run:
//   hexa run verify/numerics_cross_pillar.hexa
//
// @no-lock-needed

use "self/runtime/math_pure"

let HOME = env("HOME")

fn _root() -> str {
    let r = env("PETITE_CERN_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-cern"
}

let ROOT = _root()

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

fn abs_rel_err(actual: float, target: float) -> float {
    let d = (actual - target) / target
    if d < 0.0 { return -d }
    return d
}

// ── physical / lattice constants ────────────────────────────────────────
let M_E      = 9.10938356e-31   // electron mass kg
let E_CHARGE = 1.602176634e-19
let EPS0     = 8.8541878128e-12
let C_LIGHT  = 2.99792458e8
let M_E_C2_MEV = 0.5109989461

let SIGMA = 12
let TAU   = 4
let PHI   = 2
let N     = 6

// ── pillar anchors (must match per-pillar numerics scripts) ─────────────
//
// mini (numerics_wakefield.hexa):
let MINI_E_PEAK_GV_PER_M = 120.0       // E_peak σ·(σ-φ)
let MINI_TARGET_MEV      = 100.0       // target electron energy
let MINI_LASER_LAMBDA_NM = 800.0       // Ti:Sapphire laser
//
// parent (numerics_sigma_cascade.hexa):
let PARENT_E_1_MEV       = 100.0       // cascade stage 1 = 100 MeV
let PARENT_E_2_MEV       = 1000.0      // cascade stage 2 = 1 GeV
//
// classical (numerics_classical.hexa):
let CLASSICAL_DOF_USED   = 2           // 1-DOF stub uses phase-space dim 2
let CLASSICAL_DOF_FULL   = SIGMA       // SE(3) full = σ = 12

// ── derived numerical quantities ────────────────────────────────────────

fn gamma_at_MeV(E_MeV: float) -> float {
    return 1.0 + E_MeV / M_E_C2_MEV
}

// reduced plasma wavelength λ_p = 2π c / ω_p with ω_p = e·E_peak / (m_e c)
// (cold-plasma wave-breaking field)
fn plasma_lambda_um_from_E_peak(E_peak_GV_per_m: float) -> float {
    let E_V_per_m = E_peak_GV_per_m * 1.0e9
    let omega_p = (E_CHARGE * E_V_per_m) / (M_E * C_LIGHT)
    let lambda_p_m = 2.0 * pi_pure() * C_LIGHT / omega_p
    return lambda_p_m * 1.0e6
}

// ── checks ──────────────────────────────────────────────────────────────

fn check_mini_parent_e1_match() {
    // mini's target energy must match parent's cascade stage 1.
    _check(MINI_TARGET_MEV == PARENT_E_1_MEV,
           "mini target == parent cascade E_1  (100 MeV ↔ 100 MeV)",
           "mini target = " + str(MINI_TARGET_MEV) + " MeV, " +
           "parent E_1 = " + str(PARENT_E_1_MEV) + " MeV")
}

fn check_gamma_at_e1() {
    let g = gamma_at_MeV(MINI_TARGET_MEV)
    let target = 1.0 + 100.0 / 0.5109989461
    let err = abs_rel_err(g, target)
    _check(err < 1.0e-9,
           "γ at 100 MeV consistent across pillars (γ ≈ 196.69)",
           "γ = " + str(g) + " (target = " + str(target) + ", rel err = " + str(err) + ")")
}

fn check_phase_space_subset() {
    // 1-DOF stub uses dim 2 ⊆ full SE(3) σ = 12.
    let ok = CLASSICAL_DOF_USED <= CLASSICAL_DOF_FULL
    _check(ok,
           "classical stub phase-space ⊆ Hamilton σ = 12  (1-DOF ⊆ 6-DOF SE(3))",
           "stub dim = " + str(CLASSICAL_DOF_USED) + ", full = " + str(CLASSICAL_DOF_FULL))
}

fn check_plasma_lambda_in_bubble_regime() {
    // λ_p should sit in the LWFA-bubble window (~10–50 µm typical).
    // Below 1 µm the plasma is overdense vs the laser; above 100 µm the
    // bubble is too large for benchtop scale.
    let lambda_um = plasma_lambda_um_from_E_peak(MINI_E_PEAK_GV_PER_M)
    let ok = lambda_um >= 1.0 && lambda_um <= 100.0
    _check(ok,
           "plasma λ_p in LWFA bubble window (1 ≤ λ_p ≤ 100 µm)",
           "λ_p = " + str(lambda_um) + " µm  (computed from E_peak = " + str(MINI_E_PEAK_GV_PER_M) + " GV/m)")
}

fn check_laser_vs_plasma_separation() {
    // Driver-pulse / wake-bubble separation: λ_laser << λ_p
    // 800 nm = 0.8 µm laser vs ~26 µm λ_p ⇒ ratio ~ 32 (well separated)
    let lambda_um = plasma_lambda_um_from_E_peak(MINI_E_PEAK_GV_PER_M)
    let lambda_laser_um = MINI_LASER_LAMBDA_NM / 1000.0
    let ratio = lambda_um / lambda_laser_um
    let ok = ratio >= 5.0
    _check(ok,
           "λ_p / λ_laser ≥ 5  (driver / bubble scale separation)",
           "ratio = " + str(ratio))
}

fn check_n6_lattice_consistent() {
    // All three pillars use the same n=6 constants.
    _check(SIGMA == 12 && TAU == 4 && PHI == 2 && N == 6,
           "n=6 lattice constants identical across pillar numerics",
           "σ=12, τ=4, φ=2, n=6")
}

fn check_chain_seed_decade_above_seed_lattice() {
    // Cascade E_0 = 10 MeV = sopfr·φ·10⁰ = 5·2 = 10  (n=6 derivation)
    // Verify both the algebraic (sopfr·φ) match and the gamma at E_0 ≈ 20.57.
    let sopfr_phi = 5 * 2
    _check(sopfr_phi == 10,
           "cascade seed E_0 = sopfr(6)·φ(6) = 5·2 = 10 MeV",
           "")
    let g0 = gamma_at_MeV(10.0)
    let ok = g0 > 20.0 && g0 < 21.0
    _check(ok,
           "γ_0 at E_0 = 10 MeV ≈ 20.57  (boundary between mildly- and ultra-relativistic)",
           "γ_0 = " + str(g0))
}

let FALSIFIERS = [
    "mini target ≠ parent E_1 -> chain seed disagrees, retract σ-cascade claim",
    "γ at 100 MeV computed differently in two pillars -> rest-mass tail bug",
    "classical stub uses phase-space > σ -> bigger than full SE(3) (impossible)",
    "λ_p outside 1–100 µm -> not LWFA bubble regime, n=6 derivation off",
    "λ_p / λ_laser < 5 -> driver / wake not separated, bubble not formed",
    "different n=6 lattice constants per pillar -> single-source-of-truth broken",
]

fn main() {
    println("========================================================================")
    println("  hexa-cern — cross-pillar numerical consistency")
    println("  (mini ↔ parent ↔ classical numerics agree on shared anchors)")
    println("========================================================================")
    println("")

    println("  shared anchors:")
    println("    mini.target          = " + str(MINI_TARGET_MEV) + " MeV   (electron exit energy)")
    println("    parent.E_1           = " + str(PARENT_E_1_MEV)   + " MeV   (cascade stage 1)")
    println("    parent.E_2           = " + str(PARENT_E_2_MEV)   + " MeV   (cascade stage 2)")
    println("    γ at 100 MeV         = " + str(gamma_at_MeV(100.0)))
    println("    plasma λ_p (from E_peak " + str(MINI_E_PEAK_GV_PER_M) + " GV/m)")
    println("                         = " + str(plasma_lambda_um_from_E_peak(MINI_E_PEAK_GV_PER_M)) + " µm")
    println("    classical stub dim   = " + str(CLASSICAL_DOF_USED) + "  ⊆ full SE(3) = " + str(CLASSICAL_DOF_FULL))
    println("")

    check_mini_parent_e1_match()
    check_gamma_at_e1()
    check_phase_space_subset()
    check_plasma_lambda_in_bubble_regime()
    check_laser_vs_plasma_separation()
    check_n6_lattice_consistent()
    check_chain_seed_decade_above_seed_lattice()

    println("")
    println("  FALSIFIERS (" + str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }
    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_CERN_NUMERICS_CROSS_PILLAR__ FAIL")
        exit(1)
    }
    println("__HEXA_CERN_NUMERICS_CROSS_PILLAR__ PASS")
    exit(0)
}
