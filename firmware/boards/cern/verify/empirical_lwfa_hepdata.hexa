#!hexa strict
// hexa-cern/verify/empirical_lwfa_hepdata.hexa — F-PCERN-3 T3 closure.
//
// Confirms that the published empirical-LWFA literature (BELLA, FACET-II,
// FLASHForward, generic 1 GeV/m wakefield) is real and findable. Under
// "HEPData" we use the **Inspire-HEP** literature API, which indexes
// the published high-energy / plasma-physics work (HEPData proper has
// less LWFA coverage; Inspire-HEP is the canonical paper index).
//
// Policy (per dancinlife 2026-05-08): API-first, fixture-fallback,
// both compared when available.
//   1. Try live Inspire-HEP query for each LWFA milestone.
//   2. Always fall back to bundled fixture under verify/fixtures/.
//   3. If both reachable, assert API total ≥ fixture total
//      (papers monotonically accumulate; never disappear).
//
// PASS = ≥ 3 of 4 milestone queries return ≥ 1 paper (proves the
//        empirical LWFA territory is real and indexed).
// FAIL = fewer than 3 milestones found across BOTH API and fixture.
//
// Queries (each cached as `verify/fixtures/lwfa_<slug>.json`):
//   - BELLA 8 GeV wakefield        (LBNL milestone)
//   - FACET-II 10 GeV plasma       (SLAC)
//   - FLASHForward GeV plasma      (DESY)
//   - laser wakefield 1 GeV/m      (generic envelope)
//
// Tier: F-PCERN-3 T3 (paper-existence empirical anchor). Strict
// raw-data fit deferred to roadmap §A.2 v2.0.0.
//
// Run:
//   hexa run verify/empirical_lwfa_hepdata.hexa
//
// @no-lock-needed

let HOME = env("HOME")

fn _root() -> str {
    let r = env("PETITE_CERN_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-cern"
}

let ROOT = _root()
let FIXTURE_DIR = ROOT + "/verify/fixtures"
let DOC_MINI = ROOT + "/mini/doc/mini-accelerator.md"

fn _read(p: str) -> str {
    if file_exists(p) == false { return "" }
    return read_file(p)
}

fn _has(t: str, s: str) -> bool {
    if t.len() == 0 { return false }
    return t.find(s) >= 0
}

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

fn _info(label: str, detail: str) {
    println("  [INFO] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ── milestone registry ──────────────────────────────────────────────────
//
// Each entry: (label, query string, fixture filename, min expected total).
let M_LABEL    = ["BELLA 8 GeV", "FACET-II 10 GeV", "FLASHForward GeV", "1 GeV/m wakefield"]
let M_QUERY    = ["BELLA+8+GeV+wakefield",
                  "FACET-II+10+GeV+plasma",
                  "FLASHForward+GeV+plasma",
                  "laser+wakefield+1+GeV/m"]
let M_FIXTURE  = ["lwfa_BELLA_8_GeV_wakefield.json",
                  "lwfa_FACET-II_10_GeV_plasma.json",
                  "lwfa_FLASHForward_GeV_plasma.json",
                  "lwfa_laser_wakefield_1_GeVm.json"]
let M_MIN_PAPERS = [1, 1, 1, 1]   // each milestone must have ≥ 1 paper

// ── API ─────────────────────────────────────────────────────────────────
let API_BASE = "https://inspirehep.net/api/literature?q="
let API_TAIL = "&size=3&fields=titles,publication_info"

fn fetch_api(query: str) -> str {
    let url = API_BASE + query + API_TAIL
    let cmd = "curl -s --max-time 10 '" + url + "' 2>/dev/null"
    return exec(cmd)
}

// Parse "total":N  (Inspire-HEP returns hits.total = number)
fn parse_total(json: str) -> int {
    let needle = "\"total\":"
    let idx = json.find(needle)
    if idx < 0 { return -1 }
    let n = json.len()
    let mut i = idx + needle.len()
    let mut digits = ""
    while i < n {
        let c = json[i]
        let is_digit = (c == "0" || c == "1" || c == "2" || c == "3" || c == "4" ||
                        c == "5" || c == "6" || c == "7" || c == "8" || c == "9")
        if is_digit { digits = digits + c; i = i + 1 } else { break }
    }
    if digits.len() == 0 { return -1 }
    return int(digits)
}

// ── checks ──────────────────────────────────────────────────────────────

fn check_network_reachable() -> bool {
    let probe = exec("curl -s --max-time 5 -o /dev/null -w '%{http_code}' https://inspirehep.net/ 2>/dev/null").trim()
    let ok = probe == "200" || probe == "301" || probe == "302"
    if !ok {
        _info("network unreachable to inspirehep.net  (offline mode)",
              "fixture-only path engaged; API totals not compared")
    } else {
        _info("network reachable to inspirehep.net  (api-vs-fixture compare engaged)",
              "http_code = " + probe)
    }
    return ok
}

fn check_milestone(idx: int, net_up: bool) -> bool {
    let label    = M_LABEL[idx]
    let query    = M_QUERY[idx]
    let fixture  = M_FIXTURE[idx]
    let min_pap  = M_MIN_PAPERS[idx]

    // fixture (always)
    let fix_path = FIXTURE_DIR + "/" + fixture
    let fix_text = _read(fix_path)
    let fix_total = if fix_text.len() > 0 { parse_total(fix_text) } else { -1 }

    // API (if network up)
    let api_total = if net_up {
        let api_text = fetch_api(query)
        if api_text.len() > 0 { parse_total(api_text) } else { -1 }
    } else { -1 }

    let fix_ok = fix_total >= min_pap
    let api_ok = api_total >= min_pap
    let either_ok = fix_ok || api_ok
    _check(either_ok,
           label + ": ≥ " + str(min_pap) + " paper(s) on Inspire-HEP",
           "fixture total = " + str(fix_total) + ", API total = " + str(api_total))

    // Cross-check: when both reachable, API total should be ≥ fixture total
    // (literature only grows; fixtures are snapshots).
    if api_total >= 0 && fix_total >= 0 {
        let monotone = api_total >= fix_total
        _check(monotone,
               label + ": API total ≥ fixture total  (literature monotone)",
               "Δ = " + str(api_total - fix_total))
    }

    return either_ok
}

fn check_pillar_doc_anchor() {
    let txt = _read(DOC_MINI)
    let ok = _has(txt, "wakefield") || _has(txt, "laser-plasma") || _has(txt, "LWFA")
    _check(ok, "mini doc references wakefield / laser-plasma / LWFA", "")
}

fn check_at_least_three_milestones(hits: int) {
    _check(hits >= 3,
           "≥ 3 of 4 LWFA milestones present (BELLA / FACET-II / FLASHForward / 1 GeV/m)",
           "milestone hits = " + str(hits) + " of 4")
}

let FALSIFIERS = [
    "fewer than 3 of 4 LWFA milestones return papers -> public LWFA literature is sparser than n=6 derivation assumes",
    "API total < fixture total -> Inspire-HEP literature shrank (record withdrawn or feed broken)",
    "no fixture present + no network -> T3 cannot close (offline + cold)",
    "mini doc loses LWFA / laser-plasma anchor -> empirical motivation broken",
]

fn main() {
    println("========================================================================")
    println("  hexa-cern mini — F-PCERN-3 T3 partial closure (Inspire-HEP literature)")
    println("  (LWFA milestone-paper existence check; raw-data fit deferred to v2.0.0)")
    println("========================================================================")
    println("")
    println("  policy: API-first, fixture-fallback, compare both when available")
    println("  fixture dir: " + FIXTURE_DIR)
    println("")

    // HEXA_CERN_OFFLINE=1 → fixture-only mode (skip API entirely).
    let offline = env("HEXA_CERN_OFFLINE") == "1"
    if offline {
        _info("HEXA_CERN_OFFLINE=1 → fixture-only mode (Inspire-HEP API skipped)",
              "no network probe, no live fetch; fixture-only path engaged")
    }
    let net_up = if offline { false } else { check_network_reachable() }

    let mut hits = 0
    let mut i = 0
    while i < M_LABEL.len() {
        let ok = check_milestone(i, net_up)
        if ok { hits = hits + 1 }
        i = i + 1
    }

    println("")
    check_at_least_three_milestones(hits)
    check_pillar_doc_anchor()

    println("")
    println("  FALSIFIERS (" + str(len(FALSIFIERS)) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }
    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_CERN_EMPIRICAL_LWFA_HEPDATA__ FAIL")
        exit(1)
    }
    println("__HEXA_CERN_EMPIRICAL_LWFA_HEPDATA__ PASS — F-PCERN-3 T3 (LWFA paper feed) closes")
    exit(0)
}
