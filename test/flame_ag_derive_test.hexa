// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// test/flame_ag_derive_test.hexa — flame autograd-auto SD1+SD2+SD3 byte-eq oracle
//
// Falsifiers:
//   F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ
//     matmul_bwd_auto(x, W, dy, …) output {dW, dx} byte-identical
//     (max|Δ| = 0.0) to nn_linear_bwd's {dW, dx} on a fixed-seed input
//     B=4·D=8·C=6.                                              (SD1)
//   F-RFC043-AUTOGRAD-AUTO-ADD-BYTE-EQ
//     add_bwd_auto(x, b, dy, …) output {db} byte-identical
//     (max|Δ| = 0.0) to nn_linear_bwd's {db} on the same fixed-seed
//     input B=4·D=8·C=6 (re-using SD1's dy and shapes for parallelism
//     across the matmul ⊕ broadcast-bias-add halves of nn_linear).
//                                                                (SD2)
//   F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ
//     silu_gate_bwd_auto(a, b, ds, …) output {da, db} byte-identical
//     (max|Δ| = 0.0) to the closed-form silu-gate vjp reference (the
//     same formula `ag_tape::ag_backward_reg`'s silu_gate case uses,
//     lines 742–757; equivalently `nn_swiglu_bwd` lines 446–452). The
//     reference computation lives in this test file using the same
//     `dt_exp`-based sigmoid as `flame_math::dt_exp` to guarantee
//     identical IEEE-754 trajectories.                            (SD3)
//
// Scope (matches inbox/notes/2026-05-20-flame-autograd-auto-scoping.md):
//   - Pure-CPU, $0, three oracles in one binary.
//   - SD1 compares ag_derive's matmul_bwd_auto OUTPUT against
//     nn_linear_bwd's {dW, dx} (matmul vjp pair).
//   - SD2 compares ag_derive's add_bwd_auto OUTPUT against
//     nn_linear_bwd's {db} (broadcast-bias vjp = reduce-sum along
//     axis=0). The dx-half of the bias-add vjp is the identity
//     adjoint (dy verbatim), so the SD2 oracle is solely db.
//   - SD3 compares ag_derive's silu_gate_bwd_auto OUTPUT against an
//     in-test closed-form reference (the same `da/db` formula
//     `ag_tape`'s silu_gate backward case emits). The fwd primitive
//     is the elementwise `s[i] = silu(a[i]) · b[i]` (SwiGLU's middle
//     stage; ag_tape's `ag_k_silu_gate`). NO matrix dims — pure
//     elementwise over `len`. Fixed-seed inputs `a`, `b`, `ds`.
//   - The fwd is `y = x · W + b` decomposed: `farr_matmul` directly
//     produces y0 = x · W (SD1's regime), then the bias broadcast
//     `y[i,j] += b[j]` is the surface SD2's rule targets. The two
//     halves are independent vjps that compose in nn_linear_bwd; SD2
//     keeps them independent here. SD3 is a separate primitive
//     (gated SiLU activation, no linear involved).
//
// Exit codes (rfc_003 idiom):
//   0  PASS — SD1 + SD2 + SD3 oracles all PASS (max|Δ|=0 across
//             {dW, dx, db_add, da_silu, db_silu} − reference).
//   91 FAIL — any register/dispatch/byte-eq fail.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/flame_math"
use "stdlib/flame/ag_derive"

fn ag_dt_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ag_dt_maxdev(a: int, b: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let d = ag_dt_abs(t_get(a, i) - t_get(b, i))
        if d > m { m = d }
        i = i + 1
    }
    return m
}

// ─── fixed-seed inputs (scoping note §3 + task brief) ──────────────────
//   B = 4, D = 8, C = 6 — same shape pattern as Test 2 in
//   flame_ag_tape_test (the simple-linear sanity case the scope
//   references). LCG seed bases chosen for stability:
//     x  seed = 1337 * 7 + 13 = 9372   (same scheme as flame_nn_test
//                                       check_linear, just a different
//                                       base seed so SD1's oracle is
//                                       NOT colored by an existing
//                                       known-pass dataset)
//     W  seed = 1337
//     dy seed = 31337               (same as flame_nn_test check_linear)

println("=== flame autograd-auto SD1 selftest (ag_derive · matmul vjp byte-eq) ===")

let B = 4
let D = 8
let C = 6

let x = t_zeros(B * D)
t_fill_lcg(x, B * D, 1337 * 7 + 13, 1.0)
let W = t_zeros(D * C)
t_fill_lcg(W, D * C, 1337, 0.5)
let dy = t_zeros(B * C)
t_fill_lcg(dy, B * C, 31337, 1.0)

// ─── reference: hand-written nn_linear_bwd ─────────────────────────────
// nn_linear_bwd writes dW, dx, db; we extract dW + dx only (SD1 scope).
let dW_ref = t_zeros(D * C)
let dx_ref = t_zeros(B * D)
let db_ref = t_zeros(C)
nn_linear_bwd(x, W, dy, dW_ref, dx_ref, db_ref, B, D, C)

// ─── candidate: ag_derive · matmul_bwd_auto ────────────────────────────
let reg = ag_derive_registry_new()
let reg_rc = ag_derive_register(reg, ag_derive_k_matmul())
if reg_rc == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ  registry rejected matmul kind")
    exit(91)
}
let is_reg = ag_derive_is_registered(reg, ag_derive_k_matmul())
if is_reg == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ  registry lookup returned 0 after register")
    exit(91)
}

let dW_auto = t_zeros(D * C)
let dx_auto = t_zeros(B * D)
let dispatch_rc = matmul_bwd_auto(reg, x, W, dy, dW_auto, dx_auto, B, D, C)
if dispatch_rc == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ  matmul_bwd_auto dispatch returned 0")
    exit(91)
}

// ─── byte-eq oracle ────────────────────────────────────────────────────
let dW_dev = ag_dt_maxdev(dW_auto, dW_ref, D * C)
let dx_dev = ag_dt_maxdev(dx_auto, dx_ref, B * D)

print("dW max|Δ| = ")
print(dW_dev)
println("")
print("dx max|Δ| = ")
print(dx_dev)
println("")

if dW_dev == 0.0 {
    if dx_dev == 0.0 {
        println("PASS  F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ  max|{dW, dx}_auto − {dW, dx}_ref| = 0.0 (byte-eq · matmul-vjp registry rule ≡ nn_linear_bwd hand-written reference)")
    } else {
        println("FAIL  F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ  dx deviation non-zero")
        exit(91)
    }
} else {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-MATMUL-BYTE-EQ  dW deviation non-zero")
    exit(91)
}

// ─── SD2: broadcast bias-add vjp byte-eq oracle ────────────────────────
// Same registry, same fixed-seed dy, same shapes B=4·D=8·C=6. We
// register ag_derive_k_add() and call add_bwd_auto. The bias `b`
// (length C) is generated with a third LCG base so it is independent
// of x, W, dy.
//
// Reference `db_ref` was already produced by `nn_linear_bwd` above —
// SD2's oracle is simply: does add_bwd_auto's db_auto equal db_ref
// byte-for-byte?

println("=== flame autograd-auto SD2 selftest (ag_derive · add vjp byte-eq) ===")

// b is length C; LCG base 4242 — distinct from x(9372)/W(1337)/dy(31337).
// The closed-form vjp does not READ b (db = Σ_i dy[i,j] only), but we
// still allocate + fill it so the add_bwd_auto surface gets a real
// tensor id (parity with SD4's future tape integration where b WILL be
// a recorded input).
let bb = t_zeros(C)
t_fill_lcg(bb, C, 4242, 0.25)

let reg_add_rc = ag_derive_register(reg, ag_derive_k_add())
if reg_add_rc == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-ADD-BYTE-EQ  registry rejected add kind")
    exit(91)
}
let is_reg_add = ag_derive_is_registered(reg, ag_derive_k_add())
if is_reg_add == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-ADD-BYTE-EQ  registry lookup returned 0 after register")
    exit(91)
}

let db_auto = t_zeros(C)
let add_dispatch_rc = add_bwd_auto(reg, x, bb, dy, db_auto, B, C)
if add_dispatch_rc == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-ADD-BYTE-EQ  add_bwd_auto dispatch returned 0")
    exit(91)
}

let db_dev = ag_dt_maxdev(db_auto, db_ref, C)
print("db max|Δ| = ")
print(db_dev)
println("")

if db_dev == 0.0 {
    println("PASS  F-RFC043-AUTOGRAD-AUTO-ADD-BYTE-EQ  max|db_auto − db_ref| = 0.0 (byte-eq · broadcast-bias-add vjp registry rule ≡ nn_linear_bwd db-block reference)")
} else {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-ADD-BYTE-EQ  db deviation non-zero")
    exit(91)
}

// ─── SD3: elementwise silu_gate vjp byte-eq oracle ─────────────────────
// Fwd: s[i] = silu(a[i]) · b[i]   (i ∈ [0, len)) — the elementwise
// gated-SiLU primitive at the core of SwiGLU. Closed-form vjp:
//   da[i] = ds[i] · b[i] · silu'(a[i])
//   db[i] = ds[i] · silu(a[i])
// where silu(x) = x·σ(x), σ(x) = 1/(1+exp(-x)), silu'(x) = σ + x·σ·(1-σ).
//
// Reference: an in-test closed-form computation using the SAME
// `dt_exp`-based sigmoid that flame's ag_tape silu_gate case uses
// (`ag_tape.hexa`'s `_ag_sigmoid`/`_ag_silu_grad`/`_ag_silu`, lines
// 488–492). We mirror those helpers here locally so the byte-eq
// comparison traverses identical IEEE-754 operations — i.e. the SD3
// rule body and the test reference both reduce via `flame_math::dt_exp`
// and the same product-rule expansion in the same order.
//
// Fixed-seed inputs:
//   len = 24                                   (small but non-trivial)
//   a  seed = 9001    scale = 1.0      ∈ ≈ [-1, 1]
//   b  seed = 2718    scale = 0.5      ∈ ≈ [-0.5, 0.5]
//   ds seed = 16180   scale = 1.0      ∈ ≈ [-1, 1]
// The scales keep |a| well inside dt_exp's stable Taylor band, but
// nothing in the gate hinges on numerical-range — byte-eq does not
// care about magnitude.

println("=== flame autograd-auto SD3 selftest (ag_derive · silu_gate vjp byte-eq) ===")

let len3 = 24

let a3  = t_zeros(len3)
t_fill_lcg(a3, len3, 9001, 1.0)
let b3  = t_zeros(len3)
t_fill_lcg(b3, len3, 2718, 0.5)
let ds3 = t_zeros(len3)
t_fill_lcg(ds3, len3, 16180, 1.0)

// ─── SD3 reference: closed-form silu-gate vjp using dt_exp ─────────────
// (mirrors ag_tape.hexa::_ag_sigmoid/_ag_silu/_ag_silu_grad; the SD3
// rule body in ag_derive.hexa uses the same formula via
// _ag_derive_silu/_ag_derive_silu_grad — therefore byte-eq.)

let da_ref = t_zeros(len3)
let db_ref3 = t_zeros(len3)
let mut ii = 0
while ii < len3 {
    let av  = t_get(a3, ii)
    let dsk = t_get(ds3, ii)
    // sigmoid(av) via dt_exp (flame_math)
    let sg  = 1.0 / (1.0 + dt_exp(0.0 - av))
    let silu_av    = av * sg
    let silu_g_av  = sg + av * sg * (1.0 - sg)
    t_set(da_ref, ii, dsk * t_get(b3, ii) * silu_g_av)
    t_set(db_ref3, ii, dsk * silu_av)
    ii = ii + 1
}

// ─── SD3 candidate: ag_derive · silu_gate_bwd_auto ─────────────────────
let reg_silu_rc = ag_derive_register(reg, ag_derive_k_silu_gate())
if reg_silu_rc == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ  registry rejected silu_gate kind")
    exit(91)
}
let is_reg_silu = ag_derive_is_registered(reg, ag_derive_k_silu_gate())
if is_reg_silu == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ  registry lookup returned 0 after register")
    exit(91)
}

let da_auto = t_zeros(len3)
let db_auto3 = t_zeros(len3)
let silu_dispatch_rc = silu_gate_bwd_auto(reg, a3, b3, ds3, da_auto, db_auto3, len3)
if silu_dispatch_rc == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ  silu_gate_bwd_auto dispatch returned 0")
    exit(91)
}

let da_dev = ag_dt_maxdev(da_auto, da_ref, len3)
let db3_dev = ag_dt_maxdev(db_auto3, db_ref3, len3)

print("da max|Δ| = ")
print(da_dev)
println("")
print("db max|Δ| = ")
print(db3_dev)
println("")

if da_dev == 0.0 {
    if db3_dev == 0.0 {
        println("PASS  F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ  max|{da, db}_auto − {da, db}_ref| = 0.0 (byte-eq · silu-gate-vjp registry rule ≡ ag_tape silu_gate closed-form reference)")
        println("=== SD1 + SD2 + SD3 PASS ===")
        exit(0)
    } else {
        println("FAIL  F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ  db deviation non-zero")
        exit(91)
    }
} else {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SILU-GATE-BYTE-EQ  da deviation non-zero")
    exit(91)
}
