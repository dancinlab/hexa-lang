// test/symmetric_group_s6_smoke.hexa — smoke for symbolic/symmetric_group_s6.hexa
//
// @version 0.1.0
// @capabilities [pure]
//
// Reference values from symmetric_group_s6.py (archive-TECS-L/.shared/calc,
// commit 4ee05c39):
//   6! = 720 ; C(6,2)=15 ; C(6,3)=20 ; C(2n,n)/(n+1)…(catalan elsewhere)
//   partition counts p(0..6) = 1,1,2,3,5,7,11  (p(6)=11)
//   |Aut(S₆)| = 2·6! = 1440 ; |Out(S₆)| = 2 (S₆ unique outer-automorphism)
//   transpositions C(6,2)=15 = 2^τ(6)−1 = 2⁴−1 (Mersenne)
//   C(n,2)=2^k−1 (triangular-Mersenne) exhaustive : {2,3,6,91} in [2,2000]
//   p(6)=11 = sopfr(28) = sopfr(P₂)
//   6! = 720 = n·σ·sopfr·φ = 6·12·5·2
//
// Run:  hexa run test/symmetric_group_s6_smoke.hexa
// Sentinel: __S6_SMOKE__ PASS|FAIL on the final line.

import "compiler/atlas/symbolic/symmetric_group_s6.hexa"

let mut PASS = 0
let mut FAIL = 0

fn check(label: string, cond: bool) {
    if cond {
        PASS = PASS + 1
        println("[PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("[FAIL] " + label)
    }
}

// ── primitives ──────────────────────────────────────────────────────────
check("6! == 720",       s6_factorial(6) == 720)
check("0! == 1",         s6_factorial(0) == 1)
check("C(6,2) == 15",    s6_binomial(6, 2) == 15)
check("C(6,3) == 20",    s6_binomial(6, 3) == 20)
check("C(10,5) == 252",  s6_binomial(10, 5) == 252)
check("C(6,0) == 1",     s6_binomial(6, 0) == 1)
check("C(6,7) == 0",     s6_binomial(6, 7) == 0)

// ── partition count p(n) — pentagonal recurrence ─────────────────────────
check("p(0) == 1",  s6_partition_count(0) == 1)
check("p(1) == 1",  s6_partition_count(1) == 1)
check("p(4) == 5",  s6_partition_count(4) == 5)
check("p(5) == 7",  s6_partition_count(5) == 7)
check("p(6) == 11", s6_partition_count(6) == 11)
check("p(10) == 42", s6_partition_count(10) == 42)
check("p(20) == 627", s6_partition_count(20) == 627)

// ── S₆ outer-automorphism exceptionality ─────────────────────────────────
check("|Aut(S₆)| == 1440 (= 2·6!)", s6_aut_order() == 1440)
check("|Out(S₆)| == 2", s6_out_order() == 2)
check("S₆ unique outer-automorphism witness", s6_is_unique_outer(20))

// ── transpositions = 2^τ(6)−1 (Mersenne) ─────────────────────────────────
check("transpositions C(6,2) == 15", s6_transpositions() == 15)
check("2^τ(6)−1 == 15", s6_mersenne_tau6() == 15)
check("C(6,2) is Mersenne 2^4−1", s6_transposition_is_mersenne())

// ── C(n,2) = 2^k−1 exhaustive : {2, 6} ───────────────────────────────────
check("15 is Mersenne (2^4−1)", s6_is_mersenne_number(15))
check("1 is Mersenne (2^1−1)",  s6_is_mersenne_number(1))
check("14 not Mersenne",        !s6_is_mersenne_number(14))
let sols = s6_cn2_mersenne_solutions(2000)
check("C(n,2)=2^k−1 → {2,3,6,91} (n=6 present; honest set)",
      len(sols) == 4 && sols[0] == 2 && sols[1] == 3 && sols[2] == 6 && sols[3] == 91)

// ── representation theory + factorial capacity ───────────────────────────
check("sopfr(28) == 11 (2+2+7)", s6_sopfr(28) == 11)
check("p(6)==11==sopfr(28)==sopfr(P₂)", s6_p6_eq_sopfr28())
check("6! = 720 = 6·12·5·2 (n·σ·sopfr·φ)", s6_factorial_capacity_identity())

println("")
println("═══════════════════════════════════════════════════════════")
println("  symmetric_group_s6 smoke: PASS=" + str(PASS) + " FAIL=" + str(FAIL))
println("═══════════════════════════════════════════════════════════")
if FAIL > 0 {
    println("__S6_SMOKE__ FAIL")
} else {
    println("__S6_SMOKE__ PASS")
}
