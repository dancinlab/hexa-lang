// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// test/flame_ag_extract_sd12_compile_test.hexa — flame autograd-auto SD12
//
// Falsifier:
//   F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ
//     The reverse walker's emit step produces hexa source that is
//     ACTUALLY COMPILABLE and ACTUALLY RUNNABLE for a TWO-INPUT fwd
//     `f(x, y) = x * y` — generalising SD11's relu single-Param round
//     trip. Concretely the SD9 reverse_walk_v2 on the bilinear MUL
//     produces (one per target Param) a bwd AST whose
//     `ag_extract_emit_program_xy_dy` rendering is written to
//     `/tmp/sd12_x_bwd.hexa` and `/tmp/sd12_y_bwd.hexa`. Each builds via
//     `hexa.real build` (the canonical hexa-native toolchain verb,
//     AGENTS.tape n1) and invokes as
//     `/tmp/sd12_{x,y}_bwd <x_repr> <y_repr> <dy_repr>` for each
//     LCG-seeded (x, y, dy) triple (len=32). The resulting
//     `dx_compiled[i]` / `dyg_compiled[i]` round-trip via `.to_float()`
//     to a bit-identical scalar against:
//       (A) the in-process AST-interpret value `ag_extract_interpret_v2_multi`
//           on the SAME bwd AST, and
//       (B) the hand-derived reference (Option-A reorder-match the SD9
//           manual uses: `(dy * y) + 0.0` for df/dx, `0.0 + (dy * x)`
//           for df/dy).
//     All three columns byte-eq across all 32 triples for BOTH Params:
//       dx_compiled  ≡ dx_interp  ≡ dx_hand   (max|Δ| = 0.0)
//       dyg_compiled ≡ dyg_interp ≡ dyg_hand  (max|Δ| = 0.0)
//
// Why this matters (task brief north-star ① — multi-input compile-and-run):
//   SD11 closed the loop end-to-end for the SIMPLEST case (relu, single
//   Param, pure conditional). SD12 lifts that to the SIMPLEST non-trivial
//   MULTI-INPUT case — bilinear MUL. The new emit shape is
//   `(x: float, y: float, dy: float) -> float` (vs SD11's `(x, dy)`),
//   the new argv reader takes 3 floats, and the harness coordinates
//   TWO binaries (one per Param direction) instead of one. Three-way
//   byte-eq across both Params is the measured proof that the
//   walker-emit-compile-run round-trip generalises to multi-input fwds.
//
// Honest scope (task brief §5, g3):
//   SD12 PROVES: multi-input compile-and-run for `f(x, y) = x * y` —
//   the simplest non-trivial 2-Param fwd. The SD9 reverse walker's bwd
//   AST contains `Var_FwdResult` nodes that REFERENCE PARAMS (because
//   the bilinear MUL's children ARE Params); SD12's `emit_expr_xy`
//   resolves those references to their argv-bound identifiers ("x", "y").
//   SD12 does NOT prove: compile-and-run for fwds whose bwd AST has
//   `Var_FwdResult` pointing to a NON-Param intermediate (sigmoid /
//   sigmoid-div / multi-use — SD6/7/10 paths); those need fwd-cache
//   materialisation INSIDE the emitted main(), which is SD13+ work.
//
// Round-trip invariant for byte-eq:
//   compiled_binary(json_stringify(x), json_stringify(y), json_stringify(dy))
//     .first_line_as_float()
//     ≡  ag_extract_interpret_v2_multi(arena, bwd_root, param_vals,
//                                       dy, fwd_cache)
//     ≡  hand_reference(x, y, dy)
//   because (a) hexa runtime's `json_stringify(f)` routes through
//   `_shortest_double` (runtime.c:7909) — the shortest %g-form decimal
//   that strtod-round-trips to the SAME binary64 (loops 1..17 digits,
//   checking each via strtod); (b) `.to_float()` / `argv[i].to_float()`
//   routes to strtod, parsing the shortest-roundtrip text back to the
//   identical bit pattern; (c) `emit_expr_xy` replaces
//   `Var_FwdResult(Param(ix))` with the corresponding identifier
//   (`x` for ix=0, `y` for ix=1); the bilinear fwd-cache evaluation
//   (`ag_extract_eval_fwd_multi` §Param branch) writes
//   `param_vals[ix]` into `fwd_cache[node]` and returns it verbatim —
//   IEEE-754 byte-eq because no arithmetic intervenes.
//
// NOTE on the `_fwd<id>` symbol (SD12+ stop-condition):
//   `emit_expr_xy` falls back to the SD11 `_fwd<id>` lexeme if the
//   Var_FwdResult's target is NOT a Param. That keeps SD13+ shapes
//   (sigmoid, sigmoid-div) failing as a CLEARLY VISIBLE compile error
//   (undefined identifier) rather than silently producing wrong
//   gradients. SD13 must add the fwd-cache materialisation step.
//
// Atlas cite:
//   Griewank & Walther §3.2 Algorithm 3.6 (reverse-mode AD emit) +
//   IEEE-754 binary64 round-trip lemma (Steele & White 1990, "How to
//   print floating-point numbers accurately" — 17 decimal digits
//   suffice for double-precision round-trip).
//
// Exit codes:
//   0  PASS — F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ green.
//   91 FAIL — hexa-build of an emitted source failed (compile error;
//             walker likely emits source missing imports or syntax).
//   92 FAIL — compiled-binary invocation failed (binary missing or
//             non-zero rc).
//   93 FAIL — three-way byte-eq broke on at least one input triple
//             for at least one Param direction.
//
// CPU-only, $0. Surgical — only stdlib/flame/ag_extract.hexa helpers
// (`ag_extract_emit_expr_xy`, `ag_extract_emit_program_xy_dy`) + this
// test + stdlib/flame/PLAN.md.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/ag_extract"

fn sd12_dt_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Hand-derived references — Option-A reorder-match (SD9 manual idiom):
// the SD9 reverse walker emits `mk_binop_add(ga, gb)` for the bilinear
// MUL, with `ga = dc_b` for the matched-Param branch and `gb = 0.0` (or
// vice versa for the other Param). For target=0 (df/dx) the order is
// `(dy * y_cached) + 0.0`; for target=1 (df/dy) the order is
// `0.0 + (dy * x_cached)`. Same `*` order, same `+` order — no
// factoring; same IEEE-754 trajectory as `interpret_v2_multi` on the
// same bwd AST.
fn bwd_x_hand(x: float, y: float, dy: float) -> float {
    let t1 = dy * y
    let t2 = 0.0
    return t1 + t2
}

fn bwd_y_hand(x: float, y: float, dy: float) -> float {
    let t1 = 0.0
    let t2 = dy * x
    return t1 + t2
}

println("=== flame autograd-auto SD12 selftest (ag_extract · multi-input walker-emit → hexa-build → compiled-binary round-trip byte-eq · bilinear f(x,y) = x*y) ===")

// ─── step 1: build bilinear fwd + reverse walk both Params ─────────────
let arena = ag_extract_arena_new()
let cache_meta = t_zeros(4)
let fwd_root = ag_extract_build_bilinear_fwd(arena, cache_meta)
println("bilinear fwd AST built — root (MUL) node id = " + to_string(fwd_root))
println("  param slots: x=" + to_string(to_int(t_get(cache_meta, 1)))
      + ", y=" + to_string(to_int(t_get(cache_meta, 2))))

// One upstream node per direction (each bwd AST holds its own Var_Upstream
// — independent of the target Param direction, but a fresh node keeps
// arena topology clean per SD9's idiom).
let upstream_x = ag_extract_mk_var_upstream(arena)
let bwd_x_root = ag_extract_reverse_walk_v2(arena, fwd_root, upstream_x, 0)
println("reverse-mode walk v2 (target=x · Param(0)) complete — bwd_x root id = " + to_string(bwd_x_root))

let upstream_y = ag_extract_mk_var_upstream(arena)
let bwd_y_root = ag_extract_reverse_walk_v2(arena, fwd_root, upstream_y, 1)
println("reverse-mode walk v2 (target=y · Param(1)) complete — bwd_y root id = " + to_string(bwd_y_root))

// ─── step 2: emit BOTH bwd programs and print them ─────────────────────
// The SD12 `emit_program_xy_dy` helper renders `(x, y, dy) -> float`
// plus an `fn main()` argv reader for 3 floats. Var_FwdResult(Param(ix))
// is resolved to the identifier (x/y) by `emit_expr_xy`.
let src_x = ag_extract_emit_program_xy_dy(arena, bwd_x_root, "f_x_bwd_auto")
let src_y = ag_extract_emit_program_xy_dy(arena, bwd_y_root, "f_y_bwd_auto")
println("emitted hexa-lang program (df/dx — bilinear MUL, target=Param(0)):")
println("--- BEGIN /tmp/sd12_x_bwd.hexa ---")
println(src_x)
println("--- END /tmp/sd12_x_bwd.hexa ---")
println("emitted hexa-lang program (df/dy — bilinear MUL, target=Param(1)):")
println("--- BEGIN /tmp/sd12_y_bwd.hexa ---")
println(src_y)
println("--- END /tmp/sd12_y_bwd.hexa ---")

// ─── step 3: write both sources + locate hexa.real ─────────────────────
let src_x_path = "/tmp/sd12_x_bwd.hexa"
let bin_x_path = "/tmp/sd12_x_bwd"
let src_y_path = "/tmp/sd12_y_bwd.hexa"
let bin_y_path = "/tmp/sd12_y_bwd"
write_file(src_x_path, src_x)
write_file(src_y_path, src_y)
println("wrote emitted sources to " + src_x_path + " + " + src_y_path)

// Resolve hexa.real via the SD11 3-tier fallback: (a) $HEXA_LANG/hexa.real
// (main repo layout — worktrees inherit nothing); (b) ~/.hx/bin/hexa_real
// (the installed toolchain symlink); (c) /Users/ghost/core/hexa-lang/hexa.real
// (canonical absolute fallback). First-found wins.
let hexa_lang_dir = env("HEXA_LANG")
let mut hexa_real_bin = ""
if len(hexa_lang_dir) > 0 {
    let cand_a = hexa_lang_dir + "/hexa.real"
    if file_exists(cand_a) { hexa_real_bin = cand_a }
}
if len(hexa_real_bin) == 0 {
    let home = env("HOME")
    if len(home) > 0 {
        let cand_b = home + "/.hx/bin/hexa_real"
        if file_exists(cand_b) { hexa_real_bin = cand_b }
    }
}
if len(hexa_real_bin) == 0 {
    let cand_c = "/Users/ghost/core/hexa-lang/hexa.real"
    if file_exists(cand_c) { hexa_real_bin = cand_c }
}
if len(hexa_real_bin) == 0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  cannot locate hexa.real toolchain binary — tried $HEXA_LANG/hexa.real, $HOME/.hx/bin/hexa_real, /Users/ghost/core/hexa-lang/hexa.real. Install hexa-lang or set HEXA_LANG to the repo root.")
    exit(91)
}
println("resolved hexa.real -> " + hexa_real_bin)

// ─── step 4: hexa.real build BOTH emitted programs ─────────────────────
// `exec()` with `2>&1; echo __RC=$?` (single combined pipe via popen,
// out-of-band rc surfacing) — same SD11 pattern that dodges
// `exec_capture`'s alternating-blocking-read deadlock on heavy stdout.
let _ = exec("rm -f " + bin_x_path + " " + bin_y_path + " 2>/dev/null")

let build_cmd_x = hexa_real_bin + " build " + src_x_path + " -o " + bin_x_path
                + " 2>&1; echo __RC=$?"
println("running: " + build_cmd_x)
let bx_combined = to_string(exec(build_cmd_x))
let bx_rc_at = bx_combined.index_of("__RC=")
let mut bx_rc = 1
let mut bx_stdout = bx_combined
if bx_rc_at >= 0 {
    let rc_tail = bx_combined.substring(bx_rc_at + 5, len(bx_combined)).trim()
    try { bx_rc = to_int(rc_tail) } catch e { bx_rc = 1 }
    bx_stdout = bx_combined.substring(0, bx_rc_at)
}
println("build_x rc = " + to_string(bx_rc))
if bx_rc != 0 {
    println("build_x combined output (merged stdout+stderr):")
    println(bx_stdout)
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  hexa-build failed (rc=" + to_string(bx_rc) + ") on emitted df/dx source — walker emit may be missing imports / syntax. See diagnostic above.")
    exit(91)
}
if file_exists(bin_x_path) == false {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  build_x rc=0 but binary " + bin_x_path + " is missing (toolchain misroute?).")
    exit(91)
}
println("build_x OK — binary at " + bin_x_path)

let build_cmd_y = hexa_real_bin + " build " + src_y_path + " -o " + bin_y_path
                + " 2>&1; echo __RC=$?"
println("running: " + build_cmd_y)
let by_combined = to_string(exec(build_cmd_y))
let by_rc_at = by_combined.index_of("__RC=")
let mut by_rc = 1
let mut by_stdout = by_combined
if by_rc_at >= 0 {
    let rc_tail = by_combined.substring(by_rc_at + 5, len(by_combined)).trim()
    try { by_rc = to_int(rc_tail) } catch e { by_rc = 1 }
    by_stdout = by_combined.substring(0, by_rc_at)
}
println("build_y rc = " + to_string(by_rc))
if by_rc != 0 {
    println("build_y combined output (merged stdout+stderr):")
    println(by_stdout)
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  hexa-build failed (rc=" + to_string(by_rc) + ") on emitted df/dy source — walker emit may be missing imports / syntax. See diagnostic above.")
    exit(91)
}
if file_exists(bin_y_path) == false {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  build_y rc=0 but binary " + bin_y_path + " is missing (toolchain misroute?).")
    exit(91)
}
println("build_y OK — binary at " + bin_y_path)

// ─── step 5: fixed-seed inputs (len=32, two-axis: x · y · dy) ─────────
// LCG seeds match SD9's `test/flame_ag_extract_test.hexa` so the input
// domain mirrors the proven SD9 byte-eq corpus.
//   x_arr: seed 4242, scale 2.0, shift -1.0  →  [-1, 1]
//   y_arr: seed 70707, scale 2.0, shift -1.0 →  [-1, 1]
//   dy_arr: seed 31337, scale 1.0            →  [0, 1)
let LEN = 32

let x_arr = t_zeros(LEN)
t_fill_lcg(x_arr, LEN, 4242, 2.0)
let mut i_x_shift = 0
while i_x_shift < LEN {
    t_set(x_arr, i_x_shift, t_get(x_arr, i_x_shift) - 1.0)
    i_x_shift = i_x_shift + 1
}

let y_arr = t_zeros(LEN)
t_fill_lcg(y_arr, LEN, 70707, 2.0)
let mut i_y_shift = 0
while i_y_shift < LEN {
    t_set(y_arr, i_y_shift, t_get(y_arr, i_y_shift) - 1.0)
    i_y_shift = i_y_shift + 1
}

let dy_arr = t_zeros(LEN)
t_fill_lcg(dy_arr, LEN, 31337, 1.0)

// Sanity span check — both Param directions must hit both signs so the
// byte-eq guarantee covers the full IEEE-754 corpus, not just the
// positive quadrant.
let mut nx_pos = 0
let mut nx_neg = 0
let mut ny_pos = 0
let mut ny_neg = 0
let mut i_chk = 0
while i_chk < LEN {
    let xv = t_get(x_arr, i_chk)
    let yv = t_get(y_arr, i_chk)
    if xv > 0.0 { nx_pos = nx_pos + 1 }
    if xv < 0.0 { nx_neg = nx_neg + 1 }
    if yv > 0.0 { ny_pos = ny_pos + 1 }
    if yv < 0.0 { ny_neg = ny_neg + 1 }
    i_chk = i_chk + 1
}
println("input span: x=" + to_string(nx_pos) + "/" + to_string(nx_neg) + " (+/−), y=" + to_string(ny_pos) + "/" + to_string(ny_neg) + " (+/−)")

// ─── step 6: three-way evaluation loop, two Param directions ──────────
// For each i ∈ [0, LEN) and each Param direction p ∈ {x, y}:
//   d_interp[i]   = ag_extract_interpret_v2_multi(arena, bwd_p_root, ...)  (oracle A)
//   d_hand[i]     = bwd_p_hand(x, y, dy)                                    (oracle B)
//   d_compiled[i] = parse_stdout(exec(bin_p + " " + x + " " + y + " " + dy)) (oracle C)
// PASS condition: max|A-B| = max|A-C| = max|B-C| = 0.0 for BOTH p.
let dx_interp_arr   = t_zeros(LEN)
let dx_hand_arr     = t_zeros(LEN)
let dx_compiled_arr = t_zeros(LEN)
let dyg_interp_arr   = t_zeros(LEN)
let dyg_hand_arr     = t_zeros(LEN)
let dyg_compiled_arr = t_zeros(LEN)

// `param_vals` and `fwd_cache` are reusable per-i scratch — overwritten
// fresh per i to keep interpret_v2_multi's IEEE-754 trajectory identical
// to the SD9 driver's per-element loop.
let fwd_cache  = t_zeros(64)
let param_vals = t_zeros(2)

let mut i = 0
while i < LEN {
    let xi  = t_get(x_arr, i)
    let yi  = t_get(y_arr, i)
    let dyi = t_get(dy_arr, i)

    // Populate fwd cache + param_vals for this i (matches the SD9
    // driver's pattern: write [x, y] into param_vals then run
    // eval_fwd_multi to populate the fwd_cache used by
    // interpret_v2_multi).
    t_set(param_vals, 0, xi)
    t_set(param_vals, 1, yi)
    let _ = ag_extract_eval_fwd_multi(arena, fwd_root, param_vals, fwd_cache)

    // oracle A — in-process AST interpret
    let dx_a = ag_extract_interpret_v2_multi(arena, bwd_x_root, param_vals, dyi, fwd_cache)
    t_set(dx_interp_arr, i, dx_a)
    let dy_a = ag_extract_interpret_v2_multi(arena, bwd_y_root, param_vals, dyi, fwd_cache)
    t_set(dyg_interp_arr, i, dy_a)

    // oracle B — hand-derived Option-A reorder-match
    let dx_b = bwd_x_hand(xi, yi, dyi)
    t_set(dx_hand_arr, i, dx_b)
    let dy_b = bwd_y_hand(xi, yi, dyi)
    t_set(dyg_hand_arr, i, dy_b)

    // oracle C — invoke compiled binaries
    let xrep  = json_stringify(xi)
    let yrep  = json_stringify(yi)
    let dyrep = json_stringify(dyi)

    let cmd_x = bin_x_path + " " + xrep + " " + yrep + " " + dyrep + " 2>&1; echo __RC=$?"
    let cx_combined = to_string(exec(cmd_x))
    let cx_rc_at = cx_combined.index_of("__RC=")
    let mut cx_rc = 1
    let mut cx_stdout = cx_combined
    if cx_rc_at >= 0 {
        let rc_tail = cx_combined.substring(cx_rc_at + 5, len(cx_combined)).trim()
        try { cx_rc = to_int(rc_tail) } catch e { cx_rc = 1 }
        cx_stdout = cx_combined.substring(0, cx_rc_at)
    }
    if cx_rc != 0 {
        println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dx compiled binary returned rc=" + to_string(cx_rc) + " at i=" + to_string(i) + " for (x=" + to_string(xi) + ", y=" + to_string(yi) + ", dy=" + to_string(dyi) + "). combined output: " + cx_stdout)
        exit(92)
    }
    let dx_c = cx_stdout.trim().to_float()
    t_set(dx_compiled_arr, i, dx_c)

    let cmd_y = bin_y_path + " " + xrep + " " + yrep + " " + dyrep + " 2>&1; echo __RC=$?"
    let cy_combined = to_string(exec(cmd_y))
    let cy_rc_at = cy_combined.index_of("__RC=")
    let mut cy_rc = 1
    let mut cy_stdout = cy_combined
    if cy_rc_at >= 0 {
        let rc_tail = cy_combined.substring(cy_rc_at + 5, len(cy_combined)).trim()
        try { cy_rc = to_int(rc_tail) } catch e { cy_rc = 1 }
        cy_stdout = cy_combined.substring(0, cy_rc_at)
    }
    if cy_rc != 0 {
        println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dy compiled binary returned rc=" + to_string(cy_rc) + " at i=" + to_string(i) + " for (x=" + to_string(xi) + ", y=" + to_string(yi) + ", dy=" + to_string(dyi) + "). combined output: " + cy_stdout)
        exit(92)
    }
    let dy_c = cy_stdout.trim().to_float()
    t_set(dyg_compiled_arr, i, dy_c)

    i = i + 1
}
println("evaluated 32 input triples across two Param directions, three oracles each (interp / hand / compiled)")

// ─── step 7: byte-eq gates (per Param direction) ──────────────────────
// max|Δ| across all 32 triples for each (oracle_A, oracle_B) pair.
let mut max_x_ic = 0.0  // df/dx interp vs compiled
let mut max_x_ih = 0.0  // df/dx interp vs hand
let mut max_x_ch = 0.0  // df/dx compiled vs hand
let mut max_y_ic = 0.0  // df/dy interp vs compiled
let mut max_y_ih = 0.0  // df/dy interp vs hand
let mut max_y_ch = 0.0  // df/dy compiled vs hand
let mut j = 0
while j < LEN {
    let xa = t_get(dx_interp_arr,   j)
    let xb = t_get(dx_hand_arr,     j)
    let xc = t_get(dx_compiled_arr, j)
    let dx_ac = sd12_dt_abs(xa - xc)
    let dx_ab = sd12_dt_abs(xa - xb)
    let dx_bc = sd12_dt_abs(xb - xc)
    if dx_ac > max_x_ic { max_x_ic = dx_ac }
    if dx_ab > max_x_ih { max_x_ih = dx_ab }
    if dx_bc > max_x_ch { max_x_ch = dx_bc }

    let ya = t_get(dyg_interp_arr,   j)
    let yb = t_get(dyg_hand_arr,     j)
    let yc = t_get(dyg_compiled_arr, j)
    let dy_ac = sd12_dt_abs(ya - yc)
    let dy_ab = sd12_dt_abs(ya - yb)
    let dy_bc = sd12_dt_abs(yb - yc)
    if dy_ac > max_y_ic { max_y_ic = dy_ac }
    if dy_ab > max_y_ih { max_y_ih = dy_ab }
    if dy_bc > max_y_ch { max_y_ch = dy_bc }
    j = j + 1
}

println("df/dx three-way max|Δ|:")
println("  interp   vs compiled : " + to_string(max_x_ic))
println("  interp   vs hand     : " + to_string(max_x_ih))
println("  compiled vs hand     : " + to_string(max_x_ch))
println("df/dy three-way max|Δ|:")
println("  interp   vs compiled : " + to_string(max_y_ic))
println("  interp   vs hand     : " + to_string(max_y_ih))
println("  compiled vs hand     : " + to_string(max_y_ch))

// First 4-element transparent audit (mirrors SD5/6/7/9/10/11 idiom).
println("first 4 rows df/dx (i, x, y, dy, dx_interp, dx_compiled, dx_hand):")
let mut dbg_x = 0
while dbg_x < 4 {
    let xi  = t_get(x_arr, dbg_x)
    let yi  = t_get(y_arr, dbg_x)
    let dyi = t_get(dy_arr, dbg_x)
    let a = t_get(dx_interp_arr,   dbg_x)
    let c = t_get(dx_compiled_arr, dbg_x)
    let b = t_get(dx_hand_arr,     dbg_x)
    println("  i=" + to_string(dbg_x)
          + "  x=" + to_string(xi)
          + "  y=" + to_string(yi)
          + "  dy=" + to_string(dyi)
          + "  dx_interp=" + to_string(a)
          + "  dx_compiled=" + to_string(c)
          + "  dx_hand=" + to_string(b))
    dbg_x = dbg_x + 1
}
println("first 4 rows df/dy (i, x, y, dy, dyg_interp, dyg_compiled, dyg_hand):")
let mut dbg_y = 0
while dbg_y < 4 {
    let xi  = t_get(x_arr, dbg_y)
    let yi  = t_get(y_arr, dbg_y)
    let dyi = t_get(dy_arr, dbg_y)
    let a = t_get(dyg_interp_arr,   dbg_y)
    let c = t_get(dyg_compiled_arr, dbg_y)
    let b = t_get(dyg_hand_arr,     dbg_y)
    println("  i=" + to_string(dbg_y)
          + "  x=" + to_string(xi)
          + "  y=" + to_string(yi)
          + "  dy=" + to_string(dyi)
          + "  dyg_interp=" + to_string(a)
          + "  dyg_compiled=" + to_string(c)
          + "  dyg_hand=" + to_string(b))
    dbg_y = dbg_y + 1
}

if max_x_ic != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dx interp vs compiled max|Δ| = " + to_string(max_x_ic) + " ≠ 0.0 — emitted df/dx source compiles & runs but produces a different IEEE-754 trajectory than the in-process interpret walker.")
    exit(93)
}
if max_x_ih != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dx interp vs hand max|Δ| = " + to_string(max_x_ih) + " ≠ 0.0 — in-process interpret already diverges from hand-derived reference; SD9 regression?")
    exit(93)
}
if max_x_ch != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dx compiled vs hand max|Δ| = " + to_string(max_x_ch) + " ≠ 0.0 — compiled binary diverges from hand reference for df/dx.")
    exit(93)
}
if max_y_ic != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dy interp vs compiled max|Δ| = " + to_string(max_y_ic) + " ≠ 0.0 — emitted df/dy source compiles & runs but produces a different IEEE-754 trajectory than the in-process interpret walker.")
    exit(93)
}
if max_y_ih != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dy interp vs hand max|Δ| = " + to_string(max_y_ih) + " ≠ 0.0 — in-process interpret already diverges from hand-derived reference; SD9 regression?")
    exit(93)
}
if max_y_ch != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  df/dy compiled vs hand max|Δ| = " + to_string(max_y_ch) + " ≠ 0.0 — compiled binary diverges from hand reference for df/dy.")
    exit(93)
}

println("PASS  F-RFC043-AUTOGRAD-AUTO-SD12-BILINEAR-COMPILE-RUN-BYTE-EQ  three-way byte-eq across 32 input triples for BOTH Params:")
println("       df/dx: interp ≡ compiled ≡ hand   (max|Δ| = 0.0 on all three pairs)")
println("       df/dy: interp ≡ compiled ≡ hand   (max|Δ| = 0.0 on all three pairs)")
println("=== SD12 PASS — AD pipeline MULTI-INPUT END-TO-END for f(x,y) = x*y (walker-emit → hexa-build × 2 → exec × 2 → parse → byte-eq) ===")
exit(0)
