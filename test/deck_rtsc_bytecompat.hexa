    spec_set(spec, "prototype",      "sodalite_im3m_yh10")
    spec_set(spec, "prefix",         "yh10_250")
    spec_set(spec, "m_site_symbol",  "Y")
    spec_set(spec, "m_site_mass",    "88.906")
    spec_set(spec, "m_site_upf",     "Y.pbe-spn-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "celldm_bohr",    "8.975")
    spec_set(spec, "a_conv_ang",     "4.75")
