fn _ysbh6_spec() -> DeckSpec {
    let spec = deck_spec_new()
    spec_set(spec, "prototype",      "a15_ysbh6")
    spec_set(spec, "prefix",         "ysbh6")
    spec_set(spec, "a_site_symbol",  "Y")
    spec_set(spec, "b_site_symbol",  "Sb")
    spec_set(spec, "a_site_mass",    "88.906")
    spec_set(spec, "b_site_mass",    "121.760")
    spec_set(spec, "a_site_upf",     "Y.pbe-spn-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "b_site_upf",     "Sb.pbe-n-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "celldm_bohr",    "8.10")
    spec_set(spec, "pressure_kbar",  "500.0")
    spec_set(spec, "pressure_gpa",   "50")
    spec_set(spec, "nq",             "4")
    return spec
}

fn _write_all(files: [DeckFile], dir: string) {
    let _mk = exec("mkdir -p " + dir)
    let mut i = 0
    while i < len(files) {
        let f = files[i]
        let _w = write_text(dir + "/" + f.path, f.content)
        i = i + 1
    }
}

fn _li2mgh16_spec() -> DeckSpec {
    // li2mgh16 needs ONLY the prototype key — every structural field has a
    // curated-deck default baked into the emitter (38-atom verbatim).
    let spec = deck_spec_new()
    spec_set(spec, "prototype", "li2mgh16")
    return spec
}

fn _emit(out: string, name: string, spec: DeckSpec) {
    let files = gen_deck("rtsc", spec)
    _write_all(files, out + "/" + name)
    println("  emitted " + name + " (" + str(len(files)) + " files)")
}

fn main() {
    let av = args()
    let mut out = "/tmp/deck_rtsc_bytecompat"
    if len(av) >= 3 { out = av[2] }
    println("# deck_rtsc_bytecompat — emit 5 existing prototypes (byte-compat, no new key) + li2mgh16 to " + out)
    _emit(out, "MgBeH8", _mgbeh8_spec())
    _emit(out, "CaAuH3", _caauh3_spec())
    _emit(out, "H3Cl",   _h3cl_spec())
    _emit(out, "YH10",   _yh10_spec())
    _emit(out, "YSbH6",  _ysbh6_spec())
    _emit(out, "Li2MgH16", _li2mgh16_spec())
    println("__DECK_RTSC_BYTECOMPAT__ DONE")
}
