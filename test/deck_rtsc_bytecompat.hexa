    let spec = deck_spec_new()
    spec_set(spec, "prototype",      "im3m_group17")
    spec_set(spec, "prefix",         "h3cl")
    spec_set(spec, "x_site_symbol",  "Cl")
    spec_set(spec, "x_site_mass",    "35.45")
    spec_set(spec, "x_site_upf",     "Cl.pbe-n-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "celldm_bohr",    "5.60")
    spec_set(spec, "a_conv_ang",     "2.96")
    spec_set(spec, "pressure_kbar",  "2000.0")
    spec_set(spec, "pressure_comment", "200 GPa")
    spec_set(spec, "pressure_gpa",   "200")
    spec_set(spec, "k_grid",         "16 16 16")
    spec_set(spec, "nq",             "4")
