// HEXA Standard Library — deck/rtsc byte-compat harness (@L3)
//
// Emits every EXISTING RTSC prototype with NO new spec key and writes the
// 4 files of each to a target dir. The @L1 k-grid/ecut spec params carry
// byte-compat defaults equal to the prior hardcoded values, so a diff of
// this emit (post-change) vs the same emit (pre-change, baseline from git
// HEAD) MUST be empty for all five existing prototypes.
//
// Usage:
//   hexa run test/deck_rtsc_bytecompat.hexa <out_dir>
// The five specs are the same fixtures used by test/deck_gen_smoke.hexa.

import "stdlib/deck/gen.hexa"
import "stdlib/io.hexa"

fn _mgbeh8_spec() -> DeckSpec {
    let spec = deck_spec_new()
    spec_set(spec, "prototype",                    "beh8_clathrate")
    spec_set(spec, "prefix",                       "mgbeh8")
    spec_set(spec, "celldm_bohr",                  "8.5132")
    spec_set(spec, "a_conv_ang",                   "4.505")
    spec_set(spec, "anchor_a_ang",                 "5.30")
    spec_set(spec, "contraction_pct",              "15")
    spec_set(spec, "a_site_symbol",                "Mg")
    spec_set(spec, "a_site_mass",                  "24.305")
    spec_set(spec, "a_site_upf",                   "Mg.pbe-spnl-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "a_site_radius_ang",            "1.60")
    spec_set(spec, "pressure_kbar",                "100.0")
    spec_set(spec, "pressure_comment",             "10 GPa  (QE press unit = kbar; 10 GPa = 100 kbar)")
    spec_set(spec, "pressure_kbar_int",            "100")
    spec_set(spec, "pressure_gpa",                 "10")
    spec_set(spec, "fallback_pressure_kbar",       "500.0")
    spec_set(spec, "fallback_pressure_kbar_int",   "500")
    spec_set(spec, "fallback_pressure_comment",    "50 GPa")
    spec_set(spec, "fallback_pressure_gpa",        "50")
    spec_set(spec, "nq",                           "2")
    spec_set(spec, "max_seconds",                  "504000")
    spec_set(spec, "walltime_comment",
        "140h floor (preflight ×1.5 of 93h est for 2x2x2 metallic)")
    return spec
}

fn _caauh3_spec() -> DeckSpec {
    let spec = deck_spec_new()
    spec_set(spec, "prototype",       "perovskite_pm3m")
    spec_set(spec, "prefix",          "caauh3")
    spec_set(spec, "a_site_symbol",   "Ca")
    spec_set(spec, "b_site_symbol",   "Au")
    spec_set(spec, "a_site_mass",     "40.078")
    spec_set(spec, "b_site_mass",     "196.967")
    spec_set(spec, "a_site_upf",      "Ca.pbe-spn-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "b_site_upf",      "Au.pbe-n-rrkjus_psl.1.0.0.UPF")
    spec_set(spec, "celldm_bohr",     "6.8361")
    spec_set(spec, "anchor_a_ang",    "3.828")
    spec_set(spec, "a_conv_ang",      "3.618")
    spec_set(spec, "contraction_pct", "5-7")
    spec_set(spec, "pressure_kbar",   "50.0")
    spec_set(spec, "pressure_gpa",    "50")
    spec_set(spec, "outdir",          "/home/aiden/rtsc_caauh3/out")
    spec_set(spec, "pseudo_dir",      "/home/aiden/rtsc_caauh3/pseudo")
    spec_set(spec, "mixing_beta",     "0.4")
    spec_set(spec, "degauss",         "0.02")
    spec_set(spec, "nq",              "4")
    return spec
}

