// test/atlas_anima_smoke.hexa — Wave-1 anima absorption smoke test
//
// Verifies:
//   * ANIMA_PSI_CONSTANTS holds 11 @C nodes (consciousness_laws.json subset)
//   * ANIMA_PSI_LAWS      holds 14 @L nodes (L1..L14)
//   * ANIMA_HEXAD_CONSTANTS holds 6 @C CDESM-channel nodes
//   * 3 spot-check values reach the expected literal:
//       alpha       = 0.014
//       balance     = 0.5
//       f_critical  = 0.10
//   * `~/.hx/data/atlas.overlay.n6` exists and carries the three
//     `# absorbed from ~/core/anima/n6/...` marker headers from the
//     wave-1 overlay merge.
//
// Run:
//   hexa run test/atlas_anima_smoke.hexa
//
// Absorbed alongside compiler/atlas/anima_psi.gen.hexa
// and compiler/atlas/anima_hexad.gen.hexa (MIT, dancinlab 2026-05-14).

use "compiler/atlas/parser"
use "compiler/atlas/anima_psi.gen"
use "compiler/atlas/anima_hexad.gen"

fn _check(label: string, ok: bool, fails) {
    if ok {
        println("  PASS  " + label)
    } else {
        println("  FAIL  " + label)
        fails.push(label)
    }
}

// Locate a constant by its `id` field (linear scan — 11 entries, O(n)
// is fine). Returns the empty-kind sentinel if not found.
fn _find(nodes, id: string) -> AtlasNode {
    let n = len(nodes)
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node.id == id { return node }
        i = i + 1
    }
    return AtlasNode {
        kind: "", id: "", raw: "", source_file: "", source_line: 0,
        grade: GradeInfo { value: -1, verified: false, breakthrough: false, hypothesis: false },
        edges: EdgeInfo { depends_on: [], derives: [], applications: [], equivalents: [], converges: [], verified_by: [], breakthroughs: [] }
    }
}

// Spot-check: the raw payload for `anima.psi.<name>` must contain
// the literal "= <expected_value>" — this is how the absorption
// generator pins each Ψ-constant's value-by-substring.
fn _has_value(nodes, id: string, expected: string) -> bool {
    let node = _find(nodes, id)
    if node.kind == "" { return false }
    // The header line is `@C anima.psi.<name> = <value> :: ...`
    let needle = "= " + expected + " ::"
    return node.raw.contains(needle)
}

fn main() {
    let fails = []

    println("anima absorption smoke — wave 1")

    let psi = anima_psi_constants()
    let laws = anima_psi_laws()
    let hexad = anima_hexad_constants()

    _check("ANIMA_PSI_CONSTANTS count == 11", len(psi) == 11, fails)
    _check("ANIMA_PSI_LAWS      count == 14", len(laws) == 14, fails)
    _check("ANIMA_HEXAD_CONSTS  count == 6",  len(hexad) == 6, fails)

    // Spot-check values per the absorption plan §E.
    _check("psi.alpha = 0.014",       _has_value(psi, "anima.psi.alpha",      "0.014"), fails)
    _check("psi.balance = 0.5",       _has_value(psi, "anima.psi.balance",    "0.5"),   fails)
    _check("psi.f_critical = 0.1",    _has_value(psi, "anima.psi.f_critical", "0.1"),   fails)

    // Quick law sanity — L1 = holo_positivity (the AdS/CFT MI surrogate
    // must not collapse to zero consciousness).
    let l1 = _find(laws, "anima.law.L1")
    _check("law L1 found",         l1.kind == "L", fails)
    _check("law L1 = holo_positivity", l1.raw.contains("holo_positivity"), fails)

    // Overlay file presence + marker headers.
    let overlay = env("HOME") + "/.hx/data/atlas.overlay.n6"
    _check("overlay file exists", file_exists(overlay), fails)
    if file_exists(overlay) {
        let body = read_file(overlay)
        _check("overlay marker: historical-absorption",
               body.contains("# absorbed from ~/core/anima/n6/atlas.append.anima-historical-absorption-2026-04-26.n6 2026-05-14"),
               fails)
        _check("overlay marker: evolution-omega-saturation",
               body.contains("# absorbed from ~/core/anima/n6/atlas.append.anima-evolution-omega-saturation-2-cycles-2026-04-28.n6 2026-05-14"),
               fails)
        _check("overlay marker: raw-135-136-pattern-7c",
               body.contains("# absorbed from ~/core/anima/n6/atlas.append.session-2026-04-28-raw-135-136-pattern-7c-self-enforcement.n6 2026-05-14"),
               fails)
    }

    let nf = len(fails)
    println("")
    if nf == 0 {
        println("anima smoke: PASS")
    } else {
        println("anima smoke: FAIL — " + to_string(nf) + " check(s) failed")
        let mut i = 0
        while i < nf {
            println("  - " + to_string(fails[i]))
            i = i + 1
        }
    }
}
