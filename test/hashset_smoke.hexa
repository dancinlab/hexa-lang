// test/hashset_smoke.hexa — smoke for stdlib/hashset.hexa
//
// @version 0.1.0
// @capabilities [pure]
//
// Run:  hexa build test/hashset_smoke.hexa -o /tmp/hashset_smoke.bin
//       /tmp/hashset_smoke.bin
// Sentinel: __HASHSET_SMOKE__ PASS|FAIL on the final line.

import "stdlib/hashset.hexa"

let mut PASS = 0
let mut FAIL = 0

fn check(label: string, cond: bool) {
    if cond {
        PASS = PASS + 1
        println("[PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("[FAIL] " + label)
    }
}

// ── T1 : empty constructor ───────────────────────────────────────────────
let s1 = hashset_new()
check("new() is empty", hashset_is_empty(s1))
check("new() len == 0", hashset_len(s1) == 0)
check("new() contains nothing", !hashset_contains(s1, "x"))
check("new() to_array == []", len(hashset_to_array(s1)) == 0)

// ── T2 : single insert ───────────────────────────────────────────────────
let s2 = hashset_new()
check("first insert returns true (newly added)", hashset_insert(s2, "a"))
check("len 1 after one insert", hashset_len(s2) == 1)
check("contains the inserted item", hashset_contains(s2, "a"))
check("does not contain absent item", !hashset_contains(s2, "b"))
check("is_empty false after insert", !hashset_is_empty(s2))

// ── T3 : insert dedup (idempotent) ───────────────────────────────────────
let s3 = hashset_new()
hashset_insert(s3, "x")
check("second insert returns false (already present)", !hashset_insert(s3, "x"))
check("len still 1 after dup insert", hashset_len(s3) == 1)

// ── T4 : multiple distinct inserts ───────────────────────────────────────
let s4 = hashset_new()
hashset_insert(s4, "a")
hashset_insert(s4, "b")
hashset_insert(s4, "c")
check("len 3 after 3 distinct inserts", hashset_len(s4) == 3)
check("contains a", hashset_contains(s4, "a"))
check("contains b", hashset_contains(s4, "b"))
check("contains c", hashset_contains(s4, "c"))
check("to_array length == 3", len(hashset_to_array(s4)) == 3)

// ── T5 : remove ──────────────────────────────────────────────────────────
let s5 = hashset_new()
hashset_insert(s5, "a")
hashset_insert(s5, "b")
check("remove returns true when present", hashset_remove(s5, "a"))
check("len decremented after remove", hashset_len(s5) == 1)
check("contains false after remove", !hashset_contains(s5, "a"))
check("contains other still true", hashset_contains(s5, "b"))
check("remove returns false when absent", !hashset_remove(s5, "a"))
check("remove of never-present returns false", !hashset_remove(s5, "z"))

// ── T6 : clear ───────────────────────────────────────────────────────────
let s6 = hashset_new()
hashset_insert(s6, "a")
hashset_insert(s6, "b")
hashset_insert(s6, "c")
hashset_clear(s6)
check("len 0 after clear", hashset_len(s6) == 0)
check("is_empty true after clear", hashset_is_empty(s6))
check("contains false after clear", !hashset_contains(s6, "a"))
// reusable after clear
hashset_insert(s6, "z")
check("re-insertable after clear", hashset_len(s6) == 1)
check("re-inserted item present", hashset_contains(s6, "z"))

// ── T7 : from_array dedup ────────────────────────────────────────────────
let s7 = hashset_from_array(["a", "b", "a", "c", "b", "a"])
check("from_array dedups (len == 3)", hashset_len(s7) == 3)
check("from_array preserves a", hashset_contains(s7, "a"))
check("from_array preserves b", hashset_contains(s7, "b"))
check("from_array preserves c", hashset_contains(s7, "c"))

// ── T8 : from_array empty input ──────────────────────────────────────────
let s8 = hashset_from_array([])
check("from_array([]) is empty", hashset_is_empty(s8))

// ── T9 : int keys (primitive non-string) ─────────────────────────────────
let s9 = hashset_new()
hashset_insert(s9, 1)
hashset_insert(s9, 2)
hashset_insert(s9, 3)
check("int contains 1", hashset_contains(s9, 1))
check("int contains 2", hashset_contains(s9, 2))
check("int absent 99", !hashset_contains(s9, 99))
check("int dedup", !hashset_insert(s9, 1))
check("int len 3", hashset_len(s9) == 3)

// ── T10 : iteration covers every element exactly once ────────────────────
let s10 = hashset_from_array(["a", "b", "c"])
let xs = hashset_to_array(s10)
check("to_array yields 3 elements", len(xs) == 3)
let mut saw_a = false
let mut saw_b = false
let mut saw_c = false
let mut i = 0
while i < len(xs) {
    if xs[i] == "a" { saw_a = true }
    if xs[i] == "b" { saw_b = true }
    if xs[i] == "c" { saw_c = true }
    i = i + 1
}
check("iteration yields a", saw_a)
check("iteration yields b", saw_b)
check("iteration yields c", saw_c)

// ── summary ──────────────────────────────────────────────────────────────
println("")
println("== hashset_smoke: " + to_string(PASS) + " passed, " + to_string(FAIL) + " failed ==")
if FAIL == 0 {
    println("__HASHSET_SMOKE__ PASS")
} else {
    println("__HASHSET_SMOKE__ FAIL")
}
