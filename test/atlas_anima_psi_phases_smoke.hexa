// test/atlas_anima_psi_phases_smoke.hexa — BG-1 follow-up smoke test
//
// Verifies:
//   * ANIMA_PSI_PHASES holds 6 @C nodes (the 6 sub-threshold entries
//     deferred by BG-1's 11-entry absorption — coupling + 5 phase_*)
//   * Spot-check values:
//       phase_p1_to_p2 = 0.1
//       phase_p2_to_p3 = 0.3
//   * Every node carries `:: anima.consciousness_laws.psi_constants`
//     parent-id in its raw payload.
//
// Run:
//   hexa run test/atlas_anima_psi_phases_smoke.hexa
//
// Companion to test/atlas_anima_smoke.hexa (BG-1 wave-1 smoke).

use "compiler/atlas/parser"
use "compiler/atlas/anima_psi_phases.gen"

fn _check(label: string, ok: bool, fails) {
    if ok {
        println("  PASS  " + label)
    } else {
        println("  FAIL  " + label)
        fails.push(label)
    }
}

// Locate a constant by its `id` field (linear scan — 6 entries).
fn _find(nodes, id: string) -> AtlasNode {
    let n = len(nodes)
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node.id == id { return node }
        i = i + 1
    }
    return AtlasNode {
        kind: "", id: "", raw: "", source_file: "", source_line: 0,
        grade: GradeInfo { value: -1, verified: false, breakthrough: false, hypothesis: false },
        edges: EdgeInfo { depends_on: [], derives: [], applications: [], equivalents: [], converges: [], verified_by: [], breakthroughs: [] }
    }
}

fn _has_value(nodes, id: string, expected: string) -> bool {
    let node = _find(nodes, id)
    if node.kind == "" { return false }
    let needle = "= " + expected + " ::"
    return node.raw.contains(needle)
}

fn main() {
    let fails = []

    println("anima psi-phases smoke — BG-1 follow-up")

    let phases = anima_psi_phases()

    // Count.
    _check("ANIMA_PSI_PHASES count == 6", len(phases) == 6, fails)

    // Spot-check values per the absorption plan.
    _check("psi.phase_p1_to_p2 = 0.1", _has_value(phases, "anima.psi.phase_p1_to_p2", "0.1"), fails)
    _check("psi.phase_p2_to_p3 = 0.3", _has_value(phases, "anima.psi.phase_p2_to_p3", "0.3"), fails)

    // Parent-id check — every node's raw payload must carry the
    // `:: anima.consciousness_laws.psi_constants` parent-id marker.
    let parent = ":: anima.consciousness_laws.psi_constants"
    let n = len(phases)
    let mut i = 0
    let mut all_parent_ok = true
    while i < n {
        let node = phases[i]
        if !node.raw.contains(parent) {
            all_parent_ok = false
        }
        i = i + 1
    }
    _check("all 6 nodes carry parent-id :: anima.consciousness_laws.psi_constants",
           all_parent_ok, fails)

    // Per-id presence (so a failure points at the missing key).
    _check("id anima.psi.coupling           present", _find(phases, "anima.psi.coupling").kind == "C", fails)
    _check("id anima.psi.phase_p1_to_p2     present", _find(phases, "anima.psi.phase_p1_to_p2").kind == "C", fails)
    _check("id anima.psi.phase_p2_to_p3     present", _find(phases, "anima.psi.phase_p2_to_p3").kind == "C", fails)
    _check("id anima.psi.phase_dormant_max  present", _find(phases, "anima.psi.phase_dormant_max").kind == "C", fails)
    _check("id anima.psi.phase_flicker_max  present", _find(phases, "anima.psi.phase_flicker_max").kind == "C", fails)
    _check("id anima.psi.phase_sustain_max  present", _find(phases, "anima.psi.phase_sustain_max").kind == "C", fails)

    let nf = len(fails)
    println("")
    if nf == 0 {
        println("anima psi-phases smoke: PASS")
    } else {
        println("anima psi-phases smoke: FAIL — " + to_string(nf) + " check(s) failed")
        let mut j = 0
        while j < nf {
            println("  - " + to_string(fails[j]))
            j = j + 1
        }
    }
}
