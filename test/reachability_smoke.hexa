// test/reachability_smoke.hexa — smoke for symbolic/reachability.hexa
//
// @version 0.1.0
// @capabilities [pure]
//
// Reference values from reachability_calculator.py (archive-TECS-L/
// .shared/calc, commit 4ee05c39) — integer-exact reachable-set kernel:
//   operands {1,2,3,6} (divisors of perfect number 6), ops {+,−,×,÷}:
//     ≤1 op → 12 integers reachable in [1,100]
//     ≤2 ops → 57 integers reachable in [1,100]
//   operands {2,3,4,6,12} (σ/τ/φ-context atoms), [1,200]:
//     ≤1 op → 20 reachable · ≤2 ops → 127 reachable
//   28 (2nd perfect number) IS reachable from divisors(6) in ≤2 ops
//   {2,3}: 5 = 2+3 reachable in 1 op · 1 = 3−2 reachable in 1 op
//
// Run:  hexa run test/reachability_smoke.hexa
// Sentinel: __REACHABILITY_SMOKE__ PASS|FAIL on the final line.

import "compiler/atlas/symbolic/reachability.hexa"

let mut PASS = 0
let mut FAIL = 0

fn check(label: string, cond: bool) {
    if cond {
        PASS = PASS + 1
        println("[PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("[FAIL] " + label)
    }
}

let div6: [int]  = [1, 2, 3, 6]
let atoms: [int] = [2, 3, 4, 6, 12]

// ── T1 : reachable set is non-trivial and contains the seeds ─────────────
let s1 = rc_reachable_set(div6, 1, 100)
check("reachable set ≤1 op is non-empty", len(s1) > 4)
check("reachable set contains seed 6", rc_is_reachable(div6, 0, 6))

// ── T2 : reach counts match the Python reference ─────────────────────────
check("divisors(6) ≤1 op → 12 in [1,100]", rc_reach_count(div6, 1, 1, 100) == 12)
check("divisors(6) ≤2 ops → 57 in [1,100]", rc_reach_count(div6, 2, 1, 100) == 57)
check("{2,3,4,6,12} ≤1 op → 20 in [1,200]", rc_reach_count(atoms, 1, 1, 200) == 20)
check("{2,3,4,6,12} ≤2 ops → 127 in [1,200]", rc_reach_count(atoms, 2, 1, 200) == 127)

// ── T3 : reachable fraction (parts-per-million) is monotone in max_ops ───
let f1 = rc_reach_fraction_ppm(div6, 1, 1, 100)
let f2 = rc_reach_fraction_ppm(div6, 2, 1, 100)
check("ppm ≤1 op == 120000 (12/100)", f1 == 120000)
check("ppm ≤2 ops == 570000 (57/100)", f2 == 570000)
check("more ops ⇒ ≥ reachable fraction", f2 >= f1)

// ── T4 : specific-target reachability ────────────────────────────────────
check("28 reachable from divisors(6) in ≤2 ops", rc_is_reachable(div6, 2, 28))
check("5 = 2+3 reachable from {2,3} in 1 op", rc_is_reachable([2, 3], 1, 5))
check("1 = 3−2 reachable from {2,3} in 1 op", rc_is_reachable([2, 3], 1, 1))
check("6 reachable from {2,3} in 1 op (2·3)", rc_is_reachable([2, 3], 1, 6))

println("")
println("═══════════════════════════════════════════════════════════")
println("  reachability smoke: PASS=" + str(PASS) + " FAIL=" + str(FAIL))
println("═══════════════════════════════════════════════════════════")
if FAIL > 0 {
    println("__REACHABILITY_SMOKE__ FAIL")
} else {
    println("__REACHABILITY_SMOKE__ PASS")
}
