// test/atlas_engine_candidates_smoke.hexa — BG-K anima-engine promotion smoke
//
// Verifies the overlay block emitted by
// tool/atlas_promote_engine_candidates.hexa:
//
//   * BEGIN/END markers present.
//   * Reasonable row count (~400-560 post-dedup/de-noise).
//   * parse_atlas_file() can ingest the overlay; @P / @L / @? counts
//     within the BG-K block are consistent with the input (post pre-flight).
//   * EVERY new row in the BG-K block carries the [needs-review] grade.
//   * Spot-check 3 ids drawn from distinct kinds.
//
// Run:
//   hexa run test/atlas_engine_candidates_smoke.hexa

use "compiler/atlas/parser"
use "compiler/atlas/overlay"

let _BEGIN = "# ===== ANIMA ENGINE HARVEST PROMOTION 2026-05-14 BEGIN ====="
let _END   = "# ===== ANIMA ENGINE HARVEST PROMOTION 2026-05-14 END ====="

fn _check(label: string, ok: bool, fails) {
    if ok {
        println("  PASS  " + label)
    } else {
        println("  FAIL  " + label)
        fails.push(label)
    }
}

fn _find(nodes, id: string) -> AtlasNode {
    let n = len(nodes)
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node.id == id { return node }
        i = i + 1
    }
    return AtlasNode {
        kind: "", id: "", raw: "", source_file: "", source_line: 0,
        grade: GradeInfo { value: -1, verified: false, breakthrough: false, hypothesis: false },
        edges: EdgeInfo { depends_on: [], derives: [], applications: [], equivalents: [], converges: [], verified_by: [], breakthroughs: [] }
    }
}

// Slice body between BEGIN and END markers (exclusive of the marker
// lines themselves) — used to count rows scoped to the BG-K block only.
fn _slice_block(body: string) -> string {
    let i = body.index_of(_BEGIN)
    let j = body.index_of(_END)
    if i < 0 || j < 0 || j <= i { return "" }
    // Skip past the BEGIN marker + its newline.
    let start = i + len(_BEGIN)
    return body.substring(start, j)
}

// Count lines in `block` that start with the literal `prefix`.
fn _count_prefix(block: string, prefix: string) -> i64 {
    let lines = block.split("\n")
    let n = len(lines)
    let lp = len(prefix)
    let mut c = 0
    let mut i = 0
    while i < n {
        let line = to_string(lines[i])
        if len(line) >= lp && line.substring(0, lp) == prefix { c = c + 1 }
        i = i + 1
    }
    return c
}

fn main() {
    let fails = []

    println("anima engine candidate promotion smoke — BG-K")

    let path = overlay_path()
    _check("overlay file exists", file_exists(path), fails)
    if !file_exists(path) {
        println("engine candidate smoke: FAIL — overlay file missing.")
        return
    }

    let body = read_file(path)
    _check("overlay BEGIN marker present", body.contains(_BEGIN), fails)
    _check("overlay END   marker present", body.contains(_END),   fails)
    if !body.contains(_BEGIN) || !body.contains(_END) {
        println("engine candidate smoke: FAIL — markers missing; rest of checks skipped.")
        return
    }

    let block = _slice_block(body)
    let n_p = _count_prefix(block, "@P anima.engine.")
    let n_l = _count_prefix(block, "@L anima.engine.")
    let n_q = _count_prefix(block, "@? anima.engine.")
    let total = n_p + n_l + n_q
    println("    block @P=" + to_string(n_p) + " @L=" + to_string(n_l) + " @?=" + to_string(n_q) + " total=" + to_string(total))

    // Per spec: ~400-560 after dedup/de-noise. Lower bound conservative
    // (de-noise rejects 1 row; dedup expected 0). Upper bound is the
    // total candidate count (560).
    _check("block total rows in [400, 560]", total >= 400 && total <= 560, fails)
    _check("@P rows >= 100",                n_p >= 100, fails)
    _check("@L rows >= 200",                n_l >= 200, fails)
    _check("@? rows >= 50",                 n_q >= 50,  fails)

    // EVERY non-comment, non-continuation row in the BG-K block must
    // carry [needs-review]. Walk the block lines and check every header.
    let lines = block.split("\n")
    let mut bad_grade = 0
    let mut i = 0
    let nlines = len(lines)
    while i < nlines {
        let line = to_string(lines[i])
        let is_header = false
        let mut hk = false
        if len(line) >= 3 {
            let p3 = line.substring(0, 3)
            if p3 == "@P " || p3 == "@L " || p3 == "@? " { hk = true }
        }
        if hk {
            if !line.contains("[needs-review]") {
                bad_grade = bad_grade + 1
                eprintln("  bad-grade line: " + line)
            }
        }
        i = i + 1
    }
    _check("every header row tagged [needs-review]", bad_grade == 0, fails)

    // citation_unverified = true must appear on @L rows. Check that
    // the count of that continuation line is >= n_l.
    let unverified = _count_prefix(block, "  citation_unverified = true")
    _check("citation_unverified=true on every row", unverified >= total, fails)

    // Parser round-trip — exercises the full continuation handling.
    let nodes = parse_atlas_file(path, "atlas.overlay.n6")
    _check("parse_atlas_file produced > 0 nodes", len(nodes) > 0, fails)

    // Count anima.engine.* nodes in the parsed result.
    let np = len(nodes)
    let mut engine_nodes = 0
    let prefix = "anima.engine."
    let lp = len(prefix)
    let mut j = 0
    while j < np {
        let node = nodes[j]
        if len(node.id) >= lp && node.id.substring(0, lp) == prefix {
            engine_nodes = engine_nodes + 1
        }
        j = j + 1
    }
    _check("parse_atlas_file sees >= 400 anima.engine.* nodes", engine_nodes >= 400, fails)
    println("    (parser saw " + to_string(engine_nodes) + " engine nodes)")

    // Spot checks — one per kind. These ids come straight from the BG-B
    // candidates file and remain stable across reruns.
    // 1. @P spot: anima.engine.addiction_phi.primitive_0
    let spot1 = "anima.engine.addiction_phi.primitive_0"
    let n1 = _find(nodes, spot1)
    _check("spot @P " + spot1 + " found", n1.kind == "P", fails)
    if n1.kind == "P" {
        _check("spot1 raw [needs-review]", n1.raw.contains("[needs-review]"), fails)
        _check("spot1 has scanned_at",     n1.raw.contains("scanned_at = \"2026-05-14\""), fails)
    }

    // 2. @L spot: anima.engine.aesthetic_phi.citation_0  (Berlyne 1971)
    let spot2 = "anima.engine.aesthetic_phi.citation_0"
    let n2 = _find(nodes, spot2)
    _check("spot @L " + spot2 + " found", n2.kind == "L", fails)
    if n2.kind == "L" {
        _check("spot2 raw [needs-review]",       n2.raw.contains("[needs-review]"), fails)
        _check("spot2 citation_unverified=true", n2.raw.contains("citation_unverified = true"), fails)
        _check("spot2 carries citation_source",  n2.raw.contains("citation_source = \""), fails)
    }

    // 3. @? spot: anima.engine.abiogenesis_phi.open  (status=open preserved)
    let spot3 = "anima.engine.abiogenesis_phi.open"
    let n3 = _find(nodes, spot3)
    _check("spot @? " + spot3 + " found", n3.kind == "Q", fails)
    if n3.kind == "Q" {
        _check("spot3 raw [needs-review]", n3.raw.contains("[needs-review]"), fails)
        _check("spot3 status=open",        n3.raw.contains("status = \"open\""), fails)
    }

    let nf = len(fails)
    println("")
    if nf == 0 {
        println("engine candidate smoke: PASS")
    } else {
        println("engine candidate smoke: FAIL — " + to_string(nf) + " check(s) failed")
        let mut k = 0
        while k < nf {
            println("  - " + to_string(fails[k]))
            k = k + 1
        }
    }
}
