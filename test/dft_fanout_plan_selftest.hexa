// dft_fanout_plan_selftest — §4b SEPARATE-PODS fan-out plan logic (handoff
// 22486f26, PR #2125 follow-up).
//
// Asserts the d_parallel_fire 1순위 contract of the §4b fan-out executor's PURE
// planner `dft_fanout_plan` (stdlib/cloud/dft_dispatch.hexa): given N candidate
// decks + their readiness tags, it renders a SEPARATE-PODS roll-call where
//   • each candidate maps to exactly ONE pod (never packed behind another),
//   • only READY decks claim a pod slot (UNVALIDATED/INCOMPLETE are skipped),
//   • the ready/blocked counts are exact.
//
// The live module carries heavy cloud/vast/pod_registry deps (a multi-use build
// link-fails locally), so this harness inlines a byte-for-byte copy of the pure
// `dft_fanout_plan` body and pins it against golden strings — the documented
// isolated-single-file logic test for a pure fn in a dep-heavy stdlib module.
// If the live function's logic changes, this copy must be kept in lockstep.
//
// Usage:
//   hexa run test/dft_fanout_plan_selftest.hexa

// ── COPY of stdlib/cloud/dft_dispatch.hexa :: dft_fanout_plan (keep in sync) ──
fn fanout_plan(decks: [str], tags: [str]) -> str {
    let n = len(decks)
    let mut ready = 0
    let mut s = "[dft-fanout] §4b SEPARATE-PODS-PER-CANDIDATE (d_parallel_fire 1순위)\n"
    s = s + "[dft-fanout] " + to_string(n) + " candidate deck(s) -> "
        + to_string(n) + " pod(s), exactly one deck per pod (d17 · isolated scratch)\n"
    let mut i = 0
    while i < n {
        let tag = if i < len(tags) { tags[i] } else { "INCOMPLETE" }
        let mark = if tag == "READY" { "+ pod " + to_string(ready + 1) } else { "x skip" }
        s = s + "  [" + mark + "] " + decks[i] + " - " + tag + "\n"
        if tag == "READY" { ready = ready + 1 }
        i = i + 1
    }
    let blocked = n - ready
    s = s + "[dft-fanout] " + to_string(ready) + " READY -> "
        + to_string(ready) + " pod(s) to rent; " + to_string(blocked) + " blocked\n"
    if blocked > 0 {
        s = s + "[dft-fanout] blocked decks need `hexa cloud dft-run <deck> --validate`"
            + " (or --force to fire unvalidated)\n"
    }
    return s
}

fn _check(name: string, cond: bool, fails: [bool]) {
    if cond {
        println("  PASS  " + name)
    } else {
        println("  FAIL  " + name)
        fails[0] = true
    }
}

fn main() {
    println("# dft_fanout_plan_selftest — §4b SEPARATE-PODS fan-out planner")
    println("")
    let fails = [false]

    // ── all three candidates READY → 3 pods, 0 blocked ──────────────────
    println("## 3 READY candidates — expect 3 pods, sequential pod numbering")
    let p3 = fanout_plan(["d/a", "d/b", "d/c"], ["READY", "READY", "READY"])
    _check("header = SEPARATE-PODS-PER-CANDIDATE",
        p3.contains("SEPARATE-PODS-PER-CANDIDATE"), fails)
    _check("cites d_parallel_fire 1순위",
        p3.contains("d_parallel_fire 1순위"), fails)
    _check("3 candidate -> 3 pod line",
        p3.contains("3 candidate deck(s) -> 3 pod(s)"), fails)
    _check("one deck per pod contract present",
        p3.contains("exactly one deck per pod"), fails)
    _check("pod slots numbered 1..3 (each candidate its OWN pod)",
        p3.contains("[+ pod 1] d/a") && p3.contains("[+ pod 2] d/b")
        && p3.contains("[+ pod 3] d/c"), fails)
    _check("3 READY -> 3 pod(s) to rent; 0 blocked",
        p3.contains("3 READY -> 3 pod(s) to rent; 0 blocked"), fails)
    _check("no blocked-decks hint when 0 blocked",
        !p3.contains("blocked decks need"), fails)
    println("")

    // ── mixed readiness → only READY claims a pod, blocked are skipped ───
    println("## mixed (READY/UNVALIDATED/INCOMPLETE) — only READY gets a pod")
    let pm = fanout_plan(
        ["d/a", "d/b", "d/c"],
        ["READY", "UNVALIDATED", "INCOMPLETE"])
    _check("READY deck claims pod 1",
        pm.contains("[+ pod 1] d/a - READY"), fails)
    _check("UNVALIDATED deck is skipped (no pod slot)",
        pm.contains("[x skip] d/b - UNVALIDATED"), fails)
    _check("INCOMPLETE deck is skipped (no pod slot)",
        pm.contains("[x skip] d/c - INCOMPLETE"), fails)
    _check("count = 1 READY -> 1 pod; 2 blocked",
        pm.contains("1 READY -> 1 pod(s) to rent; 2 blocked"), fails)
    _check("blocked-decks --validate hint shown when blocked > 0",
        pm.contains("blocked decks need")
        && pm.contains("--validate"), fails)
    println("")

    // ── pod numbering compacts past skipped decks ───────────────────────
    println("## numbering compacts — a skip between two READY decks does NOT gap")
    let pc = fanout_plan(
        ["d/x", "d/y", "d/z"],
        ["READY", "INCOMPLETE", "READY"])
    _check("first READY = pod 1",
        pc.contains("[+ pod 1] d/x"), fails)
    _check("second READY = pod 2 (NOT pod 3 — numbering ignores the skip)",
        pc.contains("[+ pod 2] d/z"), fails)
    _check("2 READY -> 2 pod(s); 1 blocked",
        pc.contains("2 READY -> 2 pod(s) to rent; 1 blocked"), fails)
    println("")

    // ── single deck (degenerate fan-out = 1 pod) ────────────────────────
    println("## single READY candidate — degenerate fan-out = 1 pod")
    let p1 = fanout_plan(["solo"], ["READY"])
    _check("1 candidate -> 1 pod",
        p1.contains("1 candidate deck(s) -> 1 pod(s)"), fails)
    _check("1 READY -> 1 pod(s); 0 blocked",
        p1.contains("1 READY -> 1 pod(s) to rent; 0 blocked"), fails)
    println("")

    if fails[0] {
        println("__DFT_FANOUT_PLAN_SELFTEST__ FAIL")
    } else {
        println("__DFT_FANOUT_PLAN_SELFTEST__ PASS")
    }
}
