// test/platonic_solids_smoke.hexa — smoke for symbolic/platonic_solids.hexa
//
// @version 0.1.0
// @capabilities [pure]
//
// Reference values from platonic_solids_n6.py (archive-TECS-L/.shared/calc,
// commit 4ee05c39):
//   Tetra (4,6,4) · Cube (8,12,6) · Octa (6,12,8) · Dodec (20,30,12)
//   Icosa (12,30,20) — Euler V−E+F = 2 for all (sphere topology)
//   "exactly 5" : integer {p,q} with 1/p+1/q>1/2 (p,q≥3) → exactly 5
//   duality: 3 dual classes (Tet self-dual, Cube↔Oct, Dodec↔Icos) = 6/φ(6)
//   edge sum 6+12+12+30+30 = 90 = 6·C(6,2) = 6·15
//   Schläfli derivation: {3,3}→E=6, {5,3}→E=30 (dodecahedron)
//
// Run:  hexa run test/platonic_solids_smoke.hexa
// Sentinel: __PLATONIC_SMOKE__ PASS|FAIL on the final line.

import "compiler/atlas/symbolic/platonic_solids.hexa"

let mut PASS = 0
let mut FAIL = 0

fn check(label: string, cond: bool) {
    if cond {
        PASS = PASS + 1
        println("[PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("[FAIL] " + label)
    }
}

// ── table sanity ─────────────────────────────────────────────────────────
check("5 Platonic solids", pl_count() == 5)
check("Tetrahedron (V,E,F)=(4,6,4)",  pl_V(0)==4 && pl_E(0)==6 && pl_F(0)==4)
check("Cube (V,E,F)=(8,12,6)",        pl_V(1)==8 && pl_E(1)==12 && pl_F(1)==6)
check("Octahedron (V,E,F)=(6,12,8)",  pl_V(2)==6 && pl_E(2)==12 && pl_F(2)==8)
check("Dodecahedron (V,E,F)=(20,30,12)", pl_V(3)==20 && pl_E(3)==30 && pl_F(3)==12)
check("Icosahedron (V,E,F)=(12,30,20)",  pl_V(4)==12 && pl_E(4)==30 && pl_F(4)==20)

// ── Euler characteristic χ = 2 ───────────────────────────────────────────
check("χ(Tetrahedron) == 2",  pl_euler(0) == 2)
check("χ(Icosahedron)  == 2", pl_euler(4) == 2)
check("χ == 2 for ALL 5 solids (sphere topology)", pl_all_euler_2())

// ── "exactly 5" Schläfli closed-form classification ──────────────────────
check("{3,3} valid (tetrahedron)", pl_schlafli_valid(3, 3))
check("{3,6} invalid (planar tiling)", !pl_schlafli_valid(3, 6))
check("{4,4} invalid (square tiling)", !pl_schlafli_valid(4, 4))
check("exactly 5 valid {p,q} (3..20) — the uniqueness proof",
      pl_schlafli_solution_count(20) == 5)
check("exactly 5 still holds at bound 100",
      pl_schlafli_solution_count(100) == 5)

// ── Schläfli → (V,E,F) derivation ────────────────────────────────────────
check("{3,3} → E=6 (tetrahedron)",   pl_E_from_schlafli(3, 3) == 6)
check("{4,3} → E=12 (cube)",         pl_E_from_schlafli(4, 3) == 12)
check("{5,3} → V=20 (dodecahedron)", pl_V_from_schlafli(5, 3) == 20)
check("{3,5} → F=20 (icosahedron)",  pl_F_from_schlafli(3, 5) == 20)

// ── duality : 3 pairs = 6/φ(6) ───────────────────────────────────────────
check("Tetrahedron self-dual", pl_dual_index(0) == 0)
check("Cube ↔ Octahedron",     pl_dual_index(1) == 2 && pl_dual_index(2) == 1)
check("Dodec ↔ Icosa",         pl_dual_index(3) == 4 && pl_dual_index(4) == 3)
check("3 dual classes = 6/φ(6) = 3", pl_dual_pair_count() == 3)

// ── edge-sum identity 90 = 6·C(6,2) ──────────────────────────────────────
check("edge sum == 90", pl_edge_sum() == 90)
check("C(6,2) == 15",   pl_binom6_2() == 15)
check("90 = P1·C(P1,2) = 6·15", pl_edge_sum_identity())

println("")
println("═══════════════════════════════════════════════════════════")
println("  platonic_solids smoke: PASS=" + str(PASS) + " FAIL=" + str(FAIL))
println("═══════════════════════════════════════════════════════════")
if FAIL > 0 {
    println("__PLATONIC_SMOKE__ FAIL")
} else {
    println("__PLATONIC_SMOKE__ PASS")
}
