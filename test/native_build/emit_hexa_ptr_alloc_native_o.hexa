// test/native_build/emit_hexa_ptr_alloc_native_o.hexa
//
// HEXA_BACKEND flip · chunk-B phase-H "아홉째 increment" — production-wire
// SECOND PROBE: hexa-native override for the `_hexa_ptr_alloc` runtime fn.
//
// Horizontal expansion of the `_hexa_exit` weak-override pattern (PR #1321 +
// #1324). Same recipe — emit a Mach-O .o exporting a strong external symbol
// whose body is a HexaVal-ABI ↔ raw-ABI adapter wrapping the `rt_alloc`
// primitive's machine-code (from self/codegen/runtime_arm64.hexa::rt_alloc).
//
// The C-side `hexa_ptr_alloc` in self/runtime.c carries `__attribute__((weak))`
// after this cycle's surgical edit; ld64 binds `bl _hexa_ptr_alloc` callsites
// to this hexa-emit strong symbol when HEXA_NATIVE_RT_PTR_ALLOC=1 gates the
// cmd_build native-path link append.
//
// ── ABI ADAPTER ──
//
// CALLER ABI (aprime_cc emit, HexaVal struct ≤16 B by value):
//   x0 = HexaVal.tag       (= TAG_INT = 0 when caller is `hexa_ptr_alloc(int)`)
//   x1 = HexaVal.payload   (= the byte-count N to allocate)
//
// PRIMITIVE ABI (rt_alloc per self/codegen/runtime_arm64.hexa, post-2026-05-26
// header refactor — pair-safe alloc/free): x0=N → mmap(N+16) → store N at
// addr[0..8] → return user_ptr = addr + 16.
//   x0 = N (raw int, original user size)
//   internal: x1 = N+16, mmap'd → x0; *(size_t*)x0 = N; x0 += 16
//   svc #0x80 with x16=197 (SYS_mmap)
//   returns user-facing ptr in x0 (= header_addr + 16)
//
// RETURN ABI (HexaVal struct ≤16 B by value):
//   x0 = TAG_INT = 0
//   x1 = user_ptr (HexaVal.payload — caller treats as int64 by `HX_INT(v)`)
//
// ADAPTER BODY (80 bytes total):
//   ── input prefix (4 B) ──
//   mov x0, x1                       // HexaVal.payload (N) → x0
//   ── rt_alloc body minus its final epilogue (60 B) ──
//   stp x29, x30, [sp, #-16]!
//   mov x29, sp
//   stp x19, x20, [sp, #-16]!        // save callee-saved
//   mov x19, x0                      // x19 = N (preserved across svc)
//   add x1, x0, #16                  // x1 = N+16 (mmap size)
//   mov x0, #0                       // addr = NULL
//   mov x2, #3                       // PROT_RW
//   mov x3, #0x1002                  // MAP_ANON|MAP_PRIVATE
//   movn x4, #0                      // fd = -1
//   mov x5, #0                       // offset = 0
//   mov x16, #197                    // SYS_mmap
//   svc #0x80                        // x0 = mmap'd addr
//   str x19, [x0]                    // header_addr[0..8] = N
//   add x0, x0, #16                  // x0 = user_ptr = addr + 16
//   ldp x19, x20, [sp], #16          // restore callee-saved
//   ── HexaVal-return postfix (8 B) ──
//   mov x1, x0                       // user_ptr → HexaVal.payload (x1)
//   mov x0, #0                       // tag = TAG_INT = 0
//   ── epilogue (8 B — restored from rt_alloc's tail) ──
//   ldp x29, x30, [sp], #16
//   ret
//
// Note: rt_alloc's own epilogue (ldp+ret, 8 B) is STRIPPED — we inject our
// HexaVal-return postfix between the inner ldp x19/x20 and the outer ldp
// x29/x30. Total adapter = 4 (prefix) + 60 (rt_alloc body sans outer
// epilogue) + 8 (return postfix) + 8 (epilogue) = 80 bytes.
//
// ── HONESTY ──
//
// Cross-cutting:
//   - closure = production override active (otool shows hexa-emit body when
//     env on); selfhosted opt-in (env unset → byte-identical link).
//   - f1/f2 — clang ONLY as link-side oracle, NEVER in this .o's emit path.
//   - selfhosted opt-in — HEXA_NATIVE_RT_PTR_ALLOC=1 gates the cmd_build
//     append; unset = no behavior change (default build_aprime.sh stays
//     byte-identical to the pre-cycle baseline).
//   - g5 verbatim — verify smoke script pastes raw rc + stdout.
//
// PAIR-SAFETY (closes #1326 residual (B), 2026-05-26):
//   - The override now allocates with a 16-B size header. The companion
//     `_hexa_ptr_free` override (test/native_build/emit_hexa_ptr_free_native_o.hexa)
//     recovers the header and munmaps with the correct size.
//   - Default-flip safe when BOTH env gates are on (alloc + free).
//   - alloc-only (HEXA_NATIVE_RT_PTR_ALLOC=1 alone): still UB if hexa_ptr_free
//     is called (libc free() on mmap'd ptr corrupts heap). Document as
//     opt-in unsafe (no behavior change vs pre-refactor in this mode).
//
// SELF-CONTAINED: same module-loader rationale as emit_hexa_exit_native_o.hexa
// (the v2 wrapper is inlined byte-for-byte). The deliberate diffs vs the exit
// emit driver: (a) the adapter is 60 B not 20 B (return-ABI postprocess), and
// (b) the exported symbol is `_hexa_ptr_alloc` (15 B + NUL = 16 B) instead of
// `_hexa_exit` (10 B + NUL = 11 B) — strtab payload + size shift accordingly.

// ═══════════════════════════════════════════════════════════════════
// Adapter body — HexaVal-ABI prefix + rt_alloc body (header pattern)
// + HexaVal-return postfix.
// rt_alloc bytes verbatim from self/codegen/runtime_arm64.hexa
// (post-2026-05-26 header refactor — pair-safe with rt_free).
// ═══════════════════════════════════════════════════════════════════
fn hexa_ptr_alloc_adapter_bytes() -> [int] {
    let mut c = []

    // ── input prefix (4 bytes) ──
    // mov x0, x1   (= orr x0, xzr, x1)   0xAA0103E0  → e0 03 01 aa LE
    c.push(0xe0); c.push(0x03); c.push(0x01); c.push(0xaa)

    // ── rt_alloc body minus outer epilogue (60 bytes, 15 instructions) ──
    // stp x29, x30, [sp, #-16]!          0xA9BF7BFD
    c.push(253); c.push(123); c.push(191); c.push(169)
    // mov x29, sp                         0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // stp x19, x20, [sp, #-16]!          0xA9BF53F3
    c.push(243); c.push(83); c.push(191); c.push(169)
    // mov x19, x0   (save N)             0xAA0003F3
    c.push(243); c.push(3); c.push(0); c.push(170)
    // add x1, x0, #16  (N+16 → x1)      0x91004001
    c.push(1); c.push(64); c.push(0); c.push(145)
    // mov x0, #0  (addr=NULL)            0xD2800000
    c.push(0); c.push(0); c.push(128); c.push(210)
    // mov x2, #3  (PROT_RW)              0xD2800062
    c.push(98); c.push(0); c.push(128); c.push(210)
    // mov x3, #0x1002 (MAP)              0xD2820043
    c.push(67); c.push(0); c.push(130); c.push(210)
    // movn x4, #0 (fd=-1)                0x92800004
    c.push(4); c.push(0); c.push(128); c.push(146)
    // mov x5, #0  (offset)               0xD2800005
    c.push(5); c.push(0); c.push(128); c.push(210)
    // mov x16, #197 (SYS_mmap)           0xD28018B0
    c.push(176); c.push(24); c.push(128); c.push(210)
    // svc #0x80                          0xD4001001
    c.push(1); c.push(16); c.push(0); c.push(212)
    // str x19, [x0]   (header=N)         0xF9000013
    c.push(19); c.push(0); c.push(0); c.push(249)
    // add x0, x0, #16  (ptr += 16)       0x91004000
    c.push(0); c.push(64); c.push(0); c.push(145)
    // ldp x19, x20, [sp], #16            0xA8C153F3
    c.push(243); c.push(83); c.push(193); c.push(168)
    // (rt_alloc's outer ldp/ret epilogue STRIPPED — HexaVal-return below)

    // ── HexaVal-return postfix (8 bytes) ──
    // mov x1, x0  (ptr -> HexaVal.payload)  0xAA0003E1 → e1 03 00 aa
    c.push(0xe1); c.push(0x03); c.push(0x00); c.push(0xaa)
    // mov x0, #0  (TAG_INT = 0)            0xD2800000 → 00 00 80 d2
    c.push(0x00); c.push(0x00); c.push(0x80); c.push(0xd2)

    // ── epilogue (8 bytes — restored from rt_alloc's tail) ──
    // ldp x29, x30, [sp], #16            0xA8C17BFD
    c.push(253); c.push(123); c.push(193); c.push(168)
    // ret                                 0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)

    return c
}

// ═══════════════════════════════════════════════════════════════════
// Inlined from self/codegen/macho.hexa (constants + helpers + obj_wrap)
// Identical to emit_hexa_exit_native_o.hexa except for the symbol name +
// strtab payload at the end (_hexa_ptr_alloc = 15 B + NUL = 16 B total
// strtab, vs _hexa_exit = 10 B + NUL = 11 B).
// ═══════════════════════════════════════════════════════════════════
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

fn push_u16_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

fn push_u32_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}

fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// Inlined from self/codegen/macho.hexa::macho_obj_wrap (L34-136).
// Symbol exported = `_hexa_ptr_alloc` (15 chars + NUL = 16 B strtab).
fn macho_obj_wrap_hexa_ptr_alloc(code: [int], main_offset: int) -> [int] {
    let mut out = []
    let code_size = len(code)

    let header_size = 32
    let segment_cmd_size = 152
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let symtab_offset = align_to_v(code_offset + code_size, 4)
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size
    // strtab = "\0_hexa_ptr_alloc\0" = 1 + 15 + 1 = 17 bytes total.
    // The leading NUL is the empty-string sentinel (string index 0); the
    // exported symbol's name lives at string index 1 and is NUL-terminated.
    let strtab_size = 1 + 16

    // Mach-O Header (32 bytes)
    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SEGMENT_64
    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, align_to_v(strtab_offset + strtab_size, 8))
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, strtab_offset + strtab_size - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0)

    // Section header: __text (80 bytes)
    out.push(95); out.push(95); out.push(116); out.push(101); out.push(120); out.push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95); out.push(95); out.push(84); out.push(69); out.push(88); out.push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SYMTAB
    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    // Pad to code_offset
    while len(out) < code_offset { out.push(0) }

    // Code section
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    // Pad to symtab_offset
    while len(out) < symtab_offset { out.push(0) }

    // Symbol table: nlist_64 (16 bytes)
    out = push_u32_le_v(out, 1)
    out.push(n_sect_v() + n_ext_v())
    out.push(1)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, main_offset)

    // String table — "\0_hexa_ptr_alloc\0" (17 bytes total: 1 NUL + 15 chars + 1 NUL)
    out.push(0)
    // "_hexa_ptr_alloc\0"
    //  _   h    e    x    a    _   p    t    r    _   a   l    l    o    c   \0
    //  95 104 101 120  97  95 112 116 114  95  97 108 108 111  99   0
    out.push(95); out.push(104); out.push(101); out.push(120); out.push(97)
    out.push(95); out.push(112); out.push(116); out.push(114); out.push(95)
    out.push(97); out.push(108); out.push(108); out.push(111); out.push(99); out.push(0)

    return out
}

// ═══════════════════════════════════════════════════════════════════
// Driver
// ═══════════════════════════════════════════════════════════════════
fn emit_hexa_ptr_alloc_native_o() {
    println("[wire] HEXA_BACKEND flip · 열한째 increment refresh — _hexa_ptr_alloc native override (header pattern, pair-safe with _hexa_ptr_free)")

    let code = hexa_ptr_alloc_adapter_bytes()
    if len(code) != 80 {
        println("FAIL: adapter expected 80 bytes (4 prefix + 60 rt_alloc-body + 8 ret-postfix + 8 epilogue), got " + to_string(len(code)))
        return
    }
    println("  adapter bytes  : " + to_string(len(code)) + " (80 expected — 4 prefix + 60 mmap+header + 8 ret-postfix + 8 epilogue)")

    // mov x0, x1 (e0 03 01 aa) sanity at offset 0
    if code[0] != 0xe0 || code[1] != 0x03 || code[2] != 0x01 || code[3] != 0xaa {
        println("FAIL: mov x0, x1 prefix mismatch")
        return
    }
    println("  ABI prefix     : e0 03 01 aa (mov x0, x1) OK")

    // add x1, x0, #16 at offset 20 (4 prefix + 16 outer/inner-frame; encoding 01 40 00 91)
    if code[20] != 1 || code[21] != 64 || code[22] != 0 || code[23] != 145 {
        println("FAIL: add x1, x0, #16 (header math) at offset 20 mismatch")
        return
    }
    println("  hdr add x1     : 01 40 00 91 (add x1, x0, #16) OK")

    // svc trailer at offset 48 (1, 16, 0, 212 = 0xD4001001 LE — mmap call)
    if code[48] != 1 || code[49] != 16 || code[50] != 0 || code[51] != 212 {
        println("FAIL: SVC at offset 48 mismatch (rt_alloc mmap body)")
        return
    }
    println("  SVC mid-body   : 01 10 00 d4 (svc #0x80, mmap call) OK")

    // str x19, [x0] at offset 52 (encoding 13 00 00 f9)
    if code[52] != 19 || code[53] != 0 || code[54] != 0 || code[55] != 249 {
        println("FAIL: str x19, [x0] (header write) at offset 52 mismatch")
        return
    }
    println("  hdr str x19    : 13 00 00 f9 (store N at header) OK")

    // mov x1, x0 (e1 03 00 aa) at offset 64 (HexaVal ret postfix)
    if code[64] != 0xe1 || code[65] != 0x03 || code[66] != 0x00 || code[67] != 0xaa {
        println("FAIL: mov x1, x0 ret-postfix mismatch")
        return
    }
    println("  ret-postfix    : e1 03 00 aa + 00 00 80 d2 (mov x1,x0; mov x0,#0) OK")

    // ret at offset 76-79 (c0 03 5f d6)
    if code[76] != 192 || code[77] != 3 || code[78] != 95 || code[79] != 214 {
        println("FAIL: RET trailer mismatch")
        return
    }
    println("  RET trailer    : c0 03 5f d6 OK")

    let obj = macho_obj_wrap_hexa_ptr_alloc(code, 0)
    println("  obj_wrap size  : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 LE at offset 0 (0xFEEDFACF → cf fa ed fe)
    if obj[0] != 0xcf || obj[1] != 0xfa || obj[2] != 0xed || obj[3] != 0xfe {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")

    // filetype = MH_OBJECT (1) at offset 12
    if obj[12] != 1 {
        println("FAIL: filetype not MH_OBJECT")
        return
    }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out = "/tmp/hexa_ptr_alloc_native.o"
    write_bytes(out, obj)
    println("  wrote          : " + out)
    println("[wire] EMIT OK — link via cmd_build native path with HEXA_NATIVE_RT_PTR_ALLOC=1")
}

emit_hexa_ptr_alloc_native_o()
