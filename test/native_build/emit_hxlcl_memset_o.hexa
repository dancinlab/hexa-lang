// test/native_build/emit_hxlcl_memset_o.hexa
//
// F3 ACTIVATION RUNBOOK · Path A · FIRST primitive `rt_memset` —
// production-wire the self-emitted memset over the C `hxlcl_memset`.
//
// EMITS: a Mach-O .o file exporting a strong external symbol `_hxlcl_memset`
// whose body is rt_memset's verbatim machine-code (the pure byte-store
// loop). When the driver / module_loader is built under HEXA_RT_SELFEMIT=1,
// `self/runtime.c` declares `hxlcl_memset` as `extern` (no body) instead of
// the file-local `static` definition, and ld64 binds the `bl _hxlcl_memset`
// callsites to this .o's strong symbol — the C runtime's memset is replaced
// by the hexa-emitted one.
//
// ── ABI ──
//
// rt_memset(x0=dst, x1=byte_val, x2=len) writes the low byte of x1 into
// dst[0 .. len-1] via a `strb w1, [x0, x3]` loop, then `ret`. The loop uses
// only the caller-saved scratch x3 and NEVER modifies x0, so on `ret`
// x0 = dst — exactly matching the C `void* memset(void*, int, size_t)`
// return-value contract. No relocation, no arena state, no HexaVal touch.
//
// ── HONESTY ──
//
//   - closure = runs exact — a memset-using C program linked against this .o
//     must produce byte-identical output to the C `hxlcl_memset`.
//   - f1/f2 — clang ONLY as link-side oracle, NEVER in this .o's emit path
//     (the 28 bytes come from rt_memset(), inlined verbatim below).
//   - selfhosted opt-in — HEXA_RT_SELFEMIT=1 gates the build append; unset =
//     no behavior change (default build keeps `static` = 0-libc-extern).
//   - no binaries committed.
//
// SELF-CONTAINED: same module-loader rationale as poc_rt_exit_obj_emit.hexa
// (the local repo has no compiled module_loader, so multi-`use` programs
// link-fail). The v wrapper is inlined byte-for-byte. The deliberate diffs
// vs the predecessor PoC are: (1) the 28 rt_memset bytes (vs 16 rt_exit),
// (2) the EXPORTED SYMBOL NAME `_hxlcl_memset` (13 B → strtab_size = 1+13).
// The 28 bytes are character-identical to self/codegen/runtime_arm64.hexa
// L709 rt_memset(); this proves the upstream fn produces a working .o.

// ═══════════════════════════════════════════════════════════════════
// Inlined from self/codegen/runtime_arm64.hexa::rt_memset (lines 709-747)
// 7 instructions, 28 bytes. mov x3,#0 / loop: cmp / b.hs / strb / add / b
// / done: ret. x0 (dst) never written → x0=dst on return (C ABI compat).
// ═══════════════════════════════════════════════════════════════════
fn rt_memset_bytes() -> [int] {
    let mut c = []
    // mov x3, #0  (counter i)        0xD2800003
    c.push(3); c.push(0); c.push(128); c.push(210)
    // loop: cmp x3, x2               0xEB02007F
    c.push(127); c.push(0); c.push(2); c.push(235)
    // b.hs done (+4 instrs = +16)    0x54000082
    c.push(130); c.push(0); c.push(0); c.push(84)
    // strb w1, [x0, x3]              0x38236801
    c.push(1); c.push(104); c.push(35); c.push(56)
    // add x3, x3, #1                 0x91000463
    c.push(99); c.push(4); c.push(0); c.push(145)
    // b loop (-4 instrs = -16)       0x17FFFFFC
    c.push(252); c.push(255); c.push(255); c.push(23)
    // done: ret                      0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// ═══════════════════════════════════════════════════════════════════
// Inlined from self/codegen/macho.hexa (constants + helpers + obj_wrap)
// Identical to poc_rt_exit_obj_emit.hexa except the symbol name + strtab.
// ═══════════════════════════════════════════════════════════════════
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

fn push_u16_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

fn push_u32_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}

fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// Inlined from self/codegen/macho.hexa::macho_obj_wrap (L34-136).
// Symbol exported = `_hxlcl_memset` (strtab_size = 1 + 13 NUL-term = 14).
fn macho_obj_wrap_hxlcl_memset(code: [int], main_offset: int) -> [int] {
    let mut out = []
    let code_size = len(code)

    let header_size = 32
    let segment_cmd_size = 152
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let symtab_offset = align_to_v(code_offset + code_size, 4)
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size
    // strtab = "\0_hxlcl_memset\0" = 1 + 13 = 14 bytes.
    let strtab_size = 1 + 13

    // Mach-O Header (32 bytes)
    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SEGMENT_64
    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, align_to_v(strtab_offset + strtab_size, 8))
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, strtab_offset + strtab_size - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0)

    // Section header: __text (80 bytes)
    out.push(95); out.push(95); out.push(116); out.push(101); out.push(120); out.push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95); out.push(95); out.push(84); out.push(69); out.push(88); out.push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SYMTAB
    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    // Pad to code_offset
    while len(out) < code_offset { out.push(0) }

    // Code section
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    // Pad to symtab_offset
    while len(out) < symtab_offset { out.push(0) }

    // Symbol table: nlist_64 (16 bytes)
    out = push_u32_le_v(out, 1)
    out.push(n_sect_v() + n_ext_v())
    out.push(1)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, main_offset)

    // String table — "\0_hxlcl_memset\0" (14 bytes)
    out.push(0)
    // "_hxlcl_memset\0"
    //  95='_' 104='h' 120='x' 108='l' 99='c' 108='l' 95='_'
    //  109='m' 101='e' 109='m' 115='s' 101='e' 116='t' 0=NUL
    out.push(95); out.push(104); out.push(120); out.push(108); out.push(99); out.push(108); out.push(95)
    out.push(109); out.push(101); out.push(109); out.push(115); out.push(101); out.push(116); out.push(0)

    return out
}

// ═══════════════════════════════════════════════════════════════════
// Driver
// ═══════════════════════════════════════════════════════════════════
fn emit_hxlcl_memset_o() {
    println("[wire] F3 Path A · rt_memset native override — _hxlcl_memset")

    let code = rt_memset_bytes()
    if len(code) != 28 {
        println("FAIL: rt_memset expected 28 bytes, got " + to_string(len(code)))
        return
    }
    println("  rt_memset bytes: " + to_string(len(code)) + " (28 expected)")

    // mov x3,#0 (03 00 80 d2) sanity at offset 0
    if code[0] != 3 || code[1] != 0 || code[2] != 128 || code[3] != 210 {
        println("FAIL: mov x3,#0 prefix mismatch")
        return
    }
    println("  counter init   : 03 00 80 d2 (mov x3, #0) OK")

    // strb w1,[x0,x3] (01 68 23 38) at offset 12 (the byte-store body)
    if code[12] != 1 || code[13] != 104 || code[14] != 35 || code[15] != 56 {
        println("FAIL: strb w1,[x0,x3] mismatch")
        return
    }
    println("  byte store     : 01 68 23 38 (strb w1, [x0, x3]) OK")

    // ret (c0 03 5f d6) at offset 24
    if code[24] != 192 || code[25] != 3 || code[26] != 95 || code[27] != 214 {
        println("FAIL: ret trailer mismatch")
        return
    }
    println("  ret trailer    : c0 03 5f d6 (ret) OK — x0=dst preserved")

    let obj = macho_obj_wrap_hxlcl_memset(code, 0)
    println("  obj_wrap size  : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 LE at offset 0 (0xFEEDFACF → cf fa ed fe)
    if obj[0] != 0xcf || obj[1] != 0xfa || obj[2] != 0xed || obj[3] != 0xfe {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")

    // filetype = MH_OBJECT (1) at offset 12
    if obj[12] != 1 {
        println("FAIL: filetype not MH_OBJECT")
        return
    }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out_path = env_var("HEXA_HXLCL_MEMSET_O")
    let mut dest = out_path
    if dest == "" { dest = "build/poc/hxlcl_memset.o" }
    write_bytes(dest, obj)
    println("  wrote          : " + dest)
    println("[wire] EMIT OK — link via build recipe with HEXA_RT_SELFEMIT=1")
}

emit_hxlcl_memset_o()
