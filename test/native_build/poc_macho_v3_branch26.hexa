// test/native_build/poc_macho_v3_branch26.hexa
//
// macho_obj_wrap_v3 BRANCH26 + undefined-external link-test (PR #1475 follow-on,
// the #2 runtime.c→hexa-port emit-layer verification).
//
// Proves: a hexa-emitted .o can declare an UNDEFINED external symbol
// (`_poc_target`) and `bl` it via an ARM64_RELOC_BRANCH26 reloc; ld64
// resolves the call to a symbol defined in a SEPARATE C .o at link time.
// This is the cross-object-call path that lets future hexa-emit adapters
// (`_hexa_math_sin`) `bl _rt_sin` into hexa-source rt_* symbols.
//
// SELF-CONTAINED (inlines a minimal macho_obj_wrap_v3 — the verify host's
// module_loader can't resolve `use "self/codegen/macho"` cheaply; the
// SSOT for production callers is self/codegen/macho.hexa::macho_obj_wrap_v3,
// extended with the same BRANCH26+undef logic in PR #1475).
//
// Emitted .o (`_poc_call`):
//   bl _poc_target    ; 0x94000000 placeholder; BRANCH26 reloc → sym[1]
//   ret               ; 0xD65F03C0 ; returns poc_target()'s x0
// Symbols: sym[0]=_poc_call (defined __text @0), sym[1]=_poc_target (undef extern).
// Reloc:   offset 0, kind 2 (BRANCH26), symnum 1, pcrel 1, extern 1, length 2.
//
// Link oracle (clang, downstream of emit — not part of the produced .o):
//   _poc_target defined in C (returns 42), _main calls poc_call → exit 42.

// LINK-TEST STATUS (2026-05-27): emit VERIFIED (303-byte .o, segment
// filesize correct after strtab off-by-one fix). The clang link-oracle
// (clang poc.o caller.c -o exe) could NOT run this session — the pool-route
// hook intercepts every clang/xcrun invocation to a Linux/mini pool host
// whose synced workdir lacks the local /tmp .o (sync is periodic, not
// instant). Run the link on a non-routing local clang to confirm ld64
// accepts BRANCH26+undef (and whether LC_DYSYMTAB is then required).
// NOTE: the PRODUCTION macho_obj_wrap_v3 (self/codegen/macho.hexa) computes
// strtab_size data-driven from len(sym_name_bytes[i]) — it does NOT have
// the hardcoded off-by-one this self-contained PoC originally had (fixed).
//
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return ((val + align - 1) / align) * align
}
fn push_u16_le_v(buf: [int], val: int) -> [int] {
    let mut b = buf
    b.push(val % 0x100); b.push((val / 0x100) % 0x100)
    return b
}
fn push_u32_le_v(buf: [int], val: int) -> [int] {
    let mut b = buf
    b.push(val % 0x100); b.push((val / 0x100) % 0x100)
    b.push((val / 0x10000) % 0x100); b.push((val / 0x1000000) % 0x100)
    return b
}
fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// Minimal macho_obj_wrap_v3 with 2 symbols (1 defined + 1 undef) + 1 BRANCH26
// reloc, single __text section. Mirrors self/codegen/macho.hexa::macho_obj_wrap_v3
// (PR #1475 BRANCH26/undef extension).
fn emit_branch26_obj(code: [int]) -> [int] {
    let mut out = []
    let code_size = len(code)

    // strtab: "\0_poc_call\0_poc_target\0"
    // _poc_call   = 9 chars + NUL = 10 ; strx = 1
    // _poc_target = 11 chars + NUL = 12 ; strx = 1+10 = 11
    let strx_call   = 1
    let strx_target = 11
    let strtab_size = 1 + 10 + 12

    let nsects = 1
    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size
    let header_size = 32
    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let reloc_offset = align_to_v(code_offset + code_size, 4)
    let nreloc = 1
    let reloc_size = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let nsyms = 2
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // header
    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SEGMENT_64 (1 section)
    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, nsects)
    out = push_u32_le_v(out, 0)

    // section_64 __text
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, reloc_offset)
    out = push_u32_le_v(out, nreloc)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SYMTAB
    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, nsyms)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    // pad to code_offset, __text payload
    while len(out) < code_offset { out.push(0) }
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    // pad to reloc_offset, reloc record (BRANCH26)
    while len(out) < reloc_offset { out.push(0) }
    // r_address = 0 (the bl is the first instruction)
    out = push_u32_le_v(out, 0)
    // bits: r_symbolnum=1, r_pcrel=1, r_length=2, r_extern=1, r_type=2 (BRANCH26)
    let r_symnum = 1
    let r_pcrel = 1
    let r_length = 2
    let r_extern = 1
    let r_kind = 2
    let bits = (r_symnum % 0x1000000)
             + (r_pcrel * 0x1000000)
             + (r_length * 0x2000000)
             + (r_extern * 0x8000000)
             + ((r_kind % 16) * 0x10000000)
    out = push_u32_le_v(out, bits)

    // pad to symtab_offset, nlist × 2
    while len(out) < symtab_offset { out.push(0) }
    // sym[0] = _poc_call (defined __text @0)
    out = push_u32_le_v(out, strx_call)
    out.push(n_sect_v() + n_ext_v())   // 0x0f N_SECT|N_EXT
    out.push(1)                        // n_sect = 1 (__text)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)        // n_value = 0
    // sym[1] = _poc_target (UNDEFINED extern)
    out = push_u32_le_v(out, strx_target)
    out.push(n_ext_v())                // 0x01 N_EXT only (undefined)
    out.push(0)                        // n_sect = 0 (NO_SECT)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)        // n_value = 0

    // strtab: "\0_poc_call\0_poc_target\0"
    out.push(0)
    // "_poc_call\0"  (95 _, p o c _ c a l l, 0)
    out.push(95).push(112).push(111).push(99).push(95).push(99).push(97).push(108).push(108).push(0)
    // "_poc_target\0"
    out.push(95).push(112).push(111).push(99).push(95).push(116).push(97).push(114).push(103).push(101).push(116).push(0)

    return out
}

fn main() {
    // _poc_call: bl _poc_target (0x94000000 placeholder) ; ret (0xD65F03C0)
    let mut code = []
    // bl 0 — little-endian 0x94000000 = bytes 00 00 00 94
    code.push(0x00); code.push(0x00); code.push(0x00); code.push(0x94)
    // ret — 0xD65F03C0 = bytes C0 03 5F D6
    code.push(0xC0); code.push(0x03); code.push(0x5F); code.push(0xD6)

    let obj = emit_branch26_obj(code)
    write_bytes("/tmp/poc_macho_v3_branch26.o", obj)
    println("emitted /tmp/poc_macho_v3_branch26.o  (" + to_string(len(obj)) + " bytes)")
    println("strx: _poc_call=1 _poc_target=12  reloc: BRANCH26 off=0 sym=1")
    println("link-oracle: clang poc.o caller.c -o exe && ./exe; echo \\$?  → expect 42")
}
