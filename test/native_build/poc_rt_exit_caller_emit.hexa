#!hexa strict
// self/native/poc_rt_exit_caller_emit.hexa
//   B9.C (.c-text · #1850 pattern) — poc_rt_exit_caller.c source emitter.
//
// B9.C — trivial C caller for the chunk-B/A rt_exit .o bridge PoC (poc_rt_exit_drive.hexa); cited by .verdicts/runtime-arm64-poc-rt-exit/F-PHASEH-CHUNKB-BRIDGE.txt
//
// Emits poc_rt_exit_caller.c VERBATIM. The hexa build regenerates the .c from
// this emitter before compiling, so the emitter becomes the SSOT and the
// .c becomes a build artifact. Byte-identity (gate-1 source-SHA, proven by
// poc_rt_exit_caller_byte_diff.hexa) ⇒ identical .o/.so ⇒ PERF UNCHANGED.
//
// GENERATED by tool/gen_c_text_emitter.hexa — do not hand-edit; re-run the
// generator against the hand-written .c if it ever changes.
//
// Invocation:  hexa-run self/native/poc_rt_exit_caller_emit.hexa <output-path>
// Default output path (if argv missing): "poc_rt_exit_caller.c" in cwd.

let MODULE_NAME = "poc_rt_exit_caller_emit"

fn emit_poc_rt_exit_caller_c() -> str {
    // Verbatim content of hand-written self/native/poc_rt_exit_caller.c
    let s =
            "/* test/native_build/poc_rt_exit_caller.c\n"
          + " *\n"
          + " * Chunk B/A bridge PoC — tiny C caller for hexa-emitted rt_exit .o.\n"
          + " *\n"
          + " * Links against /tmp/poc_rt_exit.o (produced by poc_rt_exit_obj_emit.hexa).\n"
          + " * The .o exports `_hexa_main` (Mach-O underscore convention → `hexa_main`\n"
          + " * in C). rt_exit's 16 bytes set x16=SYS_exit and svc #0x80; they DO NOT\n"
          + " * touch x0, so the syscall consumes whatever x0 the caller set.\n"
          + " *\n"
          + " * On AArch64 macOS ABI, the first arg to hexa_main is passed in x0.\n"
          + " * We pass 42 → exit(42) → shell sees rc=42.\n"
          + " *\n"
          + " * Compile:\n"
          + " *   clang poc_rt_exit_caller.c /tmp/poc_rt_exit.o -o /tmp/poc_rt_exit_run\n"
          + " * Run:\n"
          + " *   /tmp/poc_rt_exit_run ; echo \"rc=$?\"     → rc=42\n"
          + " *\n"
          + " * NO direct exit/_exit syscall here. The C side ONLY tail-calls into\n"
          + " * hexa-emitted bytes; control NEVER returns. main() takes a noreturn\n"
          + " * branch into hexa_main, and the svc terminates the process.\n"
          + " */\n"
          + "\n"
          + "extern void hexa_main(long x0);\n"
          + "\n"
          + "int main(void) {\n"
          + "    hexa_main(42);\n"
          + "    return 99;  /* unreachable — hexa_main does svc #0x80 exit */\n"
          + "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "poc_rt_exit_caller.c" }
    let c_text = emit_poc_rt_exit_caller_c()
    let cmd = "cat > \"" + out_path + "\" <<'GEN_poc_rt_exit_caller_EOF'\n" +
              c_text + "GEN_poc_rt_exit_caller_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[poc_rt_exit_caller_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[poc_rt_exit_caller_emit] wrote " + out_path)
    exit(0)
}
