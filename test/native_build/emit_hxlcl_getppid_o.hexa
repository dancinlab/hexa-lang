// test/native_build/emit_hxlcl_getppid_o.hexa
//
// F3 ACTIVATION RUNBOOK · Path A · wave 2 — class-C syscall ABI 0-arg
// no-errno svc-trap. Production-wire the self-emitted getppid over the C
// `hxlcl_getppid` raw-svc wrapper (self/runtime.c).
//
// EMITS: a Mach-O .o file exporting a strong external symbol `_hxlcl_getppid`
// whose body is rt_getppid's verbatim machine-code — the EXACT rt_getuid
// sequence with only the `mov w16` immediate changed from #24 → #39
// (SYS_GETUID → SYS_GETPPID). When the driver / module_loader is built
// under HEXA_RT_SELFEMIT=1, self/runtime.c declares `hxlcl_getppid` as
// `extern` (no body), and ld64 binds the `bl _hxlcl_getppid` callsites to
// this .o's strong symbol.
//
// ── ABI (class-C syscall · 0-arg no-errno) ──
//
// rt_getppid() takes NO args; loads SYS_GETPPID(39) into x16, zeroes x0,
// issues `svc #0x80`, returns x0 (the kernel-supplied parent pid). getppid
// CANNOT fail on Darwin (no errno path); the plain trap is exact. The 4-instr
// 16-byte sequence matches `as -arch arm64` byte-for-byte:
//   mov w16, #39 ; mov x0, #0 ; svc #0x80 ; ret
//
// ── HONESTY ──
//
//   - closure = runs exact — must return the SAME ppid as libc getppid().
//   - f1/f2 — clang ONLY as link-side oracle, NEVER in emit path.
//   - selfhosted opt-in — HEXA_RT_SELFEMIT=1 gates the build append.
//   - no binaries committed.
//
// SELF-CONTAINED. Deliberate diffs vs getuid: (1) `mov w16,#39` bytes,
// (2) symbol name `_hxlcl_getppid` (14 B → strtab_size = 1+14 = 15).

// ═══════════════════════════════════════════════════════════════════
// Inlined from self/codegen/runtime_arm64.hexa::rt_getppid
// 4 instructions, 16 bytes. mov w16,#39 / mov x0,#0 / svc #0x80 / ret.
// ═══════════════════════════════════════════════════════════════════
fn rt_getppid_bytes() -> [int] {
    let mut c = []
    // mov w16, #39  (SYS_GETPPID)    0x528004F0
    c.push(240); c.push(4); c.push(128); c.push(82)
    // mov x0, #0   (no syscall arg)  0xD2800000
    c.push(0); c.push(0); c.push(128); c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1); c.push(16); c.push(0); c.push(212)
    // ret  (x0 = ppid)               0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// ═══════════════════════════════════════════════════════════════════
// Inlined macho_obj_wrap helpers (same shape as the getuid driver, with
// the symbol-name length bumped 13 → 14).
// ═══════════════════════════════════════════════════════════════════
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

fn push_u16_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

fn push_u32_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}

fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// Symbol exported = `_hxlcl_getppid` (strtab_size = 1 + 14 NUL-term = 15).
fn macho_obj_wrap_hxlcl_getppid(code: [int], main_offset: int) -> [int] {
    let mut out = []
    let code_size = len(code)

    let header_size = 32
    let segment_cmd_size = 152
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let symtab_offset = align_to_v(code_offset + code_size, 4)
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size
    // strtab = "\0_hxlcl_getppid\0" = 1 + 14 = 15 bytes.
    let strtab_size = 1 + 14

    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, align_to_v(strtab_offset + strtab_size, 8))
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, strtab_offset + strtab_size - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0)

    out.push(95); out.push(95); out.push(116); out.push(101); out.push(120); out.push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95); out.push(95); out.push(84); out.push(69); out.push(88); out.push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    while len(out) < code_offset { out.push(0) }

    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    while len(out) < symtab_offset { out.push(0) }

    out = push_u32_le_v(out, 1)
    out.push(n_sect_v() + n_ext_v())
    out.push(1)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, main_offset)

    // String table — "\0_hxlcl_getppid\0" (15 bytes)
    out.push(0)
    // "_hxlcl_getppid\0"
    //  95='_' 104='h' 120='x' 108='l' 99='c' 108='l' 95='_'
    //  103='g' 101='e' 116='t' 112='p' 112='p' 105='i' 100='d' 0=NUL
    out.push(95); out.push(104); out.push(120); out.push(108); out.push(99); out.push(108); out.push(95)
    out.push(103); out.push(101); out.push(116); out.push(112); out.push(112); out.push(105); out.push(100); out.push(0)

    return out
}

// ═══════════════════════════════════════════════════════════════════
// Driver
// ═══════════════════════════════════════════════════════════════════
fn emit_hxlcl_getppid_o() {
    println("[wire] F3 Path A · wave 2 · rt_getppid native override — _hxlcl_getppid")

    let code = rt_getppid_bytes()
    if len(code) != 16 {
        println("FAIL: rt_getppid expected 16 bytes, got " + to_string(len(code)))
        return
    }
    println("  rt_getppid bytes: " + to_string(len(code)) + " (16 expected)")

    // mov w16,#39 (f0 04 80 52) sanity at offset 0 — SYS_GETPPID into x16
    if code[0] != 240 || code[1] != 4 || code[2] != 128 || code[3] != 82 {
        println("FAIL: mov w16,#39 prefix mismatch")
        return
    }
    println("  syscall number : f0 04 80 52 (mov w16, #39 = SYS_GETPPID) OK")

    if code[8] != 1 || code[9] != 16 || code[10] != 0 || code[11] != 212 {
        println("FAIL: svc #0x80 mismatch")
        return
    }
    println("  syscall trap   : 01 10 00 d4 (svc #0x80) OK")

    if code[12] != 192 || code[13] != 3 || code[14] != 95 || code[15] != 214 {
        println("FAIL: ret trailer mismatch")
        return
    }
    println("  ret trailer    : c0 03 5f d6 (ret) OK — x0=ppid returned")

    let obj = macho_obj_wrap_hxlcl_getppid(code, 0)
    println("  obj_wrap size  : " + to_string(len(obj)) + " bytes total")

    if obj[0] != 0xcf || obj[1] != 0xfa || obj[2] != 0xed || obj[3] != 0xfe {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")

    if obj[12] != 1 {
        println("FAIL: filetype not MH_OBJECT")
        return
    }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out_path = env_var("HEXA_HXLCL_GETPPID_O")
    let mut dest = out_path
    if dest == "" { dest = "build/poc/hxlcl_getppid.o" }
    write_bytes(dest, obj)
    println("  wrote          : " + dest)
    println("[wire] EMIT OK — link via build recipe with HEXA_RT_SELFEMIT=1")
}

emit_hxlcl_getppid_o()
