// test/native_build/poc_multi_sym_emit.hexa
//
// HEXA_BACKEND flip chunk-B phase-H — PR #1297 residual #1 closure PoC.
//
// Bundles MULTIPLE primitive functions into ONE hexa-emit .o file:
//   _rt_exit     at offset  0 — 16 bytes (SYS_exit)
//   _rt_alloc    at offset 16 — 48 bytes (mmap-anon)
//   _hexa_main   at offset 64 — 16 bytes (BL rt_alloc · BL rt_exit(42))
//
// Both `_rt_exit` and `_rt_alloc` are now exposed as external symbols
// (visible in `nm`), proving macho_obj_wrap_v3's multi-symbol symtab
// emit is correct. v1 (`macho_obj_wrap`) and v2 (`macho_obj_wrap_v2`)
// could only emit a single `_hexa_main` symbol — this was the structural
// blocker for wiring runtime_arm64.hexa primitives into production.
//
// PIPELINE (NO clang in object production):
//   1. Concat rt_exit() · rt_alloc() · _hexa_main() bytes  → [int]
//   2. macho_obj_wrap_v3 with 3 sym names, all in __text   → MH_OBJECT bytes
//   3. write_bytes("/tmp/poc_multi_sym.o", obj)            → file
//
// Inlined per the same convention as poc_rt_exit_obj_emit.hexa (compiled
// module_loader absent on local build hosts ⇒ multi-`use` link-fails).
// Byte-identical to self/codegen/runtime_arm64.hexa rt_exit + rt_alloc.
//
// Cross-cutting:
//   - closure = exact: each exported symbol must show up in `nm` AND
//     `_hexa_main` must call `_rt_alloc` + `_rt_exit` via intra-__text
//     PC-relative BL → process exits with 42.
//   - selfhosted opt-in (hexa-emit object, clang only as link control).
//   - g5 verbatim: stdout from verify scripts pasted unchanged.

// ─── Inlined byte arrays — verbatim from self/codegen/runtime_arm64.hexa
fn rt_exit_bytes() -> [int] {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253).push(123).push(191).push(169)
    // mov x29, sp                    0x910003FD
    c.push(253).push(3).push(0).push(145)
    // mov x16, #1 (SYS_exit)         0xD2800030
    c.push(48).push(0).push(128).push(210)
    // svc #0x80                      0xD4001001
    c.push(1).push(16).push(0).push(212)
    return c
}

fn rt_alloc_bytes() -> [int] {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253).push(123).push(191).push(169)
    // mov x29, sp                    0x910003FD
    c.push(253).push(3).push(0).push(145)
    // mov x1, x0  (size -> x1)      0xAA0003E1
    c.push(225).push(3).push(0).push(170)
    // mov x0, #0  (addr=NULL)       0xD2800000
    c.push(0).push(0).push(128).push(210)
    // mov x2, #3  (PROT_RW)         0xD2800062
    c.push(98).push(0).push(128).push(210)
    // mov x3, #0x1002 (MAP)         0xD2820043
    c.push(67).push(0).push(130).push(210)
    // movn x4, #0 (fd=-1)           0x92800004
    c.push(4).push(0).push(128).push(146)
    // mov x5, #0  (offset)          0xD2800005
    c.push(5).push(0).push(128).push(210)
    // mov x16, #197 (SYS_mmap)      0xD28018B0
    c.push(176).push(24).push(128).push(210)
    // svc #0x80                      0xD4001001
    c.push(1).push(16).push(0).push(212)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c.push(253).push(123).push(193).push(168)
    // ret                            0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}

// _hexa_main at offset 64 — calls rt_alloc(64), then rt_exit(42).
// All BL targets are WITHIN this same __text section; offsets are
// fixed at emit time and the linker passes them through (BL to a
// same-section relative target needs no relocation when both
// instructions and target land in the SAME final __text).
//
// _hexa_main prologue/epilogue elided (we never return — rt_exit
// terminates the process via svc #0x80 SYS_exit).
//
// Instr layout (PC values relative to _hexa_main start at offset 64):
//   PC=64  mov x0, #64        movz w0, #0x40       0xD2800800
//   PC=68  bl rt_alloc        offset 16 - 68 = -52 = -13 instr
//                             imm26 (sign-ext 26-bit) = 0x03FFFFF3
//                             0x94000000 | 0x03FFFFF3 = 0x97FFFFF3
//   PC=72  mov x0, #42        movz w0, #0x2A       0xD2800540
//   PC=76  bl rt_exit         offset 0  - 76 = -76 = -19 instr
//                             imm26 (sign-ext 26-bit) = 0x03FFFFED
//                             0x94000000 | 0x03FFFFED = 0x97FFFFED
fn hexa_main_bytes() -> [int] {
    let mut c = []
    // mov x0, #64                    0xD2800800 → 00 08 80 D2
    c.push(0).push(8).push(128).push(210)
    // bl rt_alloc (delta=-52 bytes)  0x97FFFFF3 → F3 FF FF 97
    c.push(243).push(255).push(255).push(151)
    // mov x0, #42                    0xD2800540 → 40 05 80 D2
    c.push(64).push(5).push(128).push(210)
    // bl rt_exit (delta=-76 bytes)   0x97FFFFED → ED FF FF 97
    c.push(237).push(255).push(255).push(151)
    return c
}

// ─── helpers (inlined from self/codegen/macho.hexa) ───────────────

fn push_u16_le(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

fn push_u32_le(buf: [int], val: int) -> [int] {
    return buf
      .push(val % 256)
      .push((val / 256) % 256)
      .push((val / 65536) % 256)
      .push((val / 16777216) % 256)
}

fn push_u64_le(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le(buf, val % 0x100000000)
    return push_u32_le(b, val / 0x100000000)
}

fn align_to(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

// ─── macho_obj_wrap_v3 (verbatim inline from self/codegen/macho.hexa) ─

fn macho_obj_wrap_v3(code: [int],
                     sym_name_bytes: [[int]],
                     sym_offsets: [int],
                     sym_sections: [int],
                     state_bytes: [int],
                     reloc_offs: [int],
                     reloc_kinds: [int],
                     reloc_symnums: [int]) -> [int] {
    let mut out = []
    let code_size  = len(code)
    let state_size = len(state_bytes)
    let nreloc     = len(reloc_offs)
    let nsyms      = len(sym_name_bytes)

    let mut sym_strx: [int] = []
    let mut strtab_size = 1
    let mut si = 0
    while si < nsyms {
        sym_strx.push(strtab_size)
        strtab_size = strtab_size + len(sym_name_bytes[si])
        si = si + 1
    }

    let mut nsects = 1
    if state_size > 0 { nsects = 2 }

    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let header_size = 32
    let code_offset = align_to(header_size + sizeofcmds, 8)

    let mut const_offset = code_offset + code_size
    if state_size > 0 {
        const_offset = align_to(code_offset + code_size, 8)
    }
    let data_end = const_offset + state_size

    let reloc_offset = align_to(data_end, 4)
    let reloc_size   = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header (32 bytes)
    out = push_u32_le(out, 0xFEEDFACF)
    out = push_u32_le(out, 0x0100000C)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 3)
    out = push_u32_le(out, sizeofcmds)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    // LC_SEGMENT_64
    out = push_u32_le(out, 0x19)
    out = push_u32_le(out, segment_cmd_size)
    let mut i0 = 0
    while i0 < 16 { out.push(0); i0 = i0 + 1 }
    out = push_u64_le(out, 0)
    out = push_u64_le(out, total_end - code_offset)
    out = push_u64_le(out, code_offset)
    out = push_u64_le(out, total_end - code_offset)
    out = push_u32_le(out, 7)
    out = push_u32_le(out, 7)
    out = push_u32_le(out, nsects)
    out = push_u32_le(out, 0)

    // section_64 __text (80 bytes)
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j0 = 0
    while j0 < 10 { out.push(0); j0 = j0 + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j0 = 0
    while j0 < 10 { out.push(0); j0 = j0 + 1 }
    out = push_u64_le(out, 0)
    out = push_u64_le(out, code_size)
    out = push_u32_le(out, code_offset)
    out = push_u32_le(out, 2)
    out = push_u32_le(out, reloc_offset)
    out = push_u32_le(out, nreloc)
    out = push_u32_le(out, 0x80000400)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    if state_size > 0 {
        out.push(95).push(95).push(99).push(111).push(110).push(115).push(116)
        let mut j1 = 0
        while j1 < 9 { out.push(0); j1 = j1 + 1 }
        out.push(95).push(95).push(84).push(69).push(88).push(84)
        j1 = 0
        while j1 < 10 { out.push(0); j1 = j1 + 1 }
        out = push_u64_le(out, code_size)
        out = push_u64_le(out, state_size)
        out = push_u32_le(out, const_offset)
        out = push_u32_le(out, 3)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
    }

    // LC_SYMTAB (24 bytes)
    out = push_u32_le(out, 0x02)
    out = push_u32_le(out, symtab_cmd_size)
    out = push_u32_le(out, symtab_offset)
    out = push_u32_le(out, nsyms)
    out = push_u32_le(out, strtab_offset)
    out = push_u32_le(out, strtab_size)

    // LC_BUILD_VERSION (24 bytes)
    out = push_u32_le(out, 0x32)
    out = push_u32_le(out, build_version_cmd_size)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0)

    while len(out) < code_offset { out.push(0) }
    let mut k0 = 0
    while k0 < len(code) { out.push(code[k0]); k0 = k0 + 1 }

    if state_size > 0 {
        while len(out) < const_offset { out.push(0) }
        let mut sb = 0
        while sb < state_size { out.push(state_bytes[sb]); sb = sb + 1 }
    }

    while len(out) < reloc_offset { out.push(0) }
    let mut ri = 0
    while ri < nreloc {
        let r_off    = reloc_offs[ri]
        let r_kind   = reloc_kinds[ri]
        let r_symnum = reloc_symnums[ri]
        out = push_u32_le(out, r_off)
        let mut r_pcrel = 0
        if r_kind == 3 { r_pcrel = 1 }
        let r_length = 2
        let r_extern = 1
        let bits = (r_symnum % 0x1000000)
                 + (r_pcrel * 0x1000000)
                 + (r_length * 0x2000000)
                 + (r_extern * 0x8000000)
                 + ((r_kind % 16) * 0x10000000)
        out = push_u32_le(out, bits)
        ri = ri + 1
    }

    while len(out) < symtab_offset { out.push(0) }
    let mut sj = 0
    while sj < nsyms {
        let s_strx    = sym_strx[sj]
        let s_offset  = sym_offsets[sj]
        let s_section = sym_sections[sj]
        let mut n_value = s_offset
        if s_section == 2 { n_value = code_size + s_offset }
        out = push_u32_le(out, s_strx)
        out.push(0x0E + 0x01)
        out.push(s_section)
        out = push_u16_le(out, 0)
        out = push_u64_le(out, n_value)
        sj = sj + 1
    }

    // String table: "\0<name0>\0<name1>\0..."
    out.push(0)
    let mut sk = 0
    while sk < nsyms {
        let nb = sym_name_bytes[sk]
        let mut nbi = 0
        while nbi < len(nb) {
            out.push(nb[nbi])
            nbi = nbi + 1
        }
        sk = sk + 1
    }

    return out
}

// ─── driver ───────────────────────────────────────────────────────

fn main() {
    println("=== PoC multi-symbol .o emit — rt_exit + rt_alloc + _hexa_main ===")

    // Build the concatenated __text bytes.
    let rt_exit  = rt_exit_bytes()
    let rt_alloc = rt_alloc_bytes()
    let hxmain   = hexa_main_bytes()
    println("rt_exit   bytes : " + to_string(len(rt_exit)) + " (16 expected)")
    println("rt_alloc  bytes : " + to_string(len(rt_alloc)) + " (48 expected)")
    println("hexa_main bytes : " + to_string(len(hxmain)) + " (16 expected)")

    let mut code = []
    let mut ce = 0
    while ce < len(rt_exit)  { code.push(rt_exit[ce]);  ce = ce + 1 }
    let mut ca = 0
    while ca < len(rt_alloc) { code.push(rt_alloc[ca]); ca = ca + 1 }
    let mut cm = 0
    while cm < len(hxmain)   { code.push(hxmain[cm]);   cm = cm + 1 }
    println("total code      : " + to_string(len(code)) + " (80 expected)")

    // Sanity: SVC #0x80 at offset 12 (end of rt_exit) and 60 (end of svc inside rt_alloc body, before ldp/ret).
    // rt_alloc has svc #0x80 at the 10th instr → offset 16 + 9*4 = 52.
    if code[12] != 1   { println("FAIL: rt_exit  svc[0]") }
    if code[15] != 212 { println("FAIL: rt_exit  svc[3]") }
    if code[52] != 1   { println("FAIL: rt_alloc svc[0]") }
    if code[55] != 212 { println("FAIL: rt_alloc svc[3]") }
    println("svc trailers   : rt_exit @12 + rt_alloc @52 OK")

    // BL target bytes inside _hexa_main:
    //   instr @ code[68..72] = BL rt_alloc → F3 FF FF 97
    //   instr @ code[76..80] = BL rt_exit  → ED FF FF 97
    if code[68] != 243 || code[69] != 255 || code[70] != 255 || code[71] != 151 {
        println("FAIL: BL rt_alloc encoding mismatch")
    }
    if code[76] != 237 || code[77] != 255 || code[78] != 255 || code[79] != 151 {
        println("FAIL: BL rt_exit encoding mismatch")
    }
    println("BL encodings   : rt_alloc@68 + rt_exit@76 OK")

    // ── Build sym tables ────────────────────────────────────────────
    // Three text symbols, all section 1 (__text):
    //   [0] _rt_exit     offset  0
    //   [1] _rt_alloc    offset 16
    //   [2] _hexa_main   offset 64
    //
    // Symbol-name bytes (NUL-terminated, byte literals):
    //   "_rt_exit\0"   = 95 114 116 95 101 120 105 116 0   (9 bytes)
    //   "_rt_alloc\0"  = 95 114 116 95 97 108 108 111 99 0 (10 bytes)
    //   "_hexa_main\0" = 95 104 101 120 97 95 109 97 105 110 0 (11 bytes)

    let mut name_rt_exit = []
    name_rt_exit.push(95).push(114).push(116).push(95).push(101).push(120).push(105).push(116).push(0)

    let mut name_rt_alloc = []
    name_rt_alloc.push(95).push(114).push(116).push(95).push(97).push(108).push(108).push(111).push(99).push(0)

    let mut name_hexa_main = []
    name_hexa_main.push(95).push(104).push(101).push(120).push(97).push(95).push(109).push(97).push(105).push(110).push(0)

    let mut sym_name_bytes = []
    sym_name_bytes.push(name_rt_exit).push(name_rt_alloc).push(name_hexa_main)

    let mut sym_offsets = []
    sym_offsets.push(0).push(16).push(64)

    let mut sym_sections = []
    sym_sections.push(1).push(1).push(1)

    // No relocs, no __const.
    let state_bytes  = []
    let reloc_offs   = []
    let reloc_kinds  = []
    let reloc_symnums = []

    let obj = macho_obj_wrap_v3(code, sym_name_bytes, sym_offsets,
                                sym_sections, state_bytes,
                                reloc_offs, reloc_kinds, reloc_symnums)
    println("obj size       : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 = FEEDFACF → CF FA ED FE
    if obj[0] != 207 { println("FAIL: magic[0]") }
    if obj[1] != 250 { println("FAIL: magic[1]") }
    if obj[2] != 237 { println("FAIL: magic[2]") }
    if obj[3] != 254 { println("FAIL: magic[3]") }
    println("MH_MAGIC_64    : cf fa ed fe OK")

    if obj[12] != 1 { println("FAIL: filetype != 1") }
    println("filetype       : 1 (MH_OBJECT) OK")

    write_bytes("/tmp/poc_multi_sym.o", obj)
    println("wrote          : /tmp/poc_multi_sym.o")
    println("[poc] EMIT OK")
}

// auto-invoke handles main()
