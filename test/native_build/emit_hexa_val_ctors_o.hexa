// test/native_build/emit_hexa_val_ctors_o.hexa
//
// B9.6 / F3 class-D — FIRST struct-return (x0:x1 register-pair) self-emit.
//
// EMITS: a Mach-O .o exporting SIX strong external symbols whose bodies
// are the verbatim machine code for the runtime's universal HexaVal
// constructors:
//   _hexa_void       offset  0 — 12 B  hexa_void()  -> {tag=TAG_VOID(4)}
//   _hexa_int        offset 12 — 12 B  hexa_int(n)  -> {tag=TAG_INT(0),.i=n}
//   _hexa_bool       offset 24 — 12 B  hexa_bool(b) -> {tag=TAG_BOOL(2),.b=b}
//   _hexa_float      offset 36 — 12 B  hexa_float(f)-> {tag=TAG_FLOAT(1),.f=f}
//   _hexa_enum_str   offset 48 — 12 B  hexa_enum_str(s)  -> {tag=TAG_ENUM(11),.s=s}
//   _hexa_enum_str_v offset 60 — 12 B  hexa_enum_str_v(d)-> {tag=TAG_ENUM(11),.s=d}
//
// (B9.6-D2 scale-out: _hexa_float/_hexa_enum_str/_hexa_enum_str_v added to the
//  original #1858 _hexa_void/_hexa_int/_hexa_bool bundle — same multi-symbol .o.)
//
// Each returns a 16-byte aggregate by value. On AAPCS arm64 a ≤16-byte
// aggregate is returned in the x0:x1 register PAIR (NRRP — no hidden x8
// indirect-result pointer). x0 = low 8 bytes (the tag), x1 = high 8 bytes
// (the union value). These are the FIRST self-emit leaves that set x1 —
// every prior leaf in self/codegen/runtime_arm64.hexa returns a single x0.
//
// ── ABI (verified vs clang -O2 -S of runtime_core.c ctors, assembled
//    with `as -arch arm64`, byte-confirmed via otool) ──
//   hexa_void       : mov w0,#4 ; mov x1,#0  ; ret  (constant tag + zero value)
//   hexa_int        : mov x1,x0 ; mov x0,#0  ; ret  (x1<-arg BEFORE x0<-tag)
//   hexa_bool       : mov w1,w0 ; mov w0,#2  ; ret  (w1<-arg BEFORE w0<-tag)
//   hexa_float      : fmov x1,d0; mov w0,#1  ; ret  (FP-arg d0->x1, raw bits)
//   hexa_enum_str   : mov x1,x0 ; mov w0,#11 ; ret  (ptr-store, no malloc)
//   hexa_enum_str_v : mov x1,x0 ; mov w0,#11 ; ret  (byte-identical to enum_str)
//
// ── HONESTY ──
//   - closure = runs exact: a C driver calling these symbols (declared
//     with the real HexaVal return type) must read back the correct
//     {tag, value} for each — JIT-exec correctness gate (poc_drive).
//   - f1/f2 — clang ONLY as link-side oracle, NEVER in this .o's emit
//     path (the 36 bytes come from the inlined ctor sequences below).
//   - selfhosted opt-in — these symbols are OPT-IN self-emit externs
//     (HEXA_RT_SELFEMIT path in runtime_core.c), NOT libc externs; the
//     default build keeps the static-inline C ctors (0-extern preserved).
//   - no binaries committed.
//
// SELF-CONTAINED: same module-loader rationale as poc_multi_sym_emit.hexa
// (the local repo has no compiled module_loader, so multi-`use` programs
// link-fail). macho_obj_wrap_v3 + helpers inlined verbatim; the ctor
// bytes are character-identical to self/codegen/runtime_arm64.hexa
// rt_hexa_void / rt_hexa_int / rt_hexa_bool.

// ═══════════════════════════════════════════════════════════════════
// Inlined from self/codegen/runtime_arm64.hexa — the three ctors.
// ═══════════════════════════════════════════════════════════════════
fn rt_hexa_void_bytes() -> [int] {
    let mut c = []
    // mov w0, #4   (tag = TAG_VOID)   0x52800080
    c.push(128).push(0).push(128).push(82)
    // mov x1, #0   (union half = 0)   0xD2800001
    c.push(1).push(0).push(128).push(210)
    // ret                             0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}
fn rt_hexa_int_bytes() -> [int] {
    let mut c = []
    // mov x1, x0   (union half = n)   0xAA0003E1
    c.push(225).push(3).push(0).push(170)
    // mov x0, #0   (tag = TAG_INT)    0xD2800000
    c.push(0).push(0).push(128).push(210)
    // ret                             0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}
fn rt_hexa_bool_bytes() -> [int] {
    let mut c = []
    // mov w1, w0   (union half = b)   0x2A0003E1
    c.push(225).push(3).push(0).push(42)
    // mov w0, #2   (tag = TAG_BOOL)   0x52800040
    c.push(64).push(0).push(128).push(82)
    // ret                             0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}
// B9.6-D2 scale-out — 3 more struct-build ctors. Bytes character-identical
// to self/codegen/runtime_arm64.hexa rt_hexa_float / rt_hexa_enum_str /
// rt_hexa_enum_str_v.
fn rt_hexa_float_bytes() -> [int] {
    let mut c = []
    // fmov x1, d0  (union half = raw f bits)  0x9E660001
    c.push(1).push(0).push(102).push(158)
    // mov w0, #1   (tag = TAG_FLOAT)          0x52800020
    c.push(32).push(0).push(128).push(82)
    // ret                                     0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}
fn rt_hexa_enum_str_bytes() -> [int] {
    let mut c = []
    // mov x1, x0   (union half = display ptr) 0xAA0003E1
    c.push(225).push(3).push(0).push(170)
    // mov w0, #11  (tag = TAG_ENUM)           0x52800160
    c.push(96).push(1).push(128).push(82)
    // ret                                     0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}
fn rt_hexa_enum_str_v_bytes() -> [int] {
    let mut c = []
    // mov x1, x0   (union half = desc ptr)    0xAA0003E1 (byte-identical to enum_str)
    c.push(225).push(3).push(0).push(170)
    // mov w0, #11  (tag = TAG_ENUM)           0x52800160
    c.push(96).push(1).push(128).push(82)
    // ret                                     0xD65F03C0
    c.push(192).push(3).push(95).push(214)
    return c
}

// ─── helpers (inlined from self/codegen/macho.hexa) ───────────────
fn push_u16_le(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}
fn push_u32_le(buf: [int], val: int) -> [int] {
    return buf
      .push(val % 256)
      .push((val / 256) % 256)
      .push((val / 65536) % 256)
      .push((val / 16777216) % 256)
}
fn push_u64_le(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le(buf, val % 0x100000000)
    return push_u32_le(b, val / 0x100000000)
}
fn align_to(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

// ─── macho_obj_wrap_v3 (verbatim inline from poc_multi_sym_emit.hexa) ─
fn macho_obj_wrap_v3(code: [int],
                     sym_name_bytes: [[int]],
                     sym_offsets: [int],
                     sym_sections: [int],
                     state_bytes: [int],
                     reloc_offs: [int],
                     reloc_kinds: [int],
                     reloc_symnums: [int]) -> [int] {
    let mut out = []
    let code_size  = len(code)
    let state_size = len(state_bytes)
    let nreloc     = len(reloc_offs)
    let nsyms      = len(sym_name_bytes)

    let mut sym_strx: [int] = []
    let mut strtab_size = 1
    let mut si = 0
    while si < nsyms {
        sym_strx.push(strtab_size)
        strtab_size = strtab_size + len(sym_name_bytes[si])
        si = si + 1
    }

    let mut nsects = 1
    if state_size > 0 { nsects = 2 }

    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let header_size = 32
    let code_offset = align_to(header_size + sizeofcmds, 8)

    let mut const_offset = code_offset + code_size
    if state_size > 0 {
        const_offset = align_to(code_offset + code_size, 8)
    }
    let data_end = const_offset + state_size

    let reloc_offset = align_to(data_end, 4)
    let reloc_size   = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header (32 bytes)
    out = push_u32_le(out, 0xFEEDFACF)
    out = push_u32_le(out, 0x0100000C)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 3)
    out = push_u32_le(out, sizeofcmds)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    // LC_SEGMENT_64
    out = push_u32_le(out, 0x19)
    out = push_u32_le(out, segment_cmd_size)
    let mut i0 = 0
    while i0 < 16 { out.push(0); i0 = i0 + 1 }
    out = push_u64_le(out, 0)
    out = push_u64_le(out, total_end - code_offset)
    out = push_u64_le(out, code_offset)
    out = push_u64_le(out, total_end - code_offset)
    out = push_u32_le(out, 7)
    out = push_u32_le(out, 7)
    out = push_u32_le(out, nsects)
    out = push_u32_le(out, 0)

    // section_64 __text (80 bytes)
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j0 = 0
    while j0 < 10 { out.push(0); j0 = j0 + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j0 = 0
    while j0 < 10 { out.push(0); j0 = j0 + 1 }
    out = push_u64_le(out, 0)
    out = push_u64_le(out, code_size)
    out = push_u32_le(out, code_offset)
    out = push_u32_le(out, 2)
    out = push_u32_le(out, reloc_offset)
    out = push_u32_le(out, nreloc)
    out = push_u32_le(out, 0x80000400)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    if state_size > 0 {
        out.push(95).push(95).push(99).push(111).push(110).push(115).push(116)
        let mut j1 = 0
        while j1 < 9 { out.push(0); j1 = j1 + 1 }
        out.push(95).push(95).push(84).push(69).push(88).push(84)
        j1 = 0
        while j1 < 10 { out.push(0); j1 = j1 + 1 }
        out = push_u64_le(out, code_size)
        out = push_u64_le(out, state_size)
        out = push_u32_le(out, const_offset)
        out = push_u32_le(out, 3)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
    }

    // LC_SYMTAB (24 bytes)
    out = push_u32_le(out, 0x02)
    out = push_u32_le(out, symtab_cmd_size)
    out = push_u32_le(out, symtab_offset)
    out = push_u32_le(out, nsyms)
    out = push_u32_le(out, strtab_offset)
    out = push_u32_le(out, strtab_size)

    // LC_BUILD_VERSION (24 bytes)
    out = push_u32_le(out, 0x32)
    out = push_u32_le(out, build_version_cmd_size)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0)

    while len(out) < code_offset { out.push(0) }
    let mut k0 = 0
    while k0 < len(code) { out.push(code[k0]); k0 = k0 + 1 }

    if state_size > 0 {
        while len(out) < const_offset { out.push(0) }
        let mut sb = 0
        while sb < state_size { out.push(state_bytes[sb]); sb = sb + 1 }
    }

    while len(out) < reloc_offset { out.push(0) }
    let mut ri = 0
    while ri < nreloc {
        let r_off    = reloc_offs[ri]
        let r_kind   = reloc_kinds[ri]
        let r_symnum = reloc_symnums[ri]
        out = push_u32_le(out, r_off)
        let mut r_pcrel = 0
        if r_kind == 3 { r_pcrel = 1 }
        let r_length = 2
        let r_extern = 1
        let bits = (r_symnum % 0x1000000)
                 + (r_pcrel * 0x1000000)
                 + (r_length * 0x2000000)
                 + (r_extern * 0x8000000)
                 + ((r_kind % 16) * 0x10000000)
        out = push_u32_le(out, bits)
        ri = ri + 1
    }

    while len(out) < symtab_offset { out.push(0) }
    let mut sj = 0
    while sj < nsyms {
        let s_strx    = sym_strx[sj]
        let s_offset  = sym_offsets[sj]
        let s_section = sym_sections[sj]
        let mut n_value = s_offset
        if s_section == 2 { n_value = code_size + s_offset }
        out = push_u32_le(out, s_strx)
        out.push(0x0E + 0x01)
        out.push(s_section)
        out = push_u16_le(out, 0)
        out = push_u64_le(out, n_value)
        sj = sj + 1
    }

    // String table: "\0<name0>\0<name1>\0..."
    out.push(0)
    let mut sk = 0
    while sk < nsyms {
        let nb = sym_name_bytes[sk]
        let mut nbi = 0
        while nbi < len(nb) {
            out.push(nb[nbi])
            nbi = nbi + 1
        }
        sk = sk + 1
    }

    return out
}

// ─── driver ───────────────────────────────────────────────────────
fn main() {
    println("[wire] B9.6/F3 class-D · HexaVal struct-return ctors — void/int/bool/float/enum_str/enum_str_v")

    let hvoid = rt_hexa_void_bytes()
    let hint  = rt_hexa_int_bytes()
    let hbool = rt_hexa_bool_bytes()
    let hfloat = rt_hexa_float_bytes()
    let henum  = rt_hexa_enum_str_bytes()
    let henumv = rt_hexa_enum_str_v_bytes()
    if len(hvoid) != 12 || len(hint) != 12 || len(hbool) != 12
       || len(hfloat) != 12 || len(henum) != 12 || len(henumv) != 12 {
        println("FAIL: each ctor must be 12 bytes")
        return
    }
    println("  ctor bytes     : void=12 int=12 bool=12 float=12 enum_str=12 enum_str_v=12 OK")

    // Concatenate: void(0) · int(12) · bool(24) · float(36) · enum_str(48) · enum_str_v(60).
    let mut code = []
    let mut a = 0
    while a < len(hvoid) { code.push(hvoid[a]); a = a + 1 }
    let mut b = 0
    while b < len(hint)  { code.push(hint[b]);  b = b + 1 }
    let mut d = 0
    while d < len(hbool) { code.push(hbool[d]); d = d + 1 }
    let mut e = 0
    while e < len(hfloat) { code.push(hfloat[e]); e = e + 1 }
    let mut g = 0
    while g < len(henum) { code.push(henum[g]); g = g + 1 }
    let mut h = 0
    while h < len(henumv) { code.push(henumv[h]); h = h + 1 }
    println("  total code     : " + to_string(len(code)) + " (72 expected)")

    // Symbol name bytes (NUL-terminated):
    //   "_hexa_void\0" = 95 104 101 120 97 95 118 111 105 100 0   (11 bytes)
    //   "_hexa_int\0"  = 95 104 101 120 97 95 105 110 116 0       (10 bytes)
    //   "_hexa_bool\0" = 95 104 101 120 97 95 98 111 111 108 0    (11 bytes)
    let mut name_void = []
    name_void.push(95).push(104).push(101).push(120).push(97).push(95).push(118).push(111).push(105).push(100).push(0)
    let mut name_int = []
    name_int.push(95).push(104).push(101).push(120).push(97).push(95).push(105).push(110).push(116).push(0)
    let mut name_bool = []
    name_bool.push(95).push(104).push(101).push(120).push(97).push(95).push(98).push(111).push(111).push(108).push(0)
    // B9.6-D2 scale-out symbol names (NUL-terminated):
    //   "_hexa_float\0"      (12 bytes)
    //   "_hexa_enum_str\0"   (15 bytes)
    //   "_hexa_enum_str_v\0" (17 bytes)
    let mut name_float = []
    name_float.push(95).push(104).push(101).push(120).push(97).push(95).push(102).push(108).push(111).push(97).push(116).push(0)
    let mut name_enum = []
    name_enum.push(95).push(104).push(101).push(120).push(97).push(95).push(101).push(110).push(117).push(109).push(95).push(115).push(116).push(114).push(0)
    let mut name_enumv = []
    name_enumv.push(95).push(104).push(101).push(120).push(97).push(95).push(101).push(110).push(117).push(109).push(95).push(115).push(116).push(114).push(95).push(118).push(0)

    let mut sym_name_bytes = []
    sym_name_bytes.push(name_void).push(name_int).push(name_bool).push(name_float).push(name_enum).push(name_enumv)
    let mut sym_offsets = []
    sym_offsets.push(0).push(12).push(24).push(36).push(48).push(60)
    let mut sym_sections = []
    sym_sections.push(1).push(1).push(1).push(1).push(1).push(1)

    let state_bytes   = []
    let reloc_offs    = []
    let reloc_kinds   = []
    let reloc_symnums = []

    let obj = macho_obj_wrap_v3(code, sym_name_bytes, sym_offsets,
                                sym_sections, state_bytes,
                                reloc_offs, reloc_kinds, reloc_symnums)
    println("  obj size       : " + to_string(len(obj)) + " bytes total")

    if obj[0] != 207 || obj[1] != 250 || obj[2] != 237 || obj[3] != 254 {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")
    if obj[12] != 1 { println("FAIL: filetype not MH_OBJECT"); return }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out_path = env_var("HEXA_VAL_CTORS_O")
    let mut dest = out_path
    if dest == "" { dest = "build/poc/hexa_val_ctors.o" }
    write_bytes(dest, obj)
    println("  wrote          : " + dest)
    println("[wire] EMIT OK — link the .o + a C driver to JIT-exec-verify the x0:x1 struct return")
}
// auto-invoke handles main()
