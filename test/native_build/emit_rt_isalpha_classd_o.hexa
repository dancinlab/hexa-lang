// test/native_build/emit_rt_isalpha_classd_o.hexa
//
// F3 PATH-A RUNBOOK · F3-classd-repr-body1 — FIRST class-D HexaVal-repr body
// behavioral self-emit. Production-wire a self-emitted `rt_isalpha` over the
// C `rt_isalpha` (self/runtime.c L1594, gated by HEXA_HAS_HEXA_RT_STDLIB).
//
// 🔑 EXTENDS THE PR #1911 WALL REFRAME TO CLASS-D HexaVal-repr (THE LARGEST
//    REMAINING HARD LAYER, ~350-450 fn).
// PR #1911 (rt_strdup) was the FIRST behavioral self-emit ever — a class-B
// HARD pointer-return primitive. It drove a stake through the
// byte-identical-vs-clang gate (a bootstrapping convenience, NOT a governance
// mandate). This driver extends the same model to class-D HexaVal-repr
// struct-return bodies: AAPCS HexaVal in x0:x1 → HexaVal in x0:x1 (low half
// = tag w/ 4-B pad, high half = .i / .b / .s union slot, since HexaVal is
// 16 bytes total — `enum HexaTag` 4-B + 4-B pad + 8-B union).
//
// This .o exports a strong external `_rt_isalpha` whose body is
// `rt_isalpha_classd()`'s verbatim machine code (frame + 4 range cmps +
// 1 bl + multi-BB merge), declares an UNDEFINED-external `_hexa_bool` (the
// HexaVal ctor callee at self/runtime_core.c L1283), and carries ONE
// ARM64_RELOC_BRANCH26 reloc at code offset 0x34 (52). ld64 binds that `bl`
// to runtime_core.c's `hexa_bool` (non-static, always available) at link
// time. NOT byte-identical to clang -O2 (which would inline the ctor and
// fuse via `and x8,x1,#~0x20; sub; cmp #26; cset` in 5 instr) — that is the
// behavioral-equivalence wall reframe.
//
// ── ABI (class-D HexaVal-repr · struct-return) ──
//   Input:  x0 = c.tag (TAG_INT = 0 expected) · x1 = c.i (int codepoint)
//   Output: x0 = tag (TAG_BOOL = 2 from hexa_bool) · x1 = .b (0 or 1)
//   x29/x30 saved (16-B frame, bl consumes LR). No callee-saved register
//   spills (x19/x20/x21 untouched) because c.i in x1 is fully consumed
//   before the bl; no live state across the call.
//   16 instr, 64 bytes. ONE BRANCH26 reloc @ 0x34.
//
// ── HONESTY ──
//   - closure = runs exact — a C driver linking this .o + real _hexa_bool
//     + 8 char inputs (ASCII low edge / high edge / out-of-range / non-letter
//     bytes / boundary 64 / 91 / 96 / 123 / lowercase span / digit / TAB)
//     produces the C-equivalent bool for every input.
//   - clang is used ONLY as the link-side oracle (the C _hexa_bool ctor
//     stand-in) and NEVER in this .o's emit path (64 bytes come from
//     rt_isalpha_classd()).
//   - BRANCH26 + LC_SYMTAB only: no LC_DYSYMTAB (matches PR #1911 strdup).
//   - selfhosted opt-in — HEXA_RT_SELFEMIT=1 gates the build append; unset =
//     no behavior change (default keeps C body = 0 extern delta).
//   - no binaries committed.
//
// SELF-CONTAINED: macho v3 wrapper (1 defined `_rt_isalpha` + 1 undefined-
// external `_hexa_bool` + 1 BRANCH26 @ 0x34) inlined byte-for-byte, mirroring
// self/codegen/macho.hexa::macho_obj_wrap_v3 and the precedent
// test/native_build/emit_hxlcl_strdup_o.hexa.

// ═════════════════════════════════════════════════════════════════
// Inlined from self/codegen/runtime_arm64.hexa::rt_isalpha_classd
// 16 instructions, 64 bytes. frame + 4 range cmp + bl _hexa_bool +
// multi-BB 0/1 merge. bl BRANCH26 @ 0x34.
// ═════════════════════════════════════════════════════════════════
fn rt_isalpha_classd_bytes() -> [int] {
    let mut c = []
    // stp x29, x30, [sp, #-16]!    0xA9BF7BFD
    c.push(253); c.push(123); c.push(191); c.push(169)
    // mov x29, sp                  0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // cmp x1, #65                  0xF101043F
    c.push(63); c.push(4); c.push(1); c.push(241)
    // b.lt .Lzero                  0x5400012B
    c.push(43); c.push(1); c.push(0); c.push(84)
    // cmp x1, #90                  0xF101683F
    c.push(63); c.push(104); c.push(1); c.push(241)
    // b.le .Lone                   0x540000AD
    c.push(173); c.push(0); c.push(0); c.push(84)
    // cmp x1, #97                  0xF101843F
    c.push(63); c.push(132); c.push(1); c.push(241)
    // b.lt .Lzero                  0x540000AB
    c.push(171); c.push(0); c.push(0); c.push(84)
    // cmp x1, #122                 0xF101E83F
    c.push(63); c.push(232); c.push(1); c.push(241)
    // b.gt .Lzero                  0x5400006C
    c.push(108); c.push(0); c.push(0); c.push(84)
    // .Lone: mov w0, #1            0x52800020
    c.push(32); c.push(0); c.push(128); c.push(82)
    // b .Lcall                     0x14000002
    c.push(2); c.push(0); c.push(0); c.push(20)
    // .Lzero: mov w0, #0           0x52800000
    c.push(0); c.push(0); c.push(128); c.push(82)
    // bl _hexa_bool [BRANCH26]     0x94000000  @ 0x34
    c.push(0); c.push(0); c.push(0); c.push(148)
    // ldp x29, x30, [sp], #16      0xA8C17BFD
    c.push(253); c.push(123); c.push(193); c.push(168)
    // ret                          0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// ═════════════════════════════════════════════════════════════════
// Inlined macho v3 (constants + helpers + obj_wrap with BRANCH26 + undef).
// 2-symbol case: 1 defined composite (_rt_isalpha, 11 chars) + 1 undefined-
// external callee (_hexa_bool, 10 chars). 1 BRANCH26 @ 0x34.
// ═════════════════════════════════════════════════════════════════
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}
fn push_u16_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}
fn push_u32_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}
fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// 2 symbols + 1 BRANCH26 reloc. Symbol exported = `_rt_isalpha` (11 chars,
// defined), undefined callee = `_hexa_bool` (10 chars).
// strtab: "\0_rt_isalpha\0_hexa_bool\0" = 1 + 12 + 11 = 24 bytes.
//   _rt_isalpha strx = 1
//   _hexa_bool  strx = 1 + 12 = 13
fn macho_obj_wrap_rt_isalpha_classd(code: [int]) -> [int] {
    let mut out = []
    let code_size = len(code)

    let strx_isalpha = 1
    let strx_bool = 13
    let strtab_size = 1 + 12 + 11

    let nsects = 1
    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size
    let header_size = 32
    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let reloc_offset = align_to_v(code_offset + code_size, 4)
    let nreloc = 1
    let reloc_size = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let nsyms = 2
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header
    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SEGMENT_64 (1 section)
    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, nsects)
    out = push_u32_le_v(out, 0)

    // section_64 __text
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, reloc_offset)
    out = push_u32_le_v(out, nreloc)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SYMTAB
    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, nsyms)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    // Pad to code_offset, __text payload
    while len(out) < code_offset { out.push(0) }
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    // Pad to reloc_offset, reloc record (BRANCH26 @ off 0x34 → sym[1])
    while len(out) < reloc_offset { out.push(0) }
    out = push_u32_le_v(out, 52)
    let r_symnum = 1
    let r_pcrel = 1
    let r_length = 2
    let r_extern = 1
    let r_kind = 2
    let bits = (r_symnum % 0x1000000)
             + (r_pcrel * 0x1000000)
             + (r_length * 0x2000000)
             + (r_extern * 0x8000000)
             + ((r_kind % 16) * 0x10000000)
    out = push_u32_le_v(out, bits)

    // Pad to symtab_offset, nlist × 2 (defined first, undefined last)
    while len(out) < symtab_offset { out.push(0) }
    // sym[0] = _rt_isalpha (defined __text @0)
    out = push_u32_le_v(out, strx_isalpha)
    out.push(n_sect_v() + n_ext_v())
    out.push(1)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)
    // sym[1] = _hexa_bool (UNDEFINED extern — DEFINED in runtime_core.c .o)
    out = push_u32_le_v(out, strx_bool)
    out.push(n_ext_v())
    out.push(0)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)

    // String table — "\0_rt_isalpha\0_hexa_bool\0" (24 bytes)
    out.push(0)
    // "_rt_isalpha\0" (12 bytes)
    out.push(95).push(114).push(116).push(95).push(105).push(115).push(97).push(108).push(112).push(104).push(97).push(0)
    // "_hexa_bool\0" (11 bytes)
    out.push(95).push(104).push(101).push(120).push(97).push(95).push(98).push(111).push(111).push(108).push(0)

    return out
}

// ═════════════════════════════════════════════════════════════════
// Driver
// ═════════════════════════════════════════════════════════════════
fn emit_rt_isalpha_classd_o() {
    println("[wire] F3 Path A · F3-classd-repr-body1 · rt_isalpha class-D HexaVal-repr — _rt_isalpha")

    let code = rt_isalpha_classd_bytes()
    if len(code) != 64 {
        println("FAIL: rt_isalpha_classd expected 64 bytes, got " + to_string(len(code)))
        return
    }
    println("  rt_isalpha bytes: " + to_string(len(code)) + " (64 expected)")

    // stp x29,x30 prologue (fd 7b bf a9) at offset 0 — 16-B frame spill.
    if code[0] != 253 || code[1] != 123 || code[2] != 191 || code[3] != 169 {
        println("FAIL: stp x29,x30 prologue mismatch")
        return
    }
    println("  prologue       : fd 7b bf a9 (stp x29,x30,[sp,#-16]!) OK")

    // bl (00 00 00 94) at offset 0x34=52 — cross-object CALL (BRANCH26 site).
    if code[52] != 0 || code[53] != 0 || code[54] != 0 || code[55] != 148 {
        println("FAIL: bl _hexa_bool mismatch")
        return
    }
    println("  call           : 00 00 00 94 (bl _hexa_bool, BRANCH26 @0x34) OK")

    // ret (c0 03 5f d6) at offset 60.
    if code[60] != 192 || code[61] != 3 || code[62] != 95 || code[63] != 214 {
        println("FAIL: ret trailer mismatch")
        return
    }
    println("  ret trailer    : c0 03 5f d6 (ret) OK")

    let obj = macho_obj_wrap_rt_isalpha_classd(code)
    println("  obj_wrap size  : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 LE at offset 0 (0xFEEDFACF → cf fa ed fe)
    if obj[0] != 0xcf || obj[1] != 0xfa || obj[2] != 0xed || obj[3] != 0xfe {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")

    // filetype = MH_OBJECT (1) at offset 12
    if obj[12] != 1 {
        println("FAIL: filetype not MH_OBJECT")
        return
    }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out_path = env_var("HEXA_RT_ISALPHA_CLASSD_O")
    let mut dest = out_path
    if dest == "" { dest = "build/poc/rt_isalpha_classd.o" }
    write_bytes(dest, obj)
    println("  wrote          : " + dest)
    println("[wire] EMIT OK — link via build recipe with HEXA_RT_SELFEMIT=1")
}

emit_rt_isalpha_classd_o()
