// test/native_build/emit_hxlcl_atoi_o.hexa
//
// F3 ACTIVATION RUNBOOK · Path A · B9.6-B1 — class-B calling-convention
// composite FIRST self-emit. Production-wire the self-emitted atoi over the
// C `hxlcl_atoi` wrapper (self/runtime.c L298).
//
// EMITS: a Mach-O .o exporting a strong external symbol `_hxlcl_atoi` whose
// body is rt_atoi's verbatim machine-code (a function that CALLS another
// function via `bl` with a real stack frame — the FIRST class-B composite,
// NOT a leaf). It ALSO declares an UNDEFINED-external symbol `_hxlcl_atoll`
// (the callee) and carries an ARM64_RELOC_BRANCH26 reloc at code offset 0x08
// (the `bl`) targeting it. ld64 binds that bl to runtime.c's hxlcl_atoll
// (which becomes non-static under the guard) at link time.
//
// When the driver / module_loader is built under HEXA_RT_SELFEMIT=1,
// `self/runtime.c` declares `hxlcl_atoi` as `extern` (no body) and EXPORTS
// `hxlcl_atoll` (drops its `static`), and ld64 binds the `bl _hxlcl_atoll`
// inside this .o to the C hxlcl_atoll — the C runtime's atoi is replaced by
// the hexa-emitted composite that calls back into the C atoll.
//
// ── ABI (class-B calling convention) ──
//
// rt_atoi(const char *s) -> int. macOS arm64 AAPCS: a NON-LEAF must spill the
// link register x30 (+frame pointer x29) before the `bl`, because `bl`
// clobbers x30. The 5-instr 20-byte sequence matches `as -arch arm64` of the
// C source byte-for-byte:
//   stp x29,x30,[sp,#-16]! ; mov x29,sp ; bl _hxlcl_atoll
//   ; ldp x29,x30,[sp],#16 ; ret
// The `(int)` cast is free (w0 is the low 32 bits of x0).
//
// ── HONESTY ──
//
//   - closure = runs exact — an atoi-calling C program linked against this .o
//     and a C `_hxlcl_atoll` must return the SAME int as libc atoi.
//   - f1/f2 — clang ONLY as link-side oracle, NEVER in this .o's emit path
//     (the 20 bytes come from rt_atoi(), inlined verbatim below).
//   - BRANCH26 + LC_SYMTAB-only: the cross-object `bl` to an undefined
//     external links with NO LC_DYSYMTAB (resolves macho.hexa #1475 caveat).
//   - selfhosted opt-in — HEXA_RT_SELFEMIT=1 gates the build append; unset =
//     no behavior change (default keeps `static` = 0-libc-extern).
//   - no binaries committed.
//
// SELF-CONTAINED: same module-loader rationale as emit_hxlcl_getpid_o.hexa
// (the local repo has no compiled module_loader, so multi-`use` programs
// link-fail). The macho v3 wrapper (N text + undefined externs + BRANCH26
// reloc) is inlined byte-for-byte; it mirrors
// self/codegen/macho.hexa::macho_obj_wrap_v3. The 20 bytes are
// character-identical to self/codegen/runtime_arm64.hexa rt_atoi().

// ═══════════════════════════════════════════════════════════════════
// Inlined from self/codegen/runtime_arm64.hexa::rt_atoi
// 5 instructions, 20 bytes. frame + bl _hxlcl_atoll + epilogue + ret.
// ═══════════════════════════════════════════════════════════════════
fn rt_atoi_bytes() -> [int] {
    let mut c = []
    // stp x29, x30, [sp, #-16]!   0xA9BF7BFD  (LE: fd 7b bf a9)
    c.push(253); c.push(123); c.push(191); c.push(169)
    // mov x29, sp                 0x910003FD  (LE: fd 03 00 91)
    c.push(253); c.push(3); c.push(0); c.push(145)
    // bl _hxlcl_atoll  [BRANCH26] 0x94000000  (LE: 00 00 00 94)
    c.push(0); c.push(0); c.push(0); c.push(148)
    // ldp x29, x30, [sp], #16     0xA8C17BFD  (LE: fd 7b c1 a8)
    c.push(253); c.push(123); c.push(193); c.push(168)
    // ret                         0xD65F03C0  (LE: c0 03 5f d6)
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// ═══════════════════════════════════════════════════════════════════
// Inlined macho v3 (constants + helpers + obj_wrap with BRANCH26 + undef).
// Mirrors self/codegen/macho.hexa::macho_obj_wrap_v3 for the 2-symbol case
// (1 defined composite + 1 undefined-external callee) + 1 BRANCH26 reloc.
// ═══════════════════════════════════════════════════════════════════
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}
fn push_u16_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}
fn push_u32_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}
fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// 2 symbols + 1 BRANCH26 reloc. Symbol exported = `_hxlcl_atoi` (defined,
// 11 chars), undefined callee = `_hxlcl_atoll` (12 chars).
// strtab: "\0_hxlcl_atoi\0_hxlcl_atoll\0" = 1 + 12 + 13 = 26 bytes.
//   _hxlcl_atoi  strx = 1
//   _hxlcl_atoll strx = 1 + 12 = 13
fn macho_obj_wrap_hxlcl_atoi(code: [int]) -> [int] {
    let mut out = []
    let code_size = len(code)

    let strx_atoi  = 1
    let strx_atoll = 13
    let strtab_size = 1 + 12 + 13

    let nsects = 1
    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size
    let header_size = 32
    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let reloc_offset = align_to_v(code_offset + code_size, 4)
    let nreloc = 1
    let reloc_size = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let nsyms = 2
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header
    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SEGMENT_64 (1 section)
    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, nsects)
    out = push_u32_le_v(out, 0)

    // section_64 __text
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, reloc_offset)
    out = push_u32_le_v(out, nreloc)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SYMTAB
    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, nsyms)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    // Pad to code_offset, __text payload
    while len(out) < code_offset { out.push(0) }
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    // Pad to reloc_offset, reloc record (BRANCH26 @ off 8 → sym[1])
    while len(out) < reloc_offset { out.push(0) }
    out = push_u32_le_v(out, 8)
    let r_symnum = 1
    let r_pcrel = 1
    let r_length = 2
    let r_extern = 1
    let r_kind = 2
    let bits = (r_symnum % 0x1000000)
             + (r_pcrel * 0x1000000)
             + (r_length * 0x2000000)
             + (r_extern * 0x8000000)
             + ((r_kind % 16) * 0x10000000)
    out = push_u32_le_v(out, bits)

    // Pad to symtab_offset, nlist × 2 (defined first, undefined last)
    while len(out) < symtab_offset { out.push(0) }
    // sym[0] = _hxlcl_atoi (defined __text @0)
    out = push_u32_le_v(out, strx_atoi)
    out.push(n_sect_v() + n_ext_v())
    out.push(1)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)
    // sym[1] = _hxlcl_atoll (UNDEFINED extern — DEFINED in runtime.c .o)
    out = push_u32_le_v(out, strx_atoll)
    out.push(n_ext_v())
    out.push(0)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)

    // String table — "\0_hxlcl_atoi\0_hxlcl_atoll\0" (26 bytes)
    out.push(0)
    // "_hxlcl_atoi\0"
    out.push(95).push(104).push(120).push(108).push(99).push(108).push(95).push(97).push(116).push(111).push(105).push(0)
    // "_hxlcl_atoll\0"
    out.push(95).push(104).push(120).push(108).push(99).push(108).push(95).push(97).push(116).push(111).push(108).push(108).push(0)

    return out
}

// ═══════════════════════════════════════════════════════════════════
// Driver
// ═══════════════════════════════════════════════════════════════════
fn emit_hxlcl_atoi_o() {
    println("[wire] F3 Path A · B9.6-B1 · rt_atoi class-B composite — _hxlcl_atoi")

    let code = rt_atoi_bytes()
    if len(code) != 20 {
        println("FAIL: rt_atoi expected 20 bytes, got " + to_string(len(code)))
        return
    }
    println("  rt_atoi bytes  : " + to_string(len(code)) + " (20 expected)")

    // stp x29,x30 prologue (fd 7b bf a9) at offset 0 — the frame spill.
    if code[0] != 253 || code[1] != 123 || code[2] != 191 || code[3] != 169 {
        println("FAIL: stp x29,x30 prologue mismatch")
        return
    }
    println("  prologue       : fd 7b bf a9 (stp x29,x30,[sp,#-16]!) OK")

    // bl (00 00 00 94) at offset 8 — the cross-object CALL (BRANCH26 site).
    if code[8] != 0 || code[9] != 0 || code[10] != 0 || code[11] != 148 {
        println("FAIL: bl _hxlcl_atoll mismatch")
        return
    }
    println("  call           : 00 00 00 94 (bl _hxlcl_atoll, BRANCH26 @0x08) OK")

    // ldp epilogue (fd 7b c1 a8) at offset 12.
    if code[12] != 253 || code[13] != 123 || code[14] != 193 || code[15] != 168 {
        println("FAIL: ldp x29,x30 epilogue mismatch")
        return
    }
    println("  epilogue       : fd 7b c1 a8 (ldp x29,x30,[sp],#16) OK")

    // ret (c0 03 5f d6) at offset 16.
    if code[16] != 192 || code[17] != 3 || code[18] != 95 || code[19] != 214 {
        println("FAIL: ret trailer mismatch")
        return
    }
    println("  ret trailer    : c0 03 5f d6 (ret) OK — w0=(int)atoll result")

    let obj = macho_obj_wrap_hxlcl_atoi(code)
    println("  obj_wrap size  : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 LE at offset 0 (0xFEEDFACF → cf fa ed fe)
    if obj[0] != 0xcf || obj[1] != 0xfa || obj[2] != 0xed || obj[3] != 0xfe {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")

    // filetype = MH_OBJECT (1) at offset 12
    if obj[12] != 1 {
        println("FAIL: filetype not MH_OBJECT")
        return
    }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out_path = env_var("HEXA_HXLCL_ATOI_O")
    let mut dest = out_path
    if dest == "" { dest = "build/poc/hxlcl_atoi.o" }
    write_bytes(dest, obj)
    println("  wrote          : " + dest)
    println("[wire] EMIT OK — link via build recipe with HEXA_RT_SELFEMIT=1")
}

emit_hxlcl_atoi_o()
