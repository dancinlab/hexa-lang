// test/native_build/emit_hxlcl_strdup_o.hexa
//
// F3 ACTIVATION RUNBOOK · Path A · F3-codegen-kickoff — class-B HARD primitive
// FIRST behavioral self-emit. Production-wire a self-emitted strdup over the C
// `hxlcl_strdup` wrapper (self/runtime.c L353).
//
// 🔑 THE F3 WALL REFRAME (BEHAVIORAL-EQUIVALENCE, NOT BYTE-IDENTITY-VS-CLANG).
// The prior wall (B9.6-B2/E2) held that strdup-class copy-loop primitives were
// BLOCKED: clang -O2 auto-vectorizes the copy (NEON ld1/st1, head/tail peel,
// RA-emergent frame), and reproducing that byte-for-byte = reimplementing
// clang's optimizer (impossible). That gate is a BOOTSTRAPPING CONVENIENCE, not
// a correctness requirement. No @D / RUNTIME.floor.md rule mandates
// byte-identity-vs-clang; the real correctness anchors are (a) the self-host
// fixpoint f(C)=C (tool/meta2_verify.hexa) and (b) the default-0-extern build
// staying byte-identical (preserved here: the guard is OPT-IN).
//
// This driver emits a .o whose body is rt_strdup()'s OWN instruction
// selection — a plain SCALAR byte-copy loop, deliberately NOT clang's
// vectorized form — and proves it BEHAVIORALLY: linked against a real
// _hxlcl_malloc and a C driver, it returns a distinct, exact, NUL-terminated
// copy for every input (empty / short / long / embedded-high-byte / NULL).
//
// EMITS: a Mach-O .o exporting a strong external `_hxlcl_strdup` whose body is
// rt_strdup's verbatim machine code (frame + 2 scalar loops + bl + multi-BB),
// declaring an UNDEFINED-external `_hxlcl_malloc` (the callee), and carrying ONE
// ARM64_RELOC_BRANCH26 reloc at code offset 0x30 (the `bl`). ld64 binds that bl
// to runtime.c's hxlcl_malloc (non-static under the guard) at link time.
//
// ── ABI (class-B HARD: frame + copy loop + cross-object call) ──
//   x19=s · x20=n · x21=out are callee-saved and stay LIVE ACROSS the bl
//   (the wall's "RA-emergent multi-pair frame" — here a fixed, correct one).
//   28 instr, 112 bytes. NOT byte-identical to clang -O2 (that is the point).
//
// ── HONESTY ──
//   - closure = runs exact — a strdup-calling C program linked against this .o
//     + a real _hxlcl_malloc returns a correct distinct copy for all inputs.
//   - clang is used ONLY as a link-side oracle (the C _hxlcl_malloc stand-in)
//     and NEVER in this .o's emit path (112 bytes come from rt_strdup()).
//   - BRANCH26 + LC_SYMTAB-only: the cross-object `bl` links with NO
//     LC_DYSYMTAB (same as B9.6-B1 rt_atoi).
//   - selfhosted opt-in — HEXA_RT_SELFEMIT=1 gates the build append; unset =
//     no behavior change (default keeps `static` = 0-libc-extern).
//   - no binaries committed.
//
// SELF-CONTAINED: the macho v3 wrapper (N text + undefined externs + BRANCH26
// reloc) is inlined byte-for-byte, mirroring
// self/codegen/macho.hexa::macho_obj_wrap_v3 and
// test/native_build/emit_hxlcl_atoi_o.hexa. The 112 bytes are
// character-identical to self/codegen/runtime_arm64.hexa rt_strdup().

// ═════════════════════════════════════════════════════════════════
// Inlined from self/codegen/runtime_arm64.hexa::rt_strdup
// 28 instructions, 112 bytes. frame + strlen loop + bl _hxlcl_malloc
// + copy loop + multi-BB NULL/return epilogue. bl BRANCH26 @ 0x30.
// ═════════════════════════════════════════════════════════════════
fn rt_strdup_bytes() -> [int] {
    let mut c = []
    // stp x29, x30, [sp, #-48]!   0xA9BD7BFD
    c.push(253); c.push(123); c.push(189); c.push(169)
    // mov x29, sp                 0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // stp x19, x20, [sp, #16]     0xA90153F3
    c.push(243); c.push(83); c.push(1); c.push(169)
    // str x21, [sp, #32]          0xF90013F5
    c.push(245); c.push(19); c.push(0); c.push(249)
    // cbz x0, .Lnull              0xB4000260
    c.push(96); c.push(2); c.push(0); c.push(180)
    // mov x19, x0                 0xAA0003F3
    c.push(243); c.push(3); c.push(0); c.push(170)
    // mov x20, #0                 0xD2800014
    c.push(20); c.push(0); c.push(128); c.push(210)
    // .Llen: ldrb w9, [x19, x20]  0x38746A69
    c.push(105); c.push(106); c.push(116); c.push(56)
    // cbz w9, .Llen_done          0x34000069
    c.push(105); c.push(0); c.push(0); c.push(52)
    // add x20, x20, #1            0x91000694
    c.push(148); c.push(6); c.push(0); c.push(145)
    // b .Llen                     0x17FFFFFD
    c.push(253); c.push(255); c.push(255); c.push(23)
    // .Llen_done: add x0, x20, #1 0x91000680
    c.push(128); c.push(6); c.push(0); c.push(145)
    // bl _hxlcl_malloc [BRANCH26] 0x94000000  @ 0x30
    c.push(0); c.push(0); c.push(0); c.push(148)
    // cbz x0, .Lnull              0xB4000140
    c.push(64); c.push(1); c.push(0); c.push(180)
    // mov x21, x0                 0xAA0003F5
    c.push(245); c.push(3); c.push(0); c.push(170)
    // mov x10, #0                 0xD280000A
    c.push(10); c.push(0); c.push(128); c.push(210)
    // .Lcopy: ldrb w9, [x19, x10] 0x386A6A69
    c.push(105); c.push(106); c.push(106); c.push(56)
    // strb w9, [x21, x10]         0x382A6AA9
    c.push(169); c.push(106); c.push(42); c.push(56)
    // cmp x10, x20               0xEB14015F
    c.push(95); c.push(1); c.push(20); c.push(235)
    // add x10, x10, #1           0x9100054A
    c.push(74); c.push(5); c.push(0); c.push(145)
    // b.lo .Lcopy                0x54FFFF83
    c.push(131); c.push(255); c.push(255); c.push(84)
    // mov x0, x21                0xAA1503E0
    c.push(224); c.push(3); c.push(21); c.push(170)
    // b .Lret                    0x14000002
    c.push(2); c.push(0); c.push(0); c.push(20)
    // .Lnull: mov x0, #0         0xD2800000
    c.push(0); c.push(0); c.push(128); c.push(210)
    // .Lret: ldr x21, [sp, #32]  0xF94013F5
    c.push(245); c.push(19); c.push(64); c.push(249)
    // ldp x19, x20, [sp, #16]    0xA94153F3
    c.push(243); c.push(83); c.push(65); c.push(169)
    // ldp x29, x30, [sp], #48    0xA8C37BFD
    c.push(253); c.push(123); c.push(195); c.push(168)
    // ret                        0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// ═════════════════════════════════════════════════════════════════
// Inlined macho v3 (constants + helpers + obj_wrap with BRANCH26 + undef).
// Mirrors self/codegen/macho.hexa::macho_obj_wrap_v3 for the 2-symbol case
// (1 defined composite + 1 undefined-external callee) + 1 BRANCH26 reloc.
// ═════════════════════════════════════════════════════════════════
fn mh_magic_64_v() -> int { return 0xFEEDFACF }
fn mh_object_v() -> int { return 1 }
fn cpu_type_arm64_v() -> int { return 0x0100000C }
fn cpu_subtype_all_v() -> int { return 0 }
fn lc_segment_64_v() -> int { return 0x19 }
fn lc_symtab_v() -> int { return 0x02 }
fn lc_build_version_v() -> int { return 0x32 }
fn s_attr_pure_v() -> int { return 0x80000000 }
fn s_attr_some_v() -> int { return 0x00000400 }
fn n_ext_v() -> int { return 0x01 }
fn n_sect_v() -> int { return 0x0e }

fn align_to_v(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}
fn push_u16_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}
fn push_u32_le_v(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}
fn push_u64_le_v(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le_v(buf, val % 0x100000000)
    return push_u32_le_v(b, val / 0x100000000)
}

// 2 symbols + 1 BRANCH26 reloc. Symbol exported = `_hxlcl_strdup` (defined,
// 13 chars), undefined callee = `_hxlcl_malloc` (13 chars).
// strtab: "\0_hxlcl_strdup\0_hxlcl_malloc\0" = 1 + 14 + 14 = 29 bytes.
//   _hxlcl_strdup strx = 1
//   _hxlcl_malloc strx = 1 + 14 = 15
fn macho_obj_wrap_hxlcl_strdup(code: [int]) -> [int] {
    let mut out = []
    let code_size = len(code)

    let strx_strdup = 1
    let strx_malloc = 15
    let strtab_size = 1 + 14 + 14

    let nsects = 1
    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size
    let header_size = 32
    let code_offset = align_to_v(header_size + sizeofcmds, 8)
    let reloc_offset = align_to_v(code_offset + code_size, 4)
    let nreloc = 1
    let reloc_size = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let nsyms = 2
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header
    out = push_u32_le_v(out, mh_magic_64_v())
    out = push_u32_le_v(out, cpu_type_arm64_v())
    out = push_u32_le_v(out, cpu_subtype_all_v())
    out = push_u32_le_v(out, mh_object_v())
    out = push_u32_le_v(out, 3)
    out = push_u32_le_v(out, sizeofcmds)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SEGMENT_64 (1 section)
    out = push_u32_le_v(out, lc_segment_64_v())
    out = push_u32_le_v(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u64_le_v(out, code_offset)
    out = push_u64_le_v(out, total_end - code_offset)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, 7)
    out = push_u32_le_v(out, nsects)
    out = push_u32_le_v(out, 0)

    // section_64 __text
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le_v(out, 0)
    out = push_u64_le_v(out, code_size)
    out = push_u32_le_v(out, code_offset)
    out = push_u32_le_v(out, 2)
    out = push_u32_le_v(out, reloc_offset)
    out = push_u32_le_v(out, nreloc)
    out = push_u32_le_v(out, s_attr_pure_v() + s_attr_some_v())
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)
    out = push_u32_le_v(out, 0)

    // LC_SYMTAB
    out = push_u32_le_v(out, lc_symtab_v())
    out = push_u32_le_v(out, symtab_cmd_size)
    out = push_u32_le_v(out, symtab_offset)
    out = push_u32_le_v(out, nsyms)
    out = push_u32_le_v(out, strtab_offset)
    out = push_u32_le_v(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le_v(out, lc_build_version_v())
    out = push_u32_le_v(out, build_version_cmd_size)
    out = push_u32_le_v(out, 1)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0x000E0000)
    out = push_u32_le_v(out, 0)

    // Pad to code_offset, __text payload
    while len(out) < code_offset { out.push(0) }
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }

    // Pad to reloc_offset, reloc record (BRANCH26 @ off 0x30 → sym[1])
    while len(out) < reloc_offset { out.push(0) }
    out = push_u32_le_v(out, 48)
    let r_symnum = 1
    let r_pcrel = 1
    let r_length = 2
    let r_extern = 1
    let r_kind = 2
    let bits = (r_symnum % 0x1000000)
             + (r_pcrel * 0x1000000)
             + (r_length * 0x2000000)
             + (r_extern * 0x8000000)
             + ((r_kind % 16) * 0x10000000)
    out = push_u32_le_v(out, bits)

    // Pad to symtab_offset, nlist × 2 (defined first, undefined last)
    while len(out) < symtab_offset { out.push(0) }
    // sym[0] = _hxlcl_strdup (defined __text @0)
    out = push_u32_le_v(out, strx_strdup)
    out.push(n_sect_v() + n_ext_v())
    out.push(1)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)
    // sym[1] = _hxlcl_malloc (UNDEFINED extern — DEFINED in runtime.c .o)
    out = push_u32_le_v(out, strx_malloc)
    out.push(n_ext_v())
    out.push(0)
    out = push_u16_le_v(out, 0)
    out = push_u64_le_v(out, 0)

    // String table — "\0_hxlcl_strdup\0_hxlcl_malloc\0" (29 bytes)
    out.push(0)
    // "_hxlcl_strdup\0"
    out.push(95).push(104).push(120).push(108).push(99).push(108).push(95).push(115).push(116).push(114).push(100).push(117).push(112).push(0)
    // "_hxlcl_malloc\0"
    out.push(95).push(104).push(120).push(108).push(99).push(108).push(95).push(109).push(97).push(108).push(108).push(111).push(99).push(0)

    return out
}

// ═════════════════════════════════════════════════════════════════
// Driver
// ═════════════════════════════════════════════════════════════════
fn emit_hxlcl_strdup_o() {
    println("[wire] F3 Path A · F3-codegen-kickoff · rt_strdup class-B HARD — _hxlcl_strdup")

    let code = rt_strdup_bytes()
    if len(code) != 112 {
        println("FAIL: rt_strdup expected 112 bytes, got " + to_string(len(code)))
        return
    }
    println("  rt_strdup bytes: " + to_string(len(code)) + " (112 expected)")

    // stp x29,x30 prologue (fd 7b bd a9) at offset 0 — 48-B frame spill.
    if code[0] != 253 || code[1] != 123 || code[2] != 189 || code[3] != 169 {
        println("FAIL: stp x29,x30 prologue mismatch")
        return
    }
    println("  prologue       : fd 7b bd a9 (stp x29,x30,[sp,#-48]!) OK")

    // bl (00 00 00 94) at offset 0x30=48 — cross-object CALL (BRANCH26 site).
    if code[48] != 0 || code[49] != 0 || code[50] != 0 || code[51] != 148 {
        println("FAIL: bl _hxlcl_malloc mismatch")
        return
    }
    println("  call           : 00 00 00 94 (bl _hxlcl_malloc, BRANCH26 @0x30) OK")

    // ret (c0 03 5f d6) at offset 108.
    if code[108] != 192 || code[109] != 3 || code[110] != 95 || code[111] != 214 {
        println("FAIL: ret trailer mismatch")
        return
    }
    println("  ret trailer    : c0 03 5f d6 (ret) OK")

    let obj = macho_obj_wrap_hxlcl_strdup(code)
    println("  obj_wrap size  : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 LE at offset 0 (0xFEEDFACF → cf fa ed fe)
    if obj[0] != 0xcf || obj[1] != 0xfa || obj[2] != 0xed || obj[3] != 0xfe {
        println("FAIL: MH_MAGIC_64 mismatch")
        return
    }
    println("  MH_MAGIC_64    : cf fa ed fe OK")

    // filetype = MH_OBJECT (1) at offset 12
    if obj[12] != 1 {
        println("FAIL: filetype not MH_OBJECT")
        return
    }
    println("  filetype       : 1 (MH_OBJECT) OK")

    let out_path = env_var("HEXA_HXLCL_STRDUP_O")
    let mut dest = out_path
    if dest == "" { dest = "build/poc/hxlcl_strdup.o" }
    write_bytes(dest, obj)
    println("  wrote          : " + dest)
    println("[wire] EMIT OK — link via build recipe with HEXA_RT_SELFEMIT=1")
}

emit_hxlcl_strdup_o()
