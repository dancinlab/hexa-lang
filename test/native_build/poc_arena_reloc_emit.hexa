// PoC — emit a hexa-native .o that uses adrp/add against an
// `_arena_state` symbol in __const, with the matching reloc records.
//
// HEXA_BACKEND flip chunk-B, phase-H emit-side closure — PR #1297
// residual #2. This is the FIRST end-to-end proof that
// `macho_obj_wrap_v2` produces a Mach-O .o whose reloc table is
// parsed/applied by the hexa-native linker (`tool/hexa_ld.hexa` PR
// #1282) so that `adrp x9, _arena_state@PAGE` + `add x9, x9, _arena_state@PAGEOFF`
// resolve to the right absolute VM address.
//
// All bytes inlined verbatim per the same convention as
// test/native_build/poc_rt_exit_obj_emit.hexa (PR #1297). The build
// hosts have no compiled hexa_module_loader so we cannot `use` the
// real macho.hexa; instead this PoC inlines `macho_obj_wrap_v2` from
// `self/codegen/macho.hexa::macho_obj_wrap_v2` byte-identical so any
// divergence shows up immediately as a mismatched header / MAGIC /
// section count sanity check.

// ─── ARM64 instruction synthesizer (1 fn) ─────────────────────────
//
// _hexa_main(unused) — loads _arena_state[0] (8 bytes) into x0, returns:
//   adrp x9, _arena_state@PAGE     (PLACEHOLDER 0x90000009)
//   add  x9, x9, _arena_state@PAGEOFF (PLACEHOLDER 0x91000129)
//   ldr  x0, [x9]                  (0xF9400120)
//   ret                            (0xD65F03C0)
//
// All 4 instructions = 16 bytes. The adrp/add placeholders are the
// pre-link bit patterns clang/ld64 expect; the linker fills in the
// immediates via the reloc records this PoC emits.

fn synth_main_bytes() -> [int] {
    let mut c = []
    // adrp x9, #0  (placeholder; PAGE21 reloc patches immhi+immlo)
    // 0x90000009 LE  → 09 00 00 90
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add x9, x9, #0  (placeholder; PAGEOFF12 reloc patches imm12)
    // 0x91000129 LE  → 29 01 00 91
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x0, [x9]   (load 8 bytes from base — state[0])
    // 0xF9400120 LE  → 20 01 40 F9
    c.push(32)
    c.push(1)
    c.push(64)
    c.push(249)
    // ret
    // 0xD65F03C0 LE  → C0 03 5F D6
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ─── helpers (inlined from self/codegen/macho.hexa) ───────────────

fn push_u16_le(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

fn push_u32_le(buf: [int], val: int) -> [int] {
    return buf
      .push(val % 256)
      .push((val / 256) % 256)
      .push((val / 65536) % 256)
      .push((val / 16777216) % 256)
}

fn push_u64_le(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le(buf, val % 0x100000000)
    return push_u32_le(b, val / 0x100000000)
}

fn align_to(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

// ─── macho_obj_wrap_v2 (verbatim inline from self/codegen/macho.hexa) ─

fn macho_obj_wrap_v2(code: [int], main_offset: int, state_bytes: [int],
                     reloc_offs: [int], reloc_kinds: [int]) -> [int] {
    let mut out = []
    let code_size  = len(code)
    let state_size = len(state_bytes)
    let nreloc     = len(reloc_offs)

    let strx_main  = 1
    let strx_state = 12
    let strtab_size = 1 + 11 + 13

    let segment_cmd_size = 72 + 80 + 80
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let header_size = 32
    let code_offset  = align_to(header_size + sizeofcmds, 8)
    let const_offset = align_to(code_offset + code_size, 8)
    let reloc_offset = align_to(const_offset + state_size, 4)
    let reloc_size   = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let nsyms = 2
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header (32 bytes)
    out = push_u32_le(out, 0xFEEDFACF)       // magic
    out = push_u32_le(out, 0x0100000C)       // cputype ARM64
    out = push_u32_le(out, 0)                // cpusubtype
    out = push_u32_le(out, 1)                // filetype MH_OBJECT
    out = push_u32_le(out, 3)                // ncmds
    out = push_u32_le(out, sizeofcmds)
    out = push_u32_le(out, 0)                // flags
    out = push_u32_le(out, 0)                // reserved

    // LC_SEGMENT_64 (1 segment, 2 sections)
    out = push_u32_le(out, 0x19)             // LC_SEGMENT_64
    out = push_u32_le(out, segment_cmd_size)
    let mut i = 0
    while i < 16 { out.push(0); i = i + 1 }  // segname (16 NUL)
    out = push_u64_le(out, 0)                // vmaddr
    out = push_u64_le(out, total_end - code_offset)  // vmsize
    out = push_u64_le(out, code_offset)      // fileoff
    out = push_u64_le(out, total_end - code_offset)  // filesize
    out = push_u32_le(out, 7)                // maxprot
    out = push_u32_le(out, 7)                // initprot
    out = push_u32_le(out, 2)                // nsects
    out = push_u32_le(out, 0)                // flags

    // section_64 __text (80 bytes)
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le(out, 0)                // addr
    out = push_u64_le(out, code_size)        // size
    out = push_u32_le(out, code_offset)      // offset
    out = push_u32_le(out, 2)                // align
    out = push_u32_le(out, reloc_offset)     // reloff
    out = push_u32_le(out, nreloc)           // nreloc
    out = push_u32_le(out, 0x80000400)       // S_ATTR_PURE + SOME
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    // section_64 __const (80 bytes)
    out.push(95).push(95).push(99).push(111).push(110).push(115).push(116)
    j = 0
    while j < 9 { out.push(0); j = j + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out.push(0); j = j + 1 }
    out = push_u64_le(out, code_size)        // addr (offset in seg)
    out = push_u64_le(out, state_size)
    out = push_u32_le(out, const_offset)
    out = push_u32_le(out, 3)                // align = log2(8)
    out = push_u32_le(out, 0)                // reloff
    out = push_u32_le(out, 0)                // nreloc
    out = push_u32_le(out, 0)                // flags S_REGULAR
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    // LC_SYMTAB (24 bytes)
    out = push_u32_le(out, 0x02)             // LC_SYMTAB
    out = push_u32_le(out, symtab_cmd_size)
    out = push_u32_le(out, symtab_offset)
    out = push_u32_le(out, nsyms)
    out = push_u32_le(out, strtab_offset)
    out = push_u32_le(out, strtab_size)

    // LC_BUILD_VERSION (24 bytes)
    out = push_u32_le(out, 0x32)             // LC_BUILD_VERSION
    out = push_u32_le(out, build_version_cmd_size)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0)

    while len(out) < code_offset { out.push(0) }
    let mut k = 0
    while k < len(code) { out.push(code[k]); k = k + 1 }
    while len(out) < const_offset { out.push(0) }
    let mut sb = 0
    while sb < state_size { out.push(state_bytes[sb]); sb = sb + 1 }
    while len(out) < reloc_offset { out.push(0) }

    // Relocation table — N records, each 8 bytes
    let mut ri = 0
    while ri < nreloc {
        let r_off  = reloc_offs[ri]
        let r_kind = reloc_kinds[ri]
        out = push_u32_le(out, r_off)
        let r_symbolnum = 1                  // _arena_state index
        let r_pcrel  = 1
        let r_length = 2
        let r_extern = 1
        let bits = (r_symbolnum % 0x1000000)
                 + (r_pcrel * 0x1000000)
                 + (r_length * 0x2000000)
                 + (r_extern * 0x8000000)
                 + ((r_kind % 16) * 0x10000000)
        out = push_u32_le(out, bits)
        ri = ri + 1
    }

    while len(out) < symtab_offset { out.push(0) }

    // Symbol table — 2 records
    // sym[0] = _hexa_main in __text
    out = push_u32_le(out, strx_main)
    out.push(0x0E + 0x01)                    // N_SECT | N_EXT
    out.push(1)                              // n_sect = __text
    out = push_u16_le(out, 0)
    out = push_u64_le(out, main_offset)
    // sym[1] = _arena_state in __const
    out = push_u32_le(out, strx_state)
    out.push(0x0E + 0x01)
    out.push(2)                              // n_sect = __const
    out = push_u16_le(out, 0)
    out = push_u64_le(out, 0)

    // String table
    out.push(0)
    // "_hexa_main\0"
    out.push(95).push(104).push(101).push(120).push(97)
    out.push(95).push(109).push(97).push(105).push(110).push(0)
    // "_arena_state\0"
    out.push(95).push(97).push(114).push(101).push(110).push(97)
    out.push(95).push(115).push(116).push(97).push(116).push(101).push(0)

    return out
}

// ─── driver ───────────────────────────────────────────────────────

fn main() {
    println("=== PoC arena reloc emit — adrp/add → _arena_state in __const ===")

    // Build the __text bytes: 16 bytes (4 ARM64 instructions).
    let code = synth_main_bytes()
    println("code size      : " + to_string(len(code)) + " bytes (16 expected)")

    // Sanity: first 4 bytes should be the adrp placeholder (09 00 00 90).
    if code[0] != 9 { println("FAIL: code[0] != 9 (adrp opcode low byte)") }
    if code[3] != 144 { println("FAIL: code[3] != 144 (0x90)") }
    if code[4] != 41 { println("FAIL: code[4] != 41 (add opcode low byte)") }
    if code[7] != 145 { println("FAIL: code[7] != 145 (0x91)") }

    // Build the state slot (24 bytes for base/ptr/end; PoC prefills
    // state[0] with the 64-bit value 0x2A=42 so loading state[0] →
    // x0 → C caller exits 42).
    let mut state_bytes = []
    state_bytes.push(42).push(0).push(0).push(0).push(0).push(0).push(0).push(0)
    // ptr (8 zero bytes)
    state_bytes.push(0).push(0).push(0).push(0).push(0).push(0).push(0).push(0)
    // end (8 zero bytes)
    state_bytes.push(0).push(0).push(0).push(0).push(0).push(0).push(0).push(0)
    println("state size     : " + to_string(len(state_bytes)) + " bytes (24 expected)")

    // Reloc records:
    //   offset 0 → ARM64_RELOC_PAGE21    (kind 3, for adrp)
    //   offset 4 → ARM64_RELOC_PAGEOFF12 (kind 4, for add unscaled)
    let mut reloc_offs = []
    reloc_offs.push(0).push(4)
    let mut reloc_kinds = []
    reloc_kinds.push(3).push(4)
    println("nreloc         : " + to_string(len(reloc_offs)) + " records (2 expected)")

    // Build the .o
    let obj = macho_obj_wrap_v2(code, 0, state_bytes, reloc_offs, reloc_kinds)
    println("obj size       : " + to_string(len(obj)) + " bytes total")

    // Sanity: MH_MAGIC_64 = 0xFEEDFACF; little-endian first 4 bytes
    // = CF FA ED FE = 207 250 237 254.
    if obj[0] != 207 { println("FAIL: MH_MAGIC byte 0 != 207") }
    if obj[1] != 250 { println("FAIL: MH_MAGIC byte 1 != 250") }
    if obj[2] != 237 { println("FAIL: MH_MAGIC byte 2 != 237") }
    if obj[3] != 254 { println("FAIL: MH_MAGIC byte 3 != 254") }
    println("MH_MAGIC_64    : cf fa ed fe OK")

    // Sanity: filetype field at offset 12 should be 1 (MH_OBJECT).
    if obj[12] != 1 { println("FAIL: filetype != 1 (MH_OBJECT)") }
    println("filetype       : 1 (MH_OBJECT) OK")

    // Write to /tmp/poc_arena_reloc.o
    write_bytes("/tmp/poc_arena_reloc.o", obj)
    println("wrote          : /tmp/poc_arena_reloc.o")
}

main()
