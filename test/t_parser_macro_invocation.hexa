// Parser regression: macro-call postfix `name!(args)` and `name![args]`.
//
// Companion to parse_macro_def (self/parser.hexa L4164). Until this commit,
// the invocation site `hello!()` parsed only the prefix `Not` (unary `!`)
// path — `let result = hello!()` failed at the trailing `)`. parse_postfix
// now recognizes `Ident + Not + ( ... )` (and `[ ... ]`) as a MacroCall AST
// node. Expansion (compile-time substitution) is a future cycle — codegen
// does not yet consume MacroCall, so this test is parse-gate only.
//
// MINIMUM scope: parse cleanly, no semantic claim.

// --- 1. Zero-arg invocation ---
fn t1() {
    let r = hello!()
    print(r)
}

// --- 2. Single-arg invocation ---
fn t2() {
    let r = double!(5)
    print(r)
}

// --- 3. Multi-arg invocation ---
fn t3() {
    let r = add3!(10, 20, 30)
    print(r)
}

// --- 4. Bracket invocation form ---
fn t4() {
    let r = double![7]
    print(r)
}

// --- 5. Nested invocation ---
fn t5() {
    let r = double!(double!(3))
    print(r)
}

fn main() {
    t1()
    t2()
    t3()
    t4()
    t5()
}
