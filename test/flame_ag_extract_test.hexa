// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// test/flame_ag_extract_test.hexa — flame autograd-auto SD5 + SD6 + SD7
//                                    + SD9 + SD10 oracles
//
// Falsifiers:
//   F-RFC043-AUTOGRAD-AUTO-SD5-RELU-BYTE-EQ
//     AST-driven reverse-mode derivation of relu's vjp produces a bwd
//     whose output dx is byte-identical (max|Δ| = 0.0) to the
//     hand-written reference `relu_bwd_manual(x, dy) = if x > 0 then
//     dy else 0` on a fixed-seed input (len=32).
//   F-RFC043-AUTOGRAD-AUTO-SD6-SIGMOID-BYTE-EQ
//     AST-driven reverse-mode derivation of sigmoid's vjp via the
//     per-op rule table (ADD/SUB/MUL/DIV/NEG/dt_exp) + fwd-result
//     cache produces a bwd whose output dx is byte-identical
//     (max|Δ| = 0.0) to the hand-written reference
//     `sigmoid_bwd_manual(x, dy) = let s = 1/(1+dt_exp(-x));
//                                    dy * s * (1 - s)`
//     on a fixed-seed input (len=32). Per task §7, if byte-eq fails
//     by machine-eps amount, this is reported as a HONEST finding
//     (the walker's per-op rule chain produces a different IEEE-754
//     trajectory than the hand-derived closed form; SD5's byte-eq
//     lemma was specific to pure-conditional vjp shapes and does
//     NOT generalize without arithmetic reorder).
//   F-RFC043-AUTOGRAD-AUTO-SD7-MULTIUSE-BYTE-EQ
//     AST-driven reverse-mode derivation handles a Param used in
//     2+ forward usage sites (`f(x) = x*x + dt_exp(x)` — x appears 3
//     times) by accumulating per-usage-site gradient contributions
//     via the walker's natural BinOp-emits-ADD recursion structure.
//     Reference is hand-written matching the walker's emit order
//     (Option A per task §6) — `(((dy*x)+(dy*x)) + (dy*exp(x)))` —
//     so the byte-eq gate measures `max|Δ| = 0.0` on a fixed-seed
//     input (len=32). Multi-use accumulation is the foundational
//     autograd primitive (Griewank & Walther §3.2 Algorithm 3.6).
//   F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ
//     AST-driven reverse-mode derivation handles a MULTI-INPUT scalar
//     function `f(x, y) = x * y`: invoking the walker twice (once per
//     target Param index ∈ {0, 1}) produces two independent per-Param
//     bwd ASTs. Interpreted under a 2-cell param-vals farr, they
//     compute `df/dx = dy * y` and `df/dy = dy * x`. Both byte-eq
//     gates (one per Param direction) must measure max|Δ| = 0.0 on
//     a fixed-seed input (len=32) — separate LCG seeds for x, y, dy
//     so the test does not pass trivially under shared trajectories.
//     Multi-input vjp is the literal Algorithm 3.6 specialization to
//     a scalar output (Griewank & Walther §3.2; Pearlmutter & Siskind
//     §3 compositional vjp).
//   F-RFC043-AUTOGRAD-AUTO-SD10-DIV-MULTI-BYTE-EQ
//     AST-driven reverse-mode derivation handles a MULTI-INPUT
//     ARITHMETIC scalar function `f(x, y) = x / (1 + dt_exp(0 − y))`
//     (sigmoid-weighted division — SD6's algebraic-identity ULP zone
//     meets SD9's multi-input mechanism). Two walker invocations
//     (target_ix ∈ {0, 1}) produce two per-Param bwd ASTs whose
//     interpretation under a 2-cell param-vals farr yields
//     `df/dx = dy / d` (walker emit; algebraically dy * s(y)) and
//     `df/dy = dy * x * s * (1-s)` (algebraically; walker emits a
//     longer NEG/DIV/MUL chain). Reference uses SD6's exact form
//     (`s = 1/(1+exp(-y))`, then `dy*s` for x-dir and
//     `dy*x*s*(1-s)` for y-dir). Each per-Param byte-eq gate is
//     reported HONESTLY (PASS if max|Δ| = 0.0 — algebraic shape
//     happens to byte-align; HONEST if max|Δ| is machine-eps-scale,
//     ≤ 10×eps, confirming SD6's reorder lesson under multi-input;
//     FAIL if max|Δ| exceeds tolerance — real regression). Atlas:
//     Griewank-Walther §3.2 Algorithm 3.6 (multi-input VJP) +
//     §3.2 elementary-primitives table (DIV/dt_exp rules) + SD6
//     reorder note (this file's SD6 header).
//
// Scope (matches task brief §3 + §7):
//   - SD5 retained verbatim — relu's vjp walker is the SD5 walker
//     (single-rule IfElse). SD6 extends with a SECOND op (sigmoid)
//     via a new per-op walker `ag_extract_reverse_walk_v2`.
//   - SD6 is the "second op proof of generalization" step. NOT yet
//     a true autograd library — that's SD7+ (parser integration,
//     gradient accumulation across multi-use vars, more rules).
//   - Compiler/parse/ast.hexa is NOT imported. ag_extract.hexa
//     hand-builds the sigmoid fwd AST with the same shape an honest
//     parser would emit. Parser integration is SD7's blocker.
//   - The emitted bwd source is printed (for inspection / future
//     SD10 compile-and-load) but the byte-eq oracle goes through
//     the in-process AST interpret path — single hexa invocation,
//     no second compile cycle.
//
// Exit codes (rfc_003 idiom):
//   0  PASS — SD5 + SD6 + SD7 + SD9 + SD10 falsifiers all pass (with
//             HONEST-finding allowed for the SD6/SD10-y-dir
//             algebraic-identity ULP zone, ≤ 10×eps tolerance).
//   91 FAIL — SD5 byte-eq fails.
//   92 FAIL — SD6 byte-eq fails (with honest machine-eps report).
//   93 FAIL — SD7 multi-use accumulation byte-eq fails.
//   94 FAIL — SD9 bilinear multi-input vjp byte-eq fails (either
//             per-Param direction or both).
//   95 FAIL — SD10 sigmoid-div multi-input vjp byte-eq exceeds
//             10×machine-eps tolerance on either per-Param direction
//             (real regression vs honest 1-ULP finding).
//
// CPU-only, $0. Builds on stdlib/flame/ag_extract.hexa.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/flame_math"  // dt_exp for the hand-written sigmoid reference
use "stdlib/flame/ag_extract"

fn ag_dt_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ag_dt_maxdev(a: int, b: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let d = ag_dt_abs(t_get(a, i) - t_get(b, i))
        if d > m { m = d }
        i = i + 1
    }
    return m
}

// ─── hand-written reference: relu_bwd_manual ───────────────────────────
// The closed-form vjp of `relu(x) = max(x, 0)`:
//   dx = if x > 0 then dy else 0
//
// This is the SD5 byte-eq oracle reference. The same closed-form the
// AST walker is supposed to emit. We hand-code it here in a tight
// elementwise loop with the SAME IEEE-754 ops (a single `>` comparison
// against 0.0, then a conditional copy of `dy` or `0.0`) so the
// interpret path can match it byte-for-byte.
fn relu_bwd_manual(x_arr: int, dy_arr: int, dx_out: int, len: int) {
    let mut i = 0
    while i < len {
        let xi = t_get(x_arr, i)
        let dyi = t_get(dy_arr, i)
        if xi > 0.0 {
            t_set(dx_out, i, dyi)
        } else {
            t_set(dx_out, i, 0.0)
        }
        i = i + 1
    }
}

println("=== flame autograd-auto SD5 selftest (ag_extract · relu vjp AST byte-eq) ===")

// ─── fixed-seed inputs (len=32) ────────────────────────────────────────
// Use t_fill_lcg to get a deterministic mix of positive + negative
// floats; this guarantees BOTH branches of the relu vjp are exercised
// (without it the test could pass trivially with x>0 everywhere or
// vice versa). Seed bases chosen to be unrelated to SD1/SD2/SD3 seeds
// (which target B=4·D=8·C=6 matrices).
let LEN = 32
let x_arr = t_zeros(LEN)
// LCG with scale=2.0 + a manual subtract makes x_arr span [-1.0, 1.0]
// (the LCG output is [0, scale]; we subtract scale/2 below for a
// signed range). Seed 4242.
t_fill_lcg(x_arr, LEN, 4242, 2.0)
let mut i_shift = 0
while i_shift < LEN {
    t_set(x_arr, i_shift, t_get(x_arr, i_shift) - 1.0)
    i_shift = i_shift + 1
}

let dy_arr = t_zeros(LEN)
t_fill_lcg(dy_arr, LEN, 31337, 1.0)

// Sanity check: x_arr spans both signs (so both branches of the relu
// vjp are exercised by the test).
let mut n_pos = 0
let mut n_neg = 0
let mut i_check = 0
while i_check < LEN {
    let v = t_get(x_arr, i_check)
    if v > 0.0 { n_pos = n_pos + 1 }
    if v < 0.0 { n_neg = n_neg + 1 }
    i_check = i_check + 1
}
println("input span: " + to_string(n_pos) + " positives, " + to_string(n_neg) + " negatives (both branches of relu vjp exercised)")

// ─── reference: hand-written relu_bwd_manual ───────────────────────────
let dx_ref = t_zeros(LEN)
relu_bwd_manual(x_arr, dy_arr, dx_ref, LEN)

// ─── SD5 path: AST-driven derivation ───────────────────────────────────
// Step 1: build the forward AST in an arena.
let arena = ag_extract_arena_new()
let fwd_root = ag_extract_build_relu_fwd(arena)
println("fwd AST built — root node id = " + to_string(fwd_root))

// Step 2: reverse-mode walk to produce the bwd AST (vjp w.r.t. param 0 = x).
let bwd_root = ag_extract_reverse_walk(arena, fwd_root, 0)
println("reverse-mode walk complete — bwd AST root node id = " + to_string(bwd_root))

// Step 3: emit the bwd as hexa-lang source (for inspection — could be
// filed as a generated file in a future SD9 closure).
let bwd_src = ag_extract_emit_fn(arena, bwd_root, "relu_bwd_auto_emitted")
println("emitted bwd hexa-lang source:")
println(bwd_src)

// Step 4: interpret the bwd AST elementwise to produce dx_auto.
let dx_auto = t_zeros(LEN)
ag_extract_relu_bwd_via_ast(arena, bwd_root, x_arr, dy_arr, dx_auto, LEN)

// ─── byte-eq gate: F-RFC043-AUTOGRAD-AUTO-SD5-RELU-BYTE-EQ ─────────────
let dx_delta = ag_dt_maxdev(dx_auto, dx_ref, LEN)
println("dx max|Δ| = " + to_string(dx_delta))

if dx_delta != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD5-RELU-BYTE-EQ  max|dx_auto − dx_ref| = " + to_string(dx_delta) + " ≠ 0.0 (AST-extracted relu vjp diverges from hand-written reference)")
    exit(91)
}

println("PASS  F-RFC043-AUTOGRAD-AUTO-SD5-RELU-BYTE-EQ  max|dx_auto − dx_ref| = 0.0 (byte-eq · AST→reverse-walk→interpret pipeline ≡ hand-written relu_bwd reference)")
println("=== SD5 PASS ===")

// ════════════════════════════════════════════════════════════════════════
// SD6 — sigmoid byte-eq oracle (second op proof of generalization)
// ════════════════════════════════════════════════════════════════════════
println("")
println("=== flame autograd-auto SD6 selftest (ag_extract · sigmoid vjp AST byte-eq) ===")

// ─── hand-written reference: sigmoid_bwd_manual ────────────────────────
// Closed-form vjp of `sigmoid(x) = 1/(1+exp(-x))`:
//   ds/dx = s * (1 - s)
//   ⇒ dx = dy * s * (1 - s)
// where s is the FORWARD sigmoid output. The reference computes the
// forward exactly as the walker's fwd AST would (same op order:
// u = 0 − x, e = dt_exp(u), d = 1 + e, s = 1/d) so the fwd value
// itself is byte-identical to the walker-cached forward; the byte-eq
// question reduces to whether the bwd combinator `dy * s * (1 - s)`
// is the same IEEE-754 trajectory as the walker's emitted combinator.
fn sigmoid_bwd_manual(x_arr: int, dy_arr: int, dx_out: int, len: int) {
    let mut i = 0
    while i < len {
        let xi  = t_get(x_arr, i)
        let dyi = t_get(dy_arr, i)
        // forward (matches the fwd AST builder's op order exactly)
        let u   = 0.0 - xi
        let e   = dt_exp(u)
        let d   = 1.0 + e
        let s   = 1.0 / d
        // closed-form vjp
        let dxi = dyi * s * (1.0 - s)
        t_set(dx_out, i, dxi)
        i = i + 1
    }
}

// ─── inputs for SD6 (reuse SD5's seeded x_arr/dy_arr) ──────────────────
// Same len=32 + same x_arr (positive + negative span) + same dy_arr as
// SD5. This is intentional — using a different seed would mask any
// shared-input regressions.

// ─── reference: hand-written sigmoid_bwd_manual ────────────────────────
let sd6_dx_ref = t_zeros(LEN)
sigmoid_bwd_manual(x_arr, dy_arr, sd6_dx_ref, LEN)

// ─── SD6 path: per-op AST-driven derivation ────────────────────────────
// Step 1: build the sigmoid fwd AST in a fresh arena. Use a fresh
// arena (rather than the SD5 arena) to keep the two demonstrations
// independent and the cache_out slot-ids clean.
let sd6_arena = ag_extract_arena_new()
let sd6_cache_meta = t_zeros(4)
let sd6_fwd_root = ag_extract_build_sigmoid_fwd(sd6_arena, sd6_cache_meta)
println("sigmoid fwd AST built — root (s) node id = " + to_string(sd6_fwd_root))
println("  cached intermediates: s=" + to_string(to_int(t_get(sd6_cache_meta, 0)))
      + ", d=" + to_string(to_int(t_get(sd6_cache_meta, 1)))
      + ", e=" + to_string(to_int(t_get(sd6_cache_meta, 2)))
      + ", u=" + to_string(to_int(t_get(sd6_cache_meta, 3))))

// Step 2: reverse-mode walk v2 with upstream = Var_Upstream (= dy).
let sd6_upstream = ag_extract_mk_var_upstream(sd6_arena)
let sd6_bwd_root = ag_extract_reverse_walk_v2(sd6_arena, sd6_fwd_root, sd6_upstream, 0)
println("reverse-mode walk v2 complete — bwd AST root node id = " + to_string(sd6_bwd_root))

// Step 3: emit the bwd source (for inspection — future SD10
// compile-and-load closure).
let sd6_bwd_src = ag_extract_emit_fn(sd6_arena, sd6_bwd_root, "sigmoid_bwd_auto_emitted")
println("emitted bwd hexa-lang source (sigmoid):")
println(sd6_bwd_src)

// Step 4: interpret the bwd AST elementwise with fwd-cache populated.
// Cache farr must be sized to the arena capacity (64 slots).
let sd6_fwd_cache = t_zeros(64)
let sd6_dx_auto = t_zeros(LEN)
ag_extract_sigmoid_bwd_via_ast(sd6_arena, sd6_fwd_root, sd6_bwd_root,
                                x_arr, dy_arr, sd6_dx_auto, LEN, sd6_fwd_cache)

// ─── byte-eq gate: F-RFC043-AUTOGRAD-AUTO-SD6-SIGMOID-BYTE-EQ ──────────
let sd6_dx_delta = ag_dt_maxdev(sd6_dx_auto, sd6_dx_ref, LEN)
println("sigmoid dx max|Δ| = " + to_string(sd6_dx_delta))

// Honest reporting: even when byte-eq holds at machine-eps, log the
// first few (x, dx_auto, dx_ref, delta) tuples so the floating-point
// trajectory is auditable.
println("first 4 element-wise comparison (x_i, dx_auto_i, dx_ref_i, |Δ|):")
let mut sd6_dbg_i = 0
while sd6_dbg_i < 4 {
    let xi  = t_get(x_arr, sd6_dbg_i)
    let dai = t_get(sd6_dx_auto, sd6_dbg_i)
    let dri = t_get(sd6_dx_ref, sd6_dbg_i)
    let dlt = ag_dt_abs(dai - dri)
    println("  i=" + to_string(sd6_dbg_i)
          + "  x=" + to_string(xi)
          + "  dx_auto=" + to_string(dai)
          + "  dx_ref=" + to_string(dri)
          + "  |Δ|=" + to_string(dlt))
    sd6_dbg_i = sd6_dbg_i + 1
}

// SD6 byte-eq is a HONEST FINDING gate (per task §7 of the SD6 brief)
// — the walker's emit `dy × s × e/d` is mathematically identical to
// the reference's `dy × s × (1 − s)` (algebraic identity 1−s ≡ e/d)
// but the IEEE-754 trajectory differs by ~1 ULP. SD6 documents this
// as the expected deliverable; the test does NOT exit on the
// honest-eps divergence so subsequent SDs (SD7+) can run.
//
// If max|Δ| exceeds machine-eps-scale tolerance (10× the observed
// 5.55e-17 ⇒ 5.55e-16), that is a real regression and we exit.
let sd6_honest_tolerance = 5.55e-16
if sd6_dx_delta > sd6_honest_tolerance {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD6-SIGMOID-BYTE-EQ  max|dx_auto − dx_ref| = "
          + to_string(sd6_dx_delta) + " > " + to_string(sd6_honest_tolerance) + " (10× machine-eps tolerance breached — real regression)")
    exit(92)
}

if sd6_dx_delta != 0.0 {
    // Honest finding (g3): the walker's per-op rule chain produces an
    // IEEE-754 trajectory different from the hand-derived closed
    // form `dy * s * (1 - s)`. SD5's byte-eq lemma was specific to
    // pure-conditional vjp shapes (no float arithmetic was reordered
    // — both paths went through the same `>`-then-select dataflow).
    // For sigmoid, the walker emits a multiplicative chain involving
    // cached _fwd values, while the reference uses the algebraic
    // identity `e/d ≡ 1-s` — these are equal mathematically but differ
    // in last-bit rounding. SD7 (below) revisits this question and
    // achieves byte-eq under Option A by aligning the reference's
    // IEEE-754 trajectory to the walker's emit order.
    println("HONEST  F-RFC043-AUTOGRAD-AUTO-SD6-SIGMOID-BYTE-EQ  max|dx_auto − dx_ref| = "
          + to_string(sd6_dx_delta) + " (machine-eps-scale ULP divergence, < 10×eps tolerance — algebraic identity 1-s ≡ e/d holds mathematically)")
    println("=== SD6 HONEST FINDING (documented, not a regression) ===")
} else {
    println("PASS  F-RFC043-AUTOGRAD-AUTO-SD6-SIGMOID-BYTE-EQ  max|dx_auto − dx_ref| = 0.0 (byte-eq · AST→reverse-walk-v2→interpret pipeline ≡ hand-written sigmoid_bwd reference)")
    println("=== SD6 PASS ===")
}

// ════════════════════════════════════════════════════════════════════════
// SD7 — multi-use Param accumulation byte-eq oracle
//
// Test function: f(x) = x*x + dt_exp(x), df/dx = 2*x + dt_exp(x).
// The Param x appears 3 times in the fwd AST (twice in x*x as two
// independent Param-leaves, once inside dt_exp). The walker's existing
// recursion structure (BinOp-emits-ADD) accumulates gradient
// contributions from each occurrence — this is the foundational
// reverse-mode accumulator (Griewank & Walther §3.2 Algorithm 3.6).
//
// Option A byte-eq (per task §6) — the reference's IEEE-754 trajectory
// matches the walker's natural emit order
// `(((dy*x) + (dy*x)) + (dy*exp_x))`. Max|Δ| = 0.0 expected.
// ════════════════════════════════════════════════════════════════════════
println("")
println("=== flame autograd-auto SD7 selftest (ag_extract · multi-use Param accumulation byte-eq) ===")

// ─── hand-written reference: multiuse_bwd_manual (Option A) ────────────
// Reference IEEE-754 trajectory MUST mirror the walker's emit order
// exactly. Walker emit (after the per-op chain) for f(x) = (x*x) + dt_exp(x)
// with upstream = dy, target = x:
//
//   ADD( ADD( MUL(dy, x_b_cached), MUL(dy, x_a_cached) ),
//        MUL(dy, exp_x_cached) )
//
// Under interpret_v2 with fwd_cache populated by eval_fwd, each
// Var_FwdResult(slot) reads back `x_val` (for the three Param(0) slots)
// and `dt_exp(x_val)` (for the dt_exp slot). So scalar evaluation is
//
//   (((dy * x) + (dy * x)) + (dy * exp_x))
//
// where exp_x = dt_exp(x). The reference below computes the same
// expression with the IDENTICAL operand sequence — no re-association
// into `dy * (2*x + exp_x)`. This is the Option A reorder-match.
fn multiuse_bwd_manual(x_arr: int, dy_arr: int, dx_out: int, len: int) {
    let mut i = 0
    while i < len {
        let xi   = t_get(x_arr, i)
        let dyi  = t_get(dy_arr, i)
        // forward intermediate that the walker also caches (read back
        // via Var_FwdResult); dt_exp is pure so the same input ⇒ same
        // output bit-for-bit.
        let ex   = dt_exp(xi)
        // walker emit order:
        //   t1 = dy * x         (from MUL rule da_contrib = dc * b_cached = dy * x_b)
        //   t2 = dy * x         (from MUL rule db_contrib = dc * a_cached = dy * x_a)
        //   t3 = t1 + t2        (from inner BinOp_ADD combining the two MUL contribs)
        //   t4 = dy * exp_x     (from Call_DTEXP rule da_contrib = dc * c_cached)
        //   dx = t3 + t4        (from top-level BinOp_ADD combining mul_xx with dt_exp)
        let t1 = dyi * xi
        let t2 = dyi * xi
        let t3 = t1 + t2
        let t4 = dyi * ex
        let dxi = t3 + t4
        t_set(dx_out, i, dxi)
        i = i + 1
    }
}

// ─── inputs for SD7 (reuse SD5/SD6 seeded x_arr/dy_arr) ────────────────
// Same len=32 x_arr (span [-1, 1] via LCG seed 4242 + −1 shift) and
// dy_arr (LCG seed 31337) — keeps SD7 in the same input domain as
// SD5 + SD6 so shared-input regressions can't hide.

let sd7_dx_ref = t_zeros(LEN)
multiuse_bwd_manual(x_arr, dy_arr, sd7_dx_ref, LEN)

// ─── SD7 path: AST-driven derivation with multi-use Param ──────────────
// Step 1: build the multi-use fwd AST in a fresh arena. Three independent
// Param(0) slots — one per occurrence of x in the source.
let sd7_arena = ag_extract_arena_new()
let sd7_cache_meta = t_zeros(4)
let sd7_fwd_root = ag_extract_build_multiuse_fwd(sd7_arena, sd7_cache_meta)
println("multi-use fwd AST built — root (ADD) node id = " + to_string(sd7_fwd_root))
println("  cached intermediates: root=" + to_string(to_int(t_get(sd7_cache_meta, 0)))
      + ", mul_xx=" + to_string(to_int(t_get(sd7_cache_meta, 1)))
      + ", exp_x=" + to_string(to_int(t_get(sd7_cache_meta, 2))))

// Step 2: reverse-mode walk v2 with upstream = Var_Upstream (= dy).
// The walker's natural recursion (BinOp-emits-ADD) is the accumulator.
let sd7_upstream = ag_extract_mk_var_upstream(sd7_arena)
let sd7_bwd_root = ag_extract_reverse_walk_v2(sd7_arena, sd7_fwd_root, sd7_upstream, 0)
println("reverse-mode walk v2 complete — bwd AST root node id = " + to_string(sd7_bwd_root))

// Step 3: emit the bwd source for inspection (paste in PLAN entry).
let sd7_bwd_src = ag_extract_emit_fn(sd7_arena, sd7_bwd_root, "multiuse_bwd_auto_emitted")
println("emitted bwd hexa-lang source (multi-use):")
println(sd7_bwd_src)

// Step 4: elementwise driver with fwd-cache populated per i.
let sd7_fwd_cache = t_zeros(64)
let sd7_dx_auto = t_zeros(LEN)
ag_extract_multiuse_bwd_via_ast(sd7_arena, sd7_fwd_root, sd7_bwd_root,
                                 x_arr, dy_arr, sd7_dx_auto, LEN, sd7_fwd_cache)

// ─── byte-eq gate: F-RFC043-AUTOGRAD-AUTO-SD7-MULTIUSE-BYTE-EQ ─────────
let sd7_dx_delta = ag_dt_maxdev(sd7_dx_auto, sd7_dx_ref, LEN)
println("multi-use dx max|Δ| = " + to_string(sd7_dx_delta))

// First-4-element transparent IEEE-754 audit (mirrors SD6 idiom).
println("first 4 element-wise comparison (x_i, dx_auto_i, dx_ref_i, |Δ|):")
let mut sd7_dbg_i = 0
while sd7_dbg_i < 4 {
    let xi  = t_get(x_arr, sd7_dbg_i)
    let dai = t_get(sd7_dx_auto, sd7_dbg_i)
    let dri = t_get(sd7_dx_ref, sd7_dbg_i)
    let dlt = ag_dt_abs(dai - dri)
    println("  i=" + to_string(sd7_dbg_i)
          + "  x=" + to_string(xi)
          + "  dx_auto=" + to_string(dai)
          + "  dx_ref=" + to_string(dri)
          + "  |Δ|=" + to_string(dlt))
    sd7_dbg_i = sd7_dbg_i + 1
}

if sd7_dx_delta != 0.0 {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD7-MULTIUSE-BYTE-EQ  max|dx_auto − dx_ref| = "
          + to_string(sd7_dx_delta) + " ≠ 0.0")
    println("Walker emit order: (((dy*x_b_cached) + (dy*x_a_cached)) + (dy*exp_x_cached))")
    println("Reference order:   (((dy*x)         + (dy*x)         ) + (dy*exp_x))")
    println("If max|Δ| is ULP-scale (~5e-17), then Option A reorder-match has a subtle cache-vs-direct read divergence — investigate eval_fwd write order vs the recursion's Var_FwdResult read order. Otherwise this is a real accumulation bug.")
    exit(93)
}

println("PASS  F-RFC043-AUTOGRAD-AUTO-SD7-MULTIUSE-BYTE-EQ  max|dx_auto − dx_ref| = 0.0 (byte-eq · AST walker's BinOp-emits-ADD recursion ≡ hand-written multi-use accumulator reference under Option A)")
println("=== SD7 PASS ===")

// ════════════════════════════════════════════════════════════════════════
// SD9 — bilinear multi-input vjp byte-eq oracle
//
// Test function: f(x, y) = x * y.
//   df/dx = y  ⇒  dx = dy * y
//   df/dy = x  ⇒  dy_grad = dy * x
//
// The walker is invoked twice with the SAME fwd AST: once with
// target_param_ix = 0 (producing the df/dx bwd AST) and once with
// target_param_ix = 1 (producing the df/dy bwd AST). Each bwd AST
// is interpreted via `ag_extract_interpret_v2_multi` against a 2-cell
// `param_vals` farr [x_i, y_i]. Both per-Param byte-eq gates must
// PASS for the SD9 falsifier to be satisfied.
//
// Walker emit (after the BinOp_MUL rule chain) for target = 0:
//   ADD( MUL(dy, y_cached), Const(0.0) )
// Reference for df/dx (Option A — mirror the walker's emit order):
//   t1 = dy * y; t2 = 0.0; dx = t1 + t2
//
// Walker emit for target = 1:
//   ADD( Const(0.0), MUL(dy, x_cached) )
// Reference for df/dy:
//   t1 = 0.0; t2 = dy * x; dy_grad = t1 + t2
// ════════════════════════════════════════════════════════════════════════
println("")
println("=== flame autograd-auto SD9 selftest (ag_extract · bilinear multi-input vjp byte-eq) ===")

// ─── hand-written references: bilinear_bwd_x_manual / _y_manual ────────
// Option A reorder-match — IEEE-754 trajectory mirrors the walker's
// emit order: for target=0 it's `((dy*y) + 0.0)`, for target=1 it's
// `(0.0 + (dy*x))`. Same `*` order, same `+` order — no factoring.
// `bilinear_bwd_x_manual` reads `y_arr` (df/dx = y) — `x_arr` is unused
// in this direction; passed so the call-sites are symmetric with the
// y-direction manual. Same for the y-direction manual: it reads x_arr
// and ignores y_arr.
fn bilinear_bwd_x_manual(x_arr: int, y_arr: int, dy_arr: int, dx_out: int, len: int) {
    let mut i = 0
    while i < len {
        let yi  = t_get(y_arr, i)
        let dyi = t_get(dy_arr, i)
        // Walker emit order:
        //   t1 = dy * y_cached         (from MUL rule da_contrib = dc * b_cached)
        //   t2 = 0.0                   (from Param(1) leaf when target=0)
        //   dx = t1 + t2               (from BinOp_MUL emits ADD combining child contribs)
        let t1 = dyi * yi
        let t2 = 0.0
        let dxi = t1 + t2
        t_set(dx_out, i, dxi)
        i = i + 1
    }
}

fn bilinear_bwd_y_manual(x_arr: int, y_arr: int, dy_arr: int, dyg_out: int, len: int) {
    let mut i = 0
    while i < len {
        let xi  = t_get(x_arr, i)
        let dyi = t_get(dy_arr, i)
        // Walker emit order for target=1:
        //   t1 = 0.0                   (from Param(0) leaf when target=1)
        //   t2 = dy * x_cached         (from MUL rule db_contrib = dc * a_cached)
        //   dy_grad = t1 + t2
        let t1 = 0.0
        let t2 = dyi * xi
        let dyg_i = t1 + t2
        t_set(dyg_out, i, dyg_i)
        i = i + 1
    }
}

// ─── fixed-seed inputs for SD9 (separate seeds per axis) ───────────────
// Per task §5: separate LCG seeds for x, y, dy. We REUSE the SD5/6/7
// x_arr (seed 4242 + −1 shift) and dy_arr (seed 31337) so the
// regression check shares a single input domain. A fresh y_arr uses
// LCG seed 70707 with the same scale=2.0 + −1 shift so y also spans
// [-1, 1] (non-zero product distribution exercises both Param
// directions on non-trivial signs).
let y_arr = t_zeros(LEN)
t_fill_lcg(y_arr, LEN, 70707, 2.0)
let mut sd9_y_shift = 0
while sd9_y_shift < LEN {
    t_set(y_arr, sd9_y_shift, t_get(y_arr, sd9_y_shift) - 1.0)
    sd9_y_shift = sd9_y_shift + 1
}

// Sanity check: y_arr spans both signs (no trivial-sign mask hiding
// gradient errors).
let mut sd9_y_pos = 0
let mut sd9_y_neg = 0
let mut sd9_y_check = 0
while sd9_y_check < LEN {
    let v = t_get(y_arr, sd9_y_check)
    if v > 0.0 { sd9_y_pos = sd9_y_pos + 1 }
    if v < 0.0 { sd9_y_neg = sd9_y_neg + 1 }
    sd9_y_check = sd9_y_check + 1
}
println("y_arr span: " + to_string(sd9_y_pos) + " positives, " + to_string(sd9_y_neg) + " negatives (both Param directions exercised on non-trivial signs)")

// ─── references: hand-written manual gradients ─────────────────────────
let sd9_dx_ref = t_zeros(LEN)
let sd9_dyg_ref = t_zeros(LEN)
bilinear_bwd_x_manual(x_arr, y_arr, dy_arr, sd9_dx_ref, LEN)
bilinear_bwd_y_manual(x_arr, y_arr, dy_arr, sd9_dyg_ref, LEN)

// ─── SD9 path: AST-driven derivation with 2 Params ─────────────────────
// Step 1: build the bilinear fwd AST in a fresh arena.
let sd9_arena = ag_extract_arena_new()
let sd9_cache_meta = t_zeros(4)
let sd9_fwd_root = ag_extract_build_bilinear_fwd(sd9_arena, sd9_cache_meta)
println("bilinear fwd AST built — root (MUL) node id = " + to_string(sd9_fwd_root))
println("  param slots: x=" + to_string(to_int(t_get(sd9_cache_meta, 1)))
      + ", y=" + to_string(to_int(t_get(sd9_cache_meta, 2))))

// Step 2: reverse-mode walk v2 TWICE, once per target Param index.
// Each call produces an independent bwd AST in the same arena. The
// upstream node is shared because it is a `dy` leaf — independent of
// the target Param direction.
let sd9_upstream_x = ag_extract_mk_var_upstream(sd9_arena)
let sd9_bwd_x_root = ag_extract_reverse_walk_v2(sd9_arena, sd9_fwd_root, sd9_upstream_x, 0)
println("reverse-mode walk v2 (target=x · Param(0)) complete — bwd_x AST root id = " + to_string(sd9_bwd_x_root))

let sd9_upstream_y = ag_extract_mk_var_upstream(sd9_arena)
let sd9_bwd_y_root = ag_extract_reverse_walk_v2(sd9_arena, sd9_fwd_root, sd9_upstream_y, 1)
println("reverse-mode walk v2 (target=y · Param(1)) complete — bwd_y AST root id = " + to_string(sd9_bwd_y_root))

// Step 3: emit BOTH bwd sources for inspection. The xy-signature emit
// helper (`ag_extract_emit_fn_xy`) renders `(x, y, dy) -> float` —
// each call would, after SD11's compile-and-load loop, become a
// standalone hexa function.
let sd9_bwd_x_src = ag_extract_emit_fn_xy(sd9_arena, sd9_bwd_x_root, "f_x_bwd_auto")
let sd9_bwd_y_src = ag_extract_emit_fn_xy(sd9_arena, sd9_bwd_y_root, "f_y_bwd_auto")
println("emitted bwd hexa-lang source (bilinear, df/dx):")
println(sd9_bwd_x_src)
println("emitted bwd hexa-lang source (bilinear, df/dy):")
println(sd9_bwd_y_src)

// Step 4: elementwise drivers with fwd-cache + 2-cell param_vals.
let sd9_fwd_cache = t_zeros(64)
let sd9_param_vals = t_zeros(2)
let sd9_dx_auto = t_zeros(LEN)
let sd9_dyg_auto = t_zeros(LEN)
ag_extract_bilinear_bwd_via_ast(sd9_arena, sd9_fwd_root, sd9_bwd_x_root,
                                 x_arr, y_arr, dy_arr, sd9_dx_auto, LEN,
                                 sd9_fwd_cache, sd9_param_vals)
ag_extract_bilinear_bwd_via_ast(sd9_arena, sd9_fwd_root, sd9_bwd_y_root,
                                 x_arr, y_arr, dy_arr, sd9_dyg_auto, LEN,
                                 sd9_fwd_cache, sd9_param_vals)

// ─── byte-eq gate (per Param): F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ ─
let sd9_dx_delta  = ag_dt_maxdev(sd9_dx_auto, sd9_dx_ref, LEN)
let sd9_dyg_delta = ag_dt_maxdev(sd9_dyg_auto, sd9_dyg_ref, LEN)
println("df/dx max|Δ| = " + to_string(sd9_dx_delta))
println("df/dy max|Δ| = " + to_string(sd9_dyg_delta))

// First-4-elements transparent IEEE-754 audit (one block per Param dir).
println("first 4 element-wise comparison (df/dx — x_i, y_i, dy_i, dx_auto, dx_ref, |Δ|):")
let mut sd9_dbg_x_i = 0
while sd9_dbg_x_i < 4 {
    let xi   = t_get(x_arr, sd9_dbg_x_i)
    let yi   = t_get(y_arr, sd9_dbg_x_i)
    let dyi  = t_get(dy_arr, sd9_dbg_x_i)
    let dai  = t_get(sd9_dx_auto, sd9_dbg_x_i)
    let dri  = t_get(sd9_dx_ref, sd9_dbg_x_i)
    let dlt  = ag_dt_abs(dai - dri)
    println("  i=" + to_string(sd9_dbg_x_i)
          + "  x=" + to_string(xi)
          + "  y=" + to_string(yi)
          + "  dy=" + to_string(dyi)
          + "  dx_auto=" + to_string(dai)
          + "  dx_ref=" + to_string(dri)
          + "  |Δ|=" + to_string(dlt))
    sd9_dbg_x_i = sd9_dbg_x_i + 1
}
println("first 4 element-wise comparison (df/dy — x_i, y_i, dy_i, dyg_auto, dyg_ref, |Δ|):")
let mut sd9_dbg_y_i = 0
while sd9_dbg_y_i < 4 {
    let xi   = t_get(x_arr, sd9_dbg_y_i)
    let yi   = t_get(y_arr, sd9_dbg_y_i)
    let dyi  = t_get(dy_arr, sd9_dbg_y_i)
    let dai  = t_get(sd9_dyg_auto, sd9_dbg_y_i)
    let dri  = t_get(sd9_dyg_ref, sd9_dbg_y_i)
    let dlt  = ag_dt_abs(dai - dri)
    println("  i=" + to_string(sd9_dbg_y_i)
          + "  x=" + to_string(xi)
          + "  y=" + to_string(yi)
          + "  dy=" + to_string(dyi)
          + "  dyg_auto=" + to_string(dai)
          + "  dyg_ref=" + to_string(dri)
          + "  |Δ|=" + to_string(dlt))
    sd9_dbg_y_i = sd9_dbg_y_i + 1
}

// Per-Param verdicts (printed regardless of overall PASS/FAIL for
// transparent oracle reporting).
let mut sd9_x_pass = 0
if sd9_dx_delta == 0.0 {
    sd9_x_pass = 1
    println("PASS  F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ (df/dx)  max|dx_auto − dx_ref| = 0.0")
} else {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ (df/dx)  max|dx_auto − dx_ref| = "
          + to_string(sd9_dx_delta) + " ≠ 0.0")
}
let mut sd9_y_pass = 0
if sd9_dyg_delta == 0.0 {
    sd9_y_pass = 1
    println("PASS  F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ (df/dy)  max|dyg_auto − dyg_ref| = 0.0")
} else {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ (df/dy)  max|dyg_auto − dyg_ref| = "
          + to_string(sd9_dyg_delta) + " ≠ 0.0")
}

if sd9_x_pass == 0 {
    println("Walker emit order (df/dx): ADD( MUL(dy, y_cached), Const(0.0) )")
    println("Reference order  (df/dx): ((dy * y) + 0.0)")
    println("If max|Δ| is ULP-scale, the param-vals indirection introduces a subtle read-order divergence. Otherwise this is a real multi-input vjp bug.")
    exit(94)
}
if sd9_y_pass == 0 {
    println("Walker emit order (df/dy): ADD( Const(0.0), MUL(dy, x_cached) )")
    println("Reference order  (df/dy): (0.0 + (dy * x))")
    exit(94)
}

println("PASS  F-RFC043-AUTOGRAD-AUTO-SD9-BILINEAR-BYTE-EQ  BOTH per-Param gates green (df/dx · df/dy)")
println("=== SD9 PASS ===")

// ════════════════════════════════════════════════════════════════════════
// SD10 — multi-input arithmetic vjp byte-eq oracle
//
// Test function: f(x, y) = x / (1 + dt_exp(0 − y))
//   df/dx = 1 / (1 + exp(-y)) = s(y)
//   df/dy = x * s(y) * (1 - s(y))         (sigmoid derivative reappears)
//
// SD10 = SD6 algebraic-identity ULP zone × SD9 multi-input mechanism.
//
// Walker emits (target=0, df/dx) — DIV at root, all sigmoid-subtree
// contributions reduce to Const(0.0) since their Param leaves are
// ix=1 ≠ 0:
//   ADD( DIV(dy, _fwd_d),
//        ADD( Const(0.0),
//             ADD( MUL(dy, _fwd_e) · 0   chain reducing to 0.0 ) ) )
//   ⇒ interprets to `(dy / d) + (0.0 + (0.0 + (0.0 + 0.0)))`
//     = `dy / d` (with three Const(0.0) ADDs as trailing pad).
// Reference (SD6 exact form, dy * s):
//   s = 1.0 / (1.0 + dt_exp(0.0 - y));  dx_ref = dy * s
//   ⇒ trajectory: `dy * (1.0 / d)`  (DIV + MUL, vs walker's single DIV
//     + ADD-chain-of-zeros). Different IEEE-754 trajectory ⇒
//     HONEST 1-ULP zone expected, or PASS byte-eq if rounding aligns.
//
// Walker emits (target=1, df/dy) — DIV at root, only sigmoid-subtree
// path is non-zero (Param(0)=x leaf returns Const(0.0)):
//   ADD( Const(0.0),                                  (x-leaf when target=1)
//        ADD( Const(0.0),                              (ONE_A const)
//             ADD( Const(0.0),                         (ZERO_A const inside SUB)
//                  NEG( MUL(db_local, _fwd_e) ) ) ) )
//   where  db_local = NEG( DIV( MUL(dy, _fwd_root), _fwd_d_2 ) )
//   ⇒ Interprets to:
//       neg_inner  = (dy * c) / d         (with c = f(x,y) = x/d)
//       db_local   = NEG(neg_inner)       = -(dy * c / d)
//       dc_c       = db_local * e         = -(dy * c / d) * e
//       neg_total  = NEG(dc_c)            = (dy * c / d) * e
//       tail_add   = 0.0 + neg_total
//                  = 0.0 + ((dy * c / d) * e)
//       y_dir      = 0.0 + (0.0 + (0.0 + tail_add))
//                  = 0.0 + (0.0 + (0.0 + ((dy * c / d) * e)))
// Reference (SD6 exact form, dy * x * s * (1-s)):
//   s = 1.0 / d;  one_minus_s = 1.0 - s;  dy_ref = dy * x * s * one_minus_s
//   ⇒ trajectory: `dy * x * s * (1 - s)`. Algebraically identical:
//       (dy * c / d) * e  =  (dy * (x/d) / d) * e  =  dy * x * (e/d) / d
//       =  dy * x * (e/d) * (1/d)  =  dy * x * (1-s) * s
//   But IEEE-754 last-bit differs (the SD6 reorder lesson) ⇒
//     HONEST 1-ULP zone expected.
//
// Both per-Param gates report verdict honestly:
//   PASS    : max|Δ| = 0.0   (algebraic shape happens to byte-align)
//   HONEST  : 0 < max|Δ| ≤ 10×eps  (SD6 reorder lesson confirmed)
//   FAIL(95): max|Δ| > 10×eps  (real regression — investigate)
// ════════════════════════════════════════════════════════════════════════
println("")
println("=== flame autograd-auto SD10 selftest (ag_extract · sigmoid-div multi-input vjp · SD6×SD9 cross-product) ===")

// ─── hand-written references: sd10_div_x_manual / _y_manual ───────────
// Both references use SD6's EXACT form per task brief — recompute
// `s` from scratch as `1.0 / (1.0 + dt_exp(0.0 - y))`, then use
// `s` (for df/dx) and `s * (1.0 - s)` (for df/dy). This deliberately
// does NOT mirror the walker's emit trajectory — that's the point of
// SD10: measure whether SD6's algebraic-identity reorder lesson
// generalizes under multi-input mechanism. The reference's
// `1 - s` and the walker's `e/d` are mathematically equal; this
// gate measures the IEEE-754 last-bit verdict.
fn sd10_div_x_manual(x_arr: int, y_arr: int, dy_arr: int, dx_out: int, len: int) {
    let mut i = 0
    while i < len {
        let yi  = t_get(y_arr, i)
        let dyi = t_get(dy_arr, i)
        // forward (matches the fwd AST builder's op order for d only —
        // the manual recomputes s independently of the AST cache,
        // using the SD6 closed form).
        let u   = 0.0 - yi
        let e   = dt_exp(u)
        let d   = 1.0 + e
        let s   = 1.0 / d
        // closed-form vjp: df/dx = s ⇒ dx = dy * s
        let dxi = dyi * s
        t_set(dx_out, i, dxi)
        i = i + 1
    }
}

fn sd10_div_y_manual(x_arr: int, y_arr: int, dy_arr: int, dyg_out: int, len: int) {
    let mut i = 0
    while i < len {
        let xi  = t_get(x_arr, i)
        let yi  = t_get(y_arr, i)
        let dyi = t_get(dy_arr, i)
        // forward (sigmoid recomputed manually per SD6 form)
        let u   = 0.0 - yi
        let e   = dt_exp(u)
        let d   = 1.0 + e
        let s   = 1.0 / d
        let one_minus_s = 1.0 - s
        // closed-form vjp: df/dy = x * s * (1 - s)
        //                ⇒ dyg = dy * x * s * (1 - s)
        let dyg_i = dyi * xi * s * one_minus_s
        t_set(dyg_out, i, dyg_i)
        i = i + 1
    }
}

// ─── inputs for SD10 (reuse SD5/6/7/9 seeded arrays) ──────────────────
// Per task §5 — len=32 fixed-seed LCG per axis. We REUSE the
// existing arrays (x_arr seed 4242 + −1 shift, y_arr seed 70707 +
// −1 shift, dy_arr seed 31337). This keeps SD10 in the same input
// domain as SD5/6/7/9, ensuring shared-input regressions can't hide
// behind a fresh seed.

let sd10_dx_ref  = t_zeros(LEN)
let sd10_dyg_ref = t_zeros(LEN)
sd10_div_x_manual(x_arr, y_arr, dy_arr, sd10_dx_ref, LEN)
sd10_div_y_manual(x_arr, y_arr, dy_arr, sd10_dyg_ref, LEN)

// ─── SD10 path: AST-driven derivation with 2 Params + arithmetic ──────
// Step 1: build the SD10 fwd AST `x / (1 + dt_exp(0 - y))` in a fresh
// arena (slot count: 8 fwd + ~17 bwd × 2 dirs ≈ 42, under 64-cap).
let sd10_arena = ag_extract_arena_new()
let sd10_cache_meta = t_zeros(4)
let sd10_fwd_root = ag_extract_build_sigmoid_div_multi_fwd(sd10_arena, sd10_cache_meta)
println("sigmoid-div multi fwd AST built — root (DIV) node id = " + to_string(sd10_fwd_root))
println("  param slots: x=" + to_string(to_int(t_get(sd10_cache_meta, 1)))
      + ", y=" + to_string(to_int(t_get(sd10_cache_meta, 2)))
      + ", d=" + to_string(to_int(t_get(sd10_cache_meta, 3))))

// Step 2: reverse-mode walk v2 TWICE, once per target Param index.
let sd10_upstream_x = ag_extract_mk_var_upstream(sd10_arena)
let sd10_bwd_x_root = ag_extract_reverse_walk_v2(sd10_arena, sd10_fwd_root, sd10_upstream_x, 0)
println("reverse-mode walk v2 (target=x · Param(0)) complete — bwd_x AST root id = " + to_string(sd10_bwd_x_root))

let sd10_upstream_y = ag_extract_mk_var_upstream(sd10_arena)
let sd10_bwd_y_root = ag_extract_reverse_walk_v2(sd10_arena, sd10_fwd_root, sd10_upstream_y, 1)
println("reverse-mode walk v2 (target=y · Param(1)) complete — bwd_y AST root id = " + to_string(sd10_bwd_y_root))

// Step 3: emit BOTH bwd sources for inspection — the (x, y, dy) signature.
let sd10_bwd_x_src = ag_extract_emit_fn_xy(sd10_arena, sd10_bwd_x_root, "f_x_bwd_auto")
let sd10_bwd_y_src = ag_extract_emit_fn_xy(sd10_arena, sd10_bwd_y_root, "f_y_bwd_auto")
println("emitted bwd hexa-lang source (sigmoid-div, df/dx):")
println(sd10_bwd_x_src)
println("emitted bwd hexa-lang source (sigmoid-div, df/dy):")
println(sd10_bwd_y_src)

// Step 4: elementwise drivers with fwd-cache + 2-cell param_vals.
let sd10_fwd_cache  = t_zeros(64)
let sd10_param_vals = t_zeros(2)
let sd10_dx_auto    = t_zeros(LEN)
let sd10_dyg_auto   = t_zeros(LEN)
ag_extract_sigmoid_div_multi_bwd_via_ast(sd10_arena, sd10_fwd_root, sd10_bwd_x_root,
                                          x_arr, y_arr, dy_arr, sd10_dx_auto, LEN,
                                          sd10_fwd_cache, sd10_param_vals)
ag_extract_sigmoid_div_multi_bwd_via_ast(sd10_arena, sd10_fwd_root, sd10_bwd_y_root,
                                          x_arr, y_arr, dy_arr, sd10_dyg_auto, LEN,
                                          sd10_fwd_cache, sd10_param_vals)

// ─── byte-eq gate (per Param): F-RFC043-AUTOGRAD-AUTO-SD10-DIV-MULTI-BYTE-EQ ─
let sd10_dx_delta  = ag_dt_maxdev(sd10_dx_auto,  sd10_dx_ref,  LEN)
let sd10_dyg_delta = ag_dt_maxdev(sd10_dyg_auto, sd10_dyg_ref, LEN)
println("df/dx max|Δ| = " + to_string(sd10_dx_delta))
println("df/dy max|Δ| = " + to_string(sd10_dyg_delta))

// First-4-elements transparent IEEE-754 audit (one block per Param dir).
println("first 4 element-wise comparison (df/dx — x_i, y_i, dy_i, dx_auto, dx_ref, |Δ|):")
let mut sd10_dbg_x_i = 0
while sd10_dbg_x_i < 4 {
    let xi   = t_get(x_arr, sd10_dbg_x_i)
    let yi   = t_get(y_arr, sd10_dbg_x_i)
    let dyi  = t_get(dy_arr, sd10_dbg_x_i)
    let dai  = t_get(sd10_dx_auto, sd10_dbg_x_i)
    let dri  = t_get(sd10_dx_ref, sd10_dbg_x_i)
    let dlt  = ag_dt_abs(dai - dri)
    println("  i=" + to_string(sd10_dbg_x_i)
          + "  x=" + to_string(xi)
          + "  y=" + to_string(yi)
          + "  dy=" + to_string(dyi)
          + "  dx_auto=" + to_string(dai)
          + "  dx_ref=" + to_string(dri)
          + "  |Δ|=" + to_string(dlt))
    sd10_dbg_x_i = sd10_dbg_x_i + 1
}
println("first 4 element-wise comparison (df/dy — x_i, y_i, dy_i, dyg_auto, dyg_ref, |Δ|):")
let mut sd10_dbg_y_i = 0
while sd10_dbg_y_i < 4 {
    let xi   = t_get(x_arr, sd10_dbg_y_i)
    let yi   = t_get(y_arr, sd10_dbg_y_i)
    let dyi  = t_get(dy_arr, sd10_dbg_y_i)
    let dai  = t_get(sd10_dyg_auto, sd10_dbg_y_i)
    let dri  = t_get(sd10_dyg_ref,  sd10_dbg_y_i)
    let dlt  = ag_dt_abs(dai - dri)
    println("  i=" + to_string(sd10_dbg_y_i)
          + "  x=" + to_string(xi)
          + "  y=" + to_string(yi)
          + "  dy=" + to_string(dyi)
          + "  dyg_auto=" + to_string(dai)
          + "  dyg_ref=" + to_string(dri)
          + "  |Δ|=" + to_string(dlt))
    sd10_dbg_y_i = sd10_dbg_y_i + 1
}

// Per-Param verdicts. SD10 follows SD6's HONEST-finding pattern:
// machine-eps-scale divergence (≤ 10×eps) is a documented honest
// finding (algebraic-identity reorder lesson under multi-input);
// exceeding the tolerance is a real regression and exits 95.
//
// Tolerance: 10× the SD6 baseline 5.55e-17 ≈ 5.55e-16. The y-direction
// has a LONGER algebraic chain (dy × x × s × (1-s) vs walker's
// (dy × c × e) / d via three NEG/DIV/MUL ops) so its 1-ULP zone may
// be slightly larger — we use the same SD6 tolerance to keep the
// verdict crisp; the audit prints the actual max|Δ| regardless.
let sd10_honest_tolerance = 5.55e-16

if sd10_dx_delta > sd10_honest_tolerance {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD10-DIV-MULTI-BYTE-EQ (df/dx)  max|dx_auto − dx_ref| = "
          + to_string(sd10_dx_delta) + " > " + to_string(sd10_honest_tolerance)
          + " (10× machine-eps tolerance breached — real regression)")
    println("Walker emit order (df/dx): ADD( DIV(dy, _fwd_d), Const-zero-chain )")
    println("Reference order  (df/dx): dy * (1.0 / (1.0 + dt_exp(0.0 - y)))")
    exit(95)
}
if sd10_dyg_delta > sd10_honest_tolerance {
    println("FAIL  F-RFC043-AUTOGRAD-AUTO-SD10-DIV-MULTI-BYTE-EQ (df/dy)  max|dyg_auto − dyg_ref| = "
          + to_string(sd10_dyg_delta) + " > " + to_string(sd10_honest_tolerance)
          + " (10× machine-eps tolerance breached — real regression)")
    println("Walker emit order (df/dy): Const-zero-chain + NEG(MUL(NEG(DIV(MUL(dy,c),d)), e))")
    println("Reference order  (df/dy): dy * x * s * (1 - s)  where s = 1.0/d")
    exit(95)
}

// Both gates within tolerance — emit per-direction verdict.
let mut sd10_x_label = "HONEST"
if sd10_dx_delta == 0.0 { sd10_x_label = "PASS" }
let mut sd10_y_label = "HONEST"
if sd10_dyg_delta == 0.0 { sd10_y_label = "PASS" }

println(sd10_x_label + "  F-RFC043-AUTOGRAD-AUTO-SD10-DIV-MULTI-BYTE-EQ (df/dx)  max|dx_auto − dx_ref| = "
      + to_string(sd10_dx_delta)
      + "   (walker: dy/d · reference: dy*(1/d))")
println(sd10_y_label + "  F-RFC043-AUTOGRAD-AUTO-SD10-DIV-MULTI-BYTE-EQ (df/dy)  max|dyg_auto − dyg_ref| = "
      + to_string(sd10_dyg_delta)
      + "   (walker: (dy*c*e)/d · reference: dy*x*s*(1-s) — SD6 reorder zone)")

if sd10_x_label == "PASS" {
    if sd10_y_label == "PASS" {
        println("=== SD10 PASS (BOTH per-Param gates byte-eq — algebraic shape happens to align even under arithmetic + multi-input) ===")
    } else {
        println("=== SD10 PASS-with-HONEST (df/dx byte-eq · df/dy honest 1-ULP — SD6 reorder lesson confirmed under multi-input on the y-dir's algebraic-identity chain) ===")
    }
} else {
    if sd10_y_label == "PASS" {
        println("=== SD10 PASS-with-HONEST (df/dx honest 1-ULP · df/dy byte-eq — predicted SD6 reorder under multi-input on x-dir's DIV-vs-MUL-(1/d) split) ===")
    } else {
        println("=== SD10 HONEST FINDING (both per-Param dirs ≤ 10×eps — SD6 algebraic-identity reorder lesson fully confirmed under multi-input arithmetic) ===")
    }
}

println("")
println("=== SD5 + SD6 + SD7 + SD9 + SD10 closure (SD10 multi-input arithmetic vjp validated · SD6 ULP zone × SD9 multi-input mechanism) ===")
exit(0)
