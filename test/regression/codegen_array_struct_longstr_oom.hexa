// REGRESSION REPRODUCER — substrate blocker `runtime-selfcompile-memory`
// (COMPILE-ONLY.log.tape @? root_substrate_defect_selfcompile_oom).
//
// Compiling an array literal of N struct-literals whose fields include a
// LONG string literal makes the NEW compiler/* codegen|lower|emit blow RSS
// super-quadratically (cliff ~1000→2000 elements; full embedded-atlas
// N≈7400 → linear ~11 GiB/s → OOM @ 251 GiB in 52 s).
//
// PROVEN-INNOCENT (host interp RUN of this exact source at N=4000 = 1 MB / 1 s):
//   runtime array/heapify · legacy parser · bind · resolve · types — fine.
// CULPRIT (root-caused, scope-corrected — see COMPILE-ONLY.log.tape
//   @A selfcompile_oom_scope_correction): the NEW compiler/* pipeline has
//   NO array-literal-EXPRESSION support at all (parser parse_primary has no
//   `[` case; ast.hexa has no ExprKind::ArrayLit; lower/mir/codegen/emit
//   have no array-construction path). `let t=[…]` → HX2001 `undefined name
//   '[' / ','` per array literal; on the 7400-elem embedded-atlas array the
//   error-RECOVERY records (placeholder + HexaError carrying long span text)
//   accumulate O(n²) → the OOM. This is ALSO a large slice of the 1803
//   HX2001 (one `[`+`,` pair per array literal, used pervasively).
// FIX (NOT a codegen port — that plan is retracted): implement array-literal
//   expressions across all 6 pipeline stages (ast + parser + ast_to_hir +
//   hir_to_mir + codegen/* + emit/asm), construction loop/chunk-based to
//   avoid reintroducing compile-time O(n²) at scale. Track:
//   `new-compiler-array-literals` (same family as the landed operator-
//   lowering fix; the next, larger, unimplemented expression production).
//
// PASS CRITERION: `hexa build` (new stage1) of this file at N=2000 peaks
//   < 200 MB (currently ~4 GB). At N=250/500/1000 it already completes; the
//   cliff is 1000→2000.
struct AN { k: string, id: string, raw: string, g: i64 }
fn build() -> [AN] {
    let t = [
        AN { k: "C", id: "NODE-0", raw: "@C NODE-0 = some atlas content payload number 0 :: domain [10] => derived claim 0", g: 0 },
        AN { k: "C", id: "NODE-1", raw: "@C NODE-1 = some atlas content payload number 1 :: domain [10] => derived claim 1", g: 1 },
        AN { k: "C", id: "NODE-2", raw: "@C NODE-2 = some atlas content payload number 2 :: domain [10] => derived claim 2", g: 2 }
        // … generator emits N of these; see test harness. 3 kept here as the
        // canonical shape (array-of-struct-with-long-string-literal).
    ]
    return t
}
fn main() { let x = build(); println(to_string(len(x))) }
