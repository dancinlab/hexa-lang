// PROBE r9-19 regression — pub(crate)/pub(super)/pub(self) top-level dispatch
//
// Originally filed as "pub(crate) fn x() {} fails with expected identifier,
// got Crate ('crate')" — caused by parse_visibility calling p_expect_ident()
// directly inside the LParen ... RParen, which rejects the keyword tokens
// Crate / Super / Self_ / Mod that the lexer emits for those scope words.
//
// FIXED by PR #373 (commit 858107e4 "fix(parser): widen `pub` parsing — struct
// fields · impl/trait methods · `pub(crate)`") — parse_visibility now accepts
// the keyword token kinds via tok.value alongside Ident.  Visibility value is
// still discarded (single-TU monolith — enforcement is a multi-TU design item).
//
// This file locks the surface so a future parser refactor cannot silently
// regress the four top-level shapes.  Sibling test t37_attr_pub_fn.hexa
// covers the `@attr pub fn` interaction (G39); this one covers the bare
// `pub(scope) fn` surface (r9-19).
//
// Expected output:
//   x=1
//   y=2
//   z=3
//   w=4

pub(crate) fn x() { return 1 }
pub(super) fn y() { return 2 }
pub(self)  fn z() { return 3 }
pub        fn w() { return 4 }

fn main() {
    println("x=" + to_string(x()))
    println("y=" + to_string(y()))
    println("z=" + to_string(z()))
    println("w=" + to_string(w()))
}
