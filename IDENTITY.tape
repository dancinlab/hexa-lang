  kind = "perfect-number programming language · n=6 lattice authority · canonical-format SSOT"
  => "Self-hosting hexa-lang compiler + stdlib + raw-rule promotion authority. Sister of n6 (semantic atom), hxc (byte wire), n12 (cube), tape (causal trace)."

@I scope :: identity [d=2026-05-14 ok]
  <- hexa_lang
  capabilities = ["parse","build","cc","run","atlas-register","atlas-promote","raw-rule-authority"]
  authorizes = ["lattice-native (§3.1 LATTICE_POLICY)","lattice-acceptor (§3.2)"]
  refuses = ["fit-to-convenient-number","over-claim","n=6-as-constraint"]

@I origin :: identity [d=2026-05-14 ok]
  <- hexa_lang
  repo = "github.com/dancinlab/hexa-lang"
  ssot = "~/core/hexa-lang/"
  raw_audit = ".raw-audit/ — hash-chained 143-line log (80% already tape-shaped)"

@I principle :: identity [d=2026-05-14 ok]
  <- hexa_lang
