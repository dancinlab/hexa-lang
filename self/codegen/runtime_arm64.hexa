// ── rt_strcat ────────────────────────────────────────────────
// strcat(x0=dst, x1=src) — append NUL-terminated src to the end of
// NUL-terminated dst (including the terminating NUL); return dst in
// x0. Composite of a strlen-scan (advance to dst's NUL) + a strcpy
// (copy src bytes incl. NUL). Pure byte load/store loops; no
// relocation, no calls, no arena state, no HexaVal touch — the LAST
// simple composite-leaf in the easy phase (B9.6a / F3 increment 4).
//
// Algorithm:
//   mov x2, x0           ; p = dst (x0 preserved as return value)
//   scan: ldrb w3, [x2]  ; advance p to dst's NUL terminator
