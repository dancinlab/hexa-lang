// self/codegen/runtime_arm64.hexa — ARM64 machine code for runtime primitives
// Replaces runtime.c — these produce raw ARM64 instruction bytes
// that get embedded directly into native Mach-O binaries.
//
// macOS ARM64 syscalls (svc #0x80):
//   SYS_exit  = 1
//   SYS_write = 4
//   SYS_mmap  = 197
//
// Each function returns a [int] of little-endian ARM64 instruction bytes.
// Byte values are pre-computed decimals to avoid hex-literal and
// large-integer precision issues in the interp NaN-boxing runtime.
//
// ── P40 WORKAROUND — interp interpreter SIGSEGV ─────────────────────
// Running this file directly under `build/hexa_interp runtime_arm64.hexa`
// exits 139 (SIGSEGV) with garbled output like "rt_exit : bytes" and
// "<__not_fused__>". Root cause: HEXA_VAL_ARENA=1 (default since rt 32-L)
// corrupts arrays returned from helper fn A and consumed inside helper
// fn B — exactly the pattern every rt_* function here uses:
//     fn rt_exit() { let mut c = []; c.push(253); ...; return c }
//     fn test_runtime_arm64() { let exit_bytes = rt_exit(); len(exit_bytes) ... }
// len() returns a stale TAG_VALSTRUCT instead of TAG_INT; eventually
// valstruct_get_by_key is probed with a NULL key → strcmp(NULL) → SIGSEGV.
//
// Workaround for local smoke-test:
//     HEXA_VAL_ARENA=0 build/hexa_interp self/codegen/runtime_arm64.hexa
// Under this flag every Val is malloc'd and ALL CHECKS PASS cleanly.
//
// See doc/grammar.jsonl P40 for the full repro + fix-plan.
// Sibling class: P16 (argv()[N] NaN-box pointer corruption under arena ON).

// ── rt_exit ──────────────────────────────────────────────────
// exit(x0)  — x0 = exit code
// 4 instructions, 16 bytes

fn rt_exit() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // mov x16, #1 (SYS_exit)        0xD2800030
    c.push(48)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // (no epilogue — exit never returns)
    return c
}

// ── rt_print_str ─────────────────────────────────────────────
// print_str(x0=ptr, x1=len) — write(1, ptr, len) via SYS_write
// 9 instructions, 36 bytes

fn rt_print_str() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // mov x2, x1  (len -> x2)       0xAA0103E2
    c.push(226)
    c.push(3)
    c.push(1)
    c.push(170)
    // mov x1, x0  (buf -> x1)       0xAA0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(170)
    // mov x0, #1  (fd=stdout)       0xD2800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #4 (SYS_write)       0xD2800090
    c.push(144)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_println ───────────────────────────────────────────────
