    // mov w16, #24  (SYS_GETUID)     0x52800310
    c.push(16)
    c.push(3)
    c.push(128)
    c.push(82)
    // mov x0, #0   (no syscall arg)  0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret  (x0 = uid)                0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

