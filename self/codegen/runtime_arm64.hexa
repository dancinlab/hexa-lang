    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // sxtw x1, w1  (sign-extend newfd)      0x93407C21
    c.push(33)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #90  (SYS_DUP2)              0x52800B50
    c.push(80)
    c.push(11)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = newfd on success / -1)     0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

