// ── rt_select (B9.6-C14 — class-C syscall · 6-arg NON-_cf no-errno) ──────
// select(int nfds, void *r, void *w, void *e, void *t) -> int. A 6-arg svc
// WITHOUT the carry-flag / errno path (runtime.c uses the plain
// `_hxlcl_syscall6`, not the `_cf` variant). Only the FIRST arg (nfds, int, x0)
// is sign-extended; the four fd_set/timeval POINTERS (r/w/e/t, x1-x4) are
// already 64-bit and pass through untouched; the unused 6th syscall slot (x5)
// is zeroed. Then trap and ret — NO error branch, NO reloc. runtime.c L1572:
//   hxlcl_select(int nfds, void *r, void *w, void *e, void *t) { return (int)_hxlcl_syscall6(HXLCL_SYS_SELECT, (long)nfds, (long)r, (long)w, (long)e, (long)t, 0); }
// SYS_SELECT = 93 (0x5d). clang -O2 (== as -arch arm64) is byte-for-byte:
//   sxtw x0,w0 / mov x5,#0 / mov w16,#93 / svc #0x80 / ret  (no reloc)
// 5-instr 20 B body — the SAME length as rt_kill but a single-sxtw + an x5 zero
// (the literal 6th arg) instead of a dual-sxtw. The non-_cf distinction drops
// the entire errno tail.
fn rt_select() {
    let mut c = []
    // sxtw x0, w0  (sign-extend nfds)       0x93407C00
    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov x5, #0   (zero the unused 6th arg) 0xD2800005
    c.push(5)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov w16, #93  (SYS_SELECT)            0x52800BB0
    c.push(176)
    c.push(11)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret  (x0 = #ready / -1)               0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_poll (B9.6-C15 — class-C syscall · ptr+uint+int NON-_cf no-errno) ─
// poll(void *fds, unsigned int nfds, int timeout) -> int. A 3-arg svc WITHOUT
// the carry-flag / errno path (plain `_hxlcl_syscall3`). The FIRST arg (fds,
// ptr, x0) is already 64-bit and untouched; nfds (UNSIGNED int, x1) is
// ZERO-extended via `mov w1,w1` (the FIRST uxtw widening in the class-C set —
// every prior int arg was sign-extended via sxtw); timeout (int, x2) is
// sign-extended. Then trap and ret — NO error branch, NO reloc. runtime.c
// L1573:
//   hxlcl_poll(void *fds, unsigned int nfds, int timeout) { return (int)_hxlcl_syscall3(HXLCL_SYS_POLL, (long)fds, (long)nfds, (long)timeout); }
// SYS_POLL = 230 (0xe6). clang -O2 (== as -arch arm64) is byte-for-byte:
//   mov w1,w1 / sxtw x2,w2 / mov w16,#230 / svc #0x80 / ret  (no reloc)
// 5-instr 20 B body. `mov w1,w1` (0x2a0103e1) is the unsigned-int zero-extend:
// writing w1 clears the high 32 bits of x1, the correct widening for the
// unsigned nfds (vs the signed sxtw used for fd/int args elsewhere).
fn rt_poll() {
    let mut c = []
    // mov w1, w1   (zero-extend uint nfds)  0x2A0103E1
    c.push(225)
    c.push(3)
    c.push(1)
    c.push(42)
    // sxtw x2, w2  (sign-extend timeout)    0x93407C42
    c.push(66)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #230  (SYS_POLL)             0x52801CD0
    c.push(208)
    c.push(28)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret  (x0 = #ready / -1)               0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_waitpid (B9.6-C16 — class-C syscall · 4-arg _cf + errno) ──────────
// waitpid(int pid, int *status, int options) -> int. The FIRST 4-arg svc-_cf
// body — it extends the proven 3-arg _cf template (rt_lseek) by ONE more arg.
// runtime.c routes waitpid to the wait4(2) syscall with a NULL 4th arg
// (struct rusage*). The arg-widening: pid (int, x0) and options (int, x2) are
// each sign-extended; status (ptr, x1) is already 64-bit and untouched; the
// literal 4th arg (x3) is set to 0 via `mov x3,#0`. Then the full _cf errno
// tail. runtime.c L1579:
//   hxlcl_waitpid(int pid, int *status, int options) { return (int)_hxlcl_syscall4_cf(HXLCL_SYS_WAIT4, (long)pid, (long)status, (long)options, 0); }
// SYS_WAIT4 = 7. clang -O2 (== as -arch arm64, errno-define context):
//   sxtw x0,w0 / sxtw x2,w2 / mov x3,#0 / mov w16,#7 / svc #0x80 / cset x8,hs
//   / cbz x8,Lret / adrp x8,errno / str w0,[x8] / mov x0,#-1 / ret
// 11-instr 44 B body. errno reloc sites: 0x1c (PAGE21) / 0x20 (PAGEOFF12) —
// shifted +4 vs rt_lseek's dup2-offsets because of the extra `mov x3,#0`
// literal-arg instruction in the prologue.
fn rt_waitpid() {
    let mut c = []
    // sxtw x0, w0  (sign-extend pid)        0x93407C00
    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // sxtw x2, w2  (sign-extend options)    0x93407C42
    c.push(66)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov x3, #0   (NULL rusage 4th arg)    0xD2800003
    c.push(3)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov w16, #7  (SYS_WAIT4)              0x528000F0
    c.push(240)
    c.push(0)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = reaped pid / -1 error)     0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_waitpid — two errno records (adrp/str), shifted +4 vs
// rt_lseek because of the extra `mov x3,#0` literal-arg prologue instruction:
//   offset 0x1c (28) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x20 (32) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_waitpid_reloc_offs() {
