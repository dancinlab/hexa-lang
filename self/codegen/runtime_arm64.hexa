    // ── B9.6 / F3 class-D — struct-return x0:x1 signature checks ──
    // The defining feature vs every prior single-x0 leaf is that the
    // HIGH half of the 16-byte HexaVal is set in x1. We assert the
    // exact tag-half AND value-half instruction bytes per ctor.

    // rt_hexa_void: mov w0, #4 (tag=TAG_VOID) at offset 0
    //   0x52800080 → little-endian bytes 128, 0, 128, 82.
    if hvoid[0] != 128 || hvoid[1] != 0 || hvoid[2] != 128 || hvoid[3] != 82 {
