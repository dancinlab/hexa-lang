    c.push(66)
    c.push(4)
    c.push(0)
    c.push(209)
    // b tail_loop (-24 = -6 instrs)  0x17FFFFFA
    c.push(250)
    c.push(255)
    c.push(255)
    c.push(23)
    // eq:
    // mov x0, xzr  (return 0)        0xAA1F03E0
    c.push(224)
    c.push(3)
    c.push(31)
    c.push(170)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    // ne:
    // mov x0, #1   (return 1)        0xD2800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(210)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── NEON self-test ────────────────────────────────────────────

fn test_neon_string_ops() {
    let mcpy = rt_memcpy_neon()
    let slen = rt_strlen_neon()
    let mcmp = rt_memcmp_neon()

    println("")
    println("NEON SIMD string ops (ARM64)")
    println("  rt_memcpy_neon : " + to_string(len(mcpy)) + " bytes")
    println("  rt_strlen_neon : " + to_string(len(slen)) + " bytes")
    println("  rt_memcmp_neon : " + to_string(len(mcmp)) + " bytes")

    let mut ok = true

    // Non-empty
    if len(mcpy) == 0 { println("  FAIL: rt_memcpy_neon empty"); ok = false }
    if len(slen) == 0 { println("  FAIL: rt_strlen_neon empty"); ok = false }
    if len(mcmp) == 0 { println("  FAIL: rt_memcmp_neon empty"); ok = false }

    // < 256 bytes (per spec)
    if len(mcpy) >= 256 { println("  FAIL: rt_memcpy_neon too big"); ok = false }
    if len(slen) >= 256 { println("  FAIL: rt_strlen_neon too big"); ok = false }
    if len(mcmp) >= 256 { println("  FAIL: rt_memcmp_neon too big"); ok = false }

    // Expected exact byte counts (from validated assembly)
    if len(mcpy) != 60 { println("  FAIL: rt_memcpy_neon expected 60, got " + to_string(len(mcpy))); ok = false }
    if len(slen) != 68 { println("  FAIL: rt_strlen_neon expected 68, got " + to_string(len(slen))); ok = false }
    if len(mcmp) != 100 { println("  FAIL: rt_memcmp_neon expected 100, got " + to_string(len(mcmp))); ok = false }

    // 4-byte alignment (ARM64 fixed-width)
    if len(mcpy) % 4 != 0 { println("  FAIL: rt_memcpy_neon not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_strlen_neon not aligned"); ok = false }
    if len(mcmp) % 4 != 0 { println("  FAIL: rt_memcmp_neon not aligned"); ok = false }

    // RET trailer check (last 4 bytes = 192, 3, 95, 214 = 0xD65F03C0)
    let nc = len(mcpy)
    if mcpy[nc - 4] != 192 { println("  FAIL: rt_memcpy_neon no RET"); ok = false }
    if mcpy[nc - 1] != 214 { println("  FAIL: rt_memcpy_neon RET byte3"); ok = false }
    let nl = len(slen)
    if slen[nl - 4] != 192 { println("  FAIL: rt_strlen_neon no RET"); ok = false }
    if slen[nl - 1] != 214 { println("  FAIL: rt_strlen_neon RET byte3"); ok = false }
    let nm = len(mcmp)
    if mcmp[nm - 4] != 192 { println("  FAIL: rt_memcmp_neon no RET"); ok = false }
    if mcmp[nm - 1] != 214 { println("  FAIL: rt_memcmp_neon RET byte3"); ok = false }

    // Verify first LD1 instruction in memcpy is at offset 16 (after 4-instr prologue)
    // Expected bytes: 32, 112, 223, 76 (0x4CDF7020 little-endian)
    if mcpy[16] != 32 { println("  FAIL: rt_memcpy_neon LD1 byte0 != 32"); ok = false }
    if mcpy[17] != 112 { println("  FAIL: rt_memcpy_neon LD1 byte1 != 112"); ok = false }
    if mcpy[18] != 223 { println("  FAIL: rt_memcpy_neon LD1 byte2 != 223"); ok = false }
    if mcpy[19] != 76 { println("  FAIL: rt_memcpy_neon LD1 byte3 != 76"); ok = false }

    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ═══════════════════════════════════════════════════════════════
// Arena bump allocator (HX5: AI-native algorithm replacement)
// ═══════════════════════════════════════════════════════════════
// AI-native vector — arena bump allocator (docs/ai-native.md).
//
// Motivation: ML workloads allocate many tensors then free all at once.
// libc malloc pays 10-50x overhead per call (free-list walk, coalesce,
// metadata, fragmentation). A bump allocator trades per-object free
// for O(1) alloc and bulk reset, which is exactly the shape of tensor
// allocation in a forward/backward pass.
//
// Layout:
//   arena_state (24 bytes, shared across the 4 fns below):
//     [ 0] base : pointer to mmap'd region (set by init, cleared by release)
//     [ 8] ptr  : next free byte (bump pointer; reset() sets ptr = base)
//     [16] end  : base + size (mmap'd limit)
//
// State access convention (PR #1297 residual #2 — widened to adrp+add):
//   Each fn emits an `adrp x9, _arena_state@PAGE` + `add x9, x9,
//   _arena_state@PAGEOFF` pair (8 bytes) as a placeholder — the linker
//   (`tool/hexa_ld.hexa` PR #1282 + `macho_obj_wrap_v2` PR #1302) emits
//   matching ARM64_RELOC_PAGE21 (kind=3) + ARM64_RELOC_PAGEOFF12
//   (kind=4) records at the same byte offsets, patching the adrp page
//   immediate (immhi:immlo) + add unscaled imm12 so x9 lands on the
//   absolute VM address of the shared `_arena_state` blob in __const.
//   This supersedes the prior single `adr x9, #0` (4 B) placeholder
//   which had no matching reloc kind in the v1 wrap. Each fn stays
//   self-contained for byte-count testing while all 4 share one state
//   region.
//
// macOS ARM64 syscall ABI:
//   SYS_mmap  = 197  (x0=addr, x1=len, x2=prot, x3=flags, x4=fd, x5=off)
//   SYS_munmap = 73  (x0=addr, x1=len)
//   All syscalls use svc #0x80, return value in x0.

// ── rt_arena_init ────────────────────────────────────────────
// arena_init(x0=size_mb) — mmap(size_mb << 20) anonymous RW region.
// Stores base/ptr/end into the shared arena_state.
// 19 instructions, 76 bytes (was 72; +4 B from adr→adrp+add widening
// per PR #1297 residual #2).
//
// macOS svc #0x80 (mmap) CLOBBERS the syscall-arg registers on return
// (x0 = base, x1 = 0). The size (x1 = size_mb << 20) must therefore be
// preserved across the svc into a register the kernel does NOT touch —
// empirically x6..x15 all survive the macOS mmap svc (verified by a
// standalone svc probe). We save the size into x6 BEFORE the syscall and
// use x6 (not the clobbered x1) in the post-svc `add x10, x0, x6`
// (end = base + size). Computing `end` from the stale x1 yielded
// end == base → zero-capacity arena → every arena_alloc failed its bound
// check and returned NULL.

fn rt_arena_init() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // lsl x1, x0, #20  (MB -> bytes) 0xD36CAC01
    c.push(1)
    c.push(172)
    c.push(108)
    c.push(211)
    // mov x6, x1  (save size; svc clobbers x1)  0xAA0103E6
    c.push(230)
    c.push(3)
    c.push(1)
    c.push(170)
    // mov x0, #0  (addr=NULL)        0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x2, #3  (PROT_RW)          0xD2800062
    c.push(98)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x3, #0x1002 (MAP_ANON|PRIV)0xD2820043
    c.push(67)
    c.push(0)
    c.push(130)
    c.push(210)
    // movn x4, #0 (fd=-1)            0x92800004
    c.push(4)
    c.push(0)
    c.push(128)
    c.push(146)
    // mov x5, #0  (offset=0)         0xD2800005
    c.push(5)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #197 (SYS_mmap)       0xD28018B0
    c.push(176)
    c.push(24)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // str x0, [x9]       (state.base = x0)          0xF9000120
    c.push(32)
    c.push(1)
    c.push(0)
    c.push(249)
    // str x0, [x9, #8]   (state.ptr  = x0)          0xF9000520
    c.push(32)
    c.push(5)
    c.push(0)
    c.push(249)
    // add x10, x0, x6    (x10 = base + saved size)   0x8B06000A
    c.push(10)
    c.push(0)
    c.push(6)
    c.push(139)
    // str x10, [x9, #16] (state.end = base+size)    0xF900092A
    c.push(42)
    c.push(9)
    c.push(0)
    c.push(249)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_arena_alloc ───────────────────────────────────────────
// arena_alloc(x0=size) — bump ptr by size, return OLD ptr.
// Returns 0 (NULL) on overflow (new_ptr > state.end).
// Leaf function: no prologue (saves 2 instructions vs rt_alloc).
//
// Hot-path cost (overflow-free):
//   2 loads + 1 add + 1 cmp + 1 branch + 1 store + 1 mov + ret = 7 ops
//
// 12 instructions, 48 bytes (was 44; +4 B from adr→adrp+add widening
// per PR #1297 residual #2). Still < 64 — hot-path spec preserved.

fn rt_arena_alloc() {
    let mut c = []
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x1, [x9, #8]   (x1 = state.ptr = old)     0xF9400521
    c.push(33)
    c.push(5)
    c.push(64)
    c.push(249)
    // add x2, x1, x0     (x2 = new_ptr)             0x8B000022
    c.push(34)
    c.push(0)
    c.push(0)
    c.push(139)
    // ldr x3, [x9, #16]  (x3 = state.end)           0xF9400923
    c.push(35)
    c.push(9)
    c.push(64)
    c.push(249)
    // cmp x2, x3                                     0xEB03005F
    c.push(95)
    c.push(0)
    c.push(3)
    c.push(235)
    // b.hi +2 (to oom)                               0x54000088
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(84)
    // str x2, [x9, #8]   (state.ptr = new_ptr)      0xF9000522
    c.push(34)
    c.push(5)
    c.push(0)
    c.push(249)
    // mov x0, x1         (return old_ptr)           0xAA0103E0
    c.push(224)
    c.push(3)
    c.push(1)
    c.push(170)
    // ret                                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    // oom: mov x0, #0  (return NULL on overflow)    0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // ret                                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_arena_reset ───────────────────────────────────────────
// arena_reset() — state.ptr = state.base (bulk free).
// The mmap'd region is kept for subsequent allocations.
// 5 instructions, 20 bytes (was 16; +4 B from adr→adrp+add widening
// per PR #1297 residual #2).

fn rt_arena_reset() {
    let mut c = []
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x0, [x9]       (x0 = state.base)          0xF9400120
    c.push(32)
    c.push(1)
    c.push(64)
    c.push(249)
    // str x0, [x9, #8]   (state.ptr = base)         0xF9000520
    c.push(32)
    c.push(5)
    c.push(0)
    c.push(249)
    // ret                                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_arena_release ─────────────────────────────────────────
// arena_release() — munmap(base, end-base); zero state.
// Called at process teardown or when shrinking memory pressure.
// 17 instructions, 68 bytes (was 60; +8 B from TWO adr→adrp+add
// widenings per PR #1297 residual #2 — one before munmap, one after).

fn rt_arena_release() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x0, [x9]       (x0 = state.base)          0xF9400120
    c.push(32)
    c.push(1)
    c.push(64)
    c.push(249)
    // ldr x1, [x9, #16]  (x1 = state.end)           0xF9400921
    c.push(33)
    c.push(9)
    c.push(64)
    c.push(249)
    // sub x1, x1, x0     (x1 = size = end-base)     0xCB000021
    c.push(33)
    c.push(0)
    c.push(0)
    c.push(203)
    // mov x16, #73 (SYS_munmap)                     0xD2800930
    c.push(48)
    c.push(9)
    c.push(128)
    c.push(210)
    // svc #0x80                                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // mov x10, #0                                    0xD280000A
    c.push(10)
    c.push(0)
    c.push(128)
    c.push(210)
    // str x10, [x9]      (state.base = 0)           0xF900012A
    c.push(42)
    c.push(1)
    c.push(0)
    c.push(249)
    // str x10, [x9, #8]  (state.ptr = 0)            0xF900052A
    c.push(42)
    c.push(5)
    c.push(0)
    c.push(249)
    // str x10, [x9, #16] (state.end = 0)            0xF900092A
    c.push(42)
    c.push(9)
    c.push(0)
    c.push(249)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── HexaVal struct-return constructors (B9.6 / F3 class-D) ────
//
// FIRST class-D increment: the runtime's universal value constructors
// (hexa_int / hexa_bool / hexa_void at runtime_core.c:1281-1284) each
// return a 16-byte `HexaVal` tagged-union BY VALUE. On AAPCS arm64 a
// ≤16-byte aggregate is returned in the x0:x1 register PAIR (NRRP — no
// hidden x8 indirect-result pointer). Every prior self-emit leaf in
// this file returns a single x0 scalar; THESE are the first emitters
// of the x0:x1 struct-return sequence — the infra that unblocks the
// ~350-450 HexaVal-producing class-D primitives.
//
// ── HexaVal layout (self/runtime.h:79-92, sizeof 16) ──
//   struct { HexaTag tag; union { int64_t i; double f; int b; char* s; ... }; }
//   offset 0..8  : tag        (HexaTag enum; low 32 bits = tag value)
//   offset 8..16 : union value
// Returned as: x0 = low 8 bytes (tag), x1 = high 8 bytes (union value).
//
// ── HexaTag enum values (self/runtime.h:39-52) ──
//   TAG_INT=0  TAG_FLOAT=1  TAG_BOOL=2  TAG_STR=3  TAG_VOID=4  ...
//
// The exact x0:x1 sequences below were VERIFIED against clang -O2 -S of
// the actual runtime_core.c ctors and assembled with `as -arch arm64`
// (byte encodings confirmed via otool). Each is a 3-instruction leaf
// (no prologue — pure register moves + ret); no stack, no relocation,
// no arena state. The ONLY new ABI vs prior leaves is that x1 is set
// (the struct high half) in addition to x0.

// ── rt_hexa_void ─────────────────────────────────────────────
// hexa_void() -> HexaVal{tag=TAG_VOID(4)}. Simplest class-D ctor:
// zero args, both halves are compile-time constants.
//   clang -O2 -S:  mov w0, #4 ; mov x1, #0 ; ret
//   x0 = 4 (TAG_VOID, tag half) · x1 = 0 (union half, unused/zero)
// 3 instructions, 12 bytes.
fn rt_hexa_void() {
    let mut c = []
    // mov w0, #4   (tag = TAG_VOID)   0x52800080
    c.push(128)
    c.push(0)
    c.push(128)
    c.push(82)
    // mov x1, #0   (union half = 0)   0xD2800001
    c.push(1)
    c.push(0)
    c.push(128)
    c.push(210)
    // ret                             0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_hexa_int ──────────────────────────────────────────────
// hexa_int(int64_t n) -> HexaVal{tag=TAG_INT(0), .i=n}. The int arg
// arrives in x0; the result needs tag(=0) in x0 and the value in x1.
//   clang -O2 -S:  mov x1, x0 ; mov x0, #0 ; ret
//   x1 = n (union half = .i) · x0 = 0 (TAG_INT, tag half)
// Order matters: x1<-x0 BEFORE x0<-#0 (else the arg is clobbered).
// 3 instructions, 12 bytes.
fn rt_hexa_int() {
    let mut c = []
    // mov x1, x0   (union half = n)   0xAA0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(170)
    // mov x0, #0   (tag = TAG_INT)    0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // ret                             0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_hexa_bool ─────────────────────────────────────────────
// hexa_bool(int b) -> HexaVal{tag=TAG_BOOL(2), .b=b}. The int arg
// arrives in w0; the result needs tag(=2) in x0 and the value in x1.
//   clang -O2 -S:  mov w1, w0 ; mov w0, #2 ; ret
//   x1 = b (union half = .b, 32-bit move zero-extends) · x0 = 2 (TAG_BOOL)
// Order matters: w1<-w0 BEFORE w0<-#2 (else the arg is clobbered).
// 3 instructions, 12 bytes.
fn rt_hexa_bool() {
    let mut c = []
    // mov w1, w0   (union half = b)   0x2A0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(42)
    // mov w0, #2   (tag = TAG_BOOL)   0x52800040
    c.push(64)
    c.push(0)
    c.push(128)
    c.push(82)
    // ret                             0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_hexa_float (B9.6-D2 scale-out) ────────────────────────
// hexa_float(double f) -> HexaVal{tag=TAG_FLOAT(1), .f=f}. The double
// arg arrives in d0 (FP register, AAPCS NGRN/NSRN); the result needs
// tag(=1) in x0 and the raw 64-bit double bit-pattern in x1.
//   clang -O2 -S:  fmov x1, d0 ; mov w0, #1 ; ret
//   x1 = bitcast<int64>(f) (union half = .f) · x0 = 1 (TAG_FLOAT)
// FIRST self-emit leaf to read an FP arg — the `fmov x1, d0` GP<-FP
// move (0x9E660001) is the only new instruction vs the int ctors;
// it copies the d0 double bits verbatim into x1 (no conversion).
// Order matters: x1<-d0 BEFORE x0<-#1 (x0 untouched by fmov, but the
// clang ordering is preserved for byte-identity).
// 3 instructions, 12 bytes.
fn rt_hexa_float() {
    let mut c = []
    // fmov x1, d0  (union half = raw f bits)  0x9E660001
    c.push(1)
    c.push(0)
    c.push(102)
    c.push(158)
    // mov w0, #1   (tag = TAG_FLOAT)          0x52800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(82)
    // ret                                     0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_hexa_enum_str (B9.6-D2 scale-out) ─────────────────────
// hexa_enum_str(const char* display) -> HexaVal{tag=TAG_ENUM(11),
// .s=display}. The pointer arg arrives in x0; the result needs
// tag(=11) in x0 and the pointer verbatim in x1. NO malloc — the
// caller-owned read-only literal pointer is stored as-is (matches the
// runtime no-free contract). Same shape as rt_hexa_int, tag=11 vs 0.
//   clang -O2 -S:  mov x1, x0 ; mov w0, #11 ; ret
//   x1 = display (union half = .s) · x0 = 11 (TAG_ENUM)
// Order matters: x1<-x0 BEFORE x0<-#11 (else the arg is clobbered).
// 3 instructions, 12 bytes.
fn rt_hexa_enum_str() {
    let mut c = []
    // mov x1, x0   (union half = display ptr) 0xAA0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(170)
    // mov w0, #11  (tag = TAG_ENUM)           0x52800160
    c.push(96)
    c.push(1)
    c.push(128)
    c.push(82)
    // ret                                     0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_hexa_enum_str_v (B9.6-D2 scale-out) ───────────────────
// hexa_enum_str_v(const HexaEnumDesc* desc) -> HexaVal{tag=TAG_ENUM(11),
// .s=(char*)desc}. The descriptor-pointer arg arrives in x0; identical
// machine code to rt_hexa_enum_str (a pointer-store ctor — the C type
// differs, the ABI is byte-identical). NO malloc.
//   clang -O2 -S:  mov x1, x0 ; mov w0, #11 ; ret
//   x1 = desc (union half = .s) · x0 = 11 (TAG_ENUM)
// 3 instructions, 12 bytes — byte-identical to rt_hexa_enum_str.
fn rt_hexa_enum_str_v() {
    let mut c = []
    // mov x1, x0   (union half = desc ptr)    0xAA0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(170)
    // mov w0, #11  (tag = TAG_ENUM)           0x52800160
    c.push(96)
    c.push(1)
    c.push(128)
    c.push(82)
    // ret                                     0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_getpid (B9.6-C1 — class-C syscall ABI FIRST self-emit) ────
// getpid() -> int. The FIRST class-C (syscall-ABI) self-emit leaf:
// it issues a raw `svc #0x80` BSD syscall instead of computing a
// value in registers (class-A/D) or looping over memory (the leaf
// family). This opens the ~190-fn layer-② `hxlcl_*` svc-wrapper
// subtrack per the #1812 audit.
//
// macOS arm64 BSD syscall ABI: the syscall number goes in x16, args
// in x0.., then `svc #0x80`; the result returns in x0. getpid is
// SYS_GETPID = 20. It takes NO arguments and CANNOT fail (no errno /
// carry-flag path — like getuid), so the plain (non-_cf) trap is
// exact: just load nr, zero x0, trap, return.
//
// This mirrors self/runtime.c L1247
//   hxlcl_getpid(void) { return (int)_hxlcl_syscall1(HXLCL_SYS_GETPID, 0); }
// whose clang -O2 -S (== `as -arch arm64`) is byte-for-byte:
//   mov w16, #20 ; mov x0, #0 ; svc #0x80 ; ret
// (clang picks the 32-bit `mov w16` MOVZ form for the small immediate.)
//
// Unlike rt_exit (which never returns, so has no epilogue and no
// well-defined return value), getpid RETURNS the pid in x0 — making
// it JIT-exec-checkable: a C driver calling the linked _hxlcl_getpid
// must get the same value as libc getpid(). That return path is what
// makes it the right FIRST class-C activation candidate.
//
// 4 instructions, 16 bytes.
fn rt_getpid() {
    let mut c = []
    // mov w16, #20  (SYS_GETPID)     0x52800290
    c.push(144)
    c.push(2)
    c.push(128)
    c.push(82)
    // mov x0, #0   (no syscall arg)  0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret  (x0 = pid)                0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_close (B9.6-C2 — class-C syscall WITH arg + errno/carry-flag) ──
// close(int fd) -> int. The SECOND class-C (syscall-ABI) self-emit, and
// the FIRST that carries (a) a real syscall ARGUMENT and (b) the Darwin
// CARRY-FLAG error convention + errno store. #1860's rt_getpid was a
// 0-arg / cannot-fail leaf (plain trap, no carry path); this increment
// builds the multi-arg + `_cf` (carry-flag) errno template that the
// remaining ~190 `hxlcl_*` svc-wrappers (#1812 audit) need to scale out.
//
// macOS arm64 BSD syscall ABI (error path): the syscall number goes in
// x16, args in x0.., then `svc #0x80`. On SUCCESS the carry flag (C bit
// of NZCV) is CLEAR and x0 holds the result; on ERROR the carry is SET
// and x0 holds the POSITIVE errno. The wrapper captures the carry with
// `cset x8, hs`, and on carry stores x0 into `errno` and returns -1.
// SYS_CLOSE = 6, one arg (fd).
//
// This mirrors self/runtime.c L1255
//   hxlcl_close(int fd) { return (int)_hxlcl_syscall1_cf(HXLCL_SYS_CLOSE, fd); }
// whose clang -O2 (== `as -arch arm64`) is byte-for-byte (9 instr, 36 B):
//   sxtw x0,w0 / mov w16,#6 / svc #0x80 / cset x8,hs / cbz x8,Lret
//   / adrp x8,errno@PAGE / str w0,[x8,errno@PAGEOFF] / mov x0,#-1 / ret
//
// ⚠ RELOC + REGISTER-CLOBBER FINDING (load-bearing — see byte-diff doc):
// the errno store is `adrp x8,errno ; str w0,[x8]` — x8 is RE-derived
// PC-relatively AFTER the svc, NOT a caller-passed pointer register. This
// is REQUIRED, not stylistic: the Darwin `close` svc CLOBBERS the arg
// registers on the error path (probe: x1 → 0x0 after a failing close),
// so a register-passed errno destination would `str` through a clobbered
// pointer and segfault. The errno destination must be a fixed DATA SYMBOL
// reached via adrp/str, which means the emitted .o needs TWO relocations:
//   - ARM64_RELOC_PAGE21   (kind 3, pcrel) at code offset 0x14 (the adrp)
//   - ARM64_RELOC_PAGEOFF12 (kind 4)       at code offset 0x18 (the str)
// both targeting the `errno` (hxlcl_errno) data symbol. rt_close_reloc_offs
// / rt_close_reloc_kinds below expose that table for the macho_obj_wrap_v2
// reloc path (the same machinery the rt_arena_* state-relative primitives
// use). Full production Path-A activation against runtime.c's SHARED
// `hxlcl_errno` additionally needs UNDEFINED-external-symbol reloc support
// (v2 today resolves a SELF-DEFINED __const symbol); that is the remaining
// ~190-layer wiring step — see RUNTIME.floor.md F3.
//
// 9 instructions, 36 bytes. The adrp (offset 0x14) and str (0x18) words
// carry a ZEROED immediate pre-relocation, exactly as `as -arch arm64`
// emits before the linker patches them.
fn rt_close() {
    let mut c = []
    // sxtw x0, w0  (sign-extend fd arg)     0x93407C00
    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #6  (SYS_CLOSE)              0x528000D0
    c.push(208)
    c.push(0)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = 0 on success / -1 error)   0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_close — the two records the errno `adrp`/`str` need
// when wrapped into a Mach-O .o via macho_obj_wrap_v2. Parallel arrays:
// reloc applies at the given __text byte offset with the given kind.
//   offset 0x14 (20) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x18 (24) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_close_reloc_offs() {
    let mut o = []
    o.push(20)
    o.push(24)
    return o
}
fn rt_close_reloc_kinds() {
    let mut k = []
    k.push(3)
    k.push(4)
    return k
}

// ── rt_atoi (B9.6-B1 — class-B calling-convention composite · FIRST BL) ──
// int atoi(const char *s) -> (int)atoll(s). The FIRST class-B (call-bound
// composite) self-emit: the self-emit catalog gains its first function that
// CALLS another function via `bl` with a real STACK FRAME. Every prior
// activation was a LEAF (rt_getpid/rt_close issue a svc but never `bl`; the
// 16 string/mem leaves and the HexaVal ctors are all single-frame register/
// memory bodies). hxlcl_atoi is the simplest composite in self/runtime.c:
// one tail-call to hxlcl_atoll, the `(int)` truncation folded into the w0
// half of x0 (free), no other work.
//
// macOS arm64 AAPCS calling convention (the class-B essence): a non-leaf
// must SPILL the link register x30 (and frame pointer x29) before the `bl`,
// because `bl` overwrites x30 with the return address. Without the frame the
// callee returns into the composite, whose own `ret` then jumps back to its
// own `bl`/`ret` -> INFINITE LOOP (empirically reproduced with a frameless
// PoC: the binary spins, rc=124 under timeout). The frame is the load-bearing
// difference between a leaf and a composite.
//
// This mirrors self/runtime.c L298
//   static int hxlcl_atoi(const char *s) { return (int)hxlcl_atoll(s); }
// whose clang -O2 (== `as -arch arm64`) is byte-for-byte (5 instr, 20 B):
//   stp x29,x30,[sp,#-16]! / mov x29,sp / bl _hxlcl_atoll
//   / ldp x29,x30,[sp],#16 / ret
//
// ⚠ BRANCH26 + CALLEE-EXPORT FINDING (load-bearing — see byte-diff doc):
// the `bl _hxlcl_atoll` (offset 0x08) carries a ZEROED 26-bit displacement
// pre-relocation; the emitted .o needs ONE relocation:
//   - ARM64_RELOC_BRANCH26 (kind 2, pcrel) at code offset 0x08, targeting the
//     UNDEFINED-external symbol `_hxlcl_atoll`.
// This is the FIRST cross-object-CALL reloc in F3 activation (class-A/C used
// PAGE21/PAGEOFF12 data relocs against a DEFINED symbol; this is a code reloc
// against an UNDEFINED one). The link test (clang composite.o callee.o main.c)
// SUCCEEDS with LC_SYMTAB ONLY — NO LC_DYSYMTAB required (the macho.hexa
// "link-test pending" caveat from #1475 is hereby RESOLVED for BRANCH26).
// For production Path-A activation against runtime.c, the BL TARGET
// (hxlcl_atoll) must ALSO be exported (non-static under the guard) so ld64
// can bind the BRANCH26 reloc to it — a class-B-specific wrinkle the leaf and
// data-reloc tracks never hit (their override slot was a single symbol).
//
// 5 instructions, 20 bytes. The bl (offset 0x08) word carries a zeroed
// immediate pre-relocation, exactly as `as -arch arm64` emits.
fn rt_atoi() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!  (prologue spill)   0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                                   0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // bl _hxlcl_atoll  [RELOC BRANCH26]             0x94000000  (imm zeroed)
    c.push(0)
    c.push(0)
    c.push(0)
    c.push(148)
    // ldp x29, x30, [sp], #16    (epilogue reload)  0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret  (w0 = (int)atoll result)                 0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_atoi — the one BRANCH26 record the `bl` needs when
// wrapped into a Mach-O .o via macho_obj_wrap_v3. The reloc applies at the
// __text byte offset (0x08, the bl) with kind 2 (ARM64_RELOC_BRANCH26),
// targeting an UNDEFINED-external symbol (sym_section == 0) = the callee.
//   offset 0x08 (8) → ARM64_RELOC_BRANCH26 (kind 2, pcrel bl)
fn rt_atoi_reloc_offs() {
    let mut o = []
    o.push(8)
    return o
}
fn rt_atoi_reloc_kinds() {
    let mut k = []
    k.push(2)
    return k
}

// ── rt_munmap (B9.6-E1 · class-E memory-lifecycle FIRST LIVE wire) ─────
//
// FIRST class-E increment that is actually WIRED into the live runtime
// (the rt_arena_* set #1252/#1297/#1315 emits an arena .o but the runtime
// never calls those symbols — they are shadow-only). class-E = the
// GC/arena/malloc memory-management core. This runtime has NO classic
// mark/sweep GC: reclamation is scope-pop + bulk arena-reset, and the
// deallocation primitives (`hxlcl_free` / `hxlcl_munmap`) are no-op /
// constant-return leaves over the mmap-backed bump allocator. That bump
// allocator IS the irreducible "some allocator seed" B9.8 flagged.
//
// rt_munmap is the unmap/dealloc SIDE of class-E — the simplest tractable,
// JIT-verifiable, named-external memory-lifecycle primitive:
//   self/runtime.c L902 `hxlcl_munmap(void*, size_t) { (void)addr;(void)length; return 0; }`
// The bump allocator never frees, so unmap is a constant-0 success stub
// (live call sites = mmap-file cleanup, runtime.c L7438/L7609).
//   clang -O2 -S:  mov w0, #0 ; ret   (int return → 32-bit MOVZ)
//   x0 = 0 (success) · no frame, no reloc, no svc, no arena state.
// 2 instructions, 8 bytes. The byte shape reuses the proven class-D leaf
// capability (mov w0,#imm + ret); the NEW thing is class-E live-wiring,
// not a new instruction. The JIT-exec gate proves the unmap stub returns 0
// AND the runtime's mmap-file cleanup path still works once it binds to the
// self-emitted symbol.
fn rt_munmap() {
    let mut c = []
    // mov w0, #0   (return 0 = success)   0x52800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(82)
    // ret                                 0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_getuid (B9.6-C3 — class-C syscall ABI · 0-arg no-errno) ───────
// getuid() -> int. SECOND 0-arg / cannot-fail svc-trap (after rt_getpid),
// scaling out the no-errno base template. runtime.c L1396 says it verbatim:
//   hxlcl_getuid(void) { return (int)_hxlcl_syscall1(HXLCL_SYS_GETUID, 0); }
// SYS_GETUID = 24. Byte shape is the EXACT rt_getpid sequence with only the
// `mov w16` immediate changed (#20 -> #24):
//   mov w16,#24 / mov x0,#0 / svc #0x80 / ret  (4 instr, 16 B, no reloc)
// clang -O2 (== as -arch arm64) of the runtime.c body is byte-for-byte this.
// Like getpid it RETURNS a real value (the uid) so it is JIT-exec-checkable
// against libc getuid(). No carry-flag / errno path (BSD getuid cannot fail).
fn rt_getuid() {
    let mut c = []
    // mov w16, #24  (SYS_GETUID)     0x52800310
    c.push(16)
    c.push(3)
    c.push(128)
    c.push(82)
    // mov x0, #0   (no syscall arg)  0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret  (x0 = uid)                0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_dup2 (B9.6-C4 — class-C syscall · 2-arg _cf + errno) ──────────
// dup2(int oldfd, int newfd) -> int. The FIRST 2-arg svc-_cf self-emit,
// extending the rt_close 1-arg carry-flag template by ONE instruction (a
// second `sxtw x1,w1` for the newfd arg). runtime.c L1417:
//   hxlcl_dup2(int oldfd, int newfd) { return (int)_hxlcl_syscall2_cf(HXLCL_SYS_DUP2, ...); }
// SYS_DUP2 = 90. clang -O2 (== as -arch arm64, in runtime.c's `#define errno
// hxlcl_errno` context) is byte-for-byte (10 instr, 40 B):
//   sxtw x0,w0 / sxtw x1,w1 / mov w16,#90 / svc #0x80 / cset x8,hs
//   / cbz x8,Lret / adrp x8,errno / str w0,[x8] / mov x0,#-1 / ret
// Both args are int → both sign-extended. The extra sxtw shifts every later
// instruction +4: the cbz still skips 4 instr (adrp/str/mov-1 to ret), and
// the errno reloc sites move to 0x18 (PAGE21) / 0x1c (PAGEOFF12) vs close's
// 0x14 / 0x18. The errno store is PC-relative (adrp/str) AFTER the svc, NOT a
// caller register — the dup2 svc clobbers arg regs on the error path, exactly
// the class-C-with-errno finding proven for rt_close.
fn rt_dup2() {
    let mut c = []
    // sxtw x0, w0  (sign-extend oldfd)      0x93407C00
    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // sxtw x1, w1  (sign-extend newfd)      0x93407C21
    c.push(33)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #90  (SYS_DUP2)              0x52800B50
    c.push(80)
    c.push(11)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = newfd on success / -1)     0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_dup2 — two errno records (adrp/str), shifted +4 vs
// rt_close because of the extra sxtw x1,w1 prologue instruction:
//   offset 0x18 (24) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x1c (28) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_dup2_reloc_offs() {
    let mut o = []
    o.push(24)
    o.push(28)
    return o
}
fn rt_dup2_reloc_kinds() {
    let mut k = []
    k.push(3)
    k.push(4)
    return k
}

// ── rt_mkdir (B9.6-C5 — class-C syscall · ptr+int _cf + errno) ───────
// mkdir(const char *path, int mode) -> int. A 2-arg svc-_cf with a POINTER
// first arg + an int second arg — so only the int (mode, x1) is sign-extended
// and x0 (the already-64-bit path pointer) passes through untouched. runtime.c
// L1302:
//   hxlcl_mkdir(const char *path, int mode) { return (int)_hxlcl_syscall2_cf(HXLCL_SYS_MKDIR, ...); }
// SYS_MKDIR = 136. clang -O2 (== as -arch arm64, errno-define context) is
// byte-for-byte (9 instr, 36 B — same length as rt_close, only the SINGLE
// sxtw targets x1 not x0):
//   sxtw x1,w1 / mov w16,#136 / svc #0x80 / cset x8,hs / cbz x8,Lret
//   / adrp x8,errno / str w0,[x8] / mov x0,#-1 / ret
// errno reloc sites: 0x14 (PAGE21) / 0x18 (PAGEOFF12) — same as rt_close
// (the body is the same length; only the sxtw register and SYS number differ).
fn rt_mkdir() {
    let mut c = []
    // sxtw x1, w1  (sign-extend mode arg)   0x93407C21
    c.push(33)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #136  (SYS_MKDIR)            0x52801110
    c.push(16)
    c.push(17)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = 0 on success / -1 error)   0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_mkdir — two errno records (adrp/str), same offsets as
// rt_close (9-instr body of identical length):
//   offset 0x14 (20) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x18 (24) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_mkdir_reloc_offs() {
    let mut o = []
    o.push(20)
    o.push(24)
    return o
}
fn rt_mkdir_reloc_kinds() {
    let mut k = []
    k.push(3)
    k.push(4)
    return k
}

// ── rt_fstat (B9.6-C6 — class-C syscall · int+ptr _cf + errno) ───────
// fstat(int fd, void *buf) -> int. A 2-arg svc-_cf where the FIRST arg is an
// int (fd, x0 sign-extended) and the SECOND is a pointer (buf, x1 untouched) —
// the mirror image of rt_mkdir (which signs the 2nd arg). 9-instr 36 B body,
// identical length to mkdir; only the sxtw target register (x0 here vs x1) and
// the SYS number differ. runtime.c L1550:
//   hxlcl_fstat(int fd, void *buf) { return (int)_hxlcl_syscall2_cf(HXLCL_SYS_FSTAT, ...); }
// SYS_FSTAT = 339 (0x153) — note the syscall number exceeds 255, exercising
// the full 16-bit `mov w16` immediate (0x52802a70) for the first time in the
// class-C set (prior numbers ≤ 136 fit a narrower encoding nibble). clang -O2
// (== as -arch arm64, errno-define context) is byte-for-byte:
//   sxtw x0,w0 / mov w16,#339 / svc #0x80 / cset x8,hs / cbz x8,Lret
//   / adrp x8,errno / str w0,[x8] / mov x0,#-1 / ret
// errno reloc sites: 0x14 (PAGE21) / 0x18 (PAGEOFF12) — same as rt_mkdir
// (the body is the same length; only the sxtw register and SYS number differ).
fn rt_fstat() {
    let mut c = []
    // sxtw x0, w0  (sign-extend fd arg)     0x93407C00
    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #339  (SYS_FSTAT)            0x52802A70
    c.push(112)
    c.push(42)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = 0 on success / -1 error)   0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_fstat — two errno records (adrp/str), same offsets as
// rt_mkdir (9-instr body of identical length):
//   offset 0x14 (20) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x18 (24) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_fstat_reloc_offs() {
    let mut o = []
    o.push(20)
    o.push(24)
    return o
}
fn rt_fstat_reloc_kinds() {
    let mut k = []
    k.push(3)
    k.push(4)
    return k
}

// ── rt_stat (B9.6-C7 — class-C syscall · ptr+ptr _cf + errno) ────────
// stat(const char *path, void *buf) -> int. A 2-arg svc-_cf where BOTH args
// are pointers (path x0, buf x1) — so NEITHER is sign-extended. This is the
// FIRST NO-SXTW 2-arg svc body: the prologue drops straight to `mov w16` with
// no register-widening at all (the args are already 64-bit). 8-instr 32 B body
// (4 bytes shorter than mkdir/fstat — exactly the one dropped sxtw). runtime.c
// L1552:
//   hxlcl_stat(const char *path, void *buf) { return (int)_hxlcl_syscall2_cf(HXLCL_SYS_STAT, ...); }
// SYS_STAT = 338 (0x152). clang -O2 (== as -arch arm64, errno-define context):
//   mov w16,#338 / svc #0x80 / cset x8,hs / cbz x8,Lret / adrp x8,errno
//   / str w0,[x8] / mov x0,#-1 / ret
// Because the body starts 4 bytes earlier (no sxtw), the errno reloc sites
// shift down by 4 vs mkdir: 0x10 (PAGE21) / 0x14 (PAGEOFF12).
fn rt_stat() {
    let mut c = []
    // mov w16, #338  (SYS_STAT)             0x52802A50
    c.push(80)
    c.push(42)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return)           0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = 0 on success / -1 error)   0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_stat — two errno records (adrp/str), shifted DOWN by 4
// vs rt_mkdir because the NO-SXTW prologue removes one leading instruction:
//   offset 0x10 (16) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x14 (20) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_stat_reloc_offs() {
    let mut o = []
    o.push(16)
    o.push(20)
    return o
}
fn rt_stat_reloc_kinds() {
    let mut k = []
    k.push(3)
    k.push(4)
    return k
}

// ── rt_kill (B9.6-C8 — class-C syscall · int+int NON-_cf no-errno) ───
// kill(int pid, int sig) -> int. A 2-arg svc WITHOUT the carry-flag / errno
// path (runtime.c uses the plain `_hxlcl_syscall2`, not the `_cf` variant) —
// so it is the 2-arg analogue of rt_getuid: both int args sign-extended, then
// trap, then ret with NO error branch and NO reloc. 5-instr 20 B body — the
// SAME length as rt_atoi but a pure leaf (no frame, no bl). runtime.c L1495:
//   hxlcl_kill(int pid, int sig) { return (int)_hxlcl_syscall2(HXLCL_SYS_KILL, ...); }
// SYS_KILL = 37 (0x25). clang -O2 (== as -arch arm64) is byte-for-byte:
//   sxtw x0,w0 / sxtw x1,w1 / mov w16,#37 / svc #0x80 / ret  (no reloc)
// Like getuid it returns x0 directly (whatever the trap leaves) — no errno
// store, so there is NOTHING to relocate. dup2 shares the dual-sxtw prologue
// but kill drops the entire 5-instr errno tail (the non-_cf distinction).
fn rt_kill() {
    let mut c = []
    // sxtw x0, w0  (sign-extend pid)        0x93407C00
    c.push(0)
    c.push(124)
    c.push(64)
    c.push(147)
    // sxtw x1, w1  (sign-extend sig)        0x93407C21
    c.push(33)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #37  (SYS_KILL)              0x528004B0
    c.push(176)
    c.push(4)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret  (x0 = trap result)               0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── self-test ────────────────────────────────────────────────

fn test_runtime_arm64() {
    let exit_bytes = rt_exit()
    let pstr = rt_print_str()
    let pln = rt_println()
    let pint = rt_print_int()
    let alloc_bytes = rt_alloc()
    let free_bytes = rt_free()
    let slen = rt_str_len()
    let mset = rt_memset()
    let mcmp = rt_memcmp()
    let mcpy = rt_memcpy()
    let mmove = rt_memmove()
    let scmp = rt_strcmp()
    let sncmp = rt_strncmp()
    let schr = rt_strchr()
    let srchr = rt_strrchr()
    let scpy = rt_strcpy()
    let sncpy = rt_strncpy()
    let scat = rt_strcat()
    let clz = rt_clz()
    let ctz = rt_ctz()
    let popc = rt_popcount()
    let bswap = rt_bswap()
    let ainit = rt_arena_init()
    let aalloc = rt_arena_alloc()
    let areset = rt_arena_reset()
    let arel = rt_arena_release()
    // B9.6 / F3 class-D — HexaVal struct-return constructors (x0:x1 pair).
    let hvoid = rt_hexa_void()
    let hint = rt_hexa_int()
    let hbool = rt_hexa_bool()
    // B9.6-D2 scale-out — 3 more struct-build ctors (FP-arg + enum ptr).
    let hfloat = rt_hexa_float()
    let henum = rt_hexa_enum_str()
    let henumv = rt_hexa_enum_str_v()
    // B9.6-C1 — class-C syscall ABI FIRST self-emit (raw svc #0x80).
    let gpid = rt_getpid()
    // B9.6-C2 — class-C syscall WITH arg (fd) + errno/carry-flag store.
    let clos = rt_close()
    let cl_roff = rt_close_reloc_offs()
    let cl_rkind = rt_close_reloc_kinds()
    // B9.6-B1 — class-B calling-convention composite (frame + bl + epilogue).
    let atoi_b = rt_atoi()
    let at_roff = rt_atoi_reloc_offs()
    let at_rkind = rt_atoi_reloc_kinds()
    // B9.6-E1 — class-E memory-lifecycle FIRST LIVE wire (unmap/dealloc stub).
    let munmap_b = rt_munmap()
    // B9.6-C3 — class-C syscall ABI: 0-arg no-errno (getpid mirror).
    let getuid_b = rt_getuid()
    // B9.6-C4 — class-C syscall ABI: 2-arg _cf + errno (int+int args).
    let dup2_b = rt_dup2()
    let d2_roff = rt_dup2_reloc_offs()
    let d2_rkind = rt_dup2_reloc_kinds()
    // B9.6-C5 — class-C syscall ABI: 2-arg _cf + errno (ptr+int args).
    let mkdir_b = rt_mkdir()
    let mk_roff = rt_mkdir_reloc_offs()
    let mk_rkind = rt_mkdir_reloc_kinds()
    // B9.6-C6 — class-C syscall ABI: 2-arg _cf + errno (int+ptr args, mkdir mirror).
    let fstat_b = rt_fstat()
    let fs_roff = rt_fstat_reloc_offs()
    let fs_rkind = rt_fstat_reloc_kinds()
    // B9.6-C7 — class-C syscall ABI: 2-arg _cf + errno (ptr+ptr, NO sxtw).
    let stat_b = rt_stat()
    let st_roff = rt_stat_reloc_offs()
    let st_rkind = rt_stat_reloc_kinds()
    // B9.6-C8 — class-C syscall ABI: 2-arg non-_cf no-errno (int+int, getuid 2-arg analogue).
    let kill_b = rt_kill()

    println("runtime_arm64 — ARM64 machine code byte arrays")
    println("  rt_exit          : " + to_string(len(exit_bytes)) + " bytes")
    println("  rt_print_str     : " + to_string(len(pstr)) + " bytes")
    println("  rt_println       : " + to_string(len(pln)) + " bytes")
    println("  rt_print_int     : " + to_string(len(pint)) + " bytes")
    println("  rt_alloc         : " + to_string(len(alloc_bytes)) + " bytes")
    println("  rt_free          : " + to_string(len(free_bytes)) + " bytes")
    println("  rt_str_len       : " + to_string(len(slen)) + " bytes")
    println("  rt_memset        : " + to_string(len(mset)) + " bytes")
    println("  rt_memcmp        : " + to_string(len(mcmp)) + " bytes")
    println("  rt_memcpy        : " + to_string(len(mcpy)) + " bytes")
    println("  rt_memmove       : " + to_string(len(mmove)) + " bytes")
    println("  rt_strcmp        : " + to_string(len(scmp)) + " bytes")
    println("  rt_strncmp       : " + to_string(len(sncmp)) + " bytes")
    println("  rt_strchr        : " + to_string(len(schr)) + " bytes")
    println("  rt_strrchr       : " + to_string(len(srchr)) + " bytes")
    println("  rt_strcpy        : " + to_string(len(scpy)) + " bytes")
    println("  rt_strncpy       : " + to_string(len(sncpy)) + " bytes")
    println("  rt_strcat        : " + to_string(len(scat)) + " bytes")
    println("  rt_clz           : " + to_string(len(clz)) + " bytes")
    println("  rt_ctz           : " + to_string(len(ctz)) + " bytes")
    println("  rt_popcount      : " + to_string(len(popc)) + " bytes")
    println("  rt_bswap         : " + to_string(len(bswap)) + " bytes")
    println("  rt_arena_init    : " + to_string(len(ainit)) + " bytes")
    println("  rt_arena_alloc   : " + to_string(len(aalloc)) + " bytes")
    println("  rt_arena_reset   : " + to_string(len(areset)) + " bytes")
    println("  rt_arena_release : " + to_string(len(arel)) + " bytes")
    println("  rt_hexa_void     : " + to_string(len(hvoid)) + " bytes")
    println("  rt_hexa_int      : " + to_string(len(hint)) + " bytes")
    println("  rt_hexa_bool     : " + to_string(len(hbool)) + " bytes")
    println("  rt_hexa_float    : " + to_string(len(hfloat)) + " bytes")
    println("  rt_hexa_enum_str : " + to_string(len(henum)) + " bytes")
    println("  rt_hexa_enum_str_v: " + to_string(len(henumv)) + " bytes")
    println("  rt_getpid        : " + to_string(len(gpid)) + " bytes")
    println("  rt_close         : " + to_string(len(clos)) + " bytes (" + to_string(len(cl_roff)) + " relocs)")
    println("  rt_atoi          : " + to_string(len(atoi_b)) + " bytes (" + to_string(len(at_roff)) + " reloc · BRANCH26)")
    println("  rt_munmap        : " + to_string(len(munmap_b)) + " bytes (class-E lifecycle)")
    println("  rt_getuid        : " + to_string(len(getuid_b)) + " bytes")
    println("  rt_dup2          : " + to_string(len(dup2_b)) + " bytes (" + to_string(len(d2_roff)) + " relocs)")
    println("  rt_mkdir         : " + to_string(len(mkdir_b)) + " bytes (" + to_string(len(mk_roff)) + " relocs)")
    println("  rt_fstat         : " + to_string(len(fstat_b)) + " bytes (" + to_string(len(fs_roff)) + " relocs)")
    println("  rt_stat          : " + to_string(len(stat_b)) + " bytes (" + to_string(len(st_roff)) + " relocs)")
    println("  rt_kill          : " + to_string(len(kill_b)) + " bytes (no reloc)")

    // Verify sizes match expected instruction counts * 4
    let mut ok = true
    if len(exit_bytes) != 16 { println("  FAIL: rt_exit expected 16, got " + to_string(len(exit_bytes))); ok = false }
    if len(pstr) != 36 { println("  FAIL: rt_print_str expected 36, got " + to_string(len(pstr))); ok = false }
    if len(pln) != 52 { println("  FAIL: rt_println expected 52, got " + to_string(len(pln))); ok = false }
    if len(pint) != 184 { println("  FAIL: rt_print_int expected 184, got " + to_string(len(pint))); ok = false }
    // rt_alloc 48 → 68 (+20 · header pattern: stp x19/x20, mov x19=N,
    //   add x1=N+16, str x19, add x0+=16, ldp x19/x20). Pair-safe with rt_free.
    if len(alloc_bytes) != 68 { println("  FAIL: rt_alloc expected 68, got " + to_string(len(alloc_bytes))); ok = false }
    if len(free_bytes) != 24 { println("  FAIL: rt_free expected 24, got " + to_string(len(free_bytes))); ok = false }
    if len(slen) != 44 { println("  FAIL: rt_str_len expected 44, got " + to_string(len(slen))); ok = false }
    // rt_memset 28 (B9.6a / F3 increment): 7-instr leaf byte-store loop.
    if len(mset) != 28 { println("  FAIL: rt_memset expected 28, got " + to_string(len(mset))); ok = false }
    // B9.6a / F3 increment 2 — 4 reloc-free leaf primitives:
    //   rt_memcmp  13-instr 52 B  (byte-load compare loop, signed diff)
    //   rt_memcpy   8-instr 32 B  (scalar forward byte copy)
    //   rt_memmove 16-instr 64 B  (overlap-safe fwd/bwd copy)
    //   rt_strcmp  12-instr 48 B  (NUL-terminated compare, signed diff)
    if len(mcmp) != 52 { println("  FAIL: rt_memcmp expected 52, got " + to_string(len(mcmp))); ok = false }
    if len(mcpy) != 32 { println("  FAIL: rt_memcpy expected 32, got " + to_string(len(mcpy))); ok = false }
    if len(mmove) != 64 { println("  FAIL: rt_memmove expected 64, got " + to_string(len(mmove))); ok = false }
    if len(scmp) != 48 { println("  FAIL: rt_strcmp expected 48, got " + to_string(len(scmp))); ok = false }
    // B9.6a / F3 increment 3 — 5 reloc-free leaf string primitives:
    //   rt_strncmp 14-instr 56 B  (bounded compare, len OR NUL stop)
    //   rt_strchr  11-instr 44 B  (first occurrence, NULL if absent)
    //   rt_strrchr 11-instr 44 B  (last occurrence, NULL if absent)
    //   rt_strcpy   7-instr 28 B  (NUL-terminated copy, returns dst)
    //   rt_strncpy 14-instr 56 B  (bounded copy + NUL pad, C semantics)
    if len(sncmp) != 56 { println("  FAIL: rt_strncmp expected 56, got " + to_string(len(sncmp))); ok = false }
    if len(schr) != 44 { println("  FAIL: rt_strchr expected 44, got " + to_string(len(schr))); ok = false }
    if len(srchr) != 44 { println("  FAIL: rt_strrchr expected 44, got " + to_string(len(srchr))); ok = false }
    if len(scpy) != 28 { println("  FAIL: rt_strcpy expected 28, got " + to_string(len(scpy))); ok = false }
    if len(sncpy) != 56 { println("  FAIL: rt_strncpy expected 56, got " + to_string(len(sncpy))); ok = false }
    // B9.6a / F3 increment 4 — final 5 simple reloc-free leaf primitives
    // (the LAST cold-batchable tier; thereafter = reloc/HexaVal/GC HARD floor):
    //   rt_strcat   12-instr 48 B  (strlen-scan + strcpy composite, returns dst)
    //   rt_clz       2-instr  8 B  (native CLZ; clz(0)=64)
    //   rt_ctz       3-instr 12 B  (RBIT+CLZ; ctz(0)=64)
    //   rt_popcount  5-instr 20 B  (NEON CNT+ADDV over 8 byte lanes)
    //   rt_bswap     2-instr  8 B  (native REV; 64-bit byte reverse)
    if len(scat) != 48 { println("  FAIL: rt_strcat expected 48, got " + to_string(len(scat))); ok = false }
    if len(clz) != 8 { println("  FAIL: rt_clz expected 8, got " + to_string(len(clz))); ok = false }
    if len(ctz) != 12 { println("  FAIL: rt_ctz expected 12, got " + to_string(len(ctz))); ok = false }
    if len(popc) != 20 { println("  FAIL: rt_popcount expected 20, got " + to_string(len(popc))); ok = false }
    if len(bswap) != 8 { println("  FAIL: rt_bswap expected 8, got " + to_string(len(bswap))); ok = false }
    // PR #1297 residual #2 — adr (4 B) → adrp+add (8 B) widening for
    // _arena_state PAGE21+PAGEOFF12 reloc machinery. Per-fn deltas:
    //   init   72 → 76 (+4 · 1 site)
    //   alloc  44 → 48 (+4 · 1 site)
    //   reset  16 → 20 (+4 · 1 site)
    //   release 60 → 68 (+8 · 2 sites)
    if len(ainit) != 76 { println("  FAIL: rt_arena_init expected 76, got " + to_string(len(ainit))); ok = false }
    if len(aalloc) != 48 { println("  FAIL: rt_arena_alloc expected 48, got " + to_string(len(aalloc))); ok = false }
    if len(areset) != 20 { println("  FAIL: rt_arena_reset expected 20, got " + to_string(len(areset))); ok = false }
    if len(arel) != 68 { println("  FAIL: rt_arena_release expected 68, got " + to_string(len(arel))); ok = false }

    // Spec constraint: rt_arena_alloc must be < 64 bytes (hot path)
    if len(aalloc) >= 64 { println("  FAIL: rt_arena_alloc must be < 64 bytes"); ok = false }

    // B9.6 / F3 class-D — HexaVal struct-return ctors are each a 3-instr
    // (12 B) leaf emitting the x0:x1 register-pair return:
    //   rt_hexa_void  mov w0,#4 / mov x1,#0  / ret  (tag=TAG_VOID, val=0)
    //   rt_hexa_int   mov x1,x0 / mov x0,#0  / ret  (tag=TAG_INT,  val=x0)
    //   rt_hexa_bool  mov w1,w0 / mov w0,#2  / ret  (tag=TAG_BOOL, val=w0)
    if len(hvoid) != 12 { println("  FAIL: rt_hexa_void expected 12, got " + to_string(len(hvoid))); ok = false }
    if len(hint) != 12 { println("  FAIL: rt_hexa_int expected 12, got " + to_string(len(hint))); ok = false }
    if len(hbool) != 12 { println("  FAIL: rt_hexa_bool expected 12, got " + to_string(len(hbool))); ok = false }
    // B9.6-D2 scale-out — each is a 3-instr 12 B x0:x1 leaf:
    //   rt_hexa_float      fmov x1,d0 / mov w0,#1  / ret  (tag=TAG_FLOAT, val=d0 bits)
    //   rt_hexa_enum_str   mov x1,x0  / mov w0,#11 / ret  (tag=TAG_ENUM,  val=ptr)
    //   rt_hexa_enum_str_v mov x1,x0  / mov w0,#11 / ret  (byte-identical to enum_str)
    if len(hfloat) != 12 { println("  FAIL: rt_hexa_float expected 12, got " + to_string(len(hfloat))); ok = false }
    if len(henum) != 12 { println("  FAIL: rt_hexa_enum_str expected 12, got " + to_string(len(henum))); ok = false }
    if len(henumv) != 12 { println("  FAIL: rt_hexa_enum_str_v expected 12, got " + to_string(len(henumv))); ok = false }
    // B9.6-C1 — class-C syscall ABI: rt_getpid is a 4-instr 16 B leaf
    //   mov w16,#20 / mov x0,#0 / svc #0x80 / ret  (svc-trap, returns pid in x0)
    if len(gpid) != 16 { println("  FAIL: rt_getpid expected 16, got " + to_string(len(gpid))); ok = false }
    // svc #0x80 must be present at offset 8 (01 10 00 d4) — the syscall trap.
    if gpid[8] != 1 || gpid[9] != 16 || gpid[10] != 0 || gpid[11] != 212 { println("  FAIL: rt_getpid missing svc #0x80 at offset 8"); ok = false }
    // mov w16,#20 prefix (90 02 80 52) — SYS_GETPID loaded into x16.
    if gpid[0] != 144 || gpid[1] != 2 || gpid[2] != 128 || gpid[3] != 82 { println("  FAIL: rt_getpid wrong syscall number prefix"); ok = false }
    // ret trailer (c0 03 5f d6) — getpid RETURNS (unlike rt_exit).
    if gpid[12] != 192 || gpid[13] != 3 || gpid[14] != 95 || gpid[15] != 214 { println("  FAIL: rt_getpid no RET"); ok = false }
    // B9.6-C2 — class-C syscall WITH arg + errno/carry-flag: rt_close is a
    //   9-instr 36 B body sxtw / mov w16,#6 / svc / cset / cbz / adrp / str
    //   / mov x0,#-1 / ret  (svc-trap w/ fd arg, carry→errno store, -1 ret).
    if len(clos) != 36 { println("  FAIL: rt_close expected 36, got " + to_string(len(clos))); ok = false }
    // sxtw x0,w0 prefix (00 7c 40 93) — fd arg sign-extended into x0.
    if clos[0] != 0 || clos[1] != 124 || clos[2] != 64 || clos[3] != 147 { println("  FAIL: rt_close missing sxtw fd-arg prefix"); ok = false }
    // mov w16,#6 (d0 00 80 52) — SYS_CLOSE loaded into x16.
    if clos[4] != 208 || clos[5] != 0 || clos[6] != 128 || clos[7] != 82 { println("  FAIL: rt_close wrong syscall number (SYS_CLOSE=6)"); ok = false }
    // svc #0x80 at offset 8 (01 10 00 d4) — the BSD syscall trap.
    if clos[8] != 1 || clos[9] != 16 || clos[10] != 0 || clos[11] != 212 { println("  FAIL: rt_close missing svc #0x80 at offset 8"); ok = false }
    // cset x8,hs at offset 12 (e8 37 9f 9a) — capture carry flag (error bit).
    if clos[12] != 232 || clos[13] != 55 || clos[14] != 159 || clos[15] != 154 { println("  FAIL: rt_close missing cset (carry-flag capture)"); ok = false }
    // cbz x8,Lret at offset 16 (88 00 00 b4) — success skips the errno store.
    if clos[16] != 136 || clos[17] != 0 || clos[18] != 0 || clos[19] != 180 { println("  FAIL: rt_close missing cbz (success branch)"); ok = false }
    // adrp x8,errno at offset 20 (08 00 00 90) — errno PAGE21 reloc site.
    if clos[20] != 8 || clos[21] != 0 || clos[22] != 0 || clos[23] != 144 { println("  FAIL: rt_close missing adrp errno (reloc 0x14)"); ok = false }
    // str w0,[x8] at offset 24 (00 01 00 b9) — errno PAGEOFF12 reloc site.
    if clos[24] != 0 || clos[25] != 1 || clos[26] != 0 || clos[27] != 185 { println("  FAIL: rt_close missing str errno (reloc 0x18)"); ok = false }
    // mov x0,#-1 at offset 28 (00 00 80 92) — error return value.
    if clos[28] != 0 || clos[29] != 0 || clos[30] != 128 || clos[31] != 146 { println("  FAIL: rt_close missing mov x0,#-1 (error ret)"); ok = false }
    // ret trailer (c0 03 5f d6) — close RETURNS (0 success / -1 error).
    if clos[32] != 192 || clos[33] != 3 || clos[34] != 95 || clos[35] != 214 { println("  FAIL: rt_close no RET"); ok = false }
    // reloc table: 2 records (PAGE21@0x14 + PAGEOFF12@0x18) for errno store.
    if len(cl_roff) != 2 { println("  FAIL: rt_close expected 2 reloc offsets, got " + to_string(len(cl_roff))); ok = false }
    if len(cl_rkind) != 2 { println("  FAIL: rt_close expected 2 reloc kinds, got " + to_string(len(cl_rkind))); ok = false }
    if cl_roff[0] != 20 || cl_roff[1] != 24 { println("  FAIL: rt_close reloc offsets must be 0x14,0x18"); ok = false }
    if cl_rkind[0] != 3 || cl_rkind[1] != 4 { println("  FAIL: rt_close reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }
    // B9.6-B1 — class-B calling-convention composite: rt_atoi is a 5-instr 20 B
    //   body stp x29,x30,[sp,#-16]! / mov x29,sp / bl _hxlcl_atoll
    //   / ldp x29,x30,[sp],#16 / ret  (frame + cross-object call + epilogue).
    if len(atoi_b) != 20 { println("  FAIL: rt_atoi expected 20, got " + to_string(len(atoi_b))); ok = false }
    // stp x29,x30,[sp,#-16]! prefix (fd 7b bf a9) — prologue spilling x29/x30.
    if atoi_b[0] != 253 || atoi_b[1] != 123 || atoi_b[2] != 191 || atoi_b[3] != 169 { println("  FAIL: rt_atoi missing stp x29,x30 prologue"); ok = false }
    // mov x29,sp at offset 4 (fd 03 00 91) — frame pointer set up.
    if atoi_b[4] != 253 || atoi_b[5] != 3 || atoi_b[6] != 0 || atoi_b[7] != 145 { println("  FAIL: rt_atoi missing mov x29,sp"); ok = false }
    // bl _hxlcl_atoll at offset 8 (00 00 00 94) — the cross-object CALL (BRANCH26 reloc site).
    if atoi_b[8] != 0 || atoi_b[9] != 0 || atoi_b[10] != 0 || atoi_b[11] != 148 { println("  FAIL: rt_atoi missing bl (reloc 0x08, zeroed imm)"); ok = false }
    // ldp x29,x30,[sp],#16 at offset 12 (fd 7b c1 a8) — epilogue restoring x29/x30.
    if atoi_b[12] != 253 || atoi_b[13] != 123 || atoi_b[14] != 193 || atoi_b[15] != 168 { println("  FAIL: rt_atoi missing ldp x29,x30 epilogue"); ok = false }
    // ret trailer (c0 03 5f d6) — atoi RETURNS (int)atoll(s).
    if atoi_b[16] != 192 || atoi_b[17] != 3 || atoi_b[18] != 95 || atoi_b[19] != 214 { println("  FAIL: rt_atoi no RET"); ok = false }
    // reloc table: 1 record (BRANCH26@0x08) for the cross-object bl.
    if len(at_roff) != 1 { println("  FAIL: rt_atoi expected 1 reloc offset, got " + to_string(len(at_roff))); ok = false }
    if len(at_rkind) != 1 { println("  FAIL: rt_atoi expected 1 reloc kind, got " + to_string(len(at_rkind))); ok = false }
    if at_roff[0] != 8 { println("  FAIL: rt_atoi reloc offset must be 0x08 (the bl)"); ok = false }
    if at_rkind[0] != 2 { println("  FAIL: rt_atoi reloc kind must be BRANCH26(2)"); ok = false }
    // B9.6-E1 — class-E memory-lifecycle: rt_munmap is a 2-instr 8 B leaf
    //   mov w0,#0 / ret  (unmap success stub over the never-free bump allocator).
    if len(munmap_b) != 8 { println("  FAIL: rt_munmap expected 8, got " + to_string(len(munmap_b))); ok = false }
    // mov w0,#0 prefix (00 00 80 52) — return 0 (success).
    if munmap_b[0] != 0 || munmap_b[1] != 0 || munmap_b[2] != 128 || munmap_b[3] != 82 { println("  FAIL: rt_munmap missing mov w0,#0 (success ret)"); ok = false }
    // ret trailer (c0 03 5f d6) — munmap RETURNS 0.
    if munmap_b[4] != 192 || munmap_b[5] != 3 || munmap_b[6] != 95 || munmap_b[7] != 214 { println("  FAIL: rt_munmap no RET"); ok = false }
    // B9.6-C3 — class-C syscall ABI: rt_getuid is a 4-instr 16 B leaf,
    //   byte-identical to rt_getpid except mov w16,#24 (SYS_GETUID) vs #20.
    if len(getuid_b) != 16 { println("  FAIL: rt_getuid expected 16, got " + to_string(len(getuid_b))); ok = false }
    // mov w16,#24 prefix (10 03 80 52) — SYS_GETUID loaded into x16.
    if getuid_b[0] != 16 || getuid_b[1] != 3 || getuid_b[2] != 128 || getuid_b[3] != 82 { println("  FAIL: rt_getuid wrong syscall number prefix (SYS_GETUID=24)"); ok = false }
    // svc #0x80 at offset 8 (01 10 00 d4) — the BSD syscall trap.
    if getuid_b[8] != 1 || getuid_b[9] != 16 || getuid_b[10] != 0 || getuid_b[11] != 212 { println("  FAIL: rt_getuid missing svc #0x80 at offset 8"); ok = false }
    // ret trailer (c0 03 5f d6) — getuid RETURNS the uid.
    if getuid_b[12] != 192 || getuid_b[13] != 3 || getuid_b[14] != 95 || getuid_b[15] != 214 { println("  FAIL: rt_getuid no RET"); ok = false }
    // B9.6-C4 — class-C syscall ABI: rt_dup2 is a 10-instr 40 B body (the
    //   2-arg _cf template; sxtw x0 / sxtw x1 / mov w16,#90 / svc / cset /
    //   cbz / adrp errno / str / mov x0,#-1 / ret).
    if len(dup2_b) != 40 { println("  FAIL: rt_dup2 expected 40, got " + to_string(len(dup2_b))); ok = false }
    // sxtw x0,w0 prefix (00 7c 40 93) — oldfd arg sign-extended.
    if dup2_b[0] != 0 || dup2_b[1] != 124 || dup2_b[2] != 64 || dup2_b[3] != 147 { println("  FAIL: rt_dup2 missing sxtw x0 (oldfd)"); ok = false }
    // sxtw x1,w1 (21 7c 40 93) — newfd arg sign-extended (the 2-arg extension).
    if dup2_b[4] != 33 || dup2_b[5] != 124 || dup2_b[6] != 64 || dup2_b[7] != 147 { println("  FAIL: rt_dup2 missing sxtw x1 (newfd)"); ok = false }
    // mov w16,#90 (50 0b 80 52) — SYS_DUP2 loaded into x16.
    if dup2_b[8] != 80 || dup2_b[9] != 11 || dup2_b[10] != 128 || dup2_b[11] != 82 { println("  FAIL: rt_dup2 wrong syscall number (SYS_DUP2=90)"); ok = false }
    // svc #0x80 at offset 12 (01 10 00 d4) — the BSD syscall trap.
    if dup2_b[12] != 1 || dup2_b[13] != 16 || dup2_b[14] != 0 || dup2_b[15] != 212 { println("  FAIL: rt_dup2 missing svc #0x80 at offset 12"); ok = false }
    // cset x8,hs at offset 16 (e8 37 9f 9a) — carry-flag capture.
    if dup2_b[16] != 232 || dup2_b[17] != 55 || dup2_b[18] != 159 || dup2_b[19] != 154 { println("  FAIL: rt_dup2 missing cset (carry capture)"); ok = false }
    // adrp x8,errno at offset 24 (08 00 00 90) — PAGE21 reloc site.
    if dup2_b[24] != 8 || dup2_b[25] != 0 || dup2_b[26] != 0 || dup2_b[27] != 144 { println("  FAIL: rt_dup2 missing adrp errno (reloc 0x18)"); ok = false }
    // str w0,[x8] at offset 28 (00 01 00 b9) — PAGEOFF12 reloc site.
    if dup2_b[28] != 0 || dup2_b[29] != 1 || dup2_b[30] != 0 || dup2_b[31] != 185 { println("  FAIL: rt_dup2 missing str errno (reloc 0x1c)"); ok = false }
    // ret trailer (c0 03 5f d6).
    if dup2_b[36] != 192 || dup2_b[37] != 3 || dup2_b[38] != 95 || dup2_b[39] != 214 { println("  FAIL: rt_dup2 no RET"); ok = false }
    // reloc table: 2 records (PAGE21@0x18 + PAGEOFF12@0x1c).
    if len(d2_roff) != 2 { println("  FAIL: rt_dup2 expected 2 reloc offsets, got " + to_string(len(d2_roff))); ok = false }
    if len(d2_rkind) != 2 { println("  FAIL: rt_dup2 expected 2 reloc kinds, got " + to_string(len(d2_rkind))); ok = false }
    if d2_roff[0] != 24 || d2_roff[1] != 28 { println("  FAIL: rt_dup2 reloc offsets must be 0x18,0x1c"); ok = false }
    if d2_rkind[0] != 3 || d2_rkind[1] != 4 { println("  FAIL: rt_dup2 reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }
    // B9.6-C5 — class-C syscall ABI: rt_mkdir is a 9-instr 36 B body (ptr+int
    //   _cf; only x1/mode sign-extended, path ptr passes through). Same length
    //   as rt_close, only the sxtw register + SYS number differ.
    if len(mkdir_b) != 36 { println("  FAIL: rt_mkdir expected 36, got " + to_string(len(mkdir_b))); ok = false }
    // sxtw x1,w1 prefix (21 7c 40 93) — mode arg sign-extended (path ptr untouched).
    if mkdir_b[0] != 33 || mkdir_b[1] != 124 || mkdir_b[2] != 64 || mkdir_b[3] != 147 { println("  FAIL: rt_mkdir missing sxtw x1 (mode arg)"); ok = false }
    // mov w16,#136 (10 11 80 52) — SYS_MKDIR loaded into x16.
    if mkdir_b[4] != 16 || mkdir_b[5] != 17 || mkdir_b[6] != 128 || mkdir_b[7] != 82 { println("  FAIL: rt_mkdir wrong syscall number (SYS_MKDIR=136)"); ok = false }
    // svc #0x80 at offset 8 (01 10 00 d4).
    if mkdir_b[8] != 1 || mkdir_b[9] != 16 || mkdir_b[10] != 0 || mkdir_b[11] != 212 { println("  FAIL: rt_mkdir missing svc #0x80 at offset 8"); ok = false }
    // adrp x8,errno at offset 20 (08 00 00 90) — PAGE21 reloc site (== rt_close).
    if mkdir_b[20] != 8 || mkdir_b[21] != 0 || mkdir_b[22] != 0 || mkdir_b[23] != 144 { println("  FAIL: rt_mkdir missing adrp errno (reloc 0x14)"); ok = false }
    // str w0,[x8] at offset 24 (00 01 00 b9) — PAGEOFF12 reloc site.
    if mkdir_b[24] != 0 || mkdir_b[25] != 1 || mkdir_b[26] != 0 || mkdir_b[27] != 185 { println("  FAIL: rt_mkdir missing str errno (reloc 0x18)"); ok = false }
    // ret trailer (c0 03 5f d6).
    if mkdir_b[32] != 192 || mkdir_b[33] != 3 || mkdir_b[34] != 95 || mkdir_b[35] != 214 { println("  FAIL: rt_mkdir no RET"); ok = false }
    // reloc table: 2 records (PAGE21@0x14 + PAGEOFF12@0x18) — same as rt_close.
    if len(mk_roff) != 2 { println("  FAIL: rt_mkdir expected 2 reloc offsets, got " + to_string(len(mk_roff))); ok = false }
    if len(mk_rkind) != 2 { println("  FAIL: rt_mkdir expected 2 reloc kinds, got " + to_string(len(mk_rkind))); ok = false }
    if mk_roff[0] != 20 || mk_roff[1] != 24 { println("  FAIL: rt_mkdir reloc offsets must be 0x14,0x18"); ok = false }
    if mk_rkind[0] != 3 || mk_rkind[1] != 4 { println("  FAIL: rt_mkdir reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }
    // B9.6-C6 — class-C syscall ABI: rt_fstat is a 9-instr 36 B body (int+ptr
    //   _cf; sxtw targets x0/fd, the buf ptr x1 untouched — mirror of mkdir).
    if len(fstat_b) != 36 { println("  FAIL: rt_fstat expected 36, got " + to_string(len(fstat_b))); ok = false }
    // sxtw x0,w0 prefix (00 7c 40 93) — fd arg sign-extended (buf ptr untouched).
    if fstat_b[0] != 0 || fstat_b[1] != 124 || fstat_b[2] != 64 || fstat_b[3] != 147 { println("  FAIL: rt_fstat missing sxtw x0 (fd arg)"); ok = false }
    // mov w16,#339 (70 2a 80 52) — SYS_FSTAT; first class-C SYS number > 255 (full imm16).
    if fstat_b[4] != 112 || fstat_b[5] != 42 || fstat_b[6] != 128 || fstat_b[7] != 82 { println("  FAIL: rt_fstat wrong syscall number (SYS_FSTAT=339)"); ok = false }
    // svc #0x80 at offset 8 (01 10 00 d4).
    if fstat_b[8] != 1 || fstat_b[9] != 16 || fstat_b[10] != 0 || fstat_b[11] != 212 { println("  FAIL: rt_fstat missing svc #0x80 at offset 8"); ok = false }
    // cset x8,hs at offset 12 (e8 37 9f 9a) — carry-flag capture.
    if fstat_b[12] != 232 || fstat_b[13] != 55 || fstat_b[14] != 159 || fstat_b[15] != 154 { println("  FAIL: rt_fstat missing cset (carry capture)"); ok = false }
    // adrp x8,errno at offset 20 (08 00 00 90) — PAGE21 reloc site (== rt_mkdir).
    if fstat_b[20] != 8 || fstat_b[21] != 0 || fstat_b[22] != 0 || fstat_b[23] != 144 { println("  FAIL: rt_fstat missing adrp errno (reloc 0x14)"); ok = false }
    // str w0,[x8] at offset 24 (00 01 00 b9) — PAGEOFF12 reloc site.
    if fstat_b[24] != 0 || fstat_b[25] != 1 || fstat_b[26] != 0 || fstat_b[27] != 185 { println("  FAIL: rt_fstat missing str errno (reloc 0x18)"); ok = false }
    // ret trailer (c0 03 5f d6).
    if fstat_b[32] != 192 || fstat_b[33] != 3 || fstat_b[34] != 95 || fstat_b[35] != 214 { println("  FAIL: rt_fstat no RET"); ok = false }
    // reloc table: 2 records (PAGE21@0x14 + PAGEOFF12@0x18) — same as rt_mkdir.
    if len(fs_roff) != 2 { println("  FAIL: rt_fstat expected 2 reloc offsets, got " + to_string(len(fs_roff))); ok = false }
    if len(fs_rkind) != 2 { println("  FAIL: rt_fstat expected 2 reloc kinds, got " + to_string(len(fs_rkind))); ok = false }
    if fs_roff[0] != 20 || fs_roff[1] != 24 { println("  FAIL: rt_fstat reloc offsets must be 0x14,0x18"); ok = false }
    if fs_rkind[0] != 3 || fs_rkind[1] != 4 { println("  FAIL: rt_fstat reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }
    // B9.6-C7 — class-C syscall ABI: rt_stat is an 8-instr 32 B body (ptr+ptr
    //   _cf; NEITHER arg sign-extended — the FIRST no-sxtw 2-arg svc body, 4 B
    //   shorter than mkdir/fstat exactly because the sxtw is dropped).
    if len(stat_b) != 32 { println("  FAIL: rt_stat expected 32, got " + to_string(len(stat_b))); ok = false }
    // mov w16,#338 (50 2a 80 52) prefix — SYS_STAT loaded directly, NO leading sxtw.
    if stat_b[0] != 80 || stat_b[1] != 42 || stat_b[2] != 128 || stat_b[3] != 82 { println("  FAIL: rt_stat wrong prologue (expected mov w16,#338 with NO sxtw)"); ok = false }
    // svc #0x80 at offset 4 (01 10 00 d4) — shifted down 4 vs mkdir (no sxtw).
    if stat_b[4] != 1 || stat_b[5] != 16 || stat_b[6] != 0 || stat_b[7] != 212 { println("  FAIL: rt_stat missing svc #0x80 at offset 4"); ok = false }
    // cset x8,hs at offset 8 (e8 37 9f 9a) — carry-flag capture.
    if stat_b[8] != 232 || stat_b[9] != 55 || stat_b[10] != 159 || stat_b[11] != 154 { println("  FAIL: rt_stat missing cset (carry capture)"); ok = false }
    // adrp x8,errno at offset 16 (08 00 00 90) — PAGE21 reloc site (shifted -4 vs mkdir).
    if stat_b[16] != 8 || stat_b[17] != 0 || stat_b[18] != 0 || stat_b[19] != 144 { println("  FAIL: rt_stat missing adrp errno (reloc 0x10)"); ok = false }
    // str w0,[x8] at offset 20 (00 01 00 b9) — PAGEOFF12 reloc site.
    if stat_b[20] != 0 || stat_b[21] != 1 || stat_b[22] != 0 || stat_b[23] != 185 { println("  FAIL: rt_stat missing str errno (reloc 0x14)"); ok = false }
    // ret trailer (c0 03 5f d6).
    if stat_b[28] != 192 || stat_b[29] != 3 || stat_b[30] != 95 || stat_b[31] != 214 { println("  FAIL: rt_stat no RET"); ok = false }
    // reloc table: 2 records (PAGE21@0x10 + PAGEOFF12@0x14) — shifted -4 vs mkdir.
    if len(st_roff) != 2 { println("  FAIL: rt_stat expected 2 reloc offsets, got " + to_string(len(st_roff))); ok = false }
    if len(st_rkind) != 2 { println("  FAIL: rt_stat expected 2 reloc kinds, got " + to_string(len(st_rkind))); ok = false }
    if st_roff[0] != 16 || st_roff[1] != 20 { println("  FAIL: rt_stat reloc offsets must be 0x10,0x14"); ok = false }
    if st_rkind[0] != 3 || st_rkind[1] != 4 { println("  FAIL: rt_stat reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }
    // B9.6-C8 — class-C syscall ABI: rt_kill is a 5-instr 20 B leaf (int+int
    //   NON-_cf no-errno; both args sxtw, trap, ret — getuid's 2-arg analogue,
    //   NO carry-flag path and NO reloc).
    if len(kill_b) != 20 { println("  FAIL: rt_kill expected 20, got " + to_string(len(kill_b))); ok = false }
    // sxtw x0,w0 prefix (00 7c 40 93) — pid arg sign-extended.
    if kill_b[0] != 0 || kill_b[1] != 124 || kill_b[2] != 64 || kill_b[3] != 147 { println("  FAIL: rt_kill missing sxtw x0 (pid)"); ok = false }
    // sxtw x1,w1 (21 7c 40 93) — sig arg sign-extended.
    if kill_b[4] != 33 || kill_b[5] != 124 || kill_b[6] != 64 || kill_b[7] != 147 { println("  FAIL: rt_kill missing sxtw x1 (sig)"); ok = false }
    // mov w16,#37 (b0 04 80 52) — SYS_KILL loaded into x16.
    if kill_b[8] != 176 || kill_b[9] != 4 || kill_b[10] != 128 || kill_b[11] != 82 { println("  FAIL: rt_kill wrong syscall number (SYS_KILL=37)"); ok = false }
    // svc #0x80 at offset 12 (01 10 00 d4) — trap, NO errno tail after.
    if kill_b[12] != 1 || kill_b[13] != 16 || kill_b[14] != 0 || kill_b[15] != 212 { println("  FAIL: rt_kill missing svc #0x80 at offset 12"); ok = false }
    // ret trailer (c0 03 5f d6) directly after svc — no carry-flag / errno path.
    if kill_b[16] != 192 || kill_b[17] != 3 || kill_b[18] != 95 || kill_b[19] != 214 { println("  FAIL: rt_kill no RET (or unexpected errno tail)"); ok = false }

    // Verify all sizes are multiples of 4 (ARM64 fixed-width)
    if len(exit_bytes) % 4 != 0 { println("  FAIL: rt_exit not aligned"); ok = false }
    if len(pstr) % 4 != 0 { println("  FAIL: rt_print_str not aligned"); ok = false }
    if len(pln) % 4 != 0 { println("  FAIL: rt_println not aligned"); ok = false }
    if len(pint) % 4 != 0 { println("  FAIL: rt_print_int not aligned"); ok = false }
    if len(alloc_bytes) % 4 != 0 { println("  FAIL: rt_alloc not aligned"); ok = false }
    if len(free_bytes) % 4 != 0 { println("  FAIL: rt_free not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_str_len not aligned"); ok = false }
    if len(mset) % 4 != 0 { println("  FAIL: rt_memset not aligned"); ok = false }
    if len(mcmp) % 4 != 0 { println("  FAIL: rt_memcmp not aligned"); ok = false }
    if len(mcpy) % 4 != 0 { println("  FAIL: rt_memcpy not aligned"); ok = false }
    if len(mmove) % 4 != 0 { println("  FAIL: rt_memmove not aligned"); ok = false }
    if len(scmp) % 4 != 0 { println("  FAIL: rt_strcmp not aligned"); ok = false }
    if len(sncmp) % 4 != 0 { println("  FAIL: rt_strncmp not aligned"); ok = false }
    if len(schr) % 4 != 0 { println("  FAIL: rt_strchr not aligned"); ok = false }
    if len(srchr) % 4 != 0 { println("  FAIL: rt_strrchr not aligned"); ok = false }
