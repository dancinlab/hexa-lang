    // strb w3, [sp]                  0x390003E3
    c.push(227)
    c.push(3)
    c.push(0)
    c.push(57)
    // mov x0, #1  (fd=stdout)       0xD2800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x1, sp  (buf=sp)          0x910003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(145)
    // mov x2, #1  (len=1)           0xD2800022
    c.push(34)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #4 (SYS_write)       0xD2800090
    c.push(144)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // add sp, sp, #16                0x910043FF
    c.push(255)
    c.push(67)
    c.push(0)
    c.push(145)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_print_int ─────────────────────────────────────────────
// print_int(x0) — convert int to decimal ASCII, write to stdout + newline
//
// Algorithm: divide by 10 repeatedly, store digits backwards in a
// 20-byte stack buffer, then write(1, buf, len).
//
// Register usage:
//   x0  = input / quotient        x3  = constant 10
//   x1  = buffer pointer          x4  = quotient (x0/10)
//   x2  = digit count             x5  = remainder / digit
//   x19 = is-negative flag (callee-saved)
//
// 46 instructions, 184 bytes

fn rt_print_int() {
    let mut c = []

    // ── prologue ──
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // stp x19, x20, [sp, #-16]!     0xA9BF53F3
    c.push(243)
    c.push(83)
    c.push(191)
    c.push(169)
    // sub sp, sp, #32                0xD10083FF
    c.push(255)
    c.push(131)
    c.push(0)
    c.push(209)

    // ── init ──
    // mov x19, #0  (neg flag)        0xD2800013
    c.push(19)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x1, sp                     0x910003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(145)
    // add x1, x1, #20               0x91005021
    c.push(33)
    c.push(80)
    c.push(0)
    c.push(145)
    // mov x2, #0  (digit count)     0xD2800002
    c.push(2)
    c.push(0)
    c.push(128)
    c.push(210)

    // ── handle negative ──
    // cmp x0, #0                     0xF100001F
    c.push(31)
    c.push(0)
    c.push(0)
    c.push(241)
    // b.ge +2 (skip neg)             0x5400004A
    c.push(74)
    c.push(0)
    c.push(0)
    c.push(84)
    // neg x0, x0                     0xCB0003E0
    c.push(224)
    c.push(3)
    c.push(0)
    c.push(203)
    // mov x19, #1                    0xD2800033
    c.push(51)
    c.push(0)
    c.push(128)
    c.push(210)

    // ── handle zero ──
    // cbnz x0, +6 (to loop)         0xB50000C0
    c.push(192)
    c.push(0)
    c.push(0)
    c.push(181)
    // mov w5, #48  (ASCII '0')      0x52800605
    c.push(5)
    c.push(6)
    c.push(128)
    c.push(82)
    // sub x1, x1, #1                0xD1000421
    c.push(33)
    c.push(4)
    c.push(0)
    c.push(209)
    // strb w5, [x1]                  0x39000025
    c.push(37)
    c.push(0)
    c.push(0)
    c.push(57)
    // add x2, x2, #1                0x91000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(145)
    // b +10 (to write section)       0x1400000A
    c.push(10)
    c.push(0)
    c.push(0)
    c.push(20)

    // ── digit extraction loop ──
    // mov x3, #10                    0xD2800143
    c.push(67)
    c.push(1)
    c.push(128)
    c.push(210)
    // udiv x4, x0, x3               0x9AC30804
    c.push(4)
    c.push(8)
    c.push(195)
    c.push(154)
    // msub x5, x4, x3, x0           0x9B038085
    c.push(133)
    c.push(128)
    c.push(3)
    c.push(155)
    // add x5, x5, #48  (ASCII)      0x9100C0A5
    c.push(165)
    c.push(192)
    c.push(0)
    c.push(145)
    // sub x1, x1, #1                0xD1000421
    c.push(33)
    c.push(4)
    c.push(0)
    c.push(209)
    // strb w5, [x1]                  0x39000025
    c.push(37)
    c.push(0)
    c.push(0)
    c.push(57)
    // add x2, x2, #1                0x91000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(145)
    // mov x0, x4  (quotient)        0xAA0403E0
    c.push(224)
    c.push(3)
    c.push(4)
    c.push(170)
    // cbnz x0, -8 (back to loop)    0xB5FFFF00
    c.push(0)
    c.push(255)
    c.push(255)
    c.push(181)

    // ── write section: prepend '-' if negative ──
    // cbz x19, +5 (skip minus)      0xB40000B3
    c.push(179)
    c.push(0)
    c.push(0)
    c.push(180)
    // mov w5, #45  (ASCII '-')      0x528005A5
    c.push(165)
    c.push(5)
    c.push(128)
    c.push(82)
    // sub x1, x1, #1                0xD1000421
    c.push(33)
    c.push(4)
    c.push(0)
    c.push(209)
    // strb w5, [x1]                  0x39000025
    c.push(37)
    c.push(0)
    c.push(0)
    c.push(57)
    // add x2, x2, #1                0x91000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(145)

    // ── syscall write(1, x1, x2) ──
    // mov x0, #1  (fd=stdout)       0xD2800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #4 (SYS_write)       0xD2800090
    c.push(144)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)

    // ── print newline ──
    // mov w3, #10                    0x52800143
    c.push(67)
    c.push(1)
    c.push(128)
    c.push(82)
    // strb w3, [sp]                  0x390003E3
    c.push(227)
    c.push(3)
    c.push(0)
    c.push(57)
    // mov x0, #1                     0xD2800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x1, sp                     0x910003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(145)
    // mov x2, #1                     0xD2800022
    c.push(34)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #4                    0xD2800090
    c.push(144)
    c.push(0)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)

    // ── epilogue ──
    // add sp, sp, #32                0x910083FF
    c.push(255)
    c.push(131)
    c.push(0)
    c.push(145)
    // ldp x19, x20, [sp], #16       0xA8C153F3
    c.push(243)
    c.push(83)
    c.push(193)
    c.push(168)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)

    return c
}

// ── rt_alloc ─────────────────────────────────────────────────
// alloc(x0=size N) — anonymous mmap allocation with 16-B size header,
// returns user-facing ptr (= header_addr + 16) in x0.
//
// Layout:
//   [header_addr + 0..8]  : stored N (original user size)
//   [header_addr + 8..16] : pad (alignment to 16 B)
//   [header_addr + 16..N+16]: user buffer (returned ptr starts here)
//
// Pair: rt_free recovers header_addr = ptr - 16, reads N from [addr],
// then munmap(addr, N+16). The 16-B header preserves 16-B alignment for
// the returned ptr (mmap pages are page-aligned, plus 16 stays aligned).
//
// HEXA_BACKEND flip · chunk-B phase-H "열한째 increment" (2026-05-26):
// pair-safe alloc/free closure for the #1326 residual (B). Prior rt_alloc
// (48 B raw mmap, no header) is INCOMPATIBLE with libc `free()` AND with
// any pair'd munmap that doesn't know the size — this header form makes
// the alloc/free pair symmetric and size-self-describing.
//
// mmap(NULL, N+16, PROT_READ|PROT_WRITE, MAP_ANON|MAP_PRIVATE, -1, 0)
//   x0 = 0 (addr=NULL)     x3 = 0x1002 (MAP_ANON|MAP_PRIVATE, macOS)
//   x1 = N+16 (mmap size)   x4 = -1 (fd)
//   x2 = 3 (PROT_RW)       x5 = 0 (offset)
//   x16 = 197 (SYS_mmap)
// 17 instructions, 68 bytes.

fn rt_alloc() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // stp x19, x20, [sp, #-16]!     0xA9BF53F3  (save x19 callee-saved)
    c.push(243)
    c.push(83)
    c.push(191)
    c.push(169)
    // mov x19, x0  (save N)         0xAA0003F3
    c.push(243)
    c.push(3)
    c.push(0)
    c.push(170)
    // add x1, x0, #16  (N+16→x1)    0x91004001
    c.push(1)
    c.push(64)
    c.push(0)
    c.push(145)
    // mov x0, #0  (addr=NULL)       0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x2, #3  (PROT_RW)         0xD2800062
    c.push(98)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x3, #0x1002 (MAP)         0xD2820043
    c.push(67)
    c.push(0)
    c.push(130)
    c.push(210)
    // movn x4, #0 (fd=-1)           0x92800004
    c.push(4)
    c.push(0)
    c.push(128)
    c.push(146)
    // mov x5, #0  (offset)          0xD2800005
    c.push(5)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #197 (SYS_mmap)      0xD28018B0
    c.push(176)
    c.push(24)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // str x19, [x0]  (header=N)     0xF9000013
    c.push(19)
    c.push(0)
    c.push(0)
    c.push(249)
    // add x0, x0, #16  (ptr+=16)    0x91004000
    c.push(0)
    c.push(64)
    c.push(0)
    c.push(145)
    // ldp x19, x20, [sp], #16       0xA8C153F3
    c.push(243)
    c.push(83)
    c.push(193)
    c.push(168)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_free ──────────────────────────────────────────────────
// free(x0=user ptr) — recover header, munmap(addr, N+16). Leaf fn.
//
// Pair to rt_alloc above — assumes the input ptr came from rt_alloc
// (i.e. has a 16-B size header at [ptr - 16]). The mmap region was
// allocated with size N+16; munmap also takes N+16.
//
// munmap(addr, length):
//   x0 = addr     (= user_ptr - 16, i.e. the original mmap address)
//   x1 = length   (= stored N + 16)
//   x16 = 73      (SYS_munmap on macOS arm64)
//
// 6 instructions, 24 bytes (leaf — no prologue/epilogue).

fn rt_free() {
    let mut c = []
    // sub x0, x0, #16   (x0 = header addr)   0xD1004000
    c.push(0)
    c.push(64)
    c.push(0)
    c.push(209)
    // ldr x1, [x0]      (x1 = stored N)      0xF9400001
    c.push(1)
    c.push(0)
    c.push(64)
    c.push(249)
    // add x1, x1, #16   (x1 = N + 16)        0x91004021
    c.push(33)
    c.push(64)
    c.push(0)
    c.push(145)
    // mov x16, #73 (SYS_munmap)              0xD2800930
    c.push(48)
    c.push(9)
    c.push(128)
    c.push(210)
    // svc #0x80                              0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // ret                                    0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_str_len ───────────────────────────────────────────────
// str_len(x0=ptr) — length of null-terminated string, returned in x0
// 11 instructions, 44 bytes

fn rt_str_len() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // mov x1, x0  (save ptr)        0xAA0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(170)
    // mov x2, #0  (counter)         0xD2800002
    c.push(2)
    c.push(0)
    c.push(128)
    c.push(210)
    // loop: ldrb w3, [x1, x2]       0x38626823
    c.push(35)
    c.push(104)
    c.push(98)
    c.push(56)
    // cbz w3, +3 (done)             0x34000063
    c.push(99)
    c.push(0)
    c.push(0)
    c.push(52)
    // add x2, x2, #1                0x91000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(145)
    // b -3 (back to loop)           0x17FFFFFD
    c.push(253)
    c.push(255)
    c.push(255)
    c.push(23)
    // done: mov x0, x2 (return len) 0xAA0203E0
    c.push(224)
    c.push(3)
    c.push(2)
    c.push(170)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_memset ────────────────────────────────────────────────
// memset(x0=dst, x1=byte_val, x2=len) — write low byte of x1 to
// dst[0 .. len-1]. Pure byte-store loop; no relocation, no arena
// state, no HexaVal touch — the smallest unimplemented runtime
// leaf after the rt_arena_* / rt_str_len family (B9.6a / F3).
//
// Leaf function (no prologue — like rt_arena_alloc): the loop uses
// only caller-saved x3 as a scratch counter, so no frame is needed.
//
// Algorithm:
//   mov x3, #0            ; i = 0
//   loop: cmp x3, x2      ; i == len?
//         b.hs done       ; if i >= len, return
//         strb w1, [x0, x3]; dst[i] = (byte)val
//         add x3, x3, #1   ; i++
//         b loop
//   done: ret
//
// 7 instructions, 28 bytes. Encodings validated against
