    if len(hfloat) % 4 != 0 { println("  FAIL: rt_hexa_float not aligned"); ok = false }
    if len(henum) % 4 != 0 { println("  FAIL: rt_hexa_enum_str not aligned"); ok = false }
    if len(henumv) % 4 != 0 { println("  FAIL: rt_hexa_enum_str_v not aligned"); ok = false }
