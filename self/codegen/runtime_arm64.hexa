    // mov w0, #0                   0x52800000
    c.push(0); c.push(0); c.push(128); c.push(82)
    // bl _hexa_int [BRANCH26]      0x94000000  @ 0x0C
    c.push(0); c.push(0); c.push(0); c.push(148)
    c.push(253); c.push(123); c.push(193); c.push(168)
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

fn rt_fs_rotate_if_over_classd_reloc_offs() {
    let mut o = []; o.push(12); return o
}
fn rt_fs_rotate_if_over_classd_reloc_kinds() {
    let mut k = []; k.push(2); return k
}

fn test_rt_fs_rotate_if_over_classd() {
    println("test_rt_fs_rotate_if_over_classd (F3 class-D batch3 · 3-arg discard · int(0) replicate)")
    let mut ok = true
    let s = rt_fs_rotate_if_over_classd()
    println("  rt_fs_rotate_if_over_classd : " + to_string(len(s)) + " bytes (24 expected)")
    if len(s) != 24 { println("  FAIL: rt_fs_rotate_if_over_classd expected 24 bytes"); ok = false }
    if s[8] != 0 || s[9] != 0 || s[10] != 128 || s[11] != 82 {
        println("  FAIL: mov w0,#0 mismatch"); ok = false
    }
    if s[12] != 0 || s[13] != 0 || s[14] != 0 || s[15] != 148 {
        println("  FAIL: bl _hexa_int (BRANCH26 @0x0C) mismatch"); ok = false
    }
    if s[20] != 192 || s[21] != 3 || s[22] != 95 || s[23] != 214 {
        println("  FAIL: ret trailer mismatch"); ok = false
    }
    if ok { println("  ALL CHECKS PASS") }
}

test_rt_fs_rotate_if_over_classd()

test_runtime_arm64()
test_neon_string_ops()
test_rt_strdup()
test_rt_strndup()
test_rt_free_noop()
