    let mut c = []
    // mov x2, #0  (index i)          0xD2800002
    c.push(2)
    c.push(0)
    c.push(128)
    c.push(210)
    // loop: ldrb w3, [x1, x2]        0x38626823
    c.push(35)
    c.push(104)
    c.push(98)
    c.push(56)
    // strb w3, [x0, x2]              0x38226803
    c.push(3)
    c.push(104)
    c.push(34)
    c.push(56)
    // cbz w3, done (+3 instrs = +12) 0x34000063
    c.push(99)
    c.push(0)
    c.push(0)
    c.push(52)
    // add x2, x2, #1                 0x91000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(145)
    // b loop (-4 instrs = -16)       0x17FFFFFC
    c.push(252)
    c.push(255)
    c.push(255)
    c.push(23)
    // done: ret                      0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_strncpy ───────────────────────────────────────────────
// strncpy(x0=dst, x1=src, x2=len) — copy at most len bytes of
// NUL-terminated src into dst; if src is shorter than len, the
// remainder of dst (up to len) is NUL-padded. NOT guaranteed
// NUL-terminated when len <= strlen(src) — exact C semantics.
// Two phases: a copy loop that stops at len OR src NUL, then a
// pad loop that zero-fills the rest. Pure byte load/store loops;
// no relocation, no arena state, no HexaVal touch (B9.6a/F3 inc 3).
//
// Algorithm:
//   mov x3, #0           ; i = 0
//   loop: cmp x3, x2     ; i == len?
//         b.hs done      ; bound reached
//         ldrb w4, [x1, x3]
//         strb w4, [x0, x3]
//         add x3, x3, #1
//         cbz w4, pad    ; copied a NUL -> switch to pad
//         b loop
//   pad:  cmp x3, x2
//         b.hs done
//         strb wzr, [x0, x3]   ; dst[i] = 0
//         add x3, x3, #1
//         b pad
//   done: ret
//
// 14 instructions, 56 bytes. Encodings validated against
// `as -arch arm64` disassembly (B9.6a self-emit increment 3).

fn rt_strncpy() {
    let mut c = []
    // mov x3, #0  (counter i)        0xD2800003
    c.push(3)
    c.push(0)
    c.push(128)
    c.push(210)
    // loop: cmp x3, x2               0xEB02007F
    c.push(127)
    c.push(0)
    c.push(2)
    c.push(235)
    // b.hs done (+11 instrs = +44)   0x54000162
    c.push(98)
    c.push(1)
    c.push(0)
    c.push(84)
    // ldrb w4, [x1, x3]              0x38636824
    c.push(36)
    c.push(104)
    c.push(99)
    c.push(56)
    // strb w4, [x0, x3]              0x38236804
    c.push(4)
    c.push(104)
    c.push(35)
    c.push(56)
    // add x3, x3, #1                 0x91000463
    c.push(99)
    c.push(4)
    c.push(0)
    c.push(145)
    // cbz w4, pad (+2 instrs = +8)   0x34000044
    c.push(68)
    c.push(0)
    c.push(0)
    c.push(52)
    // b loop (-6 instrs = -24)       0x17FFFFFA
    c.push(250)
    c.push(255)
    c.push(255)
    c.push(23)
    // pad: cmp x3, x2                0xEB02007F
    c.push(127)
    c.push(0)
    c.push(2)
    c.push(235)
    // b.hs done (+4 instrs = +16)    0x54000082
    c.push(130)
    c.push(0)
    c.push(0)
    c.push(84)
    // strb wzr, [x0, x3]             0x3823681F
    c.push(31)
    c.push(104)
    c.push(35)
    c.push(56)
    // add x3, x3, #1                 0x91000463
    c.push(99)
    c.push(4)
    c.push(0)
    c.push(145)
    // b pad (-4 instrs = -16)        0x17FFFFFC
    c.push(252)
    c.push(255)
    c.push(255)
    c.push(23)
    // done: ret                      0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ═══════════════════════════════════════════════════════════════
// NEON SIMD string operations (HX5: AI-native algorithm replacement)
// ═══════════════════════════════════════════════════════════════
// These replace naive byte-loop string ops with 16-byte-wide NEON
// (Advanced SIMD) operations for 2-5× throughput on aligned strings.
//
// All encodings below have been validated against `as -arch arm64`
// disassembly (see commit notes). Decimals are little-endian bytes.

// ── rt_memcpy_neon ───────────────────────────────────────────
// memcpy(x0=dst, x1=src, x2=len) — NEON 16-byte bulk copy
//
// Algorithm:
//   head_loop: while len >= 16:
//     LD1 {v0.16b}, [x1], #16   // load 16 bytes, post-increment
//     ST1 {v0.16b}, [x0], #16   // store 16 bytes, post-increment
//     sub x2, x2, #16
//   tail_loop: byte-wise copy for remaining len < 16
//
// 15 instructions, 60 bytes

fn rt_memcpy_neon() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // head_loop:
    // cmp x2, #16                    0xF100405F
    c.push(95)
    c.push(64)
    c.push(0)
    c.push(241)
    // b.lt tail_loop (+20 = +5 instrs)  0x540000AB
    c.push(171)
    c.push(0)
    c.push(0)
    c.push(84)
    // ld1 {v0.16b}, [x1], #16        0x4CDF7020
    c.push(32)
    c.push(112)
    c.push(223)
    c.push(76)
    // st1 {v0.16b}, [x0], #16        0x4C9F7000
    c.push(0)
    c.push(112)
    c.push(159)
    c.push(76)
    // sub x2, x2, #16                0xD1004042
    c.push(66)
    c.push(64)
    c.push(0)
    c.push(209)
    // b head_loop (-16 = -4 instrs)  0x17FFFFFB
    c.push(251)
    c.push(255)
    c.push(255)
    c.push(23)
    // tail_loop:
    // cbz x2, done (+20 = +5 instrs) 0xB40000A2
    c.push(162)
    c.push(0)
    c.push(0)
    c.push(180)
    // ldrb w3, [x1], #1              0x38401423
    c.push(35)
    c.push(20)
    c.push(64)
    c.push(56)
    // strb w3, [x0], #1              0x38001403
    c.push(3)
    c.push(20)
    c.push(0)
    c.push(56)
    // sub x2, x2, #1                 0xD1000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(209)
    // b tail_loop (-16 = -4 instrs)  0x17FFFFFC
    c.push(252)
    c.push(255)
    c.push(255)
    c.push(23)
    // done:
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_strlen_neon ───────────────────────────────────────────
// strlen(x0=str) — length of null-terminated string
//
// Algorithm:
//   chunk_loop: load 16 bytes, CMEQ vs 0 → 0xFF where null.
//     UMAXV byte = max of 16 lanes. If max==0 → no null → advance 16.
//     Else → branch to byte_scan (we know null is within this chunk).
//   byte_scan: byte-wise find the exact null position.
//   result: x0 = cur_ptr - original_ptr
//
// NOTE: Reads up to 15 bytes past the null terminator. This matches
// glibc strlen behaviour; safe for null-terminated strings that don't
// straddle a page boundary right at the null. For pathological inputs
// use rt_str_len (byte-wise) above.
//
// 17 instructions, 68 bytes

fn rt_strlen_neon() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // mov x1, x0  (x1 = cursor)      0xAA0003E1
    c.push(225)
    c.push(3)
    c.push(0)
    c.push(170)
    // chunk_loop:
    // ld1 {v0.16b}, [x1]             0x4C407020
    c.push(32)
    c.push(112)
    c.push(64)
    c.push(76)
    // cmeq v0.16b, v0.16b, #0        0x4E209800
    c.push(0)
    c.push(152)
    c.push(32)
    c.push(78)
    // umaxv b2, v0.16b               0x6E30A802
    c.push(2)
    c.push(168)
    c.push(48)
    c.push(110)
    // umov w3, v2.b[0]               0x0E013C43
    c.push(67)
    c.push(60)
    c.push(1)
    c.push(14)
    // cbnz w3, byte_scan (+12 = +3)  0x35000063
    c.push(99)
    c.push(0)
    c.push(0)
    c.push(53)
    // add x1, x1, #16                0x91004021
    c.push(33)
    c.push(64)
    c.push(0)
    c.push(145)
    // b chunk_loop (-24 = -6 instrs) 0x17FFFFFA
    c.push(250)
    c.push(255)
    c.push(255)
    c.push(23)
    // byte_scan:
    // ldrb w4, [x1]                  0x39400024
    c.push(36)
    c.push(0)
    c.push(64)
    c.push(57)
    // cbz w4, found (+12 = +3 instrs) 0x34000064
    c.push(100)
    c.push(0)
    c.push(0)
    c.push(52)
    // add x1, x1, #1                 0x91000421
    c.push(33)
    c.push(4)
    c.push(0)
    c.push(145)
    // b byte_scan (-12 = -3 instrs)  0x17FFFFFD
    c.push(253)
    c.push(255)
    c.push(255)
    c.push(23)
    // found:
    // sub x0, x1, x0                 0xCB000020
    c.push(32)
    c.push(0)
    c.push(0)
    c.push(203)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_memcmp_neon ───────────────────────────────────────────
// memcmp(x0=a, x1=b, x2=len) → x0 = 0 if equal, 1 otherwise
//
// Algorithm:
//   head_loop: while len >= 16:
//     load 16 bytes each, CMEQ → 0xFF where equal, 0x00 where differ.
//     UMINV = min across all 16 lanes. If min==0 → mismatch found → return 1.
//     Else advance both, sub 16 from len.
//   tail_loop: byte-wise compare for remaining len < 16.
//
// 25 instructions, 100 bytes

fn rt_memcmp_neon() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // head_loop:
    // cmp x2, #16                    0xF100405F
    c.push(95)
    c.push(64)
    c.push(0)
    c.push(241)
    // b.lt tail_loop (+36 = +9 instrs)  0x5400012B
    c.push(43)
    c.push(1)
    c.push(0)
    c.push(84)
    // ld1 {v0.16b}, [x0], #16        0x4CDF7000
    c.push(0)
    c.push(112)
    c.push(223)
    c.push(76)
    // ld1 {v1.16b}, [x1], #16        0x4CDF7021
    c.push(33)
    c.push(112)
    c.push(223)
    c.push(76)
    // cmeq v0.16b, v0.16b, v1.16b    0x6E218C00
    c.push(0)
    c.push(140)
    c.push(33)
    c.push(110)
    // uminv b2, v0.16b               0x6E31A802
    c.push(2)
    c.push(168)
    c.push(49)
    c.push(110)
    // umov w3, v2.b[0]               0x0E013C43
    c.push(67)
    c.push(60)
    c.push(1)
    c.push(14)
    // cbz w3, ne (+52 = +13 instrs)  0x340001A3
    c.push(163)
    c.push(1)
    c.push(0)
    c.push(52)
    // sub x2, x2, #16                0xD1004042
    c.push(66)
    c.push(64)
    c.push(0)
    c.push(209)
    // b head_loop (-36 = -9 instrs)  0x17FFFFF7
    c.push(247)
    c.push(255)
    c.push(255)
    c.push(23)
    // tail_loop:
    // cbz x2, eq (+28 = +7 instrs)   0xB40000E2
    c.push(226)
    c.push(0)
    c.push(0)
    c.push(180)
    // ldrb w3, [x0], #1              0x38401403
    c.push(3)
    c.push(20)
    c.push(64)
    c.push(56)
    // ldrb w4, [x1], #1              0x38401424
    c.push(36)
    c.push(20)
    c.push(64)
    c.push(56)
    // sub w5, w3, w4                 0x4B040065
    c.push(101)
    c.push(0)
    c.push(4)
    c.push(75)
    // cbnz w5, ne (+24 = +6 instrs)  0x350000C5
    c.push(197)
    c.push(0)
    c.push(0)
    c.push(53)
    // sub x2, x2, #1                 0xD1000442
    c.push(66)
    c.push(4)
    c.push(0)
    c.push(209)
    // b tail_loop (-24 = -6 instrs)  0x17FFFFFA
    c.push(250)
    c.push(255)
    c.push(255)
    c.push(23)
    // eq:
    // mov x0, xzr  (return 0)        0xAA1F03E0
    c.push(224)
    c.push(3)
    c.push(31)
    c.push(170)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    // ne:
    // mov x0, #1   (return 1)        0xD2800020
    c.push(32)
    c.push(0)
    c.push(128)
    c.push(210)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── NEON self-test ────────────────────────────────────────────

fn test_neon_string_ops() {
    let mcpy = rt_memcpy_neon()
    let slen = rt_strlen_neon()
    let mcmp = rt_memcmp_neon()

    println("")
    println("NEON SIMD string ops (ARM64)")
    println("  rt_memcpy_neon : " + to_string(len(mcpy)) + " bytes")
    println("  rt_strlen_neon : " + to_string(len(slen)) + " bytes")
    println("  rt_memcmp_neon : " + to_string(len(mcmp)) + " bytes")

    let mut ok = true

    // Non-empty
    if len(mcpy) == 0 { println("  FAIL: rt_memcpy_neon empty"); ok = false }
    if len(slen) == 0 { println("  FAIL: rt_strlen_neon empty"); ok = false }
    if len(mcmp) == 0 { println("  FAIL: rt_memcmp_neon empty"); ok = false }

    // < 256 bytes (per spec)
    if len(mcpy) >= 256 { println("  FAIL: rt_memcpy_neon too big"); ok = false }
    if len(slen) >= 256 { println("  FAIL: rt_strlen_neon too big"); ok = false }
    if len(mcmp) >= 256 { println("  FAIL: rt_memcmp_neon too big"); ok = false }

    // Expected exact byte counts (from validated assembly)
    if len(mcpy) != 60 { println("  FAIL: rt_memcpy_neon expected 60, got " + to_string(len(mcpy))); ok = false }
    if len(slen) != 68 { println("  FAIL: rt_strlen_neon expected 68, got " + to_string(len(slen))); ok = false }
    if len(mcmp) != 100 { println("  FAIL: rt_memcmp_neon expected 100, got " + to_string(len(mcmp))); ok = false }

    // 4-byte alignment (ARM64 fixed-width)
    if len(mcpy) % 4 != 0 { println("  FAIL: rt_memcpy_neon not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_strlen_neon not aligned"); ok = false }
    if len(mcmp) % 4 != 0 { println("  FAIL: rt_memcmp_neon not aligned"); ok = false }

    // RET trailer check (last 4 bytes = 192, 3, 95, 214 = 0xD65F03C0)
    let nc = len(mcpy)
    if mcpy[nc - 4] != 192 { println("  FAIL: rt_memcpy_neon no RET"); ok = false }
    if mcpy[nc - 1] != 214 { println("  FAIL: rt_memcpy_neon RET byte3"); ok = false }
    let nl = len(slen)
    if slen[nl - 4] != 192 { println("  FAIL: rt_strlen_neon no RET"); ok = false }
    if slen[nl - 1] != 214 { println("  FAIL: rt_strlen_neon RET byte3"); ok = false }
    let nm = len(mcmp)
    if mcmp[nm - 4] != 192 { println("  FAIL: rt_memcmp_neon no RET"); ok = false }
    if mcmp[nm - 1] != 214 { println("  FAIL: rt_memcmp_neon RET byte3"); ok = false }

    // Verify first LD1 instruction in memcpy is at offset 16 (after 4-instr prologue)
    // Expected bytes: 32, 112, 223, 76 (0x4CDF7020 little-endian)
    if mcpy[16] != 32 { println("  FAIL: rt_memcpy_neon LD1 byte0 != 32"); ok = false }
    if mcpy[17] != 112 { println("  FAIL: rt_memcpy_neon LD1 byte1 != 112"); ok = false }
    if mcpy[18] != 223 { println("  FAIL: rt_memcpy_neon LD1 byte2 != 223"); ok = false }
    if mcpy[19] != 76 { println("  FAIL: rt_memcpy_neon LD1 byte3 != 76"); ok = false }

    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ═══════════════════════════════════════════════════════════════
// Arena bump allocator (HX5: AI-native algorithm replacement)
// ═══════════════════════════════════════════════════════════════
// AI-native vector — arena bump allocator (docs/ai-native.md).
//
// Motivation: ML workloads allocate many tensors then free all at once.
// libc malloc pays 10-50x overhead per call (free-list walk, coalesce,
// metadata, fragmentation). A bump allocator trades per-object free
// for O(1) alloc and bulk reset, which is exactly the shape of tensor
// allocation in a forward/backward pass.
//
// Layout:
//   arena_state (24 bytes, shared across the 4 fns below):
//     [ 0] base : pointer to mmap'd region (set by init, cleared by release)
//     [ 8] ptr  : next free byte (bump pointer; reset() sets ptr = base)
//     [16] end  : base + size (mmap'd limit)
//
// State access convention (PR #1297 residual #2 — widened to adrp+add):
//   Each fn emits an `adrp x9, _arena_state@PAGE` + `add x9, x9,
//   _arena_state@PAGEOFF` pair (8 bytes) as a placeholder — the linker
//   (`tool/hexa_ld.hexa` PR #1282 + `macho_obj_wrap_v2` PR #1302) emits
//   matching ARM64_RELOC_PAGE21 (kind=3) + ARM64_RELOC_PAGEOFF12
//   (kind=4) records at the same byte offsets, patching the adrp page
//   immediate (immhi:immlo) + add unscaled imm12 so x9 lands on the
//   absolute VM address of the shared `_arena_state` blob in __const.
//   This supersedes the prior single `adr x9, #0` (4 B) placeholder
//   which had no matching reloc kind in the v1 wrap. Each fn stays
//   self-contained for byte-count testing while all 4 share one state
//   region.
//
// macOS ARM64 syscall ABI:
//   SYS_mmap  = 197  (x0=addr, x1=len, x2=prot, x3=flags, x4=fd, x5=off)
//   SYS_munmap = 73  (x0=addr, x1=len)
//   All syscalls use svc #0x80, return value in x0.

// ── rt_arena_init ────────────────────────────────────────────
// arena_init(x0=size_mb) — mmap(size_mb << 20) anonymous RW region.
// Stores base/ptr/end into the shared arena_state.
// 19 instructions, 76 bytes (was 72; +4 B from adr→adrp+add widening
// per PR #1297 residual #2).
//
// macOS svc #0x80 (mmap) CLOBBERS the syscall-arg registers on return
// (x0 = base, x1 = 0). The size (x1 = size_mb << 20) must therefore be
// preserved across the svc into a register the kernel does NOT touch —
// empirically x6..x15 all survive the macOS mmap svc (verified by a
// standalone svc probe). We save the size into x6 BEFORE the syscall and
// use x6 (not the clobbered x1) in the post-svc `add x10, x0, x6`
// (end = base + size). Computing `end` from the stale x1 yielded
// end == base → zero-capacity arena → every arena_alloc failed its bound
// check and returned NULL.

fn rt_arena_init() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // lsl x1, x0, #20  (MB -> bytes) 0xD36CAC01
    c.push(1)
    c.push(172)
    c.push(108)
    c.push(211)
    // mov x6, x1  (save size; svc clobbers x1)  0xAA0103E6
    c.push(230)
    c.push(3)
    c.push(1)
    c.push(170)
    // mov x0, #0  (addr=NULL)        0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x2, #3  (PROT_RW)          0xD2800062
    c.push(98)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x3, #0x1002 (MAP_ANON|PRIV)0xD2820043
    c.push(67)
    c.push(0)
    c.push(130)
    c.push(210)
    // movn x4, #0 (fd=-1)            0x92800004
    c.push(4)
    c.push(0)
    c.push(128)
    c.push(146)
    // mov x5, #0  (offset=0)         0xD2800005
    c.push(5)
    c.push(0)
    c.push(128)
    c.push(210)
    // mov x16, #197 (SYS_mmap)       0xD28018B0
    c.push(176)
    c.push(24)
    c.push(128)
    c.push(210)
    // svc #0x80                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // str x0, [x9]       (state.base = x0)          0xF9000120
    c.push(32)
    c.push(1)
    c.push(0)
    c.push(249)
    // str x0, [x9, #8]   (state.ptr  = x0)          0xF9000520
    c.push(32)
    c.push(5)
    c.push(0)
    c.push(249)
    // add x10, x0, x6    (x10 = base + saved size)   0x8B06000A
    c.push(10)
    c.push(0)
    c.push(6)
    c.push(139)
    // str x10, [x9, #16] (state.end = base+size)    0xF900092A
    c.push(42)
    c.push(9)
    c.push(0)
    c.push(249)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_arena_alloc ───────────────────────────────────────────
// arena_alloc(x0=size) — bump ptr by size, return OLD ptr.
// Returns 0 (NULL) on overflow (new_ptr > state.end).
// Leaf function: no prologue (saves 2 instructions vs rt_alloc).
//
// Hot-path cost (overflow-free):
//   2 loads + 1 add + 1 cmp + 1 branch + 1 store + 1 mov + ret = 7 ops
//
// 12 instructions, 48 bytes (was 44; +4 B from adr→adrp+add widening
// per PR #1297 residual #2). Still < 64 — hot-path spec preserved.

fn rt_arena_alloc() {
    let mut c = []
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x1, [x9, #8]   (x1 = state.ptr = old)     0xF9400521
    c.push(33)
    c.push(5)
    c.push(64)
    c.push(249)
    // add x2, x1, x0     (x2 = new_ptr)             0x8B000022
    c.push(34)
    c.push(0)
    c.push(0)
    c.push(139)
    // ldr x3, [x9, #16]  (x3 = state.end)           0xF9400923
    c.push(35)
    c.push(9)
    c.push(64)
    c.push(249)
    // cmp x2, x3                                     0xEB03005F
    c.push(95)
    c.push(0)
    c.push(3)
    c.push(235)
    // b.hi +2 (to oom)                               0x54000088
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(84)
    // str x2, [x9, #8]   (state.ptr = new_ptr)      0xF9000522
    c.push(34)
    c.push(5)
    c.push(0)
    c.push(249)
    // mov x0, x1         (return old_ptr)           0xAA0103E0
    c.push(224)
    c.push(3)
    c.push(1)
    c.push(170)
    // ret                                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    // oom: mov x0, #0  (return NULL on overflow)    0xD2800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(210)
    // ret                                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_arena_reset ───────────────────────────────────────────
// arena_reset() — state.ptr = state.base (bulk free).
// The mmap'd region is kept for subsequent allocations.
// 5 instructions, 20 bytes (was 16; +4 B from adr→adrp+add widening
// per PR #1297 residual #2).

fn rt_arena_reset() {
    let mut c = []
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x0, [x9]       (x0 = state.base)          0xF9400120
    c.push(32)
    c.push(1)
    c.push(64)
    c.push(249)
    // str x0, [x9, #8]   (state.ptr = base)         0xF9000520
    c.push(32)
    c.push(5)
    c.push(0)
    c.push(249)
    // ret                                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── rt_arena_release ─────────────────────────────────────────
// arena_release() — munmap(base, end-base); zero state.
// Called at process teardown or when shrinking memory pressure.
// 17 instructions, 68 bytes (was 60; +8 B from TWO adr→adrp+add
// widenings per PR #1297 residual #2 — one before munmap, one after).

fn rt_arena_release() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c.push(253)
    c.push(123)
    c.push(191)
    c.push(169)
    // mov x29, sp                    0x910003FD
    c.push(253)
    c.push(3)
    c.push(0)
    c.push(145)
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // ldr x0, [x9]       (x0 = state.base)          0xF9400120
    c.push(32)
    c.push(1)
    c.push(64)
    c.push(249)
    // ldr x1, [x9, #16]  (x1 = state.end)           0xF9400921
    c.push(33)
    c.push(9)
    c.push(64)
    c.push(249)
    // sub x1, x1, x0     (x1 = size = end-base)     0xCB000021
    c.push(33)
    c.push(0)
    c.push(0)
    c.push(203)
    // mov x16, #73 (SYS_munmap)                     0xD2800930
    c.push(48)
    c.push(9)
    c.push(128)
    c.push(210)
    // svc #0x80                                      0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // adrp x9, _arena_state@PAGE  (PAGE21 reloc patches)  0x90000009
    c.push(9)
    c.push(0)
    c.push(0)
    c.push(144)
    // add  x9, x9, _arena_state@PAGEOFF (PAGEOFF12 reloc) 0x91000129
    c.push(41)
    c.push(1)
    c.push(0)
    c.push(145)
    // mov x10, #0                                    0xD280000A
    c.push(10)
    c.push(0)
    c.push(128)
    c.push(210)
    // str x10, [x9]      (state.base = 0)           0xF900012A
    c.push(42)
    c.push(1)
    c.push(0)
    c.push(249)
    // str x10, [x9, #8]  (state.ptr = 0)            0xF900052A
    c.push(42)
    c.push(5)
    c.push(0)
    c.push(249)
    // str x10, [x9, #16] (state.end = 0)            0xF900092A
    c.push(42)
    c.push(9)
    c.push(0)
    c.push(249)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c.push(253)
    c.push(123)
    c.push(193)
    c.push(168)
    // ret                            0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// ── self-test ────────────────────────────────────────────────

fn test_runtime_arm64() {
    let exit_bytes = rt_exit()
    let pstr = rt_print_str()
    let pln = rt_println()
    let pint = rt_print_int()
    let alloc_bytes = rt_alloc()
    let free_bytes = rt_free()
    let slen = rt_str_len()
    let mset = rt_memset()
    let mcmp = rt_memcmp()
    let mcpy = rt_memcpy()
    let mmove = rt_memmove()
    let scmp = rt_strcmp()
    let sncmp = rt_strncmp()
    let schr = rt_strchr()
    let srchr = rt_strrchr()
    let scpy = rt_strcpy()
    let sncpy = rt_strncpy()
    let ainit = rt_arena_init()
    let aalloc = rt_arena_alloc()
    let areset = rt_arena_reset()
    let arel = rt_arena_release()

    println("runtime_arm64 — ARM64 machine code byte arrays")
    println("  rt_exit          : " + to_string(len(exit_bytes)) + " bytes")
    println("  rt_print_str     : " + to_string(len(pstr)) + " bytes")
    println("  rt_println       : " + to_string(len(pln)) + " bytes")
    println("  rt_print_int     : " + to_string(len(pint)) + " bytes")
    println("  rt_alloc         : " + to_string(len(alloc_bytes)) + " bytes")
    println("  rt_free          : " + to_string(len(free_bytes)) + " bytes")
    println("  rt_str_len       : " + to_string(len(slen)) + " bytes")
    println("  rt_memset        : " + to_string(len(mset)) + " bytes")
    println("  rt_memcmp        : " + to_string(len(mcmp)) + " bytes")
    println("  rt_memcpy        : " + to_string(len(mcpy)) + " bytes")
    println("  rt_memmove       : " + to_string(len(mmove)) + " bytes")
    println("  rt_strcmp        : " + to_string(len(scmp)) + " bytes")
    println("  rt_strncmp       : " + to_string(len(sncmp)) + " bytes")
    println("  rt_strchr        : " + to_string(len(schr)) + " bytes")
    println("  rt_strrchr       : " + to_string(len(srchr)) + " bytes")
    println("  rt_strcpy        : " + to_string(len(scpy)) + " bytes")
    println("  rt_strncpy       : " + to_string(len(sncpy)) + " bytes")
    println("  rt_arena_init    : " + to_string(len(ainit)) + " bytes")
    println("  rt_arena_alloc   : " + to_string(len(aalloc)) + " bytes")
    println("  rt_arena_reset   : " + to_string(len(areset)) + " bytes")
    println("  rt_arena_release : " + to_string(len(arel)) + " bytes")

    // Verify sizes match expected instruction counts * 4
    let mut ok = true
    if len(exit_bytes) != 16 { println("  FAIL: rt_exit expected 16, got " + to_string(len(exit_bytes))); ok = false }
    if len(pstr) != 36 { println("  FAIL: rt_print_str expected 36, got " + to_string(len(pstr))); ok = false }
    if len(pln) != 52 { println("  FAIL: rt_println expected 52, got " + to_string(len(pln))); ok = false }
    if len(pint) != 184 { println("  FAIL: rt_print_int expected 184, got " + to_string(len(pint))); ok = false }
    // rt_alloc 48 → 68 (+20 · header pattern: stp x19/x20, mov x19=N,
    //   add x1=N+16, str x19, add x0+=16, ldp x19/x20). Pair-safe with rt_free.
    if len(alloc_bytes) != 68 { println("  FAIL: rt_alloc expected 68, got " + to_string(len(alloc_bytes))); ok = false }
    if len(free_bytes) != 24 { println("  FAIL: rt_free expected 24, got " + to_string(len(free_bytes))); ok = false }
    if len(slen) != 44 { println("  FAIL: rt_str_len expected 44, got " + to_string(len(slen))); ok = false }
    // rt_memset 28 (B9.6a / F3 increment): 7-instr leaf byte-store loop.
    if len(mset) != 28 { println("  FAIL: rt_memset expected 28, got " + to_string(len(mset))); ok = false }
    // B9.6a / F3 increment 2 — 4 reloc-free leaf primitives:
    //   rt_memcmp  13-instr 52 B  (byte-load compare loop, signed diff)
    //   rt_memcpy   8-instr 32 B  (scalar forward byte copy)
    //   rt_memmove 16-instr 64 B  (overlap-safe fwd/bwd copy)
    //   rt_strcmp  12-instr 48 B  (NUL-terminated compare, signed diff)
    if len(mcmp) != 52 { println("  FAIL: rt_memcmp expected 52, got " + to_string(len(mcmp))); ok = false }
    if len(mcpy) != 32 { println("  FAIL: rt_memcpy expected 32, got " + to_string(len(mcpy))); ok = false }
    if len(mmove) != 64 { println("  FAIL: rt_memmove expected 64, got " + to_string(len(mmove))); ok = false }
    if len(scmp) != 48 { println("  FAIL: rt_strcmp expected 48, got " + to_string(len(scmp))); ok = false }
    // B9.6a / F3 increment 3 — 5 reloc-free leaf string primitives:
    //   rt_strncmp 14-instr 56 B  (bounded compare, len OR NUL stop)
    //   rt_strchr  11-instr 44 B  (first occurrence, NULL if absent)
    //   rt_strrchr 11-instr 44 B  (last occurrence, NULL if absent)
    //   rt_strcpy   7-instr 28 B  (NUL-terminated copy, returns dst)
    //   rt_strncpy 14-instr 56 B  (bounded copy + NUL pad, C semantics)
    if len(sncmp) != 56 { println("  FAIL: rt_strncmp expected 56, got " + to_string(len(sncmp))); ok = false }
    if len(schr) != 44 { println("  FAIL: rt_strchr expected 44, got " + to_string(len(schr))); ok = false }
    if len(srchr) != 44 { println("  FAIL: rt_strrchr expected 44, got " + to_string(len(srchr))); ok = false }
    if len(scpy) != 28 { println("  FAIL: rt_strcpy expected 28, got " + to_string(len(scpy))); ok = false }
    if len(sncpy) != 56 { println("  FAIL: rt_strncpy expected 56, got " + to_string(len(sncpy))); ok = false }
    // PR #1297 residual #2 — adr (4 B) → adrp+add (8 B) widening for
    // _arena_state PAGE21+PAGEOFF12 reloc machinery. Per-fn deltas:
    //   init   72 → 76 (+4 · 1 site)
    //   alloc  44 → 48 (+4 · 1 site)
    //   reset  16 → 20 (+4 · 1 site)
    //   release 60 → 68 (+8 · 2 sites)
    if len(ainit) != 76 { println("  FAIL: rt_arena_init expected 76, got " + to_string(len(ainit))); ok = false }
    if len(aalloc) != 48 { println("  FAIL: rt_arena_alloc expected 48, got " + to_string(len(aalloc))); ok = false }
    if len(areset) != 20 { println("  FAIL: rt_arena_reset expected 20, got " + to_string(len(areset))); ok = false }
    if len(arel) != 68 { println("  FAIL: rt_arena_release expected 68, got " + to_string(len(arel))); ok = false }

    // Spec constraint: rt_arena_alloc must be < 64 bytes (hot path)
    if len(aalloc) >= 64 { println("  FAIL: rt_arena_alloc must be < 64 bytes"); ok = false }

    // Verify all sizes are multiples of 4 (ARM64 fixed-width)
    if len(exit_bytes) % 4 != 0 { println("  FAIL: rt_exit not aligned"); ok = false }
    if len(pstr) % 4 != 0 { println("  FAIL: rt_print_str not aligned"); ok = false }
    if len(pln) % 4 != 0 { println("  FAIL: rt_println not aligned"); ok = false }
    if len(pint) % 4 != 0 { println("  FAIL: rt_print_int not aligned"); ok = false }
    if len(alloc_bytes) % 4 != 0 { println("  FAIL: rt_alloc not aligned"); ok = false }
    if len(free_bytes) % 4 != 0 { println("  FAIL: rt_free not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_str_len not aligned"); ok = false }
    if len(mset) % 4 != 0 { println("  FAIL: rt_memset not aligned"); ok = false }
    if len(mcmp) % 4 != 0 { println("  FAIL: rt_memcmp not aligned"); ok = false }
    if len(mcpy) % 4 != 0 { println("  FAIL: rt_memcpy not aligned"); ok = false }
    if len(mmove) % 4 != 0 { println("  FAIL: rt_memmove not aligned"); ok = false }
    if len(scmp) % 4 != 0 { println("  FAIL: rt_strcmp not aligned"); ok = false }
    if len(sncmp) % 4 != 0 { println("  FAIL: rt_strncmp not aligned"); ok = false }
    if len(schr) % 4 != 0 { println("  FAIL: rt_strchr not aligned"); ok = false }
    if len(srchr) % 4 != 0 { println("  FAIL: rt_strrchr not aligned"); ok = false }
    if len(scpy) % 4 != 0 { println("  FAIL: rt_strcpy not aligned"); ok = false }
    if len(sncpy) % 4 != 0 { println("  FAIL: rt_strncpy not aligned"); ok = false }
    if len(ainit) % 4 != 0 { println("  FAIL: rt_arena_init not aligned"); ok = false }
    if len(aalloc) % 4 != 0 { println("  FAIL: rt_arena_alloc not aligned"); ok = false }
    if len(areset) % 4 != 0 { println("  FAIL: rt_arena_reset not aligned"); ok = false }
    if len(arel) % 4 != 0 { println("  FAIL: rt_arena_release not aligned"); ok = false }

    // Verify RET trailer: last 4 bytes = 192, 3, 95, 214 (0xD65F03C0)
    // (except rt_exit which ends with svc)
    let n = len(pstr)
    if pstr[n - 4] != 192 { println("  FAIL: rt_print_str no RET"); ok = false }
    let n2 = len(pln)
    if pln[n2 - 4] != 192 { println("  FAIL: rt_println no RET"); ok = false }
    let n3 = len(pint)
    if pint[n3 - 4] != 192 { println("  FAIL: rt_print_int no RET"); ok = false }
    let n4 = len(alloc_bytes)
    if alloc_bytes[n4 - 4] != 192 { println("  FAIL: rt_alloc no RET"); ok = false }
    let nf = len(free_bytes)
    if free_bytes[nf - 4] != 192 { println("  FAIL: rt_free no RET"); ok = false }
    let n5 = len(slen)
    if slen[n5 - 4] != 192 { println("  FAIL: rt_str_len no RET"); ok = false }
    let nm = len(mset)
    if mset[nm - 4] != 192 { println("  FAIL: rt_memset no RET"); ok = false }
    // F3 inc 2 — all four leaves end with ret (192,3,95,214).
    let ncm = len(mcmp)
    if mcmp[ncm - 4] != 192 { println("  FAIL: rt_memcmp no RET"); ok = false }
    let ncp = len(mcpy)
    if mcpy[ncp - 4] != 192 { println("  FAIL: rt_memcpy no RET"); ok = false }
    let nmv = len(mmove)
    if mmove[nmv - 4] != 192 { println("  FAIL: rt_memmove no RET"); ok = false }
    let nsc = len(scmp)
    if scmp[nsc - 4] != 192 { println("  FAIL: rt_strcmp no RET"); ok = false }
    // F3 inc 3 — all five string leaves end with ret (192,3,95,214).
    let nsnc = len(sncmp)
    if sncmp[nsnc - 4] != 192 { println("  FAIL: rt_strncmp no RET"); ok = false }
    let nsch = len(schr)
    if schr[nsch - 4] != 192 { println("  FAIL: rt_strchr no RET"); ok = false }
    let nsrc = len(srchr)
    if srchr[nsrc - 4] != 192 { println("  FAIL: rt_strrchr no RET"); ok = false }
    let nscp = len(scpy)
    if scpy[nscp - 4] != 192 { println("  FAIL: rt_strcpy no RET"); ok = false }
    let nsnp = len(sncpy)
    if sncpy[nsnp - 4] != 192 { println("  FAIL: rt_strncpy no RET"); ok = false }
    let na1 = len(ainit)
    if ainit[na1 - 4] != 192 { println("  FAIL: rt_arena_init no RET"); ok = false }
    let na2 = len(aalloc)
    if aalloc[na2 - 4] != 192 { println("  FAIL: rt_arena_alloc no RET"); ok = false }
    let na3 = len(areset)
    if areset[na3 - 4] != 192 { println("  FAIL: rt_arena_reset no RET"); ok = false }
    let na4 = len(arel)
    if arel[na4 - 4] != 192 { println("  FAIL: rt_arena_release no RET"); ok = false }

    // Verify SVC trailer on rt_exit: last 4 bytes = 1, 16, 0, 212 (0xD4001001)
    let ne = len(exit_bytes)
    if exit_bytes[ne - 4] != 1 { println("  FAIL: rt_exit no SVC"); ok = false }

    // Verify rt_arena_init contains mov x16, #197 (SYS_mmap)
    //   encoded as 0xD28018B0 → little-endian bytes 176, 24, 128, 210.
    let mut found_mmap = false
    let mut i = 0
    while i + 3 < len(ainit) {
        if ainit[i] == 176 {
            if ainit[i + 1] == 24 {
                if ainit[i + 2] == 128 {
                    if ainit[i + 3] == 210 {
                        found_mmap = true
                    }
                }
            }
        }
        i = i + 1
    }
    if !found_mmap { println("  FAIL: rt_arena_init missing mov x16, #197 (SYS_mmap)"); ok = false }

    // Verify rt_arena_init contains svc #0x80 (bytes 1, 16, 0, 212)
    let mut found_svc = false
    let mut j = 0
    while j + 3 < len(ainit) {
        if ainit[j] == 1 {
            if ainit[j + 1] == 16 {
                if ainit[j + 2] == 0 {
                    if ainit[j + 3] == 212 {
                        found_svc = true
                    }
                }
            }
        }
        j = j + 1
    }
    if !found_svc { println("  FAIL: rt_arena_init missing svc #0x80"); ok = false }

    // Verify rt_arena_release contains mov x16, #73 (SYS_munmap)
    //   encoded as 0xD2800930 → little-endian bytes 48, 9, 128, 210.
    let mut found_munmap = false
    let mut k = 0
    while k + 3 < len(arel) {
        if arel[k] == 48 {
            if arel[k + 1] == 9 {
                if arel[k + 2] == 128 {
                    if arel[k + 3] == 210 {
                        found_munmap = true
                    }
                }
            }
        }
        k = k + 1
    }
    if !found_munmap { println("  FAIL: rt_arena_release missing mov x16, #73 (SYS_munmap)"); ok = false }

    // Verify rt_free contains mov x16, #73 (SYS_munmap) — pair-safe with rt_alloc.
    //   encoded as 0xD2800930 → little-endian bytes 48, 9, 128, 210.
    let mut found_free_munmap = false
    let mut kf = 0
    while kf + 3 < len(free_bytes) {
        if free_bytes[kf] == 48 {
            if free_bytes[kf + 1] == 9 {
                if free_bytes[kf + 2] == 128 {
                    if free_bytes[kf + 3] == 210 {
                        found_free_munmap = true
                    }
                }
            }
        }
        kf = kf + 1
    }
    if !found_free_munmap { println("  FAIL: rt_free missing mov x16, #73 (SYS_munmap)"); ok = false }

    // Verify rt_alloc contains add x1, x0, #16 (header offset adjust).
    //   encoded as 0x91004001 → little-endian bytes 1, 64, 0, 145.
    let mut found_alloc_hdr_add = false
    let mut ka = 0
    while ka + 3 < len(alloc_bytes) {
        if alloc_bytes[ka] == 1 {
            if alloc_bytes[ka + 1] == 64 {
                if alloc_bytes[ka + 2] == 0 {
                    if alloc_bytes[ka + 3] == 145 {
                        found_alloc_hdr_add = true
                    }
                }
            }
        }
        ka = ka + 1
    }
    if !found_alloc_hdr_add { println("  FAIL: rt_alloc missing add x1, x0, #16 (header math)"); ok = false }

    // Verify rt_alloc contains str x19, [x0] (write header).
    //   encoded as 0xF9000013 → little-endian bytes 19, 0, 0, 249.
    let mut found_alloc_str = false
    let mut ks = 0
    while ks + 3 < len(alloc_bytes) {
        if alloc_bytes[ks] == 19 {
            if alloc_bytes[ks + 1] == 0 {
                if alloc_bytes[ks + 2] == 0 {
                    if alloc_bytes[ks + 3] == 249 {
                        found_alloc_str = true
                    }
                }
            }
        }
        ks = ks + 1
    }
    if !found_alloc_str { println("  FAIL: rt_alloc missing str x19, [x0] (header write)"); ok = false }

    // Verify rt_memset contains strb w1, [x0, x3] (the byte-store body).
    //   encoded as 0x38236801 → little-endian bytes 1, 104, 35, 56.
    let mut found_memset_strb = false
    let mut km = 0
    while km + 3 < len(mset) {
        if mset[km] == 1 {
            if mset[km + 1] == 104 {
                if mset[km + 2] == 35 {
                    if mset[km + 3] == 56 {
                        found_memset_strb = true
                    }
                }
            }
        }
        km = km + 1
    }
    if !found_memset_strb { println("  FAIL: rt_memset missing strb w1, [x0, x3] (byte store)"); ok = false }

    // Verify rt_memcmp contains subs w6, w4, w5 (the compare body).
    //   encoded as 0x6B050086 → little-endian bytes 134, 0, 5, 107.
    let mut found_memcmp_subs = false
    let mut ic = 0
    while ic + 3 < len(mcmp) {
        if mcmp[ic] == 134 {
            if mcmp[ic + 1] == 0 {
                if mcmp[ic + 2] == 5 {
                    if mcmp[ic + 3] == 107 {
                        found_memcmp_subs = true
                    }
                }
            }
        }
        ic = ic + 1
    }
    if !found_memcmp_subs { println("  FAIL: rt_memcmp missing subs w6, w4, w5 (compare)"); ok = false }

    // Verify rt_memcpy contains ldrb w4, [x1, x3] (the source load).
    //   encoded as 0x38636824 → little-endian bytes 36, 104, 99, 56.
    let mut found_memcpy_ldrb = false
    let mut ip = 0
    while ip + 3 < len(mcpy) {
        if mcpy[ip] == 36 {
            if mcpy[ip + 1] == 104 {
                if mcpy[ip + 2] == 99 {
                    if mcpy[ip + 3] == 56 {
                        found_memcpy_ldrb = true
                    }
                }
            }
        }
        ip = ip + 1
    }
    if !found_memcpy_ldrb { println("  FAIL: rt_memcpy missing ldrb w4, [x1, x3] (src load)"); ok = false }

    // Verify rt_memmove contains cmp x0, x1 (the direction decision).
    //   encoded as 0xEB01001F → little-endian bytes 31, 0, 1, 235.
    let mut found_memmove_cmp = false
    let mut iv = 0
    while iv + 3 < len(mmove) {
        if mmove[iv] == 31 {
            if mmove[iv + 1] == 0 {
                if mmove[iv + 2] == 1 {
                    if mmove[iv + 3] == 235 {
                        found_memmove_cmp = true
                    }
                }
            }
        }
        iv = iv + 1
    }
    if !found_memmove_cmp { println("  FAIL: rt_memmove missing cmp x0, x1 (dir decision)"); ok = false }

    // Verify rt_strcmp contains cbz w4, eq (the NUL-terminator stop).
    //   encoded as 0x34000064 → little-endian bytes 100, 0, 0, 52.
    let mut found_strcmp_cbz = false
    let mut isc = 0
    while isc + 3 < len(scmp) {
        if scmp[isc] == 100 {
            if scmp[isc + 1] == 0 {
                if scmp[isc + 2] == 0 {
                    if scmp[isc + 3] == 52 {
                        found_strcmp_cbz = true
                    }
                }
            }
        }
        isc = isc + 1
    }
    if !found_strcmp_cbz { println("  FAIL: rt_strcmp missing cbz w4 (NUL stop)"); ok = false }

    // Verify rt_strncmp contains subs w6, w4, w5 (the compare body).
    //   encoded as 0x6B050086 → little-endian bytes 134, 0, 5, 107.
    let mut found_strncmp_subs = false
    let mut isn = 0
    while isn + 3 < len(sncmp) {
        if sncmp[isn] == 134 {
            if sncmp[isn + 1] == 0 {
                if sncmp[isn + 2] == 5 {
                    if sncmp[isn + 3] == 107 {
                        found_strncmp_subs = true
                    }
                }
            }
        }
        isn = isn + 1
    }
    if !found_strncmp_subs { println("  FAIL: rt_strncmp missing subs w6, w4, w5 (compare)"); ok = false }

    // Verify rt_strchr contains add x0, x0, x2 (found-path return ptr).
    //   encoded as 0x8B020000 → little-endian bytes 0, 0, 2, 139.
    let mut found_strchr_add = false
    let mut ich = 0
    while ich + 3 < len(schr) {
        if schr[ich] == 0 {
            if schr[ich + 1] == 0 {
                if schr[ich + 2] == 2 {
                    if schr[ich + 3] == 139 {
                        found_strchr_add = true
                    }
                }
            }
        }
        ich = ich + 1
    }
    if !found_strchr_add { println("  FAIL: rt_strchr missing add x0, x0, x2 (found ptr)"); ok = false }

    // Verify rt_strrchr contains add x4, x0, x2 (record last match).
    //   encoded as 0x8B020004 → little-endian bytes 4, 0, 2, 139.
    let mut found_strrchr_add = false
    let mut irc = 0
    while irc + 3 < len(srchr) {
        if srchr[irc] == 4 {
            if srchr[irc + 1] == 0 {
                if srchr[irc + 2] == 2 {
                    if srchr[irc + 3] == 139 {
                        found_strrchr_add = true
                    }
                }
            }
        }
        irc = irc + 1
    }
    if !found_strrchr_add { println("  FAIL: rt_strrchr missing add x4, x0, x2 (last match)"); ok = false }

    // Verify rt_strcpy contains strb w3, [x0, x2] (the byte store body).
    //   encoded as 0x38226803 → little-endian bytes 3, 104, 34, 56.
    let mut found_strcpy_strb = false
    let mut icp = 0
    while icp + 3 < len(scpy) {
        if scpy[icp] == 3 {
            if scpy[icp + 1] == 104 {
                if scpy[icp + 2] == 34 {
                    if scpy[icp + 3] == 56 {
                        found_strcpy_strb = true
                    }
                }
            }
        }
        icp = icp + 1
    }
    if !found_strcpy_strb { println("  FAIL: rt_strcpy missing strb w3, [x0, x2] (byte store)"); ok = false }

    // Verify rt_strncpy contains strb wzr, [x0, x3] (the NUL-pad store).
    //   encoded as 0x3823681F → little-endian bytes 31, 104, 35, 56.
    let mut found_strncpy_pad = false
    let mut inp = 0
    while inp + 3 < len(sncpy) {
        if sncpy[inp] == 31 {
            if sncpy[inp + 1] == 104 {
                if sncpy[inp + 2] == 35 {
                    if sncpy[inp + 3] == 56 {
                        found_strncpy_pad = true
                    }
                }
            }
        }
        inp = inp + 1
    }
    if !found_strncpy_pad { println("  FAIL: rt_strncpy missing strb wzr, [x0, x3] (NUL pad)"); ok = false }

    if ok {
        println("  ALL CHECKS PASS")
    }
}

test_runtime_arm64()
test_neon_string_ops()
