//   fmov d0, x0          ; move 64 bits into NEON d0
//   cnt v0.8b, v0.8b     ; per-byte popcount (8 lanes)
//   addv b0, v0.8b       ; horizontal sum of the 8 byte lanes
//   fmov w0, s0          ; result (0..64) back to w0
//   ret
