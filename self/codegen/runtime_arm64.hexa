//   cpy: ldrb w4, [x1, x3]; w4 = src[i]
//        strb w4, [x2, x3]; p[i] = w4  (copies the NUL too)
//        cbz w4, cpydone  ; stop after writing the terminator
//        add x3, x3, #1
//        b cpy
