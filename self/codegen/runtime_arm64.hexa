// ── rt_mmap (B9.6-C17 — class-C syscall · 6-arg _cf + errno) ─────────────
// mmap(void *addr, unsigned long len, int prot, int flags, int fd, long off)
// -> void *. A 6-arg svc-_cf — the wrapper itself is a pure svc trap (the arena
// bump-allocator state machine lives elsewhere; this is just the kernel call).
// The arg-widening: addr (ptr, x0) + len (ulong, x1) + off (long, x5) are
// already 64-bit and untouched; the THREE int args prot/flags/fd (x2/x3/x4) are
// each sign-extended. Then the full _cf errno tail; on error x0=-1 == MAP_FAILED
// (the correct pointer error sentinel). runtime.c L1657:
//   hxlcl_mmap(void *addr, unsigned long len, int prot, int flags, int fd, long off) { return (void *)_hxlcl_syscall6_cf(HXLCL_SYS_MMAP, (long)addr, (long)len, (long)prot, (long)flags, (long)fd, off); }
// SYS_MMAP = 197 (0xc5). clang -O2 (== as -arch arm64, errno-define context):
//   sxtw x2,w2 / sxtw x3,w3 / sxtw x4,w4 / mov w16,#197 / svc #0x80 / cset x8,hs
//   / cbz x8,Lret / adrp x8,errno / str w0,[x8] / mov x0,#-1 / ret
// 11-instr 44 B body — same length as rt_waitpid (three widenings + the full
// _cf errno tail). errno reloc sites: 0x1c (PAGE21) / 0x20 (PAGEOFF12) — same
// as rt_waitpid (three prologue instructions push the adrp/str to the same offs).
fn rt_mmap() {
    let mut c = []
    // sxtw x2, w2  (sign-extend prot)       0x93407C42
    c.push(66)
    c.push(124)
    c.push(64)
    c.push(147)
    // sxtw x3, w3  (sign-extend flags)      0x93407C63
    c.push(99)
    c.push(124)
    c.push(64)
    c.push(147)
    // sxtw x4, w4  (sign-extend fd)         0x93407C84
    c.push(132)
    c.push(124)
    c.push(64)
    c.push(147)
    // mov w16, #197  (SYS_MMAP)             0x528018B0
    c.push(176)
    c.push(24)
    c.push(128)
    c.push(82)
    // svc #0x80                             0xD4001001
    c.push(1)
    c.push(16)
    c.push(0)
    c.push(212)
    // cset x8, hs  (capture carry = error)  0x9A9F37E8
    c.push(232)
    c.push(55)
    c.push(159)
    c.push(154)
    // cbz x8, Lret (success → skip errno)   0xB4000088  (+0x10 to ret)
    c.push(136)
    c.push(0)
    c.push(0)
    c.push(180)
    // adrp x8, errno@PAGE  [RELOC PAGE21]   0x90000008  (imm zeroed)
    c.push(8)
    c.push(0)
    c.push(0)
    c.push(144)
    // str w0, [x8, errno@PAGEOFF] [RELOC]   0xB9000100  (imm zeroed)
    c.push(0)
    c.push(1)
    c.push(0)
    c.push(185)
    // mov x0, #-1  (error return = MAP_FAILED) 0x92800000
    c.push(0)
    c.push(0)
    c.push(128)
    c.push(146)
    // ret  (x0 = mapped addr / -1 MAP_FAILED) 0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// Reloc table for rt_mmap — two errno records (adrp/str), same offsets as
// rt_waitpid (three leading widenings match the waitpid prologue length):
//   offset 0x1c (28) → ARM64_RELOC_PAGE21   (kind 3, pcrel adrp)
//   offset 0x20 (32) → ARM64_RELOC_PAGEOFF12 (kind 4, str low-12 bits)
fn rt_mmap_reloc_offs() {
    let mut o = []
    o.push(28)
    o.push(32)
    return o
