    //   int NON-_cf no-errno; fds/x0 ptr untouched, nfds/x1 ZERO-extended via the
    //   FIRST `mov w1,w1` uxtw, timeout/x2 sxtw — trap, ret, NO reloc).
    if len(poll_b) != 20 { println("  FAIL: rt_poll expected 20, got " + to_string(len(poll_b))); ok = false }
    // mov w1,w1 prefix (e1 03 01 2a) — UNSIGNED nfds zero-extended (FIRST uxtw).
    if poll_b[0] != 225 || poll_b[1] != 3 || poll_b[2] != 1 || poll_b[3] != 42 { println("  FAIL: rt_poll missing mov w1,w1 (uxtw nfds)"); ok = false }
    // sxtw x2,w2 (42 7c 40 93) — timeout arg sign-extended.
    if poll_b[4] != 66 || poll_b[5] != 124 || poll_b[6] != 64 || poll_b[7] != 147 { println("  FAIL: rt_poll missing sxtw x2 (timeout)"); ok = false }
    // mov w16,#230 (d0 1c 80 52) — SYS_POLL loaded into x16.
    if poll_b[8] != 208 || poll_b[9] != 28 || poll_b[10] != 128 || poll_b[11] != 82 { println("  FAIL: rt_poll wrong syscall number (SYS_POLL=230)"); ok = false }
    // svc #0x80 at offset 12 (01 10 00 d4) — trap, NO errno tail.
    if poll_b[12] != 1 || poll_b[13] != 16 || poll_b[14] != 0 || poll_b[15] != 212 { println("  FAIL: rt_poll missing svc #0x80 at offset 12"); ok = false }
    // ret trailer (c0 03 5f d6) directly after svc.
    if poll_b[16] != 192 || poll_b[17] != 3 || poll_b[18] != 95 || poll_b[19] != 214 { println("  FAIL: rt_poll no RET (or unexpected errno tail)"); ok = false }
    // B9.6-C16 — class-C syscall ABI: rt_waitpid is an 11-instr 44 B body (FIRST
    //   4-arg svc-_cf; sxtw x0/pid + sxtw x2/options + mov x3,#0 NULL rusage —
    //   status/x1 ptr untouched — then the full _cf errno tail). errno relocs at
    //   0x1c/0x20 (shifted +4 vs lseek for the extra mov x3,#0).
    if len(waitpid_b) != 44 { println("  FAIL: rt_waitpid expected 44, got " + to_string(len(waitpid_b))); ok = false }
    // sxtw x0,w0 prefix (00 7c 40 93) — pid arg sign-extended.
    if waitpid_b[0] != 0 || waitpid_b[1] != 124 || waitpid_b[2] != 64 || waitpid_b[3] != 147 { println("  FAIL: rt_waitpid missing sxtw x0 (pid)"); ok = false }
    // sxtw x2,w2 (42 7c 40 93) — options arg sign-extended (status/x1 untouched).
    if waitpid_b[4] != 66 || waitpid_b[5] != 124 || waitpid_b[6] != 64 || waitpid_b[7] != 147 { println("  FAIL: rt_waitpid missing sxtw x2 (options)"); ok = false }
    // mov x3,#0 (03 00 80 d2) — NULL rusage 4th arg (the 4-arg extension).
    if waitpid_b[8] != 3 || waitpid_b[9] != 0 || waitpid_b[10] != 128 || waitpid_b[11] != 210 { println("  FAIL: rt_waitpid missing mov x3,#0 (NULL rusage)"); ok = false }
    // mov w16,#7 (f0 00 80 52) — SYS_WAIT4 loaded into x16.
    if waitpid_b[12] != 240 || waitpid_b[13] != 0 || waitpid_b[14] != 128 || waitpid_b[15] != 82 { println("  FAIL: rt_waitpid wrong syscall number (SYS_WAIT4=7)"); ok = false }
    // svc #0x80 at offset 16 (01 10 00 d4).
    if waitpid_b[16] != 1 || waitpid_b[17] != 16 || waitpid_b[18] != 0 || waitpid_b[19] != 212 { println("  FAIL: rt_waitpid missing svc #0x80 at offset 16"); ok = false }
    // cset x8,hs at offset 20 (e8 37 9f 9a) — carry-flag capture.
    if waitpid_b[20] != 232 || waitpid_b[21] != 55 || waitpid_b[22] != 159 || waitpid_b[23] != 154 { println("  FAIL: rt_waitpid missing cset (carry capture)"); ok = false }
    // adrp x8,errno at offset 28 (08 00 00 90) — PAGE21 reloc site.
    if waitpid_b[28] != 8 || waitpid_b[29] != 0 || waitpid_b[30] != 0 || waitpid_b[31] != 144 { println("  FAIL: rt_waitpid missing adrp errno (reloc 0x1c)"); ok = false }
    // str w0,[x8] at offset 32 (00 01 00 b9) — PAGEOFF12 reloc site.
    if waitpid_b[32] != 0 || waitpid_b[33] != 1 || waitpid_b[34] != 0 || waitpid_b[35] != 185 { println("  FAIL: rt_waitpid missing str errno (reloc 0x20)"); ok = false }
    // ret trailer (c0 03 5f d6).
    if waitpid_b[40] != 192 || waitpid_b[41] != 3 || waitpid_b[42] != 95 || waitpid_b[43] != 214 { println("  FAIL: rt_waitpid no RET"); ok = false }
    if len(wp_roff) != 2 { println("  FAIL: rt_waitpid expected 2 reloc offsets, got " + to_string(len(wp_roff))); ok = false }
    if wp_roff[0] != 28 || wp_roff[1] != 32 { println("  FAIL: rt_waitpid reloc offsets must be 0x1c,0x20"); ok = false }
    if wp_rkind[0] != 3 || wp_rkind[1] != 4 { println("  FAIL: rt_waitpid reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }
    // B9.6-C17 — class-C syscall ABI: rt_mmap is an 11-instr 44 B body (6-arg
    //   svc-_cf; sxtw x2/prot + sxtw x3/flags + sxtw x4/fd — addr/x0, len/x1,
    //   off/x5 untouched — then the full _cf errno tail; -1 == MAP_FAILED).
    if len(mmap_b) != 44 { println("  FAIL: rt_mmap expected 44, got " + to_string(len(mmap_b))); ok = false }
    // sxtw x2,w2 prefix (42 7c 40 93) — prot arg sign-extended.
    if mmap_b[0] != 66 || mmap_b[1] != 124 || mmap_b[2] != 64 || mmap_b[3] != 147 { println("  FAIL: rt_mmap missing sxtw x2 (prot)"); ok = false }
    // sxtw x3,w3 (63 7c 40 93) — flags arg sign-extended.
    if mmap_b[4] != 99 || mmap_b[5] != 124 || mmap_b[6] != 64 || mmap_b[7] != 147 { println("  FAIL: rt_mmap missing sxtw x3 (flags)"); ok = false }
    // sxtw x4,w4 (84 7c 40 93) — fd arg sign-extended.
    if mmap_b[8] != 132 || mmap_b[9] != 124 || mmap_b[10] != 64 || mmap_b[11] != 147 { println("  FAIL: rt_mmap missing sxtw x4 (fd)"); ok = false }
    // mov w16,#197 (b0 18 80 52) — SYS_MMAP loaded into x16.
    if mmap_b[12] != 176 || mmap_b[13] != 24 || mmap_b[14] != 128 || mmap_b[15] != 82 { println("  FAIL: rt_mmap wrong syscall number (SYS_MMAP=197)"); ok = false }
    // svc #0x80 at offset 16 (01 10 00 d4).
    if mmap_b[16] != 1 || mmap_b[17] != 16 || mmap_b[18] != 0 || mmap_b[19] != 212 { println("  FAIL: rt_mmap missing svc #0x80 at offset 16"); ok = false }
    // cset x8,hs at offset 20 (e8 37 9f 9a) — carry-flag capture.
    if mmap_b[20] != 232 || mmap_b[21] != 55 || mmap_b[22] != 159 || mmap_b[23] != 154 { println("  FAIL: rt_mmap missing cset (carry capture)"); ok = false }
    // adrp x8,errno at offset 28 (08 00 00 90) — PAGE21 reloc site.
    if mmap_b[28] != 8 || mmap_b[29] != 0 || mmap_b[30] != 0 || mmap_b[31] != 144 { println("  FAIL: rt_mmap missing adrp errno (reloc 0x1c)"); ok = false }
    // str w0,[x8] at offset 32 (00 01 00 b9) — PAGEOFF12 reloc site.
    if mmap_b[32] != 0 || mmap_b[33] != 1 || mmap_b[34] != 0 || mmap_b[35] != 185 { println("  FAIL: rt_mmap missing str errno (reloc 0x20)"); ok = false }
    // ret trailer (c0 03 5f d6).
    if mmap_b[40] != 192 || mmap_b[41] != 3 || mmap_b[42] != 95 || mmap_b[43] != 214 { println("  FAIL: rt_mmap no RET"); ok = false }
    if len(mm_roff) != 2 { println("  FAIL: rt_mmap expected 2 reloc offsets, got " + to_string(len(mm_roff))); ok = false }
    if mm_roff[0] != 28 || mm_roff[1] != 32 { println("  FAIL: rt_mmap reloc offsets must be 0x1c,0x20"); ok = false }
    if mm_rkind[0] != 3 || mm_rkind[1] != 4 { println("  FAIL: rt_mmap reloc kinds must be PAGE21(3),PAGEOFF12(4)"); ok = false }

    // Verify all sizes are multiples of 4 (ARM64 fixed-width)
    if len(exit_bytes) % 4 != 0 { println("  FAIL: rt_exit not aligned"); ok = false }
    if len(pstr) % 4 != 0 { println("  FAIL: rt_print_str not aligned"); ok = false }
    if len(pln) % 4 != 0 { println("  FAIL: rt_println not aligned"); ok = false }
    if len(pint) % 4 != 0 { println("  FAIL: rt_print_int not aligned"); ok = false }
    if len(alloc_bytes) % 4 != 0 { println("  FAIL: rt_alloc not aligned"); ok = false }
    if len(free_bytes) % 4 != 0 { println("  FAIL: rt_free not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_str_len not aligned"); ok = false }
    if len(mset) % 4 != 0 { println("  FAIL: rt_memset not aligned"); ok = false }
    if len(mcmp) % 4 != 0 { println("  FAIL: rt_memcmp not aligned"); ok = false }
    if len(mcpy) % 4 != 0 { println("  FAIL: rt_memcpy not aligned"); ok = false }
    if len(mmove) % 4 != 0 { println("  FAIL: rt_memmove not aligned"); ok = false }
    if len(scmp) % 4 != 0 { println("  FAIL: rt_strcmp not aligned"); ok = false }
    if len(sncmp) % 4 != 0 { println("  FAIL: rt_strncmp not aligned"); ok = false }
    if len(schr) % 4 != 0 { println("  FAIL: rt_strchr not aligned"); ok = false }
    if len(srchr) % 4 != 0 { println("  FAIL: rt_strrchr not aligned"); ok = false }
    if len(scpy) % 4 != 0 { println("  FAIL: rt_strcpy not aligned"); ok = false }
    if len(sncpy) % 4 != 0 { println("  FAIL: rt_strncpy not aligned"); ok = false }
    if len(scat) % 4 != 0 { println("  FAIL: rt_strcat not aligned"); ok = false }
    if len(clz) % 4 != 0 { println("  FAIL: rt_clz not aligned"); ok = false }
    if len(ctz) % 4 != 0 { println("  FAIL: rt_ctz not aligned"); ok = false }
    if len(popc) % 4 != 0 { println("  FAIL: rt_popcount not aligned"); ok = false }
    if len(bswap) % 4 != 0 { println("  FAIL: rt_bswap not aligned"); ok = false }
    if len(ainit) % 4 != 0 { println("  FAIL: rt_arena_init not aligned"); ok = false }
    if len(aalloc) % 4 != 0 { println("  FAIL: rt_arena_alloc not aligned"); ok = false }
    if len(areset) % 4 != 0 { println("  FAIL: rt_arena_reset not aligned"); ok = false }
    if len(arel) % 4 != 0 { println("  FAIL: rt_arena_release not aligned"); ok = false }
    if len(hvoid) % 4 != 0 { println("  FAIL: rt_hexa_void not aligned"); ok = false }
    if len(hint) % 4 != 0 { println("  FAIL: rt_hexa_int not aligned"); ok = false }
    if len(hbool) % 4 != 0 { println("  FAIL: rt_hexa_bool not aligned"); ok = false }
    if len(hfloat) % 4 != 0 { println("  FAIL: rt_hexa_float not aligned"); ok = false }
    if len(henum) % 4 != 0 { println("  FAIL: rt_hexa_enum_str not aligned"); ok = false }
    if len(henumv) % 4 != 0 { println("  FAIL: rt_hexa_enum_str_v not aligned"); ok = false }
    if len(gpid) % 4 != 0 { println("  FAIL: rt_getpid not aligned"); ok = false }
    if len(clos) % 4 != 0 { println("  FAIL: rt_close not aligned"); ok = false }
    if len(atoi_b) % 4 != 0 { println("  FAIL: rt_atoi not aligned"); ok = false }
    if len(munmap_b) % 4 != 0 { println("  FAIL: rt_munmap not aligned"); ok = false }
    if len(getuid_b) % 4 != 0 { println("  FAIL: rt_getuid not aligned"); ok = false }
    if len(dup2_b) % 4 != 0 { println("  FAIL: rt_dup2 not aligned"); ok = false }
    if len(mkdir_b) % 4 != 0 { println("  FAIL: rt_mkdir not aligned"); ok = false }
    if len(fstat_b) % 4 != 0 { println("  FAIL: rt_fstat not aligned"); ok = false }
    if len(stat_b) % 4 != 0 { println("  FAIL: rt_stat not aligned"); ok = false }
    if len(kill_b) % 4 != 0 { println("  FAIL: rt_kill not aligned"); ok = false }
    if len(lseek_b) % 4 != 0 { println("  FAIL: rt_lseek not aligned"); ok = false }
    if len(fcntl_b) % 4 != 0 { println("  FAIL: rt_fcntl not aligned"); ok = false }
    if len(ioctl_b) % 4 != 0 { println("  FAIL: rt_ioctl not aligned"); ok = false }
    if len(read_b) % 4 != 0 { println("  FAIL: rt_read not aligned"); ok = false }
    if len(write_b) % 4 != 0 { println("  FAIL: rt_write not aligned"); ok = false }
    if len(select_b) % 4 != 0 { println("  FAIL: rt_select not aligned"); ok = false }
    if len(poll_b) % 4 != 0 { println("  FAIL: rt_poll not aligned"); ok = false }
    if len(waitpid_b) % 4 != 0 { println("  FAIL: rt_waitpid not aligned"); ok = false }
    if len(mmap_b) % 4 != 0 { println("  FAIL: rt_mmap not aligned"); ok = false }
    // B9.6-D2 — all three end with ret (192,3,95,214).
    let nhf = len(hfloat)
    if hfloat[nhf - 4] != 192 { println("  FAIL: rt_hexa_float no RET"); ok = false }
    let nhe = len(henum)
    if henum[nhe - 4] != 192 { println("  FAIL: rt_hexa_enum_str no RET"); ok = false }
    let nhev = len(henumv)
    if henumv[nhev - 4] != 192 { println("  FAIL: rt_hexa_enum_str_v no RET"); ok = false }

    // Verify RET trailer: last 4 bytes = 192, 3, 95, 214 (0xD65F03C0)
    // (except rt_exit which ends with svc)
    let n = len(pstr)
    if pstr[n - 4] != 192 { println("  FAIL: rt_print_str no RET"); ok = false }
    let n2 = len(pln)
    if pln[n2 - 4] != 192 { println("  FAIL: rt_println no RET"); ok = false }
    let n3 = len(pint)
    if pint[n3 - 4] != 192 { println("  FAIL: rt_print_int no RET"); ok = false }
    let n4 = len(alloc_bytes)
    if alloc_bytes[n4 - 4] != 192 { println("  FAIL: rt_alloc no RET"); ok = false }
    let nf = len(free_bytes)
    if free_bytes[nf - 4] != 192 { println("  FAIL: rt_free no RET"); ok = false }
    let n5 = len(slen)
    if slen[n5 - 4] != 192 { println("  FAIL: rt_str_len no RET"); ok = false }
    let nm = len(mset)
    if mset[nm - 4] != 192 { println("  FAIL: rt_memset no RET"); ok = false }
    // F3 inc 2 — all four leaves end with ret (192,3,95,214).
    let ncm = len(mcmp)
    if mcmp[ncm - 4] != 192 { println("  FAIL: rt_memcmp no RET"); ok = false }
    let ncp = len(mcpy)
    if mcpy[ncp - 4] != 192 { println("  FAIL: rt_memcpy no RET"); ok = false }
    let nmv = len(mmove)
    if mmove[nmv - 4] != 192 { println("  FAIL: rt_memmove no RET"); ok = false }
    let nsc = len(scmp)
    if scmp[nsc - 4] != 192 { println("  FAIL: rt_strcmp no RET"); ok = false }
    // F3 inc 3 — all five string leaves end with ret (192,3,95,214).
    let nsnc = len(sncmp)
    if sncmp[nsnc - 4] != 192 { println("  FAIL: rt_strncmp no RET"); ok = false }
    let nsch = len(schr)
    if schr[nsch - 4] != 192 { println("  FAIL: rt_strchr no RET"); ok = false }
    let nsrc = len(srchr)
    if srchr[nsrc - 4] != 192 { println("  FAIL: rt_strrchr no RET"); ok = false }
    let nscp = len(scpy)
    if scpy[nscp - 4] != 192 { println("  FAIL: rt_strcpy no RET"); ok = false }
    let nsnp = len(sncpy)
    if sncpy[nsnp - 4] != 192 { println("  FAIL: rt_strncpy no RET"); ok = false }
    // F3 inc 4 — all five final leaves end with ret (192,3,95,214).
    let nscat = len(scat)
    if scat[nscat - 4] != 192 { println("  FAIL: rt_strcat no RET"); ok = false }
    let nclz = len(clz)
    if clz[nclz - 4] != 192 { println("  FAIL: rt_clz no RET"); ok = false }
    let nctz = len(ctz)
    if ctz[nctz - 4] != 192 { println("  FAIL: rt_ctz no RET"); ok = false }
    let npop = len(popc)
    if popc[npop - 4] != 192 { println("  FAIL: rt_popcount no RET"); ok = false }
    let nbsw = len(bswap)
    if bswap[nbsw - 4] != 192 { println("  FAIL: rt_bswap no RET"); ok = false }
    let na1 = len(ainit)
    if ainit[na1 - 4] != 192 { println("  FAIL: rt_arena_init no RET"); ok = false }
    let na2 = len(aalloc)
    if aalloc[na2 - 4] != 192 { println("  FAIL: rt_arena_alloc no RET"); ok = false }
    let na3 = len(areset)
    if areset[na3 - 4] != 192 { println("  FAIL: rt_arena_reset no RET"); ok = false }
    let na4 = len(arel)
    if arel[na4 - 4] != 192 { println("  FAIL: rt_arena_release no RET"); ok = false }
    // B9.6 / F3 class-D — all three struct-return ctors end with ret.
    let nhv = len(hvoid)
    if hvoid[nhv - 4] != 192 { println("  FAIL: rt_hexa_void no RET"); ok = false }
    let nhi = len(hint)
    if hint[nhi - 4] != 192 { println("  FAIL: rt_hexa_int no RET"); ok = false }
    let nhb = len(hbool)
    if hbool[nhb - 4] != 192 { println("  FAIL: rt_hexa_bool no RET"); ok = false }

    // Verify SVC trailer on rt_exit: last 4 bytes = 1, 16, 0, 212 (0xD4001001)
    let ne = len(exit_bytes)
    if exit_bytes[ne - 4] != 1 { println("  FAIL: rt_exit no SVC"); ok = false }

    // Verify rt_arena_init contains mov x16, #197 (SYS_mmap)
    //   encoded as 0xD28018B0 → little-endian bytes 176, 24, 128, 210.
    let mut found_mmap = false
    let mut i = 0
    while i + 3 < len(ainit) {
        if ainit[i] == 176 {
            if ainit[i + 1] == 24 {
                if ainit[i + 2] == 128 {
                    if ainit[i + 3] == 210 {
                        found_mmap = true
                    }
                }
            }
        }
        i = i + 1
    }
    if !found_mmap { println("  FAIL: rt_arena_init missing mov x16, #197 (SYS_mmap)"); ok = false }

    // Verify rt_arena_init contains svc #0x80 (bytes 1, 16, 0, 212)
    let mut found_svc = false
    let mut j = 0
    while j + 3 < len(ainit) {
        if ainit[j] == 1 {
            if ainit[j + 1] == 16 {
                if ainit[j + 2] == 0 {
                    if ainit[j + 3] == 212 {
                        found_svc = true
                    }
                }
            }
        }
        j = j + 1
    }
    if !found_svc { println("  FAIL: rt_arena_init missing svc #0x80"); ok = false }

    // Verify rt_arena_release contains mov x16, #73 (SYS_munmap)
    //   encoded as 0xD2800930 → little-endian bytes 48, 9, 128, 210.
    let mut found_munmap = false
    let mut k = 0
    while k + 3 < len(arel) {
        if arel[k] == 48 {
            if arel[k + 1] == 9 {
                if arel[k + 2] == 128 {
                    if arel[k + 3] == 210 {
                        found_munmap = true
                    }
                }
            }
        }
        k = k + 1
    }
    if !found_munmap { println("  FAIL: rt_arena_release missing mov x16, #73 (SYS_munmap)"); ok = false }

    // Verify rt_free contains mov x16, #73 (SYS_munmap) — pair-safe with rt_alloc.
    //   encoded as 0xD2800930 → little-endian bytes 48, 9, 128, 210.
    let mut found_free_munmap = false
    let mut kf = 0
    while kf + 3 < len(free_bytes) {
        if free_bytes[kf] == 48 {
            if free_bytes[kf + 1] == 9 {
                if free_bytes[kf + 2] == 128 {
                    if free_bytes[kf + 3] == 210 {
                        found_free_munmap = true
                    }
                }
            }
        }
        kf = kf + 1
    }
    if !found_free_munmap { println("  FAIL: rt_free missing mov x16, #73 (SYS_munmap)"); ok = false }

    // Verify rt_alloc contains add x1, x0, #16 (header offset adjust).
    //   encoded as 0x91004001 → little-endian bytes 1, 64, 0, 145.
    let mut found_alloc_hdr_add = false
    let mut ka = 0
    while ka + 3 < len(alloc_bytes) {
        if alloc_bytes[ka] == 1 {
            if alloc_bytes[ka + 1] == 64 {
                if alloc_bytes[ka + 2] == 0 {
                    if alloc_bytes[ka + 3] == 145 {
                        found_alloc_hdr_add = true
                    }
                }
            }
        }
        ka = ka + 1
    }
    if !found_alloc_hdr_add { println("  FAIL: rt_alloc missing add x1, x0, #16 (header math)"); ok = false }

    // Verify rt_alloc contains str x19, [x0] (write header).
    //   encoded as 0xF9000013 → little-endian bytes 19, 0, 0, 249.
    let mut found_alloc_str = false
    let mut ks = 0
    while ks + 3 < len(alloc_bytes) {
        if alloc_bytes[ks] == 19 {
            if alloc_bytes[ks + 1] == 0 {
                if alloc_bytes[ks + 2] == 0 {
                    if alloc_bytes[ks + 3] == 249 {
                        found_alloc_str = true
                    }
                }
            }
        }
        ks = ks + 1
    }
    if !found_alloc_str { println("  FAIL: rt_alloc missing str x19, [x0] (header write)"); ok = false }

    // Verify rt_memset contains strb w1, [x0, x3] (the byte-store body).
    //   encoded as 0x38236801 → little-endian bytes 1, 104, 35, 56.
    let mut found_memset_strb = false
    let mut km = 0
    while km + 3 < len(mset) {
        if mset[km] == 1 {
            if mset[km + 1] == 104 {
                if mset[km + 2] == 35 {
                    if mset[km + 3] == 56 {
                        found_memset_strb = true
                    }
                }
            }
        }
        km = km + 1
    }
    if !found_memset_strb { println("  FAIL: rt_memset missing strb w1, [x0, x3] (byte store)"); ok = false }

    // Verify rt_memcmp contains subs w6, w4, w5 (the compare body).
    //   encoded as 0x6B050086 → little-endian bytes 134, 0, 5, 107.
    let mut found_memcmp_subs = false
    let mut ic = 0
    while ic + 3 < len(mcmp) {
        if mcmp[ic] == 134 {
            if mcmp[ic + 1] == 0 {
                if mcmp[ic + 2] == 5 {
                    if mcmp[ic + 3] == 107 {
                        found_memcmp_subs = true
                    }
                }
            }
        }
        ic = ic + 1
    }
    if !found_memcmp_subs { println("  FAIL: rt_memcmp missing subs w6, w4, w5 (compare)"); ok = false }

    // Verify rt_memcpy contains ldrb w4, [x1, x3] (the source load).
    //   encoded as 0x38636824 → little-endian bytes 36, 104, 99, 56.
    let mut found_memcpy_ldrb = false
    let mut ip = 0
    while ip + 3 < len(mcpy) {
        if mcpy[ip] == 36 {
            if mcpy[ip + 1] == 104 {
                if mcpy[ip + 2] == 99 {
                    if mcpy[ip + 3] == 56 {
                        found_memcpy_ldrb = true
                    }
                }
            }
        }
        ip = ip + 1
    }
    if !found_memcpy_ldrb { println("  FAIL: rt_memcpy missing ldrb w4, [x1, x3] (src load)"); ok = false }

    // Verify rt_memmove contains cmp x0, x1 (the direction decision).
    //   encoded as 0xEB01001F → little-endian bytes 31, 0, 1, 235.
    let mut found_memmove_cmp = false
    let mut iv = 0
    while iv + 3 < len(mmove) {
        if mmove[iv] == 31 {
            if mmove[iv + 1] == 0 {
                if mmove[iv + 2] == 1 {
                    if mmove[iv + 3] == 235 {
                        found_memmove_cmp = true
                    }
                }
            }
        }
        iv = iv + 1
    }
    if !found_memmove_cmp { println("  FAIL: rt_memmove missing cmp x0, x1 (dir decision)"); ok = false }

    // Verify rt_strcmp contains cbz w4, eq (the NUL-terminator stop).
    //   encoded as 0x34000064 → little-endian bytes 100, 0, 0, 52.
    let mut found_strcmp_cbz = false
    let mut isc = 0
    while isc + 3 < len(scmp) {
        if scmp[isc] == 100 {
            if scmp[isc + 1] == 0 {
                if scmp[isc + 2] == 0 {
                    if scmp[isc + 3] == 52 {
                        found_strcmp_cbz = true
                    }
                }
            }
        }
        isc = isc + 1
    }
    if !found_strcmp_cbz { println("  FAIL: rt_strcmp missing cbz w4 (NUL stop)"); ok = false }

    // Verify rt_strncmp contains subs w6, w4, w5 (the compare body).
    //   encoded as 0x6B050086 → little-endian bytes 134, 0, 5, 107.
    let mut found_strncmp_subs = false
    let mut isn = 0
    while isn + 3 < len(sncmp) {
        if sncmp[isn] == 134 {
            if sncmp[isn + 1] == 0 {
                if sncmp[isn + 2] == 5 {
                    if sncmp[isn + 3] == 107 {
                        found_strncmp_subs = true
                    }
                }
            }
        }
        isn = isn + 1
    }
    if !found_strncmp_subs { println("  FAIL: rt_strncmp missing subs w6, w4, w5 (compare)"); ok = false }

    // Verify rt_strchr contains add x0, x0, x2 (found-path return ptr).
    //   encoded as 0x8B020000 → little-endian bytes 0, 0, 2, 139.
    let mut found_strchr_add = false
    let mut ich = 0
    while ich + 3 < len(schr) {
        if schr[ich] == 0 {
            if schr[ich + 1] == 0 {
                if schr[ich + 2] == 2 {
                    if schr[ich + 3] == 139 {
                        found_strchr_add = true
                    }
                }
            }
        }
        ich = ich + 1
    }
    if !found_strchr_add { println("  FAIL: rt_strchr missing add x0, x0, x2 (found ptr)"); ok = false }

    // Verify rt_strrchr contains add x4, x0, x2 (record last match).
    //   encoded as 0x8B020004 → little-endian bytes 4, 0, 2, 139.
    let mut found_strrchr_add = false
    let mut irc = 0
    while irc + 3 < len(srchr) {
        if srchr[irc] == 4 {
            if srchr[irc + 1] == 0 {
                if srchr[irc + 2] == 2 {
                    if srchr[irc + 3] == 139 {
                        found_strrchr_add = true
                    }
                }
            }
        }
        irc = irc + 1
    }
    if !found_strrchr_add { println("  FAIL: rt_strrchr missing add x4, x0, x2 (last match)"); ok = false }

    // Verify rt_strcpy contains strb w3, [x0, x2] (the byte store body).
    //   encoded as 0x38226803 → little-endian bytes 3, 104, 34, 56.
    let mut found_strcpy_strb = false
    let mut icp = 0
    while icp + 3 < len(scpy) {
        if scpy[icp] == 3 {
            if scpy[icp + 1] == 104 {
                if scpy[icp + 2] == 34 {
                    if scpy[icp + 3] == 56 {
                        found_strcpy_strb = true
                    }
                }
            }
        }
        icp = icp + 1
    }
    if !found_strcpy_strb { println("  FAIL: rt_strcpy missing strb w3, [x0, x2] (byte store)"); ok = false }

    // Verify rt_strncpy contains strb wzr, [x0, x3] (the NUL-pad store).
    //   encoded as 0x3823681F → little-endian bytes 31, 104, 35, 56.
    let mut found_strncpy_pad = false
    let mut inp = 0
    while inp + 3 < len(sncpy) {
        if sncpy[inp] == 31 {
            if sncpy[inp + 1] == 104 {
                if sncpy[inp + 2] == 35 {
                    if sncpy[inp + 3] == 56 {
                        found_strncpy_pad = true
                    }
                }
            }
        }
        inp = inp + 1
    }
    if !found_strncpy_pad { println("  FAIL: rt_strncpy missing strb wzr, [x0, x3] (NUL pad)"); ok = false }

    // Verify rt_strcat contains strb w4, [x2, x3] (the copy-phase store).
    //   encoded as 0x38236844 → little-endian bytes 68, 104, 35, 56.
    let mut found_strcat_strb = false
    let mut ica = 0
    while ica + 3 < len(scat) {
        if scat[ica] == 68 {
            if scat[ica + 1] == 104 {
                if scat[ica + 2] == 35 {
                    if scat[ica + 3] == 56 {
                        found_strcat_strb = true
                    }
                }
            }
        }
        ica = ica + 1
    }
    if !found_strcat_strb { println("  FAIL: rt_strcat missing strb w4, [x2, x3] (copy store)"); ok = false }

    // Verify rt_clz contains clz x0, x0 (the count-leading-zeros op).
    //   encoded as 0xDAC01000 → little-endian bytes 0, 16, 192, 218.
    let mut found_clz_op = false
    let mut icl = 0
    while icl + 3 < len(clz) {
        if clz[icl] == 0 {
            if clz[icl + 1] == 16 {
                if clz[icl + 2] == 192 {
                    if clz[icl + 3] == 218 {
                        found_clz_op = true
                    }
                }
            }
        }
        icl = icl + 1
    }
    if !found_clz_op { println("  FAIL: rt_clz missing clz x0, x0"); ok = false }

    // Verify rt_ctz contains rbit x0, x0 (the bit-reverse before clz).
    //   encoded as 0xDAC00000 → little-endian bytes 0, 0, 192, 218.
    let mut found_ctz_rbit = false
    let mut ict = 0
    while ict + 3 < len(ctz) {
        if ctz[ict] == 0 {
            if ctz[ict + 1] == 0 {
                if ctz[ict + 2] == 192 {
                    if ctz[ict + 3] == 218 {
                        found_ctz_rbit = true
                    }
                }
            }
        }
        ict = ict + 1
    }
    if !found_ctz_rbit { println("  FAIL: rt_ctz missing rbit x0, x0"); ok = false }

    // Verify rt_popcount contains cnt v0.8b, v0.8b (per-byte popcount).
    //   encoded as 0x0E205800 → little-endian bytes 0, 88, 32, 14.
    let mut found_pop_cnt = false
    let mut ipo = 0
    while ipo + 3 < len(popc) {
        if popc[ipo] == 0 {
            if popc[ipo + 1] == 88 {
                if popc[ipo + 2] == 32 {
                    if popc[ipo + 3] == 14 {
                        found_pop_cnt = true
                    }
                }
            }
        }
        ipo = ipo + 1
    }
    if !found_pop_cnt { println("  FAIL: rt_popcount missing cnt v0.8b, v0.8b"); ok = false }

    // Verify rt_bswap contains rev x0, x0 (the byte-reverse op).
    //   encoded as 0xDAC00C00 → little-endian bytes 0, 12, 192, 218.
    let mut found_bswap_rev = false
    let mut ibs = 0
    while ibs + 3 < len(bswap) {
        if bswap[ibs] == 0 {
            if bswap[ibs + 1] == 12 {
                if bswap[ibs + 2] == 192 {
                    if bswap[ibs + 3] == 218 {
                        found_bswap_rev = true
                    }
                }
            }
        }
        ibs = ibs + 1
    }
    if !found_bswap_rev { println("  FAIL: rt_bswap missing rev x0, x0"); ok = false }

    // ── B9.6 / F3 class-D — struct-return x0:x1 signature checks ──
    // The defining feature vs every prior single-x0 leaf is that the
    // HIGH half of the 16-byte HexaVal is set in x1. We assert the
    // exact tag-half AND value-half instruction bytes per ctor.

    // rt_hexa_void: mov w0, #4 (tag=TAG_VOID) at offset 0
    //   0x52800080 → little-endian bytes 128, 0, 128, 82.
    if hvoid[0] != 128 || hvoid[1] != 0 || hvoid[2] != 128 || hvoid[3] != 82 {
        println("  FAIL: rt_hexa_void missing mov w0,#4 (TAG_VOID tag half)"); ok = false
    }
    // rt_hexa_void: mov x1, #0 (union half = 0) at offset 4
    //   0xD2800001 → little-endian bytes 1, 0, 128, 210.
    if hvoid[4] != 1 || hvoid[5] != 0 || hvoid[6] != 128 || hvoid[7] != 210 {
        println("  FAIL: rt_hexa_void missing mov x1,#0 (struct high half)"); ok = false
    }

    // rt_hexa_int: mov x1, x0 (union half = .i = arg) at offset 0
    //   0xAA0003E1 → little-endian bytes 225, 3, 0, 170.
    if hint[0] != 225 || hint[1] != 3 || hint[2] != 0 || hint[3] != 170 {
        println("  FAIL: rt_hexa_int missing mov x1,x0 (struct high half = arg)"); ok = false
    }
    // rt_hexa_int: mov x0, #0 (tag=TAG_INT) at offset 4
    //   0xD2800000 → little-endian bytes 0, 0, 128, 210.
    if hint[4] != 0 || hint[5] != 0 || hint[6] != 128 || hint[7] != 210 {
        println("  FAIL: rt_hexa_int missing mov x0,#0 (TAG_INT tag half)"); ok = false
    }

    // rt_hexa_bool: mov w1, w0 (union half = .b = arg) at offset 0
    //   0x2A0003E1 → little-endian bytes 225, 3, 0, 42.
    if hbool[0] != 225 || hbool[1] != 3 || hbool[2] != 0 || hbool[3] != 42 {
        println("  FAIL: rt_hexa_bool missing mov w1,w0 (struct high half = arg)"); ok = false
    }
    // rt_hexa_bool: mov w0, #2 (tag=TAG_BOOL) at offset 4
    //   0x52800040 → little-endian bytes 64, 0, 128, 82.
    if hbool[4] != 64 || hbool[5] != 0 || hbool[6] != 128 || hbool[7] != 82 {
        println("  FAIL: rt_hexa_bool missing mov w0,#2 (TAG_BOOL tag half)"); ok = false
    }

    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ── rt_strdup (F3-codegen-kickoff — class-B HARD primitive · BEHAVIORAL self-emit) ──
//
// char *strdup(const char *s):
//   if (!s) return NULL
//   n = strlen(s)                 (INLINE scalar byte loop — hexa's OWN selection)
//   out = malloc(n+1)             (bl _hxlcl_malloc · BRANCH26)
//   if (!out) return NULL
//   copy s[0..n] inclusive of NUL (INLINE scalar byte loop)
//   return out
//
// 🔑 STRATEGIC SIGNIFICANCE — THE F3 WALL REFRAME.
// The B9.6-B2/E2 wall narrative held that class-B copy-loop primitives
// (strdup/strndup) were BLOCKED because the byte-identity-vs-clang gate forces
// reproducing clang -O2's AUTO-VECTORIZED copy (ld1/st1 NEON, head/tail
// peeling, an RA-emergent multi-pair frame). Hand-rolling that byte-for-byte is
// the "reimplement clang's optimizer" impossibility.
//
// This emitter DROPS the clang-byte-match requirement. A self-hosting compiler
// emits ITS OWN correct machine code; correctness is BEHAVIOR, not a diff vs a
// third-party optimizer. The sequence below is a plain SCALAR byte-copy loop —
// NOT byte-identical to clang -O2 — verified by:
//   (1) interp self-test (length + structural byte asserts, below)
//   (2) `as -arch arm64` ROUND-TRIP (our own .s assembles to these exact bytes —
//       proves the encoding is a legal ARM64 program, NOT that it matches clang)
//   (3) JIT-exec BEHAVIORAL battery (emit_hxlcl_strdup_o.hexa → link against a
//       real _hxlcl_malloc + C driver → distinct ptr · exact content · NUL term ·
//       empty/embedded-high-byte/NULL-input edges all PASS, rc=0)
// PLUS the self-host fixpoint (tool/meta2_verify.hexa f(C)=C) is the standing
// correctness anchor, and the default 0-extern build stays byte-identical
// (the guard is OPT-IN; default keeps the C body).
//
// This is the FIRST class-B HARD primitive (frame + bl + COPY LOOP, not a bare
// tail-call like rt_atoi): it carries callee-saved state (x19=s, x20=n, x21=out)
// LIVE ACROSS the bl, two distinct scalar loops, and multi-BB control flow with
// a shared NULL/return epilogue — the exact shape the wall called "unbuilt".
// Emitting our OWN correct form makes it tractable engineering.
//
// macOS arm64 AAPCS · 28 instructions, 112 bytes · ONE BRANCH26 reloc @ 0x30.
// Registers: x19=s · x20=n · x21=out (callee-saved, restored in epilogue);
//            x9/x10 scratch; bl _hxlcl_malloc clobbers x0..x18 (none live).
// Bytes below are character-identical to `as -arch arm64` of the .s in
// .verdicts/runtime-floor-closure/F3-strdup-behavioral.txt (NOT to clang -O2).
fn rt_strdup() {
    let mut c = []
    // stp x29, x30, [sp, #-48]!   0xA9BD7BFD  (frame + LR spill, 48-B frame)
    c.push(253); c.push(123); c.push(189); c.push(169)
    // mov x29, sp                 0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // stp x19, x20, [sp, #16]     0xA90153F3  (save callee-saved pair)
    c.push(243); c.push(83); c.push(1); c.push(169)
    // str x21, [sp, #32]          0xF90013F5  (save callee-saved x21)
    c.push(245); c.push(19); c.push(0); c.push(249)
    // cbz x0, .Lnull (+0x50→0x60) 0xB4000260  (if (!s) return NULL)
    c.push(96); c.push(2); c.push(0); c.push(180)
    // mov x19, x0                 0xAA0003F3  (x19 = s)
    c.push(243); c.push(3); c.push(0); c.push(170)
    // mov x20, #0                 0xD2800014  (n = 0)
    c.push(20); c.push(0); c.push(128); c.push(210)
    // .Llen: ldrb w9, [x19, x20]  0x38746A69
    c.push(105); c.push(106); c.push(116); c.push(56)
    // cbz w9, .Llen_done (+0xc)   0x34000069  (NUL terminator → length found)
    c.push(105); c.push(0); c.push(0); c.push(52)
    // add x20, x20, #1            0x91000694
    c.push(148); c.push(6); c.push(0); c.push(145)
    // b .Llen (-0xc→0x1c)         0x17FFFFFD
    c.push(253); c.push(255); c.push(255); c.push(23)
    // .Llen_done: add x0, x20, #1 0x91000680  (malloc arg = n+1)
    c.push(128); c.push(6); c.push(0); c.push(145)
    // bl _hxlcl_malloc [BRANCH26] 0x94000000  (imm zeroed pre-reloc) @ 0x30
    c.push(0); c.push(0); c.push(0); c.push(148)
    // cbz x0, .Lnull (+0x28→0x5c) 0xB4000140  (malloc failed → NULL)
    c.push(64); c.push(1); c.push(0); c.push(180)
    // mov x21, x0                 0xAA0003F5  (x21 = out)
    c.push(245); c.push(3); c.push(0); c.push(170)
    // mov x10, #0                 0xD280000A  (copy index i = 0)
    c.push(10); c.push(0); c.push(128); c.push(210)
    // .Lcopy: ldrb w9, [x19, x10] 0x386A6A69
    c.push(105); c.push(106); c.push(106); c.push(56)
    // strb w9, [x21, x10]         0x382A6AA9
    c.push(169); c.push(106); c.push(42); c.push(56)
    // cmp x10, x20               0xEB14015F
    c.push(95); c.push(1); c.push(20); c.push(235)
    // add x10, x10, #1           0x9100054A
    c.push(74); c.push(5); c.push(0); c.push(145)
    // b.lo .Lcopy (-0x10→0x40)   0x54FFFF83  (while i<n; at i==n the NUL is copied then stop)
    c.push(131); c.push(255); c.push(255); c.push(84)
    // mov x0, x21                0xAA1503E0  (return out)
    c.push(224); c.push(3); c.push(21); c.push(170)
    // b .Lret (+0x8→0x60)        0x14000002
    c.push(2); c.push(0); c.push(0); c.push(20)
    // .Lnull: mov x0, #0         0xD2800000  (NULL result, shared by !s and OOM)
    c.push(0); c.push(0); c.push(128); c.push(210)
    // .Lret: ldr x21, [sp, #32]  0xF94013F5
    c.push(245); c.push(19); c.push(64); c.push(249)
    // ldp x19, x20, [sp, #16]    0xA94153F3
    c.push(243); c.push(83); c.push(65); c.push(169)
    // ldp x29, x30, [sp], #48    0xA8C37BFD
    c.push(253); c.push(123); c.push(195); c.push(168)
    // ret                        0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// Reloc table for rt_strdup — ONE BRANCH26 for the `bl _hxlcl_malloc` at the
// __text byte offset 0x30 (48). kind 2 = ARM64_RELOC_BRANCH26, undefined-extern
// callee (sym_section==0). Identical shape to rt_atoi_reloc_* (B9.6-B1).
fn rt_strdup_reloc_offs() {
    let mut o = []
    o.push(48)
    return o
}
fn rt_strdup_reloc_kinds() {
    let mut k = []
    k.push(2)
    return k
}

fn test_rt_strdup() {
    println("test_rt_strdup (F3 class-B HARD primitive · behavioral self-emit)")
    let mut ok = true
    let s = rt_strdup()
    println("  rt_strdup : " + to_string(len(s)) + " bytes (112 expected)")
    if len(s) != 112 {
        println("  FAIL: rt_strdup expected 112 bytes"); ok = false
    }
    // prologue stp x29,x30,[sp,#-48]!  (fd 7b bd a9) @ 0
    if s[0] != 253 || s[1] != 123 || s[2] != 189 || s[3] != 169 {
        println("  FAIL: stp x29,x30 prologue (48-B frame) mismatch"); ok = false
    }
    // bl _hxlcl_malloc (00 00 00 94) @ 0x30 = 48 — the cross-object CALL site
    if s[48] != 0 || s[49] != 0 || s[50] != 0 || s[51] != 148 {
        println("  FAIL: bl _hxlcl_malloc (BRANCH26 @0x30) mismatch"); ok = false
    }
    // ret (c0 03 5f d6) @ 0x6c = 108
    if s[108] != 192 || s[109] != 3 || s[110] != 95 || s[111] != 214 {
        println("  FAIL: ret trailer mismatch"); ok = false
    }
    // reloc table: one BRANCH26 @ 48
    let offs = rt_strdup_reloc_offs()
    let kinds = rt_strdup_reloc_kinds()
    if len(offs) != 1 || offs[0] != 48 {
        println("  FAIL: reloc offset expected [48]"); ok = false
    }
    if len(kinds) != 1 || kinds[0] != 2 {
        println("  FAIL: reloc kind expected [2] (BRANCH26)"); ok = false
    }
    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ── rt_strndup (F3 class-B HARD scale-out — 2nd activated class-B HARD) ──
//
// char *strndup(const char *s, size_t cap):
//   if (!s) return NULL
//   n = 0
//   while n < cap && s[n] != 0: n++              (cap-bounded scalar byte loop)
//   out = malloc(n+1)                             (bl _hxlcl_malloc · BRANCH26)
//   if (!out) return NULL
//   for i in 0..<n: out[i] = s[i]                 (scalar byte copy loop)
//   out[n] = '\0'                                 (explicit NUL — source may lack it)
//   return out
//
// Mechanical port of rt_strdup (PR #1911 / #1917) following the proven recipe:
//   * Same callee-saved-state shape (s/n/out live across the bl) PLUS a new
//     callee-saved register for cap (x20 holds cap; x21 holds n; x22 holds out;
//     x19 holds s — same x19=s convention).
//   * Same 48-B frame: stp x29/x30 [sp,#-48]! / stp x19,x20 [sp,#16] / str x21
//     [sp,#32] / str x22 [sp,#40]. (x22 is the new 4th callee-saved slot at +40.)
//   * Same ONE BRANCH26 reloc for `bl _hxlcl_malloc` (offset shifts from 0x30
//     to 0x40 because the prologue is one instr longer for the x22 spill +
//     three extra setup instrs for the cap-bounded length loop).
//   * Explicit `.Lterm` writes `out[n] = 0` AFTER the copy loop (vs strdup,
//     which lets the copy loop naturally copy the source NUL): the source may
//     legitimately lack a NUL within the cap window, so the terminator is
//     unconditional. This is the ONE behavioral difference vs strdup.
//
// macOS arm64 AAPCS · 36 instructions, 144 bytes · ONE BRANCH26 reloc @ 0x40.
// Registers: x19=s · x20=cap · x21=n · x22=out (all callee-saved, restored);
//            x9/x10 scratch; bl _hxlcl_malloc clobbers x0..x18 (none live).
// Bytes below are character-identical to `as -arch arm64` round-trip oracle
// (verified at PR-prep time, NOT to clang -O2; the F3 wall-reframe holds —
// behavioral-equivalence, not byte-identity-vs-clang).
fn rt_strndup() {
    let mut c = []
    // 0x00  stp x29, x30, [sp, #-48]!   0xA9BD7BFD
    c.push(253); c.push(123); c.push(189); c.push(169)
    // 0x04  mov x29, sp                 0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // 0x08  stp x19, x20, [sp, #16]     0xA90153F3
    c.push(243); c.push(83); c.push(1); c.push(169)
    // 0x0c  str x21, [sp, #32]          0xF90013F5
    c.push(245); c.push(19); c.push(0); c.push(249)
    // 0x10  str x22, [sp, #40]          0xF90017F6  (NEW: 4th callee-saved slot for out)
    c.push(246); c.push(23); c.push(0); c.push(249)
    // 0x14  cbz x0, .Lnull (+0x64→0x78) 0xB4000320  (if (!s) return NULL)
    c.push(32); c.push(3); c.push(0); c.push(180)
    // 0x18  mov x19, x0                 0xAA0003F3  (x19 = s)
    c.push(243); c.push(3); c.push(0); c.push(170)
    // 0x1c  mov x20, x1                 0xAA0103F4  (x20 = cap — NEW)
    c.push(244); c.push(3); c.push(1); c.push(170)
    // 0x20  mov x21, #0                 0xD2800015  (x21 = n = 0)
    c.push(21); c.push(0); c.push(128); c.push(210)
    // 0x24  .Llen: cmp x21, x20         0xEB1402BF  (cmp n, cap — NEW)
    c.push(191); c.push(2); c.push(20); c.push(235)
    // 0x28  b.eq .Llen_done (+0x14→0x3c) 0x540000A0  (n==cap → done — NEW)
    c.push(160); c.push(0); c.push(0); c.push(84)
    // 0x2c  ldrb w9, [x19, x21]         0x38756A69
    c.push(105); c.push(106); c.push(117); c.push(56)
    // 0x30  cbz w9, .Llen_done (+0xc→0x3c) 0x34000069  (NUL terminator)
    c.push(105); c.push(0); c.push(0); c.push(52)
    // 0x34  add x21, x21, #1            0x910006B5
    c.push(181); c.push(6); c.push(0); c.push(145)
    // 0x38  b .Llen (-0x14→0x24)        0x17FFFFFB
    c.push(251); c.push(255); c.push(255); c.push(23)
    // 0x3c  .Llen_done: add x0, x21, #1 0x910006A0  (malloc arg = n+1)
    c.push(160); c.push(6); c.push(0); c.push(145)
    // 0x40  bl _hxlcl_malloc [BRANCH26] 0x94000000  (imm zeroed pre-reloc) @ 0x40
    c.push(0); c.push(0); c.push(0); c.push(148)
    // 0x44  cbz x0, .Lnull (+0x34→0x78) 0xB40001A0  (malloc failed → NULL)
    c.push(160); c.push(1); c.push(0); c.push(180)
    // 0x48  mov x22, x0                 0xAA0003F6  (x22 = out — NEW)
    c.push(246); c.push(3); c.push(0); c.push(170)
    // 0x4c  mov x10, #0                 0xD280000A  (i = 0)
    c.push(10); c.push(0); c.push(128); c.push(210)
    // 0x50  .Lcopy: cmp x10, x21        0xEB15015F  (cmp i, n — NEW exit-test)
    c.push(95); c.push(1); c.push(21); c.push(235)
    // 0x54  b.eq .Lterm (+0x14→0x68)    0x540000A0  (i==n → terminate)
    c.push(160); c.push(0); c.push(0); c.push(84)
    // 0x58  ldrb w9, [x19, x10]         0x386A6A69
    c.push(105); c.push(106); c.push(106); c.push(56)
    // 0x5c  strb w9, [x22, x10]         0x382A6AC9  (write into out, not strdup's x21)
    c.push(201); c.push(106); c.push(42); c.push(56)
    // 0x60  add x10, x10, #1            0x9100054A
    c.push(74); c.push(5); c.push(0); c.push(145)
    // 0x64  b .Lcopy (-0x14→0x50)       0x17FFFFFB
    c.push(251); c.push(255); c.push(255); c.push(23)
    // 0x68  .Lterm: mov w9, #0          0x52800009  (NUL byte)
    c.push(9); c.push(0); c.push(128); c.push(82)
    // 0x6c  strb w9, [x22, x21]         0x38356AC9  (out[n] = '\0' — UNCONDITIONAL)
    c.push(201); c.push(106); c.push(53); c.push(56)
    // 0x70  mov x0, x22                 0xAA1603E0  (return out)
    c.push(224); c.push(3); c.push(22); c.push(170)
    // 0x74  b .Lret (+0x8→0x7c)         0x14000002
    c.push(2); c.push(0); c.push(0); c.push(20)
    // 0x78  .Lnull: mov x0, #0          0xD2800000  (NULL — shared by !s and OOM)
    c.push(0); c.push(0); c.push(128); c.push(210)
    // 0x7c  .Lret: ldr x22, [sp, #40]   0xF94017F6
    c.push(246); c.push(23); c.push(64); c.push(249)
    // 0x80  ldr x21, [sp, #32]          0xF94013F5
    c.push(245); c.push(19); c.push(64); c.push(249)
    // 0x84  ldp x19, x20, [sp, #16]     0xA94153F3
    c.push(243); c.push(83); c.push(65); c.push(169)
    // 0x88  ldp x29, x30, [sp], #48     0xA8C37BFD
    c.push(253); c.push(123); c.push(195); c.push(168)
    // 0x8c  ret                         0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// Reloc table for rt_strndup — ONE BRANCH26 for `bl _hxlcl_malloc` at __text
// byte offset 0x40 (64). kind 2 = ARM64_RELOC_BRANCH26, undefined-extern callee
// (sym_section==0). Same shape as rt_strdup_reloc_* (PR #1911) — only the
// offset shifts (0x30→0x40) because the prologue carries one extra spill +
// three extra setup instructions for cap-tracking.
fn rt_strndup_reloc_offs() {
    let mut o = []
    o.push(64)
    return o
}
fn rt_strndup_reloc_kinds() {
    let mut k = []
    k.push(2)
    return k
}

fn test_rt_strndup() {
    println("test_rt_strndup (F3 class-B HARD scale-out · behavioral self-emit)")
    let mut ok = true
    let s = rt_strndup()
    println("  rt_strndup : " + to_string(len(s)) + " bytes (144 expected)")
    if len(s) != 144 {
        println("  FAIL: rt_strndup expected 144 bytes"); ok = false
    }
    // prologue stp x29,x30,[sp,#-48]!  (fd 7b bd a9) @ 0
    if s[0] != 253 || s[1] != 123 || s[2] != 189 || s[3] != 169 {
        println("  FAIL: stp x29,x30 prologue (48-B frame) mismatch"); ok = false
    }
    // 4th-spill str x22, [sp, #40]  (f6 17 00 f9) @ 0x10 = 16
    if s[16] != 246 || s[17] != 23 || s[18] != 0 || s[19] != 249 {
        println("  FAIL: str x22 spill (sp+40, NEW 4th callee-save) mismatch"); ok = false
    }
    // bl _hxlcl_malloc (00 00 00 94) @ 0x40 = 64 — the cross-object CALL site
    if s[64] != 0 || s[65] != 0 || s[66] != 0 || s[67] != 148 {
        println("  FAIL: bl _hxlcl_malloc (BRANCH26 @0x40) mismatch"); ok = false
    }
    // ret (c0 03 5f d6) @ 0x8c = 140
    if s[140] != 192 || s[141] != 3 || s[142] != 95 || s[143] != 214 {
        println("  FAIL: ret trailer mismatch"); ok = false
    }
    // reloc table: one BRANCH26 @ 64
    let offs = rt_strndup_reloc_offs()
    let kinds = rt_strndup_reloc_kinds()
    if len(offs) != 1 || offs[0] != 64 {
        println("  FAIL: reloc offset expected [64]"); ok = false
    }
    if len(kinds) != 1 || kinds[0] != 2 {
        println("  FAIL: reloc kind expected [2] (BRANCH26)"); ok = false
    }
    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ── rt_free_noop (F3 class-B HARD libc-routed scale-out — trivial leaf) ──
//
// void hxlcl_free(void *p) { (void)p; }
//
// The runtime.c body is a literal noop — the bump allocator (hxlcl_malloc)
// never reclaims, so free is a no-op. Self-emit body is therefore the
// SHORTEST possible function: a single `ret` instruction (no frame, no
// stack, no callee-save). 4 bytes, 0 relocs. This is the cheapest possible
// class-B activation and a stress test of the BEHAVIORAL-equivalence model:
// the emitted .o body and the static C body BOTH discard `p` without
// touching it, so any caller behavior is identical.
//
// macOS arm64 AAPCS · 1 instruction, 4 bytes · zero relocs.
// Registers: x0=p (unused, callee-discarded).
// Returns: void (x0 is don't-care after ret).
fn rt_free_noop() {
    let mut c = []
    // ret  (return; x0 don't-care) 0xD65F03C0
    c.push(192)
    c.push(3)
    c.push(95)
    c.push(214)
    return c
}

// rt_free_noop has NO relocations — trivial leaf, no inner bl, no data refs.
// Empty parallel arrays kept for uniformity with other class-B HARD shadows.
fn rt_free_noop_reloc_offs() {
    let o = []
    return o
}
fn rt_free_noop_reloc_kinds() {
    let k = []
    return k
}

fn test_rt_free_noop() {
    println("test_rt_free_noop (F3 class-B HARD libc-routed scale-out · trivial leaf)")
    let mut ok = true
    let s = rt_free_noop()
    println("  rt_free_noop : " + to_string(len(s)) + " bytes (4 expected)")
    if len(s) != 4 {
        println("  FAIL: rt_free_noop expected 4 bytes"); ok = false
    }
    // ret (c0 03 5f d6) @ 0 — the entire body
    if s[0] != 192 || s[1] != 3 || s[2] != 95 || s[3] != 214 {
        println("  FAIL: ret instruction mismatch"); ok = false
    }
    // reloc table: zero entries (no inner bl, no data ref)
    let offs = rt_free_noop_reloc_offs()
    let kinds = rt_free_noop_reloc_kinds()
    if len(offs) != 0 {
        println("  FAIL: reloc offset expected [] (trivial leaf)"); ok = false
    }
    if len(kinds) != 0 {
        println("  FAIL: reloc kind expected [] (trivial leaf)"); ok = false
    }
    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ═══════════════════════════════════════════════════════════════════════
// === class-D HexaVal-repr bodies (F3 wall-extension · BEHAVIORAL self-emit) ===
// ═══════════════════════════════════════════════════════════════════════
//
// Class-D = HexaVal-returning functions whose body is a HexaVal struct-return
// composite (NOT pointer-return like rt_strdup, NOT a bare struct-pack ctor
// like hexa_bool). These take a HexaVal in x0:x1 and return a HexaVal in
// x0:x1 — exactly the AAPCS ≤16-byte struct ABI, low half = tag (with 4-B
// pad), high half = 8-byte union slot (.i / .b / .s / pointer).
//
// THIS PR extends the PR #1911 wall-reframe (byte-identical-vs-clang was a
// bootstrapping convenience, NOT a governance mandate) to the largest
// remaining HARD layer: ~350-450 fn class-D HexaVal-repr family. The first
// tractable body landed here is `rt_isalpha` — chosen as the SIMPLEST class-D
// body: pure INT-path (no HX_STR deref → no extra null-check loop), 4 range
// comparisons + 1 `bl hexa_bool` ctor call, no callee-saved state needed.
//
// Why rt_isalpha is the right first class-D body:
//   - returns HexaVal (struct-return in x0:x1)  ✓
//   - SHORT body: 16 instr / 64 bytes (well under the ≤30 instr / ≤120 byte
//     cap and the rt_strdup 28-instr precedent)
//   - exactly 1 bl callee (`_hexa_bool`) → 1 BRANCH26 reloc, same shape as
//     rt_strdup's `bl _hxlcl_malloc`
//   - NO callee-saved spills (x19/x20/x21 untouched) — pure scratch x0/x1
//     because `hexa_bool` is the ONLY call and the input `c.i` in x1 is
//     consumed before the bl
//   - clang -O2 inlines `hexa_bool` and computes the range in 5 instr
//     (`and x8,x1,#~0x20; sub x8,x8,#65; cmp x8,#26; cset w1,lo; mov w0,#2`).
//     Our hexa-emitted form is a SCALAR branchy form WITH `bl _hexa_bool` —
//     deliberately NOT byte-identical to clang -O2 (that is the point).
//   - non-overlapping with the parallel `f3-rt-strdup-activation` agent's
//     `rt_strdup`/`hxlcl_strdup` region.
//
// ── ABI (class-D: HexaVal in x0:x1 → HexaVal in x0:x1, sub-call) ──
//   Input:  x0 = tag (TAG_INT = 0 expected) · x1 = c.i (the int codepoint)
//   Output: x0 = tag (TAG_BOOL = 2) · x1 = .b (0 or 1)
//   x29/x30 saved (16-B frame, the `bl` consumes LR).
//   16 instr, 64 bytes · ONE BRANCH26 reloc @ 0x34 (52).
//
// Bytes below are character-identical to `as -arch arm64` of the .s in
// .verdicts/runtime-floor-closure/F3-isalpha-classd-behavioral.txt (NOT to
// clang -O2). Pattern mirrors PR #1911 rt_strdup but for struct-return.
fn rt_isalpha_classd() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!    0xA9BF7BFD  (frame + LR spill, 16-B frame)
    c.push(253); c.push(123); c.push(191); c.push(169)
    // mov x29, sp                  0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // cmp x1, #65 ('A')            0xF101043F  (c.i in x1, low end of [A-Z])
    c.push(63); c.push(4); c.push(1); c.push(241)
    // b.lt .Lzero (+0x24→0x30)     0x5400012B
    c.push(43); c.push(1); c.push(0); c.push(84)
    // cmp x1, #90 ('Z')            0xF101683F  (high end of [A-Z])
    c.push(63); c.push(104); c.push(1); c.push(241)
    // b.le .Lone (+0x14→0x28)      0x540000AD  (in [A-Z] → result 1)
    c.push(173); c.push(0); c.push(0); c.push(84)
    // cmp x1, #97 ('a')            0xF101843F  (low end of [a-z])
    c.push(63); c.push(132); c.push(1); c.push(241)
    // b.lt .Lzero (+0x14→0x30)     0x540000AB
    c.push(171); c.push(0); c.push(0); c.push(84)
    // cmp x1, #122 ('z')           0xF101E83F  (high end of [a-z])
    c.push(63); c.push(232); c.push(1); c.push(241)
    // b.gt .Lzero (+0xc→0x30)      0x5400006C
    c.push(108); c.push(0); c.push(0); c.push(84)
    // .Lone: mov w0, #1            0x52800020  (hexa_bool arg = 1)
    c.push(32); c.push(0); c.push(128); c.push(82)
    // b .Lcall (+0x8→0x34)         0x14000002
    c.push(2); c.push(0); c.push(0); c.push(20)
    // .Lzero: mov w0, #0           0x52800000  (hexa_bool arg = 0)
    c.push(0); c.push(0); c.push(128); c.push(82)
    // bl _hexa_bool [BRANCH26]     0x94000000  (imm zeroed pre-reloc) @ 0x34
    c.push(0); c.push(0); c.push(0); c.push(148)
    // ldp x29, x30, [sp], #16      0xA8C17BFD
    c.push(253); c.push(123); c.push(193); c.push(168)
    // ret                          0xD65F03C0  (return HexaVal in x0:x1)
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

// Reloc table for rt_isalpha_classd — ONE BRANCH26 for `bl _hexa_bool` at
// __text byte offset 0x34 (52). kind 2 = ARM64_RELOC_BRANCH26, undefined-extern
// callee (sym_section==0). Same shape as rt_strdup_reloc_* (PR #1911) and
// rt_atoi_reloc_* (B9.6-B1).
fn rt_isalpha_classd_reloc_offs() {
    let mut o = []
    o.push(52)
    return o
}
fn rt_isalpha_classd_reloc_kinds() {
    let mut k = []
    k.push(2)
    return k
}

fn test_rt_isalpha_classd() {
    println("test_rt_isalpha_classd (F3 class-D HexaVal-repr body · behavioral self-emit)")
    let mut ok = true
    let s = rt_isalpha_classd()
    println("  rt_isalpha_classd : " + to_string(len(s)) + " bytes (64 expected)")
    if len(s) != 64 {
        println("  FAIL: rt_isalpha_classd expected 64 bytes"); ok = false
    }
    // prologue stp x29,x30,[sp,#-16]!  (fd 7b bf a9) @ 0
    if s[0] != 253 || s[1] != 123 || s[2] != 191 || s[3] != 169 {
        println("  FAIL: stp x29,x30 prologue (16-B frame) mismatch"); ok = false
    }
    // bl _hexa_bool (00 00 00 94) @ 0x34 = 52 — the cross-object CALL site
    if s[52] != 0 || s[53] != 0 || s[54] != 0 || s[55] != 148 {
        println("  FAIL: bl _hexa_bool (BRANCH26 @0x34) mismatch"); ok = false
    }
    // ret (c0 03 5f d6) @ 0x3c = 60
    if s[60] != 192 || s[61] != 3 || s[62] != 95 || s[63] != 214 {
        println("  FAIL: ret trailer mismatch"); ok = false
    }
    // reloc table: one BRANCH26 @ 52
    let offs = rt_isalpha_classd_reloc_offs()
    let kinds = rt_isalpha_classd_reloc_kinds()
    if len(offs) != 1 || offs[0] != 52 {
        println("  FAIL: reloc offset expected [52]"); ok = false
    }
    if len(kinds) != 1 || kinds[0] != 2 {
        println("  FAIL: reloc kind expected [2] (BRANCH26)"); ok = false
    }
    if ok {
        println("  ALL CHECKS PASS")
    }
}

test_rt_isalpha_classd()

// ═══════════════════════════════════════════════════════════════════════
// === class-D HARD scale-out — rt_isalnum + rt_pthread_noop + rt_pthread_create_policy
// ═══════════════════════════════════════════════════════════════════════
//
// PR #1914 landed rt_isalpha (16 instr · 64 B · BRANCH26 @0x34 · 1 bl _hexa_bool).
// This wave extends class-D HARD coverage with 3 more HexaVal-repr struct-return
// bodies — each verified by `as -arch arm64` round-trip + behavioral JIT-exec
// against the real ctor callees in runtime_core.c.
//
// Pick rationale (per task spec — ≤30 instr, single-bl, simple, NON-overlapping
// with parallel class-B strdup/strndup/atoll/atof + svc-wrapper agents):
//   1. rt_isalnum — sister of rt_isalpha: same range-cmp template +1 range
//      (digits [0-9]). 20 instr · 80 B · BRANCH26 @0x44 · 1 bl _hexa_bool.
//      Strongest replication signal: highest-confidence pick (1 more range).
//   2. rt_pthread_noop — `return hexa_int(0)`. Trivial single-bl on a DIFFERENT
//      ctor callee (_hexa_int instead of _hexa_bool — new dimension on the
//      template). 6 instr · 24 B · BRANCH26 @0x0C.
//   3. rt_pthread_create_policy — `return hexa_int(1)`. Same shape as #2, only
//      differs in the mov w0 immediate (#1 vs #0). 6 instr · 24 B · BRANCH26
//      @0x0C. Demonstrates that the class-D template scales mechanically by
//      varying just the constant payload.
//
// All three: 16-B frame, LR-spill only, no callee-saved spills (x19/x20/x21
// untouched), HexaVal in x0:x1 → HexaVal in x0:x1.

// ── rt_isalnum_classd (sister of rt_isalpha — extends with [0-9] range) ────
// 20 instr, 80 bytes. Bytes confirmed via `as -arch arm64` round-trip.
fn rt_isalnum_classd() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!    0xA9BF7BFD
    c.push(253); c.push(123); c.push(191); c.push(169)
    // mov x29, sp                  0x910003FD
    c.push(253); c.push(3); c.push(0); c.push(145)
    // cmp x1, #48 ('0')            0xF100C03F  (low end of [0-9])
    c.push(63); c.push(192); c.push(0); c.push(241)
    // b.lt .Lcheck_alpha (+0xc)    0x5400006B
    c.push(107); c.push(0); c.push(0); c.push(84)
    // cmp x1, #57 ('9')            0xF100E43F  (high end of [0-9])
    c.push(63); c.push(228); c.push(0); c.push(241)
    // b.le .Lone (+0x24)           0x5400012D
    c.push(45); c.push(1); c.push(0); c.push(84)
    // cmp x1, #65 ('A')            0xF101043F  (low end of [A-Z])
    c.push(63); c.push(4); c.push(1); c.push(241)
    // b.lt .Lcheck_lower (+0xc)    0x5400006B
    c.push(107); c.push(0); c.push(0); c.push(84)
    // cmp x1, #90 ('Z')            0xF101683F  (high end of [A-Z])
    c.push(63); c.push(104); c.push(1); c.push(241)
    // b.le .Lone (+0x14)           0x540000AD
    c.push(173); c.push(0); c.push(0); c.push(84)
    // cmp x1, #97 ('a')            0xF101843F  (low end of [a-z])
    c.push(63); c.push(132); c.push(1); c.push(241)
    // b.lt .Lzero (+0x14)          0x540000AB
    c.push(171); c.push(0); c.push(0); c.push(84)
    // cmp x1, #122 ('z')           0xF101E83F  (high end of [a-z])
    c.push(63); c.push(232); c.push(1); c.push(241)
    // b.gt .Lzero (+0xc)           0x5400006C
    c.push(108); c.push(0); c.push(0); c.push(84)
    // .Lone: mov w0, #1            0x52800020
    c.push(32); c.push(0); c.push(128); c.push(82)
    // b .Lcall (+0x8)              0x14000002
    c.push(2); c.push(0); c.push(0); c.push(20)
    // .Lzero: mov w0, #0           0x52800000
    c.push(0); c.push(0); c.push(128); c.push(82)
    // bl _hexa_bool [BRANCH26]     0x94000000  @ 0x44 (68)
    c.push(0); c.push(0); c.push(0); c.push(148)
    // ldp x29, x30, [sp], #16      0xA8C17BFD
    c.push(253); c.push(123); c.push(193); c.push(168)
    // ret                          0xD65F03C0
    c.push(192); c.push(3); c.push(95); c.push(214)
    return c
}

fn rt_isalnum_classd_reloc_offs() {
    let mut o = []
    o.push(68)
    return o
