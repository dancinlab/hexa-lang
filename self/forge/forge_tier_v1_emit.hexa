#!hexa strict
// self/forge/forge_tier_v1_emit.hexa
//   B9.C-6 (.c-leg small batch · #1851 self/cuda pattern) — forge_tier_v1.c source emitter.
//
// Mirrors self/cuda/runtime_cuda_emit.hexa one-to-one. self/forge/forge_tier_v1.c
// is consumed by THREE call sites — `#include`'d at self/runtime.c:13266 AND
// scp'd by tool/dispatch_r050_dispatch_validate.sh + r050_perf_inherit_validate.cu
// to remote CUDA hosts. EXACTLY the self/cuda pattern (B9.C-5 #1851):
// activation DEFERRED — only the SELF-EMIT layer + byte-diff oracle land here.
// The hand-written `.c` stays in the tree until a follow-up that also rewires
// runtime.c's `#include` AND the remote-scp call sites.
//
// Invocation:
//   hexa-run self/forge/forge_tier_v1_emit.hexa <output-path>
//
// Default output path (if argv missing): "forge_tier_v1.c" in cwd.
//
// Phase: B9.C-6 batch (cross-TU `#include` target — proof of source-identity only).

let MODULE_NAME = "forge_tier_v1_emit"

fn emit_forge_tier_v1_c() -> str {
    // Verbatim content of hand-written self/forge/forge_tier_v1.c
    let s = "/* ═══════════════════════════════════════════════════════════════════\n" +
            " * forge_tier_v1.c — RFC 050 v1 ABI stub dispatcher.\n" +
            " *\n" +
            " * STAGE A LAND (this file): the API surface is real + stable; the\n" +
            " * Stage 2 tier registry is empty until per-tier substrate RFCs land\n" +
            " * (RFC 044 A'/B'/C' Stage 2, RFC 049 BF16, RFC 048 fused). Calls\n" +
            " * that ask for an unbuilt tier fall back deterministically through\n" +
            " * the RFC 050 §6.6 chain ending at the RFC 040 cuBLAS Dgemm chain\n" +
            " * (or CPU farr on no-CUDA hosts).\n" +
            " *\n" +
            " * MATMUL + FP64 + (any regime) + DET_DEFAULT is routed directly to\n" +
            " * the existing hexa_farr_matmul (CPU + cuBLAS-conditional) - the\n" +
            " * RFC 040 baseline that is the always-available fallback at the\n" +
            " * bottom of the chain. Until Stage 2 tiers register specialized\n" +
            " * kernels, every supported dispatch is a fallback by definition;\n" +
            " * we honestly return FORGE_FALLBACK_USED so callers can log it.\n" +
            " *\n" +
            " * Compiled inline at the end of self/runtime.c so hexa_farr_matmul\n" +
            " * (defined earlier in the same TU) is in scope without a forward\n" +
            " * declaration that would re-clash with HexaVal-vs-int signatures.\n" +
            " *\n" +
            " * SSOT: inbox/rfc_drafts_2026_05_12/rfc_050_flame_forge_integration.md\n" +
            " * ═══════════════════════════════════════════════════════════════════ */\n" +
            "#include \"forge_tier_v1.h\"\n" +
            "\n" +
            "#include <stddef.h>\n" +
            "#include <string.h>\n" +
            "\n" +
            "/* ─── BF16 substrate surface (RFC 049 / RFC 050 Stage 2) ──────────────\n" +
            " * The BF16 precision path routes to runtime_bf16.c's `*_bf16_gpu` entry\n" +
            " * points. Those symbols only exist when this TU is compiled together\n" +
            " * with runtime_bf16.c (the nvcc -x cu build, or a standalone harness\n" +
            " * that #includes runtime_bf16.c before this file). A TU that wants the\n" +
            " * BF16 routing live #defines FORGE_TIER_V1_BF16 — parallel to the\n" +
            " * FORGE_TIER_V1_LIVE guard for the FP64 path. When FORGE_TIER_V1_BF16\n" +
            " * is NOT defined the BF16 branches return FORGE_PRECISION_UNSUPPORTED\n" +
            " * (graceful — no behavior change, no link dependency on runtime_bf16.c).\n" +
            " *\n" +
            " * ABI note (RFC 050 §6.3): for BF16-precision dispatch the\n" +
            " * ForgeArgs.farr_ids[] slots carry `HexaFarrBf16*` pointers cast to\n" +
            " * int64_t via intptr_t — see the ForgeArgs comment in forge_tier_v1.h.\n" +
            " * The dispatcher recovers them with `(HexaFarrBf16*)(intptr_t)id`. */\n" +
            "#ifdef FORGE_TIER_V1_BF16\n" +
            "#include <stdint.h>\n" +
            "/* runtime_bf16.c defines `typedef struct HexaFarrBf16 { ... }\n" +
            " * HexaFarrBf16;` — so the `struct HexaFarrBf16` tag is in scope when\n" +
            " * this file is #included AFTER it (the standalone harness + the nvcc\n" +
            " * TU pattern). A bare `struct HexaFarrBf16;` re-declaration of an\n" +
            " * already-defined tag is legal C; the dispatcher only ever passes the\n" +
            " * pointer through, so the incomplete-type forward decl is sufficient\n" +
            " * for the extern signatures below. The including TU is responsible for\n" +
            " * having runtime_bf16.c's definitions linkable. */\n" +
            "struct HexaFarrBf16;  /* opaque — dispatcher only passes the pointer */\n" +
            "extern int hexa_farr_matmul_bf16_gpu(struct HexaFarrBf16* A,\n" +
            "                                     int64_t M, int64_t K,\n" +
            "                                     struct HexaFarrBf16* B, int64_t N,\n" +
            "                                     struct HexaFarrBf16* C);\n" +
            "extern int hexa_farr_ffn_bf16_gpu(struct HexaFarrBf16* X,\n" +
            "                                  int64_t M, int64_t D, int64_t FD,\n" +
            "                                  struct HexaFarrBf16* W1,\n" +
            "                                  struct HexaFarrBf16* W2,\n" +
            "                                  struct HexaFarrBf16* Y);\n" +
            "#endif /* FORGE_TIER_V1_BF16 */\n" +
            "\n" +
            "/* ─── version ─────────────────────────────────────────────────────── */\n" +
            "uint32_t forge_api_version_v1(void) {\n" +
            "    return FORGE_API_VERSION_V1_ENCODED;\n" +
            "}\n" +
            "\n" +
            "/* ─── specialized registry (in-memory, capped) ────────────────────── */\n" +
            "/* flame Phase 4-C / RFC 048 will populate this at module-init. The v1\n" +
            " * stub stores entries but does NOT consult the registry from dispatch\n" +
            " * yet (no specialized fn_ptr is callable through a single int return\n" +
            " * signature; full plumbing arrives with Stage 2 when specialized\n" +
            " * kernels exist). Empty registry => every dispatch falls back.    */\n" +
            "#define FORGE_REG_CAP 256\n" +
            "typedef struct ForgeRegEntry {\n" +
            "    int                 in_use;\n" +
            "    int                 kernel_family;\n" +
            "    int                 precision_policy;\n" +
            "    int                 regime_hint;\n" +
            "    ForgeShapeInfo      shape;\n" +
            "    void               *fn_ptr;\n" +
            "} ForgeRegEntry;\n" +
            "static ForgeRegEntry _forge_reg_table[FORGE_REG_CAP];\n" +
            "static int           _forge_reg_count = 0;\n" +
            "\n" +
            "int forge_register_specialized_v1(\n" +
            "    int                     kernel_family,\n" +
            "    const ForgeShapeInfo   *shape,\n" +
            "    int                     precision_policy,\n" +
            "    int                     regime_hint,\n" +
            "    void                   *fn_ptr\n" +
            ") {\n" +
            "    if (!shape || !fn_ptr)            return FORGE_INVALID_ARGS;\n" +
            "    if (_forge_reg_count >= FORGE_REG_CAP) return FORGE_INVALID_ARGS;\n" +
            "    ForgeRegEntry *e   = &_forge_reg_table[_forge_reg_count++];\n" +
            "    e->in_use          = 1;\n" +
            "    e->kernel_family   = kernel_family;\n" +
            "    e->precision_policy= precision_policy;\n" +
            "    e->regime_hint     = regime_hint;\n" +
            "    e->shape           = *shape;\n" +
            "    e->fn_ptr          = fn_ptr;\n" +
            "    return FORGE_OK;\n" +
            "}\n" +
            "\n" +
            "/* ─── dispatcher ──────────────────────────────────────────────────── */\n" +
            "/* MATMUL + FP64 path: delegates to hexa_farr_matmul (RFC 040 baseline,\n" +
            " * always available). On non-CUDA hosts this runs the CPU reference;\n" +
            " * on CUDA hosts hexa_farr_matmul forwards through the cuBLAS Dgemm\n" +
            " * path inside runtime.c. Either way: correct, byte-eq with the CPU\n" +
            " * farr oracle, and the bottom of the §6.6 fallback chain.       */\n" +
            "static int _forge_dispatch_matmul_fp64(\n" +
            "    const ForgeShapeInfo *shape,\n" +
            "    const ForgeArgs      *in,\n" +
            "    const ForgeArgs      *out\n" +
            ") {\n" +
            "    if (!shape || !in || !out)        return FORGE_INVALID_ARGS;\n" +
            "    if (in->count  < 2)               return FORGE_INVALID_ARGS;\n" +
            "    if (out->count < 1)               return FORGE_INVALID_ARGS;\n" +
            "    if (shape->M <= 0 || shape->N <= 0 || shape->K <= 0) return FORGE_INVALID_ARGS;\n" +
            "\n" +
            "    int64_t a_id = in->farr_ids[0];\n" +
            "    int64_t b_id = in->farr_ids[1];\n" +
            "\n" +
            "    /* Output-farr contract (L1 slice 1, RFC 050 §6.2):\n" +
            "     * hexa_farr_matmul follows the RFC 032 pattern — it allocates its\n" +
            "     * OWN output farr and returns the integer handle (id into the host\n" +
            "     * _hx_farr_table). The dispatcher does NOT pre-allocate the output\n" +
            "     * farr; instead it writes the produced id back into the caller's\n" +
            "     * out->farr_ids[0] slot so the caller (flame / the forge_dispatch_\n" +
            "     * matmul builtin) can recover the result. The `out` parameter is\n" +
            "     * declared `const ForgeArgs*` for ABI stability, but the result-id\n" +
            "     * write-back is a documented, deliberate exception — we cast away\n" +
            "     * const for that single slot store. The caller still OWNS the farr\n" +
            "     * lifetime (RFC 035/040 arena ownership): the dispatcher produces\n" +
            "     * the handle, the caller releases it. A future _v2 ABI may make\n" +
            "     * `out` non-const to surface this intent in the type. */\n" +
            "    int64_t c_id = out->farr_ids[0];\n" +
            "    (void)c_id;  /* slot is OUT-only: overwritten with the produced id below */\n" +
            "\n" +
            "    /* The live MATMUL+FP64 path delegates to hexa_farr_matmul (defined\n" +
            "     * in runtime.c). That dependency only exists when this TU is\n" +
            "     * compiled inline by runtime.c (which #defines FORGE_TIER_V1_LIVE\n" +
            "     * before the #include). Standalone smoke builds skip the live\n" +
            "     * call so the dispatcher can be unit-tested without linking the\n" +
            "     * whole runtime.                                                 */\n" +
            "#ifdef FORGE_TIER_V1_LIVE\n" +
            "    extern HexaVal hexa_farr_matmul(HexaVal a_v, HexaVal ar_v, HexaVal ac_v,\n" +
            "                                    HexaVal b_v, HexaVal bc_v);\n" +
            "    extern HexaVal hexa_int(int64_t);\n" +
            "    extern int64_t hexa_as_num(HexaVal v);\n" +
            "    HexaVal r = hexa_farr_matmul(hexa_int(a_id),\n" +
            "                                 hexa_int(shape->M),\n" +
            "                                 hexa_int(shape->K),\n" +
            "                                 hexa_int(b_id),\n" +
            "                                 hexa_int(shape->N));\n" +
            "    /* Plumb the produced farr id back into the caller-designated out\n" +
            "     * slot. hexa_farr_matmul returns the farr handle (or hexa_int(-1)\n" +
            "     * on a bad-args / OOM path); hexa_as_num unwraps it to int64_t. The\n" +
            "     * caller checks for a negative id to detect failure. */\n" +
            "    ((ForgeArgs *)out)->farr_ids[0] = hexa_as_num(r);\n" +
            "#else\n" +
            "    (void)a_id; (void)b_id;  /* standalone smoke: ack args, skip live call */\n" +
            "#endif\n" +
            "    /* Stage A: even when MATMUL+FP64 runs the live RFC 040 baseline,\n" +
            "     * report FORGE_FALLBACK_USED — the registry-based specialized\n" +
            "     * path is empty until Stage 2. Caller (flame) can log + continue. */\n" +
            "    return FORGE_FALLBACK_USED;\n" +
            "}\n" +
            "\n" +
            "/* ─── BF16 dispatch helpers (RFC 050 Stage 2, RFC 049 substrate) ──────\n" +
            " * These route FORGE_PREC_PURE_BF16 work to the fire-validated\n" +
            " * runtime_bf16.c entry points (RFC 049 Stage 2 measured-PASS:\n" +
            " * hexa_farr_matmul_bf16_gpu 8.48× FP64 cuBLAS, hexa_farr_ffn_bf16_gpu\n" +
            " * 11.66×). The ForgeArgs.farr_ids[] slots carry HexaFarrBf16* pointers\n" +
            " * cast through intptr_t (see the forge_tier_v1.h ForgeArgs comment).\n" +
            " *\n" +
            " * When FORGE_TIER_V1_BF16 is not defined the BF16 substrate symbols are\n" +
            " * not in scope, so each helper returns FORGE_PRECISION_UNSUPPORTED —\n" +
            " * graceful, no crash, honoring the §6.6 no-crash mandate.            */\n" +
            "\n" +
            "/* MATMUL + PURE_BF16: C[M,N] = A[M,K] @ B[K,N], all HexaFarrBf16.\n" +
            " * in->farr_ids = [A,B]; out->farr_ids = [C]. Maps the kernel's\n" +
            " * 0 ok / -1 err to FORGE_OK / FORGE_KERNEL_UNSUPPORTED. */\n" +
            "static int _forge_dispatch_matmul_bf16(\n" +
            "    const ForgeShapeInfo *shape,\n" +
            "    const ForgeArgs      *in,\n" +
            "    const ForgeArgs      *out\n" +
            ") {\n" +
            "    if (!shape || !in || !out)        return FORGE_INVALID_ARGS;\n" +
            "    if (in->count  < 2)               return FORGE_INVALID_ARGS;\n" +
            "    if (out->count < 1)               return FORGE_INVALID_ARGS;\n" +
            "    if (shape->M <= 0 || shape->N <= 0 || shape->K <= 0) return FORGE_INVALID_ARGS;\n" +
            "#ifdef FORGE_TIER_V1_BF16\n" +
            "    /* farr_ids[] slots are HexaFarrBf16* cast via intptr_t (RFC 050 ABI). */\n" +
            "    struct HexaFarrBf16 *A = (struct HexaFarrBf16*)(intptr_t)in->farr_ids[0];\n" +
            "    struct HexaFarrBf16 *B = (struct HexaFarrBf16*)(intptr_t)in->farr_ids[1];\n" +
            "    struct HexaFarrBf16 *C = (struct HexaFarrBf16*)(intptr_t)out->farr_ids[0];\n" +
            "    if (!A || !B || !C)               return FORGE_INVALID_ARGS;\n" +
            "    int rc = hexa_farr_matmul_bf16_gpu(A, shape->M, shape->K, B, shape->N, C);\n" +
            "    /* Kernel: 0 ok / -1 err. -1 means the BF16 GPU substrate was\n" +
            "     * unavailable or cuBLAS failed — report KERNEL_UNSUPPORTED so the\n" +
            "     * caller can fall back through the §6.6 chain (never crash). */\n" +
            "    return (rc == 0) ? FORGE_OK : FORGE_KERNEL_UNSUPPORTED;\n" +
            "#else\n" +
            "    (void)shape; (void)in; (void)out;\n" +
            "    /* BF16 substrate not compiled in — graceful, no link dependency. */\n" +
            "    return FORGE_PRECISION_UNSUPPORTED;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* FFN_FUSED + PURE_BF16: Y = SiLU(X @ W1) @ W2, all HexaFarrBf16.\n" +
            " * Shape mapping (documented per task spec): M = shape->M (rows),\n" +
            " * D = shape->K (model dim), FD = shape->N (FFN inner dim). The kernel\n" +
            " * signature is hexa_farr_ffn_bf16_gpu(X, M, D, FD, W1, W2, Y).\n" +
            " * in->farr_ids = [X,W1,W2]; out->farr_ids = [Y]. */\n" +
            "static int _forge_dispatch_ffn_bf16(\n" +
            "    const ForgeShapeInfo *shape,\n" +
            "    const ForgeArgs      *in,\n" +
            "    const ForgeArgs      *out\n" +
            ") {\n" +
            "    if (!shape || !in || !out)        return FORGE_INVALID_ARGS;\n" +
            "    if (in->count  < 3)               return FORGE_INVALID_ARGS;\n" +
            "    if (out->count < 1)               return FORGE_INVALID_ARGS;\n" +
            "    if (shape->M <= 0 || shape->N <= 0 || shape->K <= 0) return FORGE_INVALID_ARGS;\n" +
            "#ifdef FORGE_TIER_V1_BF16\n" +
            "    struct HexaFarrBf16 *X  = (struct HexaFarrBf16*)(intptr_t)in->farr_ids[0];\n" +
            "    struct HexaFarrBf16 *W1 = (struct HexaFarrBf16*)(intptr_t)in->farr_ids[1];\n" +
            "    struct HexaFarrBf16 *W2 = (struct HexaFarrBf16*)(intptr_t)in->farr_ids[2];\n" +
            "    struct HexaFarrBf16 *Y  = (struct HexaFarrBf16*)(intptr_t)out->farr_ids[0];\n" +
            "    if (!X || !W1 || !W2 || !Y)       return FORGE_INVALID_ARGS;\n" +
            "    /* M=shape->M, D=shape->K, FD=shape->N — see helper-comment mapping. */\n" +
            "    int rc = hexa_farr_ffn_bf16_gpu(X, shape->M, shape->K, shape->N,\n" +
            "                                    W1, W2, Y);\n" +
            "    return (rc == 0) ? FORGE_OK : FORGE_KERNEL_UNSUPPORTED;\n" +
            "#else\n" +
            "    (void)shape; (void)in; (void)out;\n" +
            "    return FORGE_PRECISION_UNSUPPORTED;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* LAYERCAST (FORGE_PREC_LAYERCAST_BF16_FP32): the substrate kernel\n" +
            " * hexa_farr_layercast_linear_bf16_gpu takes X / Y as plain `float*`\n" +
            " * HOST arrays (only the weight is HexaFarrBf16). The ForgeArgs model\n" +
            " * keys every slot as a farr handle / pointer — it has no clean way to\n" +
            " * carry raw `float*` host activation buffers. Rather than overload the\n" +
            " * int64 slot with a third pointer convention, layercast dispatch is\n" +
            " * left UNSUPPORTED through the ForgeArgs path: callers that need the\n" +
            " * LayerCast linear call hexa_farr_layercast_linear_bf16_gpu directly\n" +
            " * (it is exported from runtime_bf16.c). A future _v2 ABI with an\n" +
            " * explicit host-buffer descriptor would re-home it here.            */\n" +
            "\n" +
            "int forge_tier_dispatch_v1(\n" +
            "    int                     kernel_family,\n" +
            "    const ForgeShapeInfo   *shape,\n" +
            "    int                     regime_hint,\n" +
            "    int                     precision_policy,\n" +
            "    int                     det_mode,\n" +
            "    const ForgeArgs        *in,\n" +
            "    const ForgeArgs        *out\n" +
            ") {\n" +
            "    /* PEDANTIC det mode is FP64-only per RFC 049 §3.3 (BF16 GemmEx\n" +
            "     * Tensor Core algos reduce in algo-dependent order — no cross-mode\n" +
            "     * bit-eq, see runtime_bf16.c contract C4). */\n" +
            "    if (det_mode == FORGE_DET_PEDANTIC && precision_policy != FORGE_PREC_FP64) {\n" +
            "        return FORGE_PRECISION_UNSUPPORTED;\n" +
            "    }\n" +
            "    /* Precision gate (RFC 050 Stage 2). FP64 is always available\n" +
            "     * (RFC 040 baseline). BF16 precisions route to the RFC 049\n" +
            "     * substrate below — no longer rejected outright. LAYERCAST_BF16_FP32\n" +
            "     * is accepted past this gate but its kernel family does not fit the\n" +
            "     * ForgeArgs model (host float* X/Y) — handled per-family below.\n" +
            "     * Any other precision value is genuinely unknown.               */\n" +
            "    if (precision_policy != FORGE_PREC_FP64 &&\n" +
            "        precision_policy != FORGE_PREC_PURE_BF16 &&\n" +
            "        precision_policy != FORGE_PREC_LAYERCAST_BF16_FP32) {\n" +
            "        return FORGE_PRECISION_UNSUPPORTED;\n" +
            "    }\n" +
            "    /* Regime is a hint, not a constraint; AUTO/SMALL/MEDIUM/LARGE all\n" +
            "     * accepted. Out-of-range values are still INVALID_ARGS.         */\n" +
            "    if (regime_hint < FORGE_REGIME_AUTO || regime_hint > FORGE_REGIME_LARGE) {\n" +
            "        return FORGE_INVALID_ARGS;\n" +
            "    }\n" +
            "\n" +
            "    /* ─── BF16 precision routing (RFC 050 Stage 2 / RFC 049) ──────────\n" +
            "     * PURE_BF16 routes MATMUL + FFN_FUSED to the fire-validated\n" +
            "     * runtime_bf16.c entry points. Other (family, BF16) combinations\n" +
            "     * keep returning UNSUPPORTED honestly — their BF16 substrate is not\n" +
            "     * landed. LAYERCAST_BF16_FP32 does not fit the ForgeArgs pointer\n" +
            "     * model (see _forge_dispatch_*_bf16 comments) so it falls through\n" +
            "     * to UNSUPPORTED for every family.                              */\n" +
            "    if (precision_policy == FORGE_PREC_PURE_BF16) {\n" +
            "        switch (kernel_family) {\n" +
            "            case FORGE_KERNEL_MATMUL:\n" +
            "                return _forge_dispatch_matmul_bf16(shape, in, out);\n" +
            "            case FORGE_KERNEL_FFN_FUSED:\n" +
            "                return _forge_dispatch_ffn_bf16(shape, in, out);\n" +
            "            case FORGE_KERNEL_FWD_BWD_LINEAR:\n" +
            "            case FORGE_KERNEL_ATTN_DT_FWD:\n" +
            "            case FORGE_KERNEL_ATTN_DT_BWD:\n" +
            "            case FORGE_KERNEL_RMSNORM_MH:\n" +
            "            case FORGE_KERNEL_SILU_GATE:\n" +
            "            case FORGE_KERNEL_ROPE_MH:\n" +
            "                /* BF16 substrate for these families not landed. */\n" +
            "                return FORGE_KERNEL_UNSUPPORTED;\n" +
            "            default:\n" +
            "                return FORGE_INVALID_ARGS;\n" +
            "        }\n" +
            "    }\n" +
            "    if (precision_policy == FORGE_PREC_LAYERCAST_BF16_FP32) {\n" +
            "        /* LayerCast linear's X/Y are host float* arrays — they do not\n" +
            "         * fit the ForgeArgs farr-handle model. Honest UNSUPPORTED;\n" +
            "         * callers use hexa_farr_layercast_linear_bf16_gpu directly. */\n" +
            "        if (kernel_family < FORGE_KERNEL_MATMUL ||\n" +
            "            kernel_family > FORGE_KERNEL_ROPE_MH) {\n" +
            "            return FORGE_INVALID_ARGS;\n" +
            "        }\n" +
            "        return FORGE_KERNEL_UNSUPPORTED;\n" +
            "    }\n" +
            "\n" +
            "    /* ─── FP64 routing (RFC 040 baseline) ──────────────────────────── */\n" +
            "    switch (kernel_family) {\n" +
            "        case FORGE_KERNEL_MATMUL:\n" +
            "            return _forge_dispatch_matmul_fp64(shape, in, out);\n" +
            "\n" +
            "        case FORGE_KERNEL_FFN_FUSED:\n" +
            "        case FORGE_KERNEL_FWD_BWD_LINEAR:\n" +
            "        case FORGE_KERNEL_ATTN_DT_FWD:\n" +
            "        case FORGE_KERNEL_ATTN_DT_BWD:\n" +
            "        case FORGE_KERNEL_RMSNORM_MH:\n" +
            "        case FORGE_KERNEL_SILU_GATE:\n" +
            "        case FORGE_KERNEL_ROPE_MH:\n" +
            "            /* Stage 2 wiring lands kernel-by-kernel; until then the\n" +
            "             * caller (flame) keeps using the direct *_gpu builtins\n" +
            "             * (e.g. farr_rmsnorm_mh_gpu) instead of routing through\n" +
            "             * the dispatcher.                                       */\n" +
            "            return FORGE_KERNEL_UNSUPPORTED;\n" +
            "\n" +
            "        default:\n" +
            "            return FORGE_INVALID_ARGS;\n" +
            "    }\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "forge_tier_v1.c" }
    let c_text = emit_forge_tier_v1_c()
    let cmd = "cat > \"" + out_path + "\" <<'__FORGE_TIER_V1_EMIT_EOF__'\n" +
              c_text + "__FORGE_TIER_V1_EMIT_EOF__"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[forge_tier_v1_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[forge_tier_v1_emit] wrote " + out_path)
    exit(0)
}
