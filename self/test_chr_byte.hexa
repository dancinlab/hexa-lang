// test_chr_byte — chr() byte-level round-trip regression (RFC chr-byte-vs-codepoint-asymmetry, 2026-05-17)
//
// chr(N) MUST produce a length-1 string whose single byte is N & 0xFF.
// Inverse symmetry with `ord(substring(s, i, 1))` (byte-level read).
// Verified under both `hexa run` (interp) and `hexa build` (compiled).
//
// Pre-fix: chr(N) for N>=0x80 emitted UTF-8 codepoint encoding (2+ bytes).
// Post-fix: chr(240) → 1 byte (0xF0), chr(240)+chr(159)+chr(154)+chr(128)
//           → 4 bytes (the raw bytes of the 🚀 emoji's UTF-8 encoding).
//
// Lowering:
//   - compiled: self/codegen_c2.hexa chr → hexa_chr_byte (self/runtime.c)
//   - interp:   self/hexa_full.hexa chr → bytes_to_str_raw([N & 0xFF])

fn assert_eq(label, got, want) {
    if got == want {
        println("PASS  " + label + ": " + str(got))
    } else {
        println("FAIL  " + label + ": got=" + str(got) + " want=" + str(want))
    }
}

fn main() -> int {
    // Single-byte round-trip across the 0..255 range.
    let mut n = 0
    let mut all_ok = true
    while n < 256 {
        let s = chr(n)
        let got = ord(s.substring(0, 1))
        if got != n {
            println("FAIL chr-ord round-trip at N=" + str(n) + " → got " + str(got))
            all_ok = false
        }
        n = n + 1
    }
    if all_ok {
        println("PASS  chr-ord round-trip 0..255 (256/256)")
    }

    // Length-1 invariant — every chr(N) must produce exactly 1 byte.
    let mut len_ok = true
    let mut n2 = 0
    while n2 < 256 {
        if len(chr(n2)) != 1 {
            println("FAIL chr length at N=" + str(n2) + " → len=" + str(len(chr(n2))))
            len_ok = false
        }
        n2 = n2 + 1
    }
    if len_ok {
        println("PASS  chr length-1 invariant 0..255")
    }

    // The motivating case — synthesise the 🚀 (U+1F680) UTF-8 bytes via chr().
    let rocket = chr(240) + chr(159) + chr(154) + chr(128)
    assert_eq("rocket emoji bytes len", len(rocket), 4)
    assert_eq("rocket byte[0]", ord(rocket.substring(0, 1)), 240)
    assert_eq("rocket byte[1]", ord(rocket.substring(1, 2)), 159)
    assert_eq("rocket byte[2]", ord(rocket.substring(2, 3)), 154)
    assert_eq("rocket byte[3]", ord(rocket.substring(3, 4)), 128)

    // High-bit byte boundary case.
    assert_eq("chr(0x80) len", len(chr(128)), 1)
    assert_eq("chr(0xFF) len", len(chr(255)), 1)

    // ASCII unaffected.
    assert_eq("chr(65)='A'", chr(65), "A")
    assert_eq("chr(10)=newline len", len(chr(10)), 1)

    return 0
}
