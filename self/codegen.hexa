            // (hexa_exec_stream_open / _write / _close_stdin). Same shape as
            // _kill above: explicit emit so user-side `exec_stream_open(cmd)` etc.
            // resolves without hexa_call1 indirection. Filed at
            // archive/patches/wilson-mcp-needs-bidi-stdio.md.
            if name == "exec_stream_open" {
                return "hexa_exec_stream_open(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "exec_stream_write" {
                return "hexa_exec_stream_write(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if name == "exec_stream_close_stdin" {
                return "hexa_exec_stream_close_stdin(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "exec_capture" {
                return "hexa_exec_capture(" + gen2_expr(node.args[0]) + ")"
