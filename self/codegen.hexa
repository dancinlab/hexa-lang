                if name == "farr32_matmul_NT_a" { return "hexa_farr32_matmul_NT_a(" + arg_strs[0] + ", " + arg_strs[1] + ", " + arg_strs[2] + ", " + arg_strs[3] + ", " + arg_strs[4] + ")" }
                // RFC 050 L1 slice 1: forge_dispatch_matmul — routes the
