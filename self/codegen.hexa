    // hexa_option_* runtime helpers needed; the dispatch is closed-form C.
    if method == "unwrap" {
        // Some([_, x]) → x; None → fatal exit. Mirrors Rust panic.
        return "(HX_IS_ARRAY(" + obj_expr + ") ? hexa_index_get(" + obj_expr + ", hexa_int(1)) : (fprintf(stderr, \"hexa: called .unwrap() on None\\n\"), exit(1), hexa_void()))"
    }
    if method == "unwrap_or" {
        // Some([_, x]) → x; None → default.
        return "(HX_IS_ARRAY(" + obj_expr + ") ? hexa_index_get(" + obj_expr + ", hexa_int(1)) : " + gen2_expr(args[0]) + ")"
    }
    if method == "map" {
        // Some([t, x]) → [t, f(x)]; None → None (pass-through).  Use a GCC
        // statement-expression to bind the receiver + closure once each.
        let _fexpr = gen2_expr(args[0])
        return "({ HexaVal __opt_self = " + obj_expr + "; HexaVal __opt_fn = " + _fexpr + "; HX_IS_ARRAY(__opt_self) ? hexa_array_push(hexa_array_push(hexa_array_new(), hexa_index_get(__opt_self, hexa_int(0))), hexa_call1(__opt_fn, hexa_index_get(__opt_self, hexa_int(1)))) : __opt_self; })"
    }
    eprintln("[codegen_c2] ERROR: unknown builtin method: " + method)
    return "(fprintf(stderr, \"CODEGEN ERROR: unknown builtin method: " + method + "\\n\"), exit(1), hexa_void())"
}

// ── b2-fnref: by-value builtin/method thunks ─────────────────
// When a bare identifier naming a builtin/method (not a user fn or local)
// appears in value position (`let f = trim; f(s)` or passed as a callback),
// codegen previously emitted a bare C identifier `trim` which clang rejects
// ("use of undeclared identifier 'trim'"). We instead emit a TAG_FN HexaVal
// wrapping a static C thunk `__hxthunk_<name>` that forwards to the canonical
// method-builtin lowering. Thunk decls are collected here and emitted once
// near the top of the TU (alongside lambda fwd decls). Scope: unambiguous
// string/scalar methods only — polymorphic/array higher-order methods are
// intentionally excluded (`reverse`, `len`, `contains`, `map`, …).
let mut _fnref_thunk_names = []

// Total arity (receiver + args) of a thunk-able builtin method, or -1.
fn _gen2_fnref_method_arity(name) {
    // Deliberately narrow: only string methods that are essentially never
    // used as local-variable identifiers. Bare-Ident scope tracking in
    // gen2_expr is incomplete (single `let x` locals aren't in
    // _gen2_declared_names), so a broad set here would mis-thunk locals like
    // `lines` / `chars` / `bytes`. Wilson's by-value uses (`trim`,
    // `char_at`) are covered. Polymorphic / common-name methods are
    // intentionally excluded.
    // arity 1 — receiver only
    if name == "trim" { return 1 }
    if name == "trim_start" { return 1 }
    if name == "trim_end" { return 1 }
    if name == "to_upper" { return 1 }
    if name == "to_lower" { return 1 }
    if name == "parse_int" { return 1 }
    if name == "parse_float" { return 1 }
    // arity 2 — receiver + 1
    if name == "char_at" { return 2 }
    if name == "char_code_at" { return 2 }
    if name == "byte_at" { return 2 }
    if name == "starts_with" { return 2 }
    if name == "ends_with" { return 2 }
    if name == "pad_left" { return 2 }
    // arity 3 — receiver + 2
    if name == "pad_right" { return 3 }
    return -1
}

// Names declared via `let` in the current function body (or script body).
// Used as a second guard in the by-value builtin/method thunk path so a
// user `let trim = …` is never replaced by a thunk. Set in gen2_fn_decl /
// the script-body walk; over-broad inside lambdas (uses the enclosing fn's
// lets) which is the safe direction (more idents left un-thunked).
let mut _gen2_current_fn_lets = []

// ── Closure mutable-capture by reference (inbox:
//    closure-mut-capture-by-value-snapshot) ──────────────────
// Function-LOCAL `let mut X` bindings that are captured by a closure AND
// assigned to inside the closure body are "boxed" into a 1-element array
// cell. The cell array's `arr_ptr` (backing buffer) is shared by reference
// when the HexaVal is copied (struct copy shares the pointer), and
// `hexa_array_set(cell, 0, v)` mutates in place — so writes through the
// closure are visible in the enclosing scope and persist across calls,
// matching Rust FnMut / JS / Python `nonlocal` semantics.
//
// Codegen contract for a boxed name X (in this fn scope):
//   LetMutStmt:  HexaVal X = hexa_array_push(hexa_array_new(), <init>);
//   Ident read:  hexa_array_get(X, 0)
//   AssignStmt:  X = hexa_array_set(X, 0, <rhs>);   (set returns the cell)
//   Capture:     env push of X pushes the cell (shared arr_ptr) verbatim;
//                inside the lambda `HexaVal X = hexa_array_get(__env, i)`
//                rebinds X to the same cell, so the boxed read/write rules
//                deref it identically. No extra capture logic needed — the
//                boxed-set stays active while the lambda body is emitted.
//
// Scope boundary: ONLY function-local `let mut` reached this path. Module-
// scope `let mut` already works canonically (the closure references the C
// global directly — no env snapshot), so it is never boxed. Read-only
// captures keep the existing by-value snapshot path (no perf/behavior
// change). Set in gen2_fn_decl from a pre-scan; reset per fn.
let mut _gen2_boxed_cells = []

fn _gen2_is_boxed_cell(name) {
    let mut i = 0
    while i < len(_gen2_boxed_cells) {
        if _gen2_boxed_cells[i] == name { return true }
        i = i + 1
    }
    return false
}

// Collect names that appear as the LHS of a simple-Ident assignment
// (AssignStmt / CompoundAssign / LogicalAssign with `node.left.kind ==
// "Ident"`) anywhere in `node`. Index/field assignments are ignored — they
// mutate a container the binding points at, not the binding cell, so they
// already propagate without boxing. Walks the same structural fields as
// gen2_collect_free so nested blocks / lambdas / arms are covered.
fn _gen2_collect_assigned(node, out) {
    if type_of(node) == "string" { return out }
    if type_of(node) == "array" {
        let mut result = out
        let mut i = 0
        while i < len(node) {
            result = _gen2_collect_assigned(node[i], result)
            i = i + 1
        }
        return result
    }
    let k = node.kind
    if k == "AssignStmt" || k == "CompoundAssign" || k == "LogicalAssign" {
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            out = _add_unique(out, node.left.name)
        }
    }
    // Generic structural recursion (mirror gen2_collect_free's coverage).
    let mut result = out
    if type_of(node.left) != "string" {
        result = _gen2_collect_assigned(node.left, result)
    }
    if type_of(node.right) != "string" {
        result = _gen2_collect_assigned(node.right, result)
    }
    if type_of(node.cond) != "string" {
        result = _gen2_collect_assigned(node.cond, result)
    }
    if type_of(node.then_body) != "string" {
        result = _gen2_collect_assigned(node.then_body, result)
    }
    if type_of(node.else_body) != "string" {
        result = _gen2_collect_assigned(node.else_body, result)
    }
    if type_of(node.body) != "string" {
        result = _gen2_collect_assigned(node.body, result)
    }
    if type_of(node.args) == "array" {
        let mut ai = 0
        while ai < len(node.args) {
            result = _gen2_collect_assigned(node.args[ai], result)
            ai = ai + 1
        }
    }
    if type_of(node.items) == "array" {
        let mut ii = 0
        while ii < len(node.items) {
            result = _gen2_collect_assigned(node.items[ii], result)
            ii = ii + 1
        }
    }
    if type_of(node.arms) == "array" {
        let mut mi = 0
        while mi < len(node.arms) {
            let arm = node.arms[mi]
            if type_of(arm.body) == "array" {
                result = _gen2_collect_assigned(arm.body, result)
            }
            mi = mi + 1
        }
    }
    return result
}

// Walk `stmts` (a fn/script body) and find every Lambda node; for each,
// compute (free vars captured) ∩ (names assigned inside the lambda body),
// and union the result into `out`. These are the outer bindings the closure
// both captures and mutates — candidates for boxing. The caller filters to
// those actually declared `let mut` in this scope.
fn _gen2_collect_lambda_mutcaps(node, out) {
    if type_of(node) == "string" { return out }
    if type_of(node) == "array" {
        let mut result = out
        let mut i = 0
        while i < len(node) {
            result = _gen2_collect_lambda_mutcaps(node[i], result)
            i = i + 1
        }
        return result
    }
    let mut result = out
    if node.kind == "Lambda" {
        // Bound names = the lambda's own params (normalize Param obj/string).
        let mut bound = []
        let mut pi = 0
        while pi < len(node.params) {
            bound.push(_lambda_param_name(node.params[pi]))
            pi = pi + 1
        }
        let free = gen2_collect_free(node.left, bound, [])
        let assigned = _gen2_collect_assigned(node.left, [])
        // Intersection: captured AND assigned (and not a lambda param).
        let mut fi = 0
        while fi < len(free) {
            let nm = free[fi]
            let mut is_assigned = false
            let mut aj = 0
            while aj < len(assigned) {
                if assigned[aj] == nm { is_assigned = true }
                aj = aj + 1
            }
            if is_assigned {
                result = _add_unique(result, nm)
            }
            fi = fi + 1
        }
    }
    // Recurse into structural fields so nested lambdas / blocks are covered.
    if type_of(node.left) != "string" {
        result = _gen2_collect_lambda_mutcaps(node.left, result)
    }
    if type_of(node.right) != "string" {
        result = _gen2_collect_lambda_mutcaps(node.right, result)
    }
    if type_of(node.cond) != "string" {
        result = _gen2_collect_lambda_mutcaps(node.cond, result)
    }
    if type_of(node.then_body) != "string" {
        result = _gen2_collect_lambda_mutcaps(node.then_body, result)
    }
    if type_of(node.else_body) != "string" {
        result = _gen2_collect_lambda_mutcaps(node.else_body, result)
    }
    if type_of(node.body) != "string" {
        result = _gen2_collect_lambda_mutcaps(node.body, result)
    }
    if type_of(node.args) == "array" {
        let mut ai = 0
        while ai < len(node.args) {
            result = _gen2_collect_lambda_mutcaps(node.args[ai], result)
            ai = ai + 1
        }
    }
    if type_of(node.items) == "array" {
        let mut ii = 0
        while ii < len(node.items) {
            result = _gen2_collect_lambda_mutcaps(node.items[ii], result)
            ii = ii + 1
        }
    }
    if type_of(node.arms) == "array" {
        let mut mi = 0
        while mi < len(node.arms) {
            let arm = node.arms[mi]
            if type_of(arm.body) == "array" {
                result = _gen2_collect_lambda_mutcaps(arm.body, result)
            }
            mi = mi + 1
        }
    }
    return result
}

// Collect names declared `let mut` (LetMutStmt) anywhere in a fn/script body.
// Restricted to LetMutStmt (NOT LetStmt) — only mutable bindings need cells.
fn _gen2_collect_letmut_names(stmts, names) {
    if type_of(stmts) == "string" { return names }
    if type_of(stmts) != "array" { return names }
    let mut i = 0
    while i < len(stmts) {
        let s = stmts[i]
        if type_of(s) != "string" {
            if s.kind == "LetMutStmt" {
                names = _add_unique(names, s.name)
            }
            if type_of(s.then_body) != "string" { names = _gen2_collect_letmut_names(s.then_body, names) }
            if type_of(s.else_body) != "string" { names = _gen2_collect_letmut_names(s.else_body, names) }
            if type_of(s.body) != "string" { names = _gen2_collect_letmut_names(s.body, names) }
            if type_of(s.arms) == "array" {
                let mut ai = 0
                while ai < len(s.arms) {
                    let arm = s.arms[ai]
                    if type_of(arm) != "string" && type_of(arm.body) != "string" {
                        names = _gen2_collect_letmut_names(arm.body, names)
                    }
                    ai = ai + 1
                }
            }
        }
        i = i + 1
    }
    return names
}

// Compute the boxed-cell set for a fn/script body: names that are declared
// `let mut` AND captured-and-mutated by some closure in the body.
fn _gen2_compute_boxed_cells(body) {
    let mutcaps = _gen2_collect_lambda_mutcaps(body, [])
    if len(mutcaps) == 0 { return [] }
    let letmuts = _gen2_collect_letmut_names(body, [])
    let mut out = []
    let mut i = 0
    while i < len(mutcaps) {
        let nm = mutcaps[i]
        let mut j = 0
        while j < len(letmuts) {
            if letmuts[j] == nm { out = _add_unique(out, nm) }
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// Queue of nested FnDecl / StructDecl encountered during fn body
// codegen. C has no nested fns / local-scoped structs, so gen2_stmt
// pushes them here and emits nothing inline; gen2_program drains the
// queue and runs ast iteration on the hoisted nodes so they appear at
// module/top scope. Non-capturing nested fns are the common case
// (test_native_multi_calls); capturing fns are a closure-conversion
// item for a later cycle.
let mut _gen2_pending_hoist = []

// ── PROBE r15-D2 (2026-05-24): postfix `?` try-propagation state ──
// gen2_expr cannot early-return the enclosing C fn (GCC statement-
// expressions only yield a value), so each `Try` node found while
// emitting a statement's expression is HOISTED: gen2_expr appends the
// success-check + early-return + payload-bind C lines to this buffer and
// returns the unwrapped-payload temp identifier in its place. gen2_stmt
// flushes the buffer (prepending it to the statement's own C) once the
// statement's expressions are fully emitted — so the receiver is
// evaluated exactly once and early-returns route through the same
// defer/arena/plain path the enclosing fn uses (_gen2_emit_tail_return_expr).
// Evaluation order is preserved because gen2_expr recurses inner-first,
// so chained `a()?.b()?` emits the inner `?` preamble before the outer.
// See RFC docs/rfc/rfc_drafts/r15-d2-question-operator.md §3.5 (Case A/B/C).
let mut _gen2_try_preamble = ""
let mut _gen2_try_counter = 0

// Params of the current fn being codegen'd. Used to suppress
// `_known_int_set` / `_known_float_set` false-positives when a
// previous fn's local `let X = 0` registers "X" as known-int and
// the current fn happens to take a param `X: float`. The set is
// module-global by design (no fn-boundary clearing), so without
// this guard the float param gets unboxed via `HX_INT()` → garbage.
// Set in gen2_fn_decl alongside _gen2_current_fn_lets.
let mut _gen2_current_fn_params = []
// Step-3 cycle 76 — parallel array of param-type-annotations populated
// alongside _gen2_current_fn_params. Enables typed-param direct-emit
// for `<`/`>`/`+`/`*` (instead of routing through hexa_cmp_lt/hexa_add)
// and typed-source direct cast for `as int`/`as float`. Empty string
// means no annotation. Indexed in lockstep with _gen2_current_fn_params.
let mut _gen2_current_fn_param_types = []

// Step-3 cycle 76 — return the declared type annotation for a fn-param
// name, or "" if not a param of the current fn.
fn _gen2_param_type(name) {
    let mut i = 0
    while i < len(_gen2_current_fn_params) {
        if _gen2_current_fn_params[i] == name {
            if i < len(_gen2_current_fn_param_types) {
                return _gen2_current_fn_param_types[i]
            }
            return ""
        }
        i = i + 1
    }
    return ""
}

// Step-3 cycle 76 — true iff `name` is a fn param annotated as int-like.
fn _gen2_param_is_int(name) {
    let t = _gen2_param_type(name)
    if t == "int" || t == "i64" || t == "i32" || t == "i16" || t == "i8" { return true }
    return false
}

fn _gen2_param_is_float(name) {
    let t = _gen2_param_type(name)
    if t == "float" || t == "f64" || t == "f32" || t == "Float" { return true }
    return false
}

fn _gen2_name_in_cur_params(name) {
    let mut i = 0
    while i < len(_gen2_current_fn_params) {
        if _gen2_current_fn_params[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _gen2_name_in_cur_lets(name) {
    let mut i = 0
    while i < len(_gen2_current_fn_lets) {
        if _gen2_current_fn_lets[i] == name { return true }
        i = i + 1
    }
    return false
}

// 2026-05-20 orbital-gotcha-A fix: local scope must shadow module-global
// fn names. The five auto-wrap sites in this file (sort_by arg @ ~3389;
// struct field @ ~4106; user-fn call arg @ ~4844; method sort_by @ ~5537;
// indirect-call arg @ ~5608) historically gated only on
// `_is_known_fn_global(name)` — which made any bare Ident whose name
// happened to match an exported stdlib fn (e.g. param `e: float` vs
// stdlib `e()` Euler constant) emit as `hexa_fn_new((void*)e, 0)` and
// break the C build. This helper centralizes the predicate: "should the
// bare Ident `name` be auto-wrapped as a TAG_FN fn-reference?". Returns
// false when the name is shadowed by a current-fn param or let (those
// take precedence per normal lexical-scope rules).
fn _gen2_should_autowrap_fnref(name) {
    if !_is_known_fn_global(name) { return false }
    if _gen2_name_in_cur_params(name) { return false }
    if _gen2_name_in_cur_lets(name) { return false }
    return true
}

// If `name` is a thunk-able builtin/method, register the thunk and return
// the C value expression `hexa_fn_new((void*)__hxthunk_<name>, N)`.
// Returns "" if `name` is not handled.
fn _gen2_fnref_thunk(name) {
    let ar = _gen2_fnref_method_arity(name)
    if ar < 1 { return "" }
    _fnref_thunk_names = _add_unique(_fnref_thunk_names, name)
    return "hexa_fn_new((void*)__hxthunk_" + name + ", " + to_string(ar) + ")"
}

// Emit `static HexaVal __hxthunk_<name>(HexaVal a0, ...) { return <body>; }`
// for every collected thunk name. Body reuses gen2_method_builtin with
// synthetic Ident params a0 (receiver), a1, a2.
fn _gen2_emit_fnref_thunks() {
    let mut out = ""
    let mut i = 0
    while i < len(_fnref_thunk_names) {
        let nm = _fnref_thunk_names[i]
        let ar = _gen2_fnref_method_arity(nm)
        let mut params = []
        let mut synth_args = []
        let mut p = 0
        while p < ar {
            params.push("HexaVal a" + to_string(p))
            if p > 0 {
                synth_args.push(#{ "kind": "Ident", "name": "a" + to_string(p) })
            }
            p = p + 1
        }
        let body = gen2_method_builtin("a0", nm, synth_args)
        // Wrap in an include guard: the SSOT compiler is built by concatenating
        // 4 transpiled modules (lexer/parser/type_checker/codegen_c2) into one
        // TU (hexa cc --regen) — each module that takes the same builtin/method
        // by-value would otherwise emit a duplicate file-scope definition.
        // The bodies are byte-identical, so first-wins is correct.
        out = out + "#ifndef HXTHUNK_" + nm + "_DEFINED\n#define HXTHUNK_" + nm + "_DEFINED\nstatic HexaVal __hxthunk_" + nm + "(" + params.join(", ") + ") { return " + body + "; }\n#endif\n"
        i = i + 1
    }
    return out
}

// ── BinOp `+` chain flattener ────────────────────────────────
// Long string-concat chains (e.g. anima training launcher files,
// 100+ segments) blow past clang's default -fbracket-depth=256 when
// emitted as left-fold hexa_add(hexa_add(...)). We detect `+` chains
// with ≥ _LONG_CONCAT_THRESH operands and emit them as a single
// compound-literal call to hexa_concat_many().
let _LONG_CONCAT_THRESH = 16

// Count operands in a left-leaning `+` chain rooted at `node`.
// A `+` BinOp with a `+` BinOp left child extends the chain; anything
// else is a leaf. Left-associative parse means right children are
// always leaves at this chain level.
fn _plus_chain_len(node) {
    let mut n = 1
    let mut cur = node
    while type_of(cur) != "string" && cur.kind == "BinOp" && cur.op == "+" {
        n = n + 1
        cur = cur.left
    }
    return n
}

// Collect flat list of operand-expression C-strings in left-to-right order.
// Two-phase: (1) snapshot leaf AST nodes walking the left spine (reverse
// order: rightmost first); (2) walk snapshot backwards, call gen2_expr so
// resulting array is left-to-right.
fn _collect_plus_parts(node) {
    let mut leaves_rev = []
    let mut cur = node
    while type_of(cur) != "string" && cur.kind == "BinOp" && cur.op == "+" {
        leaves_rev.push(cur.right)
        cur = cur.left
    }
    leaves_rev.push(cur)
    let mut flat = []
    let mut i = len(leaves_rev) - 1
    while i >= 0 {
        flat.push(gen2_expr(leaves_rev[i]))
        i = i - 1
    }
    return flat
}

// decreases node — structural
fn gen2_expr(node) {
    let k = node.kind

    // UNSHADOW #2 — cross-layer inline pilot: lower an integer literal to a
    // C compound literal `((HexaVal){.tag=TAG_INT,.i=(N)})` instead of an
    // out-of-line `hexa_int(N)` call. The boxing of a literal int has no side
    // effects, so this removes the opaque C-ABI call boundary and lets
    // clang -O2 const-fold / propagate the HexaVal through downstream
    // expressions (e.g. `hexa_add(hexa_int(1), hexa_int(2))` can fold to a
    // single immediate pair). DOUBLE-EVAL SAFE: `node.value` is a pure literal
    // token, never an expression with side effects, so the single textual
    // expansion is the only evaluation. Byte-equivalent to hexa_int():
    // runtime.c:1231 `hexa_int(n)` returns exactly `{ .tag = TAG_INT, .i = n }`.
    if k == "IntLit" { return "((HexaVal){.tag=TAG_INT,.i=(" + node.value + ")})" }
    if k == "FloatLit" { return "hexa_float(" + node.value + ")" }
    if k == "BoolLit" {
        if node.value == "true" { return "hexa_bool(1)" }
        return "hexa_bool(0)"
    }
    if k == "StringLit" { return _strlit_dedup(c_escape(node.value)) }
    // hxa-20260423-014: `comptime { expr }` wrapper. Try to fold via the
    // same evaluator used by ComptimeConst; fall through to runtime eval
    // of the inner expression when the value isn't foldable.
    if k == "ComptimeExpr" {
        let _cx_folded = comptime_eval(node.left)
        if type_of(_cx_folded) != "string" {
            return gen2_expr(_cx_folded)
        }
        return gen2_expr(node.left)
    }
    if k == "CharLit" {
        // Runtime uses TAG_STR for chars (hexa_str_chars returns single-char strings)
        // so char literals must also be TAG_STR for hexa_eq to work
        return _strlit_dedup(c_escape(node.value))
    }
    // ── PROBE r15-D2 (2026-05-24): postfix `?` try-propagation ──
    // `expr?` (Try node) on a tagged-array `[tag, payload]`:
    //   - success tag at index 0 is "Ok" or "Some" → yield the payload.
    //   - any other tag (Err / None / bare "None") → early-return the
    //     receiver UNCHANGED from the enclosing fn (identity re-wrap, §3.4).
    // gen2_expr can't return the enclosing C fn, so the check + early-return
    // are HOISTED into _gen2_try_preamble (flushed by gen2_stmt before the
    // statement) and this site evaluates to the unwrapped-payload temp.
    // node.left is itself emitted via gen2_expr → nested `?` (chains) hoist
