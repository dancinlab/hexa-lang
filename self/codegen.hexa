                if name == "readline"  { return "hexa_input(hexa_str(\"\"))" }
                if name == "random"    { return "hexa_random()" }
                // stdlib/os/proc — 0-arg fork helpers (RFC sshd-forking-daemon)
                if name == "proc_fork"          { return "hexa_proc_fork()" }
                if name == "proc_setsid"        { return "hexa_proc_setsid()" }
                if name == "proc_reap_zombies"  { return "hexa_proc_reap_zombies()" }
                // P7-6 zero-arg time/IO primitives (runtime.c)
                if name == "read_stdin"       { return "hexa_read_stdin()" }
                // TUI-PRIM L1 builtins (zero-arg variants — kick T1.A)
                if name == "term_raw_enter"        { return "hexa_term_raw_enter()" }
                if name == "term_raw_restore"      { return "hexa_term_raw_restore()" }
                if name == "term_winsize_rows"     { return "hexa_term_winsize_rows()" }
                if name == "term_winsize_cols"     { return "hexa_term_winsize_cols()" }
                if name == "term_read_byte"        { return "hexa_term_read_byte()" }
                if name == "term_install_sigwinch" { return "hexa_term_install_sigwinch()" }
                if name == "term_sigwinch_pending" { return "hexa_term_sigwinch_pending()" }
                if name == "term_install_sigint"   { return "hexa_term_install_sigint()" }
                if name == "term_sigint_pending"   { return "hexa_term_sigint_pending()" }
                // stdlib/os/pty — 0-arg builtin (RFC stdlib-os-pty.md)
                if name == "pty_open"              { return "hexa_pty_open()" }
                // stdlib/crypto — 0-arg primitives (RFC ssh-client)
                if name == "libsodium_available"   { return "hexa_libsodium_available()" }
                if name == "ed25519_keypair"       { return "hexa_ed25519_keypair()" }
                if name == "x25519_keypair"        { return "hexa_x25519_keypair()" }
                if name == "term_isatty_stdin"     { return "hexa_term_isatty_stdin()" }
                if name == "term_isatty_stdout"    { return "hexa_term_isatty_stdout()" }
