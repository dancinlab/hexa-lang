            }
            if name == "net_accept" {
                return "hexa_net_accept(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "net_close" {
                return "hexa_net_close(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "net_connect" {
                return "hexa_net_connect(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "net_read" {
                return "hexa_net_read(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "net_read_n" {
                return "hexa_net_read_n(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if name == "net_set_timeout" {
                return "hexa_net_set_timeout(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if name == "net_write" {
                return "hexa_net_write(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
