                // byte-synthesis callers (URL decode, PNG header, emoji prefix).
                // `from_char_code` retains codepoint behaviour for JSON \uXXXX.
                if name == "chr"            { return "hexa_chr_byte(" + a0 + ")" }
                // RFC 030 (2026-05-12): bytes_to_str_raw([int]) — raw byte
                // concatenation, no UTF-8 codepoint re-encoding. Unblocks
                // byte_tokenizer.hexa → string round-trip for Korean / emoji.
                if name == "bytes_to_str_raw" { return "hexa_bytes_to_str_raw(" + a0 + ")" }
                // feat/primitive-float-array (2026-05-12): farr_* primitive
                // (unboxed) packed-double array. 1-arg forms.
                if name == "farr_zeros"     { return "hexa_farr_zeros(" + a0 + ")" }
                if name == "farr_len"       { return "hexa_farr_len(" + a0 + ")" }
                if name == "farr_free"      { return "hexa_farr_free(" + a0 + ")" }
                // FP32 farr32_* mirror (forge GPU path) — same hexa_farr32_* C
