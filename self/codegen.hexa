// ═══════════════════════════════════════════════════════════
//  codegen_c2.hexa — HexaVal 기반 C 코드 생성 (Phase 5)
//  runtime.c와 함께 사용: 문자열, 배열, Map 지원
// ═══════════════════════════════════════════════════════════

// bt-53: mangle user-level global identifiers that collide with runtime.c's
// internal enum values (TAG_INT, TAG_FLOAT, …, TAG_CLOSURE) and `main`. Without
// mangling, `let TAG_INT = 0` emits `HexaVal TAG_INT;` at file scope, which
// collides with runtime.c's `enum { TAG_INT=0, … }` (same ordinary namespace).
// Reserved names get `u_` prefix at every global-decl and reference site.
fn _hexa_name_is_reserved(s) {
    if s == "TAG_INT" { return true }
    if s == "TAG_FLOAT" { return true }
    if s == "TAG_BOOL" { return true }
    if s == "TAG_STR" { return true }
    if s == "TAG_VOID" { return true }
    if s == "TAG_ARRAY" { return true }
    if s == "TAG_MAP" { return true }
    if s == "TAG_FN" { return true }
    if s == "TAG_CHAR" { return true }
    if s == "TAG_CLOSURE" { return true }
    if s == "main" { return true }
    // R7 track B Phase 3/4 (2026-05-18): stdlib.h heap names. The `free`
    // absorbed verb (compiler/free/free.hexa) defines a hexa `fn free`,
    // emitting `HexaVal free(...)` at file scope — collides with
    // <stdlib.h> `void free(void*)` (runtime.c pulls it in), giving
    // "conflicting types for 'free'" + "too many arguments" at every
    // call site. Same class as the math.h wrappers below; mangle to
    // u_free at decl + all references. (drill/chain/omega/surge/dream
    // transitively use compiler/free → same collision.)
    if s == "free" { return true }
    if s == "malloc" { return true }
    if s == "calloc" { return true }
    if s == "realloc" { return true }
    // C2 Step 2 (2026-04-16): C stdlib math names that collide with user-
    // defined wrappers. `fn fabs(x)` in .hexa source would emit
    // `HexaVal fabs(HexaVal x)` at file scope, conflicting with math.h's
    // `double fabs(double)` once runtime.c's `#include <math.h>` pulls in
    // the libc prototype. Mangling to `u_fabs` at both decl and call sites
    // sidesteps this without forcing every test file to rename its helper.
    if s == "fabs" { return true }
    if s == "fabsf" { return true }
    // stdlib.h: div_t div(int, int)
    if s == "div" { return true }
    // math.h Bessel functions: double y0(double), y1(double), j0(double), j1(double)
    if s == "y0" { return true }
    if s == "y1" { return true }
    if s == "j0" { return true }
    if s == "j1" { return true }
    // math.h functions that conflict with user-defined hexa names
    if s == "log" { return true }
    if s == "log2" { return true }
    if s == "log10" { return true }
    if s == "log1p" { return true }
    if s == "exp" { return true }
    if s == "exp2" { return true }
    if s == "expm1" { return true }
    if s == "sqrt" { return true }
    if s == "cbrt" { return true }
    if s == "hypot" { return true }
    if s == "pow" { return true }
    if s == "ceil" { return true }
    if s == "floor" { return true }
    if s == "round" { return true }
    if s == "trunc" { return true }
    if s == "abs" { return true }
    if s == "sin" { return true }
    if s == "cos" { return true }
    if s == "tan" { return true }
    if s == "asin" { return true }
    if s == "acos" { return true }
    if s == "atan" { return true }
    if s == "atan2" { return true }
    if s == "sinh" { return true }
    if s == "cosh" { return true }
    if s == "tanh" { return true }
    if s == "fmax" { return true }
    if s == "fmin" { return true }
    if s == "fma" { return true }
    if s == "erf" { return true }
    if s == "erfc" { return true }
    if s == "gamma" { return true }
    if s == "lgamma" { return true }
    if s == "tgamma" { return true }
    // string.h functions
    if s == "strchr" { return true }
    if s == "strrchr" { return true }
    if s == "strstr" { return true }
    if s == "strcmp" { return true }
    if s == "strncmp" { return true }
    if s == "strcpy" { return true }
    if s == "strncpy" { return true }
    if s == "memcpy" { return true }
    if s == "memcmp" { return true }
    if s == "memset" { return true }
    // stdio.h / stdlib.h functions
    if s == "printf" { return true }
    if s == "fprintf" { return true }
    if s == "sprintf" { return true }
    if s == "snprintf" { return true }
    if s == "scanf" { return true }
    if s == "fopen" { return true }
    if s == "fclose" { return true }
    if s == "fread" { return true }
    if s == "fwrite" { return true }
    // FIX-A 2nd batch (2026-04-19): stdlib.h `void abort(void) __attribute__((noreturn))`
    // collides with anima/training/launch_alm_r11_{a,b,c}.hexa `fn abort(code, msg)`.
    // User's 2-arg wrapper prints msg then exits — mangle to `u_abort` at decl+call sites.
    if s == "abort" { return true }
    // main() formal param names — codegen emits `int main(int argc, char** argv)`.
    // User top-level `let argv = args()` would otherwise shadow the param, causing
    // HexaVal-vs-char** type errors throughout the main body (anima-core/hub.hexa).
    if s == "argv" { return true }
    if s == "argc" { return true }
    // C type keywords that conflict with user-defined hexa names
    if s == "int" { return true }
    if s == "float" { return true }
    if s == "double" { return true }
    if s == "char" { return true }
    if s == "void" { return true }
    if s == "long" { return true }
    if s == "short" { return true }
    if s == "static" { return true }
    if s == "struct" { return true }
    if s == "enum" { return true }
    if s == "union" { return true }
    if s == "const" { return true }
    if s == "extern" { return true }
    if s == "return" { return true }
    if s == "if" { return true }
    if s == "else" { return true }
    if s == "while" { return true }
    if s == "for" { return true }
    if s == "break" { return true }
    if s == "continue" { return true }
    if s == "switch" { return true }
    if s == "case" { return true }
    if s == "default" { return true }
    if s == "sizeof" { return true }
    if s == "typedef" { return true }
    if s == "register" { return true }
    if s == "volatile" { return true }
    if s == "auto" { return true }
    if s == "goto" { return true }
    // C99/C11 keywords — emit `HexaVal inline = ...` etc. parse-fails as
    // they're reserved words at file/block scope. Same shape as the C89
    // keyword block above; user fns/lets named `inline`/`restrict` exist
    // in the wild (e.g. parser/codegen tools modeling the keyword token).
    if s == "inline" { return true }
    if s == "restrict" { return true }
    // C11 underscore-Capital keywords — preemptive audit (2026-04-27).
    // Same parse-fail shape as `inline`/`restrict` if a user fn/let lands
    // on one of these. Reserved by the C11 standard for the language.
    if s == "_Bool" { return true }
    if s == "_Atomic" { return true }
    if s == "_Static_assert" { return true }
    if s == "_Thread_local" { return true }
    if s == "_Generic" { return true }
    if s == "_Alignas" { return true }
    if s == "_Alignof" { return true }
    if s == "_Complex" { return true }
    if s == "_Imaginary" { return true }
    if s == "_Noreturn" { return true }
    // runtime fn-shim variables that clash with user-defined functions
    if s == "matvec" { return true }
    if s == "parse_float" { return true }
    if s == "env" { return true }
    // 2026-04-27: errno is a MACRO in <sys/errno.h> (`#define errno (*__error())`).
    // User-defined `fn _classify(path, errno, syscall)` (hive sandbox_deny_enrich)
    // gets parameter substituted to `(*__error())` at preprocessor stage → arg
    // type mismatch + link fail. Mangling to u_errno at decl+ref sides side-
    // steps the macro expansion. Same class: any libc ERRNO macro identifier.
    if s == "errno" { return true }
    // C7/POSIX collision avoidance (2026-05-14) — these POSIX surface names
    // collide with hexa user fns once <sys/socket.h>, <unistd.h>, etc. are
    // pulled in by runtime.c (transitively via #include). Concrete trigger:
    // `pub fn bind(module)` in compiler/check/bind.hexa transpiled to bare
    // `bind(...)` and clashed with POSIX `int bind(int, const struct sockaddr*,
    // socklen_t)`. Same class: link/connect/accept/listen/open/close/read/write
    // /stat/fork/etc. Additive allowlist (rather than universal `u_` mangling)
    // chosen to minimise blast radius on existing transpiles.
    // socket — <sys/socket.h>
    if s == "bind" { return true }
    if s == "accept" { return true }
    if s == "listen" { return true }
    if s == "connect" { return true }
    if s == "socket" { return true }
    if s == "send" { return true }
    if s == "recv" { return true }
    if s == "shutdown" { return true }
    // file I/O — <unistd.h> / <fcntl.h> / <sys/stat.h>
    if s == "open" { return true }
    if s == "close" { return true }
    if s == "read" { return true }
    if s == "write" { return true }
    if s == "link" { return true }
    if s == "unlink" { return true }
    if s == "stat" { return true }
    if s == "lstat" { return true }
    if s == "fstat" { return true }
    if s == "dup" { return true }
    if s == "dup2" { return true }
    if s == "pipe" { return true }
    if s == "mkdir" { return true }
    if s == "rmdir" { return true }
    if s == "rename" { return true }
    if s == "chdir" { return true }
    if s == "chmod" { return true }
    if s == "chown" { return true }
    // process — <unistd.h> / <sys/wait.h> / <signal.h>
    if s == "fork" { return true }
    if s == "wait" { return true }
    if s == "waitpid" { return true }
    if s == "execv" { return true }
    if s == "execve" { return true }
    if s == "kill" { return true }
    if s == "getpid" { return true }
    if s == "getuid" { return true }
    if s == "setuid" { return true }
    // memory/string — POSIX (sometimes glibc) <strings.h>
    if s == "index" { return true }
    if s == "rindex" { return true }
    // multiplexing — <sys/select.h> / <poll.h>
    if s == "select" { return true }
    if s == "poll" { return true }
    return false
}

fn _hexa_mangle_ident(name) {
    if type_of(name) != "string" { return name }
    if _hexa_name_is_reserved(name) { return "u_" + name }
    return name
}

// 2026-05-20 (blocker-5 self-shadow): check if emitted init text contains a
// reference to `name` as a standalone C identifier token. Used by LetStmt
// codegen to detect cases like `let pi = pi()` where the local would shadow
// the (presumed) function call in its own initializer. The scan is purely
// textual but accurate enough for the common case — we look for `name`
// surrounded by non-identifier chars (the C-emit always tokenizes idents
// with whitespace, parens, commas, or operators around them).
//
// False positives (emit a harmless temp) are preferred over false negatives
// (silent wrong value). False positives are confined to LetStmt emit only.
fn _init_refs_local(init, name) {
    if type_of(init) != "string" { return false }
    if type_of(name) != "string" { return false }
    let nn = len(name)
    if nn == 0 { return false }
    let il = len(init)
    if il < nn { return false }
    let mut i = 0
    while i + nn <= il {
        let seg = init.substring(i, i + nn)
        if seg == name {
            // Check boundary chars before/after — must NOT be C-ident chars.
            let prev_ok = i == 0 || !_is_c_ident_char(init.char_at(i - 1))
            let next_ok = (i + nn) == il || !_is_c_ident_char(init.char_at(i + nn))
            if prev_ok && next_ok {
                return true
            }
        }
        i = i + 1
    }
    return false
}

// C identifier-char predicate: [A-Za-z0-9_]. Single-char string in, bool out.
fn _is_c_ident_char(c) {
    if type_of(c) != "string" { return false }
    if len(c) != 1 { return false }
    if c >= "a" && c <= "z" { return true }
    if c >= "A" && c <= "Z" { return true }
    if c >= "0" && c <= "9" { return true }
    if c == "_" { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
// P7-7 rt_target routing — SSOT mirror of self/codegen/rt_symbols.hexa.
// Inlined because codegen_c2.hexa is a flatten-monolith (use directives
// are comments per tool/flatten_imports.hexa:9). Keep entries byte-
// for-byte in sync with self/codegen/rt_symbols.hexa.
//
// Flip knob: cg_rt_target() = "c" (legacy hexa_*) | "rt" (rt_*_v via abi
// wrappers). Current default "c" preserves all existing behavior — the
// helper returns exactly the same literal the prior inline `return "hexa_*"`
// form produced. Activation (Step C) is a single-line edit below.
// ═══════════════════════════════════════════════════════════════════

fn cg_rt_target() { return "c" }

fn cg_math_sym(name) {
    if cg_rt_target() == "rt" {
        if name == "abs"   { return "rt_math_abs_v" }
        if name == "sqrt"  { return "rt_math_sqrt_v" }
        if name == "floor" { return "rt_math_floor_v" }
        if name == "ceil"  { return "rt_math_ceil_v" }
        if name == "round" { return "rt_math_round_v" }
        if name == "pow"   { return "rt_math_pow_v" }
        if name == "min"   { return "rt_math_min_v" }
        if name == "max"   { return "rt_math_max_v" }
        if name == "sin"   { return "rt_math_sin_v" }
        if name == "cos"   { return "rt_math_cos_v" }
        if name == "tan"   { return "rt_math_tan_v" }
        if name == "asin"  { return "rt_math_asin_v" }
        if name == "acos"  { return "rt_math_acos_v" }
        if name == "atan"  { return "rt_math_atan_v" }
        if name == "atan2" { return "rt_math_atan2_v" }
        if name == "log"   { return "rt_math_log_v" }
        if name == "exp"   { return "rt_math_exp_v" }
        if name == "tanh"  { return "rt_math_tanh_v" }
        // 2026-05-20 (blocker-3 fmod-shim): rt-target mirror of fmod entry.
        if name == "fmod"  { return "rt_math_fmod_v" }
        return ""
    }
    if name == "abs"   { return "hexa_math_abs" }
    if name == "sqrt"  { return "hexa_math_sqrt" }
    if name == "floor" { return "hexa_math_floor" }
    if name == "ceil"  { return "hexa_math_ceil" }
    if name == "round" { return "hexa_math_round" }
    if name == "pow"   { return "hexa_math_pow" }
    if name == "min"   { return "hexa_math_min" }
    if name == "max"   { return "hexa_math_max" }
    if name == "sin"   { return "hexa_math_sin" }
    if name == "cos"   { return "hexa_math_cos" }
    if name == "tan"   { return "hexa_math_tan" }
    if name == "asin"  { return "hexa_math_asin" }
    if name == "acos"  { return "hexa_math_acos" }
    if name == "atan"  { return "hexa_math_atan" }
    if name == "atan2" { return "hexa_math_atan2" }
    if name == "log"   { return "hexa_math_log" }
    if name == "exp"   { return "hexa_math_exp" }
    if name == "tanh"  { return "hexa_math_tanh" }
    // G1-FLOAT-PRIM 2026-05-06 (.roadmap.stdlib.G1) — lgamma + classifiers.
    if name == "lgamma"     { return "hexa_math_lgamma" }
    if name == "isnan"      { return "hexa_math_isnan" }
    if name == "isinf"      { return "hexa_math_isinf" }
    if name == "isfinite"   { return "hexa_math_isfinite" }
    // VERIFY-KIT V4 2026-05-26 — special-function primitives via native libm.
    // gamma == tgamma (true Γ); bessel_j0/j1 alias libm j0/j1. CLAUDE.md
    // stdlib_trig_libm: native libm, never hand-rolled Taylor.
    if name == "gamma"      { return "hexa_math_tgamma" }
    if name == "tgamma"     { return "hexa_math_tgamma" }
    if name == "erf"        { return "hexa_math_erf" }
    if name == "erfc"       { return "hexa_math_erfc" }
    if name == "bessel_j0"  { return "hexa_math_j0" }
    if name == "bessel_j1"  { return "hexa_math_j1" }
    // 2026-05-20 (blocker-3 fmod-shim): expose libm fmod() directly. Distinct
    // from the `%` operator which routes through hexa_mod (int+float branch);
    // user code writing scientific kernels (Track B solar pilot) wants
    // `fmod(x, y)` as a primitive without going through the dispatch.
    if name == "fmod"       { return "hexa_math_fmod" }
    // f64<->bits reinterpret primitives (RUNTIME, INBOX 2026-05-27). Real
    // builtin replacing the nanbox.hexa stub (`return 0`). union-pun in
    // runtime; returns tagged int (float_to_bits) / float (bits_to_float).
    if name == "float_to_bits" { return "hexa_float_to_bits" }
    if name == "bits_to_float" { return "hexa_bits_to_float" }
    return ""
}

fn cg_string_sym(name) {
    if cg_rt_target() == "rt" {
        if name == "str_concat"      { return "rt_str_concat_v" }
        if name == "str_contains"    { return "rt_str_contains_v" }
        if name == "str_eq"          { return "rt_str_eq_v" }
        if name == "str_substring"   { return "rt_str_substring_v" }
        if name == "str_slice"       { return "rt_str_slice_v" }
        if name == "str_trim"        { return "rt_str_trim_v" }
        if name == "str_trim_start"  { return "rt_str_trim_start_v" }
        if name == "str_trim_end"    { return "rt_str_trim_end_v" }
        if name == "str_replace"     { return "rt_str_replace_v" }
        if name == "str_pad_left"    { return "rt_str_pad_left_v" }
        if name == "str_pad_right"   { return "rt_str_pad_right_v" }
        if name == "str_repeat"      { return "rt_str_repeat_v" }
        if name == "str_index_of"    { return "rt_str_index_of_v" }
        if name == "str_index_of_from" { return "rt_str_index_of_from_v" }
        if name == "str_last_index_of" { return "rt_str_last_index_of_v" }
        if name == "str_reverse"     { return "rt_str_reverse_v" }
        if name == "str_split"       { return "rt_str_split_v" }
        if name == "str_join"        { return "rt_str_join_v" }
        if name == "str_to_upper"    { return "rt_str_to_upper_v" }
        if name == "str_to_lower"    { return "rt_str_to_lower_v" }
        if name == "str_char_at"     { return "rt_str_char_at_v" }
        if name == "str_char_code_at"{ return "rt_str_char_code_at_v" }
        if name == "str_parse_int"   { return "rt_str_parse_int_v" }
        if name == "str_parse_float" { return "rt_str_parse_float_v" }
        if name == "str_bytes"       { return "rt_str_bytes_v" }
        if name == "str_from_chars"  { return "rt_str_from_chars_v" }
        // Gap-closure 2026-04-19 (7 symbols, alphabetical):
        if name == "str_center"      { return "rt_str_center_v" }
        if name == "str_chars"       { return "rt_str_chars_v" }
        if name == "str_ends_with"   { return "rt_str_ends_with_v" }
        if name == "str_len"         { return "rt_str_len_v" }
        if name == "str_lines"       { return "rt_str_lines_v" }
        if name == "str_starts_with" { return "rt_str_starts_with_v" }
        if name == "str_substr"      { return "rt_str_substr_v" }
        return ""
    }
    if name == "str_concat"      { return "hexa_str_concat" }
    if name == "str_contains"    { return "hexa_str_contains" }
    if name == "str_eq"          { return "hexa_str_eq" }
    if name == "str_substring"   { return "hexa_str_substring" }
    if name == "str_slice"       { return "hexa_str_slice" }
    if name == "str_trim"        { return "rt_str_trim" }
    if name == "str_trim_start"  { return "rt_str_trim_start" }
    if name == "str_trim_end"    { return "rt_str_trim_end" }
    if name == "str_replace"     { return "hexa_str_replace" }
    if name == "str_pad_left"    { return "rt_str_pad_left" }
    if name == "str_pad_right"   { return "rt_str_pad_right" }
    if name == "str_repeat"      { return "rt_str_repeat" }
    if name == "str_index_of"    { return "hexa_str_index_of" }
    if name == "str_index_of_from" { return "hexa_str_index_of_from" }
    if name == "str_last_index_of" { return "hexa_str_last_index_of" }
    if name == "str_reverse"     { return "hexa_str_reverse" }
    if name == "str_split"       { return "hexa_str_split" }
    if name == "str_join"        { return "hexa_str_join" }
    if name == "str_to_upper"    { return "rt_str_to_upper" }
    if name == "str_to_lower"    { return "rt_str_to_lower" }
    if name == "str_char_at"     { return "hexa_str_char_at" }
    if name == "str_char_code_at"{ return "hexa_str_char_code_at" }
    if name == "str_char_count"    { return "hexa_str_char_count" }
    if name == "str_graphemes"     { return "hexa_str_graphemes" }
    if name == "str_grapheme_count"{ return "hexa_str_grapheme_count" }
    if name == "str_nth_char"      { return "hexa_str_nth_char" }
    if name == "str_char_substring"{ return "hexa_str_char_substring" }
    if name == "str_byte_at"       { return "hexa_str_byte_at" }
    if name == "str_parse_int"   { return "hexa_str_parse_int" }
    if name == "str_parse_float" { return "hexa_str_parse_float" }
    if name == "str_bytes"       { return "hexa_str_bytes" }
    if name == "str_from_chars"  { return "hexa_str_from_chars" }
    // Gap-closure 2026-04-19 (7 symbols, alphabetical):
    if name == "str_center"      { return "rt_str_center" }
    if name == "str_chars"       { return "hexa_str_chars" }
    if name == "str_ends_with"   { return "rt_str_ends_with" }
    if name == "str_len"         { return "hexa_str_len" }
    if name == "str_lines"       { return "rt_str_lines" }
    if name == "str_starts_with" { return "rt_str_starts_with" }
    if name == "str_substr"      { return "hexa_str_substr" }
    return ""
}

// ═══════════════════════════════════════════════════════════
//  `use` / `import` resolver (2026-04-18)
// ─────────────────────────────────────────────────────────────
// Problem (pre-fix): codegen_c2 treated UseStmt / ImportStmt as opaque and
// emitted only a stderr WARNING. When anima transpiled single files without
// running tool/flatten_imports.hexa first, call sites to imported module
// fns got no extern forward declaration — clang then fell back to K&R
// implicit-int, producing "undefined reference" at link time and, where
// symbols DO exist in a sibling .c, subtle ABI mismatches (int-return vs
// HexaVal-return) and garbage HexaVal bits.
//
// Root fix: resolve `<path>.hexa` via a 4-way search, lightweight-scan its
// top-level `fn`, `pub fn`, and `struct` declarations, and emit
// `HexaVal <name>(HexaVal, …);` forward decls. This unblocks single-file
// transpile of the 88 anima .hexa files and any user project using
// `use "sibling_module"` without the flatten preprocessor.
//
// Deliberate scope (keep minimal):
//   * Text-scan only top-level decls — we do NOT reparse. Nested `fn`
//     inside a body never appears at column 0.
//   * Single-line signatures only (multi-line `fn f(\n  a,\n  b)` rare in
//     anima; those call sites fall back to indirect-call path unharmed).
//   * Arity counted by splitting `(…)` on commas, ignoring an empty body.
//   * Module deduplication via _resolved_modules array — a file `use`d by
//     two others still emits its externs once.
//   * Caller-directory hint: read args()[2] (the input.hexa path) once and
//     cache its dirname. Fallback: $HEXA_LANG/self, cwd, `./self`, `./`.

let mut _resolved_modules = []
let mut _resolve_caller_dir = ""
let mut _resolve_caller_dir_inited = false

fn _resolve_dirname(path) {
    if type_of(path) != "string" { return "." }
    let n = len(path)
    let mut i = n - 1
    while i >= 0 {
        if path.substring(i, i + 1) == "/" {
            return path.substring(0, i)
        }
        i = i - 1
    }
    return "."
}

fn _resolve_caller_dir_get() {
    if _resolve_caller_dir_inited { return _resolve_caller_dir }
    _resolve_caller_dir_inited = true
    let av = args()
    // args layout under hexat native: [hexat_bin, input.hexa, output.c]
    // (hexat's hexa_set_args does NOT dup argv[0], unlike the script path).
    // Walk from index 1 looking for the first arg ending in .hexa — that's
    // the input file whose dirname we want.
    let n = len(av)
    let mut i = 1
    while i < n {
        let a = av[i]
        if type_of(a) == "string" {
            let al = len(a)
            if al >= 5 {
                let tail = a.substring(al - 5, al)
                if tail == ".hexa" {
                    _resolve_caller_dir = _resolve_dirname(a)
                    return _resolve_caller_dir
                }
            }
        }
        i = i + 1
    }
    _resolve_caller_dir = "."
    return _resolve_caller_dir
}

fn _resolve_try_candidate(cand) {
    if len(cand) == 0 { return "" }
    if file_exists(cand) { return cand }
    return ""
}

fn _resolve_use_path(name) {
    if type_of(name) != "string" { return "" }
    if len(name) == 0 { return "" }
    // Accept both `use "foo"` and `use "foo.hexa"` — strip trailing .hexa
    // so we don't double-append below. Fixes 2026-04-18 serve_alm regression
    // where `use "self/ml/hxblas_bf16.hexa"` became `…hxblas_bf16.hexa.hexa`.
    let mut base = name
    let bn = len(base)
    if bn >= 5 {
        let tail = base.substring(bn - 5, bn)
        if tail == ".hexa" {
            base = base.substring(0, bn - 5)
        }
    }
    // 1) caller-relative (dirname of args()[2]).
    let cdir = _resolve_caller_dir_get()
    let cand1 = cdir + "/" + base + ".hexa"
    let r1 = _resolve_try_candidate(cand1)
    if len(r1) > 0 { return r1 }
    // 2) $HEXA_LANG/self/<name>.hexa (stdlib + self/runtime/ etc.)
    let hl = env_var("HEXA_LANG")
    if type_of(hl) == "string" && len(hl) > 0 {
        let cand2 = hl + "/self/" + base + ".hexa"
        let r2 = _resolve_try_candidate(cand2)
        if len(r2) > 0 { return r2 }
        // 2b) $HEXA_LANG/<name>.hexa (project-root layouts).
        let cand2b = hl + "/" + base + ".hexa"
        let r2b = _resolve_try_candidate(cand2b)
        if len(r2b) > 0 { return r2b }
    }
    // 3) cwd + common project layouts.
    let r3 = _resolve_try_candidate(base + ".hexa")
    if len(r3) > 0 { return r3 }
    let r4 = _resolve_try_candidate("self/" + base + ".hexa")
    if len(r4) > 0 { return r4 }
    return ""
}

// Already-resolved check (O(n) but n is small; hash set is overkill here).
fn _resolve_is_seen(name) {
    let n = len(_resolved_modules)
    let mut i = 0
    while i < n {
        if _resolved_modules[i] == name { return true }
        i = i + 1
    }
    return false
}

// Skip blanks + tabs at start of line — inlined to avoid str method chains
// that the pre-fix interp transpiler handles fractionally slower.
fn _resolve_line_col0(line) {
    if type_of(line) != "string" { return false }
    if len(line) == 0 { return false }
    let c = line.substring(0, 1)
    if c == " " { return false }
    if c == "\t" { return false }
    return true
}

// Count formal-parameter arity from a "p1, p2, p3" body string. Empty body → 0.
fn _resolve_param_arity(body) {
    if type_of(body) != "string" { return 0 }
    let t = body.trim()
    if len(t) == 0 { return 0 }
    // Depth-aware split on ',': ignore commas inside nested parens/brackets
    // (default-value expressions like `x = foo(a, b)` — rare in hexa sigs
    // but safe to handle).
    let n = len(t)
    let mut depth = 0
    let mut count = 1
    let mut i = 0
    while i < n {
        let c = t.substring(i, i + 1)
        if c == "(" || c == "[" || c == "{" { depth = depth + 1 }
        else if c == ")" || c == "]" || c == "}" { depth = depth - 1 }
        else if c == "," && depth == 0 { count = count + 1 }
        i = i + 1
    }
    return count
}

// Parse a single top-level `fn` signature line. Returns "name|arity" on match,
// "" otherwise. Handles `fn`, `pub fn`, and `@attr[,attr2] fn` prefixes.
fn _resolve_parse_fn_sig(line) {
    if !_resolve_line_col0(line) { return "" }
    let raw = line
    // Strip trailing block brace and comments via trim — we only need the
    // segment up to the opening `{`.
    let brace = raw.index_of("{")
    let mut sig = raw
    if brace >= 0 { sig = raw.substring(0, brace) }
    sig = sig.trim()
    // Drop leading @attr(…) / @attr segment — attrs end before the last
    // space preceding `fn` / `pub fn`.
    if sig.starts_with("@") {
        // Find " fn " or " pub fn " inside the line.
        let pfn = sig.index_of(" pub fn ")
        let fnsp = sig.index_of(" fn ")
        let mut cut = -1
        if pfn >= 0 { cut = pfn + 1 }
        else if fnsp >= 0 { cut = fnsp + 1 }
        if cut < 0 { return "" }
        sig = sig.substring(cut, len(sig))
    }
    if sig.starts_with("pub fn ") {
        sig = sig.substring(7, len(sig))
    } else if sig.starts_with("fn ") {
        sig = sig.substring(3, len(sig))
    } else {
        return ""
    }
    // sig now looks like `name(p1, p2) -> RetType` or `name(p1, p2)`.
    let lp = sig.index_of("(")
    if lp < 0 { return "" }
    let name = sig.substring(0, lp).trim()
    if len(name) == 0 { return "" }
    let rest = sig.substring(lp + 1, len(sig))
    let rp = rest.index_of(")")
    if rp < 0 { return "" }
    let body = rest.substring(0, rp)
    let arity = _resolve_param_arity(body)
    return name + "|" + to_string(arity)
}

// Parse a `struct Name { … }` line (single-line form). Struct constructors
// are callable as `Name(field1, …)` so we emit extern decls for them too.
// Arity must come from FIELD count — but fields span multiple lines, so
// single-line single-brace structs only. Conservative: emit only the name
// with arity 0 marker "S|" and let _resolve_struct_fields fill arity from
// the lines array.
fn _resolve_parse_struct_start(line) {
    if !_resolve_line_col0(line) { return "" }
    let t = line.trim()
    let body = t
    if body.starts_with("pub struct ") {
        body = body.substring(11, len(body))
    } else if body.starts_with("struct ") {
        body = body.substring(7, len(body))
    } else {
        return ""
    }
    // Strip `{` and anything after.
    let lb = body.index_of("{")
    let namepart = if lb >= 0 { body.substring(0, lb) } else { body }
    let name = namepart.trim()
    if len(name) == 0 { return "" }
    return name
}

// Emit `HexaVal name(HexaVal, …);` from a "name|arity" record.
fn _resolve_emit_extern_fn(rec) {
    let bar = rec.index_of("|")
    if bar < 0 { return "" }
    let name = rec.substring(0, bar)
    let ar_str = rec.substring(bar + 1, len(rec))
    // to_int not universally available; parse by digit accumulation.
    let arity = _resolve_parse_int(ar_str)
    let mangled = _hexa_mangle_ident(name)
    let mut params = ""
    if arity == 0 {
        params = "void"
    } else {
        let mut i = 0
        while i < arity {
            if i > 0 { params = params + ", " }
            params = params + "HexaVal"
            i = i + 1
        }
    }
    return "extern HexaVal " + mangled + "(" + params + ");\n"
}

fn _resolve_parse_int(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    let mut i = 0
    let mut v = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let o = ord(c)
        if o >= 48 && o <= 57 {
            v = v * 10 + (o - 48)
        }
        i = i + 1
    }
    return v
}

// Pass-0 helper: register imported fn/struct names into known-global sets
// WITHOUT emitting C fwd text. Called during pre-scan so a local fn body
// that references an imported fn before its `use` line appears in source
// order still classifies that name correctly. Does NOT mark the module
// as seen so the later emit-pass call still produces extern decls.
fn _resolve_use_register_names(name) {
    if type_of(name) != "string" { return 0 }
    if len(name) == 0 { return 0 }
    let path = _resolve_use_path(name)
    if len(path) == 0 { return 0 }
    let src = read_file(path)
    if type_of(src) != "string" || len(src) == 0 { return 0 }
    let lines = src.split("\n")
    let ln = len(lines)
    let mut i = 0
    while i < ln {
        let line = lines[i]
        let rec = _resolve_parse_fn_sig(line)
        if len(rec) > 0 {
            let bar = rec.index_of("|")
            let fname = rec.substring(0, bar)
            _known_fn_globals.push(fname)
            _known_nonlocal_names.push(fname)
            _known_fn_globals_add(fname)
            _known_nonlocal_add(fname)
        } else {
            let sname = _resolve_parse_struct_start(line)
            if len(sname) > 0 {
                _known_fn_globals.push(sname)
                _known_nonlocal_names.push(sname)
                _known_fn_globals_add(sname)
                _known_nonlocal_add(sname)
            }
        }
        i = i + 1
    }
}

// Main entry: resolve `use "name"` → extern fwd decl string. Also registers
// every scanned fn name into _known_fn_globals / _known_nonlocal sets so
// gen2_expr treats them as first-class callees (not free-variable captures).
// Returns the extern-forward C fragment (possibly empty). Safe to call
// twice for the same name — second call is a no-op (deduped).
fn _resolve_use_emit(name) {
    if type_of(name) != "string" { return "" }
    if len(name) == 0 { return "" }
    if _resolve_is_seen(name) { return "" }
    _resolved_modules.push(name)
    let path = _resolve_use_path(name)
    if len(path) == 0 {
        eprintln("[codegen_c2] use not found on disk: " + name + " (4-way search: caller-dir, $HEXA_LANG/self, $HEXA_LANG, cwd, ./self)")
        return "/* use: " + name + " (unresolved path) */\n"
    }
    let src = read_file(path)
    if type_of(src) != "string" || len(src) == 0 {
        eprintln("[codegen_c2] use resolved but read_file empty: " + path)
        return "/* use: " + name + " (empty source) */\n"
    }
    let lines = src.split("\n")
    let ln = len(lines)
    let mut out = ""
    out = out + "/* use: " + name + " -> " + path + " */\n"
    let mut i = 0
    while i < ln {
        let line = lines[i]
        let rec = _resolve_parse_fn_sig(line)
        if len(rec) > 0 {
            let bar = rec.index_of("|")
            let fname = rec.substring(0, bar)
            // Register for closure/free-var analysis + known-fn-global table.
            _known_fn_globals.push(fname)
            _known_nonlocal_names.push(fname)
            _known_fn_globals_add(fname)
            _known_nonlocal_add(fname)
            out = out + _resolve_emit_extern_fn(rec)
        } else {
            let sname = _resolve_parse_struct_start(line)
            if len(sname) > 0 {
                // Struct constructors are callable — register name. Arity
                // cannot be cheaply recovered without spanning multiple lines;
                // leave extern emission off (downstream call path falls through
                // to indirect-call or variadic shim). Registration alone is
                // enough to prevent free-var capture misclassification.
                _known_fn_globals.push(sname)
                _known_nonlocal_names.push(sname)
                _known_fn_globals_add(sname)
                _known_nonlocal_add(sname)
            }
        }
        i = i + 1
    }
    return out
}

// 2026-05-19 keyword-audit gap ModStmt — `mod name { decls }` is a
// namespace block whose body holds declarations. C has no namespaces,
// so the honest lowering is decl-hoisting: splice the body's decls into
// module scope, exactly the pattern _gen2_lift_nested_decls uses for
// nested fns/structs. Nested `mod` flattens recursively. A non-decl
// stmt in a mod body simply becomes a top-level stmt (consistent with
// the existing script-body convention). Zero real usage today (only
// test_keyword_audit's `mod mymod { fn inner() {...} }`).
// LIMITATION: symbols are NOT namespace-prefixed and qualified
// `modname::sym` references are not resolved here — per-mod symbol
// prefixing + qualified-path resolution is a later cycle if real `mod`
// usage with cross-mod name collisions ever lands. A `mod` nested
// inside a fn body is also out of scope (same shallow-walk boundary as
// _gen2_lift_nested_decls); top-level / script-body `mod` is covered.
fn _gen2_flatten_mods(ast) {
    let mut out = []
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        if node.kind == "ModStmt" {
            let _mbody = node.body
            if type_of(_mbody) != "string" {
                let _flat = _gen2_flatten_mods(_mbody)
                let mut bi = 0
                while bi < len(_flat) {
                    out = out.push(_flat[bi])
                    bi = bi + 1
                }
            }
        } else {
            out = out.push(node)
        }
        i = i + 1
    }
    return out
}

// 2026-05-19 parity-gate test_native_multi_calls — nested FnDecl /
// StructDecl in a fn body need module-scope hoisting (C has no nested
// fns / locally-scoped structs). Shallow walk: lift declarations from
// the TOP of each top-level fn body to the ast array. Non-capturing
// case is the common one (helper fns + types that take all data as
// params). Capturing-fn closure-conversion is a later cycle.
fn _gen2_lift_nested_decls(ast) {
    let mut lifted = []
    let mut seen_names = []
    // 2026-05-19 keyword-audit gap "ExternFnDecl in statement position":
    // pre-seed seen_names with EXISTING top-level decl names so a nested
    // decl whose name already lives at module scope is NOT lifted as a
    // duplicate. Without this, a script with both a top-level `extern fn
    // getpid()` and a fn-body-nested `extern fn getpid()` would lift the
    // nested copy → the top-level emit loop emits the FFI wrapper twice →
    // clang "redefinition of 'u_getpid'". The top-level node always wins.
    let mut _ti = 0
    while _ti < len(ast) {
        let _tk = ast[_ti].kind
        if _tk == "FnDecl" || _tk == "PureFnDecl" || _tk == "StructDecl" || _tk == "ExternFnDecl" {
            seen_names = seen_names.push(ast[_ti].name)
        }
        _ti = _ti + 1
    }
    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" || k == "PureFnDecl" {
            let _body = ast[i].body
            if type_of(_body) != "string" {
                let mut bi = 0
                while bi < len(_body) {
                    let stmt = _body[bi]
                    let sk = stmt.kind
                    if sk == "FnDecl" || sk == "PureFnDecl" || sk == "StructDecl" || sk == "ExternFnDecl" {
                        // First-wins dedup by name — multiple test_* fns
                        // share helper struct/fn names (e.g., FuncSymbol,
                        // CallFixup, patch_call_fixups_arm64). For struct
                        // decls with identical bodies (test corpus) and
                        // for non-capturing helper fns, first-wins gives
                        // a clean module-scope emission without C
                        // "redefinition" errors. Different-bodied
                        // collisions accept the first definition (per-
                        // test customisation is a closure-conversion
                        // item for a later cycle).
                        // 2026-05-19 keyword-audit gap "ExternFnDecl in
                        // statement position": an `extern fn` written at
                        // the TOP of a fn body must also hoist to module
                        // scope — C has no nested fns and the FFI wrapper
                        // (dlsym slot + static wrapper) only emits via the
                        // top-level ExternFnDecl branch. The seen_names
                        // dedup + the top-level branch's own `extern_fns`/
                        // `_fn_emit_seen` set guard against double-emit
                        // (C "redefinition"); the original nested copy is
                        // silently skipped by gen2_stmt's decl-skip below.
                        let _nm = stmt.name
                        let mut dup = false
                        let mut sni = 0
                        while sni < len(seen_names) {
                            if seen_names[sni] == _nm { dup = true }
                            sni = sni + 1
                        }
                        if !dup {
                            seen_names = seen_names.push(_nm)
                            lifted = lifted.push(stmt)
                        }
                    }
                    bi = bi + 1
                }
            }
        }
        i = i + 1
    }
    let mut out_ast = ast
    let mut li = 0
    while li < len(lifted) {
        out_ast = out_ast.push(lifted[li])
        li = li + 1
    }
    return out_ast
}

fn codegen(ast) {
    // Lift any FnDecl / StructDecl nested at the top of a fn body to
    // module scope — C has no nested fns / local types. Hexa arrays
    // are pass-by-value here (in-place push to the param wasn't
    // reaching the L923 codegen iteration), so the lift returns a new
    // array and we rebind `ast` via shadowing.
    let ast = _gen2_lift_nested_decls(_gen2_flatten_mods(ast))
    // Use arrays to avoid O(n²) string concatenation
    let mut parts = []
    parts.push("// Generated by HEXA self-host compiler\n")
    // PHASE 1.3.B (2026-05-15) — emit `#include "runtime.h"` so user.c
    // links against the precompiled runtime.o instead of re-codegenning
    // the entire 12K-LOC runtime.c per build. See COMPILE-SPEED.tape +
    // bin/hexa-fast (the wrapper that mechanically did this via sed
    // before this commit promoted the change into codegen itself).
    //
    // Escape hatch (2026-05-15) — downstream projects that aren't yet ready
    // for the runtime.o linkage model (= the monolithic compile path most of
    // them still use today) hit "undeclared function" errors because the
    // header doesn't yet re-export the runtime_hi_gen.c `static` rt_* stdlib
    // helpers. Set HEXA_USE_RUNTIME_C=1 to revert to the legacy include and
    // keep building until the header migration is complete.
    // (Patch issue: archive/patches/runtime-h-incomplete-after-phase-1-3-b.md)
    let runtime_inc = if env("HEXA_USE_RUNTIME_C") != "" { "runtime.c" } else { "runtime.h" }
    parts.push("#include \"" + runtime_inc + "\"\n\n")

    // ── C3: collect known global names for closure free-var analysis ──
    _known_fn_globals = []
    _known_nonlocal_names = []
    _known_set_init()
    _lambda_counter = 0
    _lambda_def_parts = []
    _lambda_fwd_sigs = []
    _ic_counter = 0
    // M4: reset string literal dedup table
    // rt#32-SL: _strlit_def_parts module-array push removed — emit uses
    // deterministic _strlit_counter loop (mirror of fcf275f4 IC fix).
    _strlit_keys = []
    _strlit_ids = []
    _strlit_counter = 0
    _destr_counter = 0
    // b2-fnref: reset by-value builtin/method thunk set per codegen call.
    _fnref_thunk_names = []
    _gen2_current_fn_lets = []
    // 2026-04-18 use-resolver dedup table — reset per codegen call so a
    // second invocation in the same process doesn't treat the first call's
    // resolved modules as already-emitted.
    _resolved_modules = []
    _resolve_caller_dir_inited = false
    _resolve_caller_dir = ""
    // ComptimeConst const-fold table — must reset per codegen invocation.
    _comptime_const_names = []
    _comptime_const_nodes = []
    // enum-variant access fix: reset enum-name set per codegen invocation
    // so a second TU in the same process doesn't see stale enum names.
    _enum_names = []
    // PROBE r15-D14: reset bare-variant lookup tables per TU (paired w/ _enum_names).
    _enum_variant_names = []
    _enum_variant_owners = []
    _enum_variant_ambig = []
    // B20 / roadmap 55: reset @strict_fp TU flag per codegen invocation so
    // a second compilation in the same process doesn't inherit the first.
    _gen2_tu_has_strict_fp = 0
    _gen2_current_fn_strict_fp = 0
    let mut _gi = 0
    while _gi < len(ast) {
        let _gk = ast[_gi].kind
        if _gk == "FnDecl" || _gk == "ExternFnDecl" || _gk == "PureFnDecl" {
            _known_fn_globals.push(ast[_gi].name)
            _known_nonlocal_names.push(ast[_gi].name)
            _known_fn_globals_add(ast[_gi].name)
            _known_nonlocal_add(ast[_gi].name)
        } else if _gk == "StructDecl" {
            // Struct constructors are C functions
            _known_fn_globals.push(ast[_gi].name)
            _known_nonlocal_names.push(ast[_gi].name)
            _known_fn_globals_add(ast[_gi].name)
            _known_nonlocal_add(ast[_gi].name)
        } else if _gk == "EnumDecl" {
            _known_nonlocal_names.push(ast[_gi].name)
            _known_nonlocal_add(ast[_gi].name)
        } else if _gk == "ComptimeConst" || _gk == "ConstStmt" {
            _known_nonlocal_names.push(ast[_gi].name)
            _known_nonlocal_add(ast[_gi].name)
        } else if _gk == "LetMutStmt" || _gk == "LetStmt" || _gk == "AtomicLet" {
            _known_nonlocal_names.push(ast[_gi].name)
            _known_nonlocal_add(ast[_gi].name)
        } else if _gk == "AssignStmt" {
            // 2026-04-19: module-level `n_atoms = 8` (no `let` prefix) produces
            // an AssignStmt; register the bare-Ident lhs as a known global so
            // nested lambdas don't spuriously classify it as a free variable
            // (which would emit an env-unpack prologue + undefined-ident ref).
            // Only register the bare-Ident case — skip Field/Index assigns
            // (a.b = 5 / arr[0] = x are not global bindings).
            let _alhs = ast[_gi].left
            if type_of(_alhs) == "string" && len(_alhs) > 0 {
                _known_nonlocal_names.push(_alhs)
                _known_nonlocal_add(_alhs)
            } else if type_of(_alhs) != "string" && _alhs.kind == "Ident" {
                _known_nonlocal_names.push(_alhs.name)
                _known_nonlocal_add(_alhs.name)
            }
        } else if _gk == "ImportStmt" || _gk == "UseStmt" {
            // 2026-04-18: pre-register imported fn/struct names so local fns
            // physically appearing before the `use` line still classify their
            // call sites correctly. Emit pass will still generate extern decls.
            _resolve_use_register_names(ast[_gi].name)
        }
        _gi = _gi + 1
    }

    // Collect sections as arrays, join at end
    let mut fwd_parts = []
    let mut global_parts = []
    // C7-prep / stage1-bypass: enum #defines must precede ANY code that
    // references them (fn bodies, lambda defs, fnref thunks). For normal
    // single-file source this happens for free because EnumDecls precede
    // FnDecls in source order; for FLATTENED sources (tool/flatten_imports)
    // the enum decls from downstream files (compiler/diag/catalog.hexa,
    // compiler/check/ast.hexa, …) get inlined AFTER fn bodies from earlier
    // files (self/main.hexa) that reference them via match expressions on
    // enum values. Collect enums into a dedicated section so they emit
    // BEFORE fn_parts regardless of source position. See bind_flat probe
    // 261 → 2 errors (closing 259 enum forward-reference errors).
    let mut enum_parts = []
    let mut fn_parts = []
    // init_parts: global variable initialization only (LetMutStmt, LetStmt,
    // ComptimeConst, ExternFnDecl dlopen). Emitted as a separate C function
    // so multi-module merge can call it without running expression statements.
    let mut init_parts = []
    // main_parts: module-level expression statements (tests, assertions, etc.)
    let mut main_parts = []

    // Track extern fn declarations for call codegen
    let mut extern_fns = []
    // T23: track user-defined `fn main` so C main() invokes u_main() (mangled).
    // Without this the generated C main() runs hexa_set_args+return 0 only,
    // and the user's main body silently no-ops at runtime.
    let mut has_user_main = false
    // T34: suppress auto-call when the user also writes an explicit `main()`
    // expression statement at module top-level (backwards-compat convention),
    // otherwise both the ExprStmt-emitted u_main() and the auto-appended
    // u_main() fire, running the body twice.
    let mut has_explicit_main_call = false

    // 2026-04-27: script-body decl tracking. The implicit C main() function
    // formed from top-level non-decl stmts shares one block scope, so we
    // need the same hoist+reset pattern gen2_fn_decl uses — otherwise:
    //   (a) _gen2_declared_names leaks across the boundary from the last
    //       gen2_fn_decl call (e.g. `is_arith_op` param `op`), making a
    //       subsequent top-level `let op = …` emit as a bare `op = …`
    //       reference to an undeclared identifier (aot_native_trivial.hexa
    //       link fail).
    //   (b) sibling-block duplicate top-level lets would each emit a
    //       fresh `HexaVal X = …` decl in the same C main scope → C
    //       redeclaration error.
    let _main_lets = _gen2_collect_main_body_lets(ast)
    let mut _main_decls = []
    let mut _main_hoists = []
    let mut _mli = 0
    while _mli < len(_main_lets) {
        let _mlnm = _main_lets[_mli]
        let mut _already = false
        let mut _adi = 0
        while _adi < len(_main_decls) {
            if _main_decls[_adi] == _mlnm { _already = true }
            _adi = _adi + 1
        }
        if !_already {
            let mut _cnt = 0
            let mut _ci = 0
            while _ci < len(_main_lets) {
                if _main_lets[_ci] == _mlnm { _cnt = _cnt + 1 }
                _ci = _ci + 1
            }
            if _cnt > 1 {
                _main_decls.push(_mlnm)
                // POSIX collision fix (see line ~1306 for fn-local mirror).
                _main_hoists.push("    HexaVal " + _hexa_mangle_ident(_mlnm) + " = hexa_void();\n")
            }
        }
        _mli = _mli + 1
    }
    let mut _mhi = 0
    while _mhi < len(_main_hoists) {
        main_parts.push(_main_hoists[_mhi])
        _mhi = _mhi + 1
    }

    // fn-name dedup (first-wins). module_loader can splice two files
    // that both define the same fn name (e.g. stdlib/core/math.hexa's
    // `fn euler_phi(n)` vs compiler/atlas/symbolic/congruence_chain_engine
    // .hexa's `pub fn euler_phi(n: int) -> int` — same name, different
    // signatures). Without this dedup the C output has two `HexaVal
    // euler_phi(...)` definitions and clang errors with "redefinition of
    // 'euler_phi'". First-wins matches the existing thunk policy
    // (line 3118) and promote_to_atlas (compiler/discover/promote.hexa:382).
    let mut _fn_emit_seen = []
    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" {
            // dedup: skip duplicate FnDecl with the same name (first-wins).
            let _fn_name = ast[i].name
            let mut _fes_i = 0
            let mut _fes_dup = false
            while _fes_i < len(_fn_emit_seen) {
                if _fn_emit_seen[_fes_i] == _fn_name { _fes_dup = true }
                _fes_i = _fes_i + 1
            }
            if _fes_dup {
                // PROBE r16-T3: surface the silent first-wins drop. hexa does
                // NOT support function overloading — a second `fn <name>` with
                // the same name is dropped here (first-wins) and any call to
                // the later signature would otherwise fail with an opaque clang
                // error against the first definition. Warn (stderr, non-fatal —
                // valid code still compiles) so the drop is visible. Module
                // splicing can also produce same-name dups across files; the
                // warning is informational in that case too.
                eprintln("[warn] function `" + _fn_name + "` redefined — overloading unsupported, later definition ignored")
                i = i + 1
                continue
            }
            _fn_emit_seen.push(_fn_name)
            if ast[i].name == "main" { has_user_main = true }
            fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "ExternFnDecl" {
            // Generate extern FFI wrapper
            extern_fns.push(ast[i].name)
            let ew = gen2_extern_wrapper(ast[i])
            global_parts.push(ew.global)
            fwd_parts.push(ew.forward + "\n")
            fn_parts.push(ew.fn_code + "\n\n")
            init_parts.push(ew.init)
        } else if k == "StructDecl" {
            // T33-rebuild: emit a forward declaration so the generated
            // constructor (Name(field1, ..., fieldN) -> HexaVal) can be
            // called before its definition — otherwise implicit-int K&R
            // fallback causes "conflicting types for 'Name'" at link time.
            fwd_parts.push(gen2_struct_forward(ast[i]) + "\n")
            fn_parts.push(gen2_struct_decl(ast[i]) + "\n\n")
        } else if k == "EnumDecl" {
            // C7-prep / stage1-bypass: route to enum_parts (emitted as a
            // prelude block before fn_parts) so flattened-source consumers
            // see the #define macros before any fn body that references them.
            enum_parts.push(gen2_enum_decl(ast[i]) + "\n")
        } else if k == "ImplBlock" {
            let ib = gen2_impl_block(ast[i])
            fwd_parts.push(ib.forward)
            fn_parts.push(ib.fn_code)
        } else if k == "PureFnDecl" {
            // Treat pure fn same as regular fn (with same first-wins dedup).
            let _pfn_name = ast[i].name
            let mut _pfes_i = 0
            let mut _pfes_dup = false
            while _pfes_i < len(_fn_emit_seen) {
                if _fn_emit_seen[_pfes_i] == _pfn_name { _pfes_dup = true }
                _pfes_i = _pfes_i + 1
            }
            if _pfes_dup {
                // PROBE r16-T3: same silent first-wins drop for pure fns.
                eprintln("[warn] function `" + _pfn_name + "` redefined — overloading unsupported, later definition ignored")
                i = i + 1
                continue
            }
            _fn_emit_seen.push(_pfn_name)
            fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "AsyncFnDecl" {
            // RFC-022 §3.1 / §4.1 D3 — `async fn` runs synchronously in
            // stage 1; treat exactly like a plain FnDecl. The `async`
            // keyword is annotation-only at codegen time. await-site
            // unwrap is handled by gen2_expr Await branch + runtime
            // hexa_await_unwrap (RFC-022 §4.2).
            let _afn_name = ast[i].name
            let mut _afes_i = 0
            let mut _afes_dup = false
            while _afes_i < len(_fn_emit_seen) {
                if _fn_emit_seen[_afes_i] == _afn_name { _afes_dup = true }
                _afes_i = _afes_i + 1
            }
            if _afes_dup {
                i = i + 1
                continue
            }
            _fn_emit_seen.push(_afn_name)
            fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "ComptimeConst" || k == "ConstStmt" {
            // Try compile-time const-fold first. On success, register the
            // folded literal in the lookup table and SKIP global emission —
            // every Ident reference is inlined at use-site (gen2_expr Ident).
            // On failure, fall back to runtime evaluation as a global var.
            //
            // 2026-04-26: ConstStmt also handled here. parser.hexa:1140 emits
            // `kind: "ConstStmt"` for plain `const X = expr` while keeping
            // `ComptimeConst` for `comptime const X = expr` (parser.hexa:3603).
            // Without this branch, ConstStmt fell through to gen2_stmt's
            // generic ConstStmt path which always emits `HexaVal X = ...` as
            // a LOCAL — references from nested fns (u_main → bare `X`) hit
            // clang link "Undefined symbols: _X" because the local is invisible
            // outside the C main entry. Affected ~22 hive tools (hive_daemon
            // STALE_TTL_SEC, raw81 SETTINGS_REL, os_level_lock SENTINEL_, …).
            let _cc_folded = comptime_eval(ast[i].left)
            if type_of(_cc_folded) != "string" {
                _register_comptime_const(ast[i].name, _cc_folded)
            } else {
                global_parts.push("HexaVal " + ast[i].name + ";\n")
                if type_of(ast[i].left) != "string" {
                    init_parts.push("    " + ast[i].name + " = " + gen2_expr(ast[i].left) + ";\n")
                } else {
                    init_parts.push("    " + ast[i].name + " = hexa_void();\n")
                }
            }
        } else if k == "TraitDecl" {
            // Skip
        } else if k == "InvariantDecl" {
            // T3 declarative @invariant DSL — codegen no-op.
            // 정적 분석은 self/invariant_check.hexa 가 별도 단계로 수행.
        } else if k == "ImportStmt" || k == "UseStmt" {
            // 2026-04-18 root fix: resolve `use "<path>"` to a .hexa file,
            // text-scan its top-level fns/structs, and emit extern forward
            // decls so single-file transpile (no flatten_imports) still
            // produces link-valid C. Handles the 88 anima files that use
            // `use "sibling_module"` without the pre-flatten step.
            let _use_fwd = _resolve_use_emit(ast[i].name)
            if len(_use_fwd) > 0 {
                fwd_parts.push(_use_fwd)
            } else {
                main_parts.push("    /* import: " + ast[i].name + " */\n")
            }
        } else if k == "LetMutStmt" || k == "LetStmt" || k == "AtomicLet" {
            // AtomicLet (`atomic let x = …`) at module scope: same node shape
            // (name + left=init); `atomic` is an annotation — single-threaded
            // codegen emits a normal global binding.
            // bt-53: mangle `TAG_INT`/`main`/… global names to avoid collision
            // with runtime.c's enum constants at link time.
            let _user_name = _hexa_mangle_ident(ast[i].name)
            // STRUCTURAL-2 Phase B: register global immutable let with int init
            if k == "LetStmt" && type_of(ast[i].left) != "string" {
                if _is_int_init_expr(ast[i].left) {
                    _known_int_add(ast[i].name)
                }
                // STRUCTURAL-3: register global immutable let with float init
                if _is_float_init_expr(ast[i].left) {
                    _known_float_add(ast[i].name)
                }
            }
            // ROI #43: @thread_local → _Thread_local C storage class
            let _tls_val = ast[i].value
            // `let mut` (not `let`): _is_tls is reassigned below. The plain-let
            // comptime-fold (PROBE r11 B3) would otherwise register the
            // immutable `false` and inline it on the assignment LHS, emitting
            // the un-buildable `hexa_bool(0) = hexa_bool(1);`.
            let mut _is_tls = false
            if type_of(_tls_val) == "string" {
                if _tls_val == "thread_local" {
                    _is_tls = true
                }
            }
            if _is_tls {
                global_parts.push("_Thread_local HexaVal " + _user_name + ";\n")
            } else {
                global_parts.push("HexaVal " + _user_name + ";\n")
            }
            // hxa-20260423-005: initialize in program order (main_parts) — not
            // hoisted to init_parts. Prior hoist caused `let ks = dict_keys(d)`
            // to run before `d["k1"]=1` populated d. Forward decl stays in
            // global_parts so other top-level fns can still reference the
            // variable by name without ordering constraints.
            if type_of(ast[i].left) != "string" {
                main_parts.push("    " + _user_name + " = " + gen2_expr(ast[i].left) + ";\n")
            } else {
                main_parts.push("    " + _user_name + " = hexa_void();\n")
            }
        } else {
            // T34: detect top-level `main()` ExprStmt → suppress auto-call below.
            let _tls_stmt = ast[i]
            if _tls_stmt.kind == "ExprStmt" && type_of(_tls_stmt.left) != "string" {
                let _tls_expr = _tls_stmt.left
                if _tls_expr.kind == "Call" && type_of(_tls_expr.left) != "string" {
                    let _tls_callee = _tls_expr.left
                    if _tls_callee.kind == "Ident" && _tls_callee.name == "main" {
                        has_explicit_main_call = true
                    }
                }
            }
            // 2026-04-27: rebind script-body decl tracking before each
            // gen2_stmt — gen2_fn_decl during this loop reassigns
            // _gen2_declared_names to a fresh array for the fn's own scope,
            // so we restore the script-body view here.
            _gen2_declared_names = _main_decls
            main_parts.push(gen2_stmt(ast[i], 1))
        }
        i = i + 1
    }

    // Join all sections (single pass)
    parts.push(fwd_parts.join(""))
    parts.push("\n")
    parts.push(global_parts.join(""))
    parts.push("\n")
    // C7-prep / stage1-bypass enum-ordering fix: emit ALL enum #defines
    // here as a prelude block, BEFORE any code that may reference enum
    // constants (lambda defs, fnref thunks, fn bodies). For source-order
    // input the original behavior is preserved (enums emitted before fns
    // anyway); for FLATTENED input (tool/flatten_imports inlining several
    // .hexa files) this guarantees the #defines precede fn bodies even
    // when the original file order interleaves them.
    parts.push(enum_parts.join(""))
    parts.push("\n")
    // M4: string literal deduplication — static HexaVal slots + init function
    // rt#32-SL: decls emitted via deterministic _strlit_counter loop (mirror
    // of fcf275f4 IC fix). Prior _strlit_def_parts module-array push triggered
    // T33-class freelist aliasing, dropping decls → "undeclared __hexa_sl_N".
    let mut _sl_def_i = 0
    while _sl_def_i < _strlit_counter {
        parts.push("static HexaVal __hexa_sl_" + to_string(_sl_def_i) + ";\n")
        _sl_def_i = _sl_def_i + 1
    }
    if len(_strlit_keys) > 0 {
        // Chunked emission — single __hexa_strlit_init() function with
        // thousands of statements triggers Apple clang 21.0.0 frontend
        // SIGILL (observed at ~8000+ stmts on compiler/main.hexa path-B
        // transpile). Split into 500-stmt chunks and have the main init
        // call each chunk in order.
        let _strlit_chunk = 500
        let mut _strlit_chunk_idx = 0
        let mut _sli = 0
        while _sli < len(_strlit_keys) {
            if _sli % _strlit_chunk == 0 {
                if _sli > 0 { parts.push("}\n") }
                parts.push("static void __hexa_strlit_init_" + to_string(_strlit_chunk_idx) + "(void) {\n")
                _strlit_chunk_idx = _strlit_chunk_idx + 1
            }
            parts.push("    __hexa_sl_" + to_string(_strlit_ids[_sli]) + " = hexa_str(\"" + _strlit_keys[_sli] + "\");\n")
            _sli = _sli + 1
        }
        parts.push("}\n")
        // Aggregator that the rest of the codegen still calls.
        // PR-B (#4j proper fix): emit the per-TU aggregator with a
        // module-unique suffix and *non-static* linkage so multi-file
        // driver-link patterns can call it from outside. Within-TU
        // self-call (the main caller below) still references the
        // unique-named symbol — same TU, no link mismatch. Chunk-
        // internal `__hexa_strlit_init_<N>` helpers stay static (file-
        // scope only, no cross-TU collision risk).
        parts.push("void __hexa_strlit_init__" + _hexa_cert_module_name() + "(void) {\n")
        let mut _ci = 0
        while _ci < _strlit_chunk_idx {
            parts.push("    __hexa_strlit_init_" + to_string(_ci) + "();\n")
            _ci = _ci + 1
        }
        parts.push("}\n")
    }
    // rt#37: emit inline-cache slots as file-scope statics before fn bodies.
    let mut _ic_i = 0
    while _ic_i < _ic_counter {
        parts.push("static HexaIC __hexa_ic_" + to_string(_ic_i) + " = {0};\n")
        _ic_i = _ic_i + 1
    }
    parts.push("\n")
    // FIX-B (2026-04-19): deterministic lambda fwd decl emission — counter
    // driven (mirror of fcf275f4 IC + rt#32-SL strlit fixes). Replaces
    // `_lambda_fwd_parts.join("")` which hit T33-class arena aliasing —
    // corrupt output ("xa_sl_2 = hexa_str..." garbage lines, missing fwd decls).
    let mut _lfw_i = 0
    while _lfw_i < _lambda_counter {
        parts.push("HexaVal __hexa_lambda_" + to_string(_lfw_i) + "(" + _lambda_fwd_sigs[_lfw_i] + ");\n")
        _lfw_i = _lfw_i + 1
    }
    // C3: emit lambda definitions (static C fns with __env first param)
    // FIX-C (2026-04-19): counter-driven per-slot read — replaces
    // `_lambda_def_parts.join("")` which hit T33-class arena aliasing on the
    // large body payloads. Symptom (train_v14.hexa): lambda bodies truncated
    // into fragments ("tr(\"exaVal __hexa_sl_6;" / "exaVal __hexa_sl_4;" /
    // "_hexa_sl_5int main…"). Mirror of fcf275f4 (IC) + c461f60a (fwd sigs).
    let mut _ldp_i = 0
    while _ldp_i < _lambda_counter {
        parts.push(_lambda_def_parts[_ldp_i])
        _ldp_i = _ldp_i + 1
    }
    // b2-fnref: emit static thunks for builtins/methods taken by-value,
    // before any user fn body / main can reference __hxthunk_<name>.
    parts.push(_gen2_emit_fnref_thunks())
    parts.push(fn_parts.join(""))
    // B20 / roadmap 55: emit a sentinel comment the build driver
    // (self/main.hexa) greps to decide whether to inject IEEE-strict clang
    // flags (-ffp-contract=off, -fno-fast-math, -fno-associative-math,
    // -fno-reciprocal-math, -fsignaling-nans). Emitted even without
    // @strict_fp so the driver can unambiguously detect "not strict" too.
    if _gen2_tu_has_strict_fp == 1 {
        parts.push("/* HEXA_STRICT_FP_TU: 1 */\n")
    } else {
        parts.push("/* HEXA_STRICT_FP_TU: 0 */\n")
    }
    // T3 fix: emit `int main(int argc, char** argv)` + hexa_set_args(argc, argv)
    // 이전 구현은 `int main()` 으로 argv 를 받지 않아 args() 가 항상 빈 배열을
    // 반환했다. main.hexa 의 dispatch (av[2] 등) 가 동작하려면 필수.
    parts.push("int main(int argc, char** argv) {\n")
    // Line-buffer stdout/stderr so `eprintln` / `print` from a daemon
    // (`while true`) hits the destination FD per line instead of sitting
    // in the process-local FILE* buffer until exit. Without this, hexa_run
    // daemons under `nohup > out 2> err &` show 0-byte log files until
    // they exit. _IOLBF matches the de-facto Unix daemon convention.
    // (inbox patch proc-spawn-supervised-daemon-silent-exit gap #2.)
    parts.push("    setvbuf(stdout, NULL, _IOLBF, 0);\n")
    parts.push("    setvbuf(stderr, NULL, _IOLBF, 0);\n")
    parts.push("    hexa_set_args(argc, argv);\n")
    // B20: per-thread FP control word init. Always safe to call — zero-op on
    // substrates without MXCSR/FPCR. Placing before any user init ensures
    // constexpr float computation in globals sees IEEE defaults.
    parts.push("    hexa_fp_init();\n")
    // M4: initialize deduplicated string literals before any user init code
    if len(_strlit_keys) > 0 {
        parts.push("    __hexa_strlit_init__" + _hexa_cert_module_name() + "();\n")
    }
    parts.push(init_parts.join(""))
    parts.push(main_parts.join(""))
    if has_user_main && !has_explicit_main_call { parts.push("    u_main();\n") }
    parts.push("    fflush(stdout); fflush(stderr);\n    return 0;\n}\n")
    return parts.join("")
}

// C2-attr: check if a FnDecl node has a specific attr in node.value
fn gen2_has_attr(node, target) {
    let v = node.value
    if type_of(v) != "string" { return false }
    if v == "" { return false }
    let chars = v.chars()
    let len_chars = len(chars)
    let mut i2 = 0
    let mut cur = ""
    while i2 < len_chars {
        let c = to_string(chars[i2])
        if c == "," {
            if cur == target { return true }
            cur = ""
        } else {
            cur = cur + c
        }
        i2 = i2 + 1
    }
    if cur == target { return true }
    return false
}

// Check if a FnDecl node has @inline_always attribute
fn gen2_has_inline_always(node) {
    if type_of(node.value) != "string" { return false }
    if node.value == "" { return false }
    let attrs = node.value
    let chars = attrs.chars()
    let len_chars = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < len_chars {
        let c = to_string(chars[i])
        if c == "," {
            if cur == "inline_always" { return true }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur == "inline_always" { return true }
    return false
}

fn gen2_fn_forward(node) {
    let has_restrict = gen2_has_attr(node, "restrict")
    let mut params = []
    let mut i = 0
    while i < len(node.params) {
        if has_restrict {
            // Emit restrict qualifier for noalias optimization
            params.push("HexaVal __restrict " + _hexa_mangle_ident(node.params[i].name))
        } else {
            params.push("HexaVal " + _hexa_mangle_ident(node.params[i].name))
        }
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    let mut prefix = ""
    if gen2_has_inline_always(node) { prefix = "static inline " }
    // S1-D3b: @hot/@cold/@noinline → GCC/Clang function attributes
    let mut suffix = ""
    if gen2_has_attr(node, "hot") { suffix = " __attribute__((hot))" }
    if gen2_has_attr(node, "cold") { suffix = " __attribute__((cold))" }
    if gen2_has_attr(node, "noinline") { suffix = " __attribute__((noinline))" }
    let _name_real = _hexa_mangle_ident(node.name)
    // @lazy: the body gets a _body suffix; the original name becomes a
    // thunk wrapper. Forward-declare both (wrapper is always zero-arg).
    if gen2_has_attr(node, "lazy") && len(node.params) == 0 {
        return prefix + "HexaVal " + _name_real + "_body" + "(" + p + ")" + suffix + ";\n"
            + "HexaVal " + _name_real + "(void);"
    }
    return prefix + "HexaVal " + _name_real + "(" + p + ")" + suffix + ";"
}

// ── @specialize codegen: type-specialized fast path ─────────
// If a FnDecl has @specialize in attrs and has >= 1 param, generate
// a type-check branch at entry that skips tag checks for the dominant type.
fn gen2_has_specialize(node) {
    let attrs = node.value
    if type_of(attrs) != "string" { return false }
    if attrs == "specialize" { return true }
    if contains(attrs, "specialize") { return true }
    return false
}

fn gen2_specialize_guard(node) {
    // Generate C code for type-specialized fast path on first param
    if len(node.params) == 0 { return "" }
    let p0 = node.params[0].name
    let mut out = ""
    out = out + "    /* @specialize: inline cache type guard */\n"
    out = out + "    if (HX_IS_INT(" + p0 + ")) {\n"
    out = out + "        /* monomorphic int fast-path: skip tag checks */\n"
    out = out + "        int64_t __spec_" + p0 + " = HX_INT(" + p0 + ");\n"
    out = out + "        (void)__spec_" + p0 + "; /* hint for optimizer */\n"
    out = out + "    }\n"
    return out
}

// 2026-05-18: tail-position return for an arbitrary value-producing expression.
// Mirrors the existing branch logic at gen2_fn_decl's tail-return site so all
// emission paths (defer-routed __ret_val, @no_arena, normal arena-wrapped)
// stay byte-identical. The pad argument controls indentation; pass the same
// pad the surrounding C block uses.
fn _gen2_emit_tail_return_expr(expr, pad) {
    if _gen2_defer_flag_count > 0 {
        return pad + "__ret_val = " + gen2_expr(expr) + "; goto __fn_exit;\n"
    }
    if _gen2_arena_wrap == 1 {
        return pad + "return __hexa_fn_arena_return(" + gen2_expr(expr) + ");\n"
    }
    return pad + "return " + gen2_expr(expr) + ";\n"
}

// PROBE r15-D2: same as _gen2_emit_tail_return_expr but takes an
// ALREADY-EMITTED C expression string (not an AST node). Used by the
// postfix `?` (Try) hoist, whose failure-branch re-returns a C temp
// (`__tryN`) that has no AST form. Routes through the same three
// emission paths so the early-return stays byte-identical to a normal
// `return <recv>;` under defer / arena / plain regimes.
fn _gen2_emit_tail_return_expr_raw(cexpr, pad) {
    if _gen2_defer_flag_count > 0 {
        return pad + "__ret_val = " + cexpr + "; goto __fn_exit;\n"
    }
    if _gen2_arena_wrap == 1 {
        return pad + "return __hexa_fn_arena_return(" + cexpr + ");\n"
    }
    return pad + "return " + cexpr + ";\n"
}

// 2026-05-18 (tier-2 trailing-if-expr void-return fix):
// Render a branch body (array of stmts) so its TAIL value flows out as a
// `return <expr>;` instead of being emitted as a bare `<expr>;` expression
// statement and silently discarded. All non-tail stmts emit verbatim via
// gen2_stmt (their side-effects / lets / defers preserved); only the last
// stmt is rewritten to a return — recursively when it is itself an IfExpr
// (so `else if` chains and nested if/else tails all return correctly).
//
// Pre-fix C for `fn lcm(a,b) { if a==0||b==0 {0} else { div(...) } }`:
//     if (...) { hexa_int(0); } else { hexa_div(...); }
//     return __hexa_fn_arena_return(hexa_void());   // WRONG — values dropped
// Post-fix C:
//     if (...) { return __hexa_fn_arena_return(hexa_int(0)); }
//     else     { return __hexa_fn_arena_return(hexa_div(...)); }
//     return __hexa_fn_arena_return(hexa_void());   // dead-code safety net
//
// Conservative — falls through to the void footer untouched for any tail
// stmt shape we don't recognise (non-ExprStmt tails, non-IfExpr value
// shapes that gen2_stmt already handles correctly, etc.). MatchExpr in
// tail position is currently NOT rewritten (preserved as the pre-fix
// statement form) — only IfExpr is required for the math.hexa fns
// (lcm/abs/max/min/clamp) and the cited gate-1 regression. A future
// pass can extend to MatchExpr arms by the same recursion.
fn _gen2_emit_tail_returnify_body(body_stmts, depth) {
    let pad = gen2_indent(depth)
    let mut chunks = []
    if type_of(body_stmts) != "array" {
        return chunks.join("")
    }
    let n = len(body_stmts)
    if n == 0 {
        return chunks.join("")
    }
    // Emit all but the last stmt as normal.
    let mut bi = 0
    while bi < n - 1 {
        chunks.push(gen2_stmt(body_stmts[bi], depth))
        bi = bi + 1
    }
    let last = body_stmts[n - 1]
    // Non-ExprStmt tails (e.g. ReturnStmt, LetStmt, BlockStmt, …): emit
    // normally — they either already return or genuinely produce void.
    if type_of(last) == "string" || last.kind != "ExprStmt" {
        chunks.push(gen2_stmt(last, depth))
        return chunks.join("")
    }
    let inner = last.left
    if type_of(inner) == "string" {
        chunks.push(gen2_stmt(last, depth))
        return chunks.join("")
    }
    let ik = inner.kind
    // Recurse into IfExpr: each branch's tail expression becomes a return.
    if ik == "IfExpr" {
        chunks.push(pad + "if (hexa_truthy(" + gen2_expr(inner.cond) + ")) {\n")
        chunks.push(_gen2_emit_tail_returnify_body(inner.then_body, depth + 1))
        chunks.push(pad + "}")
        if type_of(inner.else_body) != "string" && len(inner.else_body) > 0 {
            chunks.push(" else {\n")
            chunks.push(_gen2_emit_tail_returnify_body(inner.else_body, depth + 1))
            chunks.push(pad + "}")
        }
        chunks.push("\n")
        return chunks.join("")
    }
    // Call-to-void-builtin guard — mirrors gen2_fn_decl's tail-return
    // skip-list. `return println(...)` would type-error in C because the
    // builtin returns void; emit as a normal expression statement instead.
    if ik == "Call" && type_of(inner.left) != "string" && inner.left.kind == "Ident" {
        let _cname = inner.left.name
        if _cname == "println" || _cname == "print" || _cname == "eprintln" || _cname == "print_err" || _cname == "eprint" || _cname == "exit" {
            chunks.push(gen2_stmt(last, depth))
            return chunks.join("")
        }
    }
    // MatchExpr in tail position: leave as the original statement-form
    // expansion for now (pre-fix behavior preserved — value drops to
    // void). math.hexa fns don't use match; extending this to walk arms
    // is a follow-on patch.
    if ik == "MatchExpr" {
        chunks.push(gen2_stmt(last, depth))
        return chunks.join("")
    }
    // Plain value-producing expression — emit as a return.
    chunks.push(_gen2_emit_tail_return_expr(inner, pad))
    return chunks.join("")
}

// PROBE r15-D3: predicate — does this arm/branch body evaluate to C-void at
// its tail? Used by gen2_fn_decl's `_all_void` tail-match guard to decide
// whether a trailing MatchExpr is safe to returnify. Recurses so block-form
// arms (`Some(n) => { if c { println(..) } else { println(..) } }`) and
// nested matches are recognized as void, matching the void-awareness the
// IfExpr path already has in _gen2_emit_tail_returnify_body. Conservative:
// anything not provably void returns false (→ guard treats the arm as a
// value producer and the returnify proceeds, preserving prior behavior).
fn _gen2_arm_body_is_void(body) {
    if type_of(body) == "string" || len(body) == 0 { return false }
    let _last = body[len(body) - 1]
    if type_of(_last) == "string" || _last.kind != "ExprStmt" { return false }
    let _e = _last.left
    if type_of(_e) == "string" { return false }
    let _ek = _e.kind
    // Direct void-builtin call.
    if _ek == "Call" && type_of(_e.left) != "string" && _e.left.kind == "Ident" {
        let _cn = _e.left.name
        if _cn == "println" || _cn == "print" || _cn == "eprintln" || _cn == "eprint" || _cn == "exit" {
            return true
        }
        return false
    }
    // if / if-else: void when the taken branch tails are void. A missing
    // else means the false path yields hexa_void(), so then-void suffices.
    if _ek == "IfExpr" {
        let _tv = _gen2_arm_body_is_void(_e.then_body)
        if type_of(_e.else_body) == "string" || len(_e.else_body) == 0 {
            return _tv
        }
        return _tv && _gen2_arm_body_is_void(_e.else_body)
    }
    // Nested match: void when every arm body is void.
    if _ek == "MatchExpr" && type_of(_e.arms) != "string" {
        let mut _mi = 0
        while _mi < len(_e.arms) {
            if !_gen2_arm_body_is_void(_e.arms[_mi].body) { return false }
            _mi = _mi + 1
        }
        return true
    }
    return false
}

fn gen2_fn_decl(node) {
    let has_restrict = gen2_has_attr(node, "restrict")
    let has_flatten = gen2_has_attr(node, "flatten")
    let mut params = []
    let mut i = 0
    while i < len(node.params) {
        if has_restrict {
            // @restrict: C restrict qualifier for noalias vectorization
            params.push("HexaVal __restrict " + _hexa_mangle_ident(node.params[i].name))
        } else {
            params.push("HexaVal " + _hexa_mangle_ident(node.params[i].name))
        }
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    // Check for @stack_alloc attr
    let mut has_stack_alloc = false
    if type_of(node.value) == "string" && node.value != "" {
        let _sa_attrs = node.value
        // Simple check: contains "stack_alloc"
        if _sa_attrs == "stack_alloc" || _sa_attrs == "optimize,stack_alloc" || _sa_attrs == "stack_alloc,optimize" {
            has_stack_alloc = true
        }
        // More general: check if any comma-separated segment matches
        let _sa_chars = _sa_attrs.chars()
        let _sa_len = len(_sa_chars)
        let mut _sa_cur = ""
        let mut _sa_ci = 0
        while _sa_ci < _sa_len {
            let _sa_ch = to_string(_sa_chars[_sa_ci])
            if _sa_ch == "," {
                if _sa_cur == "stack_alloc" { has_stack_alloc = true }
                _sa_cur = ""
            } else {
                _sa_cur = _sa_cur + _sa_ch
            }
            _sa_ci = _sa_ci + 1
        }
        if _sa_cur == "stack_alloc" { has_stack_alloc = true }
    }
    // bt 72: per-function shadow handling via hoisting. Seed declared-names
    // with params so `let x` where x is a param emits as assignment.
    _gen2_declared_names = []
    // H17 fix: also seed _gen2_current_fn_params with the unmangled names
    // so _is_known_int_name / _is_known_float_name can detect when a
    // module-global int/float name is shadowed by a fn param. Without
    // this, a prior fn's `let a = 0` makes ALL subsequent fns' `a` params
    // (even `a: float`) get unboxed via HX_INT() → garbage values for
    // ops 0/1/2/3 of binary_value (and any similar shape). Repro:
    // perfect_number_engine_smoke a/b float params after Fibonacci helper.
    _gen2_current_fn_params = []
    _gen2_current_fn_param_types = []
    let mut _pi = 0
    while _pi < len(node.params) {
        _gen2_declared_names.push(_hexa_mangle_ident(node.params[_pi].name))
        _gen2_current_fn_params.push(node.params[_pi].name)
        _gen2_current_fn_param_types.push(node.params[_pi].value)
        _pi = _pi + 1
    }
    // Collect all LetStmt names (with duplicates).
    let all_names = _gen2_collect_lets(node.body, [])
    // b2-fnref: expose the current fn's `let` names so the bare-Ident thunk
    // path never replaces a local var with a builtin/method thunk.
    _gen2_current_fn_lets = all_names
    // closure mut-capture: pre-scan this fn body for `let mut` bindings that a
    // closure captures AND assigns to — box them into shared 1-element array
    // cells so mutation through the closure persists (canonical FnMut). Set
    // for the whole body walk (incl. inline lambda-body emission) — reset at
    // fn exit. See _gen2_boxed_cells doc block.
    _gen2_boxed_cells = _gen2_compute_boxed_cells(node.body)
    // UNSHADOW F2 (escape→stack-alloc): pre-scan the body for immutable
    // `let p = Pt{…}` bindings whose flat-eligible struct value is PROVEN
    // non-escaping (only `p.field` reads, never returned / call-arg / stored /
    // captured / reassigned). Such bindings get a stack-local __flat (no malloc)
    // at the LetStmt arm. GATED (HEXA_STACK_ALLOC) → no-op when the flag is off.
    _stack_noescape_reset()
    if _stack_alloc_enabled() {
        _stack_noescape_scan(node.body)
    }
    let mut _hoisted = []
    let mut hoists = []
    let mut ii = 0
    while ii < len(all_names) {
        let nm = all_names[ii]
        let mut already = _gen2_has_decl(nm)
        let mut jj = 0
        while jj < len(_hoisted) {
            if _hoisted[jj] == nm { already = true }
            jj = jj + 1
        }
        if !already {
            let mut cnt = 0
            let mut kk = 0
            while kk < len(all_names) {
                if all_names[kk] == nm { cnt = cnt + 1 }
                kk = kk + 1
            }
            if cnt > 1 {
                _hoisted.push(nm)
                _gen2_declared_names.push(nm)
                // POSIX collision fix: mangle hoisted local-var decl
                // (mirrors the existing mangle at the LetStmt site at
                // line ~2106). Without this, `let close = peek()` hoists
                // as `HexaVal close = hexa_void();` (bare) while the
                // assignment emits `u_close = peek();` (mangled), causing
                // "undeclared identifier u_close" in clang.
                hoists.push("    HexaVal " + _hexa_mangle_ident(nm) + " = hexa_void();\n")
            }
        }
        ii = ii + 1
    }
    let mut chunks = []
    if has_flatten {
        // @flatten (SROA): emit comment marking struct decomposition intent
        chunks.push("/* @flatten: SROA — struct params decomposed to scalars */\n")
    }
    // bt-53: mangle user fn name to avoid collision with runtime.c's `main`
    // and enum constants at link time.
    let _fn_name_real = _hexa_mangle_ident(node.name)
    // @lazy: emit body under a `_body` suffix; a static-thunk wrapper with
    // the original name is appended after the body. Wrapper guards re-entry
    // with a `computed` flag and caches the first call's result in a
    // file-scope static. Phase-1 restriction (enforced by check_lazy):
    // zero-arg fns only — thunk signature is trivially `()`.
    let _is_lazy = gen2_has_attr(node, "lazy") && len(node.params) == 0
    let _fn_name = if _is_lazy { _fn_name_real + "_body" } else { _fn_name_real }
    let mut prefix = ""
    if gen2_has_inline_always(node) { prefix = "static inline " }
    // S1-D3b / PROBE r10-15g: @hot/@cold/@noinline emit __attribute__ on the
    // forward DECLARATION only (see gen2_fn_forward). Placing these attrs on
    // the function DEFINITION trips clang's -Wgcc-compat warning ("GCC does
    // not allow '<attr>' attribute in this position on a function
    // definition"). The fwd-decl site already advertises the attribute to the
    // compiler before any caller is emitted, which is exactly what cold/hot/
    // noinline need to influence call-site code-gen. Keep fn_attr empty here
    // so the defn line is suffix-clean; do NOT re-introduce the attr here.
    let fn_attr = ""
    // FIRMWARE.md G-F* / G-R1 placeholder — RFC 063 (firmware) / RFC 064 (rtl)
    // recognize @target / @mmio / @interrupt / @asm annotations but defer
    // actual lowering to dedicated codegen cycles. For now: parse OK
    // (annotation accepted, no error), emit warning comment, fall through
    // to standard codegen. Bootstrap regen lands these annotations as
    // first-class lowering in their dedicated PRs.
    if gen2_has_attr(node, "target") || gen2_has_attr(node, "mmio") || gen2_has_attr(node, "interrupt") || gen2_has_attr(node, "asm") {
        chunks.push("    /* FIRMWARE.md @target/@mmio/@interrupt/@asm — codegen lowering pending RFC 063/064 (treated as no-op on this lane) */\n")
    }
    chunks.push(prefix + "HexaVal " + _fn_name + "(" + p + ")" + fn_attr + " {\n")
    // @specialize: emit type-specialized guard at entry (inside fn body)
    if gen2_has_specialize(node) {
        chunks.push(gen2_specialize_guard(node))
    }
    // bt 72: emit hoisted declarations at fn top
    let mut hj = 0
    while hj < len(hoists) {
        chunks.push(hoists[hj])
        hj = hj + 1
    }
    if has_stack_alloc {
        chunks.push("    /* @stack_alloc: bounded arrays use alloca */\n")
    }
    // STRUCTURAL-7 Phase A: arena fn-boundary enter/return.
    // Emit __hexa_fn_arena_enter() at fn top, wrap every return with
    // __hexa_fn_arena_return(). When arena is OFF (default), both are no-ops
    // in runtime.c. @no_arena skips emission entirely for fns that must not
    // touch the arena (e.g. runtime helpers called from within heapify).
    let has_no_arena = gen2_has_attr(node, "no_arena")
    if has_no_arena {
        _gen2_arena_wrap = 0
    } else {
        _gen2_arena_wrap = 1
        chunks.push("    __hexa_fn_arena_enter();\n")
    }
    // Plan B Phase 3: defer/scope/spawn codegen entry.
    //   Save previous fn's state (enables nested FnDecl emission to
    //   recurse without clobbering this fn's defer list), reset to
    //   empty, then pre-scan the body to declare __defer_N_active +
    //   __ret_val at the top. No defers in body → zero emission, C
    //   stays identical to the pre-Phase-3 codegen.
    let _prev_defer_bodies = _gen2_defer_bodies
    let _prev_defer_flag_count = _gen2_defer_flag_count
    _gen2_defer_bodies = []
    _gen2_defer_flag_count = 0
    let _defer_total = _gen2_count_defers(node.body)
    if _defer_total > 0 {
        chunks.push("    HexaVal __ret_val = hexa_void();\n")
        let mut _df = 0
        while _df < _defer_total {
            chunks.push("    int __defer_" + to_string(_df) + "_active = 0;\n")
            _df = _df + 1
        }
    }
    // bt 74: implicit tail-return. Previously emitted every fn body stmt
    // verbatim then appended `return hexa_void();`. That silently dropped
    // value-returning functions written in the idiomatic trailing-expr
    // style (e.g. `fn f() -> T { T { ... } }`) — the struct literal became
    // a statement with its value discarded, and the void footer returned
    // a placeholder. Downstream code doing `f().field` then failed at
    // runtime with "map key not found" because the Val was hexa_void().
    //
    // Fix: when a fn has an explicit non-void return type AND its LAST
    // body stmt is an ExprStmt whose inner expression is a plain value-
    // producer (not IfExpr/MatchExpr, which expand to statements; not
    // Call to void builtins like println/print/eprintln which return C
    // void and break `return <expr>;`), emit it as `return <expr>;`
    // instead of `<expr>;`. The void footer is kept unchanged as a
    // dead-code safety net for all other shapes: void/untyped fns,
    // loop/if tails, explicit returns, @stack_alloc bodies, empty bodies.
    let _ret_type = node.ret_type
    let mut _wants_tail_return = true
    if type_of(_ret_type) != "string" { _wants_tail_return = false }
    // Untyped fns ("" ret_type) — hexa implicit return semantics still apply;
    // tail-expr should produce the return value. Skip-list (IfExpr/MatchExpr/
    // println/print/eprintln/exit) below keeps genuinely-void trailing exprs safe.
    // Fix validated 2026-04-16 via #5 H100 CLM cuda BREAKTHROUGH — _ceil_div and
    // rtc_launch/_1d were silently dropping values due to "" guard.
    if _ret_type == "Void" || _ret_type == "void" || _ret_type == "()" {
        _wants_tail_return = false
    }
    // B20 / roadmap 55: @strict_fp fn scope — gate FMA fusion sites below.
    //   TU sticky flag feeds the `/* HEXA_STRICT_FP_TU */` marker emitted at
    //   the header boundary (see gen2_emit_file) which self/main.hexa greps
    //   to inject IEEE-strict clang flags.
    let _was_strict_fp = _gen2_current_fn_strict_fp
    if gen2_has_attr(node, "strict_fp") {
        _gen2_current_fn_strict_fp = 1
        _gen2_tu_has_strict_fp = 1
    } else {
        _gen2_current_fn_strict_fp = 0
    }
    let body_len = len(node.body)
    // PROBE r16 cross-fn-fold: scope-isolate this fn body's comptime-const
    // folds so a `let x = <lit>` here cannot bleed its folded literal into a
    // sibling fn that re-binds the same name to a non-foldable init. Without
    // this, `fn a(){let m=2147483648}` leaks m→literal into `fn b(){let m=h*2}`
    // (b's re-let doesn't _gen2_has_decl-invalidate across fn scope, and h*2
    // doesn't fold), so b's `m` reads inline the stale literal — a silent
    // wrong-answer. Mirrors the block/loop/arm scope-isolation pattern.
    // PROBE r16 param-fold-leak: each fn param shadows any enclosing same-name
    // comptime-const (module-level `const X = "x"` etc.). Without this, the body
    // reads of `param` would hit _lookup_comptime_const("param") and inline the
    // stale outer literal instead of the actual arg — silent miscompile (e.g.
    // `const raw = "x"; fn f(raw: string){ … raw … }` saw "x" for any caller).
    // Invalidate BEFORE the scope_mark so the table is permanently shorter when
    // the mark snapshots length — _comptime_const_scope_restore only knows how
    // to truncate (it assumes the table grew under the mark), so invalidating
    // AFTER mark would leave it reading past the live tail (OOB). Mirrors the
    // for-loop counter pattern at lines 3262/3288 (D18 + r15-F-FOLD): invalidate
    // first, then mark, then body emit, then restore.
    let mut _pix = 0
    while _pix < len(node.params) {
        _invalidate_comptime_const(node.params[_pix].name)
        _pix = _pix + 1
    }
    let _cc_fn_mark = _comptime_const_scope_mark()
    let mut bi = 0
    while bi < body_len {
        let stmt = node.body[bi]
        let mut did_emit_return = false
        // Implicit tail-return check — only on the very last body stmt,
        // only when stack_alloc mode is off (alloca rewriting is
        // orthogonal), and only when the fn declared a non-void type.
        if _wants_tail_return && bi == body_len - 1 && !has_stack_alloc {
            if type_of(stmt) != "string" && stmt.kind == "ExprStmt" {
                if type_of(stmt.left) != "string" {
                    let inner_kind = stmt.left.kind
                    // 2026-05-18 tier-2 fix: trailing IfExpr now routes
                    // through _gen2_emit_tail_returnify_body so each branch's
                    // tail value flows out as a `return …;` instead of being
                    // emitted as a bare expression statement (the pre-fix
                    // behaviour silently dropped lcm/abs/max/min/clamp branch
                    // values and returned hexa_void()). Recursive — handles
                    // `else if` chains and nested if-in-if. Falls through to
                    // the void footer for shapes the helper can't safely
                    // rewrite (preserves byte-identical C output for the
                    // non-tail-if-expr fn population).
                    if inner_kind == "IfExpr" {
                        chunks.push(_gen2_emit_tail_returnify_body([stmt], 1))
                        did_emit_return = true
                    }
                    let mut _skip = false
                    if inner_kind == "IfExpr" { _skip = true }
                    // PROBE r14: trailing MatchExpr now routes through the
                    // generic `return <expr>;` path below — gen2_match_expr
                    // lowers MatchExpr to a (cond1 ? val1 : (cond2 ? val2 :
                    // default)) ternary that is a valid C expression, so
                    // wrapping it in `return __hexa_fn_arena_return(...)`
                    // works. Previously this was marked _skip → the match
                    // got emitted as a bare if/else cascade with each arm's
                    // value silently discarded, and the void footer returned
                    // hexa_void(). Repro fn:
                    //   fn f(x: int) -> int { match x { 1 => 100, _ => 999 } }
                    // pre-fix: print(f(1)) emitted "void"; post-fix: "100".
                    // Sibling to the 2026-05-18 IfExpr tail-returnify fix.
                    // Call-to-void-builtin: wrapping `return println(...)`
                    // in C fails because hexa_println returns void. Skip
                    // the rewrite for these Call forms.
                    if inner_kind == "Call" && type_of(stmt.left.left) != "string" {
                        if stmt.left.left.kind == "Ident" {
                            let _cname = stmt.left.left.name
                            if _cname == "println" { _skip = true }
                            if _cname == "print" { _skip = true }
                            if _cname == "eprintln" { _skip = true }
                            if _cname == "eprint" { _skip = true }
                            if _cname == "exit" { _skip = true }
                        }
                    }
                    // PROBE r15-D3: trailing MatchExpr whose arms are all
                    // void-call bodies (println/print/eprintln/eprint/exit)
                    // — the synthesized ternary is C-void-typed, so wrapping
                    // it in `return __hexa_fn_arena_return(...)` is a clang
                    // type error. Drop the tail-returnify rewrite so the
                    // match emits as a plain statement and the function
                    // falls through to the void footer (matches the bare
                    // Call-to-void-builtin sibling rule above).
                    if inner_kind == "MatchExpr" && type_of(stmt.left.arms) != "string" {
                        let mut _all_void = true
                        let mut _qi = 0
                        let _qarms = stmt.left.arms
                        while _qi < len(_qarms) {
                            if !_gen2_arm_body_is_void(_qarms[_qi].body) { _all_void = false }
                            _qi = _qi + 1
                        }
                        if _all_void { _skip = true }
                    }
                    if !_skip {
                        // Plan B Phase 3: if this fn has defers, route
                        // the implicit tail-return through __fn_exit
                        // so the drain runs before the arena-wrapped
                        // return. Same shape as the explicit ReturnStmt
                        // branch in gen2_stmt.
                        if _gen2_defer_flag_count > 0 {
                            chunks.push("    __ret_val = " + gen2_expr(stmt.left) + "; goto __fn_exit;\n")
                        } else if has_no_arena {
                            chunks.push("    return " + gen2_expr(stmt.left) + ";\n")
                        } else {
                            chunks.push("    return __hexa_fn_arena_return(" + gen2_expr(stmt.left) + ");\n")
                        }
                        did_emit_return = true
                    }
                }
            }
        }
        if !did_emit_return {
            if has_stack_alloc {
                chunks.push(gen2_stmt_stack_alloc(stmt, 1))
            } else {
                chunks.push(gen2_stmt(stmt, 1))
            }
        }
        bi = bi + 1
    }
    _comptime_const_scope_restore(_cc_fn_mark)
    // Plan B Phase 3: emit __fn_exit drain before the safety footer
    // when this fn registered any defers. The drain runs each defer
    // body in reverse-registration order (LIFO — matches Go + the
    // interp interpreter) under its activation flag, then flows into
    // the arena-wrapped __ret_val return.
    if _gen2_defer_flag_count > 0 {
        // Fall-through path (body ran to the closing brace without
        // hitting a return or a tail-return) needs to reach __fn_exit
        // too — force the jump. Also prevents "label declared but not
        // referenced" warnings when the only references are explicit
        // returns in conditional branches.
        chunks.push("    goto __fn_exit;\n")
        chunks.push("__fn_exit:;\n")
        let mut _dd = len(_gen2_defer_bodies) - 1
        while _dd >= 0 {
            let entry = _gen2_defer_bodies[_dd]
            let flag_id = entry[0]
            let body = entry[1]
            chunks.push("    if (__defer_" + to_string(flag_id) + "_active) {\n")
            if type_of(body) == "array" {
                let mut _bj = 0
                while _bj < len(body) {
                    chunks.push(gen2_stmt(body[_bj], 2))
                    _bj = _bj + 1
                }
            }
            chunks.push("    }\n")
            _dd = _dd - 1
        }
        if has_no_arena {
            chunks.push("    return __ret_val;\n}\n")
        } else {
            chunks.push("    return __hexa_fn_arena_return(__ret_val);\n}\n")
        }
    } else if has_no_arena {
        chunks.push("    return hexa_void();\n}\n")
    } else {
        chunks.push("    return __hexa_fn_arena_return(hexa_void());\n}\n")
    }
    // Plan B Phase 3: restore outer fn's defer state (nested FnDecl case).
    _gen2_defer_bodies = _prev_defer_bodies
    _gen2_defer_flag_count = _prev_defer_flag_count
    // @lazy thunk wrapper: emit a second fn with the original name that
    // guards the body via a static `computed` flag. One-shot; zero-arg only.
    // Wrapper is NOT @hot/@cold/@restrict-decorated — it's a trivial cache
    // check, decoration on the body captures the real hotness.
    if _is_lazy {
        chunks.push("static int __thunk_computed_" + _fn_name_real + " = 0;\n")
        chunks.push("static HexaVal __thunk_result_" + _fn_name_real + ";\n")
        chunks.push("HexaVal " + _fn_name_real + "(void) {\n")
        chunks.push("    if (!__thunk_computed_" + _fn_name_real + ") {\n")
        chunks.push("        __thunk_result_" + _fn_name_real + " = " + _fn_name + "();\n")
        chunks.push("        __thunk_computed_" + _fn_name_real + " = 1;\n")
        chunks.push("    }\n")
        chunks.push("    return __thunk_result_" + _fn_name_real + ";\n")
        chunks.push("}\n")
    }
    // B20: restore @strict_fp scope on fn exit.
    _gen2_current_fn_strict_fp = _was_strict_fp
    // closure mut-capture: clear boxed-cell set on fn exit so a later fn's
    // (or the script body's) same-named binding isn't spuriously boxed.
    _gen2_boxed_cells = []
    return chunks.join("")
}

// gen2_stmt_stack_alloc — same as gen2_stmt but LetMutStmt with empty array
// uses alloca-based stack allocation instead of heap
fn gen2_stmt_stack_alloc(node, depth) {
    let pad = gen2_indent(depth)
    let k = node.kind
    if k == "LetMutStmt" {
        if type_of(node.left) != "string" && node.left.kind == "ArrayLit" {
            // @stack_alloc: emit stack-based array via alloca
            return pad + "/* @stack_alloc */ HexaVal " + node.name + " = hexa_stack_array(1024);\n"
        }
    }
    return gen2_stmt(node, depth)
}

// ── Extern FFI wrapper generation ────────────────────────
// Returns a map with: global, forward, impl, init
//
// G3: Float argument support — when any param has type Float, generates a
// typed C wrapper so the C compiler puts doubles in SIMD registers (d0-d7)
// instead of integer registers (x0-x7) on ARM64.
//
// Example: extern fn foo(a: Int, b: Float) -> Int  generates:
//   typedef int64_t (*__ffi_ftyp_foo)(int64_t, double);
//   HexaVal foo(HexaVal a, HexaVal b) {
//       int64_t __r = ((__ffi_ftyp_foo)__ffi_sym_foo)(a.i, b.f);
//       return hexa_int(__r);
//   }
//
// For Cocoa NSRect: @symbol("objc_msgSend") extern fn send_rect(obj, sel, x: Float, y: Float, w: Float, h: Float) -> *Void
//   typedef int64_t (*__ffi_ftyp_send_rect)(int64_t, int64_t, double, double, double, double);
//   — C compiler puts ptr args in x0-x1 and doubles in d0-d3 automatically.

fn gen2_extern_ret_kind(ret_type) {
    if ret_type == "Void" || ret_type == "void" || ret_type == "" { return "0" }
    if ret_type == "Int" || ret_type == "int" { return "1" }
    // FFI float bucket: Float/float/f64 = double, f32 = float — both
    // use the same 0-arg fallback dispatch kind since hexa_extern_call
    // marshals through HexaVal.f (double) and the C ABI narrows on return.
    if ret_type == "Float" || ret_type == "float" || ret_type == "f64" || ret_type == "f32" { return "2" }
    if ret_type == "Bool" || ret_type == "bool" { return "3" }
    return "4" // pointer types
}

// Map a hexa param type to a C type for the typed FFI typedef.
// ARM64 AAPCS + x86_64 SysV: C `float` passes in s0/s1/xmm0/xmm1, C `double`
// in d0/d1/xmm0/xmm1 — same register FAMILY but different calling-convention
// slot. Calling cblas_sgemm(float alpha) with a `double alpha` typedef silently
// corrupts the argument. f32 must map to C `float`, f64/Float/float to double.
fn gen2_ffi_c_type(typ) {
    if typ == "f32" { return "float" }
    if typ == "Float" || typ == "float" || typ == "f64" { return "double" }
    return "int64_t" // Int, Bool, pointers, *Void, untyped — all as int64_t
}

// Map a hexa return type to the C return type
fn gen2_ffi_c_ret_type(ret_type) {
    if ret_type == "Void" || ret_type == "void" || ret_type == "" { return "void" }
    if ret_type == "f32" { return "float" }
    if ret_type == "Float" || ret_type == "float" || ret_type == "f64" { return "double" }
    return "int64_t"
}

// Check if any param has a floating-point type — determines if typed dispatch is needed.
// f32 and f64 both require typed dispatch since HexaVal generic path can't
// distinguish narrow-to-float vs double.
fn gen2_has_float_param(params) {
    let mut i = 0
    while i < len(params) {
        let t = params[i].value
        if t == "Float" || t == "float" || t == "f64" || t == "f32" { return 1 }
        i = i + 1
    }
    return 0
}

// Marshal a HexaVal arg to the correct C type for typed FFI call.
// HexaVal.f is always `double` at the runtime level; for f32 params we
// explicitly narrow to `float` at the call site so the C compiler places
// the arg in s-registers (ARM64) / xmm low lane (x86) per sgemm ABI.
fn gen2_ffi_marshal_arg(param_name, param_type) {
    if param_type == "f32" {
        return "(float)(HX_IS_FLOAT(" + param_name + ")?" + "HX_FLOAT(" + param_name + "):(double)HX_INT(" + param_name + "))"
    }
    if param_type == "Float" || param_type == "float" || param_type == "f64" {
        return "(HX_IS_FLOAT(" + param_name + ")?" + "HX_FLOAT(" + param_name + "):(double)HX_INT(" + param_name + "))"
    }
    // For int/pointer/untyped: extract as int64_t (unsigned to preserve ARM64 pointers)
    return "(HX_IS_INT(" + param_name + ")?" + "HX_INT_U(" + param_name + "):(int64_t)HX_FLOAT(" + param_name + "))"
}

// Wrap the raw C return value back into HexaVal.
// For f32 returns, we widen float→double via hexa_float (which takes double);
// the implicit promotion in the function call is safe and lossless.
fn gen2_ffi_wrap_ret(ret_type, var_name) {
    if ret_type == "Void" || ret_type == "void" || ret_type == "" {
        return "hexa_void()"
    }
    if ret_type == "f32" {
        return "hexa_float((double)" + var_name + ")"
    }
    if ret_type == "Float" || ret_type == "float" || ret_type == "f64" {
        return "hexa_float(" + var_name + ")"
    }
    if ret_type == "Bool" || ret_type == "bool" {
        return "hexa_bool(" + var_name + " != 0)"
    }
    return "hexa_int(" + var_name + ")"
}

// ── P4-3: Static FFI — extern fn → C declaration (compile-time linking) ──
// Instead of dlsym-based wrappers, generates direct C extern declarations.
// Used when linking against C libraries at compile time.

// Map Hexa type annotation to C type for static FFI declarations
fn gen2_static_c_type(typ) {
    if typ == "i64" || typ == "Int" || typ == "int" { return "long long" }
    if typ == "i32" { return "int" }
    if typ == "f64" || typ == "Float" || typ == "float" { return "double" }
    if typ == "f32" { return "float" }
    if typ == "str" || typ == "Str" || typ == "String" { return "char*" }
    if typ == "bool" || typ == "Bool" { return "int" }
    if typ == "void" || typ == "Void" || typ == "" { return "void" }
    if typ == "*Void" || typ == "Ptr" { return "void*" }
    // Unknown type — pass through as-is (user-defined C type)
    return typ
}

// Generate a C extern function declaration for static linking
// extern fn foo(x: Int, y: Float) -> Int
//   → extern long long foo(long long x, double y);
fn gen2_extern_static_decl(node) {
    let name = node.name
    let ret_type = node.ret_type

    // Use @symbol alias if present, otherwise use the Hexa name
    let mut c_name = node.value
    if c_name == "" { c_name = name }

    // Map return type
    let c_ret = gen2_static_c_type(ret_type)

    // Map parameter types
    let mut c_params = []
    let mut i = 0
    while i < len(node.params) {
        let p = node.params[i]
        let c_typ = gen2_static_c_type(p.value)
        if c_typ == "void" {
            // Untyped param — default to long long
            c_params.push("long long " + p.name)
        } else {
            c_params.push(c_typ + " " + p.name)
        }
        i = i + 1
    }

    let params_str = c_params.join(", ")
    let mut sig = params_str
    if sig == "" { sig = "void" }

    // Build the declaration
    let mut parts = []

    // If @link("lib") is set, emit a comment noting the library
    if node.op != "" {
        parts.push("// link: -l" + node.op + "\n")
    }

    parts.push("extern " + c_ret + " " + c_name + "(" + sig + ");\n")
    return parts.join("")
}

// Collect required #include headers based on extern fn types
fn gen2_extern_includes(ast) {
    let mut needs_stdio = 0
    let mut needs_stdlib = 0
    let mut needs_string = 0
    let mut needs_math = 0
    let mut has_extern = 0

    let mut i = 0
    while i < len(ast) {
        if ast[i].kind == "ExternFnDecl" {
            has_extern = 1
            // Check @link for common libraries
            if ast[i].op == "m" || ast[i].op == "libm" {
                needs_math = 1
            }
            // Check param/return types for string usage
            let mut j = 0
            while j < len(ast[i].params) {
                let t = ast[i].params[j].value
                if t == "str" || t == "Str" || t == "String" {
                    needs_string = 1
                }
                j = j + 1
            }
            let rt = ast[i].ret_type
            if rt == "str" || rt == "Str" || rt == "String" {
                needs_string = 1
            }
        }
        i = i + 1
    }

    if has_extern == 0 { return "" }

    let mut includes = []
    includes.push("#include <stdint.h>\n")
    if needs_math == 1 {
        includes.push("#include <math.h>\n")
    }
    if needs_string == 1 {
        includes.push("#include <string.h>\n")
    }
    return includes.join("")
}

// Generate all static FFI declarations for an AST
fn gen2_static_ffi_block(ast) {
    let includes = gen2_extern_includes(ast)
    let mut decls = []
    let mut i = 0
    while i < len(ast) {
        if ast[i].kind == "ExternFnDecl" {
            decls.push(gen2_extern_static_decl(ast[i]))
        }
        i = i + 1
    }
    if len(decls) == 0 { return "" }
    let mut parts = []
    if includes != "" {
        parts.push(includes)
    }
    parts.push("\n// ── FFI declarations ──\n")
    parts.push(decls.join(""))
    parts.push("\n")
    return parts.join("")
}

fn gen2_extern_wrapper(node) {
    let name = node.name
    let nargs = len(node.params)
    let ret_type = node.ret_type

    // Resolve @symbol("c_name") alias — use node.value if set, else node.name
    let mut c_sym = node.value
    if c_sym == "" { c_sym = name }

    // 2026-05-19 keyword-audit gap "ExternFnDecl in statement position":
    // the emitted C WRAPPER function must be named with the SAME mangle as
    // every call site. gen2_expr resolves a call `f(...)` to its C name via
    // `_hexa_mangle_ident` — so a reserved extern name (e.g. `extern fn
    // getpid()`; `getpid` IS in _hexa_name_is_reserved) is referenced as
    // `u_getpid()` at the call site. The wrapper, however, was emitted as
    // plain `getpid` here, so the call resolved to libc's `int getpid(void)`
    // instead of the HexaVal wrapper → clang "assigning to HexaVal from
    // incompatible type 'int'". Mangling the wrapper's C function name
    // (forward decl + both `static HexaVal NAME(...)` definitions) closes
    // the seam: decl name == reference name. The dlsym slot
    // `__ffi_sym_<name>` and typedef tag `__ffi_ftyp_<name>` keep the raw
    // name — already uniquely-prefixed internal identifiers — and the
    // dlsym C-symbol string is `c_sym` (the real libc symbol), unaffected.
    let cname = _hexa_mangle_ident(name)

    // Global: symbol pointer
    let global = "static void* __ffi_sym_" + name + " = NULL;\n"

    // Forward declaration (hexa wrapper takes HexaVal args)
    let mut fwd_params = []
    let mut fi = 0
    while fi < nargs {
        fwd_params.push("HexaVal " + _hexa_mangle_ident(node.params[fi].name))
        fi = fi + 1
    }
    let fwd_p = fwd_params.join(", ")
    let mut sig_p = fwd_p
    if sig_p == "" { sig_p = "void" }
    // HX-ffi-static: mark FFI wrapper `static` — prevents name collision
    // when the same identifier is defined elsewhere (e.g. widths.o linking
    // against void's _hx_is_wide_cjk). The wrapper is per-TU anyway and
    // doesn't need external linkage; dlsym-loaded __ffi_sym_* is the ABI.
    let forward = "static HexaVal " + cname + "(" + sig_p + ");"

    let has_float = gen2_has_float_param(node.params)

    // perf: chunks.push + join — avoid O(n²) string concat
    let mut impl_parts = []

    if has_float == 1 || nargs > 0 {
        // ── G3: Typed dispatch — generate a typedef + direct typed call ──
        // This ensures the C compiler puts float args in SIMD registers (d0-d7)
        // and integer/pointer args in GPRs (x0-x7) on ARM64.

        // Build typedef: e.g. typedef int64_t (*__ffi_ftyp_foo)(int64_t, double, double);
        let c_ret = gen2_ffi_c_ret_type(ret_type)
        let mut typedef_params = []
        let mut ti = 0
        while ti < nargs {
            typedef_params.push(gen2_ffi_c_type(node.params[ti].value))
            ti = ti + 1
        }
        let td_p = typedef_params.join(", ")
        let mut td_sig = td_p
        if td_sig == "" { td_sig = "void" }

        impl_parts.push("typedef " + c_ret + " (*__ffi_ftyp_" + name + ")(" + td_sig + ");\n")
        impl_parts.push("static HexaVal " + cname + "(" + sig_p + ") {\n")

        // Marshal each arg to its native C type
        let mut call_args = []
        let mut ci = 0
        while ci < nargs {
            call_args.push(gen2_ffi_marshal_arg(_hexa_mangle_ident(node.params[ci].name), node.params[ci].value))
            ci = ci + 1
        }
        let call_str = call_args.join(", ")

        if ret_type == "Void" || ret_type == "void" || ret_type == "" {
            impl_parts.push("    ((__ffi_ftyp_" + name + ")__ffi_sym_" + name + ")(" + call_str + ");\n")
            impl_parts.push("    return hexa_void();\n")
        } else {
            impl_parts.push("    " + c_ret + " __r = ((__ffi_ftyp_" + name + ")__ffi_sym_" + name + ")(" + call_str + ");\n")
            impl_parts.push("    return " + gen2_ffi_wrap_ret(ret_type, "__r") + ";\n")
        }
        impl_parts.push("}\n")
    } else {
        // 0-arg function — use simple hexa_extern_call
        impl_parts.push("static HexaVal " + cname + "(" + sig_p + ") {\n")
        impl_parts.push("    return hexa_extern_call(__ffi_sym_" + name + ", NULL, 0, " + gen2_extern_ret_kind(ret_type) + ");\n")
        impl_parts.push("}\n")
    }
    let impl_code = impl_parts.join("")

    // Init: dlopen + dlsym in main() — use @symbol C name and @link library
    let mut lib_arg = "NULL"
    if node.op != "" {
        lib_arg = "\"" + node.op + "\""
    }
    let init = "    __ffi_sym_" + name + " = hexa_ffi_dlsym(hexa_ffi_dlopen(" + lib_arg + "), \"" + c_sym + "\");\n"

    return #{
        "global": global, "forward": forward, "fn_code": impl_code, "init": init,
        "kind": "", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ROI-38: pre-built indent strings for depth 0-6 — avoids per-call allocation
let mut _gen2_indent_cache = []

fn gen2_indent(n) {
    if len(_gen2_indent_cache) == 0 {
        _gen2_indent_cache = ["", "    ", "        ", "            ", "                ", "                    ", "                        "]
    }
    if n >= 0 && n < 7 { return _gen2_indent_cache[n] }
    // fallback for depth >= 7
    let mut parts = []
    let mut i = 0
    while i < n {
        parts.push("    ")
        i = i + 1
    }
    return parts.join("")
}

// bt 72: per-function set of C identifiers already declared. Hexa permits
// `let x = ...` shadow-rebind in the same block; C forbids it. gen2_fn_decl
// pre-scans the body and hoists any name declared >1 times to the function
// top as `HexaVal x = hexa_void();`, then LetStmt emits as plain assignment.
let mut _gen2_declared_names = []
let mut _gen2_arena_wrap = 0

// B20 / roadmap 55 — @strict_fp state.
//   `_gen2_current_fn_strict_fp`: 1 while emitting a fn body decorated with
//     @strict_fp; 0 otherwise. Read by the two FMA-fusion sites (compound
//     `x += a*b` at ~line 1722 and `(a*b)+c` at ~line 2502) to suppress
//     hexa_fma emission — strict_fp fns must preserve two roundings.
//   `_gen2_tu_has_strict_fp`: sticky 1 once any fn in the TU is @strict_fp.
//     Emitted as a `/* HEXA_STRICT_FP_TU */` marker at top of generated C so
//     the build driver (self/main.hexa) can inject IEEE-strict clang flags.
let mut _gen2_current_fn_strict_fp = 0
let mut _gen2_tu_has_strict_fp = 0

// Plan B Phase 3 — defer/scope/spawn codegen state (per-function).
//
// gen2_fn_decl saves + resets these at entry, restores at exit. The
// interp interpreter implements defer fully (self/hexa_full.hexa line
// 8391: DeferStmt pushes body onto a per-call defer_stack that drains
// on function return). AOT codegen previously errored with "unhandled
// stmt kind: DeferStmt"; this state + the gen2_stmt DeferStmt branch
// below mirror that semantics via static C flags + goto __fn_exit.
//
//   `_gen2_defer_bodies`: list of [flag_id, body_stmts] pairs,
//     populated in textual order as DeferStmt is encountered during
//     body emission. Drained at __fn_exit in LIFO order.
//   `_gen2_defer_flag_count`: next unused __defer_N_active id for
//     this function. Resets to 0 at every fn entry.
//
// Zero-cost when absent: functions without defer emit unchanged C —
// no flag vars, no __fn_exit label, no goto rewrites.
let mut _gen2_defer_bodies = []
let mut _gen2_defer_flag_count = 0

// _gen2_count_defers — pre-scan the fn body to count DeferStmt nodes
// so gen2_fn_decl can emit the right number of `__defer_N_active`
// declarations at the top BEFORE body codegen assigns flag ids. The
// count also drives whether the fn needs the __fn_exit scaffold at
// all (len==0 → no scaffold, original codegen preserved).
//
// Recurses into all nested statement containers (.body / .then_body /
// .else_body / .arms[].body) but NEVER into nested FnDecl / PureFnDecl
// — those are separate call frames with their own defer stacks.
// decreases stmts — structural
fn _gen2_count_defers(stmts) {
    if type_of(stmts) != "array" { return 0 }
    let mut n = 0
    let mut i = 0
    while i < len(stmts) {
        let s = stmts[i]
        i = i + 1
        if type_of(s) == "string" { continue }
        let k = s.kind
        // Nested fn decls carry their own defer scope — skip.
        if k == "FnDecl" || k == "PureFnDecl" || k == "ExternFnDecl" { continue }
        if k == "DeferStmt" { n = n + 1 }
        // Recurse into every statement-array-shaped field. Not all
        // nodes carry these; type_of guards the no-op case.
        if type_of(s.body) == "array" { n = n + _gen2_count_defers(s.body) }
        if type_of(s.then_body) == "array" { n = n + _gen2_count_defers(s.then_body) }
        if type_of(s.else_body) == "array" { n = n + _gen2_count_defers(s.else_body) }
        if type_of(s.arms) == "array" {
            let mut j = 0
            while j < len(s.arms) {
                let arm = s.arms[j]
                if type_of(arm) != "string" && type_of(arm.body) == "array" {
                    n = n + _gen2_count_defers(arm.body)
                }
                j = j + 1
            }
        }
    }
    return n
}

fn _gen2_has_decl(name) {
    let n = len(_gen2_declared_names)
    let mut i = 0
    while i < n {
        if _gen2_declared_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// decreases node — structural
fn _gen2_collect_lets_stmt(node, names) {
    if type_of(node) == "string" { return names }
    let sk = node.kind
    if sk == "LetStmt" || sk == "LetMutStmt" {
        names.push(node.name)
    }
    // PROBE r14-UUUU: let-else binders escape to the enclosing scope (canonical
    // Rust semantics).  Hoist the single-field EnumPath binder name and any
    // multi-field payload Ident binders into the function-scope flat pool so
    // the desugar (gen2_let_else) can assign without a fresh declaration.
    if sk == "LetElseStmt" {
        let _pat = node.left
        if type_of(_pat) != "string" && _pat.kind == "EnumPath" {
            if type_of(_pat.left) != "string" && _pat.left.kind == "Ident" && _pat.left.name != "_" {
                names.push(_pat.left.name)
            }
            if type_of(_pat.items) != "string" {
                let mut _lei = 0
                while _lei < len(_pat.items) {
                    let _it = _pat.items[_lei]
                    if type_of(_it) != "string" && _it.kind == "Ident" && _it.name != "_" {
                        names.push(_it.name)
                    }
                    _lei = _lei + 1
                }
            }
        }
    }
    if sk == "DestructLetStmt" || sk == "MapDestructLetStmt" {
        if type_of(node.params) != "string" {
            let mut _dpi = 0
            while _dpi < len(node.params) {
                // PROBE r16: skip `_` — it is a discard binder, never declared
                // or referenced, so it must not enter the flat-hoist pool.
                if node.params[_dpi] != "_" {
                    names.push(node.params[_dpi])
                }
                _dpi = _dpi + 1
            }
        }
        if sk == "DestructLetStmt" && type_of(node.name) == "string" && node.name != "" && node.name != "_" {
            names.push(node.name)
        }
    }
    if type_of(node.then_body) != "string" { names = _gen2_collect_lets(node.then_body, names) }
    if type_of(node.else_body) != "string" { names = _gen2_collect_lets(node.else_body, names) }
    if type_of(node.body) != "string" { names = _gen2_collect_lets(node.body, names) }
    if type_of(node.arms) != "string" {
        let mut ai = 0
        while ai < len(node.arms) {
            let arm = node.arms[ai]
            if type_of(arm) != "string" && type_of(arm.body) != "string" {
                names = _gen2_collect_lets(arm.body, names)
            }
            ai = ai + 1
        }
    }
    // ExprStmt-wrapped IfExpr/MatchExpr used as a statement
    if sk == "ExprStmt" && type_of(node.left) != "string" {
        names = _gen2_collect_lets_stmt(node.left, names)
    }
    return names
}

fn _gen2_collect_lets(stmts, names) {
    if type_of(stmts) == "string" { return names }
    let mut i = 0
    while i < len(stmts) {
        names = _gen2_collect_lets_stmt(stmts[i], names)
        i = i + 1
    }
    return names
}

// 2026-04-27: IfExpr / MatchExpr arm is "trivial" (safe for C ternary
// collapse) iff its body is empty OR a single ExprStmt. Anything else
// (LetStmt, multiple stmts) requires a GCC statement-expression so
// inner declarations survive.
fn _gen2_arm_is_trivial(body) {
    if type_of(body) == "string" { return true }
    if len(body) == 0 { return true }
    if len(body) > 1 { return false }
    let s = body[0]
    if type_of(s) == "string" { return false }
    if s.kind != "ExprStmt" { return false }
    if type_of(s.left) == "string" { return false }
    return true
}

// 2026-04-27: render a non-trivial IfExpr / MatchExpr arm body as a GCC
// statement-expression `({ stmt0; stmt1; …; (tail); })`. Inner LetStmts
// emit via gen2_stmt — they declare `HexaVal X = …` as fresh locals
// scoped to the block, exactly what we want when the arm contains
// intermediate bindings. Tail value comes from the last ExprStmt's
// expression; if the body's trailing stmt isn't a value-producing
// ExprStmt the arm evaluates to hexa_void() (mirrors the trivial-empty
// case).
fn _gen2_arm_block_expr(body) {
    if type_of(body) == "string" { return "hexa_void()" }
    if len(body) == 0 { return "hexa_void()" }
    let n = len(body)
    // Scope-isolate this block body's comptime-const folds: any `let x = <lit>`
    // emitted here must not bleed into a sibling arm or the enclosing scope.
    let _cc_mark = _comptime_const_scope_mark()
    let mut chunks = []
    chunks.push("({ ")
    let mut bi = 0
    while bi < n - 1 {
        let s = body[bi]
        if type_of(s) != "string" {
            chunks.push(gen2_stmt(s, 0))
        }
        bi = bi + 1
    }
    let last = body[n - 1]
    if type_of(last) != "string" && last.kind == "ExprStmt" && type_of(last.left) != "string" {
        chunks.push("(" + gen2_expr(last.left) + "); })")
    } else {
        if type_of(last) != "string" {
            chunks.push(gen2_stmt(last, 0))
        }
        chunks.push("hexa_void(); })")
    }
    _comptime_const_scope_restore(_cc_mark)
    return chunks.join("")
}

// 2026-04-27: walk top-level ast skipping kinds that have their own scope
// (FnDecl, StructDecl, …) or emit through the global-decl path (LetStmt at
// module level). Remaining stmts land in main_parts via gen2_stmt and share
// the implicit C main() scope — collect their let names so duplicate-name
// hoist (gen2_fn_decl-style) can apply to script-body too.
fn _gen2_collect_main_body_lets(ast) {
    let mut names = []
    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k != "FnDecl" && k != "ExternFnDecl" && k != "StructDecl"
           && k != "EnumDecl" && k != "ImplBlock" && k != "PureFnDecl"
           && k != "ComptimeConst" && k != "ConstStmt"
           && k != "TraitDecl" && k != "InvariantDecl"
           && k != "ImportStmt" && k != "UseStmt"
           && k != "LetMutStmt" && k != "LetStmt" {
            names = _gen2_collect_lets_stmt(ast[i], names)
        }
        i = i + 1
    }
    return names
}

// 2026-05-16: generalized nested mutable index-assignment lowering.
// For `root[k0][k1]...[kN] = v` the correct functional rebind assigns back to
// the ROOT lvalue (the base variable being mutated), recursing the
// hexa_index_set(...) chain — NOT to an intermediate hexa_index_get(...)
// which is a C rvalue (function-call result), not an lvalue.
//   root = hexa_index_set(root, k0,
//            hexa_index_set(hexa_index_get(root,k0), k1,
//              ... hexa_index_set(get(...get(root,k0)...,k(N-1)), kN, v) ...))
// Generalizes the prior 1-level (root[i]=v) and 2-level (root[i][j]=v) cases
// (they are the depth-1 / depth-2 instances of this recursion — byte-identical
// output preserved). lhs = the Index AST node (AssignStmt.left); val_c = the
// already-lowered RHS C-string. Returns the full `root = …;` statement string.
fn _gen2_nested_index_assign_stmt(lhs, val_c, pad) {
    // Walk the Index spine outermost→innermost collecting index keys.
    // lhs.right = last key (kN); lhs.left = root[k0]...[k(N-1)].
    let mut keys_rev = []
    let mut cur = lhs
    while type_of(cur) != "string" && cur.kind == "Index" {
        keys_rev.push(gen2_expr(cur.right))
        cur = cur.left
    }
    // `cur` is now the root lvalue node (Ident / Field / etc — anything but a
    // bare Index spine). Lower it once; this is the C lvalue we assign to.
    let root_c = gen2_expr(cur)
    // Reverse keys to top-down order k0..kN.
    let mut keys = []
    let mut ri = len(keys_rev) - 1
    while ri >= 0 {
        keys.push(keys_rev[ri])
        ri = ri - 1
    }
    let n = len(keys)
    // Build accessor prefixes: acc[0]=root_c, acc[j]=hexa_index_get(acc[j-1], k[j-1]).
    let mut acc = []
    acc.push(root_c)
    let mut ai = 1
    while ai < n {
        acc.push("hexa_index_get(" + acc[ai - 1] + ", " + keys[ai - 1] + ")")
        ai = ai + 1
    }
    // Build the nested hexa_index_set from innermost (level n-1) outward.
    // innermost replacement value = val_c.
    let mut expr = val_c
    let mut li = n - 1
    while li >= 0 {
        expr = "hexa_index_set(" + acc[li] + ", " + keys[li] + ", " + expr + ")"
        li = li - 1
    }
    // Field-rooted index assign — `obj.field[i] = v` lowered above gave
    // `hexa_map_get_ic(obj, "field", &ic) = hexa_index_set(...)` which is a
    // C function-call return on the LHS → "expression is not assignable".
    // Rewrite as `obj = hexa_map_set(obj, "field", new_field_value)`. This
    // mirrors the same wrap the plain Field-AssignStmt branch (line ~2279)
    // already emits. Repro: `cs.clusters[i] = Cluster {...}` in
    // compiler/atlas/symbolic/convergence_cluster.hexa (broke calc_cli_smoke
    // and convergence_cluster_smoke).
    if type_of(cur) != "string" && cur.kind == "Field" {
        let obj_c = gen2_expr(cur.left)
        return pad + obj_c + " = hexa_map_set(" + obj_c + ", \"" + cur.name + "\", " + expr + ");\n"
    }
    return pad + root_c + " = " + expr + ";\n"
}

// decreases node — structural
// PROBE r15-D2 (2026-05-24): gen2_stmt wrapper for postfix `?` hoisting.
// Saves + clears the Try-preamble buffer, emits the statement via the
// inner worker (gen2_expr appends any `?` early-return preamble while it
// runs), then PREPENDS the accumulated preamble so the success-check +
// early-return run before the statement uses the unwrapped payload. The
// buffer is per-statement (save/restore) so nested statements (loop /
// branch bodies, lambda bodies — each a separate gen2_stmt call) keep
// independent hoist scopes. No `?` in a statement → buffer stays "",
// emission is byte-identical to the pre-D2 path.
fn gen2_stmt(node, depth) {
    let _saved_pre = _gen2_try_preamble
    _gen2_try_preamble = ""
    let _body = _gen2_stmt_inner(node, depth)
    let _pre = _gen2_try_preamble
    _gen2_try_preamble = _saved_pre
    if _pre == "" {
        return _body
    }
    return _pre + _body
}

// PROBE r16 Q1: bitwise `& | ^ << >>` require integer operands. The naked
// `hexa_int(HX_INT(l) & HX_INT(r))` emission extracts garbage 0 from a
// float/string-tagged value (e.g. `5.0 & 3` silently became 0). Canonical
// Go/Rust treat a non-int bitwise operand as a TYPE ERROR. This helper emits a
// GCC stmt-expr that binds both operands once (no double-eval of side effects),
// throws "bitwise requires integer operands" on a non-int operand, then applies
// the inline C bit op. TAG_CHAR is int-backed and bitwise-meaningful so it is
// accepted alongside TAG_INT; everything else (float/string/array/...) throws.
fn _bitop_guarded(c_op, l, r) {
    return "({ HexaVal __bla = (" + l + "), __blb = (" + r + "); " +
           "if (!(HX_IS_INT(__bla)||HX_TAG(__bla)==TAG_CHAR) || !(HX_IS_INT(__blb)||HX_TAG(__blb)==TAG_CHAR)) " +
           "hexa_throw(hexa_str(\"bitwise requires integer operands\")); " +
           "hexa_int(HX_INT(__bla) " + c_op + " HX_INT(__blb)); })"
}

fn _gen2_stmt_inner(node, depth) {
    let pad = gen2_indent(depth)
    let k = node.kind

    // PROBE r14-S (round 3 #6 carry-over): bare-block `{ stmt; stmt; }` as a
    // statement (parser.hexa BlockStmt branch). Emits a plain C brace-group
    // so the contained stmts execute in sequence. NOTE: hexa flat-hoists
    // `let` per function (`_gen2_collect_lets`), so this brace-group does
    // NOT introduce a fresh lexical scope today — the separate scope-leak
    // RFC owns that fix. WhileStmt's body-loop is the structural template.
    if k == "BlockStmt" {
        let mut chunks = []
        chunks.push(pad + "{\n")
        let mut bi = 0
        while bi < len(node.body) {
            chunks.push(gen2_stmt(node.body[bi], depth + 1))
            bi = bi + 1
        }
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // AtomicLet (`atomic let x = …`) shares LetMutStmt's shape (name +
    // left=init); single-threaded codegen treats `atomic` as an annotation
    // and emits a normal mutable binding (no atomics infra wired).
    // PROBE r14-UUUU: let PAT = EXPR else { D } — canonical Rust let-else.
    // Lowers to a runtime tag-test guarding the binder assignment, with the
    // else-block (which MUST diverge) on the fail branch. Binders live in the
    // outer scope (function-flat hoisted via _gen2_collect_lets_stmt), so the
    // generated body is plain assignment — no fresh `HexaVal` declaration.
    // Divergence enforcement (return/break/continue/panic) is deferred to a
    // later strict pass — for v1 we trust the user.
    if k == "LetElseStmt" {
        return gen2_let_else(node, depth)
    }
    if k == "LetStmt" || k == "LetMutStmt" || k == "AtomicLet" {
        let init = "hexa_void()"
        if type_of(node.left) != "string" {
            init = gen2_expr(node.left)
        }
        // PROBE r15-D18: type-changing shadow let-rebind. If this name is a
        // same-scope re-`let` (hoisted by bt 72, so `_gen2_has_decl` is true),
        // it shadows an earlier binding — possibly with a NEW type. Any prior
        // comptime-const fold for the name is now stale and would inline the
        // OLD value at every later reference (`let x="hi"; let x=42; x` → "hi").
        // `init` above already captured this RHS using the OLD registration
        // (correct for `let n = n + 1`), so it is safe to invalidate now before
        // the re-fold below re-registers the NEW value (or falls back to the
        // live variable read when the new init does not fold).
        if _gen2_has_decl(node.name) {
            _invalidate_comptime_const(node.name)
        }
        // STRUCTURAL-2 Phase B: register immutable let with int initializer
        // as known-int for downstream BinOp .i unboxing. Only LetStmt
        // (immutable) — LetMutStmt excluded because reassignment may change type.
        if k == "LetStmt" && type_of(node.left) != "string" {
            if _is_int_init_expr(node.left) {
                _known_int_add(node.name)
            }
            // STRUCTURAL-3: register immutable let with float initializer
            if _is_float_init_expr(node.left) {
                _known_float_add(node.name)
            }
            // UNSHADOW item A: register immutable let bound to a monomorphic
            // i64 array literal (`[1,2,3,…]`) as a known-int-array, so an
            // in-range read of it inside a proven loop can drop the array-tag
            // guard and read the raw `.i` element (boxed-storage unbox).
            if _is_int_literal_array(node.left) {
                _known_intarr_add(node.name)
                // UNSHADOW [HEADLINE] F1: native-i64 array STORAGE. When the
                // gated opt-in flag is set, lower the proven monomorphic-i64
                // literal to native CONTIGUOUS int64_t[] storage
                // (hexa_arr_i64_new/push) instead of the 16-byte-stride boxed
                // HexaArr. The axis-A closed-negative proved the parity gap
                // lives in this storage (clang can't SIMD-gather 16B stride);
                // native 8B-contiguous closes it (bench: 15.3×, gap→0.94×). The
                // descriptor rides the SAME TAG_ARRAY/arr_ptr slot, and the
                // HexaArrI64 layout (ptr,len,cap) matches HexaArr so the
                // polymorphic `hexa_len` reads len at the same offset (loop
                // bound + `len(xs)` work unchanged). The in-range read arm below
                // emits the raw native `((HexaArrI64*)xs.arr_ptr)->data[i]`.
                // GATED opt-in (default OFF) because a fully-general no-escape
                // proof — needed before a non-proven polymorphic use (pass-to-
                // fn / unproven index / print) is safe — is a separate
                // multi-session sub-task; under the flag the construction is
                // sound for read-only proven-loop bindings (the c-class shape).
                if _native_arr_enabled() {
                    let _ni = len(node.left.items)
                    let mut _nout = "({ HexaVal __nia = hexa_arr_i64_new(" + to_string(_ni) + "); "
                    let mut _nai = 0
                    while _nai < _ni {
                        _nout = _nout + "hexa_arr_i64_push(__nia, (int64_t)HX_INT(" + gen2_expr(node.left.items[_nai]) + ")); "
                        _nai = _nai + 1
                    }
                    _nout = _nout + "__nia; })"
                    init = _nout
                }
            } else {
                // A same-name re-let to a non-int-array RHS voids the proof.
                _known_intarr_void(node.name)
            }
            // UNSHADOW typed monomorphic struct layout: register an immutable
            // `let p = Pt{...}` (or `Pt(...)`) whose type is flat-eligible so the
            // Field arm can lower `p.field` to an OFFSET load. Fires only under
            // HEXA_TYPED_STRUCT=1 (via _is_flat_eligible_struct gate). Any re-let
            // to a non-flat-struct RHS voids the binding (mirrors known-intarr).
            let _flat_init_type = _flat_struct_init_type(node.left)
            if _flat_init_type != "" {
                _flat_var_add(node.name, _flat_init_type)
            } else {
                _flat_var_void(node.name)
            }
            // PROBE r11 B3: also try comptime-fold for plain immutable `let`.
            // `let x = 2+3` now folds to literal 5 and registers in the
            // comptime-const table — downstream references inline the literal
            // (matches the ComptimeConst path at gen2_stmt L3188).
            // LetMutStmt + AtomicLet excluded — reassignment / atomic semantics
            // would invalidate the inlined-literal contract.
            let _let_folded = comptime_eval(node.left)
            if type_of(_let_folded) != "string" {
                _register_comptime_const(node.name, _let_folded)
            }
        }
        // 2026-04-19: local let decls must match Ident-reference mangling so
        // names in the reserved set (fmax, j1, argv, printf, …) don't land
        // with a bare `HexaVal j1 = …;` declaration while every read emits
        // `u_j1`. Bug surfaced on training/alm_val.hexa `let j1 = judge_…`.
        let _local_name = _hexa_mangle_ident(node.name)
        // UNSHADOW F2 (escape→stack-alloc): an immutable `let p = Pt{…}` whose
        // flat-eligible struct value was PROVEN non-escaping by the body pre-scan
        // (gen2_fn_decl → _stack_noescape_scan) gets a stack-local __flat instead
        // of the malloc'ing constructor — no heap descriptor. GATED
        // (HEXA_STACK_ALLOC); byte-identical reads (offset layout unchanged).
        // The descriptor's address is taken into `p.vs`; by the proof, every use
        // of `p` is a `p.field` read within this C block, so the stack object
        // strictly outlives all reads (no dangling pointer). Hoisted-name case
        // (bt 72 shadow) is excluded — the stack object needs a fresh decl.
        if k == "LetStmt" && _stack_alloc_enabled() && _is_stack_noescape(node.name) && !_gen2_has_decl(node.name) {
            let _sa_args = _flat_struct_arg_exprs(node.left)
            if type_of(_sa_args) != "string" {
                let _sa_type = _flat_struct_init_type(node.left)
                if _sa_type != "" {
                    return gen2_stack_alloc_flat(pad, _local_name, _sa_type, _sa_args)
                }
            }
        }
        // M975: register promotion — if value == "__reg_promote__", emit `register`
        if k == "LetMutStmt" && node.value == "__reg_promote__" {
            return pad + "register HexaVal " + _local_name + " = " + init + "; /* reg-promoted */\n"
        }
        // closure mut-capture: this `let mut X` is captured-and-mutated by a
        // closure — box the binding into a shared 1-element array cell. Reads
        // / writes / captures of X all deref the cell (see _gen2_boxed_cells).
        // Boxing applies only to function-LOCAL mut bindings reaching here;
        // module-scope `let mut` uses the C-global path (already canonical).
        if k == "LetMutStmt" && _gen2_is_boxed_cell(node.name) {
            let _cell = "hexa_array_push(hexa_array_new(), " + init + ")"
            if _gen2_has_decl(node.name) {
                return pad + _local_name + " = " + _cell + ";\n"
            }
            return pad + "HexaVal " + _local_name + " = " + _cell + ";\n"
        }
        // bt 72: if this name was hoisted (or matches a param), emit plain
        // assignment to avoid C "redefinition" errors from shadow semantics.
        if _gen2_has_decl(node.name) {
            return pad + _local_name + " = " + init + ";\n"
        }
        // 2026-05-20 (blocker-5 self-shadow): in C, the local being declared
        // is in scope for its own initializer. When user writes
        // `let pi = pi()` and `pi` is not a defined function, codegen emits
        // `HexaVal pi = hexa_call0(pi);` — `pi` on RHS resolves to the
        // uninitialized local, giving silent garbage (e.g. 259). Detect
        // self-reference in the init text and route through a temp so the
        // local is initialized after the init expression evaluates. The
        // textual scan is conservative (we'd rather emit a harmless temp
        // than miss a real self-shadow). Skip the rename when the name was
        // already mangled (u_X) — those don't collide with themselves.
        if _local_name == node.name && _init_refs_local(init, node.name) {
            // Emit: `HexaVal __init_<name> = <init>; HexaVal <name> = __init_<name>;`
            // Both bindings remain in scope for the rest of the block; the
            // temp is unused after the line but C-clean.
            let _tmp = "__hexa_letinit_" + node.name
            return pad + "HexaVal " + _tmp + " = " + init + "; HexaVal " + _local_name + " = " + _tmp + ";\n"
        }
        return pad + "HexaVal " + _local_name + " = " + init + ";\n"
    }

    if k == "ConstStmt" {
        return pad + "HexaVal " + node.name + " = " + gen2_expr(node.left) + ";\n"
    }

    if k == "AssignStmt" {
        // Index assignment: arr[i] = val or map["key"] = val → polymorphic.
        // Recurse the full LHS Index spine and rebind the ROOT lvalue (fixes
        // the prior nested-case bug that targeted an intermediate
        // hexa_index_get(...) rvalue — invalid C). Generalizes 1/2/N levels.
        if type_of(node.left) != "string" && node.left.kind == "Index" {
            let val = gen2_expr(node.right)
            return _gen2_nested_index_assign_stmt(node.left, val, pad)
        }
        // Field assignment: obj.field = val
        if type_of(node.left) != "string" && node.left.kind == "Field" {
            let obj = gen2_expr(node.left.left)
            let field = node.left.name
            let val = gen2_expr(node.right)
            return pad + obj + " = hexa_map_set(" + obj + ", \"" + field + "\", " + val + ");\n"
        }
        // closure mut-capture: assigning to a boxed `let mut` Ident writes
        // through the shared cell via hexa_array_set (in-place mutate; returns
        // the cell so the C local stays bound to the same array). The boxed
        // Ident read on the LHS would otherwise emit an rvalue
        // hexa_array_get(...) — invalid as an lvalue. See _gen2_boxed_cells.
        if type_of(node.left) != "string" && node.left.kind == "Ident" && _gen2_is_boxed_cell(node.left.name) {
            let _cn = _hexa_mangle_ident(node.left.name)
            return pad + _cn + " = hexa_array_set(" + _cn + ", 0, " + gen2_expr(node.right) + ");\n"
        }
        // PROBE r16 immutable-let-reassign: a plain immutable `let x = <int/float
        // lit>` is const-folded to its literal, so a later `x = …` emits the
        // folded literal as the lvalue (`<literal> = …;` → "expression is not
        // assignable" at clang). Reassignment mutates the binding, so the fold
        // is stale: drop it before emitting. The local C variable for `x` is
        // still declared (the fold only inlines reads), so gen2_expr resolves
        // the LHS (and any RHS self-reference) to the live variable. No-op for
        // non-folded / string-folded names (mirrors the re-`let` D18 invalidate).
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            _invalidate_comptime_const(node.left.name)
            // UNSHADOW item A: reassigning the binding may swap in a non-int
            // array (or a non-array) — void the known-int-array proof.
            _known_intarr_void(node.left.name)
        }
        return pad + gen2_expr(node.left) + " = " + gen2_expr(node.right) + ";\n"
    }

    if k == "CompoundAssign" {
        // Parser emits base op only ("+", "-", "*", "/", "%") — not "+=" etc.
        // Previously compared against "+=" literally → every CompoundAssign
        // fell through to the `/* compound */` comment and became a no-op
        // on AOT. Interp path routes through eval_binop(op, lv, rv) which
        // normalizes, masking the issue until regression hit it.
        let op = node.op
        // closure mut-capture: a boxed `let mut` Ident on the LHS — read derefs
        // the cell (gen2_expr already emits hexa_array_get(X,0), a valid
        // rvalue) and the write goes back through hexa_array_set. Handle here
        // before the generic `lhs = …` shape (which would assign to an
        // rvalue). See _gen2_boxed_cells.
        if type_of(node.left) != "string" && node.left.kind == "Ident" && _gen2_is_boxed_cell(node.left.name) {
            let _cn = _hexa_mangle_ident(node.left.name)
            let _rd = "hexa_array_get(" + _cn + ", 0)"
            let _rhs = gen2_expr(node.right)
            let mut _nv = ""
            if op == "+" { _nv = "hexa_add(" + _rd + ", " + _rhs + ")" }
            else if op == "-" { _nv = "hexa_sub(" + _rd + ", " + _rhs + ")" }
            else if op == "*" { _nv = "hexa_mul(" + _rd + ", " + _rhs + ")" }
            else if op == "/" { _nv = "hexa_div(" + _rd + ", " + _rhs + ")" }
            else if op == "%" { _nv = "hexa_mod(" + _rd + ", " + _rhs + ")" }
            else { return pad + "/* compound " + op + " (boxed) */\n" }
            return pad + _cn + " = hexa_array_set(" + _cn + ", 0, " + _nv + ");\n"
        }
        // FMA for compound assign: x += a * b  →  x = fma(a, b, x)
        // B20: suppressed inside @strict_fp fns (two roundings must be
        //      preserved for IEEE 754 bit-exactness).
        if op == "+" {
            if _gen2_current_fn_strict_fp == 0 && type_of(node.right) != "string" && node.right.kind == "BinaryOp" && node.right.op == "*" {
                let lhs = gen2_expr(node.left)
                let fa = gen2_expr(node.right.left)
                let fb = gen2_expr(node.right.right)
                return pad + lhs + " = hexa_fma(" + fa + ", " + fb + ", " + lhs + ");\n"
            }
        }
        let lhs = gen2_expr(node.left)
        let rhs = gen2_expr(node.right)
        if op == "+" {
            return pad + lhs + " = hexa_add(" + lhs + ", " + rhs + ");\n"
        }
        if op == "-" {
            return pad + lhs + " = hexa_sub(" + lhs + ", " + rhs + ");\n"
        }
        if op == "*" {
            return pad + lhs + " = hexa_mul(" + lhs + ", " + rhs + ");\n"
        }
        if op == "/" {
            return pad + lhs + " = hexa_div(" + lhs + ", " + rhs + ");\n"
        }
        if op == "%" {
            return pad + lhs + " = hexa_mod(" + lhs + ", " + rhs + ");\n"
        }
        // r14-MMMM: `**=` `<<=` `>>=` `|=` `&=` `^=` mirror the BinaryOp
        // emit shapes (codegen.hexa:4574-4580) — runtime helpers reused.
        if op == "**" {
            return pad + lhs + " = hexa_pow(" + lhs + ", " + rhs + ");\n"
        }
        if op == "<<" {
            return pad + lhs + " = " + _bitop_guarded("<<", lhs, rhs) + ";\n"
        }
        if op == ">>" {
            return pad + lhs + " = " + _bitop_guarded(">>", lhs, rhs) + ";\n"
        }
        if op == "|" {
            return pad + lhs + " = " + _bitop_guarded("|", lhs, rhs) + ";\n"
        }
        if op == "&" {
            return pad + lhs + " = " + _bitop_guarded("&", lhs, rhs) + ";\n"
        }
        if op == "^" {
            return pad + lhs + " = " + _bitop_guarded("^", lhs, rhs) + ";\n"
        }
        return pad + "/* compound " + op + " */\n"
    }

    // `x ??= y` / `x ||= y` / `x &&= y` — parser emits separate LogicalAssign
    // kind with op_str keeping trailing `=` ("??="/"||="/"&&="). Prior to
    // this branch AOT hit "unhandled stmt kind: LogicalAssign" — invisible
    // silent exit. Rare in current codebase but must not crash.
    if k == "LogicalAssign" {
        let op = node.op
        // closure mut-capture: boxed `let mut` Ident LHS — read derefs cell,
        // write goes through hexa_array_set. See _gen2_boxed_cells.
        if type_of(node.left) != "string" && node.left.kind == "Ident" && _gen2_is_boxed_cell(node.left.name) {
            let _cn = _hexa_mangle_ident(node.left.name)
            let _rd = "hexa_array_get(" + _cn + ", 0)"
            let _rhs = gen2_expr(node.right)
            let mut _nv = ""
            if op == "??=" { _nv = "hexa_null_coal(" + _rd + ", " + _rhs + ")" }
            else if op == "||=" { _nv = "(hexa_truthy(" + _rd + ") ? " + _rd + " : " + _rhs + ")" }
            else if op == "&&=" { _nv = "(hexa_truthy(" + _rd + ") ? " + _rhs + " : " + _rd + ")" }
            else { return pad + "/* logical " + op + " (boxed) */\n" }
            return pad + _cn + " = hexa_array_set(" + _cn + ", 0, " + _nv + ");\n"
        }
        let lhs = gen2_expr(node.left)
        let rhs = gen2_expr(node.right)
        if op == "??=" {
            return pad + lhs + " = hexa_null_coal(" + lhs + ", " + rhs + ");\n"
        }
        if op == "||=" {
            return pad + lhs + " = (hexa_truthy(" + lhs + ") ? " + lhs + " : " + rhs + ");\n"
        }
        if op == "&&=" {
            return pad + lhs + " = (hexa_truthy(" + lhs + ") ? " + rhs + " : " + lhs + ");\n"
        }
        return pad + "/* logical " + op + " */\n"
    }

    if k == "ReturnStmt" {
        // bt-void-return (2026-05-24): `return void` / `return none` / `return nil`
        // emit the void literal DIRECTLY without routing the bare-reserved-value
        // Ident through gen2_expr. The recursive gen2_expr call could return a
        // value-arena string whose backing buffer had been reclaimed from a
        // prior function's last index-tail expression (e.g. `let k = ks[i]` in a
        // while loop), leaking `hexa_index_get(ks, i)` into the void return with
        // `ks`/`i` undeclared in the current C scope. Short-circuiting the
        // reserved void/none/nil names is both a correctness guard and a tiny
        // codegen fast-path. Repro: archive/patches/hexa-return-void-mistranslate-
        // 2026-05-24.md + pool-hexa-transpiler-ks-undeclared-2026-05-24.md.
        let _ret_is_void = type_of(node.left) != "string" && node.left.kind == "Ident" && (node.left.name == "void" || node.left.name == "none" || node.left.name == "nil")
        // Plan B Phase 3: when this fn registered at least one defer,
        // route through __fn_exit so the drain + arena return run in
        // order. Non-defer fns keep the original zero-overhead path.
        if _gen2_defer_flag_count > 0 {
            if type_of(node.left) != "string" && !_ret_is_void {
                return pad + "__ret_val = " + gen2_expr(node.left) + "; goto __fn_exit;\n"
            }
            return pad + "__ret_val = hexa_void(); goto __fn_exit;\n"
        }
        if type_of(node.left) != "string" && !_ret_is_void {
            if _gen2_arena_wrap == 1 {
                return pad + "return __hexa_fn_arena_return(" + gen2_expr(node.left) + ");\n"
            }
            return pad + "return " + gen2_expr(node.left) + ";\n"
        }
        if _gen2_arena_wrap == 1 {
            return pad + "return __hexa_fn_arena_return(hexa_void());\n"
        }
        return pad + "return hexa_void();\n"
    }

    // Plan B Phase 3: defer { body } — queue cleanup onto the fn's
    // defer list and set the runtime activation flag. Emission only
    // flips the flag to 1; the actual body is emitted by gen2_fn_decl
    // at the __fn_exit drain site. Dynamic semantics preserved: if a
    // defer stmt is never reached (early return before it), its flag
    // stays 0 and the body doesn't execute — matches the interp
    // interpreter's defer_stack.push behavior.
    if k == "DeferStmt" {
        let flag_id = _gen2_defer_flag_count
        _gen2_defer_flag_count = _gen2_defer_flag_count + 1
        _gen2_defer_bodies.push([flag_id, node.body])
        return pad + "__defer_" + to_string(flag_id) + "_active = 1;\n"
    }

    // `spawn { body }` — single-threaded eval semantics (matches interp,
    // self/hexa_full.hexa line 8763). Emit as `{ ... }` so local `let`
    // declarations stay scoped per C semantics.
    // (KEYWORD_DEMOTE Phase 1: ScopeStmt branch removed — `scope` keyword
    // had 0/0 block-form usage; the construct was dead weight.)
    if k == "SpawnStmt" {
        let mut chunks = []
        chunks.push(pad + "{\n")
        if type_of(node.body) == "array" {
            let mut si = 0
            while si < len(node.body) {
                chunks.push(gen2_stmt(node.body[si], depth + 1))
                si = si + 1
            }
        }
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return "" }
        if expr.kind == "MatchExpr" {
            return gen2_match_stmt(expr, depth)
        }
        // PROBE r14-VV: IfLetExpr at stmt position → desugar to MatchExpr + route through gen2_match_stmt.
        if expr.kind == "IfLetExpr" {
            return gen2_match_stmt(_gen2_iflet_to_match(expr), depth)
        }
        if expr.kind == "IfExpr" {
            // PROBE r11 B4: comptime-fold the condition.  `if false { … }` at
            // statement position now drops the dead branch entirely instead of
            // emitting `if (hexa_truthy(hexa_bool(0))) { … }` which clang would
            // also remove but with -Wunused noise.  Mirrors the IfExpr fold
            // at L7475 (expression context).
            let _cond_fold = comptime_eval(expr.cond)
            if type_of(_cond_fold) != "string" && _cond_fold.kind == "BoolLit" {
                let mut _live = expr.then_body
                if _cond_fold.value == "false" || _cond_fold.value == "0" {
                    _live = expr.else_body
                }
                if type_of(_live) == "string" || len(_live) == 0 {
                    return ""
                }
                let mut _dchunks = []
                let mut _di = 0
                while _di < len(_live) {
                    _dchunks.push(gen2_stmt(_live[_di], depth))
                    _di = _di + 1
                }
                return _dchunks.join("")
            }
            let mut chunks = []
            chunks.push(pad + "if (hexa_truthy(" + gen2_expr(expr.cond) + ")) {\n")
            let mut ti = 0
            while ti < len(expr.then_body) {
                chunks.push(gen2_stmt(expr.then_body[ti], depth + 1))
                ti = ti + 1
            }
            chunks.push(pad + "}")
            if type_of(expr.else_body) != "string" && len(expr.else_body) > 0 {
                chunks.push(" else {\n")
                let mut ei = 0
                while ei < len(expr.else_body) {
                    chunks.push(gen2_stmt(expr.else_body[ei], depth + 1))
                    ei = ei + 1
                }
                chunks.push(pad + "}")
            }
            chunks.push("\n")
            return chunks.join("")
        }
        return pad + gen2_expr(expr) + ";\n"
    }

    if k == "WhileStmt" {
        let mut chunks = []
        // C2 (while-cond specialize): when the condition is a comparison
        // expression, emit a direct C boolean instead of wrapping through
        // hexa_truthy(hexa_cmp_*(...)) — saves tag-check + unbox per iteration.
        let cond_c = _gen2_while_cond(node.cond)
        chunks.push(pad + "while (" + cond_c + ") {\n")
        let mut wi = 0
        while wi < len(node.body) {
            chunks.push(gen2_stmt(node.body[wi], depth + 1))
            wi = wi + 1
        }
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    if k == "ForStmt" {
        let iter = node.iter_expr
        if type_of(iter) != "string" && iter.kind == "Range" {
            // C1 (native-int specialize): boxed-HexaVal counter escape.
            // Pre-C1: end bound re-evaluated via hexa_as_num() per step and
            //   counter incremented through HexaVal (.i++ on struct).
            // Post-C1: native int64_t counter + pre-computed end bound. Body
            //   still sees HexaVal <name> — materialized once per iteration
            //   from the native counter — so semantics are unchanged. Any
            //   user assignment inside the body rebinds the HexaVal alias
            //   for that iteration, matching previous observable behavior.
            let s = gen2_expr(iter.left)
            let e = gen2_expr(iter.right)
            let pad2 = gen2_indent(depth + 1)
            let mut chunks = []
            // Scoped block ensures __hx_ne_<name> is fresh per loop nest and
            // avoids identifier collisions when the same counter name reappears
            // in a sibling loop at the same depth.
            chunks.push(pad + "{\n")
            // C2: known-int end bound → HX_INT() skips hexa_as_num tag-check
            let _ei = _is_known_int(iter.right)
            let mut e_extract = "HX_INT(" + e + ")"
            if !_ei { e_extract = "hexa_as_num(" + e + ")" }
            chunks.push(pad2 + "int64_t __hx_ne_" + node.name + " = " + e_extract + ";\n")
            // Inclusive range `for i in a..=b` must iterate through b.
            // The fast-path always emitted `<` (exclusive) regardless of
            // the range kind → off-by-one (parity gap t42_for_in_range:
            // `0..=5` summed to 10 not 15). `.value == "inclusive"` is
            // the same marker the expr-position range uses (codegen
            // L5222). Use `<=` for the inclusive form.
            let mut __rcmp = " < "
            if iter.value == "inclusive" { __rcmp = " <= " }
            chunks.push(pad2 + "for (int64_t __hx_ni_" + node.name + " = HX_INT(" + s + "); __hx_ni_" + node.name + __rcmp + "__hx_ne_" + node.name + "; __hx_ni_" + node.name + "++) {\n")
            let pad3 = gen2_indent(depth + 2)
            chunks.push(pad3 + "HexaVal " + node.name + " = hexa_int(__hx_ni_" + node.name + ");\n")
            // C3 (for-range known-int): the counter is provably TAG_INT every
            // iteration — register it so BinOp/CmpOp inside the body emit
            // HX_INT() fast-path instead of hexa_as_num() tag dispatch.
            _known_int_add(node.name)
            // PROBE r15-F-FOLD: the loop var is a fresh loop-scope binding that
            // shadows any enclosing same-name `let i = <lit>`. That enclosing
            // immutable let registered a comptime-const fold (PROBE r11 B3), so
            // every read of `i` in the body would inline the STALE literal
            // instead of the live counter `hexa_int(__hx_ni_i)`
            // (`let i=100; for i in 0..3 { to_string(i) }` printed 100/100/100).
            // Kill the stale fold (D18 re-`let` invalidate pattern) before
            // emitting the body, and scope-mark/restore around the body so any
            // fold introduced inside the loop doesn't leak out and the enclosing
            // state is rebuilt after the loop (D17 block-scope pattern).
            _invalidate_comptime_const(node.name)
            let _cc_mark = _comptime_const_scope_mark()
            // ── UNSHADOW item C: proof-carrying bounds-elision ──────────────
            // Establish an in-range fact for `arr[i]` reads in this body iff:
            //   (1) exclusive range  →  i < end  (inclusive `..=` voids it)
            //   (2) lower bound is the literal 0  →  i >= 0
            //   (3) upper bound is exactly `len(arr)` / `arr.len()` for a bare
            //       Ident `arr`  →  end == arr.len, so i < arr.len
            //   (4) `arr` is never resized/reassigned/aliased in the body, AND
            //       the index var `i` is never reassigned (the elided read uses
            //       the hidden native counter, which the body cannot touch).
            // Then for the EXACT read `arr[i]`, 0 <= counter < arr.len holds by
            // construction of the C for-loop, so the runtime bounds check (and
            // its hexa_throw arm) is provably dead and may be elided. The fact
            // is popped at loop exit (LOCAL + EXACT — fold-shadow family safe).
            let mut _ir_pushed = false
            if iter.value != "inclusive" && _node_is_int_zero(iter.left) {
                let _ir_arr = _len_call_target_ident(iter.right)
                if _ir_arr != "" {
                    if !_name_resized_in_body(node.body, _ir_arr) {
                        if !_name_resized_in_body(node.body, node.name) {
                            _inrange_push(node.name, _ir_arr, "__hx_ni_" + node.name)
                            _ir_pushed = true
                        }
                    }
                }
            }
            let mut fi = 0
            while fi < len(node.body) {
                chunks.push(gen2_stmt(node.body[fi], depth + 2))
                fi = fi + 1
            }
            if _ir_pushed { _inrange_pop() }
            _comptime_const_scope_restore(_cc_mark)
            chunks.push(pad2 + "}\n")
            chunks.push(pad + "}\n")
            return chunks.join("")
        }
        // General for-in: iterate over array or map (map → keys, Python-style).
        // hexa_iter_get dispatches on tag at runtime so both work without codegen knowing the type.
        let iter_c = gen2_expr(iter)
        let mut chunks = []
        chunks.push(pad + "{\n")
        let pad2 = gen2_indent(depth + 1)
        chunks.push(pad2 + "HexaVal __iter_arr = " + iter_c + ";\n")
        chunks.push(pad2 + "int __iter_len = hexa_len(__iter_arr);\n")
        chunks.push(pad2 + "for (int __fi = 0; __fi < __iter_len; __fi++) {\n")
        let pad3 = gen2_indent(depth + 2)
        chunks.push(pad3 + "HexaVal " + node.name + " = hexa_iter_get(__iter_arr, __fi);\n")
        // PROBE r15-F-FOLD: same loop-var-shadow fold invalidation as the range
        // fast-path above — the element binding shadows any enclosing same-name
        // comptime-const `let`, so kill the stale fold and scope the body.
        _invalidate_comptime_const(node.name)
        let _cc_mark = _comptime_const_scope_mark()
        let mut fi = 0
        while fi < len(node.body) {
            chunks.push(gen2_stmt(node.body[fi], depth + 2))
            fi = fi + 1
        }
        _comptime_const_scope_restore(_cc_mark)
        chunks.push(pad2 + "}\n")
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // G43: for-in tuple destructuring — for (a, b) in pairs { body }
    if k == "ForDestructStmt" {
        let iter = node.iter_expr
        let iter_c = gen2_expr(iter)
        let destruct_names = node.params
        let num_names = len(destruct_names)
        let mut chunks = []
        chunks.push(pad + "{\n")
        let pad2 = gen2_indent(depth + 1)
        chunks.push(pad2 + "HexaVal __iter_arr = " + iter_c + ";\n")
        chunks.push(pad2 + "int __iter_len = hexa_len(__iter_arr);\n")
        chunks.push(pad2 + "for (int __fi = 0; __fi < __iter_len; __fi++) {\n")
        let pad3 = gen2_indent(depth + 2)
        chunks.push(pad3 + "HexaVal __iter_elem = hexa_iter_get(__iter_arr, __fi);\n")
        let mut di = 0
        while di < num_names {
            let vname = _hexa_mangle_ident(destruct_names[di])
            chunks.push(pad3 + "HexaVal " + vname + " = hexa_index_get(__iter_elem, hexa_int(" + to_string(di) + "));\n")
            // PROBE r15-F-FOLD: each destructured loop-var shadows any enclosing
            // same-name comptime-const `let` — invalidate per bound name. Uses
            // the raw destructure name (the fold table is keyed by the source
            // name, not the mangled C identifier).
            _invalidate_comptime_const(destruct_names[di])
            di = di + 1
        }
        // PROBE r15-F-FOLD: scope the body so folds introduced inside the loop
        // don't leak past it (D17 block-scope pattern).
        let _cc_mark = _comptime_const_scope_mark()
        let mut fi = 0
        while fi < len(node.body) {
            chunks.push(gen2_stmt(node.body[fi], depth + 2))
            fi = fi + 1
        }
        _comptime_const_scope_restore(_cc_mark)
        chunks.push(pad2 + "}\n")
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    if k == "BreakStmt" {
        return pad + "break;\n"
    }

    if k == "ContinueStmt" {
        return pad + "continue;\n"
    }

    if k == "AssertStmt" {
        return pad + "if (!hexa_truthy(" + gen2_expr(node.left) + ")) { fprintf(stderr, \"assertion failed\\n\"); exit(1); }\n"
    }

    if k == "ThrowStmt" {
        if type_of(node.left) != "string" {
            return pad + "hexa_throw(" + gen2_expr(node.left) + ");\n"
        }
        return pad + "hexa_throw(hexa_str(\"error\"));\n"
    }

    if k == "TryCatchStmt" || k == "TryCatch" {
        // Parser stores: left=try_body, right=catch_body, name=catch_var
        //
        // ARM64 hang fix (2026-04-16): use __attribute__((cleanup)) so
        // __hexa_try_top is restored on ANY scope exit — including `return`
        // inside the try body. Without this, `return` skipped __hexa_try_pop()
        // leaving a stale jmp_buf pointer on the try stack; a subsequent
        // hexa_throw would longjmp to freed stack memory → infinite loop on
        // Mac ARM64 (e.g., nt5_test_p2_5_error_handling retry() success path).
        let try_body = node.left
        let catch_body = node.right
        let catch_var = node.name
        let mut chunks = []
        chunks.push(pad + "{\n")
        let pad2 = gen2_indent(depth + 1)
        chunks.push(pad2 + "int __try_saved __attribute__((cleanup(__hexa_try_cleanup))) = __hexa_try_top; (void)__try_saved;\n")
        chunks.push(pad2 + "jmp_buf __jb; HexaVal __err = hexa_void();\n")
        chunks.push(pad2 + "if (setjmp(__jb) == 0) {\n")
        chunks.push(pad2 + "    __hexa_try_push(&__jb);\n")
        if type_of(try_body) != "string" {
            let mut ti = 0
            while ti < len(try_body) {
                chunks.push(gen2_stmt(try_body[ti], depth + 2))
                ti = ti + 1
            }
        }
        chunks.push(pad2 + "} else {\n")
        chunks.push(pad2 + "    __err = __hexa_last_error();\n")
        if catch_var != "" && catch_var != "_" {
            chunks.push(pad2 + "    HexaVal " + catch_var + " = __err;\n")
        }
        if type_of(catch_body) != "string" {
            let mut ci = 0
            while ci < len(catch_body) {
                chunks.push(gen2_stmt(catch_body[ci], depth + 2))
                ci = ci + 1
            }
        }
        chunks.push(pad2 + "}\n")
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // ── RecoverStmt → try-with-swallow-catch (failure isolation) ──
    // `recover |err| { body }` runs body; if a throw/panic occurs the
    // recover block is exited and execution continues after it (the
    // failure is isolated, not propagated) with `err` bound to the
    // error. That is exactly TryCatch with an EMPTY catch body, so it
    // reuses the same proven setjmp/longjmp + __hexa_try machinery.
    // node.left = body, node.name = catch_var.
    if k == "RecoverStmt" {
        let r_body = node.left
        let r_var = node.name
        let mut rc = []
        rc.push(pad + "{\n")
        let rpad = gen2_indent(depth + 1)
        rc.push(rpad + "int __try_saved __attribute__((cleanup(__hexa_try_cleanup))) = __hexa_try_top; (void)__try_saved;\n")
        rc.push(rpad + "jmp_buf __jb; HexaVal __err = hexa_void();\n")
        rc.push(rpad + "if (setjmp(__jb) == 0) {\n")
        rc.push(rpad + "    __hexa_try_push(&__jb);\n")
        if type_of(r_body) != "string" {
            let mut rbi = 0
            while rbi < len(r_body) {
                rc.push(gen2_stmt(r_body[rbi], depth + 2))
                rbi = rbi + 1
            }
        }
        rc.push(rpad + "} else {\n")
        rc.push(rpad + "    __err = __hexa_last_error(); (void)__err;\n")
        if r_var != "" && r_var != "_" {
            rc.push(rpad + "    HexaVal " + r_var + " = __err; (void)" + r_var + ";\n")
        }
        // empty catch — failure isolated/swallowed, fall through
        rc.push(rpad + "}\n")
        rc.push(pad + "}\n")
        return rc.join("")
    }

    // ── HandleWithStmt → emit the handled body as a scoped block ──
    // `handle { body } with { op() => … }` is an effect handler. Effect
    // dispatch only matters if some code `perform`s an effect — and a
    // repo-wide scan shows `perform`/`resume` have ZERO usage, so no
    // effect is ever triggered: the handler arms are dead and the
    // construct is exactly "run body". Lowering to the body block is
    // therefore correct for the codebase as it stands (not a stub).
    // node.body = handled block, node.items = handler arms (unused while
    // `perform` is unused). LIMITATION: if `perform`/`resume` are ever
    // implemented, real handler-dispatch codegen must replace this — see
    // the HandleWithStmt RFC note.
    if k == "HandleWithStmt" {
        let h_body = node.body
        let mut hc = []
        hc.push(pad + "{\n")
        if type_of(h_body) != "string" {
            let mut hbi = 0
            while hbi < len(h_body) {
                hc.push(gen2_stmt(h_body[hbi], depth + 1))
                hbi = hbi + 1
            }
        }
        hc.push(pad + "}\n")
        return hc.join("")
    }

    // ── YieldStmt → evaluate the yielded expr for side effects ──
    // `yield x` suspends a generator and hands `x` to a driving loop.
    // hexa has NO generator / coroutine construct in the grammar (no
    // `gen fn`, no Generator type) and a repo-wide scan shows zero
    // statement-form `yield` reached at runtime: the only definition
    // (`fn gen_vals(){ yield 10 }` in the keyword-audit) is never
    // called. With no generator drive, `yield e` is exactly "evaluate
    // e (side effects) and fall through" — correct for the codebase as
    // it stands (not a stub). LIMITATION: if a generator / coroutine
    // construct is ever added, real suspend/resume codegen must replace
    // this — see the generator RFC note.
    if k == "YieldStmt" {
        if type_of(node.left) != "string" {
            return pad + "(void)(" + gen2_expr(node.left) + ");\n"
        }
        return pad + ";\n"
    }

    // ── Match statement (MatchExpr used as statement) ────────
    if k == "MatchExpr" {
        return gen2_match_stmt(node, depth)
    }

    // ── LoopStmt → while(1) { body } ──────────────────────
    if k == "LoopStmt" {
        let mut chunks = []
        chunks.push(pad + "while (1) {\n")
        let mut li = 0
        while li < len(node.body) {
            chunks.push(gen2_stmt(node.body[li], depth + 1))
            li = li + 1
        }
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // ── WhileLetStmt → loop + match desugar (SS-3) ────────
    // `while let PAT = EXPR { body }` is the canonical pattern-binding loop.
    // It lowers to the Rust-standard form
    //   loop { match EXPR { PAT => { body }, _ => break } }
    // reusing the existing match codegen (gen2_match_stmt) so all the
    // pattern + payload-binding machinery (EnumPath, wildcard, single-field
    // payload binders) is shared with `match` — no new pattern infra. The
    // scrutinee EXPR is re-evaluated each iteration (the loop semantics), and
    // a non-matching value falls into the synthetic `_ => break` arm and
    // exits the loop. node.left = pattern, node.right = scrutinee.
    if k == "WhileLetStmt" {
        // Synthetic wildcard pattern for the fall-through break arm.
        let _wild = #{
            "kind": "Wildcard", "name": "_", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        // `break;` statement for the non-matching arm body.
        let _break_stmt = #{
            "kind": "BreakStmt", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        // Arm 0: PAT => { body } (carries the pattern + loop body).
        let _arm_match = #{
            "kind": "MatchArm", "name": "", "value": "", "op": "",
            "left": node.left, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": node.body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        // Arm 1: _ => { break }
        let _arm_break = #{
            "kind": "MatchArm", "name": "", "value": "", "op": "",
            "left": _wild, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": [_break_stmt], "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        let _match_node = #{
            "kind": "MatchExpr", "name": "", "value": "", "op": "",
            "left": node.right, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": [_arm_match, _arm_break], "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        let mut chunks = []
        chunks.push(pad + "while (1) {\n")
        chunks.push(gen2_match_stmt(_match_node, depth + 1))
        chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // (KEYWORD_DEMOTE Phase 1: GuardStmt + GuardLetStmt removed — `guard`
    // keyword had 0/0 block-form usage; `if !cond { ... }` covers the same
    // pattern. Identifier uses like `guard = guard + 1` now just work.)

    // ── T3: InvariantDecl — @invariant DSL (codegen no-op) ───
    // Static analysis only, performed by self/invariant_check.hexa.
    // Both top-level dispatcher (line 123) and nested gen2_stmt fall through
    // to here on rare cases (e.g. invariant inside impl block bodies).
    if k == "InvariantDecl" {
        return ""
    }

    // ── ComptimeConst → fold to literal at codegen, or fall back to runtime const ──
    // When ComptimeConst appears inside a function body (gen2_stmt path), we
    // still try to fold. On success: register in module-level lookup table
    // (so any reference inside or after this body inlines the literal) and
    // emit nothing (the C const is unused — the literal is inlined at call
    // sites). On failure: emit a local C variable as before.
    if k == "ComptimeConst" {
        let _cc_local = comptime_eval(node.left)
        if type_of(_cc_local) != "string" {
            _register_comptime_const(node.name, _cc_local)
            return ""
        }
        return pad + "HexaVal " + node.name + " = " + gen2_expr(node.left) + ";\n"
    }

    // ── ComptimeBlock (statement position) → emit nothing ──
    // `comptime { ... }` in statement position (no binding) is a
    // compile-time-only block: `comptime` means "evaluate at compile
    // time, emit no runtime code". With no binding the block produces
    // no runtime-observable result — any escaping value would require a
    // binding, which makes it the EXPRESSION form (`let x = comptime
    // { e }`), handled separately by the comptime_eval const-fold path
    // (regression T26) and deliberately untouched here. Emitting nothing
    // is the semantically correct lowering, matching the established
    // compile-time/declaration-only precedent (ComptimeConst-folded,
    // TypeAlias, EffectDecl, InvariantDecl below).
    // LIMITATION: a full compile-time evaluator that lets bindings
    // declared inside a statement-position `comptime { let x = … }`
    // escape into the enclosing scope is not modeled — comptime_eval is
    // const-fold-only. No corpus usage relies on that (keyword-audit's
    // `comptime { let ct = 10 }` is dead; example/test_comptime.hexa
    // exercises only the value-producing expression form).
    if k == "ComptimeBlock" {
        return ""
    }

    // ── MacroDef → emit nothing (declaration-only) ──
    // `macro! name { (pat) => { body }, … }` is a compile-time macro
    // *definition* — pure metadata, never runtime code, exactly like a
    // type/trait/effect declaration. Macro expansion (if/when wired) is
    // an upstream pre-codegen concern keyed off invocation sites, not
    // the definition node; the definition itself lowers to nothing.
    // LIMITATION: hexa codegen has no macro expander — an invoked macro
    // is a separate gap (no corpus macro is invoked through this path;
    // example/test_macros.hexa only defines them). Documented, not faked.
    if k == "MacroDef" {
        return ""
    }

    // (KEYWORD_DEMOTE Phase 2: OptimizeFnStmt removed — `optimize` keyword
    // demoted to `@optimize` attribute. @-prefixed attrs ride the existing
    // annotation channel and don't produce dedicated AST nodes.)

    // ── Ownership-group statements → no-op (SPEC §11 v1).
    //    DropStmt · OwnStmt · BorrowStmt · MoveStmt are
    //    declarations of intent in the v1 arena memory model;
    //    runtime semantics are reserved for v2 borrow checker.
    //    Parser surface lands here, codegen emits nothing — the
    //    var is unchanged and remains valid through the rest of
    //    the scope (arena owns lifetime).
    if k == "DropStmt" || k == "OwnStmt" || k == "BorrowStmt" || k == "MoveStmt" {
        return ""
    }

    // Nested FnDecl / PureFnDecl / StructDecl / ExternFnDecl in a fn body
    // — already hoisted to module scope by _gen2_lift_nested_decls at the
    // codegen_full entry. Skip inline emission (the module-scope
    // emission is the only one needed; emitting an inline stub here
    // would either redefine the symbol or fire the unhandled-kind error
    // at runtime). Deeper-nested cases (decls inside if/while/for) are
    // not yet covered by the shallow lift; they'd still hit the loud
    // error below since they wouldn't appear in the shallow walk's
    // top-of-body iteration.
    // 2026-05-19 keyword-audit gap "ExternFnDecl in statement position":
    // ExternFnDecl added here so a stmt-position `extern fn` (lifted to
    // module scope by _gen2_lift_nested_decls) does not ALSO emit a
    // `CODEGEN ERROR: unhandled stmt kind: ExternFnDecl` stub at its
    // original nested site. A top-level / script-body ExternFnDecl never
    // reaches gen2_stmt (it hits the top-level emit loop's ExternFnDecl
    // branch directly), so this only matters for the fn-body-nested case.
    if k == "FnDecl" || k == "PureFnDecl" || k == "StructDecl" || k == "ExternFnDecl" {
        return ""
    }

    // ── EffectDecl → skip (declaration only) ──
    // `effect Name { fn op(...) -> T ... }` declares effect-operation
    // signatures — a type-level construct with no runtime code, like a
    // trait/interface declaration. Emit nothing (effect handlers / perform,
    // if hexa gains them, would carry their own codegen).
    if k == "EffectDecl" {
        return ""
    }

    // ── Proof / Theorem / Contract / Invariant family → skip ──
    // These are verification-annotation statement forms (proof blocks,
    // theorem declarations, contract asserts, invariant statements). Like
    // InvariantDecl above, they carry only type-level / verification-side
    // semantics — no runtime code. The verifier consumes them; codegen
    // emits nothing. ContractAssert at runtime is a deliberate no-op for
    // now (the contract checker is a separate pass).
    if k == "ProofStmt" || k == "TheoremStmt" || k == "ContractAssert" || k == "Invariant" {
        return ""
    }

    // ── TypeAlias → skip (type-system only) ──
    // `type X = Y` is a type-system declaration; C has no direct analogue
    // (no `typedef HexaVal X` is needed since everything is HexaVal at
    // runtime), so emit nothing.
    if k == "TypeAlias" {
        return ""
    }

    // ── UseStmt → skip (already resolved by flatten step) ──
    // `use "mod.hexa"` directives are processed by module_loader's flatten
    // pass before transpile; any UseStmt reaching codegen is leftover and
    // should be a no-op.
    if k == "UseStmt" {
        return ""
    }

    // ── PanicStmt → print message to stderr + exit(1) ──
    // `panic(msg)` is unrecoverable termination. node.left = the message
    // expr. Mirrors the `eprintln` → hexa_eprint_val mapping then exits.
    if k == "PanicStmt" {
        let mut _pmsg = "hexa_str(\"panic\")"
        if type_of(node.left) != "string" {
            _pmsg = gen2_expr(node.left)
        }
        return pad + "{ hexa_eprint_val(hexa_str(\"panic: \")); hexa_eprint_val(" + _pmsg + "); hexa_eprint_val(hexa_str(\"\\n\")); exit(1); }\n"
    }

    // ── DropStmt → no-op ──
    // `drop x` is an explicit-drop hint. hexa's value model is arena/GC-
    // backed (no per-value C destructor), so an explicit drop carries no
    // codegen — the value simply isn't referenced afterward.
    if k == "DropStmt" {
        return ""
    }

    // ── KEYWORD_DEMOTE Phase 3 follow-up: @-attribute declarative AST kinds ──
    // VerifyStmt   ← @verify "NAME" { … }   (compile-time assertion block)
    // IntentStmt   ← @intent "NAME" { … }   (design-intent annotation)
    // GenerateFnStmt / GenerateStmt ← @generate … { "desc" }  (codegen hint)
    // DeriveDecl   ← @derive_meta(Trait, …) for Type   (declarative-meta-only)
    //                (also accepts legacy @derive(...) with parser-side
    //                 deprecation hint — PROBE r9 #7, 2026-05-23)
    //
    // These are all declaration-flavored: the parser produces an AST node so
    // future static-analysis passes can read them, but they emit no runtime
    // code (same rationale as EffectDecl above). Without these skips the
    // unhandled-kind branch below would fire and inject a runtime exit(1).
    //
    // DeriveDecl SPECIFIC HONESTY NOTE (PROBE r9 #7):
    //   hexa does NOT implement trait derivation. The AST node is preserved
    //   for downstream meta-passes (lint / doc / future codegen) but emits
    //   ZERO C code. Users wanting struct-printing should rely on the
    //   runtime's existing _hexa_to_string_rec TAG_VALSTRUCT field-by-field
    //   path (println(struct_value) works today via that path). A real
    //   Path B Display emitter is sketched in archive/patches/derive-meta-
    //   vs-derive-real-impl.md (deferred — needs runtime tag→fn table).
    if k == "VerifyStmt" { return "" }
    if k == "IntentStmt" { return "" }
    if k == "GenerateFnStmt" { return "" }
    if k == "GenerateStmt"   { return "" }
    if k == "DeriveDecl"     { return "" }  // no-op by design — see honesty note above

    // ── DestructLetStmt → array-positional destructure (PROBE r7) ──
    //   let [a, b, ...rest] = expr
    // AST: params = [a, b], name = rest_name ("" if none), left = rhs
    // Names are flat-hoisted by `_gen2_collect_lets_stmt` (mirrors LetStmt).
    // Emits a single tmp + per-name assignment so the rhs is evaluated once.
    if k == "DestructLetStmt" {
        // PROBE r16: the binders (a, b, …, rest) must be DECLARED — earlier
        // code emitted bare `name = …;` assignments inside a `{ }` block,
        // relying on the fn-top flat-hoist. But that hoist only declares a name
        // when it occurs >1× (the shadow case); a single-occurrence destructure
        // binder got no declaration anywhere → clang "use of undeclared
        // identifier". Fix: emit a `HexaVal <mangled> = …;` declaration at THIS
        // site (no enclosing `{ }`, so the binders escape to the enclosing
        // block, exactly like a plain `let`). When a binder was already hoisted
        // (`_gen2_has_decl`), emit a plain assignment to avoid a C redefinition.
        // `_` binders are skipped (declare + assign nothing). The rhs is bound
        // to a single `__destr_N` temp so it evaluates exactly once.
        let _dtmp = "__destr_" + to_string(_destr_counter)
        _destr_counter = _destr_counter + 1
        let _drhs = gen2_expr(node.left)
        let mut _dout = pad + "HexaVal " + _dtmp + " = " + _drhs + ";"
        let mut _di = 0
        while _di < len(node.params) {
            let _dn = node.params[_di]
            if _dn != "_" {
                let _dmn = _hexa_mangle_ident(_dn)
                let _drhs_i = "hexa_array_get(" + _dtmp + ", " + to_string(_di) + ");"
                if _gen2_has_decl(_dn) {
                    _dout = _dout + " " + _dmn + " = " + _drhs_i
                } else {
                    _dout = _dout + " HexaVal " + _dmn + " = " + _drhs_i
                    _gen2_declared_names.push(_dn)
                }
            }
            _di = _di + 1
        }
        if type_of(node.name) == "string" && node.name != "" && node.name != "_" {
            let _rmn = _hexa_mangle_ident(node.name)
            // rest: hexa_array_drop wants a HexaVal count, not a raw C int.
            let _rrhs = "hexa_array_drop(" + _dtmp + ", hexa_int(" + to_string(len(node.params)) + "));"
            if _gen2_has_decl(node.name) {
                _dout = _dout + " " + _rmn + " = " + _rrhs
            } else {
                _dout = _dout + " HexaVal " + _rmn + " = " + _rrhs
                _gen2_declared_names.push(node.name)
            }
        }
        return _dout + "\n"
    }

    // ── MapDestructLetStmt → map/dict-key destructure (PROBE r7) ──
    //   let {x, y} = map           → key=x bound to var x, key=y bound to var y
    //   let {x: px, y: py} = map   → key=x bound to var px, key=y bound to var py
    // AST: params = [target names], fields = [source keys], left = rhs.
    // No-rename form (shorthand) carries fields[i] == params[i]; rename form
    // (PROBE r14-PPP, UU follow-up) carries the source key in fields[i].
    // Back-compat: if `fields` is missing or length-mismatched (older AST),
    // fall back to params[i] as the key (no rename).
    if k == "MapDestructLetStmt" {
        // PROBE r16: same undeclared-binder fix as DestructLetStmt above —
        // declare `HexaVal <mangled> = …;` at this site (escaping the enclosing
        // block) instead of a bare assignment trapped inside `{ }`. Already-
        // hoisted names get a plain assignment; `_` binders are skipped.
        let _mtmp = "__destr_" + to_string(_destr_counter)
        _destr_counter = _destr_counter + 1
        let _mrhs = gen2_expr(node.left)
        let mut _mout = pad + "HexaVal " + _mtmp + " = " + _mrhs + ";"
        let _has_fields = type_of(node.fields) != "string" && len(node.fields) == len(node.params)
        let mut _mi = 0
        while _mi < len(node.params) {
            let _mtgt = node.params[_mi]
            let mut _mkey = _mtgt
            if _has_fields {
                _mkey = node.fields[_mi]
            }
            if _mtgt != "_" {
                let _mmn = _hexa_mangle_ident(_mtgt)
                let _mrhs_i = "hexa_map_get(" + _mtmp + ", \"" + _mkey + "\");"
                if _gen2_has_decl(_mtgt) {
                    _mout = _mout + " " + _mmn + " = " + _mrhs_i
                } else {
                    _mout = _mout + " HexaVal " + _mmn + " = " + _mrhs_i
                    _gen2_declared_names.push(_mtgt)
                }
            }
            _mi = _mi + 1
        }
        return _mout + "\n"
    }

    // Fail loud at TRANSPILE time — emitting an in-binary runtime trap
    // (`fprintf+exit(1)` C stub) buried the failure behind a clang compile
    // + a successful link.  An unhandled kind is a compiler-side gap; the
    // user should see it at `hexa run` / `hexa build` before clang runs.
    eprintln("[codegen_c2] ERROR: unhandled statement kind: " + k)
    exit(1)
}

fn c_escape(s) {
    // Escape special chars for C string literals
    // to_string() handles char type values from CharLit AST nodes
    // Must do backslash first to avoid double-escaping
    let mut out = to_string(s).replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out
}

// Builtin method dispatch used by user-impl fallback chain. `obj_expr` is
// an already-stringified C expression (typically a temp name like "__mr").
// Returns a C expression string. Mirrors the hardcoded method list in the
// Call-on-Field branch below. Kept in sync manually.
fn gen2_method_builtin(obj_expr, method, args) {
    if method == "push" {
        return "hexa_array_push(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    // FIX-A (Anima serving unblock, 2026-04-19): alias `.append(x)` to push.
    if method == "append" {
        return "hexa_array_push(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    if method == "len" {
        return "hexa_int(hexa_len(" + obj_expr + "))"
    }
    if method == "chars" {
        return cg_string_sym("str_chars") + "(" + obj_expr + ")"
    }
    // PROBE r14 (2026-05-23) — Rust canonical alias `.codepoints()` for `.chars()`.
