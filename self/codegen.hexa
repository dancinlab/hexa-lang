                if name == "farr32_zeros"   { return "hexa_farr32_zeros(" + a0 + ")" }
                if name == "farr32_free"    { return "hexa_farr32_free(" + a0 + ")" }
                // RFC 036: farr_int_array — 1-arg routes.
                if name == "farr_int_zeros" { return "hexa_farr_int_zeros(" + a0 + ")" }
                if name == "farr_int_len"   { return "hexa_farr_int_len("   + a0 + ")" }
                if name == "farr_int_copy"  { return "hexa_farr_int_copy("  + a0 + ")" }
                if name == "farr_int_sum"   { return "hexa_farr_int_sum("   + a0 + ")" }
                if name == "farr_int_free"  { return "hexa_farr_int_free("  + a0 + ")" }
                // RFC 033 (2026-05-12): farr_copy — explicit deep copy
