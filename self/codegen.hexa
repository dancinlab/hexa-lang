                return _hexa_mangle_ident(name) + "(" + arg_strs.join(", ") + ")"
            }
            // ── bt-66: free-fn call of a string-method builtin ──────────────
            // `contains(attrs, "memoize")` (bare ident) used to emit
            // `hexa_call2(contains, attrs, ...)` with `contains` undefined in C.
            // Rewrite to receiver-first builtin dispatch (args[0] = receiver).
            if len(node.args) >= 2 {
                if name == "contains" || name == "str_contains" {
                    return "hexa_bool(" + cg_string_sym("str_contains") + "(" + arg_strs[0] + ", " + arg_strs[1] + "))"
                }
                if name == "starts_with" {
                    return "hexa_bool(" + cg_string_sym("str_starts_with") + "(" + arg_strs[0] + ", " + arg_strs[1] + "))"
                }
                if name == "ends_with" {
                    return "hexa_bool(" + cg_string_sym("str_ends_with") + "(" + arg_strs[0] + ", " + arg_strs[1] + "))"
                }
                if name == "join" {
                    return cg_string_sym("str_join") + "(" + arg_strs[0] + ", " + arg_strs[1] + ")"
                }
            }
            // ── bt-71: libc / builtin family dispatch ───────────────────────
            // exit/sleep/tanh/sin/cos/log/input/is_error/read_lines/env_var/hex/
            // bin/from_char_code/delete_file/append_file/timestamp/base64_* →
            // route through typed hexa_<name> wrappers (see runtime.c).
            if len(node.args) == 0 {
                // roadmap 68 (M2): `now` is an interpreter-side alias for
                // `timestamp` (hexa_full.hexa:11366 `timestamp || now`). Mirror
                // the dispatch in AOT so removing the runtime.c `#define now
                // timestamp` shim is safe.
                if name == "timestamp" || name == "now" || name == "time_now" || name == "__builtin_time_now" { return "hexa_timestamp()" }
                // Wilson 2026-05-13 — expose hexa_time_ms (monotonic ms wall clock)
                // to user-side hexa. Filed at archive/patches/wilson-needs-time-now-ms-builtin.md.
                // Also intercept `__builtin_time_now_ms` so self/std_time.hexa's wrapper
                // body resolves (it expects the unmapped __builtin_ name).
                if name == "time_now_ms" || name == "now_ms" || name == "timestamp_ms" || name == "__builtin_time_now_ms" { return "hexa_time_ms()" }
                if name == "input"     { return "hexa_input(hexa_str(\"\"))" }
                // R7 track B cycle 10: `readline()` reads one stdin line.
                // Mirrors interp `input("")` (hexa_full.hexa L13737) — both
