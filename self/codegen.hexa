                "kind": "Call", "name": "", "value": "", "op": "",
                "left": _pr.left, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": _new_args, "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
