                return "hexa_tensor_from_ptr(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ", " + gen2_expr(node.args[2]) + ")"
            }
            // RFC r16 (named args): detect keyword arguments `f(y: 5, x: 1)`.
            // If any arg is a KwArg, reorder ALL args into the callee's
            // declared positional order and fill omitted params with defaults.
            // Keyword args require a registered plain FnDecl (param-name table);
            // a closure / unknown callee cannot be reordered → error.
            let mut _has_kwarg = false
            let mut _kwi = 0
            while _kwi < len(node.args) {
                let _ka = node.args[_kwi]
                if type_of(_ka) != "string" && _ka.kind == "KwArg" { _has_kwarg = true }
                _kwi = _kwi + 1
            }
            if _has_kwarg {
                if !_is_known_fn_global(name) || _fn_arity_lookup(name) < 0 {
                    eprintln("error: keyword arguments require a plain function with named parameters (call to `" + name + "`)")
                    exit(1)
                }
                let _kw_arity = _fn_arity_lookup(name)
                // slots[i] = emitted C expr for param i, "" = unfilled.
                let mut _slots = []
                let mut _si = 0
                while _si < _kw_arity { _slots.push(""); _si = _si + 1 }
                // Positional args fill leading slots; once a keyword is seen,
                // a later positional is a hexa-level error (Python rule).
                let mut _pos_i = 0
                let mut _seen_kw = false
                let mut _ari = 0
                while _ari < len(node.args) {
                    let _aa = node.args[_ari]
                    if type_of(_aa) != "string" && _aa.kind == "KwArg" {
                        _seen_kw = true
                        let _pidx = _fn_param_index(name, _aa.name)
                        if _pidx < 0 {
                            eprintln("error: function `" + name + "` has no parameter named `" + _aa.name + "`")
                            exit(1)
                        }
                        if _slots[_pidx] != "" {
                            eprintln("error: function `" + name + "` got multiple values for parameter `" + _aa.name + "`")
                            exit(1)
                        }
                        _slots[_pidx] = gen2_expr(_aa.left)
                    } else {
                        if _seen_kw {
                            eprintln("error: positional argument follows keyword argument in call to `" + name + "`")
                            exit(1)
                        }
                        if _pos_i >= _kw_arity {
                            eprintln("error: function `" + name + "` got too many positional arguments")
                            exit(1)
                        }
                        if type_of(_aa) != "string" && _aa.kind == "Ident" && _gen2_should_autowrap_fnref(_aa.name) {
                            _slots[_pos_i] = "hexa_fn_new((void*)" + _hexa_mangle_ident(_aa.name) + ", 0)"
                        } else {
                            _slots[_pos_i] = gen2_expr(_aa)
                        }
                        _pos_i = _pos_i + 1
                    }
                    _ari = _ari + 1
                }
                // Fill any still-empty slot with its default expr, else error.
                let mut _fk = 0
                while _fk < _kw_arity {
                    if _slots[_fk] == "" {
                        let _kdef = _fn_default_at(name, _fk)
                        if type_of(_kdef) == "string" && _kdef == "" {
                            eprintln("error: function `" + name + "` missing required argument (parameter index " + to_string(_fk) + ")")
                            exit(1)
                        }
                        _slots[_fk] = gen2_expr(_kdef)
                    }
                    _fk = _fk + 1
                }
                return _hexa_mangle_ident(name) + "(" + _slots.join(", ") + ")"
            }
            // RFC r16 (varargs): a variadic fn `fn f(a, b, xs...)` has a C
            // callee of fixed arity (arity = variadic_idx + 1): the leading
            // params plus ONE array param collecting the rest. The call emits
            // the leading positional args directly, then packs args[vidx..]
            // into a HexaVal array (built via hexa_array_push chain). A single
            // `Spread` argument in the variadic position (`f(a, b, ...arr)`)
            // passes the spread array directly instead of packing.
            let _vidx_c = -1
            if _is_known_fn_global(name) { _vidx_c = _fn_variadic_lookup(name) }
            if _vidx_c >= 0 {
                let _v_arity = _fn_arity_lookup(name)
                // Leading (pre-variadic) params are mandatory.
                if len(node.args) < _vidx_c {
                    eprintln("error: function `" + name + "` expects at least " + to_string(_vidx_c) + " argument(s) before the variadic, got " + to_string(len(node.args)))
                    exit(1)
                }
                let mut _vparts = []
                let mut _vi = 0
                while _vi < _vidx_c {
                    let _va = node.args[_vi]
                    if type_of(_va) != "string" && _va.kind == "Spread" {
                        eprintln("error: spread `...` argument is only allowed in the variadic position of `" + name + "`")
                        exit(1)
                    }
                    if type_of(_va) != "string" && _va.kind == "Ident" && _gen2_should_autowrap_fnref(_va.name) {
                        _vparts.push("hexa_fn_new((void*)" + _hexa_mangle_ident(_va.name) + ", 0)")
                    } else {
                        _vparts.push(gen2_expr(_va))
                    }
                    _vi = _vi + 1
                }
                // Build the variadic array from args[_vidx_c..].
                let _rest_n = len(node.args) - _vidx_c
                if _rest_n == 1 && type_of(node.args[_vidx_c]) != "string" && node.args[_vidx_c].kind == "Spread" {
                    // `f(..., ...arr)` — pass the spread array directly.
                    _vparts.push(gen2_expr(node.args[_vidx_c].left))
                } else {
                    let mut _arrc = "hexa_array_new()"
                    let mut _ri = _vidx_c
                    while _ri < len(node.args) {
                        let _ra = node.args[_ri]
                        if type_of(_ra) != "string" && _ra.kind == "Spread" {
                            eprintln("error: spread `...` may only be the sole variadic argument in call to `" + name + "`")
                            exit(1)
                        }
                        _arrc = "hexa_array_push(" + _arrc + ", " + gen2_expr(_ra) + ")"
                        _ri = _ri + 1
                    }
                    _vparts.push(_arrc)
                }
                if len(_vparts) != _v_arity {
                    // Defensive: leading + 1 array must equal declared arity.
                    eprintln("error: variadic call lowering arity mismatch for `" + name + "`")
                    exit(1)
                }
                return _hexa_mangle_ident(name) + "(" + _vparts.join(", ") + ")"
            }
            // User function call — direct C call if it's a known top-level
            // function, otherwise dispatch through hexa_callN (the name must
            // refer to a local/global closure-typed HexaVal).
            let mut arg_strs = []
            let mut ai = 0
            while ai < len(node.args) {
                let _arg = node.args[ai]
                if type_of(_arg) != "string" && _arg.kind == "Ident" && _gen2_should_autowrap_fnref(_arg.name) {
                    arg_strs.push("hexa_fn_new((void*)" + _hexa_mangle_ident(_arg.name) + ", 0)")
                } else {
                    arg_strs.push(gen2_expr(_arg))
                }
                ai = ai + 1
            }
            if _is_known_fn_global(name) {
                // PROBE r16-T2 + RFC r16 (default args): arity check at the
                // direct-call codegen site. The C callee is fixed-arity (all
                // declared params), so the call must pass exactly _exp_arity
                // args. With default args, the legal user-supplied count is the
                // range [_req_arity, _exp_arity]; omitted trailing params are
                // auto-filled here with their declared default expressions
                // (strategy A — full-arity expansion at the call site). Anything
                // below required or above total is a hexa-level error BEFORE
                // codegen (clearer than an opaque clang "too few/many args").
                // Registry holds plain FnDecls only (-1 = skip: extern fns,
                // struct constructors, imported names are unaffected).
                let _exp_arity = _fn_arity_lookup(name)
                if _exp_arity >= 0 {
                    let mut _req_arity = _fn_required_lookup(name)
                    if _req_arity < 0 { _req_arity = _exp_arity }
                    let _got = len(node.args)
                    if _got < _req_arity || _got > _exp_arity {
                        if _req_arity == _exp_arity {
                            eprintln("error: function `" + name + "` expects " + to_string(_exp_arity) + " argument(s), got " + to_string(_got))
                        } else {
                            eprintln("error: function `" + name + "` expects " + to_string(_req_arity) + " to " + to_string(_exp_arity) + " argument(s), got " + to_string(_got))
                        }
                        exit(1)
                    }
