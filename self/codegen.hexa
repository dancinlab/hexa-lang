                if name == "forge_dispatch_matmul" { return "hexa_forge_dispatch_matmul(" + arg_strs[0] + ", " + arg_strs[1] + ", " + arg_strs[2] + ", " + arg_strs[3] + ", " + arg_strs[4] + ")" }
                // anima RFC 034 (2026-05-16): farr autograd — ad_matmul
                // (5-arg; forward = farr_matmul + records backward).
                if name == "ad_matmul"      { return "hexa_ad_matmul(" + arg_strs[0] + ", " + arg_strs[1] + ", " + arg_strs[2] + ", " + arg_strs[3] + ", " + arg_strs[4] + ")" }
                // BC-ANIMA M3 (2026-05-28): farr_ce_seed — 5-arg
                // seed-only CE gradient (softmax, target_ids, dlogits,
                // R, C) -> int rc. dlogits[r,c] = softmax[r,c]
