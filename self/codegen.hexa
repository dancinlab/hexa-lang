            if nargs == 1 { return "hexa_call1(" + cn + ", " + arg_strs[0] + ")" }
            if nargs == 2 { return "hexa_call2(" + cn + ", " + arg_strs.join(", ") + ")" }
            if nargs == 3 { return "hexa_call3(" + cn + ", " + arg_strs.join(", ") + ")" }
