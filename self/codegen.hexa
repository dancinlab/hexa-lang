                return "hexa_host_ffi_call_6(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ", " + gen2_expr(node.args[2]) + ", " + gen2_expr(node.args[3]) + ", " + gen2_expr(node.args[4]) + ", " + gen2_expr(node.args[5]) + ", " + gen2_expr(node.args[6]) + ", " + gen2_expr(node.args[7]) + ", " + gen2_expr(node.args[8]) + ", " + gen2_expr(node.args[9]) + ")"
            }
