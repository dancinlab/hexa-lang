            }
            if name == "host_ffi_sym" {
                return "hexa_host_ffi_sym(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if name == "host_ffi_call" {
                return "hexa_host_ffi_call(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ", " + gen2_expr(node.args[2]) + ", " + gen2_expr(node.args[3]) + ")"
            }
            if name == "host_ffi_call_6" {
