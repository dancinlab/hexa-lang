                if name == "utc_compact_now"  { return "hexa_utc_compact_now()" }
                // anima RFC 034 (2026-05-16): farr autograd — 0-arg tape open.
                if name == "ad_tape_begin"    { return "hexa_ad_tape_begin()" }
            }
            if len(node.args) == 1 {
                let a0 = arg_strs[0]
                if name == "exit"           { return "hexa_exit(" + a0 + ")" }
                if name == "sleep"          { return "hexa_sleep(" + a0 + ")" }
                if name == "tanh"           { return cg_math_sym("tanh") + "(" + a0 + ")" }
                if name == "sin"            { return cg_math_sym("sin") + "(" + a0 + ")" }
                if name == "cos"            { return cg_math_sym("cos") + "(" + a0 + ")" }
                if name == "tan"            { return cg_math_sym("tan") + "(" + a0 + ")" }
                if name == "asin"           { return cg_math_sym("asin") + "(" + a0 + ")" }
                if name == "acos"           { return cg_math_sym("acos") + "(" + a0 + ")" }
                if name == "atan"           { return cg_math_sym("atan") + "(" + a0 + ")" }
                if name == "log"            { return cg_math_sym("log") + "(" + a0 + ")" }
                if name == "exp"            { return cg_math_sym("exp") + "(" + a0 + ")" }
                // G1-FLOAT-PRIM 2026-05-06 (.roadmap.stdlib.G1) — lgamma + classifiers.
                if name == "lgamma"         { return cg_math_sym("lgamma") + "(" + a0 + ")" }
                if name == "isnan"          { return cg_math_sym("isnan") + "(" + a0 + ")" }
                if name == "isinf"          { return cg_math_sym("isinf") + "(" + a0 + ")" }
                if name == "isfinite"       { return cg_math_sym("isfinite") + "(" + a0 + ")" }
                // VERIFY-KIT V4 2026-05-26 — special-function primitives (native libm).
                if name == "gamma"          { return cg_math_sym("gamma") + "(" + a0 + ")" }
                if name == "tgamma"         { return cg_math_sym("tgamma") + "(" + a0 + ")" }
                if name == "erf"            { return cg_math_sym("erf") + "(" + a0 + ")" }
                if name == "erfc"           { return cg_math_sym("erfc") + "(" + a0 + ")" }
                if name == "bessel_j0"      { return cg_math_sym("bessel_j0") + "(" + a0 + ")" }
                if name == "bessel_j1"      { return cg_math_sym("bessel_j1") + "(" + a0 + ")" }
