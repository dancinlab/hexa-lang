                let mut ien = 0
                while ien < nargs_en {
                    epn = epn + "hexa_eprint_val(" + gen2_expr(node.args[ien]) + "), "
                    ien = ien + 1
                }
                epn = epn + "hexa_void())"
                return epn
            }
            if name == "args" {
                return "hexa_args()"
            }
            if name == "argv" {
                // 2026-04-19: serve_alm.hexa + anima entry scripts spell `argv()`
                // (matching the Python/C tradition) instead of `args()`. Alias
                // both to hexa_args() — same C return so downstream av[N] works.
                return "hexa_args()"
            }
            // Canonical argv API (roadmap 65 / M3, 2026-04-23). See runtime.c
            // hexa_real_args/hexa_script_path for rationale.
            if name == "real_args" {
                return "hexa_real_args()"
            }
            if name == "script_path" {
                return "hexa_script_path()"
            }
            if name == "exec" {
                return "hexa_exec(" + gen2_expr(node.args[0]) + ")"
            }
            // mkdir(path) — interpreter has it as builtin; AOT path needs
            // routing to POSIX `mkdir(path, 0755)` since `mkdir` collides
            // with POSIX `bind`/`open`/etc-style POSIX surface (cf 9f9e9799
            // mangle allowlist). Returns hexa_void() so call sites in
            // statement position type-check.
            // PROBE r8: mkdir return code was dropped (void) — flipped to
            // `hexa_bool` (true on success, false on fail).  Matches Rust
            // `fs::create_dir(p).is_ok()` / Go `os.Mkdir(p,…) == nil`.
            if name == "mkdir" {
                return "hexa_bool(mkdir(HX_STR(" + gen2_expr(node.args[0]) + "), 0755) == 0)"
            }
            if name == "exec_with_status" {
                return "hexa_exec_with_status(" + gen2_expr(node.args[0]) + ")"
            }
            // exec_with_status3(cmd) — canonical 3-tuple [stdout, stderr,
            // exit_code] (PROBE r8). Non-breaking sibling of the 2-tuple
            // exec_with_status; body delegates to hexa_exec_capture (separate
            // stdout/stderr pipes, select-multiplexed drain). Pre-regen, the
            // baked hexat routes bare `exec_with_status3(...)` through the
            // TAG_FN bridge in runtime.c.
            if name == "exec_with_status3" {
                return "hexa_exec_with_status3(" + gen2_expr(node.args[0]) + ")"
            }
            // exec_stream(cmd, on_line) — streams stdout lines through the
            // callback as they arrive, returns int exit code. Added 2026-04-25
            // to break the silent-stall pattern from hexa_exec()'s buffering.
            // Routes to runtime.c hexa_exec_stream (HexaVal,HexaVal)->HexaVal.
            if name == "exec_stream" {
                return "hexa_exec_stream(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            // exec_stream_kill(handle) — SIGTERM->grace->SIGKILL the streaming
            // child process group (wilson tool-core ESC-cancel; build-fix-
            // checklist L25). exec_stream_close only pclose/waitpid-joins
            // (blocks until the child exits on its own). Routes to runtime.c
            // hexa_exec_stream_kill (HexaVal)->HexaVal. The exec_stream_async/
            // poll/close siblings go through the hexa_call1(raw-symbol) path;
            // _kill gets an explicit emit here too (runtime.c keeps a raw
            // `exec_stream_kill` alias either way).
            if name == "exec_stream_kill" {
                return "hexa_exec_stream_kill(" + gen2_expr(node.args[0]) + ")"
            }
