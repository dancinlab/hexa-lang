            if name == "read_file" {
                return "rt_read_file(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "write_file" {
                return "rt_write_file(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
