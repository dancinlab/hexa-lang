                    let mut _fi = _got
                    while _fi < _exp_arity {
                        let _dexpr = _fn_default_at(name, _fi)
                        if type_of(_dexpr) == "string" && _dexpr == "" {
                            // Should not happen (range checked above) but guard.
                            eprintln("error: function `" + name + "` missing argument " + to_string(_fi))
                            exit(1)
                        }
                        arg_strs.push(gen2_expr(_dexpr))
