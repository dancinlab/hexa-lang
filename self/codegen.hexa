                // binary-safe digest for base64_encode(sha1_bytes(key+magic)).
                // FIPS 180-4 reference impl in self/native/exec_argv_sha256.c.
                if name == "sha1"           { return "hexa_sha1(" + a0 + ")" }
                if name == "sha1_bytes"     { return "hexa_sha1_bytes(" + a0 + ")" }
                // G4-ISO8601 2026-05-06 (.roadmap.stdlib.G4) — format/parse mirrors
                // of utc_iso_now (runtime.c hexa_utc_iso_format / hexa_utc_iso_parse).
                if name == "utc_iso_format" { return "hexa_utc_iso_format(" + a0 + ")" }
                if name == "utc_iso_parse"  { return "hexa_utc_iso_parse(" + a0 + ")" }
                // G3-REGEX 2026-05-06 (.roadmap.stdlib.G3) — POSIX ERE bridge.
                // 1-arg form is invalid for regex (always pat + s); placeholder.
                if name == "input"          { return "hexa_input(" + a0 + ")" }
                if name == "is_error"       { return "hexa_is_error(" + a0 + ")" }
                if name == "read_lines"     { return "rt_read_lines(" + a0 + ")" }
                if name == "from_char_code" { return "hexa_from_char_code(" + a0 + ")" }
                if name == "ord"            { return "hexa_char_code(" + a0 + ", hexa_int(0))" }
                if name == "char_code"      { return "hexa_char_code(" + a0 + ", hexa_int(0))" }
                // chr-byte-fix 2026-05-17 (RFC chr-byte-vs-codepoint-asymmetry):
