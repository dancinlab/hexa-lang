            }
            if method == "get" {
                return "hexa_map_get(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + "))"
            }
            if method == "set" {
                return "hexa_map_set(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + "), " + gen2_expr(node.args[1]) + ")"
            }
            if method == "pop" {
                return "hexa_array_pop(" + obj + ")"
            }
            if method == "shift" {
                return "hexa_array_shift(" + obj + ")"
            }
            if method == "reverse" {
                return "hexa_array_reverse(" + obj + ")"
            }
            // Rust canonical alias for iterators/ranges — see sibling at the
            // `if method == "reverse"` arm earlier in this file.
            if method == "rev" {
                return "hexa_array_reverse(" + obj + ")"
            }
            if method == "sort" {
                return "hexa_array_sort(" + obj + ")"
            }
            if method == "sort_by" {
                // mirror the gen2_method_builtin arm: auto-wrap bare fn-refs.
                let _sb_arg = node.args[0]
                let mut _sb_arg_expr = gen2_expr(_sb_arg)
                if type_of(_sb_arg) != "string" && _sb_arg.kind == "Ident" && _gen2_should_autowrap_fnref(_sb_arg.name) {
                    _sb_arg_expr = "hexa_fn_new((void*)" + _hexa_mangle_ident(_sb_arg.name) + ", 0)"
                }
                return "hexa_array_sort_by(" + obj + ", " + _sb_arg_expr + ")"
            }
            // bt 55 — in-place array length shrink; caller must reassign.
            if method == "truncate" {
                return "hexa_array_truncate(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            // T33-rebuild fallback batch — missing host-backed methods that
            // were previously hitting the unhandled-method error path. Added
            // while unblocking the interp rebuild regression (task #5).
            if method == "push_nostat" {
                return "hexa_array_push_nostat(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            if method == "trim_start" {
                return cg_string_sym("str_trim_start") + "(" + obj + ")"
            }
            if method == "trim_end" {
                return cg_string_sym("str_trim_end") + "(" + obj + ")"
            }
            // String bytes — UTF-8 byte array. runtime.c hexa_str_bytes
            // mirrors interpreter self/hexa_full.hexa:15074-15079.
            if method == "bytes" {
                return cg_string_sym("str_bytes") + "(" + obj + ")"
            }
            // String lines — split on '\n'. runtime.c hexa_str_lines
            // delegates to hexa_str_split.
            if method == "lines" {
                return cg_string_sym("str_lines") + "(" + obj + ")"
            }
            if method == "slice" {
                let _sl_end = if len(node.args) >= 2 { gen2_expr(node.args[1]) } else { "hexa_void()" }
                return "hexa_array_slice(" + obj + ", " + gen2_expr(node.args[0]) + ", " + _sl_end + ")"
            }
            if method == "slice_fast" {
                let _slf_end = if len(node.args) >= 2 { gen2_expr(node.args[1]) } else { "hexa_void()" }
                return "hexa_array_slice_fast(" + obj + ", " + gen2_expr(node.args[0]) + ", " + _slf_end + ")"
            }
            if method == "to_string" {
                return "hexa_to_string(" + obj + ")"
            }
            if method == "parse_int" {
                return cg_string_sym("str_parse_int") + "(" + obj + ")"
            }
            if method == "parse_float" {
                return cg_string_sym("str_parse_float") + "(" + obj + ")"
            }
            if method == "pad_left" {
                return "hexa_pad_left(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            // Last-resort fallback — route anything unhandled through
            // gen2_method_builtin which has the comprehensive array method
            // dispatch (map/filter/fold/any/all/count/find/flat_map/enumerate
            // + many others). Without this, user-type path works via line 3479
            // but the bare inline path below hits CODEGEN ERROR for any
            // array-side method we missed. Matches line 2237+ coverage.
            let fallback = gen2_method_builtin(obj, method, node.args)
            if len(fallback) > 0 { return fallback }
            eprintln("[codegen_c2] ERROR: unhandled method call: " + method)
            return "(fprintf(stderr, \"CODEGEN ERROR: unhandled method: " + method + "\\n\"), exit(1), hexa_void())"
        }
        // Indirect call: callee is an arbitrary expression evaluating to a
        // closure (TAG_CLOSURE) or raw fn (TAG_FN). Dispatch via hexa_callN.
        let cexpr = gen2_expr(callee)
        let nargs = len(node.args)
        let mut cargs = []
        let mut ci = 0
        while ci < nargs {
            let _ca = node.args[ci]
            if type_of(_ca) != "string" && _ca.kind == "Ident" && _gen2_should_autowrap_fnref(_ca.name) {
                // Wrap function name as TAG_FN value for first-class fn passing
                cargs.push("hexa_fn_new((void*)" + _hexa_mangle_ident(_ca.name) + ", 0)")
            } else {
                cargs.push(gen2_expr(_ca))
            }
            ci = ci + 1
        }
        if nargs == 0 { return "hexa_call0(" + cexpr + ")" }
        if nargs == 1 { return "hexa_call1(" + cexpr + ", " + cargs[0] + ")" }
        if nargs == 2 { return "hexa_call2(" + cexpr + ", " + cargs.join(", ") + ")" }
        if nargs == 3 { return "hexa_call3(" + cexpr + ", " + cargs.join(", ") + ")" }
        if nargs == 4 { return "hexa_call4(" + cexpr + ", " + cargs.join(", ") + ")" }
        eprintln("[codegen_c2] ERROR: indirect call arity " + to_string(nargs) + " unsupported (max 4)")
        return "(fprintf(stderr, \"CODEGEN ERROR: indirect call arity %d unsupported\\n\", " + to_string(nargs) + "), exit(1), hexa_void())"
    }

    if k == "Array" {
        let nitems = len(node.items)
        // For large array literals, deeply-nested hexa_array_push(...)
        // chains overflow clang's parser stack (observed SIGILL on
        // ATLAS_P_NODES with ~7000 elements). Switch to GNU statement
        // expression with a sequence of pushes — flat instead of nested.
        if nitems > 64 {
            let mut out = "({ HexaVal __arr_lit = hexa_array_new(); "
            let mut ai = 0
            while ai < nitems {
                out = out + "hexa_array_push(__arr_lit, " + gen2_expr(node.items[ai]) + "); "
                ai = ai + 1
            }
            out = out + "__arr_lit; })"
            return out
        }
        let mut out = "hexa_array_new()"
        let mut ai = 0
        while ai < nitems {
            out = "hexa_array_push(" + out + ", " + gen2_expr(node.items[ai]) + ")"
            ai = ai + 1
        }
        return out
    }

    if k == "Index" {
        // arr[a..b] / arr[a..=b] — range-slice. The parser nests a Range
        // node as the index; lower it to hexa_array_slice (exclusive end,
        // +1 for the inclusive `..=` form) instead of hexa_index_get, which
        // would otherwise be handed an int-array key and crash. Open ends
        // (arr[..b] / arr[a..]) default to 0 / len(arr).
        let idx = node.right
        if type_of(idx) != "string" && idx.kind == "Range" {
            let arr_c = gen2_expr(node.left)
            let mut s_c = "hexa_int(0)"
            if type_of(idx.left) != "string" { s_c = gen2_expr(idx.left) }
            let mut e_c = "hexa_int(hexa_len(" + arr_c + "))"
            if type_of(idx.right) != "string" {
                e_c = gen2_expr(idx.right)
                if idx.value == "inclusive" {
                    e_c = "hexa_int(HX_INT(" + e_c + ") + 1)"
                }
            }
            return "hexa_array_slice(" + arr_c + ", " + s_c + ", " + e_c + ")"
        }
        // ── UNSHADOW item C: proof-carrying bounds-elision emit ─────────────
        // If `arr[i]` is covered by a LIVE in-range fact (established by an
        // enclosing `for i in 0..len(arr)` with no resize of arr / reassign of
        // i), emit a BOUNDS-FREE, throw-FREE direct read indexing the native
        // counter — `(arr.arr_ptr->items[__hx_ni_i])`. By construction of that
        // C for-loop, 0 <= counter < arr.len, so the runtime bounds check and
        // its hexa_throw arm are provably dead. HexaArr {items,len,cap} and the
        // `arr_ptr` union field are public in runtime.h → no runtime-internal
        // macro needed, works through the runtime.o C-ABI wall. Any read NOT
        // matching the proven (arr,i) pair falls through to the checked form.
        // The proof guarantees `0 <= counter < hexa_len(arr)` (the loop bound IS
        // arr's length), but codegen is untyped (HexaVal) and cannot statically
        // prove `arr` is a TAG_ARRAY rather than a map/string (`len()` is
        // polymorphic). So we elide the BOUNDS CHECK + hexa_throw — the proven-
        // dead part — but retain a single cheap TAG guard: on the array hot path
        // emit the direct `arr.arr_ptr->items[counter]` (no `idx<0||idx>=len`
        // compare, no throw, no oob-string); only a non-array `arr` falls back to
        // the full checked `hexa_index_get`. This is the EXACT provably-safe
        // elision — never an OOB read.
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            if type_of(idx) != "string" && idx.kind == "Ident" {
                let _ir_ctr = _inrange_counter_for(node.left.name, idx.name)
                if _ir_ctr != "" {
                    let _ir_av = gen2_expr(node.left)
                    // ── UNSHADOW item A: unboxed-primitive array read ───────────
                    // If `arr` is ALSO a proven known-int-array (immutable let =
                    // monomorphic i64 array literal), the receiver is statically
                    // TAG_ARRAY *and* the element is statically TAG_INT. Both the
                    // §c-class array-tag guard (`HX_IS_ARRAY(arr)?…`) and the
                    // per-element runtime work are now provably dead — drop the
                    // ternary and emit a DIRECT element read. The element is
                    // produced as a HexaVal lvalue (`arr.arr_ptr->items[ctr]`,
                    // boxed-storage form), but `_is_known_int(arr[i])` now
                    // certifies it TAG_INT, so a surrounding sum/dot BinOp
                    // extracts the raw `.i` via HX_INT() with no tag dispatch —
                    // the boxed-storage unbox (storage is still HexaVal* under
                    // the runtime.o wall; native int64_t[] storage is the modeled
                    // ceiling measured in the A/B proxy). DOUBLE-EVAL SAFE: _ir_av
                    // and _ir_ctr each appear once. FOLD-SHADOW SAFE: registration
                    // is immutable-let-only + voided on reassignment, and the
                    // read still requires a live in-range fact (no resize/realias
                    // in the loop). BOUNDARY-BOX: any use of `arr` NOT matching
                    // this proven read (passed to a fn / unproven index / untyped
                    // flow) falls through to the unchanged BOXED HexaArr path.
                    if _is_known_intarr_name(node.left.name) {
                        // UNSHADOW [HEADLINE] F1: when native-i64 STORAGE is on,
                        // this binding was constructed as a contiguous int64_t[]
                        // (hexa_arr_i64_new above), so the proven in-range read
                        // is a RAW native load `((HexaArrI64*)xs.arr_ptr)
                        // ->data[i]` — 8-byte contiguous, SIMD-gatherable, no
                        // HexaVal. A surrounding sum/dot consumes the int64_t
                        // directly (HX_INT() over hexa_int() is identity; here
                        // the value IS already raw .i). DOUBLE-EVAL SAFE: _ir_av
                        // / _ir_ctr each once. Falls back to boxed-storage read
                        // when the flag is off (axis-A / §c-class unchanged).
                        if _native_arr_enabled() {
                            // The boxed surface MUST be an INLINE compound literal
                            // — NOT an out-of-line `hexa_int(…)` runtime.o call —
                            // or the C-ABI wall blocks clang from folding
                            // HX_INT(hexa_int(data[i])) → data[i] and the native
                            // load gets re-boxed per element (defeats the gather).
                            // §hexaval-unbox proved the inline literal is what
                            // lets clang keep the raw int in a register / vectorize.
                            return "((HexaVal){.tag=TAG_INT,.i=(((HexaArrI64*)" + _ir_av + ".arr_ptr)->data[" + _ir_ctr + "])})"
                        }
                        return "(" + _ir_av + ".arr_ptr->items[" + _ir_ctr + "])"
                    }
                    return "(HX_IS_ARRAY(" + _ir_av + ") ? (" + _ir_av + ").arr_ptr->items[" + _ir_ctr + "] : hexa_index_get(" + _ir_av + ", hexa_int(" + _ir_ctr + ")))"
                }
            }
        }
        return "hexa_index_get(" + gen2_expr(node.left) + ", " + gen2_expr(node.right) + ")"
    }

    // ── Enum path: Color::Red → hexa_int(N) ──────────────────
    // RFC-020 A4: single-field payload variant construction. When the parser
    // attached a non-empty `payload_expr` (an AST map node), emit the runtime
    // form — a tagged HexaVal array `[tag, payload]` — so the payload travels
    // with the tag. Plain unit variants keep the bare `<name>_<value>` tag
    // macro (zero regression). This logic was hand-applied to the generated
    // self/native/hexa_cc.c at a85b8a1c but never back-ported here, so a later
    // `hexa cc --regen` wiped it; restoring it in the SSOT keeps regen safe.
    if k == "EnumPath" {
        let ename = node.name
        let vname = node.value
        // _is_enum_name distinguishes `Enum::Variant` (single-underscore
        // tag + optional payload array) from `Struct::method` (double-
        // underscore direct fn call).  Without this guard `Point::id(7)`
        // lowered to the enum-array shape and clang errored on the
        // undeclared `Point_id` (impl-fn is mangled `Point__id`).
        if !_is_enum_name(ename) {
            // Non-enum receiver — treat as associated fn call.  Mangling
            // matches the impl-fn definition (`Point__id`).
            let mangled = ename + "__" + vname
            let pe = node.payload_expr
            if type_of(pe) != "string" {
                return mangled + "(" + gen2_expr(pe) + ")"
            }
            return mangled
        }
        let enum_const = ename + "_" + vname
        // RFC-074 P2: multi-arg payload variants (`Shape::Square(3, 4)`)
        // arrive as `payload_args = [expr, …]`; emit nested
        // hexa_array_push per arg in order.  Single-arg keeps the
        // back-compat `payload_expr` path below.
        let pas = node.payload_args
        if type_of(pas) != "string" && len(pas) > 0 {
            let mut out = "hexa_array_push(hexa_array_new(), " + enum_const + ")"
            let mut i = 0
            while i < len(pas) {
                out = "hexa_array_push(" + out + ", " + gen2_expr(pas[i]) + ")"
                i = i + 1
            }
            return out
        }
        let pe = node.payload_expr
        if type_of(pe) != "string" {
            return "hexa_array_push(hexa_array_push(hexa_array_new(), " + enum_const + "), " + gen2_expr(pe) + ")"
        }
        return enum_const
    }

    // ── If expression (value-producing) ──────────────────────
    // Trivial arms (single tail ExprStmt, no inner LetStmt) collapse to a
    // C ternary. Non-trivial arms (multiple stmts or any LetStmt) emit a
    // GCC statement-expression `({ stmts; (tail); })` so inner declarations
    // (`let whole = …; let frac = …; whole + "." + frac`) survive — the
    // prior unconditional ternary path silently dropped non-tail stmts,
    // producing references to undeclared identifiers (gate/remote_preflight.hexa
    // probe_parallel `secs` link fail, 2026-04-27).
    if k == "IfExpr" {
        let c = gen2_expr(node.cond)
        if _gen2_arm_is_trivial(node.then_body) && _gen2_arm_is_trivial(node.else_body) {
            let mut t_val = "hexa_void()"
            if type_of(node.then_body) != "string" && len(node.then_body) > 0 {
                let t_last = node.then_body[len(node.then_body) - 1]
                if type_of(t_last) != "string" && t_last.kind == "ExprStmt" && type_of(t_last.left) != "string" {
                    t_val = gen2_expr(t_last.left)
                }
            }
            let mut e_val = "hexa_void()"
            if type_of(node.else_body) != "string" && len(node.else_body) > 0 {
                let e_last = node.else_body[len(node.else_body) - 1]
                if type_of(e_last) != "string" && e_last.kind == "ExprStmt" && type_of(e_last.left) != "string" {
                    e_val = gen2_expr(e_last.left)
                }
            }
            return "(hexa_truthy(" + c + ") ? " + t_val + " : " + e_val + ")"
        }
        let _t_arm = _gen2_arm_block_expr(node.then_body)
        let _e_arm = _gen2_arm_block_expr(node.else_body)
        return "(hexa_truthy(" + c + ") ? " + _t_arm + " : " + _e_arm + ")"
    }

    // ── Match expression (value-producing) ──────────────────
    if k == "MatchExpr" {
        return gen2_match_expr(node)
    }

    // ── Lambda / closure ────────────────────────────────────
    if k == "Lambda" {
        return gen2_lambda_expr(node)
    }

    // ── Tuple → Array ─────────────────────────────────────
    if k == "Tuple" || k == "TupleLit" {
        let mut out = "hexa_array_new()"
        let items = node.items
        if type_of(items) != "string" {
            let mut ti = 0
            while ti < len(items) {
                out = "hexa_array_push(" + out + ", " + gen2_expr(items[ti]) + ")"
                ti = ti + 1
            }
        }
        return out
    }

    // ── Map literal → hexa_map_new + set ──────────────────
    if k == "MapLit" {
        let mut out = "hexa_map_new()"
        if type_of(node.items) != "string" {
            let mut mi = 0
            while mi < len(node.items) {
                let entry = node.items[mi]
                // hexa_map_set takes const char* key — extract raw string for StringLit keys
                let mut key_c = gen2_expr(entry.left)
                if type_of(entry.left) != "string" && entry.left.kind == "StringLit" {
                    key_c = "\"" + c_escape(entry.left.value) + "\""
                } else {
                    // PROBE r16 Q4: a non-StringLit key (e.g. int `#{1: "one"}`)
                    // produced a HexaVal expression passed where const char* is
                    // expected → clang error. Maps are string→value, so stringify
                    // the key (consistent with hexa_index_get/set + the map_set
                    // builtin) — `#{1:...}` and `m["1"]` then agree.
                    key_c = "hexa_to_cstring(" + key_c + ")"
                }
                out = "hexa_map_set(" + out + ", " + key_c + ", " + gen2_expr(entry.right) + ")"
                mi = mi + 1
            }
        }
        return out
    }

    // ── Negation of float ──────────────────────────────────
    if k == "NegFloat" {
        return "hexa_float(-HX_FLOAT(" + gen2_expr(node.left) + "))"
    }

    // ── Wildcard (used in patterns) ─────────────────────────
    if k == "Wildcard" {
        return "/* wildcard */"
    }

    // ── Slice expr: arr[s:e], arr[:e], arr[s:], arr[:] ─────
    // Parser shape: left=arr, right=start ("" if missing), cond=end ("" if missing)
    if k == "Slice" {
        let arr_c = gen2_expr(node.left)
        let mut s_c = "hexa_int(0)"
        if type_of(node.right) != "string" {
            s_c = gen2_expr(node.right)
        }
        let mut e_c = "hexa_int(hexa_len(" + arr_c + "))"
        if type_of(node.cond) != "string" {
            e_c = gen2_expr(node.cond)
        }
        return "hexa_array_slice(" + arr_c + ", " + s_c + ", " + e_c + ")"
    }

    // `0..5` / `0..=5` / `0..10 step 2` at expression position — evaluate to
    // int array via runtime. ForStmt has its own fast path at line 1888;
    // this handles the general `let r = 0..n` / `(0..n).map(...)` case.
    if k == "Range" {
        let start_c = gen2_expr(node.left)
        let end_c = gen2_expr(node.right)
        let step_c = if type_of(node.cond) != "string" { gen2_expr(node.cond) } else { "hexa_void()" }
        let incl = if node.value == "inclusive" { "1" } else { "0" }
        return "hexa_range_array(" + start_c + ", " + end_c + ", " + step_c + ", " + incl + ")"
    }
    // ── Await: `await x` (RFC-022 §4.2 — G2 codegen integration) ─────────
    // Mirrors interp self/hexa_full.hexa:8048-8057. Wraps the inner
    // expression in hexa_await_unwrap() (defined in self/runtime.c) which
    // checks for a Future struct and extracts `.value`, else identity.
    //
    // Per RFC-022 §3.1: stage-1 async is annotation-only — `await` runs
    // synchronously to completion on the calling task. The unwrap is the
    // ONLY observable effect. AsyncFnDecl is intentionally treated as a
    // plain FnDecl elsewhere in this file (line 6359, 6485): the `async`
    // keyword is a typing/annotation surface, not a codegen transform.
    //
    // Parser obligation (RFC-022 §4.3, D5 — deferred): when the parser
    // begins emitting explicit AwaitExpr nodes for `await <expr>`, this
    // branch fires automatically and native AOT binaries gain the unwrap
    // semantic without further codegen change.
    if k == "Await" || k == "AwaitExpr" {
        let inner_c = gen2_expr(node.expr)
        return "hexa_await_unwrap(" + inner_c + ")"
    }
    // dead: parser rejects upstream (PROBE r9-6, 2026-05-23).
    // Macro invocations now fail loud at PARSE-time with a clear
    // "macros not yet implemented" diagnostic (see self/parser.hexa
    // parse_postfix `Not` arm). Reaching this branch means the parser
    // synthesized a MacroCall node for error-recovery but somehow the
    // file was transpiled despite the recorded parse error — that is a
    // compiler-internal contract bug. Exit before clang runs so the gap
    // surfaces to the developer, not the user. Future: replace with the
    // expander pass per archive/patches/macro-expander-pass-design.md.
    if k == "MacroCall" {
        eprintln("[codegen] ERROR: MacroCall reached codegen — parser should have rejected upstream (PROBE r9-6). This is a compiler bug; see archive/patches/macro-expander-pass-design.md")
        exit(1)
    }
    if k == "" { return "hexa_map_new()" }
    // PROBE r14-VV: IfLetExpr in expression position → synthesize MatchExpr.
    // `let x = if let PAT = e { THEN } else { ELSE }` is rare today (the
    // probe uses stmt form), but symmetry with `if/match` (both have
    // stmt + expr handlers) keeps the surface honest. gen2_match_expr
    // emits a ternary chain that reuses EnumPath tag/payload codegen.
    if k == "IfLetExpr" {
        return gen2_match_expr(_gen2_iflet_to_match(node))
    }
    // Fail loud at TRANSPILE time — sibling of the stmt-kind branch.
    // Returning an in-binary trap stub hid the failure behind clang +
    // link; an unhandled kind is a compiler gap, exit before clang runs.
    eprintln("[codegen_c2] ERROR: unhandled expression kind: " + k)
    exit(1)
}

// ═══════════════════════════════════════════════════════════
//  Escape Analysis — stack allocation codegen (ROI id=19)
//  For objects that don't escape their function scope,
//  generate stack-allocated structs instead of heap maps.
// ═══════════════════════════════════════════════════════════

// Generate stack-allocated struct initialization (instead of hexa_map_new)
// Stack-promoted vars use a local C struct on the stack frame.
fn gen2_stack_alloc_struct(var_name, fields) {
    let mut parts = []
    parts.push("    // [escape-analysis] stack-promoted: " + var_name + "\n")
    parts.push("    HexaVal " + var_name + " = hexa_map_new(); // stack-eligible\n")
    let mut i = 0
    while i < len(fields) {
        let f = fields[i]
        parts.push("    " + var_name + " = hexa_map_set(" + var_name + ", \"" + f + "\", hexa_void());\n")
        i = i + 1
    }
    return parts.join("")
}

// Generate a stack-allocated array (fixed-size, no heap)
fn gen2_stack_alloc_array(var_name, size_hint) {
    let mut parts = []
    parts.push("    // [escape-analysis] stack array: " + var_name + " (size hint: " + to_string(size_hint) + ")\n")
    parts.push("    HexaVal " + var_name + " = hexa_array_new();\n")
    return parts.join("")
}

// ═══════════════════════════════════════════════════════════
//  @vectorize — SIMD codegen helpers (ROI id=24)
//  Generates SIMD intrinsic code for vectorized loops.
//  Target: platform-agnostic (SSE/AVX on x86, NEON on ARM)
// ═══════════════════════════════════════════════════════════

// Generate SIMD loop preamble: determine vector width and alignment
fn gen2_simd_preamble(arr_name, width) {
    let mut parts = []
    parts.push("    // [vectorize] SIMD preamble (width=" + to_string(width) + ")\n")
    parts.push("    int64_t __simd_len = hexa_array_len(" + arr_name + ");\n")
    parts.push("    int64_t __simd_vec_iters = __simd_len / " + to_string(width) + ";\n")
    parts.push("    int64_t __simd_remainder = __simd_len % " + to_string(width) + ";\n")
    return parts.join("")
}

// Generate SIMD vectorized loop body for arr[i] = arr[i] op scalar
fn gen2_simd_loop(arr_name, op, scalar_expr, width) {
    let mut parts = []
    parts.push("    // [vectorize] SIMD loop: " + arr_name + "[i] = " + arr_name + "[i] " + op + " scalar\n")
    parts.push("    for (int64_t __vi = 0; __vi < __simd_vec_iters; __vi++) {\n")
    let mut lane = 0
    while lane < width {
        let idx = "__vi * " + to_string(width) + " + " + to_string(lane)
        parts.push("        hexa_array_set(" + arr_name + ", " + idx + ", hexa_int(HX_INT(hexa_array_get(" + arr_name + ", " + idx + ")) " + op + " HX_INT(" + scalar_expr + ")));\n")
        lane = lane + 1
    }
    parts.push("    }\n")
    // Scalar remainder loop
    parts.push("    // [vectorize] scalar remainder\n")
    parts.push("    for (int64_t __ri = __simd_vec_iters * " + to_string(width) + "; __ri < __simd_len; __ri++) {\n")
    parts.push("        hexa_array_set(" + arr_name + ", __ri, hexa_int(HX_INT(hexa_array_get(" + arr_name + ", __ri)) " + op + " HX_INT(" + scalar_expr + ")));\n")
    parts.push("    }\n")
    return parts.join("")
}

// Generate SoA struct constructor: splits AoS into field-parallel arrays
fn gen2_soa_struct_decl(name, fields) {
    let mut parts = []
    parts.push("// [soa] " + name + " — field-parallel layout\n")
    parts.push("HexaVal " + name + "_soa_new(HexaVal __count) {\n")
    parts.push("    HexaVal __soa = hexa_map_new();\n")
    let mut i = 0
    while i < len(fields) {
        let f = fields[i]
        parts.push("    __soa = hexa_map_set(__soa, \"" + f + "s\", hexa_array_new());\n")
        i = i + 1
    }
    parts.push("    return __soa;\n")
    parts.push("}\n")
    return parts.join("")
}

// T33-rebuild: forward declaration for the constructor emitted by
// gen2_struct_decl. Mirrors the `Name(params)` signature so forward-references
// (return Val(...) called before struct Val's body) type-check without
// dropping to K&R implicit-int.
fn gen2_struct_forward(node) {
    let name = node.name
    let nfields = len(node.fields)
    if nfields == 0 {
        return "HexaVal " + name + "(void);"
    }
    let mut params = []
    let mut fi = 0
    while fi < nfields {
        params.push("HexaVal " + node.fields[fi].name)
        fi = fi + 1
    }
    return "HexaVal " + name + "(" + params.join(", ") + ");"
}

fn gen2_struct_decl(node) {
    // Generate a constructor function: StructName(field1, field2, ...) -> HexaVal map
    let name = node.name
    // PROBE r14-CCCC: record field-name + per-field default-expr lists so the
    // `StructInit` arm can auto-fill missing fields (default present) or emit
    // a hard compile error (default absent → silent-corruption fix).
    _struct_decl_register(node)

    // rt 32-G Phase 0: `Val` is the interpreter's hot tagged-value carrier
    // (~3.37M constructions per d64 200-step run). Route its constructor to
    // the flat-struct primitive hexa_valstruct_new_v instead of hexa_map_new
    // + N map_set. All other struct names fall through to the legacy path.
    // Field order MUST match self/hexa_full.hexa `struct Val` (12 fields).
    if name == "Val" && len(node.fields) == 12 {
        let mut vs_params = []
        let mut vs_args = []
        let mut vi = 0
        while vi < len(node.fields) {
            let fname = node.fields[vi].name
            vs_params.push("HexaVal " + fname)
            vs_args.push(fname)
            vi = vi + 1
        }
        return "HexaVal " + name + "(" + vs_params.join(", ") + ") {\n    return hexa_valstruct_new_v(" + vs_args.join(", ") + ");\n}\n"
    }

    // UNSHADOW typed monomorphic struct layout (GATED HEXA_TYPED_STRUCT=1): when
    // this struct type is flat-eligible (declared, closed non-empty field set),
    // emit a per-type FLAT C-struct typedef + flat constructor instead of the
    // hash-map pack. Field reads on a statically-known instance lower to OFFSET
    // loads (see the `Field` arm). Default OFF → the hash-map path below is
    // unchanged (zero regression). Polymorphic / dynamic-key structs are never
    // flat-eligible (a dynamic-key read never matches the offset arm), so they
    // keep the hash-map ctor + hexa_map_get_ic.
    if _is_flat_eligible_struct(name) {
        return gen2_flat_struct_typedef(node)
    }

    // rt 32-A: struct constructor fast-path. Instead of emitting:
    //     HexaVal __s = hexa_map_new();
    //     __s = hexa_map_set(__s, "__type__", ...);
    //     __s = hexa_map_set(__s, "field_i", field_i);  // ×N
    // emit a single bulk call:
    //     static const char* const _k[] = {"f0","f1",...};
    //     HexaVal _v[] = {f0, f1, ...};
    //     return hexa_struct_pack_map("Name", N, _k, _v);
    // which pre-sizes the hash table once (no rehash) and batch-inserts.
    let mut params = []
    let mut keys_parts = []
    let mut vals_parts = []
    let nfields = len(node.fields)
    let mut i = 0
    while i < nfields {
        let f = node.fields[i]
        params.push("HexaVal " + f.name)
        if i > 0 {
            keys_parts.push(", ")
            vals_parts.push(", ")
        }
        keys_parts.push("\"" + f.name + "\"")
        vals_parts.push(f.name)
        i = i + 1
    }
    let p = params.join(", ")
    let mut p_sig = p
    if p_sig == "" { p_sig = "void" }
    let mut body = ""
    // Handle zero-field structs: still need valid array syntax.
    if nfields == 0 {
        body = "    return hexa_struct_pack_map(\"" + name + "\", 0, (const char* const*)0, (const HexaVal*)0);\n"
    } else {
        let ks_line = "    static const char* const _k[] = {" + keys_parts.join("") + "};\n"
        let vs_line = "    HexaVal _v[] = {" + vals_parts.join("") + "};\n"
        let call_line = "    return hexa_struct_pack_map(\"" + name + "\", " + to_string(nfields) + ", _k, _v);\n"
        body = ks_line + vs_line + call_line
    }
    return "HexaVal " + name + "(" + p_sig + ") {\n" + body + "}\n"
}

// ═══════════════════════════════════════════════════════════
//  @cache_line aligned struct codegen — 64B boundary alignment
//  When a struct has @cache_line attr (in node.value), emit
//  __attribute__((aligned(64))) on the constructor and padding.
// ═══════════════════════════════════════════════════════════

fn gen2_struct_decl_aligned(node) {
    let name = node.name
    let mut params = []
    let mut body_parts = []
    // Emit aligned struct comment
    body_parts.push("    // @cache_line: 64B aligned\n")
    body_parts.push("    HexaVal __s __attribute__((aligned(64))) = hexa_map_new();\n")
    body_parts.push("    __s = hexa_map_set(__s, \"__type__\", hexa_str(\"" + name + "\"));\n")
    // Add padding marker for hot fields
    body_parts.push("    __s = hexa_map_set(__s, \"__cache_line__\", hexa_int(64));\n")
    let mut i = 0
    while i < len(node.fields) {
        let f = node.fields[i]
        params.push("HexaVal " + f.name)
        body_parts.push("    __s = hexa_map_set(__s, \"" + f.name + "\", " + f.name + ");\n")
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    return "HexaVal " + name + "(" + p + ") {\n" + body_parts.join("") + "    return __s;\n}\n"
}

// ═══════════════════════════════════════════════════════════
//  @branch_predict codegen — __builtin_expect for if-conditions
//  Wraps if-conditions with __builtin_expect(cond, 1) (likely)
//  or __builtin_expect(cond, 0) (unlikely) based on hints.
// ═══════════════════════════════════════════════════════════

fn gen2_branch_predict_cond(cond_expr) {
    // Wrap condition with __builtin_expect(cond, 1) — assume likely path
    return "__builtin_expect(hexa_truthy(" + gen2_expr(cond_expr) + "), 1)"
}

fn gen2_branch_unlikely_cond(cond_expr) {
    return "__builtin_expect(hexa_truthy(" + gen2_expr(cond_expr) + "), 0)"
}

// ═══════════════════════════════════════════════════════════
//  @bitfield codegen helper — bit-packing access macros
//  Generates mask/shift accessors for packed bool fields.
// ═══════════════════════════════════════════════════════════

fn gen2_bitfield_accessor(struct_name, field_name, bit_offset) {
    let mask = "((1ULL << 1) - 1)"
    let getter = "#define " + struct_name + "_get_" + field_name + "(v) ((HX_INT(v) >> " + to_string(bit_offset) + ") & " + mask + ")\n"
    let setter = "#define " + struct_name + "_set_" + field_name + "(v, b) ((v) = HX_MAKE_INT((HX_INT(v) & ~(" + mask + " << " + to_string(bit_offset) + ")) | (((b) & " + mask + ") << " + to_string(bit_offset) + "))))\n"
    return getter + setter
}

// ═══════════════════════════════════════════════════════════
//  Enum codegen — tagged integer #define constants
// ═══════════════════════════════════════════════════════════

fn gen2_enum_decl(node) {
    let name = node.name
    // enum-variant access fix: record this enum's type name so the
    // gen2_expr `if k == "Field"` arm can recognize `<EnumName>.<VARIANT>`
    // and emit the `<EnumName>_<VARIANT>` #define below instead of a
    // bogus hexa_map_get_ic(<typename>, ...) field access. This runs in
    // the decl pass, before any fn body that references the enum.
    _enum_names_add(name)
    // PROBE r15-D14: register every variant name → owner so the gen2_expr
    // Ident arm can rewrite bare `Red` → `Color_Red` (the #define emitted
    // below). Ambiguous variant names (shared across enums) are flagged
    // and skipped at lookup time.
    let mut _vri = 0
    while _vri < len(node.variants) {
        _enum_variant_register(node.variants[_vri].name, name)
        _vri = _vri + 1
    }
    let vc = len(node.variants)
    // @compact enum: compute minimum bits for tag
    let tag_bits = gen2_min_bits(vc)
    // perf: chunks.push + join — avoid O(n^2) string concat
    let mut parts = []
    parts.push("// enum " + name + " (" + to_string(vc) + " variants, " + to_string(tag_bits) + " tag bit(s))\n")
    // For compact enums with <= 255 variants, use uint8_t mask comment
    if tag_bits < 8 {
        parts.push("// @compact: tag fits in " + to_string(tag_bits) + " bit(s), mask=0x" + gen2_hex_mask(tag_bits) + "\n")
    }
    // RFC-020 A4: detect any variant with a payload type (non-empty `items`).
    // Tag macros stay as `hexa_int(N)` (HexaVal) for both forms; payload-bearing
    // variants are constructed at use-sites as a HexaVal array `[tag, payload]`
    // (see gen2_expr EnumPath emission + gen2_match_cond / gen2_match_ternary).
    let mut _has_payload = false
    let mut _pi = 0
    while _pi < vc {
        let _pv = node.variants[_pi]
        if type_of(_pv.items) != "string" && len(_pv.items) > 0 {
            _has_payload = true
        }
        _pi = _pi + 1
    }
    if _has_payload {
        parts.push("// @payload: enum " + name + " carries single-field payload variants — runtime form is HexaVal array [tag, payload]\n")
    }
    // PR-2.2 (enum-to-string-codegen-emit RFC, stack PR-2/3, 2026-05-24):
    // all-unit-variant TAG_ENUM emit. Widens PR-2.1's single-enum gate
    // (`name == "Direction"`) to EVERY unit-variant (payload-free) enum.
    // Each such enum's `#define <Name>_<Variant>` now emits
    // hexa_enum_str("<Name>::<Variant>") (TAG_ENUM) instead of the legacy
    // hexa_int(N) (TAG_INT) form, so `to_string(<Name>::<Variant>)` renders
    // the display literal directly via the live _hexa_to_string_rec TAG_ENUM
    // branch. The migration is value-uniform: the `#define` is the single
    // source for both use-site values AND match-pattern constants, so the
    // match path (gen2_match_cond plain-variant `hexa_eq(scrut, <Name>_<V>)`)
    // stays correct — both operands flow through the same TAG_ENUM literal
    // and hexa_eq's pointer-eq fast-path matches. Payload-bearing enums keep
    // the legacy hexa_int(N) form for ALL their variants (the tag is reused
    // as array index 0 by the `[tag, payload]` runtime shape + the payload
    // match cond `hexa_eq(hexa_index_get(scrut, 0), <Name>_<V>)`), so the
    // `!_has_payload` guard preserves that contract with zero regression.
    // PR-3 swaps the renderer to the __enum_<Name>_names[] table (#555).
    let _enum_tag_migrate = (!_has_payload)
    // PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): unit-variant enums now
    // emit a static HexaEnumDesc per variant carrying display + variant_idx
    // + type_name, so runtime hexa_cmp_{lt,gt,le,ge} can compare same-enum
    // values by declaration order (Rust-derive-Ord). type_name field is a
    // bare string literal in each descriptor (compile-time constant); same-
    // enum gate uses strcmp (display + identity-pointer fast-paths handle
    // the common cases).
    let mut i = 0
    while i < vc {
        let v = node.variants[i]
        if _enum_tag_migrate {
            let desc_sym = "__enum_desc_" + name + "_" + v.name
            parts.push("static const struct HexaEnumDesc " + desc_sym + " = { HEXA_ENUM_DESC_MAGIC, " + to_string(i) + "U, \"" + name + "::" + v.name + "\", \"" + name + "\" };\n")
            parts.push("#define " + name + "_" + v.name + " hexa_enum_str_v(&" + desc_sym + ")\n")
        } else {
            parts.push("#define " + name + "_" + v.name + " hexa_int(" + to_string(i) + ")\n")
        }
        i = i + 1
    }
    // (b) variant names emit — additive metadata (RFC enum-to-string-codegen-emit P2,
    // PR-1 of 3-PR stack). Dead-code OK: no runtime consumer until PR-2 (TAG_ENUM) +
    // PR-3 (`_hexa_to_string_rec` branch) land. Emits per-enum:
    //   static const char* __enum_<Name>_names[<vc>] = { "Var1", "Var2", ... };
    //   static const int   __enum_<Name>_count       = <vc>;
    // Guarded behind `#ifdef HEXA_ENUM_NAMES_TABLE` so additive-only is enforced —
    // C compiler skips entire region unless future PR-2/3 enables the macro. This
    // keeps PR-1 a true no-op at runtime (binary byte-equality preserved) while
    // landing the codegen scaffolding the stack depends on.
    parts.push("#ifdef HEXA_ENUM_NAMES_TABLE\n")
    parts.push("static const char* __enum_" + name + "_names[" + to_string(vc) + "] = {")
    let mut ni = 0
    while ni < vc {
        let nv = node.variants[ni]
        if ni > 0 { parts.push(", ") }
        parts.push("\"" + nv.name + "\"")
        ni = ni + 1
    }
    parts.push("};\n")
    parts.push("static const int __enum_" + name + "_count = " + to_string(vc) + ";\n")
    parts.push("#endif\n")
    return parts.join("")
}

fn gen2_min_bits(count) {
    if count <= 1 { return 1 }
    let mut bits = 0
    let mut v = count - 1
    while v > 0 {
        bits = bits + 1
        v = v / 2
    }
    return bits
}

fn gen2_hex_mask(bits) {
    if bits == 1 { return "01" }
    if bits == 2 { return "03" }
    if bits == 3 { return "07" }
    if bits == 4 { return "0f" }
    if bits == 5 { return "1f" }
    if bits == 6 { return "3f" }
    if bits == 7 { return "7f" }
    return "ff"
}

// ═══════════════════════════════════════════════════════════
//  Match statement — generate if-else chain
// ═══════════════════════════════════════════════════════════

// PROBE r14-VV (SS follow-up): IfLetExpr lowering.
// `if let PAT = SCRUT { THEN } else { ELSE }` desugars to:
//   match SCRUT { PAT => { THEN }, _ => { ELSE } }
// Parser (G32, parser.hexa L2535-2573) already produces IfLetExpr with
// .left=pattern · .right=scrutinee · .then_body=array · .else_body=array.
// We synthesize a MatchExpr node and let gen2_match_stmt / gen2_match_expr
// do the heavy lifting (EnumPath tag-equality + payload binding already
// landed via PR #366). When else_body is missing/empty, the wildcard arm
// emits an empty body — a no-op fallthrough, matching `if cond { ... }`
// without else.
fn _gen2_iflet_to_match(node) {
    let pattern = node.left
    let scrutinee = node.right
    let then_body = node.then_body
    let else_body = node.else_body
    // First arm: PAT => { then_body }
    let arm_then = #{
        "kind": "MatchArm", "name": "", "value": "", "op": "",
        "left": pattern, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": then_body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
    // Second arm: _ => { else_body }  (else_body may be [] when no `else` clause)
    let mut wild_body = else_body
    if type_of(wild_body) == "string" { wild_body = [] }
    let arm_else = #{
        "kind": "MatchArm", "name": "", "value": "", "op": "",
        "left": #{
            "kind": "Wildcard", "name": "_", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        },
        "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": wild_body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
    return #{
        "kind": "MatchExpr", "name": "", "value": "", "op": "",
        "left": scrutinee, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": [arm_then, arm_else], "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// PROBE r14-UUUU: let-else lowering.
// `let PAT = SCRUT else { ELSE }`  ⇒
//   HexaVal __let_else_<n> = SCRUT;
//   if (!cond(__let_else_<n>, PAT)) {
//       <ELSE>      // must diverge — caller's responsibility for v1
//   }
//   <binder = hexa_index_get(__let_else_<n>, hexa_int(k));>   per payload
// The binder names were already hoisted to the function scope by
// _gen2_collect_lets_stmt (LetElseStmt branch), so we emit plain assignment.
// Sibling of _gen2_iflet_to_match — reuses gen2_match_cond for the tag test.
let mut _gen2_letelse_uid = 0
fn gen2_let_else(node, depth) {
    let pad = gen2_indent(depth)
    let pad2 = gen2_indent(depth + 1)
    let scrutinee = gen2_expr(node.right)
    let pat = node.left
    let else_body = node.else_body
    _gen2_letelse_uid = _gen2_letelse_uid + 1
    let tmp = "__let_else_" + to_string(_gen2_letelse_uid)
    let mut chunks = []
    chunks.push(pad + "HexaVal " + tmp + " = " + scrutinee + ";\n")
    let cond = gen2_match_cond(pat, tmp)
    chunks.push(pad + "if (!(" + cond + ")) {\n")
    if type_of(else_body) != "string" {
        let mut ei = 0
        while ei < len(else_body) {
            chunks.push(gen2_stmt(else_body[ei], depth + 1))
            ei = ei + 1
        }
    }
    chunks.push(pad + "}\n")
    // Bind payload(s) — outer-scope (post-test, so code after the let-else
    // sees the binders). When the same name was hoisted (count >= 2 across
    // the fn body) or shadows a fn-param, emit plain assignment; otherwise
    // emit a fresh `HexaVal` declaration and register it so downstream
    // re-emissions don't re-declare.
    if type_of(pat) != "string" && pat.kind == "EnumPath" {
        if type_of(pat.left) != "string" && pat.left.kind == "Ident" && pat.left.name != "_" {
            let _bn = _hexa_mangle_ident(pat.left.name)
            let _decl = "HexaVal "
            if _gen2_has_decl(_bn) { _decl = "" }
            chunks.push(pad + _decl + _bn + " = hexa_index_get(" + tmp + ", hexa_int(1));\n")
            if !_gen2_has_decl(_bn) { _gen2_declared_names.push(_bn) }
        }
        if type_of(pat.items) != "string" {
            let mut _pi = 0
            while _pi < len(pat.items) {
                let _it = pat.items[_pi]
                if type_of(_it) != "string" && _it.kind == "Ident" && _it.name != "_" {
                    let _bn2 = _hexa_mangle_ident(_it.name)
                    let _decl2 = "HexaVal "
                    if _gen2_has_decl(_bn2) { _decl2 = "" }
                    chunks.push(pad + _decl2 + _bn2 + " = hexa_index_get(" + tmp + ", hexa_int(" + to_string(_pi + 1) + "));\n")
                    if !_gen2_has_decl(_bn2) { _gen2_declared_names.push(_bn2) }
                }
                _pi = _pi + 1
            }
        }
    }
    return chunks.join("")
}

fn gen2_match_stmt(node, depth) {
    // PROBE r16-T4: warn on non-exhaustive enum match (statement form).
    _gen2_warn_nonexhaustive_match(node)
    let pad = gen2_indent(depth)
    let scrutinee = gen2_expr(node.left)

    // Store scrutinee in temp to avoid re-evaluation
    let mut chunks = []
    chunks.push(pad + "{\n")
    let pad2 = gen2_indent(depth + 1)
    chunks.push(pad2 + "HexaVal __match_val = " + scrutinee + ";\n")

    let mut ai = 0
    while ai < len(node.arms) {
        let arm = node.arms[ai]
        let pat = arm.left
        let is_wildcard = (type_of(pat) != "string" && pat.kind == "Wildcard")

        if is_wildcard {
            // Default arm — always matches
            if ai > 0 {
                chunks.push(" else {\n")
            } else {
                chunks.push(pad2 + "{\n")
            }
        } else {
            let cond = gen2_match_cond(pat, "__match_val")
            if ai == 0 {
                chunks.push(pad2 + "if (" + cond + ") {\n")
            } else {
                chunks.push(" else if (" + cond + ") {\n")
            }
        }

        // RFC r16 (@ binding): bind the whole scrutinee to the name on the
        // AtBinding wrapper as the first arm-body line (`m @ 1..=5 => …` binds
        // m = the matched value). The match condition was handled by
        // gen2_match_cond recursing into pat.left.
        if type_of(pat) != "string" && pat.kind == "AtBinding" {
            let _atn = pat.name
            if type_of(_atn) == "string" && _atn != "" && _atn != "_" {
                let _padat = gen2_indent(depth + 2)
                chunks.push(_padat + "HexaVal " + _hexa_mangle_ident(_atn) + " = __match_val;\n")
            }
        }
        // RFC-020 A4: emit the payload binding `HexaVal <var> = hexa_index_get(__match_val, hexa_int(1));`
        // as the FIRST line inside this arm's block, when the EnumPath pattern
        // carried a binder (single-field payload only — `Shape::Circle(r)`).
        // pat.left is the inner Ident pattern node; `_` is not a binding.
        if type_of(pat) != "string" && pat.kind == "EnumPath" && type_of(pat.left) != "string" && pat.left.kind == "Ident" {
            let _bn = pat.left.name
            if type_of(_bn) == "string" && _bn != "_" {
                let _pad3 = gen2_indent(depth + 2)
                chunks.push(_pad3 + "HexaVal " + _hexa_mangle_ident(_bn) + " = hexa_index_get(__match_val, hexa_int(1));\n")
            }
        }
        // PROBE r14-HH (CC follow-up to PR #366): multi-arg payload binders
        // (`Shape::Square(w, h)`) live in `pat.items`. Emit one `HexaVal <n>`
        // per Ident item, reading `__match_val[i+1]` (index 0 holds the tag).
        // Wildcard items (`_`) and non-Ident sub-patterns are skipped (no bind).
        if type_of(pat) != "string" && pat.kind == "EnumPath" && type_of(pat.items) != "string" {
            let _pad3 = gen2_indent(depth + 2)
            let mut _pi = 0
            while _pi < len(pat.items) {
                let _it = pat.items[_pi]
                if type_of(_it) != "string" && _it.kind == "Ident" {
                    let _in = _it.name
                    if type_of(_in) == "string" && _in != "_" {
                        chunks.push(_pad3 + "HexaVal " + _hexa_mangle_ident(_in) + " = hexa_index_get(__match_val, hexa_int(" + to_string(_pi + 1) + "));\n")
                    }
                }
                _pi = _pi + 1
            }
        }
        // PROBE r15-D3: Option/Result `Call`-shape pattern arm binding —
        // `Some(v) => …` / `Ok(v)` / `Err(e)` parses as Call{left:Ident,
        // args:[Ident v]}. Bind each Ident arg from __match_val[i+1] (index 0
        // = tag, mirroring EnumPath payload convention). Wildcards skipped.
        if type_of(pat) != "string" && pat.kind == "Call" && type_of(pat.left) != "string" && pat.left.kind == "Ident" {
            let _cn2 = pat.left.name
            if (_cn2 == "Some" || _cn2 == "Ok" || _cn2 == "Err") && type_of(pat.args) != "string" {
                let _pad3 = gen2_indent(depth + 2)
                let mut _ai = 0
                while _ai < len(pat.args) {
                    let _it = pat.args[_ai]
                    if type_of(_it) != "string" && _it.kind == "Ident" {
                        let _in = _it.name
                        if type_of(_in) == "string" && _in != "_" {
                            chunks.push(_pad3 + "HexaVal " + _hexa_mangle_ident(_in) + " = hexa_index_get(__match_val, hexa_int(" + to_string(_ai + 1) + "));\n")
                        }
                    }
                    // PROBE r16 Q3: nested Call arg `Some(Ok(v))` — the inner
                    // payload binder `v` lives at __match_val[outer+1][inner+1].
                    // Walk the inner Call's args and bind each Ident from the
                    // payload sub-array (was undeclared → clang error).
                    if type_of(_it) != "string" && _it.kind == "Call" && type_of(_it.left) != "string" && _it.left.kind == "Ident" {
                        let _innerc = _it.left.name
                        if (_innerc == "Some" || _innerc == "Ok" || _innerc == "Err") && type_of(_it.args) != "string" {
                            let _payload = "hexa_index_get(__match_val, hexa_int(" + to_string(_ai + 1) + "))"
                            let mut _ii = 0
                            while _ii < len(_it.args) {
                                let _iit = _it.args[_ii]
                                if type_of(_iit) != "string" && _iit.kind == "Ident" {
                                    let _iin = _iit.name
                                    if type_of(_iin) == "string" && _iin != "_" {
                                        chunks.push(_pad3 + "HexaVal " + _hexa_mangle_ident(_iin) + " = hexa_index_get(" + _payload + ", hexa_int(" + to_string(_ii + 1) + "));\n")
                                    }
                                }
                                _ii = _ii + 1
                            }
                        }
                    }
                    _ai = _ai + 1
                }
            }
        }

        // Arm body — scope-isolate the comptime-const fold table so a
        // `let x = <lit>` in this arm does not leak its folded literal into a
        // sibling arm or the enclosing scope (statement-position sibling to the
        // _gen2_arm_block_expr fix; closes the integer-match block-body scope
        // leak: arm-3 `a` was inlined to arm-1's stale value → 210 not 300).
        let _cc_mark = _comptime_const_scope_mark()
        let mut bi = 0
        while bi < len(arm.body) {
            chunks.push(gen2_stmt(arm.body[bi], depth + 2))
            bi = bi + 1
        }
        _comptime_const_scope_restore(_cc_mark)
        chunks.push(pad2 + "}")
        ai = ai + 1
    }
    chunks.push("\n" + pad + "}\n")
    return chunks.join("")
}

fn gen2_match_cond(pat, scrutinee_var) {
    if type_of(pat) == "string" {
        return "1"
    }
    let k = pat.kind
    if k == "Wildcard" {
        return "1"
    }
    // RFC r16 (@ binding): the match test is the sub-pattern's condition; the
    // bind itself is emitted at the arm body / value site. Recurse on the
    // wrapped sub-pattern (e.g. `n @ 1..=5` tests the `1..=5` range).
    if k == "AtBinding" {
        return gen2_match_cond(pat.left, scrutinee_var)
    }
    // OR-pattern: pattern grammar reuses parse_expr which greedy-
    // consumed `1 | 2 | 3` as a BinOp(|, …) tree.  Split into a real
    // disjunction.  Without this `match v { 1|2|3 => … }` compiled to
    // `hexa_eq(v, 1|2|3=3)` — only v==3 matched.  Round-5 pattern
    // probe finding (Class-1 silent failure).
    if k == "BinOp" && pat.op == "|" {
        let _lc = gen2_match_cond(pat.left, scrutinee_var)
        let _rc = gen2_match_cond(pat.right, scrutinee_var)
        return "(" + _lc + " || " + _rc + ")"
    }
    // Range pattern: `0..10` (exclusive) / `0..=10` (inclusive).
    // parse_expr emits a `Range` node in expression position; the
    // generic codegen lowered it to `hexa_range_array` and then
    // `hexa_eq` compared the scrutinee int to the array — never
    // matched.  Pattern semantics need a membership test.
    if k == "Range" {
        let _lo = gen2_expr(pat.left)
        let _hi = gen2_expr(pat.right)
        let _ge = "hexa_truthy(hexa_cmp_ge(" + scrutinee_var + ", " + _lo + "))"
        let mut _cmp_hi = "hexa_cmp_lt"
        if pat.value == "inclusive" { _cmp_hi = "hexa_cmp_le" }
        let _hi_test = "hexa_truthy(" + _cmp_hi + "(" + scrutinee_var + ", " + _hi + "))"
        return "(" + _ge + " && " + _hi_test + ")"
    }
    if k == "IntLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_int(" + pat.value + ")))"
    }
    if k == "FloatLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_float(" + pat.value + ")))"
    }
    if k == "StringLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_str(\"" + c_escape(pat.value) + "\")))"
    }
    if k == "BoolLit" {
        if pat.value == "true" {
            return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_bool(1)))"
        }
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_bool(0)))"
    }
    // PROBE r15-D3: Option/Result `Call`-shape patterns — `Some(v)` / `Ok(v)`
    // / `Err(e)` reach the parser as `Call{left:Ident, args:[…]}` (see
    // parse_match_pattern fallthrough to parse_expr). Test the tag at index 0
    // with HX_IS_ARRAY guard, mirroring the EnumPath single-binder arm below.
    // The actual `v` binding is emitted in gen2_match_stmt / gen2_match_ternary
    // (sibling EnumPath logic was extended to recognize the same shape).
    if k == "Call" && type_of(pat.left) != "string" && pat.left.kind == "Ident" {
        let _cn = pat.left.name
        if _cn == "Some" || _cn == "Ok" || _cn == "Err" {
            let _outer = "(HX_IS_ARRAY(" + scrutinee_var + ") && hexa_truthy(hexa_eq(hexa_index_get(" + scrutinee_var + ", hexa_int(0)), hexa_str(\"" + _cn + "\"))))"
            // PROBE r16 Q3: nested Call-shape payload `Some(Ok(v))` — the single
            // arg is itself a `Some`/`Ok`/`Err` Call pattern. The payload lives at
            // scrutinee[1]; recurse gen2_match_cond against that inner accessor so
            // the inner tag is ALSO tested (was matching outer level only). Plain
            // (non-Call) args stay irrefutable — bound, not tested.
            if type_of(pat.args) != "string" && len(pat.args) == 1 {
                let _arg0 = pat.args[0]
                if type_of(_arg0) != "string" && _arg0.kind == "Call" && type_of(_arg0.left) != "string" && _arg0.left.kind == "Ident" {
                    let _icn = _arg0.left.name
                    if _icn == "Some" || _icn == "Ok" || _icn == "Err" {
                        let _inner = gen2_match_cond(_arg0, "hexa_index_get(" + scrutinee_var + ", hexa_int(1))")
                        return "(" + _outer + " && " + _inner + ")"
                    }
                }
            }
            return _outer
        }
    }
    // PROBE r15-D3: bare `None` pattern → tag-equality with hexa_str("None").
    // Routed before the generic Ident-binder logic in gen2_match_ternary so
    // `None` is REFUTABLE (not an irrefutable binder of the scrutinee). The
    // stmt-form binder block in gen2_match_stmt similarly skips it.
    if k == "Ident" && pat.name == "None" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_str(\"None\")))"
    }
    if k == "EnumPath" {
        let enum_const = pat.name + "_" + pat.value
        // RFC-020 A4: payload-binder pattern (e.g. `Shape::Circle(r)`) — pat.left
        // holds the inner pattern node. The scrutinee then carries the runtime
        // array form `[tag, payload]`; compare the *tag only* (index 0), gated
        // on HX_IS_ARRAY so a bare-tag unit value can't crash. Plain (no-binder)
        // variants keep the original whole-value equality test.
        // PROBE r14-HH (CC follow-up to PR #366): multi-arg payload form
        // (`Shape::Square(w, h)`) lives in `pat.items` (parse_match_pattern
        // stores plist there when len > 1). Same array+tag test applies.
        if type_of(pat.left) != "string" {
            return "(HX_IS_ARRAY(" + scrutinee_var + ") && hexa_truthy(hexa_eq(hexa_index_get(" + scrutinee_var + ", hexa_int(0)), " + enum_const + ")))"
        }
        if type_of(pat.items) != "string" && len(pat.items) > 0 {
            return "(HX_IS_ARRAY(" + scrutinee_var + ") && hexa_truthy(hexa_eq(hexa_index_get(" + scrutinee_var + ", hexa_int(0)), " + enum_const + ")))"
        }
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", " + enum_const + "))"
    }
    // Fallback: compare with the expression
    return "hexa_truthy(hexa_eq(" + scrutinee_var + ", " + gen2_expr(pat) + "))"
}

// ═══════════════════════════════════════════════════════════
//  Match expression (value-producing) — uses ternary chain
// ═══════════════════════════════════════════════════════════

fn gen2_match_expr(node) {
    // PROBE r16-T4: warn on non-exhaustive enum match (expression / ternary
    // form — this is the path that silently falls through to hexa_void()).
    _gen2_warn_nonexhaustive_match(node)
    let scrutinee = gen2_expr(node.left)
    // Build a nested ternary: (cond1 ? val1 : (cond2 ? val2 : default))
    // For simplicity, wrap in a compound expression using GCC ({...})
    // Instead, just produce the ternary chain
    let arms = node.arms
    return gen2_match_ternary(arms, scrutinee, 0)
}

// decreases arms — structural
fn gen2_match_ternary(arms, scrutinee_c, idx) {
    if idx >= len(arms) {
        return "hexa_void()"
    }
    let arm = arms[idx]
    let pat = arm.left
    let is_wildcard = (type_of(pat) != "string" && pat.kind == "Wildcard")

    // A bare lowercase Ident pattern (`n -> …` / `n if g -> …`) is an
    // IRREFUTABLE BINDING (Rust-canonical): it binds the scrutinee to `n`
    // and always matches. Previously gen2_match_cond fell through to the
    // equality fallback `hexa_eq(scrutinee, n)` with `n` undeclared — a
    // clang hard-error — AND the guard referencing `n` was emitted with
    // `n` out of scope. Detect it here so both the guard and the value
    // get `n` bound via a stmt-expr (round-5 binding-arm + guard fix;
    // sibling to the EnumPath payload-binder handling below).
    let mut _bind_name = ""
    if type_of(pat) != "string" && pat.kind == "Ident" {
        let _pn = pat.name
        // PROBE r15-D3: exclude Option/Result tag names from irrefutable
        // bare-Ident binder logic — `None` is a refutable tag pattern
        // (handled in gen2_match_cond above). `Some`/`Ok`/`Err` always
        // appear as Call shapes; defensively excluded too.
        if type_of(_pn) == "string" && _pn != "_" && _pn != "None" && _pn != "Some" && _pn != "Ok" && _pn != "Err" {
            _bind_name = _pn
        }
    }

    // Get the value from the arm body (last expr)
    let mut val = gen2_arm_value(arm.body)

    // RFC-020 A4: if the EnumPath pattern carries a payload binder, the arm
    // value may reference it (e.g. `Shape::Circle(r) -> r * r * 3`). A ternary
    // chain can't introduce a C local mid-expression, so wrap the value in a
    // GCC statement-expression that binds the var from `scrutinee_c[1]`.
    let mut _enum_bind_name = ""
    if type_of(pat) != "string" && pat.kind == "EnumPath" && type_of(pat.left) != "string" && pat.left.kind == "Ident" {
        let _bn = pat.left.name
        if type_of(_bn) == "string" && _bn != "_" {
            _enum_bind_name = _bn
            val = "({ HexaVal " + _hexa_mangle_ident(_bn) + " = hexa_index_get(" + scrutinee_c + ", hexa_int(1)); (" + val + "); })"
        }
    }
    // PROBE r14-HH (CC follow-up to PR #366): multi-arg payload binders in
    // ternary-form match expressions. Compose all bindings into the GCC
    // stmt-expr wrap; each item reads `scrutinee_c[i+1]` (i=0 is the tag).
    if type_of(pat) != "string" && pat.kind == "EnumPath" && type_of(pat.items) != "string" && len(pat.items) > 0 {
        let mut _binds = ""
        let mut _pi = 0
        while _pi < len(pat.items) {
            let _it = pat.items[_pi]
            if type_of(_it) != "string" && _it.kind == "Ident" {
                let _in = _it.name
                if type_of(_in) == "string" && _in != "_" {
                    _binds = _binds + "HexaVal " + _hexa_mangle_ident(_in) + " = hexa_index_get(" + scrutinee_c + ", hexa_int(" + to_string(_pi + 1) + ")); "
                }
            }
            _pi = _pi + 1
        }
        if len(_binds) > 0 {
            val = "({ " + _binds + "(" + val + "); })"
        }
    }
    // PROBE r15-D3: Call-shape Option/Result payload binders (`Some(v)` /
    // `Ok(v)` / `Err(e)`) in ternary-form match. Wrap val (and the guard
    // below) in a stmt-expr that binds each Ident arg from scrutinee[i+1].
    // Sibling to the EnumPath wrap above; uses pat.args instead of pat.items.
    let mut _call_binds = ""
    if type_of(pat) != "string" && pat.kind == "Call" && type_of(pat.left) != "string" && pat.left.kind == "Ident" {
        let _cn3 = pat.left.name
        if (_cn3 == "Some" || _cn3 == "Ok" || _cn3 == "Err") && type_of(pat.args) != "string" {
            let mut _ai = 0
            while _ai < len(pat.args) {
                let _it = pat.args[_ai]
                if type_of(_it) != "string" && _it.kind == "Ident" {
                    let _in = _it.name
                    if type_of(_in) == "string" && _in != "_" {
                        _call_binds = _call_binds + "HexaVal " + _hexa_mangle_ident(_in) + " = hexa_index_get(" + scrutinee_c + ", hexa_int(" + to_string(_ai + 1) + ")); "
                    }
                }
                // PROBE r16 Q3: nested Call arg `Some(Ok(v))` in ternary-form
                // match. The inner binder `v` reads scrutinee[outer+1][inner+1].
                if type_of(_it) != "string" && _it.kind == "Call" && type_of(_it.left) != "string" && _it.left.kind == "Ident" {
                    let _innerc3 = _it.left.name
                    if (_innerc3 == "Some" || _innerc3 == "Ok" || _innerc3 == "Err") && type_of(_it.args) != "string" {
                        let _payload3 = "hexa_index_get(" + scrutinee_c + ", hexa_int(" + to_string(_ai + 1) + "))"
                        let mut _ii = 0
                        while _ii < len(_it.args) {
                            let _iit = _it.args[_ii]
                            if type_of(_iit) != "string" && _iit.kind == "Ident" {
                                let _iin = _iit.name
                                if type_of(_iin) == "string" && _iin != "_" {
                                    _call_binds = _call_binds + "HexaVal " + _hexa_mangle_ident(_iin) + " = hexa_index_get(" + _payload3 + ", hexa_int(" + to_string(_ii + 1) + ")); "
                                }
                            }
                            _ii = _ii + 1
                        }
                    }
                }
                _ai = _ai + 1
            }
            if len(_call_binds) > 0 {
                val = "({ " + _call_binds + "(" + val + "); })"
            }
        }
    }
    // RFC r16 (@ binding): bind the whole scrutinee to the AtBinding name in
    // the arm value (and the guard, below). Unlike the bare-Ident binder this
    // is REFUTABLE — the sub-pattern still gates the arm (cond comes from
    // gen2_match_cond, which recurses through AtBinding into the sub-pattern).
    let mut _at_bind_name = ""
    if type_of(pat) != "string" && pat.kind == "AtBinding" {
        let _atn2 = pat.name
        if type_of(_atn2) == "string" && _atn2 != "" && _atn2 != "_" {
            _at_bind_name = _atn2
            val = "({ HexaVal " + _hexa_mangle_ident(_atn2) + " = " + scrutinee_c + "; (" + val + "); })"
        }
    }
    // Bare-Ident binder: bind the whole scrutinee into the arm value.
    if len(_bind_name) > 0 {
        val = "({ HexaVal " + _hexa_mangle_ident(_bind_name) + " = " + scrutinee_c + "; (" + val + "); })"
    }

    // Build pattern-match condition; wildcard + bare-Ident binder are
    // unconditional (both always match the value, refutation is the guard).
    // An AtBinding is refutable — its cond is the sub-pattern's test.
    let mut cond = ""
    if is_wildcard || len(_bind_name) > 0 {
        cond = "1"
    } else {
        cond = gen2_match_cond(pat, scrutinee_c)
    }
    // Guard (`pat if cond_expr => …` / `_ if cond_expr => …`) — AND
    // into the arm condition. Without this the parser-captured guard
    // (`arm.cond`) was silently dropped at codegen and the arm fired
    // regardless of the guard's value — round-5 pattern probe
    // headline finding (Class-1 silent failure: wrong arm executes).
    let _guard = arm.cond
    let _has_guard = type_of(_guard) != "string"
    if _has_guard {
        let mut _guard_c = gen2_expr(_guard)
        // For a bare-Ident binder the guard references `n` — bind it in a
        // stmt-expr so the guard sees the scrutinee.
        if len(_bind_name) > 0 {
            _guard_c = "({ HexaVal " + _hexa_mangle_ident(_bind_name) + " = " + scrutinee_c + "; (" + _guard_c + "); })"
        }
        // PROBE r14-BBBB (ZZZ-1 follow-up): for an EnumPath payload binder
        // (e.g. `Some(n) if n > 0 => …`) the guard expression refers to the
        // payload binding `n`. Previously the wrap happened only for `val`,
        // so the guard hit clang with `undeclared n`. Mirror the same
        // stmt-expr wrap into the guard so `n` is in scope for the cond too.
        if len(_enum_bind_name) > 0 {
            _guard_c = "({ HexaVal " + _hexa_mangle_ident(_enum_bind_name) + " = hexa_index_get(" + scrutinee_c + ", hexa_int(1)); (" + _guard_c + "); })"
        }
        // PROBE r15-D3: same wrap for Call-shape Option/Result binders so the
        // guard sees the bound payload names (`Some(n) if n > 0 => …`).
        if len(_call_binds) > 0 {
            _guard_c = "({ " + _call_binds + "(" + _guard_c + "); })"
        }
        // RFC r16 (@ binding): the guard may reference the bound name
        // (`m @ 1..=5 if m > 2 => …`) — bind it in a stmt-expr too.
        if len(_at_bind_name) > 0 {
            _guard_c = "({ HexaVal " + _hexa_mangle_ident(_at_bind_name) + " = " + scrutinee_c + "; (" + _guard_c + "); })"
        }
        cond = "(" + cond + " && hexa_truthy(" + _guard_c + "))"
    }

    // Pure wildcard with no guard short-circuits to the value (existing
    // optimization — must check `!has_guard` so `_ if cond` still
    // emits a real check).
    if is_wildcard && !_has_guard {
        return val
    }
    if idx == len(arms) - 1 {
        return "(" + cond + " ? " + val + " : hexa_void())"
    }
    let rest = gen2_match_ternary(arms, scrutinee_c, idx + 1)
    return "(" + cond + " ? " + val + " : " + rest + ")"
}

fn gen2_arm_value(body) {
    if type_of(body) == "string" || len(body) == 0 {
        return "hexa_void()"
    }
    // 2026-04-27: same drop-inner-let class IfExpr had (commit d66037a6).
    // A match arm body like `{ let a = 1; a + 1 }` cannot be collapsed to
    // its tail expression alone — the LetStmt has to emit before the tail
    // reads its binding. Non-trivial bodies route through the shared
    // _gen2_arm_block_expr stmt-expr emitter; trivial single-tail bodies
    // keep the existing inline path so the ternary chain stays compact.
    if !_gen2_arm_is_trivial(body) {
        return _gen2_arm_block_expr(body)
    }
    // Use the last statement's expression as the value
    let last = body[len(body) - 1]
    if last.kind == "ExprStmt" {
        return gen2_expr(last.left)
    }
    if last.kind == "ReturnStmt" {
        if type_of(last.left) != "string" {
            return gen2_expr(last.left)
        }
    }
    return "hexa_void()"
}

// ═══════════════════════════════════════════════════════════
//  Lambda / closure codegen
//  Non-capturing: generate a static C function
//  Capturing: generate closure struct + function
// ═══════════════════════════════════════════════════════════

// ── Method registry for ImplBlock (P2-6 struct method dispatch) ──
// Entries are [method_name, type_name] pairs. Populated during ImplBlock
// codegen, consumed by Call-on-Field codegen to emit runtime-dispatched
// mangled calls (Type__method) guarded by hexa_is_type().
let mut _method_registry = []

// Current impl target while emitting methods of an `impl T { ... }` block.
// gen2_impl_block sets this before walking each method body and restores
// it after. Consumed by StructInit codegen so `Self { … }` literals
// inside the impl body resolve to the enclosing target type T.
let mut _cur_impl_target = ""

fn _method_registry_lookup(name) {
    let mut out = []
    let mut i = 0
    while i < len(_method_registry) {
        let e = _method_registry[i]
        if e[0] == name {
            out.push(e[1])
        }
        i = i + 1
    }
    return out
}

// Emit one C function per impl method using mangled name Type__method.
// Returns a map with `forward` and `fn_code` strings and registers each
// method into `_method_registry`.
fn gen2_impl_block(node) {
    let type_n = node.target
    // Push impl-target onto the codegen context so `Self { … }` ctor
    // literals inside method bodies resolve to type_n.  Save+restore
    // around the method-walk so a nested impl keeps proper nesting.
    let _prev_impl_target = _cur_impl_target
    _cur_impl_target = type_n
    let mut fwd_chunks = []
    let mut fn_chunks = []
    let methods = node.methods
    let mut mi = 0
    while mi < len(methods) {
        let m = methods[mi]
        let mangled = type_n + "__" + m.name
        // Register method for dispatch
        _method_registry.push([m.name, type_n])
        // Build param list (self + extras)
        let mut params = []
        let mut pi = 0
        while pi < len(m.params) {
            params.push("HexaVal " + m.params[pi].name)
            pi = pi + 1
        }
        let p = params.join(", ")
        if p == "" { p = "void" }
        fwd_chunks.push("HexaVal " + mangled + "(" + p + ");\n")
        // Body
        let mut body_chunks = []
        body_chunks.push("HexaVal " + mangled + "(" + p + ") {\n")
        let mut bi = 0
        while bi < len(m.body) {
            body_chunks.push(gen2_stmt(m.body[bi], 1))
            bi = bi + 1
        }
        body_chunks.push("    return hexa_void();\n}\n\n")
        fn_chunks.push(body_chunks.join(""))
        mi = mi + 1
    }
    _cur_impl_target = _prev_impl_target
    return #{
        "forward": fwd_chunks.join(""),
        "fn_code": fn_chunks.join("")
    }
}

let mut _lambda_counter = 0
// perf: use array accumulator — avoid O(n²) string concat for lambda defs
let mut _lambda_def_parts = []
// FIX-B (T33 aliasing follow-up, 2026-04-19): per-lambda param-signature
// slots. Was `_lambda_fwd_parts` module-array push — same T33-class freelist
// aliasing that bit `_ic_def_parts` (fcf275f4) and `_strlit_def_parts`
// (rt#32-SL) — first element / string literals occasionally eaten under
// arena reuse, producing "xa_sl_2 = hexa_str(..)" garbage lines and missing
// lambda fwd decls. Fix = counter-driven regeneration: store `p` per slot,
// emit `HexaVal __hexa_lambda_i(p);\n` in a `while i < _lambda_counter`
// loop at codegen emit time. Module-level accumulator deleted. Mirrored in
// self/native/hexa_cc.c.
let mut _lambda_fwd_sigs = []

// Normalize a lambda/fn parameter entry to the bare identifier name.
// `fn(x)` parser produces Param {name:"x", value:typ} objects; `|x|` parser
// produces bare strings. Both paths funnel into gen2_lambda_expr /
// gen2_collect_free — without normalization the Param-object branch
// stringifies as "<value>" and param names leak as "free vars" at call sites.
fn _lambda_param_name(p) {
    if type_of(p) == "string" { return p }
    return to_string(p.name)
}

// ── rt#37: Inline cache for field access ─────────────────
// Each `obj.field` emits a unique `static HexaIC __hexa_ic_N` slot and a
// `hexa_map_get_ic(obj, "field", &__hexa_ic_N)` call. The slot is zero-
// initialized; on first call it caches (keys_ptr, len, idx) and every
// subsequent monomorphic hit skips the strcmp-chain in hexa_map_get.
//
// The native-C codegen (self/native/hexa_cc.c) honors
// HEXA_IC_DISABLE=1 at codegen time for A/B benchmarking. This .hexa mirror
// is kept in sync but always emits IC — hexat is the active backend.
let mut _ic_counter = 0

// ── ComptimeConst const-fold table ───────────────────────
// `comptime const X = expr` is folded at codegen time to a literal AST node.
// Both arrays MUST be reset at the start of every codegen invocation
// (codegen_c2 / codegen_full) — see T0 lesson on _ic_def_parts.
//
// _comptime_const_names: parallel array of folded const names (strings)
// _comptime_const_nodes: parallel array of folded literal nodes
//
// On Ident lookup in gen2_expr, if name appears here, the corresponding
// folded literal is inlined via recursive gen2_expr() — turning
// `comptime const TAU = 2 * 3.14` followed by `print(TAU + 1)` into
// `hexa_add(hexa_float(6.28), hexa_int(1))` at codegen time.
let mut _comptime_const_names = []
let mut _comptime_const_nodes = []

// ── M4: String literal deduplication ────────────────────
// Each unique string literal gets a single `static const char*` + cached
// HexaVal at file scope. Repeated uses reference the cached HexaVal instead
// of calling hexa_str() (which does strlen+hash+intern) every time.
// _strlit_keys: unique escaped string values (parallel with _strlit_ids)
// _strlit_ids:  C identifier suffix for each (index number)
let mut _strlit_keys = []
let mut _strlit_ids = []
// rt#32-SL: _strlit_def_parts removed — decls regenerated by _strlit_counter
// loop at emit time (mirror of fcf275f4 IC fix).
let mut _strlit_counter = 0

// Destructure tmp-name counter (PROBE r7).  Each DestructLetStmt /
// MapDestructLetStmt allocates a fresh `__destr_<N>` to single-eval the rhs.
let mut _destr_counter = 0

// Look up a comptime-const folded literal by name.
// Returns the literal node on hit, or "" (string) on miss.
fn _lookup_comptime_const(name) {
    let mut i = 0
    while i < len(_comptime_const_names) {
        if _comptime_const_names[i] == name {
            return _comptime_const_nodes[i]
        }
        i = i + 1
    }
    return ""
}

// M4: Get or register a deduplicated string literal. Returns C expression
// referencing the cached static HexaVal (e.g. "__hexa_sl_0").
// `escaped` is the already-C-escaped string content (without quotes).
fn _strlit_dedup(escaped) {
    let mut i = 0
    while i < len(_strlit_keys) {
        if _strlit_keys[i] == escaped {
            return "__hexa_sl_" + to_string(_strlit_ids[i])
        }
        i = i + 1
    }
    // New unique literal — register
    let id = _strlit_counter
    _strlit_counter = _strlit_counter + 1
    _strlit_keys.push(escaped)
    _strlit_ids.push(id)
    let varname = "__hexa_sl_" + to_string(id)
    // rt#32-SL: no push into _strlit_def_parts — decls emitted via
    // deterministic _strlit_counter loop in codegen_c2 main emit path.
    return varname
}

// Build a literal AST node for the const-fold result. We construct minimal
// nodes inline (rather than calling parser helpers) to avoid cross-module
// import dependencies.
fn _make_int_lit_node(val_str) {
    return #{
        "kind": "IntLit", "name": "", "value": val_str, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn _make_float_lit_node(val_str) {
    return #{
        "kind": "FloatLit", "name": "", "value": val_str, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn _make_bool_lit_node(b) {
    let v = if b { "true" } else { "false" }
    return #{
        "kind": "BoolLit", "name": "", "value": v, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// Extract numeric value as float (safe for mixed int/float arithmetic).
fn _cf_as_float(lit) {
    if lit.kind == "FloatLit" { return to_float(lit.value) }
    return to_float(to_string(to_int(lit.value)))
}

// Compile-time evaluator. Returns a literal AST node on success
// (kind ∈ {IntLit, FloatLit, StringLit, BoolLit}), or "" (string) on failure.
//
// Supported folds:
//   - terminal literals: IntLit, FloatLit, StringLit, BoolLit (returned as-is)
//   - Ident → looked up in comptime-const table (inlines folded value)
//   - UnaryOp("-", const) → negation (int/float)
//   - UnaryOp("!", BoolLit) → logical not
//   - BinOp(+, -, *, /, %) on numeric literals → arithmetic (int+int → int,
//     either side float → float; / and % only int)
//   - BinOp(==, !=, <, >, <=, >=) on numeric/string/bool literals → BoolLit
//   - BinOp(&&, ||) with short-circuit on bool literals
//   - IfExpr(BoolLit cond) → evaluates chosen branch at comptime
//   - Call(abs|min|max|sqrt|floor|ceil) with literal args → numeric literal
// All other expressions return "" — caller falls back to runtime emission.
// decreases node — structural
fn comptime_eval(node) {
    if type_of(node) == "string" { return "" }
    let k = node.kind
    if k == "IntLit" { return node }
    if k == "FloatLit" { return node }
    if k == "StringLit" { return node }
    if k == "BoolLit" { return node }
    if k == "Ident" {
        return _lookup_comptime_const(node.name)
    }
    if k == "UnaryOp" {
        let op = node.op
        let v = comptime_eval(node.left)
        if type_of(v) == "string" { return "" }
        if op == "-" {
            if v.kind == "IntLit" {
                let i = -to_int(v.value)
                return _make_int_lit_node(to_string(i))
            }
            if v.kind == "FloatLit" {
                let f = -to_float(v.value)
                return _make_float_lit_node(to_string(f))
            }
            return ""
        }
        if op == "!" {
            if v.kind == "BoolLit" {
                return _make_bool_lit_node(v.value != "true")
            }
            return ""
        }
        return ""
    }
    if k == "BinOp" {
        let op = node.op
        // Short-circuit logical operators — evaluate LHS first.
        if op == "&&" {
            let ll = comptime_eval(node.left)
            if type_of(ll) == "string" { return "" }
            if ll.kind != "BoolLit" { return "" }
            if ll.value != "true" { return _make_bool_lit_node(false) }
            let rr = comptime_eval(node.right)
            if type_of(rr) == "string" { return "" }
            if rr.kind != "BoolLit" { return "" }
            return _make_bool_lit_node(rr.value == "true")
        }
        if op == "||" {
            let ll = comptime_eval(node.left)
            if type_of(ll) == "string" { return "" }
            if ll.kind != "BoolLit" { return "" }
            if ll.value == "true" { return _make_bool_lit_node(true) }
            let rr = comptime_eval(node.right)
            if type_of(rr) == "string" { return "" }
            if rr.kind != "BoolLit" { return "" }
            return _make_bool_lit_node(rr.value == "true")
        }
        let l = comptime_eval(node.left)
        if type_of(l) == "string" { return "" }
        let r = comptime_eval(node.right)
        if type_of(r) == "string" { return "" }
        let lk = l.kind
        let rk = r.kind
        // Comparison operators: fold when operands agree in category.
        if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" {
            // String comparison (== / != only — lexicographic folds skipped
            // because hexa's int comparison on strings is not guaranteed).
            if lk == "StringLit" && rk == "StringLit" {
                if op == "==" { return _make_bool_lit_node(l.value == r.value) }
                if op == "!=" { return _make_bool_lit_node(l.value != r.value) }
                return ""
            }
            if lk == "BoolLit" && rk == "BoolLit" {
                if op == "==" { return _make_bool_lit_node(l.value == r.value) }
                if op == "!=" { return _make_bool_lit_node(l.value != r.value) }
                return ""
            }
            let l_num = lk == "IntLit" || lk == "FloatLit"
            let r_num = rk == "IntLit" || rk == "FloatLit"
            if !l_num || !r_num { return "" }
            // Mixed int/float → compare as float.
            let mixed = lk == "FloatLit" || rk == "FloatLit"
            if mixed {
                let lf = _cf_as_float(l)
                let rf = _cf_as_float(r)
                if op == "==" { return _make_bool_lit_node(lf == rf) }
                if op == "!=" { return _make_bool_lit_node(lf != rf) }
                if op == "<"  { return _make_bool_lit_node(lf < rf) }
                if op == ">"  { return _make_bool_lit_node(lf > rf) }
                if op == "<=" { return _make_bool_lit_node(lf <= rf) }
                if op == ">=" { return _make_bool_lit_node(lf >= rf) }
                return ""
            }
            let li_c = to_int(l.value)
            let ri_c = to_int(r.value)
            if op == "==" { return _make_bool_lit_node(li_c == ri_c) }
            if op == "!=" { return _make_bool_lit_node(li_c != ri_c) }
            if op == "<"  { return _make_bool_lit_node(li_c < ri_c) }
            if op == ">"  { return _make_bool_lit_node(li_c > ri_c) }
            if op == "<=" { return _make_bool_lit_node(li_c <= ri_c) }
            if op == ">=" { return _make_bool_lit_node(li_c >= ri_c) }
            return ""
        }
        // String concat via +.
        if op == "+" && lk == "StringLit" && rk == "StringLit" {
            return #{
                "kind": "StringLit", "name": "", "value": l.value + r.value, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // Only numeric operands fold for arithmetic below.
        if lk != "IntLit" && lk != "FloatLit" { return "" }
        if rk != "IntLit" && rk != "FloatLit" { return "" }
        let is_float = lk == "FloatLit" || rk == "FloatLit"
        if is_float {
            // Float arithmetic: + - * / supported, % not.
            let lf = _cf_as_float(l)
            let rf = _cf_as_float(r)
            if op == "+" { return _make_float_lit_node(to_string(lf + rf)) }
            if op == "-" { return _make_float_lit_node(to_string(lf - rf)) }
            if op == "*" { return _make_float_lit_node(to_string(lf * rf)) }
            if op == "/" {
                if rf == 0.0 { return "" }
                return _make_float_lit_node(to_string(lf / rf))
            }
            return ""
        }
        // Pure int arithmetic.
        let li = to_int(l.value)
        let ri = to_int(r.value)
        if op == "+" { return _make_int_lit_node(to_string(li + ri)) }
        if op == "-" { return _make_int_lit_node(to_string(li - ri)) }
        if op == "*" { return _make_int_lit_node(to_string(li * ri)) }
        if op == "/" {
            if ri == 0 { return "" }
            return _make_int_lit_node(to_string(li / ri))
        }
        if op == "%" {
            if ri == 0 { return "" }
            return _make_int_lit_node(to_string(li % ri))
        }
        // G40: bitwise comptime fold — & | ^ only (no native << >> in host)
        if op == "&" { return _make_int_lit_node(to_string(li & ri)) }
        if op == "|" { return _make_int_lit_node(to_string((li + ri) - (li & ri))) }
        if op == "^" { return _make_int_lit_node(to_string(li ^ ri)) }
        return ""
    }
    // IfExpr with a comptime-foldable condition → fold to chosen branch value.
    // Branches are stmt arrays; we only extract the last ExprStmt's expr,
    // matching codegen's runtime IfExpr shape. Silent-skip on mismatch.
    if k == "IfExpr" {
        let c = comptime_eval(node.cond)
        if type_of(c) == "string" { return "" }
        if c.kind != "BoolLit" { return "" }
        let pick_true = c.value == "true"
        let body = if pick_true { node.then_body } else { node.else_body }
        if type_of(body) == "string" { return "" }
        if len(body) == 0 { return "" }
        let last = body[len(body) - 1]
        if type_of(last) == "string" { return "" }
        if last.kind != "ExprStmt" { return "" }
        if type_of(last.left) == "string" { return "" }
        return comptime_eval(last.left)
    }
    // Call(name, args) — fold a small whitelist of pure builtins.
    //
    // 2026-05-24 FIX: parser.hexa:3309-3320 emits `Call` with `name=""` and
    // the callee in `left` (must be `Ident`). Reading `node.name` always got
    // "", so NO BuiltinCall ever folded at codegen time — int/int min/max
    // happened to match runtime by coincidence, but `min(2, 1.5)` exposed
    // the latent gap (runtime emit at gen2_expr L5437 cast both to int64).
    // Mirror gen2_expr's Call path (L4907-4910): read `node.left.name`.
    if k == "Call" {
        if type_of(node.left) == "string" { return "" }
        if node.left.kind != "Ident" { return "" }
        let fname = node.left.name
        if type_of(node.args) == "string" { return "" }
        let nargs = len(node.args)
        // Single-arg numeric builtins.
        if nargs == 1 {
            let a = comptime_eval(node.args[0])
            if type_of(a) == "string" { return "" }
            let ak = a.kind
            if ak != "IntLit" && ak != "FloatLit" { return "" }
            if fname == "abs" {
                if ak == "IntLit" {
                    let iv = to_int(a.value)
                    let ar = if iv < 0 { -iv } else { iv }
                    return _make_int_lit_node(to_string(ar))
                }
                // Float abs — emit float literal; negative sign handled via subtract.
                let fv = to_float(a.value)
                let fr = if fv < 0.0 { 0.0 - fv } else { fv }
                return _make_float_lit_node(to_string(fr))
            }
            if fname == "sqrt" {
                // sqrt of negatives undefined → silent skip.
                let fv2 = _cf_as_float(a)
                if fv2 < 0.0 { return "" }
                // Hexa has no native sqrt folder; skip unless input is a
                // perfect small square. This keeps us conservative.
                if ak == "IntLit" {
                    let iv2 = to_int(a.value)
                    // Check up to 10_000² for exact int squares.
                    let mut s = 0
                    while s * s < iv2 && s < 10000 { s = s + 1 }
                    if s * s == iv2 {
                        // Still emit as float per runtime contract (hexa_sqrt → float).
                        return _make_float_lit_node(to_string(to_float(to_string(s))))
                    }
                    return ""
                }
                return ""
            }
            if fname == "floor" || fname == "ceil" {
                // runtime returns Int. For int input, identity; for float, fold.
                if ak == "IntLit" { return _make_int_lit_node(a.value) }
                // FloatLit → skip (no int-cast builtin in this evaluator;
                // conservative to avoid platform-dependent rounding).
                return ""
            }
            return ""
        }
        // Two-arg numeric builtins: min / max.
        if nargs == 2 && (fname == "min" || fname == "max") {
            let a1 = comptime_eval(node.args[0])
            if type_of(a1) == "string" { return "" }
            let a2 = comptime_eval(node.args[1])
            if type_of(a2) == "string" { return "" }
            let k1 = a1.kind
            let k2 = a2.kind
            let n1 = k1 == "IntLit" || k1 == "FloatLit"
            let n2 = k2 == "IntLit" || k2 == "FloatLit"
            if !n1 || !n2 { return "" }
            // Int-int preserves int; otherwise float.
            if k1 == "IntLit" && k2 == "IntLit" {
                let v1 = to_int(a1.value)
                let v2 = to_int(a2.value)
                let pick = if fname == "min" { v1 < v2 } else { v1 > v2 }
                let out = if pick { v1 } else { v2 }
                return _make_int_lit_node(to_string(out))
            }
            let f1 = _cf_as_float(a1)
            let f2 = _cf_as_float(a2)
            let pickf = if fname == "min" { f1 < f2 } else { f1 > f2 }
            let outf = if pickf { f1 } else { f2 }
            return _make_float_lit_node(to_string(outf))
        }
        return ""
    }
    return ""
}

// Register a comptime-const folded literal in the lookup table.
// `value_node` is the folded literal returned by comptime_eval.
fn _register_comptime_const(name, value_node) {
    _comptime_const_names.push(name)
    _comptime_const_nodes.push(value_node)
}

// PROBE r15-D18: type-changing shadow let-rebind. Hexa permits same-scope
// `let x = "hello"; let x = 42` (canonical Rust/Swift shadow with a new type).
// The hoist/assign path (bt 72) already emits this correctly at C level
// (HexaVal is a tagged union, so the type change is free), BUT the comptime-
// const fold table (PROBE r11 B3) registers the FIRST `let`'s literal and
// _lookup_comptime_const returns the FIRST match — so every later reference to
// the shadowed name inlines the STALE first value, ignoring the rebind
// (`println(x)` emitted "hello" instead of 42). Drop ALL prior registrations
// for `name` so a shadow rebind re-folds (or falls back to the live variable
// read). Called at the LetStmt re-register site after the init C text is
// captured (RHS reads of the OLD value are already baked into `init`).
fn _invalidate_comptime_const(name) {
    let mut _names = []
    let mut _nodes = []
    let mut i = 0
    while i < len(_comptime_const_names) {
        if _comptime_const_names[i] != name {
            _names.push(_comptime_const_names[i])
            _nodes.push(_comptime_const_nodes[i])
        }
        i = i + 1
    }
    _comptime_const_names = _names
    _comptime_const_nodes = _nodes
}

// ── match/block-body scope isolation for the comptime-const fold table ──
// The "PROBE r11 B3" plain-immutable-`let` comptime-fold registers folded
// literals into the GLOBAL parallel arrays above with no scope handling, and
// _lookup_comptime_const returns the FIRST match. Two match arms (or if/else
// arms) that each bind the same name with a literal initializer therefore
// collided: `match v { 1 -> { let a = 10; a + 1 }, 3 -> { let a = 100; let b
// = 200; a + b } }` folded arm-3's `a` to arm-1's stale `10` (first-wins),
// yielding `10 + 200 = 210` instead of `300`. Snapshot the table length
// before walking an arm/block body and truncate back to it afterwards so each
// arm's folded lets stay local — they cannot leak into a sibling arm or into
// the enclosing scope. Returns the pre-body length; pass it to
// _comptime_const_scope_restore once the body has been emitted.
fn _comptime_const_scope_mark() {
    return len(_comptime_const_names)
}

fn _comptime_const_scope_restore(mark) {
    // Rebuild both parallel arrays to length `mark` using index+push only
    // (the most portable in-place truncation across compiled-binary vintages —
    // avoids relying on .slice / .truncate codegen branches).
    let mut _names = []
    let mut _nodes = []
    let mut i = 0
    while i < mark {
        _names.push(_comptime_const_names[i])
        _nodes.push(_comptime_const_nodes[i])
        i = i + 1
    }
    _comptime_const_names = _names
    _comptime_const_nodes = _nodes
}

// ── C3: Closure capture support ──────────────────────────
// `_known_fn_globals`: names callable as direct C functions (FnDecl, extern,
//   pure fn, struct constructors). Call-by-name uses direct C call for these.
// `_known_nonlocal_names`: superset — also top-level lets, enums, comptime.
//   Free-variable analysis excludes these names from capture (they're
//   referenced by C name, not by closure env).
let mut _known_fn_globals = []
let mut _known_nonlocal_names = []

// ── PROBE r16-T2: user-FnDecl arity registry ────────────────
// Parallel arrays mapping a plain `fn name(...)` to its formal-parameter
// count. Populated in codegen_full Pass-0 from FnDecl nodes ONLY (NOT
// extern fns — variadic C signatures — NOT struct constructors, NOT
// imported names). Consulted at the direct-call codegen site to surface a
// hexa-level "fn X expects N args, got M" diagnostic BEFORE codegen,
// instead of deferring an opaque "too few/many arguments" to clang. First
// definition wins (mirrors codegen first-wins), so a redefined fn does not
// produce spurious arity errors against a later signature.
let mut _fn_arity_names = []
let mut _fn_arity_counts = []
// RFC r16 (default args): parallel registry of per-fn default-expr lists.
// _fn_default_exprs[i] is an array of length _fn_arity_counts[i] where each
// slot is either the param's default-expr AST node or "" (no default). The
// _fn_required[i] is the count of leading params WITHOUT a default (the
// minimum legal arg count). A call with len(args) in [required, total] is
// auto-filled with the trailing defaults at the call site (strategy A).
let mut _fn_default_exprs = []
let mut _fn_required = []
// RFC r16 (named args): parallel registry of per-fn param NAME lists, used to
// reorder keyword arguments (`f(y: 5, x: 1)`) into the callee's declared
// positional order at the call site.
let mut _fn_param_names = []
// RFC r16 (varargs): per-fn variadic-param index, or -1 if the fn has no
// variadic param. A variadic fn's last param collects all trailing call args
// into a single array; the C callee takes that array as one HexaVal param.
let mut _fn_variadic_idx = []

fn _fn_arity_register(name, count) {
    // First-wins: skip if already registered.
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name { return 0 }
        i = i + 1
    }
    _fn_arity_names.push(name)
    _fn_arity_counts.push(count)
    _fn_default_exprs.push([])
    _fn_required.push(count)
    _fn_param_names.push([])
    _fn_variadic_idx.push(-1)
    return 0
}

// RFC r16 (varargs): record the variadic param index for `name` (first-wins).
fn _fn_variadic_register(name, vidx) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name {
            if _fn_variadic_idx[i] < 0 { _fn_variadic_idx[i] = vidx }
            return 0
        }
        i = i + 1
    }
    return 0
}

// RFC r16 (varargs): variadic param index for `name`, or -1 (not variadic /
// unregistered).
fn _fn_variadic_lookup(name) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name { return _fn_variadic_idx[i] }
        i = i + 1
    }
    return -1
}

// RFC r16 (named args): register `name`'s ordered param-name list. First-wins;
// only fills the slot when still empty.
fn _fn_param_names_register(name, pnames) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name {
            if len(_fn_param_names[i]) == 0 { _fn_param_names[i] = pnames }
            return 0
        }
        i = i + 1
    }
    return 0
}

// RFC r16 (named args): 0-based positional index of param `pname` in `name`'s
// declaration, or -1 if `name` is unregistered or has no such param.
fn _fn_param_index(name, pname) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name {
            let _pn = _fn_param_names[i]
            let mut j = 0
            while j < len(_pn) {
                if _pn[j] == pname { return j }
                j = j + 1
            }
            return -1
        }
        i = i + 1
    }
    return -1
}

// RFC r16: register `name`'s param default-expr list. `defaults` is an array
// (one slot per param, "" = no default) and `required` is the count of params
// without a default. First-wins (mirrors _fn_arity_register); only updates the
// slot whose name matches and whose default list is still empty.
fn _fn_defaults_register(name, defaults, required) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name {
            if len(_fn_default_exprs[i]) == 0 {
                _fn_default_exprs[i] = defaults
                _fn_required[i] = required
            }
            return 0
        }
        i = i + 1
    }
    return 0
}

// _fn_arity_lookup — expected arity for `name`, or -1 if not a registered
// plain user FnDecl (callers MUST treat -1 as "skip the check").
fn _fn_arity_lookup(name) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name { return _fn_arity_counts[i] }
        i = i + 1
    }
    return -1
}

// RFC r16: minimum legal arg count for `name` (= count of params without a
// default), or -1 if not registered. When equal to _fn_arity_lookup the fn
// has no defaults (plain mandatory params).
fn _fn_required_lookup(name) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name { return _fn_required[i] }
        i = i + 1
    }
    return -1
}

// RFC r16: the default-expr AST node for param index `idx` of `name`, or ""
// if none / not registered.
fn _fn_default_at(name, idx) {
    let mut i = 0
    while i < len(_fn_arity_names) {
        if _fn_arity_names[i] == name {
            let _ds = _fn_default_exprs[i]
            if idx >= 0 && idx < len(_ds) { return _ds[idx] }
            return ""
        }
        i = i + 1
    }
    return ""
}

// ── ROI-23: 64-bucket hash sets for O(1) avg lookup ─────────
// Same pattern as interpreter.hexa env_cache / memo_cache.
let mut _known_fn_globals_set = []   // 64 buckets; each bucket is [name, ...]
let mut _known_nonlocal_set = []     // 64 buckets; each bucket is [name, ...]

// ── STRUCTURAL-2 Phase B: known-int type propagation ────────
// Immutable `let` variables whose initializer is IntLit or int-only BinOp
// are tracked here. gen2_expr BinOp uses this to bypass hexa_add/sub/mul/
// div/mod boxing and emit direct `.i` arithmetic.
// Excludes: mut variables (re-assignable), fn params (caller may pass float).
let mut _known_int_set = []          // 64 buckets; each bucket is [name, ...]

// ── STRUCTURAL-3: known-float type propagation ──────────────
// Parallel to known-int: immutable `let` with FloatLit or float-only BinOp
// initializers. gen2_expr BinOp uses this to emit direct `double` arithmetic
// via `hexa_float(HX_FLOAT(L) OP HX_FLOAT(R))`, bypassing hexa_add/sub/mul/
// div runtime tag dispatch. Critical for training loops (99% float ops).
let mut _known_float_set = []        // 64 buckets; each bucket is [name, ...]

// ── UNSHADOW item C: proof-carrying array bounds-check elision ──────────────
// Stack of ACTIVE in-range index facts. A fact is established ONLY by the
// `for i in 0..len(arr)` exclusive-range fast-path (gen2_stmt ForStmt) AFTER a
// conservative body scan proves `arr` is never resized/reassigned in the loop
// body and `i` is never reassigned. Each entry is a 3-tuple stored as a small
// array: [idx_var_name, arr_name, c_native_counter]. While such a fact is live,
// `gen2_expr` Index emits a BOUNDS-FREE, throw-FREE direct read
// (`<arr>.arr_ptr->items[<c_counter>]`) for exactly the read `arr[i]` — the
// runtime `hexa_index_get` bounds check (`idx<0 || idx>=HX_ARR_LEN` → hexa_throw)
// is provably dead because the C for-loop guarantees `0 <= counter < arr.len`.
// The fact is LOCAL and EXACT (comptime-fold-shadow family hazard): it is popped
// on loop exit, and any nested re-binding of `i` / mutation of `arr` voids it.
// HexaArr {items,len,cap} + the `arr_ptr` union field are public in runtime.h,
// so the elided read needs NO runtime-internal macro and works through the
// runtime.o C-ABI wall (the §lto-unwall NULL was a CLANG limitation; this is a
// CODEGEN proof, which is the axis unwall separated out).
let mut _inrange_facts = []          // stack of [idx_var, arr_name, c_counter]

// ── UNSHADOW item A: unboxed-primitive array — element-kind tracker ─────────
// Names of immutable `let`s whose initializer is a STATICALLY-PROVEN
// monomorphic-i64 array literal (`[1,2,3,…]`, every element an IntLit). For
// such a binding the codegen KNOWS each element is TAG_INT, so a read
// `arr[i]` covered by a live in-range fact (§c-class) is provably (a) on a
// TAG_ARRAY receiver and (b) a TAG_INT element. That lets us:
//   • DROP the §c-class array-tag guard (`HX_IS_ARRAY(arr)?…`) — array-ness is
//     now statically proven for this binding, not just bounds.
//   • Mark the read known-int so a surrounding sum/dot BinOp extracts the raw
//     `.i` (`arr.arr_ptr->items[i].i`) with NO per-element box / HX_INT tag
//     work — the boxed-storage form of the unbox.
// This is a flat list (known-int-arrays are rare & local). Registration is
// gated on immutable LetStmt only; any reassignment of the name (AssignStmt
// LHS Ident) VOIDS it (mirrors _invalidate_comptime_const), and the read
// fast-path STILL also requires a live in-range fact (which independently
// proves no resize/reassign in the loop body). Box at the dynamic boundary is
// automatic: ANY use outside the proven `arr[i]` read (passing `arr` to a fn,
// `arr` flowing to an untyped site, an unproven index) falls through to the
// unchanged BOXED HexaArr path — the elem stays a boxed HexaVal there.
let mut _known_intarr_set = []

// UNSHADOW [HEADLINE] F1: gate for native-i64 array STORAGE (HexaArrI64). Read
// once per process is fine — env is stable during a compile. Default OFF: the
// proven-loop read + boxed storage path (axis-A / §c-class) is unchanged when
// the flag is absent, so this milestone is zero-regression by default. With the
// flag ON, a proven monomorphic-i64 literal lowers to native contiguous
// int64_t[] (the measured ceiling). OPT-IN like §same-tu (HEXA_SAME_TU) because
// the full no-escape auto-firing generalization is a separate sub-task.
fn _native_arr_enabled() {
    return env("HEXA_NATIVE_ARR") != ""
}

fn _known_intarr_add(name) {
    // de-dup
    let mut i = 0
    while i < len(_known_intarr_set) {
        if _known_intarr_set[i] == name { return }
        i = i + 1
    }
    _known_intarr_set = _known_intarr_set.push(name)
}

fn _known_intarr_void(name) {
    // Remove `name` if present (reassignment / re-let invalidates the proof).
    let n = len(_known_intarr_set)
    if n <= 0 { return }
    let mut _rebuilt = []
    let mut i = 0
    while i < n {
        if _known_intarr_set[i] != name { _rebuilt = _rebuilt.push(_known_intarr_set[i]) }
        i = i + 1
    }
    _known_intarr_set = _rebuilt
}

fn _is_known_intarr_name(name) {
    let mut i = 0
    while i < len(_known_intarr_set) {
        if _known_intarr_set[i] == name { return true }
        i = i + 1
    }
    return false
}

// Is `node` an array literal whose every element is an IntLit? (Exact, narrow
// monomorphic-i64 proof — no Idents, no calls, no float, no nesting. The
// narrowest provable case the RFC names.)
// decreases node — structural (single level; elements must be leaf IntLits)
fn _is_int_literal_array(node) {
    if type_of(node) == "string" { return false }
    if node.kind != "Array" { return false }
    if type_of(node.items) != "array" { return false }
    if len(node.items) == 0 { return false }
    let mut i = 0
    while i < len(node.items) {
        let el = node.items[i]
        if type_of(el) == "string" { return false }
        if el.kind != "IntLit" { return false }
        i = i + 1
    }
    return true
}

// ── enum-variant access fix (inbox: enum-variant-access-miscodegen) ──
// `<EnumName>.<VARIANT>` (e.g. RegionShape.K_BY_K) is an enum-variant
// constant, NOT a runtime field access — the gen2_enum_decl #define
// `<EnumName>_<VARIANT>` is the only C symbol that exists. Collect every
// `enum` node.name seen by gen2_enum_decl during the decl pass (decls
// precede fn bodies — see EnumDecl routing ~L1024/L7372), then consult
// it in the gen2_expr `if k == "Field"` arm so the bare-Ident-on-known-
// enum case emits the #define instead of hexa_map_get_ic(<typename>,..).
let mut _enum_names = []

fn _enum_names_add(name) {
    let mut i = 0
    while i < len(_enum_names) {
        if _enum_names[i] == name { return }
        i = i + 1
    }
    _enum_names.push(name)
}

fn _is_enum_name(name) {
    let mut i = 0
    while i < len(_enum_names) {
        if _enum_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// ── PROBE r15-D14 (2026-05-24): bare-enum-variant Ident lookup ──
// `let c = Red` (bare, no Color:: qualifier) parses as a plain Ident.
// The gen2_expr Ident arm previously emitted `Red` literally → clang
// error `use of undeclared identifier 'Red'` because the only C symbol
// the enum decl emits is `Color_Red` (#define from gen2_enum_decl).
// Mirror the `Field` arm fix (line ~4883) for the bare form: keep a
// variant→owner registry populated during the decl pass, then consult
// it in the Ident arm AFTER local/global/fnref checks (locals and
// explicit decls always win — only fires for otherwise-undeclared
// names that uniquely match one enum's variant).  Same-named variants
// across multiple enums → ambiguous → skip (fall through to mangled
// bare emit; existing diagnostic flow is preserved).
let mut _enum_variant_names = []
let mut _enum_variant_owners = []
let mut _enum_variant_ambig  = []

fn _enum_variant_register(variant, owner) {
    let mut i = 0
    while i < len(_enum_variant_names) {
        if _enum_variant_names[i] == variant {
            if _enum_variant_owners[i] != owner {
                _enum_variant_ambig[i] = true
            }
            return
        }
        i = i + 1
    }
    _enum_variant_names.push(variant)
    _enum_variant_owners.push(owner)
    _enum_variant_ambig.push(false)
}

fn _enum_variant_lookup_owner(name) {
    let mut i = 0
    while i < len(_enum_variant_names) {
        if _enum_variant_names[i] == name {
            if _enum_variant_ambig[i] { return "" }
            return _enum_variant_owners[i]
        }
        i = i + 1
    }
    return ""
}

// PROBE r16-T4: non-exhaustive enum-match warning (deployed path).
// The r15 #453/#585 exhaustiveness check lives in type_checker.hexa but only
// runs under the opt-in HEXA_TYPECHECK env, so it never fires in normal
// transpiles — a `match c { Color::Red -> ... }` missing Blue silently falls
// through to hexa_void() ("prints void"). This emits a stderr WARNING (non-
// fatal — the match still compiles, the fallthrough is preserved) when:
//   (1) the match has NO wildcard / irrefutable-binder catch-all arm, AND
//   (2) every refutable arm is an EnumPath for the SAME user enum, AND
//   (3) at least one variant of that enum is not covered.
// Conservative by construction: int/string/bool/Option/Result/guarded matches
// never reach (2) (their arms are not registered EnumPath variants), and an
// arm whose enum can't be determined disables the warning for that match.
fn _gen2_warn_nonexhaustive_match(node) {
    if type_of(node.arms) == "string" { return 0 }
    let arms = node.arms
    let mut owner = ""
    let mut owner_set = false
    let mut bail = false
    let mut covered = []
    let mut ai = 0
    while ai < len(arms) {
        let pat = arms[ai].left
        if type_of(pat) == "string" {
            bail = true
        } else if pat.kind == "Wildcard" {
            // Catch-all present — exhaustive by construction; nothing to warn.
            return 0
        } else if pat.kind == "Ident" {
            let _pn = pat.name
            // A bare lowercase Ident (not None) is an irrefutable binder — it
            // catches everything, so the match is exhaustive. `None` is an
            // Option tag, not a user enum variant — treat as a non-enum arm
            // that disables the check (bail).
            if type_of(_pn) == "string" && _pn != "None" {
                return 0
            }
            bail = true
        } else if pat.kind == "EnumPath" {
            let _en = pat.name
            let _vn = pat.value
            // Determine the owning enum. Prefer the registry (handles ambiguous
            // / unknown variants → "" → bail); fall back to the pattern's own
            // enum-name qualifier only when the registry agrees it is an enum.
            let _reg_owner = _enum_variant_lookup_owner(_vn)
            if _reg_owner == "" {
                bail = true
            } else {
                if !owner_set {
                    owner = _reg_owner
                    owner_set = true
                } else if owner != _reg_owner {
                    bail = true
                }
                covered.push(_vn)
            }
        } else {
            // Some other refutable pattern (IntLit, Call/Some, Range, ...) —
            // not a plain enum match; disable the warning.
            bail = true
        }
        ai = ai + 1
    }
    if bail { return 0 }
    if !owner_set { return 0 }
    // Collect all declared variants of `owner` from the registry.
    let mut missing = []
    let mut vi = 0
    while vi < len(_enum_variant_names) {
        if _enum_variant_owners[vi] == owner && !_enum_variant_ambig[vi] {
            let _vname = _enum_variant_names[vi]
            let mut found = false
            let mut ci = 0
            while ci < len(covered) {
                if covered[ci] == _vname { found = true }
                ci = ci + 1
            }
            if !found { missing.push(_vname) }
        }
        vi = vi + 1
    }
    if len(missing) > 0 {
        let mut miss_str = ""
        let mut mi = 0
        while mi < len(missing) {
            if mi > 0 { miss_str = miss_str + ", " }
            miss_str = miss_str + owner + "::" + missing[mi]
            mi = mi + 1
        }
        eprintln("[warn] non-exhaustive match on enum `" + owner + "` — missing variant(s): " + miss_str + " (add a '_ ->' arm or the missing variant(s))")
    }
    return 0
}

// ═══════════════════════════════════════════════════════════════
//  PROBE r14-CCCC (YYY-1): struct field default-value registry
//
//  Keyed by struct name; each entry mirrors `node.fields` so the
//  `StructInit` emitter can look up declared field order +
//  per-field default expressions (AST nodes or "" if no default).
//  Populated at decl-emit time (gen2_struct_decl); consulted at
//  literal-emit time (StructInit arm) to (a) auto-fill missing
//  fields with their default AST nodes, (b) emit a codegen-level
//  error when a field is missing AND has no default — closing the
//  silent-corruption hole from the RFC table.
// ═══════════════════════════════════════════════════════════════
let mut _struct_field_names = []  // [[fname, ...]] parallel to _struct_decl_names
let mut _struct_field_defaults = []  // [[default_expr_or_"", ...]] parallel
let mut _struct_decl_names = []  // [name, ...]

fn _struct_decl_register(node) {
    let mut i = 0
    while i < len(_struct_decl_names) {
        if _struct_decl_names[i] == node.name { return }
        i = i + 1
    }
    let mut fnames = []
    let mut fdefs = []
    let mut fi = 0
    while fi < len(node.fields) {
        let f = node.fields[fi]
        fnames.push(f.name)
        // `default_expr` is the new AST slot from parser; "" sentinel = none.
        fdefs.push(f.default_expr)
        fi = fi + 1
    }
    _struct_decl_names.push(node.name)
    _struct_field_names.push(fnames)
    _struct_field_defaults.push(fdefs)
}

fn _struct_decl_index(name) {
    let mut i = 0
    while i < len(_struct_decl_names) {
        if _struct_decl_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

// ── UNSHADOW typed monomorphic struct layout (flat C-struct + offset access) ──
//   E(AoS↔SoA) re-open prerequisite (F1 데이터-표현 주권). The E closed-negative
//   ruled out SoA because every struct is a `hexa_struct_pack_map` HASH-MAP and
//   every field read is a `hexa_map_get_ic` strcmp/IC probe. When a struct type
//   is PROVEN MONOMORPHIC (closed field set, all accesses are static field
//   names, NO dynamic-key set/get), the compiler can emit a per-type FLAT
//   C-STRUCT typedef and lower `obj.field` to a compile-time OFFSET load. This
//   is the LLVM-can't lever: clang sees the opaque hexa_map_get_ic behind the
//   runtime.o C-ABI wall and cannot fold a hash probe to a load; the hash→offset
//   rewrite is a TYPE-LEVEL shape proof over our owned representation.
//
//   GATED opt-in (HEXA_TYPED_STRUCT=1, default OFF). When the flag is absent the
//   hash-map ctor + hexa_map_get_ic read are UNCHANGED → zero regression. When
//   ON, a proven-monomorphic struct gets a flat typedef + offset reads. The flat
//   typedef lives in USER.C (per RFC §codegen-landing — no runtime change), and
//   the flat pointer rides the public HexaVal `vs` union slot, so the proxy and
//   the landed codegen both pierce the wall with NO runtime.h edit.
fn _typed_struct_enabled() {
    return env("HEXA_TYPED_STRUCT") != ""
}

// A struct type is FLAT-ELIGIBLE when it is declared in this TU with a non-empty
// closed field set AND no field name collides with the dynamic-key escape hatch.
// Conservative monomorphic proof: declared + >=1 field. Any dynamic-key use of an
// instance (a non-literal-string key) keeps the value on the hash-map path
// because the codegen only lowers a STATIC field name to an offset — a
// dynamic-key read never matches the offset arm and falls through unchanged.
// decreases nothing — pure registry lookup.
fn _is_flat_eligible_struct(name) {
    if !_typed_struct_enabled() { return false }
    let _idx = _struct_decl_index(name)
    if _idx < 0 { return false }
    let _fnames = _struct_field_names[_idx]
    if len(_fnames) == 0 { return false }
    return true
}

// field index of `field` within struct type `sname`, or -1 if not a declared
// field (a non-declared / dynamic key → no offset, hash-map fallback).
fn _flat_field_index(sname, field) {
    let _idx = _struct_decl_index(sname)
    if _idx < 0 { return -1 }
    let _fnames = _struct_field_names[_idx]
    let mut i = 0
    while i < len(_fnames) {
        if _fnames[i] == field { return i }
        i = i + 1
    }
    return -1
}

// var name → flat-eligible struct type. Populated at `let p = Pt{...}` when Pt
// is flat-eligible and the binding is immutable (LetStmt). A reassignment / re-
// let / mut binding VOIDS it (mirrors _known_intarr_void), so the offset read
// fires ONLY for a binding statically known to hold a flat-struct instance.
let mut _flat_var_names = []   // [name, ...]
let mut _flat_var_types = []   // [struct_type, ...] parallel

fn _flat_var_add(name, sname) {
    let mut i = 0
    while i < len(_flat_var_names) {
        if _flat_var_names[i] == name {
            _flat_var_types[i] = sname
            return
        }
        i = i + 1
    }
    _flat_var_names.push(name)
    _flat_var_types.push(sname)
}

fn _flat_var_void(name) {
    let n = len(_flat_var_names)
    if n <= 0 { return }
    let mut _rn = []
    let mut _rt = []
    let mut i = 0
    while i < n {
        if _flat_var_names[i] != name {
            _rn = _rn.push(_flat_var_names[i])
            _rt = _rt.push(_flat_var_types[i])
        }
        i = i + 1
    }
    _flat_var_names = _rn
    _flat_var_types = _rt
}

// If `node` is a struct-construction expression (`Pt { ... }` StructInit, or a
// positional `Pt(...)` Call) of a FLAT-ELIGIBLE struct type, return that type
// name; else "". Used at LetStmt to bind a var to its flat-struct type. Narrow:
// only direct construction literals (the receiver type is then statically known
// for the whole immutable binding). decreases nothing — structural check.
fn _flat_struct_init_type(node) {
    if type_of(node) == "string" { return "" }
    let k = node.kind
    if k == "StructInit" {
        if _is_flat_eligible_struct(node.name) { return node.name }
        return ""
    }
    if k == "Call" {
        // positional constructor: callee is a bare Ident naming a struct type.
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            if _is_flat_eligible_struct(node.left.name) { return node.left.name }
        }
    }
    return ""
}

// struct type held by var `name`, or "" if not a known flat-struct binding.
fn _flat_var_type(name) {
    let mut i = 0
    while i < len(_flat_var_names) {
        if _flat_var_names[i] == name { return _flat_var_types[i] }
        i = i + 1
    }
    return ""
}

// Emit the per-type flat C-struct typedef + flat constructor for a proven
// monomorphic struct. Lives in user.c; carries the flat pointer in the public
// HexaVal `vs` union slot (opaque carrier — no runtime.h edit). Field decl order
// = slot order. Constructor signature MIRRORS the hash-map ctor (positional
// HexaVal params) so existing call sites are unchanged. Fields are stored as raw
// HexaVal (general — works for any field type; the offset read returns the
// HexaVal directly, NO strcmp/IC). The win is the OFFSET vs the hash probe.
fn gen2_flat_struct_typedef(node) {
    let name = node.name
    let nfields = len(node.fields)
    let mut members = []
    let mut params = []
    let mut assigns = []
    let mut fi = 0
    while fi < nfields {
        let fname = node.fields[fi].name
        members.push("HexaVal f" + to_string(fi) + "; ")
        params.push("HexaVal " + fname)
        assigns.push("s->f" + to_string(fi) + " = " + fname + "; ")
        fi = fi + 1
    }
    let mut out = "typedef struct " + name + "__flat { " + members.join("") + "} " + name + "__flat;\n"
    out = out + "HexaVal " + name + "(" + params.join(", ") + ") {\n"
    out = out + "    " + name + "__flat* s = (" + name + "__flat*)malloc(sizeof(" + name + "__flat));\n"
    out = out + "    " + assigns.join("") + "\n"
    out = out + "    HexaVal __v; __v.tag = TAG_ARRAY; __v.vs = (HexaValStruct*)s; return __v;\n"
    out = out + "}\n"
    return out
}

// ═══════════════════════════════════════════════════════════
//  UNSHADOW F2 — escape→stack-alloc (공간축 / space-axis)
//
//  A flat-eligible struct constructor (gen2_flat_struct_typedef) mallocs a
//  per-type __flat descriptor and carries the pointer in the HexaVal `vs` slot.
//  When the binding `let p = Pt{…}` is PROVEN non-escaping inside its function
//  body, that heap descriptor can live on the C stack instead — the codegen
//  emits a stack-local `Pt__flat __stk_p = {…}` and points `p.vs` at it,
//  bypassing malloc entirely (peak-RSS / heap-alloc-count ↓; byte-identical
//  stdout because the read offsets are unchanged).
//
//  LLVM-can't: escape here is a TYPE-LEVEL lifetime proof over our owned tagged
//  representation — clang sees only an opaque `HexaValStruct*` riding a union
//  slot and a malloc it cannot prove non-escaping past the C-ABI runtime wall.
//
//  GATED opt-in (HEXA_STACK_ALLOC=1, default OFF → zero regression). Conservative:
//  a binding escapes (→ keep heap) unless its ONLY uses in the body are field
//  reads `p.field`. Returned · passed as a call arg · stored to field/index/
//  global · captured by a closure · reassigned · address-of → all force heap.
// ═══════════════════════════════════════════════════════════
fn _stack_alloc_enabled() {
    return env("HEXA_STACK_ALLOC") != ""
}

// Names of flat-struct bindings in the CURRENT fn body that are proven
// non-escaping (eligible for stack allocation). Recomputed per fn in
// gen2_fn_decl, consumed at the LetStmt arm.
let mut _stack_noescape_set = []

fn _stack_noescape_reset() { _stack_noescape_set = [] }

fn _stack_noescape_add(name) {
    let mut i = 0
    while i < len(_stack_noescape_set) {
        if _stack_noescape_set[i] == name { return }
        i = i + 1
    }
    _stack_noescape_set.push(name)
}

fn _is_stack_noescape(name) {
    let mut i = 0
    while i < len(_stack_noescape_set) {
        if _stack_noescape_set[i] == name { return true }
        i = i + 1
    }
    return false
}

// Recursively scan an expression node for an ESCAPING use of `name`.
// An escaping use is any appearance of `name` OTHER than the receiver of a
// Field read (`name.field`). Conservatively: a bare Ident `name` anywhere that
// is not such a receiver counts as escaping (returned / call-arg / stored /
// element / index / operand handed to an opaque sink). decreases nothing.
fn _expr_escapes_name(node, name) {
    if type_of(node) == "string" { return false }
    let k = node.kind
    // Field read `recv.field`: the receiver may itself be `name` (NON-escaping —
    // this is exactly the allowed use). But the receiver could be a deeper
    // expression that embeds `name` in an escaping position, so recurse into it
    // ONLY when the receiver is not the bare protected Ident.
    if k == "Field" {
        let _recv = node.left
        if type_of(_recv) != "string" && _recv.kind == "Ident" && _recv.name == name {
            return false   // p.field — the sole allowed shape
        }
        if _expr_escapes_name(_recv, name) { return true }
        return false
    }
    // A bare Ident equal to `name` in any other position = escape.
    if k == "Ident" {
        if node.name == name { return true }
        return false
    }
    // Generic structural recursion over the common child slots. Any embedded
    // bare `name` reached this way is in a non-Field-receiver position → escape.
    if type_of(node.left) != "string" {
        if _expr_escapes_name(node.left, name) { return true }
    }
    if type_of(node.right) != "string" {
        if _expr_escapes_name(node.right, name) { return true }
    }
    if type_of(node.items) != "string" {
        let mut i = 0
        while i < len(node.items) {
            if _expr_escapes_name(node.items[i], name) { return true }
            i = i + 1
        }
    }
    if type_of(node.fields) != "string" {
        let mut i = 0
        while i < len(node.fields) {
            let _fe = node.fields[i]
            if type_of(_fe) != "string" && type_of(_fe.left) != "string" {
                if _expr_escapes_name(_fe.left, name) { return true }
            }
            i = i + 1
        }
    }
    if type_of(node.cond) != "string" {
        if _expr_escapes_name(node.cond, name) { return true }
    }
    return false
}

// Recursively scan a statement (and nested bodies) for an escaping use of
// `name`. ReturnStmt that returns `name` escapes; any expression position
// other than `name.field` escapes. A reassignment to `name` (LetMutStmt /
// AssignStmt with that target) also escapes (mut binding voids the proof).
fn _stmt_escapes_name(node, name) {
    if type_of(node) == "string" { return false }
    let sk = node.kind
    // Reassignment of the protected name → escape (binding became mutable/aliased).
    if sk == "LetMutStmt" || sk == "AtomicLet" {
        if node.name == name { return true }
    }
    if sk == "AssignStmt" {
        let _tgt = node.left
        if type_of(_tgt) != "string" && _tgt.kind == "Ident" && _tgt.name == name {
            return true
        }
        if type_of(_tgt) != "string" && _expr_escapes_name(_tgt, name) { return true }
        if type_of(node.right) != "string" && _expr_escapes_name(node.right, name) { return true }
        if type_of(node.value) != "string" && _expr_escapes_name(node.value, name) { return true }
        return false
    }
    if sk == "ReturnStmt" {
        if type_of(node.left) != "string" && _expr_escapes_name(node.left, name) { return true }
        if type_of(node.value) != "string" && _expr_escapes_name(node.value, name) { return true }
        return false
    }
    // ExprStmt / general statement carrying an expression in .left
    if type_of(node.left) != "string" {
        if _expr_escapes_name(node.left, name) { return true }
    }
    if type_of(node.right) != "string" {
        if _expr_escapes_name(node.right, name) { return true }
    }
    if type_of(node.value) != "string" {
        if _expr_escapes_name(node.value, name) { return true }
    }
    if type_of(node.cond) != "string" {
        if _expr_escapes_name(node.cond, name) { return true }
    }
    // Nested bodies (if / while / for / match arms / blocks).
    if type_of(node.then_body) != "string" {
        if _stmts_escape_name(node.then_body, name) { return true }
    }
    if type_of(node.else_body) != "string" {
        if _stmts_escape_name(node.else_body, name) { return true }
    }
    if type_of(node.body) != "string" {
        if _stmts_escape_name(node.body, name) { return true }
    }
    if type_of(node.arms) != "string" {
        let mut ai = 0
        while ai < len(node.arms) {
            let arm = node.arms[ai]
            if type_of(arm) != "string" && type_of(arm.body) != "string" {
                if _stmts_escape_name(arm.body, name) { return true }
            }
            ai = ai + 1
        }
    }
    return false
}

fn _stmts_escape_name(stmts, name) {
    if type_of(stmts) == "string" { return false }
    let mut i = 0
    while i < len(stmts) {
        if _stmt_escapes_name(stmts[i], name) { return true }
        i = i + 1
    }
    return false
}

// Emit a stack-allocated flat-struct binding (no malloc). `var_name` is the
// mangled C local; `sname` the flat-eligible struct type; `arg_exprs` the
// already-lowered positional field initializers (declared-order, matching the
// gen2_flat_struct_typedef constructor signature). Produces a `Pt__flat` local
// on the caller's stack frame + a HexaVal pointing at it. The descriptor is
// valid for the lifetime of the enclosing C block — which, by the non-escape
// proof, strictly contains every use of the binding.
// Scan a function body's statement list for immutable `let p = Pt{…}` bindings
// of a flat-eligible struct type that are proven non-escaping over the WHOLE
// body, registering each into _stack_noescape_set. Conservative + narrow: only
// top-level LetStmt bindings (not nested-scope) participate in v1 — a nested
// binding's lifetime/escape interaction with its enclosing block is a separate
// sub-task. For each candidate, the escape check runs against every OTHER
// statement (the binding's own RHS construction is never an escape of itself).
// Declared-order positional arg expression strings for a flat-struct
// construction node (StructInit `Pt{…}` or positional Call `Pt(…)`), matching
// the gen2_flat_struct_typedef constructor signature. Returns "" (string) on
// any shape we don't statically resolve (missing field w/o default, dynamic) —
// the caller then falls back to the normal malloc'ing constructor path.
fn _flat_struct_arg_exprs(node) {
    if type_of(node) == "string" { return "" }
    let k = node.kind
    if k == "Call" {
        // Positional Pt(a, b, …) — already in declared order.
        let mut out = []
        if type_of(node.items) != "string" {
            let mut i = 0
            while i < len(node.items) {
                out.push(gen2_expr(node.items[i]))
                i = i + 1
            }
        }
        return out
    }
    if k != "StructInit" { return "" }
    let name = node.name
    let _sidx = _struct_decl_index(name)
    if _sidx < 0 { return "" }
    let _decl_fnames = _struct_field_names[_sidx]
    let _decl_fdefs = _struct_field_defaults[_sidx]
    let mut out = []
    let mut _di = 0
    while _di < len(_decl_fnames) {
        let _dfn = _decl_fnames[_di]
        let mut _matched = -1
        let mut _fi = 0
        while _fi < len(node.fields) {
            if node.fields[_fi].name == _dfn { _matched = _fi }
            _fi = _fi + 1
        }
        let mut _expr_node = ""
        if _matched >= 0 {
            _expr_node = node.fields[_matched].left
        } else if _decl_fdefs[_di] != "" {
            _expr_node = _decl_fdefs[_di]
        } else {
            // Missing field, no default — bail to the constructor path (which
            // emits the same clang-side hard error). Don't stack-allocate.
            return ""
        }
        out.push(gen2_expr(_expr_node))
        _di = _di + 1
    }
    return out
}

fn _stack_noescape_scan(stmts) {
    if type_of(stmts) == "string" { return }
    let n = len(stmts)
    let mut i = 0
    while i < n {
        let s = stmts[i]
        if type_of(s) != "string" && s.kind == "LetStmt" {
            let _sty = _flat_struct_init_type(s.left)
            if _sty != "" {
                // Walk every statement (including this one's siblings and nested
                // bodies) for an escaping use of the binding name. The binding's
                // own RHS is a construction literal (no self-reference), so
                // scanning the full list is safe.
                let mut _escapes = false
                let mut j = 0
                while j < n {
                    if j != i {
                        if _stmt_escapes_name(stmts[j], s.name) { _escapes = true }
                    }
                    j = j + 1
                }
                if !_escapes {
                    _stack_noescape_add(s.name)
                }
            }
        }
        i = i + 1
    }
}

fn gen2_stack_alloc_flat(pad, var_name, sname, arg_exprs) {
    let _stk = "__stk_" + var_name
    let mut out = pad + "/* [escape→stack] no-escape flat-struct " + var_name + " → stack (no malloc) */\n"
    out = out + pad + sname + "__flat " + _stk + " = { " + arg_exprs.join(", ") + " };\n"
    out = out + pad + "HexaVal " + var_name + "; " + var_name + ".tag = TAG_ARRAY; " + var_name + ".vs = (HexaValStruct*)&" + _stk + ";\n"
    return out
}

fn _known_hash(key) {
    let mut h = 0
    let mut ci = 0
    let n = len(key)
    while ci < n {
        h = (h * 31 + char_code(key, ci)) % 64
        ci = ci + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

fn _known_set_init() {
    let mut fg = []
    let mut nl = []
    let mut i = 0
    while i < 64 {
        fg.push([])
        nl.push([])
        i = i + 1
    }
    _known_fn_globals_set = fg
    _known_nonlocal_set = nl
    // STRUCTURAL-2 Phase B: reset known-int set alongside other sets
    _known_int_set_init()
    // STRUCTURAL-3: reset known-float set alongside other sets
    _known_float_set_init()
}

fn _known_fn_globals_add(name) {
    let b = _known_hash(name)
    _known_fn_globals_set[b] = _known_fn_globals_set[b].push(name)
}

fn _known_nonlocal_add(name) {
    let b = _known_hash(name)
    _known_nonlocal_set[b] = _known_nonlocal_set[b].push(name)
}

fn _is_known_fn_global(name) {
    if len(_known_fn_globals_set) != 64 { return false }
    let b = _known_hash(name)
    let bucket = _known_fn_globals_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _is_known_nonlocal(name) {
    if len(_known_nonlocal_set) != 64 { return false }
    let b = _known_hash(name)
    let bucket = _known_nonlocal_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

// Back-compat alias used below in free-var analysis.
fn _is_known_global(name) { return _is_known_nonlocal(name) }

// ── STRUCTURAL-2 Phase B: known-int set helpers ─────────────
fn _known_int_set_init() {
    let mut ki = []
    let mut i = 0
    while i < 64 {
        ki.push([])
        i = i + 1
    }
    _known_int_set = ki
}

// ── STRUCTURAL-3: known-float set helpers (parallel to int set) ──
fn _known_float_set_init() {
    let mut kf = []
    let mut i = 0
    while i < 64 {
        kf.push([])
        i = i + 1
    }
    _known_float_set = kf
}

fn _known_float_add(name) {
    let b = _known_hash(name)
    _known_float_set[b] = _known_float_set[b].push(name)
}

fn _is_known_float_name(name) {
    if len(_known_float_set) != 64 { return false }
    // H17 fix: see _is_known_int_name — param annotation is authoritative
    // over any prior fn's module-global known-float registration.
    // Step-3 cycle 76: extended to recognize typed-float fn params
    // (symmetric to _is_known_int_name).
    if _gen2_name_in_cur_params(name) {
        if _gen2_param_is_float(name) { return true }
        return false
    }
    // 2026-05-19 fn-local shadowing — atlas s8_elliptic_j1728 residue:
    // `let mut x = -1` in this fn shadows another module's prior
    // `let x = <float>` global registration. Mutable lets aren't
    // re-registered (L2376), so without this guard `_is_known_float_
    // name("x")` returned true and the BinOp fast-path emitted
    // hexa_float(HX_FLOAT(x) * HX_FLOAT(x)) on an int-tagged value →
    // garbage float bits → 2-torsion loop computed wrong → verdict
    // FALSIFY. Extend H17 to fn-body locals using the existing
    // _gen2_name_in_cur_lets tracker.
    if _gen2_name_in_cur_lets(name) { return false }
    // 2026-05-19 atlas root-cause: symmetric collision check (see the
    // _is_known_int_name companion). If `name` is also registered int,
    // the int↔float classification is ambiguous across the flattened
    // unit — bail to safe tag-dispatch.
    if len(_known_int_set) == 64 {
        let _bi = _known_hash(name)
        let _ib = _known_int_set[_bi]
        let mut _ii = 0
        while _ii < len(_ib) {
            if _ib[_ii] == name { return false }
            _ii = _ii + 1
        }
    }
    let b = _known_hash(name)
    let bucket = _known_float_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _known_int_add(name) {
    let b = _known_hash(name)
    _known_int_set[b] = _known_int_set[b].push(name)
}

fn _is_known_int_name(name) {
    if len(_known_int_set) != 64 { return false }
    // H17 fix: fn params shadow any module-global known-int registration.
    // The current fn's param type is authoritative; a prior fn's `let X = 0`
    // must not be applied to this fn's `X: float` param.
    // Step-3 cycle 76 enhancement: still authoritative, but extended to
    // RECOGNIZE typed-int params (`X: int` / `X: i64` etc.) instead of
    // unconditionally bailing. This unlocks the typed-int direct-emit
    // fast paths at lines 3934-3947 (`hexa_int(HX_INT(l) + HX_INT(r))`,
    // `hexa_bool(HX_INT(l) < HX_INT(r))`) for fn params.
    if _gen2_name_in_cur_params(name) {
        if _gen2_param_is_int(name) { return true }
        return false
    }
    // 2026-05-19 fn-local shadowing — symmetric to the _is_known_float_
    // name companion. Fn-body local lets (mutable or immutable) shadow
    // a prior module's global registration; the local binding's type
    // is authoritative.
    if _gen2_name_in_cur_lets(name) { return false }
    // 2026-05-19 atlas root-cause fix: name-collision across the
    // flattened modules. _known_int_set / _known_float_set are GLOBAL
    // keyed by name, so a common name (`lhs`, `rhs`, `err`, …) can be
    // registered int by one module (`let lhs = sigma(n)*euler_phi(n)`)
    // and float by another (`let lhs = lgamma(...)+...`). If both,
    // treat the classification as ambiguous and bail to the safe
    // tag-dispatch BinOp — the prior unconditional "int wins" emitted
    // `HX_INT(lhs)-HX_INT(rhs)` on float operands, producing garbage
    // err in atlas_verify_smoke and 5 verdict FALSIFIES.
    if len(_known_float_set) == 64 {
        let _bf = _known_hash(name)
        let _fb = _known_float_set[_bf]
        let mut _fi = 0
        while _fi < len(_fb) {
            if _fb[_fi] == name { return false }
            _fi = _fi + 1
        }
    }
    let b = _known_hash(name)
    let bucket = _known_int_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

// Check if an AST node is provably TAG_INT at codegen time:
//   - IntLit → always int
//   - Ident in _known_int_set → immutable let with int initializer
fn _is_known_int(node) {
    if type_of(node) == "string" { return false }
    if node.kind == "IntLit" { return true }
    if node.kind == "Ident" { return _is_known_int_name(node.name) }
    // UNSHADOW item A: a read `arr[i]` of a proven known-int-array, where the
    // index is covered by a live in-range fact, is statically TAG_INT — its
    // element kind is monomorphic i64 by the array-literal proof. Certifying it
    // here lets a surrounding sum/dot BinOp extract the raw `.i` (HX_INT) with
    // no per-element tag dispatch. Narrow: requires BOTH the known-int-array
    // registration AND a live in-range fact (same guards as the Index emit
    // fast-path), so it never fires on an unproven / boxed access.
    if node.kind == "Index" {
        let _l = node.left
        let _r = node.right
        if type_of(_l) != "string" && _l.kind == "Ident" && _is_known_intarr_name(_l.name) {
            if type_of(_r) != "string" && _r.kind == "Ident" {
                if _inrange_counter_for(_l.name, _r.name) != "" { return true }
            }
        }
    }
    return false
}

// ── UNSHADOW item C: proof-carrying bounds-elision helpers ──────────────────
// Is `node` the integer literal 0? (IntLit.value is the source text string.)
fn _node_is_int_zero(node) {
    if type_of(node) == "string" { return false }
    if node.kind != "IntLit" { return false }
    return node.value == "0"
}

// If `node` is `len(arr)` (free fn) or `arr.len()` (method) where `arr` is a
// BARE identifier, return arr's name; otherwise "". Only the bare-Ident form is
// accepted so the body-mutation scan can reason about the array by name.
fn _len_call_target_ident(node) {
    if type_of(node) == "string" { return "" }
    if node.kind != "Call" { return "" }
    let callee = node.left
    if type_of(callee) == "string" { return "" }
    // free fn: len(arr)
    if callee.kind == "Ident" && callee.name == "len" {
        if type_of(node.args) == "array" && len(node.args) == 1 {
            let a0 = node.args[0]
            if type_of(a0) != "string" && a0.kind == "Ident" { return a0.name }
        }
        return ""
    }
    // method: arr.len()  (callee is a Field node: .left=arr Ident, .name="len")
    if callee.kind == "Field" && callee.name == "len" {
        if type_of(node.args) == "array" && len(node.args) == 0 {
            let recv = callee.left
            if type_of(recv) != "string" && recv.kind == "Ident" { return recv.name }
        }
        return ""
    }
    return ""
}

// CONSERVATIVE body scan: returns true if `arr_name` MIGHT be resized, mutated
// at the container level, reassigned, captured-and-mutated, or aliased such that
// `arr.arr_ptr->items` / `arr.len` could change during the loop. ANY of these
// voids the in-range proof, so we over-approximate to safety:
//   - reassignment:           `arr = …`  (AssignStmt/Compound/Logical LHS Ident)
//   - method receiver:        `arr.push(…)` / `arr.pop()` / `arr.<anything>(…)`
//                              — a push can realloc .items AND grow .len
//   - passed to ANY call:     `f(arr)` / `m.g(arr)` — callee may push/realloc
//                              (hexa arrays are heap-backed; pass-by-value copies
//                              the HexaVal header but shares the .items buffer)
//   - `arr[k] = v` element write is SAFE (no realloc, no .len change) and is NOT
//     flagged here — but it is also never the read we elide.
// decreases node — structural
fn _name_resized_in_body(node, arr_name) {
    if type_of(node) == "string" { return false }
    if type_of(node) == "array" {
        let mut i = 0
        while i < len(node) {
            if _name_resized_in_body(node[i], arr_name) { return true }
            i = i + 1
        }
        return false
    }
    let k = node.kind
    // reassignment of the whole binding
    if k == "AssignStmt" || k == "CompoundAssign" || k == "LogicalAssign" {
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            if node.left.name == arr_name { return true }
        }
    }
    // any Call: method-receiver mutation, or arr passed as an argument
    if k == "Call" {
        let callee = node.left
        if type_of(callee) != "string" && callee.kind == "Field" {
            let recv = callee.left
            if type_of(recv) != "string" && recv.kind == "Ident" && recv.name == arr_name {
                // arr.<method>(…) — push/pop/insert/remove/clear can all
                // resize. Conservatively void on ANY method call on arr.
                return true
            }
        }
        if type_of(node.args) == "array" {
            let mut ai = 0
            while ai < len(node.args) {
                let a = node.args[ai]
                if type_of(a) != "string" && a.kind == "Ident" && a.name == arr_name {
                    return true
                }
                ai = ai + 1
            }
        }
    }
    // Generic structural recursion (mirror _gen2_collect_assigned coverage).
    if type_of(node.left) != "string" {
        if _name_resized_in_body(node.left, arr_name) { return true }
    }
    if type_of(node.right) != "string" {
        if _name_resized_in_body(node.right, arr_name) { return true }
    }
    if type_of(node.cond) != "string" {
        if _name_resized_in_body(node.cond, arr_name) { return true }
    }
    if type_of(node.then_body) != "string" {
        if _name_resized_in_body(node.then_body, arr_name) { return true }
    }
    if type_of(node.else_body) != "string" {
        if _name_resized_in_body(node.else_body, arr_name) { return true }
    }
    if type_of(node.body) != "string" {
        if _name_resized_in_body(node.body, arr_name) { return true }
    }
    if type_of(node.iter_expr) != "string" {
        if _name_resized_in_body(node.iter_expr, arr_name) { return true }
    }
    if type_of(node.args) == "array" {
        let mut ai2 = 0
        while ai2 < len(node.args) {
            if _name_resized_in_body(node.args[ai2], arr_name) { return true }
            ai2 = ai2 + 1
        }
    }
    if type_of(node.items) == "array" {
        let mut ii = 0
        while ii < len(node.items) {
            if _name_resized_in_body(node.items[ii], arr_name) { return true }
            ii = ii + 1
        }
    }
    if type_of(node.arms) == "array" {
        let mut mi = 0
        while mi < len(node.arms) {
            let arm = node.arms[mi]
            if type_of(arm) != "string" && type_of(arm.body) == "array" {
                if _name_resized_in_body(arm.body, arr_name) { return true }
            }
            mi = mi + 1
        }
    }
    return false
}

// Push an in-range fact: while live, `arr[idx_var]` reads elide the bounds check
// and index the native counter `c_counter` directly.
fn _inrange_push(idx_var, arr_name, c_counter) {
    _inrange_facts = _inrange_facts.push([idx_var, arr_name, c_counter])
}

fn _inrange_pop() {
    // Rebuild to length n-1 with index+push only (portable in-place truncation
    // across compiled-binary vintages — mirrors _comptime_const_scope_restore;
    // avoids relying on a .slice/.truncate codegen branch).
    let n = len(_inrange_facts)
    if n <= 0 { return }
    let mut _rebuilt = []
    let mut i = 0
    while i < n - 1 {
        _rebuilt.push(_inrange_facts[i])
        i = i + 1
    }
    _inrange_facts = _rebuilt
}

// If reading `arr_name[idx_name]` is covered by a LIVE in-range fact, return the
// native C counter to index by; else "". Most-recent (innermost) fact wins.
fn _inrange_counter_for(arr_name, idx_name) {
    let mut i = len(_inrange_facts) - 1
    while i >= 0 {
        let f = _inrange_facts[i]
        if f[0] == idx_name && f[1] == arr_name { return f[2] }
        i = i - 1
    }
    return ""
}

// Check if an initializer expression is int-only (for LetStmt registration).
// Covers: IntLit, int BinOp (recursive), Ident that is already known-int,
// UnaryOp - on int.
// decreases node — structural
fn _is_int_init_expr(node) {
    if type_of(node) == "string" { return false }
    let k = node.kind
    if k == "IntLit" { return true }
    if k == "Ident" { return _is_known_int_name(node.name) }
    if k == "BinOp" {
        let op = node.op
        if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" {
            return _is_int_init_expr(node.left) && _is_int_init_expr(node.right)
        }
        // RUNTIME.md cycle-100 codegen restore: `x as int` / `x as i64` initializer
        // registers the let as known-int so downstream `if ai == bi` etc. can
        // skip hexa_eq dispatch and emit raw HX_INT(ai)==HX_INT(bi).  Without
        // this, hexa_eq same-tag TAG_INT branch cannot port (recursion trap).
        if op == "as" {
            if type_of(node.right) != "string" && node.right.kind == "Ident" {
                let tn = node.right.name
                if tn == "int" { return true }
                if tn == "i64" { return true }
                if tn == "Int" { return true }
                if tn == "i32" { return true }
                if tn == "u32" { return true }
                if tn == "u64" { return true }
            }
            return false
        }
        return false
    }
    if k == "UnaryOp" {
        if node.op == "-" { return _is_int_init_expr(node.left) }
        return false
    }
    return false
}

// Check if an AST node is provably TAG_FLOAT at codegen time:
//   - FloatLit → always float
//   - Ident in _known_float_set → immutable let with float initializer
fn _is_known_float(node) {
    if type_of(node) == "string" { return false }
    if node.kind == "FloatLit" { return true }
    if node.kind == "Ident" { return _is_known_float_name(node.name) }
    return false
}

// Check if an initializer expression is float-only (for LetStmt registration).
// Covers: FloatLit, float BinOp (recursive), Ident that is already known-float,
// UnaryOp - on float. Mixed int+float promotes to float (C semantics).
// decreases node — structural
// Unambiguously-float-returning math builtins. Recognising them in
// `_is_float_init_expr` lets `let X = lgamma(...) + ...` register X as
// known-float so the cross-module collision-guard in
// _is_known_int_name fires — without this, the atlas-verify
// transcendental `let lhs = lgamma(1/6)+lgamma(5/6)-2*lgamma(0.5)`
// stays unregistered while a different module's
// `let lhs = sigma(n)*euler_phi(n)` pollutes the global known-int set,
// and the BinOp fast-path mis-emits HX_INT(lhs)-HX_INT(rhs) on float
// operands (parity-gate atlas root: 5 verdict FALSIFY).
fn _is_float_returning_call(name) {
    if type_of(name) != "string" { return false }
    if name == "lgamma"   { return true }
    if name == "tgamma"   { return true }
    if name == "log"      { return true }
    if name == "log2"     { return true }
    if name == "log10"    { return true }
    if name == "log1p"    { return true }
    if name == "exp"      { return true }
    if name == "exp2"     { return true }
    if name == "expm1"    { return true }
    if name == "sqrt"     { return true }
    if name == "cbrt"     { return true }
    if name == "hypot"    { return true }
    if name == "pow"      { return true }
    if name == "sin"      { return true }
    if name == "cos"      { return true }
    if name == "tan"      { return true }
    if name == "asin"     { return true }
    if name == "acos"     { return true }
    if name == "atan"     { return true }
    if name == "atan2"    { return true }
    if name == "sinh"     { return true }
    if name == "cosh"     { return true }
    if name == "tanh"     { return true }
    if name == "asinh"    { return true }
    if name == "acosh"    { return true }
    if name == "atanh"    { return true }
    if name == "erf"      { return true }
    if name == "erfc"     { return true }
    if name == "gamma"      { return true }
    if name == "bessel_j0"  { return true }
    if name == "bessel_j1"  { return true }
    if name == "_abs_f"   { return true }
    if name == "_ln2"     { return true }
    if name == "_log2_f"  { return true }
    if name == "_sqrt_f"  { return true }
    if name == "_pi_const" { return true }
    if name == "hexa_to_float" { return true }
    return false
}

fn _is_float_init_expr(node) {
    if type_of(node) == "string" { return false }
    let k = node.kind
    if k == "FloatLit" { return true }
    if k == "Ident" { return _is_known_float_name(node.name) }
    // 2026-05-19 atlas root-cause fix: a Call to an unambiguously-
    // float-returning math builtin makes the result float-init.
    if k == "Call" {
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            return _is_float_returning_call(node.left.name)
        }
        return false
    }
    if k == "BinOp" {
        let op = node.op
        if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" {
            let lf = _is_float_init_expr(node.left)
            let rf = _is_float_init_expr(node.right)
            if lf && rf { return true }
            if lf && _is_int_init_expr(node.right) { return true }
            if rf && _is_int_init_expr(node.left) { return true }
        }
        // RUNTIME.md cycle-100 codegen restore (symmetric to _is_int_init_expr):
        // `x as float` / `x as f64` initializer registers the let as known-float
        // so downstream `if af == bf` can skip hexa_eq dispatch and emit raw
        // HX_FLOAT(af)==HX_FLOAT(bf).  Required for hexa_eq same-tag TAG_FLOAT
        // branch port (recursion trap).
        if op == "as" {
            if type_of(node.right) != "string" && node.right.kind == "Ident" {
                let tn = node.right.name
                if tn == "float" { return true }
                if tn == "f64" { return true }
                if tn == "Float" { return true }
                if tn == "f32" { return true }
                if tn == "double" { return true }
            }
            return false
        }
        return false
    }
    if k == "UnaryOp" {
        if node.op == "-" { return _is_float_init_expr(node.left) }
        return false
    }
    return false
}

// C2: Emit a C boolean expression for a while-loop condition.
// For comparison ops (< > <= >= == !=), avoids hexa_truthy(hexa_cmp_*())
// double-dispatch.  When both operands are known-int, emits raw C comparison
// on HX_INT() directly (zero runtime overhead).  For && / || / !, recurses.
// Falls back to hexa_truthy(gen2_expr(...)) for anything else.
// decreases node — structural
fn _gen2_while_cond(node) {
    if type_of(node) == "string" { return "hexa_truthy(" + gen2_expr(node) + ")" }
    let k = node.kind
    if k == "BinOp" {
        let op = node.op
        // Ordered comparisons
        if op == "<" || op == ">" || op == "<=" || op == ">=" {
            let li = _is_known_int(node.left)
            let ri = _is_known_int(node.right)
            if li && ri {
                // Both operands provably TAG_INT — raw C compare, no runtime call
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_INT(" + l + ") " + op + " HX_INT(" + r + "))"
            }
            // STRUCTURAL-3: known-float comparison in while-cond
            let lf = _is_known_float(node.left)
            let rf = _is_known_float(node.right)
            if lf && rf {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_FLOAT(" + l + ") " + op + " HX_FLOAT(" + r + "))"
            }
            // General case — hexa_cmp_* returns hexa_bool(); extract .b directly
            let l = gen2_expr(node.left)
            let r = gen2_expr(node.right)
            if op == "<" { return "HX_BOOL(hexa_cmp_lt(" + l + ", " + r + "))" }
            if op == ">" { return "HX_BOOL(hexa_cmp_gt(" + l + ", " + r + "))" }
            if op == "<=" { return "HX_BOOL(hexa_cmp_le(" + l + ", " + r + "))" }
            return "HX_BOOL(hexa_cmp_ge(" + l + ", " + r + "))"
        }
        // Equality
        if op == "==" {
            let li = _is_known_int(node.left)
            let ri = _is_known_int(node.right)
            if li && ri {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_INT(" + l + ") == HX_INT(" + r + "))"
            }
            // STRUCTURAL-3: known-float equality in while-cond
            let lf = _is_known_float(node.left)
            let rf = _is_known_float(node.right)
            if lf && rf {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_FLOAT(" + l + ") == HX_FLOAT(" + r + "))"
            }
            return "hexa_truthy(hexa_eq(" + gen2_expr(node.left) + ", " + gen2_expr(node.right) + "))"
        }
        if op == "!=" {
            let li = _is_known_int(node.left)
            let ri = _is_known_int(node.right)
            if li && ri {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_INT(" + l + ") != HX_INT(" + r + "))"
            }
            // STRUCTURAL-3: known-float inequality in while-cond
            let lf = _is_known_float(node.left)
            let rf = _is_known_float(node.right)
            if lf && rf {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_FLOAT(" + l + ") != HX_FLOAT(" + r + "))"
            }
            return "(!hexa_truthy(hexa_eq(" + gen2_expr(node.left) + ", " + gen2_expr(node.right) + ")))"
        }
        // Logical connectives — recurse into sub-conditions
        if op == "&&" {
            return "(" + _gen2_while_cond(node.left) + " && " + _gen2_while_cond(node.right) + ")"
        }
        if op == "||" {
            return "(" + _gen2_while_cond(node.left) + " || " + _gen2_while_cond(node.right) + ")"
        }
    }
    if k == "UnaryOp" {
        if node.op == "!" {
            return "(!" + _gen2_while_cond(node.left) + ")"
        }
    }
    // Fallback: general expression — use hexa_truthy as before
    return "hexa_truthy(" + gen2_expr(node) + ")"
}

// Builtin names that are never captured (resolved at codegen in gen2_expr Call).
fn _is_builtin_name(name) {
    if name == "println" { return true }
    if name == "print" { return true }
    if name == "eprintln" { return true }
