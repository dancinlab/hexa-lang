        }
        // PROBE r7: `x in container` — Python/Swift membership op.
        // hexa_contains_poly dispatches by container tag (array → element
        // equality, string → substring).  Convention: `x in arr` reads as
        // "needle in haystack" → container is the rhs.
        if op == "in" {
            return "hexa_contains_poly(" + r + ", " + l + ")"
        }
        eprintln("[codegen] ERROR: unhandled binary operator: " + op)
        return "(fprintf(stderr, \"CODEGEN ERROR: unhandled binop: " + op + "\\n\"), exit(1), hexa_void())"
    }

    if k == "UnaryOp" {
        // STRUCTURAL-3: known-float unary minus → direct double negation
        if node.op == "-" && _is_known_float(node.left) {
            return "hexa_float(-HX_FLOAT(" + gen2_expr(node.left) + "))"
        }
        // T23 fix: unary minus must honor TAG_FLOAT. Route through
        // hexa_sub(0, x) which uses the float-aware runtime helper.
        if node.op == "-" { return "hexa_sub(hexa_int(0), " + gen2_expr(node.left) + ")" }
        if node.op == "!" { return "hexa_bool(!hexa_truthy(" + gen2_expr(node.left) + "))" }
        if node.op == "~" { return "hexa_int(~hexa_as_num(" + gen2_expr(node.left) + "))" }
        // PROBE r16 Q2: unary plus `+x` is identity (numeric passthrough). A
        // GCC stmt-expr binds the operand once and throws on a non-numeric
        // operand (TAG_INT/TAG_FLOAT/TAG_CHAR accepted), mirroring the canonical
        // Go/Rust rule that `+` only applies to a number. Previously `+x`
        // mis-parsed to an empty map `{}`.
        if node.op == "+" {
            // UNSHADOW 🔵 C — refinement-type tag-check ELISION (prove-then-delete).
            // The numeric-operand guard below is a runtime tag-check. When the
            // operand is PROVABLY TAG_INT or TAG_FLOAT at emit time (IntLit /
            // FloatLit / immutable int|float-typed Ident — exactly what
            // _is_known_int / _is_known_float certify), the guard predicate
            // `!(HX_IS_INT||HX_IS_FLOAT||...)` is STATICALLY FALSE → the
            // hexa_throw arm is dead. Unary `+` is numeric identity, so the
            // statement-expr collapses to the operand itself. We DELETE the
            // whole check and emit the operand directly. byte-identical: the
            // elided branch was statically unreachable; the surviving value is
            // `__upx == (_o)` exactly. EXACT guard (comptime-fold-shadow family
            // hazard): elide ONLY on local _is_known proof — every other
            // operand (unknown-tag Ident, Call, Field, …) keeps the full guard,
            // so the general case is unchanged.
            if _is_known_int(node.left) || _is_known_float(node.left) {
                return "(" + gen2_expr(node.left) + ")"
            }
            let _o = gen2_expr(node.left)
            return "({ HexaVal __upx = (" + _o + "); " +
                   "if (!(HX_IS_INT(__upx)||HX_IS_FLOAT(__upx)||HX_TAG(__upx)==TAG_CHAR)) " +
                   "hexa_throw(hexa_str(\"unary + requires a numeric operand\")); __upx; })"
        }
        // `typeof x` — parser yields UnaryOp{op:"typeof"}. Reuse the same
        // runtime symbol the type_of(x) call form maps to (hexa_type_of,
        // codegen L3672/4506). Parity gap (t47_let_mut_zero).
        if node.op == "typeof" { return "hexa_type_of(" + gen2_expr(node.left) + ")" }
        eprintln("[codegen_c2] ERROR: unhandled unary operator: " + node.op)
        return "(fprintf(stderr, \"CODEGEN ERROR: unhandled unary op: " + node.op + "\\n\"), exit(1), hexa_void())"
    }

    // ── Field access: obj.field → hexa_map_get_ic(obj, "field", &ic) ──
    // rt#37: each call site gets a unique static HexaIC slot, emitted as a
    // file-scope global so it survives across calls within the same binary.
    if k == "Field" {
        // enum-variant access fix (inbox: enum-variant-access-miscodegen):
        // `<EnumName>.<VARIANT>` (e.g. RegionShape.K_BY_K) is an enum-variant
        // constant, NOT a runtime field access. node.left is a bare Ident
        // whose name is a known enum type → emit the gen2_enum_decl #define
        // `<EnumName>_<VARIANT>`. Without this it falls through to the
        // generic hexa_map_get_ic(RegionShape, "K_BY_K", &ic) — but
        // `RegionShape` is a type name with no C runtime value ("undeclared
        // identifier"). Non-enum field access is unchanged (falls through).
        if type_of(node.left) != "string" && node.left.kind == "Ident" && _is_enum_name(node.left.name) {
            return node.left.name + "_" + node.name
        }
        // UNSHADOW typed monomorphic struct layout (GATED HEXA_TYPED_STRUCT=1):
        // if the receiver is a var statically known to hold a flat-eligible
        // struct instance AND `field` is a declared field of that type, emit a
        // compile-time OFFSET load (`((Name__flat*)recv.vs)->f<idx>`) instead of
        // hexa_map_get_ic. NO strcmp, NO inline-cache slot, NO hash probe. The
        // flat pointer rides the public HexaVal `vs` slot (matches the flat
        // constructor in gen2_flat_struct_typedef). Any dynamic key, any non-
        // flat receiver, or a typo'd / non-declared field (idx<0) falls through
        // to the unchanged hexa_map_get_ic hash-map path — so polymorphic /
        // dynamic-key structs are unaffected (integrity gate).
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let _fst = _flat_var_type(node.left.name)
            if _fst != "" {
                let _fidx = _flat_field_index(_fst, node.name)
                if _fidx >= 0 {
                    return "(((" + _fst + "__flat*)(" + node.left.name + ").vs)->f" + to_string(_fidx) + ")"
                }
            }
        }
        let obj = gen2_expr(node.left)
        let field = node.name
        let id = _ic_counter
        _ic_counter = _ic_counter + 1
        let slot = "__hexa" + "_ic_" + to_string(id)
        // rt#32 우회: 슬롯 정의는 emit 시점에 _ic_counter로 유도 (hot path 배열 변이 제거)
        return "hexa_map_get_ic(" + obj + ", \"" + field + "\", &" + slot + ")"
    }

    // ── Optional chaining (PROBE r14-BB): obj?.field ──
    // Short-circuits to hexa_void() when obj is void; otherwise behaves
    // like a plain Field access (hexa_map_get_ic with a per-site IC slot).
    // Canonical Swift/JS/TS semantics: `a?.b?.c` returns void as soon as
    // any intermediate hop is void; otherwise the final field value.
    // Scope (intentionally narrow): struct-field reads only. Optional
    // method calls (`a?.f()`) are filed as follow-up; the Call arm does
    // not yet recognise an OptField callee.
    if k == "OptField" {
        let obj = gen2_expr(node.left)
        let field = node.name
        let id = _ic_counter
        _ic_counter = _ic_counter + 1
        let slot = "__hexa" + "_ic_" + to_string(id)
        // GCC/clang statement-expression evaluates `obj` once into __optrcv
        // (avoid double-eval of side-effecting receivers) then branches on
        // tag == TAG_VOID. Uses public HX_TAG macro from runtime.h (the
        // sibling HX_IS_VOID convenience macro is private to runtime_core.c).
        // Mirrors the existing statement-expr pattern used elsewhere in
        // this file (e.g. method-dispatch + array-literal).
        return "({ HexaVal __optrcv = " + obj + "; HX_TAG(__optrcv) == TAG_VOID ? hexa_void() : hexa_map_get_ic(__optrcv, \"" + field + "\", &" + slot + "); })"
    }

    // ── Struct init: Name { f1: v1, f2: v2 } → constructor call ──
    // FIX-A (Anima stdlib unblock, 2026-04-19): empty-literal `Name {}` cannot
    // call Name() because structs with fields were declared as Name(HexaVal a, …).
    // Emit an inline zero-field struct pack so `Linear {}` works regardless of
    // whether Linear has fields — caller is opting out of positional init.
    if k == "StructInit" {
        let mut name = node.name
        // `Self { … }` inside an impl block resolves to the enclosing
        // impl target — without this the codegen emits `Self(args)` and
        // clang errors on undeclared `Self`.
        if name == "Self" && len(_cur_impl_target) > 0 {
            name = _cur_impl_target
        }
        // PROBE r14-CCCC: if the struct is known (declared in this TU),
        // walk declared field order and fill missing fields with their
        // per-field default expressions; emit a clang-side compile error
        // for any field that is both missing AND lacking a default. This
        // closes the silent-corruption hole where `Point {}` previously
        // returned an empty map and `p.x` failed at runtime.
        let _sidx = _struct_decl_index(name)
        if _sidx >= 0 {
            let _decl_fnames = _struct_field_names[_sidx]
            let _decl_fdefs = _struct_field_defaults[_sidx]
            let mut arg_strs = []
            let mut _di = 0
            while _di < len(_decl_fnames) {
                let _dfn = _decl_fnames[_di]
                // Find matching FieldInit in the literal by field name.
                let mut _matched = -1
                let mut _fi = 0
                while _fi < len(node.fields) {
                    if node.fields[_fi].name == _dfn { _matched = _fi }
                    _fi = _fi + 1
                }
                let mut _expr_node = ""
                if _matched >= 0 {
                    _expr_node = node.fields[_matched].left
                } else if _decl_fdefs[_di] != "" {
                    _expr_node = _decl_fdefs[_di]
                } else {
                    // Hard error: missing field, no default. Emit a sentinel
                    // that clang will reject with a clear identifier name,
                    // turning the previous silent runtime-corruption case
                    // into a compile-time failure.
                    arg_strs.push("hexa_codegen_error__missing_field__" + name + "__" + _dfn)
                    _di = _di + 1
                    continue
                }
                let mut _arg_str = gen2_expr(_expr_node)
                if type_of(_expr_node) != "string" && _expr_node.kind == "Ident" && _gen2_should_autowrap_fnref(_expr_node.name) {
                    _arg_str = "hexa_fn_new((void*)" + _hexa_mangle_ident(_expr_node.name) + ", 0)"
                }
                arg_strs.push(_arg_str)
                _di = _di + 1
            }
            return name + "(" + arg_strs.join(", ") + ")"
        }
        // Unknown / extern struct — legacy positional path (preserves the
        // pre-CCCC behavior so anima/stdlib `Name {}` patterns keep working).
        if len(node.fields) == 0 {
            return "hexa_struct_pack_map(\"" + name + "\", 0, (const char* const*)0, (const HexaVal*)0)"
        }
        let mut arg_strs = []
        let mut si = 0
        while si < len(node.fields) {
            // auto-wrap bare fn-ref fields as TAG_FN HexaVal (mirrors the
            // indirect-call wrap at the gen2_method_builtin sort_by arm and
            // the general callsite at line 4573). Without this, passing
            // `Dispatcher { handler: my_fn, ... }` emits `Dispatcher(my_fn, ...)`
            // where my_fn is C fn-pointer typed `HexaVal (HexaVal)`, not the
            // `HexaVal` the constructor expects → clang error. Filed at
            // archive/patches/struct-fn-field-wrap.md (2026-05-14).
            let _sfv = node.fields[si].left
            let mut _sfv_expr = gen2_expr(_sfv)
            if type_of(_sfv) != "string" && _sfv.kind == "Ident" && _gen2_should_autowrap_fnref(_sfv.name) {
                _sfv_expr = "hexa_fn_new((void*)" + _hexa_mangle_ident(_sfv.name) + ", 0)"
            }
            arg_strs.push(_sfv_expr)
            si = si + 1
        }
        return name + "(" + arg_strs.join(", ") + ")"
    }

    if k == "Call" {
        let callee = node.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let name = callee.name
            // ── UNSHADOW item #4: atlas-guided const-fold pilot ────────────
            // hexa-arch-native optimization (UNSHADOW.easy.md §A, "루프/호출을
            // 안 돌기"): when codegen sees a call to a PURE atlas-verified fn
            // whose value is recorded in the atlas AND every argument is a
            // literal, emit the verified literal result directly instead of a
            // runtime call across the C-ABI boundary. LLVM cannot do this — it
            // has no theorem/verdict DB.
            //
            // SCOPE — ONE narrow case (NOT a general fold framework):
            //   beenet_grid_bins(100.0, 10.0)  →  hexa_int(11)
            //
            // Verdict source (g5 · @D h_verify_auto_absorb):
            //   `hexa verify --expr beenet_grid_bins 100.0 10.0 11`
            //     calc = 11.0 ≈ expected 11.0 (|Δ|=0.0 ≤ ε=1e-9)
            //     tier = 🟢 SUPPORTED-NUMERICAL · absorb = already in atlas
            //   def: beenet_grid_bins(ω,Δ) = floor(ω/Δ)+1  (verify_cli.hexa:1500)
            //   → floor(100.0/10.0)+1 = floor(10.0)+1 = 11.
            //
            // GUARD IS EXACT (comptime-fold-shadow family avoidance, MEMORY
            // reference_comptime_fold_shadow_family): the fold fires ONLY when
            // (a) the name is EXACTLY beenet_grid_bins, (b) it resolves to a
            // top-level fn declaration (`_is_known_fn_global` — i.e. the user
            // actually defined `fn beenet_grid_bins(...)` with the atlas-
            // canonical body, so fold-off vs fold-on are byte-comparable), (c)
            // there are EXACTLY 2 args, and (d) BOTH args are FloatLit nodes
            // whose source tokens EXACTLY match the verified pair ("100.0",
            // "10.0"). Any other call — different args, a non-literal arg, a
            // local-let shadow that isn't a known global — falls through
            // unchanged (zero behavior change for the general case). DOUBLE-EVAL
            // SAFE: literal args are never evaluated (the call is replaced
            // wholesale by a constant), so there is no double-eval surface.
            if name == "beenet_grid_bins" && _is_known_fn_global(name) && !_gen2_has_decl(name) && len(node.args) == 2 {
                let _fa0 = node.args[0]
                let _fa1 = node.args[1]
                if type_of(_fa0) != "string" && _fa0.kind == "FloatLit"
                    && type_of(_fa1) != "string" && _fa1.kind == "FloatLit"
                    && _fa0.value == "100.0" && _fa1.value == "10.0" {
                    // atlas-verified literal — emit the constant, skip the call.
                    return "hexa_int(11)"
                }
            }
            // ── UNSHADOW item #B: proof-carrying optimization + cross-layer inline ─
            // hexa-arch-native optimization (UNSHADOW.easy.md §B, "증명-허가"):
            // a VERIFIED SEMANTIC IDENTITY licenses codegen to replace an opaque,
            // out-of-line C-ABI call with the proven-equivalent closed form,
            // INLINED using only runtime.h-visible layout (the #2 cross-layer
            // inline lesson — hexa_int/hexa_float box literals link, internal
            // helpers like HX_STRLEN do not). This COMBINES #4 (atlas verdict as
            // a license) with #2 (layout-only cross-ABI inline).
            //
            // THE LICENSE (proof — without it this transform is UNSOUND):
            //   atlas node `verified-lambda_eliashberg-num`
            //     @F lambda_eliashberg(0.5) = 1.0  (= 2·0.5)  tier 🟢 SUPPORTED-NUMERICAL
            //   `hexa verify --expr lambda_eliashberg 0.5 1.0`  (verify_cli.hexa:3402)
            //   certifies the identity  lambda_eliashberg(M0) ≡ 2·M0  on the
            //   verified domain (guard: M0<0 → _NOCALC_F = -999999.0,
            //   verify_cli.hexa:1490). codegen has NO knowledge of the fn body —
            //   only the atlas identity authorizes substituting the closed form
            //   for the opaque call. LLVM cannot do this: the call is a precompiled
            //   runtime.o symbol (no LTO / no cross-TU visibility) and LLVM has no
            //   theorem/verdict DB to license the substitution.
            //
            // THE TRANSFORM (faithful — preserves the verified guard, so the A/B
            // byte-diff is IDENTICAL on ALL inputs incl. negatives):
            //   lambda_eliashberg(EXPR)
            //     → ({ HexaVal __le_x = (EXPR);
            //          HX_FLOAT(__le_x) < 0.0
            //            ? hexa_float(-999999.0)
            //            : ((HexaVal){.tag=TAG_FLOAT,.f=(2.0 * HX_FLOAT(__le_x))}); })
            //
            // DOUBLE-EVAL SAFE (the #2-ext lesson — expression args, unlike the
            // #4 literal args, MUST be let-bound once): EXPR is bound a single time
            // into __le_x, then read 3× (the guard test + the two multiplicands).
            // Without the let-bind, a side-effecting EXPR would run 3× — the
            // to_int double-eval / comptime-fold-shadow miscompile family.
            //
            // GUARD IS EXACT (comptime-fold-shadow family avoidance): fires ONLY
            // when (a) the name is EXACTLY lambda_eliashberg, (b) it resolves to a
            // top-level user fn declaration (`_is_known_fn_global`) whose body is
            // the atlas-canonical closed form — so fold-off (real call) vs fold-on
            // (inlined closed form) are byte-comparable, (c) it is NOT a local-let
            // shadow (`!_gen2_has_decl`), (d) there is EXACTLY 1 arg. Any other
            // call falls through unchanged (zero behavior change otherwise).
            // ── UNSHADOW item: verify memoization (F3 atlas-as-perf-asset) ──
            // hexa-arch-native optimization (UNSHADOW.MINING.md F3·C18,
            // easy.md §G "검증 memoization"): when the atlas PROVES a fn is
            // PURE + IDEMPOTENT, codegen may insert a call-result CACHE so that
            // a REPEATED call with the SAME argument value skips the (opaque,
            // cross-C-ABI) recompute and returns the cached result. LLVM cannot
            // do this — `pure`/`const` attrs let clang CSE adjacent identical
            // calls within one expression, but it has no theorem/verdict DB to
            // prove a runtime.o symbol is idempotent across loop iterations, so
            // it re-emits the `bl _lambda_eliashberg` every iteration.
            //
            // THE LICENSE (proof — without it the cache is UNSOUND):
            //   atlas node `verified-lambda_eliashberg-num`
            //     @F lambda_eliashberg(0.5) = 1.0   tier 🟢 SUPPORTED-NUMERICAL
            //   The verdict certifies lambda_eliashberg is a deterministic,
            //   side-effect-free numeric function of its single argument (the
            //   atlas only admits PURE numeric @F entries — see verify_cli.hexa
            //   _lambda_eliashberg: arithmetic only, no I/O / no global state).
            //   PURE ⇒ f(x) depends only on x; IDEMPOTENT-as-cache ⇒ caching the
            //   last (x, f(x)) pair is observationally equivalent to recomputing.
            //   Because f is pure, cached-value ≡ recomputed-value EXACTLY, so
            //   the A/B byte-diff (memo HIT vs memo MISS vs no-memo) is IDENTICAL.
            //
            // THE TRANSFORM (fn-local static last-arg cache, faithful — calls
            // the REAL verified fn on a miss, so the verified guard incl.
            // negatives is preserved verbatim):
            //   lambda_eliashberg(EXPR)
            //     → ({ static int __lem_v = 0; static double __lem_a;
            //          static HexaVal __lem_r;
            //          HexaVal __lem_x = (EXPR); double __lem_xf = HX_FLOAT(__lem_x);
            //          if (!(__lem_v && __lem_a == __lem_xf)) {
            //              __lem_r = lambda_eliashberg(__lem_x);
            //              __lem_a = __lem_xf; __lem_v = 1; }
            //          __lem_r; })
            // The single-eval discipline (#2-ext / to_int double-eval lesson):
            // EXPR is bound ONCE into __lem_x, so a side-effecting EXPR runs once.
            //
            // GATED OPT-IN — DEFAULT OFF (zero regression). Fires only when
            // env HEXA_VERIFY_MEMO is set AND the EXACT atlas-verified name +
            // top-level-decl + non-shadow + 1-arg guard holds (same exactness as
            // §A/§B; comptime-fold-shadow family avoidance). Off → falls through
            // to the §B closed-form inline / normal call (no behavior change).
            if name == "lambda_eliashberg" && env("HEXA_VERIFY_MEMO") != "" && _is_known_fn_global(name) && !_gen2_has_decl(name) && len(node.args) == 1 {
                let _lem_arg = gen2_expr(node.args[0])
                return "({ static int __lem_v = 0; static double __lem_a; static HexaVal __lem_r; HexaVal __lem_x = (" + _lem_arg + "); double __lem_xf = HX_FLOAT(__lem_x); if (!(__lem_v && __lem_a == __lem_xf)) { __lem_r = lambda_eliashberg(__lem_x); __lem_a = __lem_xf; __lem_v = 1; } __lem_r; })"
            }
            if name == "lambda_eliashberg" && _is_known_fn_global(name) && !_gen2_has_decl(name) && len(node.args) == 1 {
                let _le_arg = gen2_expr(node.args[0])
                return "({ HexaVal __le_x = (" + _le_arg + "); HX_FLOAT(__le_x) < 0.0 ? hexa_float(-999999.0) : ((HexaVal){.tag=TAG_FLOAT,.f=(2.0 * HX_FLOAT(__le_x))}); })"
            }
            // PROBE r15-D3: Option/Result tagged-array constructors —
            // `Some(x)` / `Ok(x)` / `Err(x)` lower to `[hexa_str(tag), x]`,
            // mirroring the EnumPath payload convention (`[tag, payload]`
            // at index 0/1; see gen2_expr EnumPath branch and gen2_match_cond
            // EnumPath arm). Bare `None` is the tag itself (hexa_str("None"),
            // emitted in the Ident branch above). Guarded by !_gen2_has_decl
            // so a user `fn Some(x)` shadow wins — keeps Rust-style canon
            // (the std prelude can be shadowed) and avoids changing existing
            // semantics for projects that already defined these names.
            if (name == "Some" || name == "Ok" || name == "Err") && !_gen2_has_decl(name) && !_is_known_fn_global(name) {
                let nargs_o = len(node.args)
                if nargs_o == 1 {
                    return "hexa_array_push(hexa_array_push(hexa_array_new(), hexa_str(\"" + name + "\")), " + gen2_expr(node.args[0]) + ")"
                }
            }
            // Built-in mappings
            // FIX (2026-04-20): variadic println/print — prior codegen
            // dropped args[1..], emitting only `hexa_println(args[0])`. For
            // println("step=", n, " loss=", f) this produced `step=`.
            // Now emit `(hexa_print_val(a1), ..., hexa_println(aN))` so all
            // args reach stdout with the final one consuming the newline.
            if name == "println" {
                let nargs_p = len(node.args)
                if nargs_p == 0 {
                    return "(printf(\"\\n\"), hexa_void())"
                }
                if nargs_p == 1 {
                    return "hexa_println(" + gen2_expr(node.args[0]) + ")"
                }
                let mut pp = "("
                let mut ip = 0
                while ip < nargs_p - 1 {
                    pp = pp + "hexa_print_val(" + gen2_expr(node.args[ip]) + "), "
                    ip = ip + 1
                }
                pp = pp + "hexa_println(" + gen2_expr(node.args[nargs_p - 1]) + "))"
                return pp
            }
            if name == "print" {
                let nargs_pr = len(node.args)
                if nargs_pr == 0 {
                    return "hexa_void()"
                }
                if nargs_pr == 1 {
                    return "(hexa_print_val(" + gen2_expr(node.args[0]) + "), hexa_void())"
                }
                let mut pr = "("
                let mut ir = 0
                while ir < nargs_pr {
                    pr = pr + "hexa_print_val(" + gen2_expr(node.args[ir]) + "), "
                    ir = ir + 1
                }
                pr = pr + "hexa_void())"
                return pr
            }
            if name == "len" {
                return "hexa_int(hexa_len(" + gen2_expr(node.args[0]) + "))"
            }
            if name == "to_string" {
                return "hexa_to_string(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "type_of" {
                return "hexa_type_of(" + gen2_expr(node.args[0]) + ")"
            }
            // RFC 055 055-P3c — host-side `gpu_launch(...)` builtin lowers
            // to the C runtime wrapper `_hx_cuda_launch_kernel(...)`. The
            // caller arranges the cubin blob + length (until P3c.e auto-
            // embed lands; today the caller passes a `const char*`-shaped
            // cubin blob + a `size_t` length, mirroring the launch ABI
            // declared in self/runtime.h). Argument shape is pass-through
            // — clang reports any signature mismatch at compile time.
            if name == "gpu_launch" {
                let mut gl = "_hx_cuda_launch_kernel("
                let mut gi = 0
                while gi < len(node.args) {
                    if gi > 0 { gl = gl + ", " }
                    gl = gl + gen2_expr(node.args[gi])
