                if name == "farr_copy"      { return "hexa_farr_copy(" + a0 + ")" }
                // anima RFC 034 (2026-05-16): farr autograd — 1-arg forms.
                if name == "ad_tape_end"    { return "hexa_ad_tape_end(" + a0 + ")" }
                if name == "ad_backward"    { return "hexa_ad_backward(" + a0 + ")" }
                if name == "ad_grad"        { return "hexa_ad_grad(" + a0 + ")" }
                // RFC 025 (2026-05-12): safetensors mmap-backed zero-copy
                // load. 1-arg forms (open/close/header/data_offset/size).
                if name == "safetensors_mmap_open"        { return "hexa_safetensors_mmap_open(" + a0 + ")" }
                if name == "safetensors_mmap_header"      { return "hexa_safetensors_mmap_header(" + a0 + ")" }
                if name == "safetensors_mmap_data_offset" { return "hexa_safetensors_mmap_data_offset(" + a0 + ")" }
                if name == "safetensors_mmap_size"        { return "hexa_safetensors_mmap_size(" + a0 + ")" }
                if name == "safetensors_mmap_close"       { return "hexa_safetensors_mmap_close(" + a0 + ")" }
                if name == "keys"           { return "hexa_map_keys(" + a0 + ")" }
                if name == "values"         { return "hexa_map_values(" + a0 + ")" }
                // F10 retire (2026-04-28): bare-call map_* builtins for AOT.
                // Mirrors method form (tbl.keys / tbl.values / tbl.contains_key
                // / etc.) so A17/A18/A19 (which call as bare functions) build.
                // Method form is unchanged — see gen2_method_builtin and the
                // inline Field-Call branch below.
                if name == "map_keys"       { return "hexa_map_keys(" + a0 + ")" }
                if name == "map_values"     { return "hexa_map_values(" + a0 + ")" }
                if name == "map_entries"    { return "hexa_map_entries(" + a0 + ")" }
                if name == "map_size"       { return "hexa_int(hexa_len(" + a0 + "))" }
                if name == "env_var"        { return "hexa_env_var(" + a0 + ")" }
                if name == "env"            { return "hexa_env_var(" + a0 + ")" }
                if name == "delete_file"    { return "rt_delete_file(" + a0 + ")" }
                // G5 (wilson-pi-port-6-gap S-FS-ATOMIC-APPEND) — 1-arg primitives.
