            }
            if name == "max" {
                let a = gen2_expr(node.args[0])
                let b = gen2_expr(node.args[1])
                return "({ HexaVal __ha = (" + a + "), __hb = (" + b + "); (HX_IS_INT(__ha) && HX_IS_INT(__hb)) ? ({ int64_t __a = HX_INT(__ha); int64_t __b = HX_INT(__hb); hexa_int(__a > __b ? __a : __b); }) : ({ double __fa = __hx_to_double(__ha); double __fb = __hx_to_double(__hb); hexa_float(__fa > __fb ? __fa : __fb); }); })"
            }
