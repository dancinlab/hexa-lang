// CANON M10: focused per-verb help. `hexa <verb> --help` / `-h` lands here
// instead of dumping the whole top-level catalog (cmd_help). One uniform
// block per core verb: signature · one-line purpose · key flags. Verbs that
// own a sub-CLI binary (atlas/qrng/qmirror/cloud/loop/gpu/sim-universe) keep
// delegating --help to their own binary; this covers the core toolchain 11.
fn cmd_verb_help(verb) {
    if verb == "run" {
        println("hexa run [--no-sentinel] <file> [args...]")
        println("  Compile a .hexa script to a native binary, then exec it (interp retired).")
        println("  args...        forwarded to the script as argv")
        println("  --no-sentinel  drop the trailing __HEXA_RC=N stdout sentinel (clean pipe)")
    } else if verb == "build" {
        println("hexa build <file> [-o out] [--target=<t>] [--shared] [--c-only]")
        println("  Compile a .hexa file to a native binary (RFC-018 5-stage IR; atlas baked in).")
        println("  -o out         output path (default build/artifacts/app)")
        println("  --target=<t>   cross-compile target triple")
        println("  --shared       emit a shared library (.so/.dylib; -fPIC -shared)")
        println("  --c-only       stop after C emission (no clang link)")
    } else if verb == "test" {
        println("hexa test <file> [--filter NAME] [--verbose] [--selftest-only]")
        println("  Run the @test fns in <file> via the native test runner.")
        println("  --filter NAME  run only @test fns whose name contains NAME")
        println("  --verbose      per-test output")
    } else if verb == "parse" {
        println("hexa parse <file>")
        println("  Parse-only syntactic check — no codegen, no exec. Exit 0 OK, 1 on error.")
    } else if verb == "check" {
        println("hexa check <file>")
        println("  Verify @invariant DSL blocks (AST-based predicate check). Exit 0 OK, else nonzero.")
    } else if verb == "typecheck" {
        println("hexa typecheck <file>")
        println("  Opt-in type-checker pass over <file> (diagnostics only, no codegen).")
    } else if verb == "bench" {
        println("hexa bench <file> [--runs N] [--json] [--compare <bin>]")
        println("  Benchmark wall/RSS/alloc over N runs (default 3).")
        println("  --json             machine-readable output")
        println("  --compare <bin>    A/B against another binary")
    } else if verb == "cc" {
        println("hexa cc [--regen]")
        println("  Rebuild the transpiler (hexa_cc — the C-seed compiler, go-tool-compile style).")
        println("  --regen        run the full auto-regeneration pipeline")
    } else if verb == "lsp" {
        println("hexa lsp")
        println("  Start the LSP server (stdin/stdout JSON-RPC) for editor integration.")
    } else if verb == "init" {
        println("hexa init <dir> [--name N]")
        println("  Scaffold <dir>/project.hexa + main.hexa. Refuses to clobber an existing project.")
        println("  --name N       project name (default = basename of <dir>)")
    } else if verb == "status" {
        println("hexa status")
        println("  Print toolchain status (transpiler / installed binaries / repo root).")
    } else if verb == "version" {
        println("hexa version    (also: --version, -v)")
        println("  Print the version string + build hash.")
    // ─── CANON M11: in-tree TOOLCHAIN drawer verbs (batch/tape/hxc/url/convergence) ───
    } else if verb == "batch" {
        println("hexa batch <file1.hexa> [file2.hexa ...]")
        println("  Compile-and-run N scripts under ONE dispatcher boot (ω-hexa-batch).")
        println("  files...       positional .hexa paths (manifest/stdin list deferred)")
    } else if verb == "tape" {
        println("hexa tape <file.tape>")
        println("  Native .tape v1.2 reader — dump the parsed directive tree. Exit 0 OK, 2 misuse.")
    } else if verb == "hxc" {
        println("hexa hxc <file.hxc>")
        println("  Generic HXC v2 wire decoder — dump the decoded record stream. Exit 0 OK, 2 misuse.")
    } else if verb == "url" {
        println("hexa url <hexa://...>")
        println("  Dispatch a hexa:// URL (e.g. 'hexa://run?file=/path/script.hexa&args=foo').")
    } else if verb == "convergence" {
        println("hexa convergence <dump|dump-meta> <file>")
        println("  Scan source-embedded @convergence metadata → JSON dump.")
        println("  dump <file>        emit the convergence blocks as JSON")
        println("  dump-meta <file>   emit only the metadata header")
    } else {
        // Unknown / sub-CLI verb — fall back to the full catalog.
        cmd_help()
    }
}

// CANON M11: uniform per-verb help for the absorbed tool-drawer verbs
// (DISCOVERY · EXTERNAL · ANNOTATOR · SCIENCE families that route through
// dispatch_absorbed). One tight block per verb — signature · purpose. The
// intercept at the top of dispatch_absorbed() catches `--help`/`-h` BEFORE
// the verb's real (often heavy — drill/kick/omega/…) work runs. Sub-CLI
// delegators (atlas/qrng/qmirror/cloud/loop/gpu/sim-universe) self-delegate
// and are NOT routed here.
fn cmd_absorbed_help(verb) {
    // DISCOVERY family (compiler/{drill,chain,...}) — gap-breakthrough engines.
    if verb == "drill" || verb == "kick" {
        println("hexa " + verb + " --seed \"<text>\" [--rounds N] [--engine mk9|mk10]")
        println("  Gap-breakthrough discovery engine (kick ≡ drill apex). Verifies + folds atlas atoms.")
    } else if verb == "chain"  { println("hexa chain [args]\n  DISCOVERY — chained drill rounds (multi-stage ω-cycle).")
    } else if verb == "omega"  { println("hexa omega [args]\n  DISCOVERY — ω-cycle apex discovery driver.")
    } else if verb == "surge"  { println("hexa surge [args]\n  DISCOVERY — burst-mode candidate generation.")
    } else if verb == "dream"  { println("hexa dream [args]\n  DISCOVERY — speculative candidate exploration.")
    } else if verb == "swarm"  { println("hexa swarm [args]\n  DISCOVERY — parallel multi-agent candidate sweep.")
    } else if verb == "reign"  { println("hexa reign [args]\n  DISCOVERY — dominance/selection over candidate pools.")
    } else if verb == "molt"   { println("hexa molt [args]\n  DISCOVERY — shed/refresh stale candidate state.")
    } else if verb == "wake"   { println("hexa wake [args]\n  DISCOVERY — resume a suspended discovery cycle.")
    } else if verb == "forge"  { println("hexa forge [args]\n  DISCOVERY — synthesize new artifacts from verified atoms.")
    } else if verb == "canon"  { println("hexa canon [args]\n  DISCOVERY — canonicalize discoveries into the atlas.")
    } else if verb == "debate" { println("hexa debate [args]\n  DISCOVERY — adversarial cross-check of candidate claims.")
    } else if verb == "revive" { println("hexa revive [args]\n  DISCOVERY — re-run/recover a prior discovery session.")
    // Phase 2 generators / verifiers.
    } else if verb == "smash"           { println("hexa smash [args]\n  DISCOVERY — generator: smash a target into sub-claims.")
    } else if verb == "free"            { println("hexa free [args]\n  DISCOVERY — generator: free-form claim expansion.")
    } else if verb == "hyperarithmetic" { println("hexa hyperarithmetic [args]\n  DISCOVERY — generator: hyperarithmetic claim ladder.")
    } else if verb == "honesty"         { println("hexa honesty <file>\n  AUDIT — over-claim / honesty verifier (BT-AI2 audit surface).")
    } else if verb == "absolute"        { println("hexa absolute <file>\n  AUDIT — absolute-claim verifier (no unfenced superlatives).")
    } else if verb == "meta-closure"    { println("hexa meta-closure <file>\n  AUDIT — meta-closure verifier (claim-graph terminality).")
    // SCIENCE absorbed verbs.
    } else if verb == "lattice"             { println("hexa lattice <verify|axis-table|cross-check>\n  SCIENCE — n=6 lattice math (pure-math axis tables · cross-check).")
    } else if verb == "atlas-audit"         { println("hexa atlas-audit <external-entity|anchor|all>\n  AUDIT — overlay-corpus atlas audit (hexa-matter doctrine gate).")
    } else if verb == "atlas-verify"        { println("hexa atlas-verify [--domain D]\n  AUDIT — atlas verdict ledger (Stage 1+2+3 hexa-native).")
    } else if verb == "repo-audit-taxonomy" { println("hexa repo-audit-taxonomy <catalog.md> <manifest.toml> [<root>]\n  AUDIT — repo taxonomy / catalog-vs-manifest audit.")
    } else if verb == "akida"               { println("hexa akida [args]\n  EXTERNAL — Akida neuromorphic HW probe.")
    // EXTERNAL data bridges (compiler/bridges/*) — fetch + verify against a source.
    } else if verb == "codata" || verb == "oeis" || verb == "arxiv" || verb == "gw" || verb == "horizons"
           || verb == "cmb" || verb == "nanograv" || verb == "simbad" || verb == "icecube"
           || verb == "nist-atomic" || verb == "wikipedia" || verb == "openalex" || verb == "gaia"
           || verb == "lhc" || verb == "pubchem" || verb == "uniprot" {
        println("hexa " + verb + " <query|id>")
        println("  EXTERNAL data bridge — fetch from " + verb + " and verify the result against the source.")
    // ANNOTATOR family (tool/hexa_annot/hexa-<name>) — source-analysis tools.
    } else if is_absorbed_verb(verb) {
        println("hexa " + verb + " <file.hexa>")
        println("  ANNOTATOR — source-analysis tool (see `hexa tool list`).")
    } else {
        // Not an absorbed verb — fall back to the per-verb / full catalog.
        cmd_verb_help(verb)
    }
}

// CANON M4: go-tool-style verb index. The bare `hexa <verb>` dispatch still
// works for every entry; this drawer groups the 80+ specialized verbs so the
// core `hexa --help` can stay focused on the everyday toolchain.
fn cmd_tool_list() {
    println("HEXA TOOL — specialized verbs · `hexa tool <verb> [args]` (or bare `hexa <verb> [args]`)")
    println("")
    println("TOOLCHAIN   batch typecheck cache daemon convergence tape hxc url stdlib")
    println("            (batch/typecheck: extra build verbs · cache/daemon: build infra")
    println("             · convergence/tape/hxc: format readers · url: hexa:// dispatch")
    println("             · stdlib: module catalog)")
    println("DISCOVERY   drill kick chain omega surge dream swarm reign molt wake forge canon")
    println("            debate revive smash free hyperarithmetic loop")
    println("EXTERNAL    codata oeis arxiv gw horizons cmb nanograv simbad icecube nist-atomic")
    println("            wikipedia openalex gaia lhc pubchem uniprot akida")
    println("ANNOTATOR   pure-check memo-check catalog readme doc codegen-hints distill effect-map")
    println("            intent-map meta-map phi-map struct-layout self-aware cognitive freedom")
    println("            infer learn safety antivirus serve tenant eval-run n6-list test-list")
    println("            schema law-link harness rule gate-register")
    println("SCIENCE     atlas calc verify atlas-verify atlas-audit lattice repo-audit-taxonomy")
    println("            honesty absolute meta-closure qrng qmirror sim-universe gpu cloud")
    println("")
    println("  per-verb detail: `hexa <verb> --help`  ·  full catalog: `hexa --help`")
}

fn cmd_tool(av) {
    // main dispatch indexes the verb at av[2] (two-slot prefix). So for
    // `hexa tool <verb> [args]`: av[2]=tool · av[3]=verb · av[4..]=args.
    let x = if len(av) >= 4 { av[3] } else { "list" }
    if x == "list" || x == "--help" || x == "-h" {
        cmd_tool_list()
        return
    }
    // Re-dispatch to the bare verb (self re-invoke). Bare `hexa <x>` is the
    // canonical path; `hexa tool <x>` is the discoverable alias.
    let mut rest = ""
    let mut i = 4
    while i < len(av) {
        rest = rest + " " + shq(av[i])
        i = i + 1
    }
    let cmd = shq(argv0_or_hexa()) + " " + shq(x) + rest
    let r = exec_with_status(cmd)
    print(r[0])
    exit(r[1])
}

// ─── hexa:// URL dispatcher ────────────────────────────────────────────
// Called from `hexa url <URL>` — typically invoked by macOS HexaURL.app's
// AppleScript handler after a user clicks a hexa:// link. Keeps parse
// minimal: no url-decode yet, no query string key aliasing.

fn hexa_url_after_scheme(url) {
    // Strip leading "hexa://" if present. Anything else returns "".
    if len(url) < 7 { return "" }
    let head = url.substring(0, 7)
    if head != "hexa://" { return "" }
    return url.substring(7, len(url))
}

fn hexa_url_split_query(rest) {
    // Returns [action, query] where query may be "".
    let n = len(rest)
    let mut i = 0
    while i < n {
        if rest.substring(i, i + 1) == "?" {
            return [rest.substring(0, i), rest.substring(i + 1, n)]
        }
        i = i + 1
    }
    return [rest, ""]
}

fn hexa_url_query_get(query, key) {
    // Scan `k=v&k=v` for first matching key. No url-decode.
    if len(query) == 0 { return "" }
    let pairs = query.split("&")
    let mut pi = 0
    while pi < len(pairs) {
        let p = pairs[pi]
        let n = len(p)
        let mut j = 0
        while j < n {
            if p.substring(j, j + 1) == "=" {
                if p.substring(0, j) == key { return p.substring(j + 1, n) }
                j = n
            } else {
                j = j + 1
            }
        }
        pi = pi + 1
    }
    return ""
}

// Bug fix (2026-05-01): cmd_url dropped `args=` query — only `file=` was
// extracted, hence `cmd_run(file, [])` always invoked with empty argv.
// hexa_url_query_get_all returns ALL values for repeated key (e.g.
// `&args=hello&args=world` → ["hello", "world"]). Decoded by the caller.
fn hexa_url_query_get_all(query, key) {
    let mut out = []
    if len(query) == 0 { return out }
    let pairs = query.split("&")
    let mut pi = 0
    while pi < len(pairs) {
        let p = pairs[pi]
        let n = len(p)
        let mut j = 0
        while j < n {
            if p.substring(j, j + 1) == "=" {
                if p.substring(0, j) == key {
                    out.push(p.substring(j + 1, n))
                }
                j = n
            } else {
                j = j + 1
            }
        }
        pi = pi + 1
    }
    return out
}

// Minimal URL percent-decode + `+` → space (application/x-www-form-urlencoded).
// Invalid `%xx` sequences pass through literally (lax — same posture as the
// rest of cmd_url; security boundary lives at forced-command pin, not here).
fn hexa_url_hex_nibble(c) {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    if c == "a" || c == "A" { return 10 }
    if c == "b" || c == "B" { return 11 }
    if c == "c" || c == "C" { return 12 }
    if c == "d" || c == "D" { return 13 }
    if c == "e" || c == "E" { return 14 }
    if c == "f" || c == "F" { return 15 }
    return -1
}

fn hexa_url_decode(s) {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "+" {
            out = out + " "
            i = i + 1
        } else if c == "%" && i + 2 < n {
            // Need 2 more chars for %XX. substring(i+2, i+3) requires i+3 <= n.
            let h = hexa_url_hex_nibble(s.substring(i + 1, i + 2))
            let l = hexa_url_hex_nibble(s.substring(i + 2, i + 3))
            if h >= 0 && l >= 0 {
                let code = h * 16 + l
                out = out + chr(code)
                i = i + 3
            } else {
                out = out + c
                i = i + 1
            }
        } else {
            out = out + c
            i = i + 1
        }
    }
    return out
}

fn cmd_url(url) {
    let rest = hexa_url_after_scheme(url)
    if rest == "" {
        println("error: expected hexa:// URL, got: " + url)
        return
    }
    let parts = hexa_url_split_query(rest)
    let action = parts[0]
    let query = parts[1]
    if action == "run" {
        let file_raw = hexa_url_query_get(query, "file")
        if file_raw == "" {
            println("error: hexa://run requires ?file=<abs-path>")
            return
        }
        let file = hexa_url_decode(file_raw)
        // args= multi-value: `&args=foo&args=bar` → ["foo", "bar"].
        // Each value individually URL-decoded (supports %20, +, etc.).
        let args_raw = hexa_url_query_get_all(query, "args")
        let mut args_list = []
        let mut ai = 0
        while ai < len(args_raw) {
            args_list.push(hexa_url_decode(args_raw[ai]))
            ai = ai + 1
        }
        // `hexa://run` URL action — user-direct invocation: compile then exec.
        cmd_run_user_direct(file, args_list)
    } else if action == "install" {
        let pkg = hexa_url_query_get(query, "pkg")
        if pkg == "" {
            println("error: hexa://install requires ?pkg=<name>")
            return
        }
        let r = exec("hx install '" + pkg + "'")
        println(r)
    } else if action == "repl" {
        let dir = hexa_url_query_get(query, "dir")
        // macOS: open Terminal tab cd'd into dir then run hexa REPL (hexa).
        let target = if dir == "" { exec("pwd 2>/dev/null | tr -d '\\n'") } else { dir }
        let cmd = "osascript -e 'tell application \"Terminal\" to do script \"cd " + target + " && hexa\"'"
        let r = exec(cmd)
        println(r)
    } else {
        println("error: unknown hexa:// action '" + action + "' (valid: run, install, repl)")
    }
}

fn cmd_version() {
    println("hexa " + version_str())
}

fn cmd_status() {
    println("HEXA toolchain status")
    println("  version:     " + version_str())
    let hexa_bin = exec("ls -la hexa 2>&1 | head -1 | tr -d '\\n'")
    println("  ./hexa:      " + hexa_bin)
    let cc_bin = exec("ls -la build/hexat 2>&1 | head -1 | tr -d '\\n'")
    println("  hexa_cc:     " + cc_bin)
    let self_cnt = exec("ls self/*.hexa 2>/dev/null | wc -l | tr -d ' \\n'")
    println("  SSOT .hexa:  " + self_cnt + " files")
    let art_cnt = exec("ls build/artifacts 2>/dev/null | wc -l | tr -d ' \\n'")
    println("  artifacts:   " + art_cnt + " files")
}

// ─────────────────────────────────────────────────────────────────────
//  cmd_init — `hexa init <dir> [--name N]`
//
//  Minimal canonical project scaffolder (cf. `go mod init` / `cargo init`).
//  Creates <dir>/ if absent and writes 3 files:
//    - project.hexa  (minimal @I identity declaration)
//    - main.hexa     (hello-world entry)
//    - .gitignore    (build/, .hexa-cache/, *.o, etc.)
//
//  Refuses (rc=2) if <dir> already contains main.hexa or project.hexa to
//  avoid clobbering existing work. Use a fresh / empty directory.
//
//  Inlined here (NOT cmd_run dispatched to tool/init_project.hexa) — the
//  R7 track B preferred path is a standalone bin/hexa-init binary, but
//  this inline avoids the cmd_run interp dependency entirely (per
//  feedback_no_interp_use_compiled). The sister tool/init_project.hexa
//  is provided as a future-build target — it mirrors this logic 1:1.
//
//  INBOX 2026-05-25T23:10Z (c) RESOLVED — was "not implemented" stub.
// ─────────────────────────────────────────────────────────────────────
fn _init_basename(path: string) -> string {
    let n = len(path)
    if n == 0 { return "project" }
    // strip trailing slashes
    let mut end = n
    while end > 0 && path.substring(end - 1, end) == "/" {
        end = end - 1
    }
    if end == 0 { return "project" }
    let mut start = end
    while start > 0 && path.substring(start - 1, start) != "/" {
        start = start - 1
    }
    let bn = path.substring(start, end)
    if len(bn) == 0 { return "project" }
    return bn
}

fn _init_shell_quote(s: string) -> string {
    // wrap in single quotes; escape embedded single quotes via '\''
    let n = len(s)
    let parts = []
    parts.push("'")
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            parts.push("'\\''")
        } else {
            parts.push(c)
        }
        i = i + 1
    }
    parts.push("'")
    return parts.join("")
}

fn cmd_init(av_init: array) {
    // av_init is the post-`init` argv slice (e.g. ["<dir>", "--name", "myapp"]).
    if len(av_init) < 1 {
        println("error: `hexa init` requires <dir> argument")
        println("usage: hexa init <dir> [--name N]")
        exit(2)
    }
    let dir = av_init[0]
    let mut name = ""
    let mut k = 1
    while k < len(av_init) {
        let a = av_init[k]
        if a == "--name" && k + 1 < len(av_init) {
            name = av_init[k + 1]
            k = k + 2
        } else {
            println("error: unknown init arg: " + a)
            println("usage: hexa init <dir> [--name N]")
            exit(2)
        }
    }
    if len(name) == 0 {
        name = _init_basename(dir)
    }

    // refuse if would clobber existing project/main
    let dq = _init_shell_quote(dir)
    let pj_path = dir + "/project.hexa"
    let mn_path = dir + "/main.hexa"
    if file_exists(pj_path) || file_exists(mn_path) {
        println("error: refusing to clobber existing project — " + dir + " already has project.hexa or main.hexa")
        exit(2)
    }

    // mkdir -p
    let _mk = exec("mkdir -p " + dq + " 2>&1")

    // write project.hexa
    let pj_parts = []
    pj_parts.push("// ")
    pj_parts.push(name)
    pj_parts.push(" — hexa project (scaffolded by `hexa init`)\n\n")
    pj_parts.push("@I := \"")
    pj_parts.push(name)
    pj_parts.push("\" :: identity [active]\n")
    pj_parts.push("  kind  = \"native binary\"\n")
    pj_parts.push("  entry = \"main.hexa\"\n")
    write_file(pj_path, pj_parts.join(""))

    // write main.hexa
    let mn_parts = []
    mn_parts.push("// ")
    mn_parts.push(name)
    mn_parts.push(" — entry point\n\n")
    mn_parts.push("fn main() {\n")
    mn_parts.push("    println(\"hello from ")
    mn_parts.push(name)
    mn_parts.push("\")\n")
    mn_parts.push("}\n")
    write_file(mn_path, mn_parts.join(""))

    // write .gitignore
    let gi_parts = []
    gi_parts.push("# hexa scaffold defaults\n")
    gi_parts.push("build/\n")
    gi_parts.push(".hexa-cache/\n")
    gi_parts.push("*.o\n")
    gi_parts.push("*.dSYM/\n")
    gi_parts.push(".DS_Store\n")
    write_file(dir + "/.gitignore", gi_parts.join(""))

    println("scaffolded: " + dir + " (name=" + name + ")")
    println("  - " + pj_path)
    println("  - " + mn_path)
    println("  - " + dir + "/.gitignore")
    println("")
    println("next:")
    println("  hexa build " + dir + "/main.hexa -o " + dir + "/" + name)
    println("  " + dir + "/" + name)
}

// ═══════════════════════════════════════════════════════════════════
//  L2 absorption — native .tape v1.2 reader + generic HXC v2 decoder
//
//  Inlined (A′) so `hexa tape <f>` / `hexa hxc <f>` are C-compiled
//  builtins with no `use` (the transpiler emits extern-only for `use`,
//  which would force build_dispatch surgery). SSOT of the parsing logic
//  is vendored from the sibling repo ~/core/tape/algorithms (tape_grep/
//  tape_index) and (historically) compiler/atlas/hxc_loader.hexa —
//  the latter was retired 2026-05-22 (PRs #312 + #314,
//  @D h_atlas_single_export) when the atlas SSOT moved to
//  n6/atlas.n6; the inlined hxc-decode logic below remains as a
//  generic HXC v2 reader for non-atlas use (e.g. `hexa hxc <f>`).
//  Verified standalone via interp before this inline. Uses
//  main.hexa's own read_file / file_exists builtins (no stdlib/fs
//  dependency).
// ═══════════════════════════════════════════════════════════════════

// One parsed .tape header + its continuation-block summary.
pub struct TapeEntry {
    typ: string,        // single char after `@` (S U A T R H D K P ? I X F N C L V)
    eid: string,        // entry id token (may be "" for `@V := ...`)
    domain: string,     // token after ` :: ` (domain / kind)
    grade: string,      // raw bracket payload, e.g. "T2 N48 ok" or "required"
    nbody: i64,         // count of 2-space continuation lines
    nedges: i64,        // continuation lines that begin with an edge operator
    lineno: i64,        // 1-based header line number
    ok: bool            // header well-formed (tape_absorb step-1, lenient)
}

pub struct HxcTable {
    tag: string,        // schema tag (e.g. "atlas")
    cols: array,        // [string] ordered column names
    rows: array,        // [[string]] one cell-array per @<tag> row
    nrows: i64
}

// Closed 17-type alphabet (tape v1.2): runtime S U A T R H D K P ? ·
// foundation I · declarative X F N C L V. (fn, not a top-level `let`,
// to keep main.hexa's no-top-level-statement invariant.)
fn _tape_types() -> string {
    return "SUATRHDKP?IXFNCLV"
}

fn _tape_is_type(t: string) -> bool {
    if t.len() != 1 { return false }
    let tt = _tape_types()
    let mut i: i64 = 0
    while i < tt.len() {
        if tt.substring(i, i + 1) == t { return true }
        i = i + 1
    }
    return false
}

// A header is a column-0 line: `@` + a valid type char + a space (or EOL).
fn _tape_is_header(line: string) -> bool {
    if line.len() < 2 { return false }
    if line.substring(0, 1) != "@" { return false }
    let t = line.substring(1, 2)
    if !_tape_is_type(t) { return false }
    if line.len() == 2 { return true }
    return line.substring(2, 3) == " "
}

fn _tape_header_type(line: string) -> string {
    if line.len() < 2 { return "" }
    return line.substring(1, 2)
}

// First token after ` :: ` — the domain (runtime) or kind (declarative).
fn _tape_header_domain(line: string) -> string {
    let parts = line.split(" :: ")
    if len(parts) < 2 { return "" }
    let rest = parts[1]
    let toks = rest.split(" ")
    if len(toks) < 1 { return "" }
    return toks[0].trim()
}

// Entry id: the token after the type, before ` = ` / ` := ` / ` :: `.
// Returns "" when absent (e.g. `@V := "tape" :: spec`).
fn _tape_header_id(line: string) -> string {
    if line.len() < 4 { return "" }
    let after = line.substring(3, line.len())   // strip `@T `
    let toks = after.split(" ")
    if len(toks) < 1 { return "" }
    let first = toks[0].trim()
    if first == ":=" || first == "=" || first == "::" { return "" }
    return first
}

// Raw grade-bracket payload: between the LAST `[` and the next `]`.
fn _tape_grade_payload(line: string) -> string {
    let mut lb: i64 = -1
    let mut rb: i64 = -1
    let mut i: i64 = 0
    while i < line.len() {
        let c = line.substring(i, i + 1)
        if c == "[" { lb = i }
        if c == "]" {
            if lb >= 0 && rb < 0 { rb = i }
        }
        i = i + 1
    }
    if lb < 0 { return "" }
    if rb < lb { return "" }
    return line.substring(lb + 1, rb)
}

// Lenient tape_absorb step-1: valid type + ` :: ` + non-empty domain.
fn _tape_well_formed(line: string) -> bool {
    if !_tape_is_header(line) { return false }
    if !line.contains(" :: ") { return false }
    if _tape_header_domain(line).len() == 0 { return false }
    return true
}

// An edge continuation line: two leading spaces + a v1.2 edge operator.
fn _tape_is_edge_line(line: string) -> bool {
    if line.len() < 4 { return false }
    if line.substring(0, 2) != "  " { return false }
    let body = line.substring(2, line.len()).trim()
    if body.len() < 2 { return false }
    let op2 = body.substring(0, 2)
    if op2 == "<-" || op2 == "->" || op2 == "=>" || op2 == "==" { return true }
    if op2 == "~>" || op2 == "|>" || op2 == "!!" || op2 == "<:" { return true }
    if op2 == ":>" || op2 == "?>" || op2 == "!>" || op2 == "@>" { return true }
    return false
}

// Parse a full .tape text into [TapeEntry] via continuation look-ahead
// (each struct built once — no arr[i].field lvalue, which the codebase
// has no precedent for).
fn tape_parse(text: string) -> array {
    let lines = text.split("\n")
    let mut out = []
    let n = len(lines)
    let mut i: i64 = 0
    while i < n {
        let ln = lines[i]
        let lno = i + 1
        if ln.len() == 0 {
            i = i + 1
            continue
        }
        if ln.substring(0, 1) == "#" {       // comment / shebang / divider
            i = i + 1
            continue
        }
        if _tape_is_header(ln) {
            let mut nbody: i64 = 0
            let mut nedges: i64 = 0
            let mut j: i64 = i + 1
            while j < n {
                let cl = lines[j]
                if cl.len() == 0 { break }            // blank → block end
                if _tape_is_header(cl) { break }      // next header → block end
                if cl.len() >= 2 && cl.substring(0, 2) == "  " {
                    nbody = nbody + 1
                    if _tape_is_edge_line(cl) { nedges = nedges + 1 }
                    j = j + 1
                } else {
                    break                              // non-indented → block end
                }
            }
            out.push(TapeEntry {
                typ: _tape_header_type(ln),
                eid: _tape_header_id(ln),
                domain: _tape_header_domain(ln),
                grade: _tape_grade_payload(ln),
                nbody: nbody,
                nedges: nedges,
                lineno: lno,
                ok: _tape_well_formed(ln)
            })
            i = j
            continue
        }
        i = i + 1
    }
    return out
}

// `hexa tape <file>` — read, parse, print a structured reader dump.
// rc: 0 = all headers well-formed · 1 = malformed present · 2 = io err.
fn tape_dump(path: string) -> i64 {
    if !file_exists(path) {
        eprintln("tape: file not found: " + path)
        return 2
    }
    let text = read_file(path)
    let entries = tape_parse(text)
    let n = len(entries)
    if n == 0 {
        println("tape: " + path + " — 0 entries")
        return 0
    }
    let mut malformed: i64 = 0
    let mut tot_edges: i64 = 0
    let mut i: i64 = 0
    while i < n {
        let e = entries[i]
        if !e.ok { malformed = malformed + 1 }
        tot_edges = tot_edges + e.nedges
        let flag = if e.ok { "  " } else { "!!" }
        let gr = if e.grade.len() > 0 { " [" + e.grade + "]" } else { "" }
        let ids = if e.eid.len() > 0 { " " + e.eid } else { "" }
        println(flag + " L" + to_string(e.lineno)
            + "  @" + e.typ + ids
            + " :: " + e.domain + gr
            + "  (body=" + to_string(e.nbody)
            + " edges=" + to_string(e.nedges) + ")")
        i = i + 1
    }
    let tt = _tape_types()
    let mut hist = ""
    let mut ti: i64 = 0
    while ti < tt.len() {
        let t = tt.substring(ti, ti + 1)
        let mut c: i64 = 0
        let mut j: i64 = 0
        while j < n {
            if entries[j].typ == t { c = c + 1 }
            j = j + 1
        }
        if c > 0 {
            if hist.len() > 0 { hist = hist + " " }
            hist = hist + "@" + t + "=" + to_string(c)
        }
        ti = ti + 1
    }
    println("──")
    println("tape: " + path + " — " + to_string(n) + " entries, "
        + to_string(tot_edges) + " edges, "
        + to_string(malformed) + " malformed")
    println("types: " + hist)
    if malformed > 0 { return 1 }
    return 0
}

// ── HXC v2 generic decode (generalized from the retired compiler/atlas/hxc_loader; ─
// atlas now uses n6/atlas.n6 via compiler/atlas/merger per @D h_atlas_single_export, 2026-05-22) ─

// Count trailing backslashes; true if odd (escaped-pipe false split).
fn _hxc_ends_odd_bs(s: string) -> bool {
    let n = len(s)
    let mut k = 0
    let mut j = n - 1
    while j >= 0 {
        if s.substring(j, j + 1) == "\\" {
            k = k + 1
            j = j - 1
        } else {
            break
        }
    }
    return (k - (k / 2) * 2) == 1
}

// Split a pipe row WITHOUT splitting on `\|`: over-split on the O(N)
// builtin, then re-merge cells whose left part ended in odd backslashes.
fn _hxc_split_pipes(s: string) -> array {
    let parts = s.split("|")
    let mut out = []
    let mut i = 0
    while i < len(parts) {
        let mut cur = parts[i]
        while _hxc_ends_odd_bs(cur) && i + 1 < len(parts) {
            cur = cur + "|" + parts[i + 1]
            i = i + 1
        }
        out.push(cur)
        i = i + 1
    }
    return out
}

// Reverse the encoder escape (`\|`→`|`, `\\`→`\`) via a single
// sentinel-free left-to-right scan. Only `\`-bearing cells reach here.
fn _hxc_unesc_pipe(s: string) -> string {
    if !s.contains("\\") { return s }
    let mut out = ""
    let n = s.len()
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" && i + 1 < n {
            let nx = s.substring(i + 1, i + 2)
            if nx == "|" {
                out = out + "|"
                i = i + 2
            } else if nx == "\\" {
                out = out + "\\"
                i = i + 2
            } else {
                out = out + c
                i = i + 1
            }
        } else {
            out = out + c
            i = i + 1
        }
    }
    return out
}

// Decode HXC v2 text into a schema-agnostic table. Const columns are
// appended after active schema columns and materialized into every row
// (full logical table, the way the retired atlas hxc_loader rebuilt
// dense rows — but with no hard-coded column set; the atlas path itself
// is now n6/atlas.n6 via compiler/atlas/merger per
// @D h_atlas_single_export, 2026-05-22).
fn hxc_decode(text: string) -> HxcTable {
    let lines = text.split("\n")
    let mut tag = ""
    let mut active_cols = []
    let mut const_names = []
    let mut const_vals = []
    let mut rows = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        i = i + 1
        if len(line) == 0 { continue }
        if line.starts_with("# const:") {
            let body = line.substring(8, len(line))
            let eq = body.index_of("=")
            if eq < 0 { continue }
            let cname = body.substring(0, eq)
            let cval = body.substring(eq + 1, len(body))
            const_names.push(cname)
            const_vals.push(cval)
            continue
        }
        if line.starts_with("# schema:") {
            let rest = line.substring(9, len(line)).trim()
            if rest == "" { continue }
            let toks = rest.split(" ")
            if len(toks) >= 1 { tag = toks[0] }
            let mut j = 1
            while j < len(toks) {
                let t = toks[j].trim()
                if t.len() > 0 { active_cols.push(t) }
                j = j + 1
            }
            continue
        }
        if line.starts_with("#") { continue }
        if line.substring(0, 1) == "@" {
            let sp = line.index_of(" ")
            if sp < 0 { continue }
            let row_tag = line.substring(1, sp)
            if tag != "" && row_tag != tag { continue }
            let payload = line.substring(sp + 1, len(line))
            let raw_cells = _hxc_split_pipes(payload)
            let mut row = []
            let mut k = 0
            while k < len(raw_cells) {
                row.push(_hxc_unesc_pipe(raw_cells[k]))
                k = k + 1
            }
            let mut cv = 0
            while cv < len(const_vals) {
                row.push(_hxc_unesc_pipe(const_vals[cv]))
                cv = cv + 1
            }
            rows.push(row)
            continue
        }
    }
    let mut cols = []
    let mut a = 0
    while a < len(active_cols) { cols.push(active_cols[a]); a = a + 1 }
    let mut b = 0
    while b < len(const_names) { cols.push(const_names[b]); b = b + 1 }
    return HxcTable {
        tag: tag,
        cols: cols,
        rows: rows,
        nrows: len(rows)
    }
}

// `hexa hxc <file>` — decode + print schema and self-describing rows.
fn hxc_dump(path: string) -> i64 {
    if !file_exists(path) {
        eprintln("hxc: file not found: " + path)
        return 2
    }
    let text = read_file(path)
    if text == "" {
        println("hxc: " + path + " — empty")
        return 0
    }
    let tbl = hxc_decode(text)
    println("hxc: " + path + "  tag=" + tbl.tag
        + "  cols=" + to_string(len(tbl.cols))
        + "  rows=" + to_string(tbl.nrows))
    let mut sch = ""
    let mut i = 0
    while i < len(tbl.cols) {
        if sch.len() > 0 { sch = sch + " " }
        sch = sch + tbl.cols[i]
        i = i + 1
    }
    println("schema: " + sch)
    println("──")
    let mut r = 0
    while r < len(tbl.rows) {
        let row = tbl.rows[r]
        let mut out = "r" + to_string(r) + "  "
        let mut c = 0
        while c < len(row) {
            let cname = if c < len(tbl.cols) { tbl.cols[c] } else { "col" + to_string(c) }
            if c > 0 { out = out + " | " }
            out = out + cname + "=" + row[c]
            c = c + 1
        }
        println(out)
        r = r + 1
    }
    return 0
}

// ── OS-specific clang flags (Mac vs Linux/glibc) ────────────
// glibc 는 POSIX/GNU 확장(strdup/popen/pclose) 을 기본 숨김 → `-D_GNU_SOURCE`.
// 수학 심볼(sqrt/pow/fmod) 은 자동 링크 안 됨 → `-lm`.
// macOS libSystem 은 두 플래그 모두 무의미하므로 Darwin 에서는 빈 문자열.
fn os_clang_cflags() {
    let mut base = ""
    if exec("uname 2>/dev/null | tr -d ' \\n\\t'") == "Linux" { base = "-D_GNU_SOURCE " }
    // 2026-05-14: libsodium optional bind for stdlib/crypto + SSH client.
    // Probe via pkg-config; on Mac without pkg-config, fall back to the
    // Homebrew default install path. If nothing is found, leave the
    // symbol undefined so native/crypto_sodium.c's stubs return errors.
    let probe = exec("pkg-config --cflags libsodium 2>/dev/null")
    if probe != "" { base = base + "-DHEXA_HAS_LIBSODIUM " + probe.trim() + " " }
    else {
        let brew_h = exec("test -f /opt/homebrew/include/sodium.h && printf '/opt/homebrew/include' || printf ''")
        if brew_h != "" { base = base + "-DHEXA_HAS_LIBSODIUM -I" + brew_h + " " }
    }
    // 2026-05-14: OpenSSL optional bind for AES-256-CTR (passphrase-
    // encrypted OpenSSH private keys). libsodium doesn't ship AES-256.
    let ossl_probe = exec("pkg-config --cflags openssl 2>/dev/null")
    if ossl_probe != "" { base = base + "-DHEXA_HAS_OPENSSL " + ossl_probe.trim() + " " }
    else {
        let brew_o = exec("test -f /opt/homebrew/include/openssl/evp.h && printf '/opt/homebrew/opt/openssl@3/include' || printf ''")
        if brew_o != "" { base = base + "-DHEXA_HAS_OPENSSL -I" + brew_o + " " }
    }
    return base
}
fn os_clang_ldflags() {
    let mut base = " -lpthread"
    if exec("uname 2>/dev/null | tr -d ' \\n\\t'") == "Linux" { base = " -lm -lpthread" }
    // 2026-05-14: libsodium link flags (when found via pkg-config or brew).
    let probe = exec("pkg-config --libs libsodium 2>/dev/null")
    if probe != "" { base = base + " " + probe.trim() }
    else {
        let brew_l = exec("test -f /opt/homebrew/lib/libsodium.dylib && printf '/opt/homebrew/lib' || printf ''")
        if brew_l != "" { base = base + " -L" + brew_l + " -lsodium" }
    }
    let ossl_probe = exec("pkg-config --libs openssl 2>/dev/null")
    if ossl_probe != "" { base = base + " " + ossl_probe.trim() }
    else {
        let brew_o = exec("test -d /opt/homebrew/opt/openssl@3/lib && printf '/opt/homebrew/opt/openssl@3/lib' || printf ''")
        if brew_o != "" { base = base + " -L" + brew_o + " -lcrypto" }
    }
    return base
}

// ── B20 / roadmap 55 Phase 1 — strict-FP clang flags ─────────
// codegen emits `/* HEXA_STRICT_FP_TU: 1 */` at the top of generated
// C when the translation unit contains any @strict_fp fn. Detect the
// marker in the emitted .c and append IEEE-strict flags so clang does
// not re-enable the relaxations the codegen-side gate just removed.
// Flag set: disable FMA contraction, fast-math family, sub-normal
// flush, and associative/reciprocal rewrites; enable signaling NaNs.
// Returns trailing-space-padded string (mirrors os_clang_cflags shape)
// or "" when the TU has no @strict_fp fn.
//
// Phase 2 follow-ups (NOT in this PR):
//   - -frounding-math + -ftrapping-math once the runtime is audited.
//   - crlibm link gate when any @strict_fp fn calls libm transcendentals.
//   - Thread-entry hexa_fp_init() propagation via pthread_create wrapper.
fn strict_fp_cflags(c_file) {
    let probe = exec("grep -q 'HEXA_STRICT_FP_TU: 1' '" + c_file + "' 2>/dev/null && printf yes || printf no")
    if probe != "yes" { return "" }
    return "-ffp-contract=off -fno-fast-math -fno-associative-math -fno-reciprocal-math -fsignaling-nans "
}

// #12 leftover (3) — wilson-needs-hexa-build-out-of-tree: `hexa cc` /
// `hexa cc --regen` resolved `self/native/hexa_cc.c`, the SSOT modules and
// the `-I` paths *relative to cwd*, so invoking from outside the repo failed
// (`fatal error: 'runtime.c' file not found`, or `hexa_cc.c` missing). Mirror
// cmd_build's `__self_dir` resolver: $HEXA_LANG > install_dir_from_argv0() >
// ./self. Behavior is identical when run from the repo root.
fn resolve_hxroot() {
    let __hxroot = env("HEXA_LANG")
    if len(__hxroot) > 0 && file_exists(__hxroot + "/self/native/hexa_cc.c") {
        return __hxroot
    }
    let __i = install_dir_from_argv0()
    if len(__i) > 0 && file_exists(__i + "/self/native/hexa_cc.c") {
        return __i
    }
    if file_exists("./self/native/hexa_cc.c") { return "." }
    // Last resort: keep cwd-relative behavior (will fail loudly downstream).
    return "."
}

fn cmd_cc() {
    println("=== Rebuilding hexa_cc (transpiler) ===")
    let __hxroot = resolve_hxroot()
    // CANON M3: the transpiler is a build artifact under build/, not a
    // committed binary. Ensure the output dir exists.
    let _ = exec("mkdir -p '" + __hxroot + "/build'")
    // OS 분기: Linux 에서는 glibc 의 POSIX/GNU 확장(strdup, getline 등)을
    //          사용하기 위해 `-D_GNU_SOURCE` 가 필요하고, 수학 심볼 참조
    //          (fmod/sqrt 등) 는 `-lm` 로 링크해야 한다. macOS 는 두 플래그
    //          모두 no-op (libSystem 이 기본 포함) 이므로 동일 적용해도
    //          무해하다. `-I self` 는 #include "runtime.c" (self/runtime.c)
    //          경로 해석에 필수 — 구 `-I.` 는 프로젝트 루트만 가리켜 Mac
    //          에서도 runtime.c 를 찾지 못했다. 본 수정으로 Mac/Linux 양쪽
    //          에서 안정화. null-char warning 2건은 non-fatal — 무시.
    let uname = exec("uname 2>/dev/null | tr -d ' \\n\\t'")
    // PHASE 1.6 (2026-05-15): build runtime.o ahead of hexa_cc.c so the
    // generated transpiler links against the precompiled runtime instead of
    // re-codegenning runtime.c inline. Saves ~8 s user-time per regen on this
    // ~33 K LOC TU (measured 26.47 s → 18.30 s with -O2). The .o is cached
    // adjacent to runtime.c; rebuild only when runtime.c is newer.
    let rt_c = __hxroot + "/self/runtime.c"
    let rt_o = __hxroot + "/self/runtime.o"
    let rt_stamp = exec("[ '" + rt_o + "' -nt '" + rt_c + "' ] && printf cached || printf stale")
    if rt_stamp == "stale" {
        let mut rt_cmd = ""
        if uname == "Linux" {
            rt_cmd = "clang -O2 -D_GNU_SOURCE -c '" + rt_c + "' -o '" + rt_o + "' 2>&1"
        } else {
            rt_cmd = "clang -O2 -c '" + rt_c + "' -o '" + rt_o + "' 2>&1"
        }
        println("  [rt] " + rt_cmd)
        let rt_out = exec(rt_cmd)
        if len(rt_out) > 0 { println(rt_out) }
    }
    let mut cmd = ""
    if uname == "Linux" {
        cmd = "clang -O2 -D_GNU_SOURCE -I '" + __hxroot + "' -I '" + __hxroot + "/self' '" + __hxroot + "/self/native/hexa_cc.c' '" + rt_o + "' -o '" + __hxroot + "/build/hexat' -lm 2>&1"
    } else {
        // macOS (Darwin) — libSystem 이 libm 자동 포함, _GNU_SOURCE 무의미.
        // 단, `-I self` 는 runtime.h 경로 해석에 반드시 필요.
        cmd = "clang -O2 -I '" + __hxroot + "' -I '" + __hxroot + "/self' '" + __hxroot + "/self/native/hexa_cc.c' '" + rt_o + "' -o '" + __hxroot + "/build/hexat' 2>&1"
    }
    println("  " + cmd)
    let r = exec(cmd)
    if len(r) > 0 {
        println(r)
    }
    println("OK: hexa_cc rebuilt")
}

// ── shell helper ─────────────────────────────────────────────────────
// POSIX single-quote wrap: wrap in '...', rewrite each embedded ' as
// '\'' (close-quote · escaped-quote · re-open-quote). Inbox patch
// hexa-run-shq-single-quote-drops-argv: prior body rejected `'` with
// `return ""` which silently dropped the arg from the joined command
// string — sidecar `/ship -m "doesn't"` hit it in production.
fn shq(s) {
    return "'" + s.replace("'", "'\\''") + "'"
}

// ─── nexus absorption verb dispatch (2026-05-13 final consolidation) ──
//
// is_absorbed_verb / dispatch_absorbed: a 60+ entry dispatch surface for
// the nexus → hexa-lang absorption project. The actual verb→script map
// lives in _absorbed_script(): given a verb id, return the script path
// (relative to the install dir). dispatch_absorbed() resolves to an
// absolute path via install_dir_from_argv0() with cwd fallback, then
// either cmd_run (for .hexa modules) or exec (for tool/hexa_annot/ bash
// scripts).
//
// Surface inventory (matches docs/notes 60+ verbs):
//   29 annotation analyzers   (tool/hexa_annot/hexa-<name>, bash)
//   3  Phase 2 verifiers      (honesty/absolute/meta-closure)
//   3  Phase 2 generators     (smash/free/hyperarithmetic)
//   13 Phase 3 drill chain    (drill/chain/omega/surge/dream/swarm/
//                              reign/molt/wake/forge/canon/debate/revive)
//   19 Phase 4 external       (qmirror/akida/qrng/kick + 16 bridges)

fn _absorbed_script(verb) {
    // Returns the relative script path for the verb, or "" if the verb is
    // not in the absorption surface. Caller must absolutise.

    // 29 annotation analyzers — bash scripts under tool/hexa_annot/.
    // Use a "ANNOT:" prefix in the return so the dispatcher knows to exec
    // (not cmd_run). Bash scripts read positional args, no .hexa runtime.
    if verb == "pure-check"       { return "ANNOT:tool/hexa_annot/hexa-pure-check" }
    if verb == "memo-check"       { return "ANNOT:tool/hexa_annot/hexa-memo-check" }
    if verb == "catalog"          { return "ANNOT:tool/hexa_annot/hexa-catalog" }
    if verb == "readme"           { return "ANNOT:tool/hexa_annot/hexa-readme" }
    if verb == "doc"              { return "ANNOT:tool/hexa_annot/hexa-doc" }
    if verb == "codegen-hints"    { return "ANNOT:tool/hexa_annot/hexa-codegen-hints" }
    if verb == "distill"          { return "ANNOT:tool/hexa_annot/hexa-distill" }
    if verb == "effect-map"       { return "ANNOT:tool/hexa_annot/hexa-effect-map" }
    if verb == "intent-map"       { return "ANNOT:tool/hexa_annot/hexa-intent-map" }
    if verb == "meta-map"         { return "ANNOT:tool/hexa_annot/hexa-meta-map" }
    if verb == "phi-map"          { return "ANNOT:tool/hexa_annot/hexa-phi-map" }
    if verb == "struct-layout"    { return "ANNOT:tool/hexa_annot/hexa-struct-layout" }
    if verb == "self-aware"       { return "ANNOT:tool/hexa_annot/hexa-self-aware" }
    if verb == "cognitive"        { return "ANNOT:tool/hexa_annot/hexa-cognitive" }
    if verb == "freedom"          { return "ANNOT:tool/hexa_annot/hexa-freedom" }
    if verb == "infer"            { return "ANNOT:tool/hexa_annot/hexa-infer" }
    if verb == "learn"            { return "ANNOT:tool/hexa_annot/hexa-learn" }
    if verb == "safety"           { return "ANNOT:tool/hexa_annot/hexa-safety" }
    if verb == "antivirus"        { return "ANNOT:tool/hexa_annot/hexa-antivirus" }
    if verb == "serve"            { return "ANNOT:tool/hexa_annot/hexa-serve" }
    if verb == "tenant"           { return "ANNOT:tool/hexa_annot/hexa-tenant" }
    if verb == "eval-run"         { return "ANNOT:tool/hexa_annot/hexa-eval-run" }
    if verb == "n6-list"          { return "ANNOT:tool/hexa_annot/hexa-n6-list" }
    if verb == "test-list"        { return "ANNOT:tool/hexa_annot/hexa-test-list" }
    if verb == "schema"           { return "ANNOT:tool/hexa_annot/hexa-schema" }
    if verb == "law-link"         { return "ANNOT:tool/hexa_annot/hexa-law-link" }
    if verb == "harness"          { return "ANNOT:tool/hexa_annot/hexa-harness" }
    if verb == "rule"             { return "ANNOT:tool/hexa_annot/hexa-rule" }
    if verb == "gate-register"    { return "ANNOT:tool/hexa_annot/hexa-gate-register" }

    // Phase 2 verifiers (3). `hexa check` for @invariant DSL is preserved
    // (handled in the main dispatch chain elsewhere); `hexa honesty` is
    // the new BT-AI2 audit surface.
    if verb == "honesty"          { return "compiler/honesty/check.hexa" }
    if verb == "absolute"         { return "compiler/absolute/check.hexa" }
    if verb == "meta-closure"     { return "compiler/meta_closure/check.hexa" }

    // Phase 2 generators (3). smash + free supersede the nexus-cli proxy.
    if verb == "smash"            { return "compiler/smash/smash.hexa" }
    if verb == "free"             { return "compiler/free/free.hexa" }
    if verb == "hyperarithmetic"  { return "compiler/hyperarithmetic/hyperarithmetic.hexa" }

    // Phase 3 drill chain (13).
    if verb == "drill"            { return "compiler/drill/drill.hexa" }
    if verb == "chain"            { return "compiler/chain/chain.hexa" }
    if verb == "omega"            { return "compiler/omega/omega.hexa" }
    if verb == "surge"            { return "compiler/surge/surge.hexa" }
    if verb == "dream"            { return "compiler/dream/dream.hexa" }
    if verb == "swarm"            { return "compiler/swarm/swarm.hexa" }
    if verb == "reign"            { return "compiler/reign/reign.hexa" }
    if verb == "molt"             { return "compiler/molt/molt.hexa" }
    if verb == "wake"             { return "compiler/wake/wake.hexa" }
    if verb == "forge"            { return "compiler/forge/forge.hexa" }
    if verb == "canon"            { return "compiler/canon_engine/canon_engine.hexa" }
    if verb == "debate"           { return "compiler/debate/debate.hexa" }
    if verb == "revive"           { return "compiler/revive/revive.hexa" }

    // Phase 4 external (17) — HW probes + kick + 16 bridges.
    // RFC 044 (qrng → stdlib/qrng/) + RFC 045 (qmirror → stdlib/quantum/) absorbed
    // the prior HW-probe stubs into stdlib; the dispatch lives in main() above as
    // explicit `else if sub == "qrng"/"qmirror"` branches (the stdlib path). The
    // legacy hw_probes/qrng + hw_probes/qmirror registry entries were RETIRED
    // 2026-05-20 per archive/patches/absorbed-verb-qrng-qmirror-superseded-by-stdlib.md
    // — they silently shadow-claimed the verb names on partial-merge branches and
    // routed `hexa qmirror` to a misleading 8/8 deterministic-stub.
    if verb == "akida"            { return "compiler/hw_probes/akida.hexa" }
    if verb == "kick"             { return "compiler/drill/drill.hexa" }   // alias: kick → drill (ω-cycle ≡ drill apex)
    if verb == "codata"           { return "compiler/bridges/codata.hexa" }
    if verb == "oeis"             { return "compiler/bridges/oeis.hexa" }
    if verb == "arxiv"            { return "compiler/bridges/arxiv.hexa" }
    if verb == "gw"               { return "compiler/bridges/gw.hexa" }
    if verb == "horizons"         { return "compiler/bridges/horizons.hexa" }
    if verb == "cmb"              { return "compiler/bridges/cmb.hexa" }
    if verb == "nanograv"         { return "compiler/bridges/nanograv.hexa" }
    if verb == "simbad"           { return "compiler/bridges/simbad.hexa" }
    if verb == "icecube"          { return "compiler/bridges/icecube.hexa" }
    if verb == "nist-atomic"      { return "compiler/bridges/nist_atomic.hexa" }
    if verb == "wikipedia"        { return "compiler/bridges/wikipedia.hexa" }
    if verb == "openalex"         { return "compiler/bridges/openalex.hexa" }
    if verb == "gaia"             { return "compiler/bridges/gaia.hexa" }
    if verb == "lhc"              { return "compiler/bridges/lhc.hexa" }
    if verb == "pubchem"          { return "compiler/bridges/pubchem.hexa" }
    if verb == "uniprot"          { return "compiler/bridges/uniprot.hexa" }

    // Phase 5 absorption (2026-05-14) — atlas + atlas-감사 verbs only (sister-project
    // 자체 도구는 분리됨: rsc → hexa-space, n6 → anima, bayes → hexa-bio, principle → anima,
    // etc. 분리 이력 see commit history 2026-05-14 split(scope)).
    // 2026-05-15 anima absorption scrubbed (see MAIN-TEMP.tape) — atlas-show verb removed
    if verb == "lattice"             { return "compiler/n6_lattice/main.hexa" }             // verify/axis-table/cross-check (n=6 math, hexa-bio-vocabulary-but-pure-math)
    if verb == "atlas-audit"         { return "compiler/atlas/audit_main.hexa" }            // external-entity/anchor/all (overlay corpus, hexa-matter doctrine gate)
    if verb == "atlas-verify"        { return "tool/atlas_verify.hexa" }                    // atlas verdict ledger — 86 entries Stage 1+2+3 hexa-native [--domain D] (wilson g_verify_hexa_cli_only)
    if verb == "repo-audit-taxonomy" { return "tool/repo_taxonomy_audit_main.hexa" }        // <catalog.md> <manifest.toml> [<root>] (hexa-chip-origin, generalized)

    return ""
}

fn is_absorbed_verb(verb) {
    return len(_absorbed_script(verb)) > 0
}

fn dispatch_absorbed(verb, ab_args) {
    let raw = _absorbed_script(verb)
    if len(raw) == 0 {
        println("error: unknown absorbed verb '" + verb + "'")
        return
    }

    // CANON M11: intercept `--help`/`-h` BEFORE resolving/running the script.
    // Many absorbed verbs (drill/kick/omega/swarm/…) trigger heavy discovery
    // work; a stray `--help` must NOT spin that up. Render the uniform per-verb
    // help block instead (mirrors M10's core-verb intercept pattern).
    if len(ab_args) >= 1 && (ab_args[0] == "--help" || ab_args[0] == "-h") {
        cmd_absorbed_help(verb)
        return
    }

    // Strip the "ANNOT:" prefix for bash-script dispatch (annotation tools).
    let is_annot = len(raw) >= 6 && raw.substring(0, 6) == "ANNOT:"
    let rel = if is_annot { raw.substring(6, len(raw)) } else { raw }

    // Resolve to absolute path with hexa's documented precedence
    // `$HEXA_LANG > install_dir > cwd` (same chain as stdlib `use` /
    // resolve_hxroot). Build low→high so the highest existing match wins:
    //   1. cwd-relative `rel` (lowest — in-repo dev runs from the root)
    //   2. install_dir_from_argv0() + rel (binary install carrying sources)
    //   3. $HEXA_LANG + rel (highest — explicit checkout override)
    // Prior code consulted only install_dir + cwd, so an exported HEXA_LANG
    // was ignored: `hexa kick` from a non-repo cwd on a host whose ~/.hx
    // install lacks the compiler/ sources failed even with HEXA_LANG set.
    let __inst = install_dir_from_argv0()
    let mut script = rel
    if len(__inst) > 0 && file_exists(__inst + "/" + rel) { script = __inst + "/" + rel }
    let __hl = env_var("HEXA_LANG")
    if len(__hl) > 0 && file_exists(__hl + "/" + rel) { script = __hl + "/" + rel }
    if !file_exists(script) {
        println("error: absorbed verb '" + verb + "' script not found: " + script)
        return
    }

    if is_annot {
        // Bash script — exec with quoted args via shq() shell wrapper.
        let cli_q = shq(script)
        if len(cli_q) == 0 { return }
        let mut cmd = cli_q
        let mut i = 0
        while i < len(ab_args) {
            let q = shq(ab_args[i])
            if len(q) == 0 { return }
            cmd = cmd + " " + q
            i = i + 1
        }
        cmd = cmd + " 2>&1"
        let r = exec(cmd)
        if len(r) > 0 { println(r) }
    } else {
        // .hexa module dispatch.
        //
        // R7 track B (2026-05-18, Phase 3/4 batch): prefer a standalone
        // compiled bin/hexa-absorbed-<verb> binary (built by
        // tool/build_absorbed_binaries.sh) over the legacy cmd_run interp
        // path. Same spawn-and-exit pattern as the named-verb cycles:
        // shq-quote args, exec with __HEXA_SHIM_RC__ marker, propagate
        // exit code. Falls back to cmd_run when the binary is absent
        // (transitional — modules that don't yet compile cleanly, e.g.
        // network-bridge deps or the atlas-memory cluster, keep working
        // via interp until their own follow-up).
        let mut abin = ""
        if len(__inst) > 0 {
            let inst_abin = __inst + "/bin/hexa-absorbed-" + verb
            if file_exists(inst_abin) { abin = inst_abin }
        }
        if len(abin) == 0 && file_exists("bin/hexa-absorbed-" + verb) {
            abin = "bin/hexa-absorbed-" + verb
        }
        if len(abin) > 0 {
            let cli_q = shq(abin)
            // R7 track B (2026-05-18): force HEXA_VAL_ARENA=0 for absorbed
            // sub-binaries. The discovery-engine family (drill/kick/omega/
            // chain/…) churns heavy struct/map sets through round_run; the
            // default-ON bump arena (S7-B) reclaims a block whose backing a
            // map HexaVal still references → hexa_map_get_ic_slow derefs a
            // stale HX_MAP_TBL ptr → SIGSEGV on certain seeds (verified:
            // lldb frame#0 hexa_map_get_ic_slow, EXC_BAD_ACCESS). Arena=0
            // (heap alloc, no reclaim aliasing) is byte-eq for working
            // seeds (seed A total=687 ON≡OFF) and makes segfaulting seeds
            // run deterministically (seed B total=683 ×2). These are
            // short-lived verb CLIs — the arena's only benefit (multi-GB
            // self-compile RSS) is irrelevant here; correctness wins. The
            // deep runtime root-fix (arena-escape heapify / IC ptr revalidation)
            // is fixpoint-critical (aprime_cc/hexat map-IC) → tracked
            // separately; this is the sound integration-layer fix.
            let mut cmd = "HEXA_VAL_ARENA=0 " + cli_q
            let mut ai = 0
            while ai < len(ab_args) {
                let q = shq(ab_args[ai])
                cmd = cmd + " " + q
                ai = ai + 1
            }
            let out = exec(cmd + " 2>&1; echo \"__HEXA_SHIM_RC__=$?\"")
            let marker = "__HEXA_SHIM_RC__="
            let mlen = len(marker)
            let mut midx = -1
            let mut sj = len(out) - mlen
            while sj >= 0 {
                if out.substring(sj, sj + mlen) == marker {
                    midx = sj
                    sj = -1
                } else {
                    sj = sj - 1
                }
            }
            if midx >= 0 {
                let body = out.substring(0, midx)
                let rc_str = out.substring(midx + mlen, len(out))
                print(body)
                let mut rs = rc_str
                let rsl = len(rs)
                if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" {
                    rs = rs.substring(0, rsl - 1)
                }
                let rc = parse_int_str(rs)
                if rc != 0 { exit(rc) }
            } else {
                print(out)
            }
        } else {
            cmd_run(script, ab_args)
        }
    }
}

fn regen_one_module(src, out_c) {
    // hexat SSOT → C 변환 한 모듈. 성공이면 "ok", 실패면 exec 출력.
    // buglist#5: resolve_hexat() 경유 — cwd 무관 install_dir 기반 탐색.
    let v2 = resolve_or_bootstrap_hexat()
    if len(v2) == 0 {
        println("  [transpile] error: hexat not found")
        return false
    }
    // Phase C.2 (2026-05-22): force HEXA_VAL_ARENA=0 for the regen transpile.
    // The bootstrap hexat binaries are built with the arena reclaim path
    // wired but never opted-in; new binaries (e.g. one freshly built from
    // self/native/hexa_cc.c) default arena=ON (S7-B) and SIGSEGV when
    // transpiling the larger SSOT modules (lexer, codegen). Pinning the
    // env OFF makes the transpile deterministic across binary vintages and
    // matches the hexat force-OFF default. Measured on ubu-2: without the
    // pin, /tmp/hexat.committed segfaults on lexer.hexa + codegen.hexa;
    // with it, all 4 modules transpile cleanly and the merge links + reaches
    // bootstrap fixpoint (gen-N codegen == gen-N+1 codegen byte-identical).
    let cmd = "HEXA_VAL_ARENA=0 " + v2 + " " + src + " " + out_c + " 2>&1"
    println("  [transpile] " + cmd)
    let r = exec(cmd)
    if len(r) > 0 { println("    " + r) }
    let chk = exec("test -f " + out_c + " && printf yes || printf no")
    return chk == "yes"
}

fn merge_modules_awk(out_path) {
    // POSIX awk 기반 merge — hexa 문자열 API 회피.
    // 입력: /tmp/_lexer.c /tmp/_parser.c /tmp/_tc.c /tmp/_cg.c (순서 고정)
    // 출력: out_path
    //   [1] 헤더 + 단일 #include "runtime.c"
    //   [2] 각 모듈 본문 (첫 `#include` 스킵, `int main()` 블록 전체 skip)
    //   [3] 커스텀 main(argc, argv) dispatcher
    let script_path = "/tmp/_hexa_cc_merge.awk"
    // awk: each module's top-level init code lives inside its own
    // `int main(int argc, char** argv)` block after hexat transpile.
    // We can't strip it (globals like `_known_fn_globals`, `p_max_errors`
    // etc. would remain uninitialized and the merged binary emits empty
    // identifiers). Instead rename it to `_MOD_init(int, char**)` and
    // have the merged dispatcher call each init before tokenize/parse.
    // `^}$` (column-0 `}`) terminates the block — the depth-tracking
    // variant was broken by braces in string literals.
    let awk_write_cmd = "cat > " + script_path + " <<'__AWK_EOF__'\nBEGIN { in_main=0 }\n/^#include/ { next }\n/^\\/\\/ Generated by/ { next }\n/^int main\\(/ { printf(\"int _%s_init(int argc, char** argv) {\\n\", MOD); in_main=1; next }\nin_main==1 && /^\\}$/ { print \"}\"; in_main=0; next }\nin_main==1 { print; next }\n{ print }\n__AWK_EOF__"
    let write = exec(awk_write_cmd)
    if len(write) > 0 { println("    awk-write: " + write) }
    // Dedup awk: 2-pass — drop redundant `HexaVal X(...);` forward decls
    // where X is defined later in the same file AND no call to X appears
    // between the fwd-decl line and the def line. Reduces ~141 LOC across
    // 4 modules (see analysis 2026-04-14). Run BEFORE the merge awk so
    // the merge filter operates on already-trimmed input.
    let dedup_path = "/tmp/_hexa_cc_dedup_fwd.awk"
    let dedup_write_cmd = "cat > " + dedup_path + " <<'__DEDUP_EOF__'\nNR == FNR {\n    lines[FNR] = $0\n    if (match($0, /^HexaVal [a-zA-Z_][a-zA-Z0-9_]*\\(.*\\) \\{$/)) {\n        split($0, a, \"(\")\n        name = a[1]; sub(/^HexaVal /, \"\", name)\n        def_line[name] = FNR\n    }\n    if (match($0, /^HexaVal [a-zA-Z_][a-zA-Z0-9_]*\\(.*\\);$/)) {\n        split($0, a, \"(\")\n        name = a[1]; sub(/^HexaVal /, \"\", name)\n        fwd_line[name] = FNR\n    }\n    next\n}\nFNR == 1 {\n    for (fn in fwd_line) {\n        if (fn in def_line) {\n            fl = fwd_line[fn]\n            dl = def_line[fn]\n            has_early_call = 0\n            pat = \"[^a-zA-Z0-9_]\" fn \"[ \\t]*\\\\(\"\n            pat2 = \"^\" fn \"[ \\t]*\\\\(\"\n            for (li = fl + 1; li < dl; li++) {\n                if (match(lines[li], pat)) { has_early_call = 1; break }\n                if (match(lines[li], pat2)) { has_early_call = 1; break }\n            }\n            if (!has_early_call) drop_fwd[fn] = 1\n        }\n    }\n}\n{\n    if (match($0, /^HexaVal [a-zA-Z_][a-zA-Z0-9_]*\\(.*\\);$/)) {\n        split($0, a, \"(\")\n        name = a[1]; sub(/^HexaVal /, \"\", name)\n        if (name in drop_fwd) next\n    }\n    print\n}\n__DEDUP_EOF__"
    let dedup_write = exec(dedup_write_cmd)
    if len(dedup_write) > 0 { println("    dedup-write: " + dedup_write) }
    // Rename awk: string-literal-aware `__hexa_{ic_,sl_,strlit_init}` prefix
    // pass. Supersedes the earlier sed pipeline — sed was global over
    // everything including the `hexa_str("...")` emit templates baked into
    // codegen, so it corrupted the prefix that future transpiles should
    // produce. The awk state-machine tracks double-quote nesting and skips
    // any substitution inside string literals. Without this fix the second
    // bootstrap round loses fixpoint (v2 transpile ≠ v1 transpile because
    // the binary now emits `__hexa_codegen_sl_N` for every module).
    let rename_path = "/tmp/_hexa_cc_rename.awk"
    let rename_write_cmd = "cat > " + rename_path + " <<'__REN_EOF__'\n{\n    line = $0\n    n = length(line)\n    out = \"\"\n    i = 1\n    in_str = 0\n    start = 1\n    while (i <= n) {\n        ch = substr(line, i, 1)\n        if (in_str) {\n            if (ch == \"\\\\\") { i += 2; continue }\n            if (ch == \"\\\"\") {\n                out = out substr(line, start, i - start + 1)\n                in_str = 0\n                start = i + 1\n                i++\n                continue\n            }\n            i++\n        } else {\n            if (ch == \"\\\"\") {\n                chunk = substr(line, start, i - start)\n                gsub(\"__hexa_ic_\", \"__hexa_\" MOD \"_ic_\", chunk)\n                gsub(\"__hexa_sl_\", \"__hexa_\" MOD \"_sl_\", chunk)\n                gsub(\"__hexa_strlit_init\", \"__hexa_\" MOD \"_strlit_init\", chunk)\n                out = out chunk\n                start = i\n                in_str = 1\n                i++\n                continue\n            }\n            i++\n        }\n    }\n    if (in_str) {\n        out = out substr(line, start)\n    } else {\n        chunk = substr(line, start)\n        gsub(\"__hexa_ic_\", \"__hexa_\" MOD \"_ic_\", chunk)\n        gsub(\"__hexa_sl_\", \"__hexa_\" MOD \"_sl_\", chunk)\n        gsub(\"__hexa_strlit_init\", \"__hexa_\" MOD \"_strlit_init\", chunk)\n        out = out chunk\n    }\n    print out\n}\n__REN_EOF__"
    let rename_write = exec(rename_write_cmd)
    if len(rename_write) > 0 { println("    rename-write: " + rename_write) }
    // Write header/footer via heredoc (quoted delimiter — no shell expansion).
    // Avoids shell_quote's double-quote wrapping which breaks on embedded `"`.
    // PHASE 1.6 (2026-05-15): emit `runtime.h` so the regenerated transpiler
    // links against the precompiled runtime.o (built ahead in the rebuild
    // step above) instead of re-codegenning runtime.c inline every cycle.
    let header_cmd = "cat > " + out_path + " <<'__HDR_EOF__'\n// HEXA self-hosted compiler — regenerated via `hexa cc --regen`\n#include \"runtime.h\"\n\n__HDR_EOF__"
    exec(header_cmd)
    // append each module (awk-filtered) with section marker
    let sections = ["lexer|/tmp/_lexer.c", "parser|/tmp/_parser.c", "type_checker|/tmp/_tc.c", "codegen|/tmp/_cg.c"]
    let mut i = 0
    while i < len(sections) {
        let entry = sections[i]
        let parts = entry.split("|")
        let name = parts[0]
        let path = parts[1]
        let marker_cmd = "{ printf '\\n// === %s ===\\n\\n' " + name + "; } >> " + out_path
        exec(marker_cmd)
        // Phase C.2: prefix per-module static symbols to avoid collision
        // when merging 4 SSOT modules into one file. Each module transpile
        // emits its own counter starting at 0 and its own __hexa_strlit_init
        // function; without renaming, clang rejects the concatenation with
        // "redefinition" errors. Three collision families observed across
        // lexer/parser/type_checker/codegen transpile outputs:
        //   __hexa_ic_N         — inline cache slots (per-call-site)
        //   __hexa_sl_N         — static string-literal interning slots
        //   __hexa_strlit_init  — the init fn that populates __hexa_sl_*
        // Filter chain: dedup (drop redundant fwd decls, 2-pass) → merge
        // awk (strip #include, rename main→_MOD_init) → per-module rename
        // awk (string-literal-aware — skips the codegen emit templates).
        let filter = "awk -f " + dedup_path + " " + path + " " + path + " | awk -v MOD=" + name + " -f " + script_path + " | awk -v MOD=" + name + " -f " + rename_path + " >> " + out_path
        let r = exec(filter + " 2>&1")
        if len(r) > 0 { println("    awk[" + name + "]: " + r) }
        i = i + 1
    }
    // custom main via heredoc (quoted delimiter)
    // Each module's top-level let/let-mut init code lives in _MOD_init()
    // (renamed from `int main()` by the merge awk). We must call them here
    // so globals like p_max_errors, _gen2_indent_cache, tc_errors etc. are
    // properly initialized before any module function runs. Without these
    // calls, globals remain zero-valued HexaVal (void) causing empty
    // identifiers and uninitialized state at runtime.
    // _type_checker_init runs only when HEXA_TYPECHECK env is set so the
    // default transpile path stays at tokenize->parse->codegen (#453
    // warnings are opt-in). The inline tests in _type_checker_init have
    // been verified safe under arena reset for our use. type_check()
    // reinits its own globals at call time.
    // M1 full · file Step 5: template emits rt_* (hexa_file_* shims removed).
    let main_cmd = "cat >> " + out_path + " <<'__MAIN_EOF__'\n\n\nint main(int argc, char** argv) {\n    if (argc < 3) {\n        printf(\"hexa-cc: HEXA self-hosted compiler\\nUsage: hexa-cc <input.hexa> <output.c>\\n\");\n        return 1;\n    }\n    hexa_set_args(argc, argv);\n    _lexer_init(argc, argv);\n    _parser_init(argc, argv);\n    _codegen_init(argc, argv);\n    HexaVal src = rt_read_file(hexa_str(argv[1]));\n    HexaVal tokens = tokenize(src);\n    /* PROBE r10-18d: thread source text into parser so parse errors can\n     * render rustc/clang-style source snippet + caret pointer. */\n    p_set_source(src);\n    HexaVal ast = parse(tokens);\n    /* PROBE r14 #453 wiring: opt-in type_check pass via HEXA_TYPECHECK env.\n     * Default off — corpus emits ~1322 warnings (immutable-let + non-exhaustive\n     * match) which would flood normal builds. `hexa typecheck` sets the env. */\n    if (getenv(\"HEXA_TYPECHECK\") != NULL) {\n        _type_checker_init(argc, argv);\n        type_check_and_emit(ast);\n    }\n    HexaVal c_code = codegen_full(ast);\n    /* F05 (2026-05-06): free AST+tokens before write to drop peak RSS. */\n    if (HX_IS_ARRAY(ast)) hexa_array_free(ast);\n    if (HX_IS_ARRAY(tokens)) hexa_array_free(tokens);\n    hexa_arena_reset();\n    rt_write_file(hexa_str(argv[2]), c_code);\n    printf(\"OK: %s\\n\", argv[2]);\n    return 0;\n}\n__MAIN_EOF__"
    exec(main_cmd)
    let chk = exec("test -f " + out_path + " && printf yes || printf no")
    return chk == "yes"
}

fn cmd_regen_cc() {
    println("=== hexa cc --regen : hexa_cc.c 자동 재생성 ===")
    println("  SSOT: self/{lexer,parser,type_checker,codegen}.hexa")
    // #12 leftover (3): resolve SSOT modules / hexa_cc.c / -I via
    // $HEXA_LANG > install_dir_from_argv0() > ./self — not cwd. `.` when
    // run from the repo root, so behavior there is unchanged.
    let __hxroot = resolve_hxroot()
    // preflight — buglist#5: resolve_hexat() 로 cwd/$HOME/argv[0] 모두 탐색.
    let v2 = resolve_or_bootstrap_hexat()
    if len(v2) == 0 {
        println("error: hexat not found — run `hexa cc` first")
        return
    }
    // Step 1-4: hexat transpile each SSOT → /tmp/_*.c
    println("")
    println("[1/4] transpiling SSOT modules via hexat")
    let ok1 = regen_one_module(__hxroot + "/self/lexer.hexa", "/tmp/_lexer.c")
    let ok2 = regen_one_module(__hxroot + "/self/parser.hexa", "/tmp/_parser.c")
    let ok3 = regen_one_module(__hxroot + "/self/type_checker.hexa", "/tmp/_tc.c")
    let ok4 = regen_one_module(__hxroot + "/self/codegen.hexa", "/tmp/_cg.c")
    let s1 = if ok1 { "ok" } else { "FAIL" }
    let s2 = if ok2 { "ok" } else { "FAIL" }
    let s3 = if ok3 { "ok" } else { "FAIL" }
    let s4 = if ok4 { "ok" } else { "FAIL" }
    println("  lexer=" + s1 + " parser=" + s2 + " tc=" + s3 + " cg=" + s4)
    if !(ok1 && ok2 && ok3 && ok4) {
        println("error: one or more SSOT modules failed to transpile (Phase C blocked on bt 35)")
        // continue to report diff on whatever was produced
    }
    // Step 5: merge → self/native/hexa_cc.c.new
    println("")
    println("[2/4] merging modules → self/native/hexa_cc.c.new  (MVP: concat + #include dedup + main strip)")
    let out_new = __hxroot + "/self/native/hexa_cc.c.new"
    let merged = merge_modules_awk(out_new)
    if !merged {
        println("error: merge failed")
        return
    }
    let new_sz = exec("wc -c < " + out_new + " | tr -d ' \\n'")
    let new_ln = exec("wc -l < " + out_new + " | tr -d ' \\n'")
    let old_sz = exec("wc -c < '" + __hxroot + "/self/native/hexa_cc.c' | tr -d ' \\n'")
    let old_ln = exec("wc -l < '" + __hxroot + "/self/native/hexa_cc.c' | tr -d ' \\n'")
    println("  hexa_cc.c      bytes=" + old_sz + "  lines=" + old_ln)
    println("  hexa_cc.c.new  bytes=" + new_sz + "  lines=" + new_ln)
    // Step 6: clang hexa_cc.c.new → /tmp/hexat.new  (실패 허용)
    println("")
    println("[3/4] clang compile hexa_cc.c.new → /tmp/hexat.new (failure tolerated)")
    // `-x c` forces C language since `.new` extension is unrecognized.
    // `-I self` mirrors the standard hexa_cc.c build (runtime.c lives in self/).
    // bt 54: int→ptr / implicit-fn 근본 해소 — 플래그 제거. -Wno-trigraphs만 유지.
    // bt 74+: -fbracket-depth=4096 — hexa codegen emits left-assoc hexa_add(hexa_add(...))
    //   for long `"a"+"b"+"c"` string concat chains (e.g. embedded Python
    //   runner in training/train_alm_14b.hexa has 500+ segments). clang's
    //   default bracket nesting limit (256) blows up on such files. Bumping
    //   to 4096 unblocks the ALM hexa-first launcher; real fix is to emit
    //   a loop or single large literal in codegen, tracked separately.
    // PHASE 1.6 (2026-05-15): step-3 smoke compile now links self/runtime.o
    // (built by cmd_cc rebuild step ahead) so the failure-tolerated smoke
    // actually exercises the same link arrangement as the real rebuild.
    // Phase C.2 (2026-05-22): split the smoke into compile-then-link. The
    // prior single-shot form passed `-x c <merged> <runtime.o>` together —
    // `-x c` is sticky and forced clang to parse runtime.o AS C SOURCE,
    // yielding a flood of "source file is not valid UTF-8" / "expected
    // identifier" errors that masked whether the merged C itself compiles.
    // Compiling the merged C to an object first (with `-x c` scoped to just
    // that translation unit) and then linking the two objects mirrors the
    // real two-TU rebuild and gives a truthful smoke result. Measured on
    // ubu-2: the merged regen C now compiles to .o with ZERO errors and the
    // link produces a working hexat that emits `__arr_raw_len` INLINE
    // (HX_ARR_LEN) instead of the stale hexa_call1(__arr_raw_len, ...).
    let cc_obj = "clang -O2 " + os_clang_cflags() + "-I '" + __hxroot + "/self' -x c -c -Wno-trigraphs -fbracket-depth=4096 " + out_new + " -o /tmp/hexa_cc.new.o 2>&1 | head -40"
    println("  " + cc_obj)
    let cc_obj_out = exec(cc_obj)
    if len(cc_obj_out) > 0 { println(cc_obj_out) }
    let obj_ok = exec("test -f /tmp/hexa_cc.new.o && printf yes || printf no")
    if obj_ok == "yes" {
        let cc_link = "clang -O2 /tmp/hexa_cc.new.o '" + __hxroot + "/self/runtime.o' -o /tmp/hexat.new" + os_clang_ldflags() + " 2>&1 | head -40"
        println("  " + cc_link)
        let cc_link_out = exec(cc_link)
        if len(cc_link_out) > 0 { println(cc_link_out) }
    } else {
        println("  (skip link — merged C failed to compile)")
    }
    let built = exec("test -x /tmp/hexat.new && printf yes || printf no")
    println("  compiled=" + built)
    // Step 7: diff report
    println("")
    println("[4/4] diff summary")
    let diff_sz = exec("diff -q '" + __hxroot + "/self/native/hexa_cc.c' " + out_new + " 2>&1 | head -1")
    println("  diff: " + diff_sz)
    println("")
    println("Phase C MVP done. Merge algorithm limitations:")
    println("  - simple concat; no global symbol collision resolution")
    println("  - main() stripped via awk brace-depth (single-line `}` assumed)")
    // Phase C.2 RESOLVED (2026-05-22, ubu-2): the awk merge + per-module
    // string-literal-aware rename is sufficient — the merged C compiles
    // and links cleanly when the DRIVING hexat is current (i.e. emits
    // rt_str_* / rt_read_file / inline HX_ARR_LEN rather than the legacy
    // hexa_str_* / hexa_call1 forms). The earlier "needs static namespacing"
    // caveat was a misdiagnosis: the real blocker was a STALE bootstrap
    // binary — a build/hexat_linux predating the runtime rt_* rename +
    // __arr_raw_len inline branch. Driving the regen with a binary freshly
    // built from self/native/hexa_cc.c (HEXA_VAL_ARENA=0) yields a clean
    // link AND reaches bootstrap fixpoint: gen-N codegen == gen-N+1 codegen
    // byte-identical. Remaining manual step: rebuild + promote the shipped
    // build/hexat_linux from the freshly-linked binary (deploy ceremony).
}

fn basename_stem(path) {
    return exec("basename " + path + " | sed 's/\\.hexa$//' | tr -d '\\n'")
}

fn ends_with_dot_hexa(s) {
    // SH3 1.E unblocker: in-process suffix check. The previous shell-out
    // form (`case ... in *.hexa) ...`) was returning "no" for absolute
    // paths in some hexa builds, breaking the file-as-subcommand
    // dispatch. Substring compare is exec-free and deterministic.
    let n = len(s)
    if n < 5 { return false }
    return s.substring(n - 5, n) == ".hexa"
}

// ── ω-cycle (2026-04-26) auto-marker protocol ─────────────────
// silent-land 근본 해결: cmd_run 종료 시점(=사용자 .hexa script main()
// 종료 시점) 자동으로 state/markers/<basename>_<ts>.marker 작성. 비
// -통신 채널이 truncate 되더라도 disk 위 marker 가 commit 신호로 잔존.
//
// 기본값 ON (default-on). 옵트아웃: HEXA_NO_MARKER=1.
// 결정성: HEXA_FROZEN_TIME=<epoch> 설정 시 timestamp 동결 → byte-identical.
// 실패 marker: rc != 0 일 경우 *_FAILED.marker 작성 (debugging).
// 디렉토리: 호출 시점 cwd 의 state/markers/ (auto mkdir). HEXA_MARKER_DIR
// 로 디렉토리 override 가능.
//
// 본 구현은 cmd_run 의 모든 종료 경로 (cache hit / 일반 / FAIL exit) 직전
// 호출되며, additive only — 기존 builtin signature 0 변경.
fn auto_marker_basename(path) {
    // basename without .hexa suffix; safe-quote for shell
    let b = exec("basename '" + path + "' 2>/dev/null | sed 's/\\.hexa$//' | tr -d '\\n'")
    if len(b) == 0 { return "anon" }
    return b
}

fn auto_marker_dir() {
    let override_dir = env_var("HEXA_MARKER_DIR")
    if len(override_dir) > 0 { return override_dir }
    return "state/markers"
}

fn auto_marker_now() {
    let frozen = env_var("HEXA_FROZEN_TIME")
    if len(frozen) > 0 { return frozen }
    return exec("date +%s | tr -d '\\n'")
}

fn auto_marker_fp(path) {
    // FNV-ish via shasum for stable fingerprint; 8 hex chars enough.
    let r = exec("shasum '" + path + "' 2>/dev/null | head -c 8 | tr -d '\\n'")
    if len(r) == 0 { return "00000000" }
    return r
}

fn auto_marker_write(file, rc) {
    if env_var("HEXA_NO_MARKER") == "1" { return }
    let dir = auto_marker_dir()
    exec("mkdir -p '" + dir + "' 2>/dev/null")
    let stem = auto_marker_basename(file)
    let ts = auto_marker_now()
    let fp = auto_marker_fp(file)
    let suffix = if rc == 0 { ".marker" } else { "_FAILED.marker" }
    let path = dir + "/" + stem + "_" + ts + suffix
    let exit_str = to_string(rc)
    let body = "{\"source\":\"" + file + "\",\"exit\":" + exit_str + ",\"fingerprint\":\"" + fp + "\",\"ts\":" + ts + "}\n"
    write_file(path, body)
}

// ── bt 40: macOS Gatekeeper codesign helper ───────────────
// 목적: AOT/build 로 생성된 exe 를 macOS Gatekeeper 가 거부하지 않도록
//       ad-hoc 서명(`codesign --sign -`) 자동 수행. Linux/기타 OS 에서는
//       skip, codesign 바이너리 부재/실패 시 warning 만 남기고 진행.
// 호출처:
//   (1) cmd_build — `hexa build` 직접 경로 (bt 37 atomic rename 직전)
// 실패정책: warning only (R1 interp 경로 보존 — 서명 실패가 실행을 막지 않음).
fn is_macos() {
    // uname 결과가 "Darwin" 인지 판정. 공백/개행 제거.
    // Linux 에서는 "Linux" 반환 → false → codesign skip.
    let u = exec("uname 2>/dev/null | tr -d ' \\n\\t'")
    return u == "Darwin"
}

fn codesign_if_macos(exe) {
    // macOS 한정 ad-hoc 서명. 기타 OS 는 no-op.
    // codesign 부재/실패 시 stderr 경고만 출력하고 계속 진행.
    if !is_macos() {
        return
    }
    let has = exec("command -v codesign >/dev/null 2>&1 && printf yes || printf no")
    if has != "yes" {
        println("warning: codesign not found — skipping signature (" + exe + ")")
        return
    }
    // `--force` 재서명 허용, `--sign -` ad-hoc 서명(배포 아닌 로컬 실행용).
    // macOS Sonoma+ 는 clang 출력이 이미 ad-hoc 서명 상태 → codesign 이
    // "replacing existing signature" 를 stderr 로 출력(정상). 이를 warning 으로
    // 간주하지 않도록 `grep -v` 로 필터. 실제 실패는 "errSec*" 또는 "invalid" 포함.
    let r = exec("codesign --force --sign - '" + exe + "' 2>&1 | grep -v 'replacing existing signature' || true")
    if len(r) > 0 {
        println("warning: codesign failed for " + exe + ": " + r)
    }
}

// ── T28 / buglist#5: hexat binary path resolution ──────
// 목적: `hexa build` / `hexa parse` 가 cwd 무관하게 hexat 트랜스파일러를
//       찾을 수 있도록 한다. 과거에는 `./self/native/hexat` (cwd 의존)
//       하드코딩이라, hexa-lang 리포 바깥에서 실행하면 바이너리 미발견
//       상태에서도 exec 가 빈 파일/실패 출력을 찍고 조용히 exit 0 하는
//       silent-failure 회귀가 있었다 (T28).
//
// buglist#5 (hetzner airgenome 재현): cwd=airgenome 에서 `hexa build ...` →
//       "sh: 1: ./self/native/hexat: not found". cwd 기반 탐색도, $HOME
//       기반 탐색도 airgenome 사용자 경로에서는 hexa-lang 리포를 못 찾음.
//       해법: args()[0] 즉 `./hexa` 실행 파일 자체의 절대 경로에서 install
//       디렉토리(dirname(exe))를 도출 → `<install_dir>/self/native/hexat`.
//       이것이 가장 신뢰할 수 있는 경로 (`./hexa` 와 `./self/...` 는 같은
//       하위 트리). 심볼릭 링크는 `cd $(dirname ..) && pwd -P` 로 해결.
//
// 탐색 순서:
//   1) argv[0] 기반 install_dir (최우선 — cwd / $HOME 와 독립)
//   2) ./self/native/hexat (cwd — 리포 안에서 실행 시 기존 동작 유지)
//   3) $HEXA_LANG/self/native/hexat (개발 fallback — bench 와 동일)
//   4) /proc/self/exe (Linux container fallback — argv[0] 빈/empty 일 때)
// 넷 다 없으면 빈 문자열 반환. 호출자가 명시 오류 + exit(1) 처리.
fn install_dir_from_argv0() {
    // args()[0] = 런타임이 삽입한 exec 경로 (상대/절대/심볼릭 모두 가능).
    // realpath 로 심볼릭 링크를 완전 해석한 뒤 dirname 수행.
    // 이전: dirname(argv0) + pwd -P → 파일 자체가 symlink 일 때 원본 디렉토리가
    //       아닌 symlink 디렉토리를 반환 (예: ~/.hx/bin/hexa → ~/.hx/packages/hexa/hexa
    //       에서 ~/.hx/bin 을 반환하여 stale interp 참조).
    // 빈 문자열(비정상) / 해석 실패 시 → /proc/self/exe Linux fallback 시도.
    //
    // hexa-runner container 진단 (BG ab36b1648a338643c, 2026-05-03):
    //   - container `/usr/local/bin/hexa` 호출 시 args()[0] empty/unresolvable
    //   - resolve_cmd 가 빈 D 반환 → install_dir 미해결 → silent emit 회귀
    //   - /proc/self/exe symlink 은 Linux kernel 이 항상 제공하므로 안정적.
    //   - macOS 는 /proc 자체가 없음 → 자동 skip (test -L 실패).
    let av0 = args()
    let exe = ""
    if len(av0) > 0 {
        exe = av0[0]
    }
    // 1-3) argv[0] 기반 — exe 비어있지 않을 때만 시도.
    if len(exe) > 0 {
        // Resolve symlinks on the exe itself (not just the directory), then dirname.
        // realpath: macOS (BSD) + GNU coreutils. readlink -f: GNU fallback.
        // If neither resolves, fall back to the original dirname + pwd -P path.
        // Bug (INBOX 2026-05-25T00:50Z): when argv[0] is a bare basename
        // (no slash — e.g. exec -a hexa from ~/.hx/bin/hexa shim), POSIX
        // realpath of a bare name probes CWD FIRST. A user running `hexa
        // build foo.hexa` from a /tmp git worktree that happens to ship the
        // same `hexa` shim file (committed into the repo) → realpath resolves
        // to the worktree's stray ./hexa, install_dir = worktree dir, no
        // build/hexa_module_loader → module_loader skipped → multi-module
        // builds link-fail. Fix: when EXE has NO slash, go through `command
        // -v` FIRST (PATH-resolved), and only fall back to the bare-name
        // realpath if PATH lookup fails. EXE with a slash (absolute or
        // relative path) keeps the realpath-first behaviour — that's the
        // canonical exec path and was never ambiguous.
        let resolve_cmd = "EXE='" + exe + "'; case \"$EXE\" in */*) USE_PATH=0;; *) USE_PATH=1;; esac; if [ \"$USE_PATH\" = 1 ]; then P=\"$(command -v \"$EXE\" 2>/dev/null)\"; if [ -n \"$P\" ] && [ -f \"$P\" ]; then REAL=\"$(realpath \"$P\" 2>/dev/null || readlink -f \"$P\" 2>/dev/null || echo \"$P\")\"; D=\"$(cd \"$(dirname \"$REAL\")\" 2>/dev/null && pwd -P)\"; else REAL=\"$(realpath \"$EXE\" 2>/dev/null || readlink -f \"$EXE\" 2>/dev/null)\"; if [ -n \"$REAL\" ] && [ -f \"$REAL\" ]; then D=\"$(cd \"$(dirname \"$REAL\")\" 2>/dev/null && pwd -P)\"; elif [ -f \"$EXE\" ]; then D=\"$(cd \"$(dirname \"$EXE\")\" 2>/dev/null && pwd -P)\"; else D=\"\"; fi; fi; else REAL=\"$(realpath \"$EXE\" 2>/dev/null || readlink -f \"$EXE\" 2>/dev/null)\"; if [ -n \"$REAL\" ] && [ -f \"$REAL\" ]; then D=\"$(cd \"$(dirname \"$REAL\")\" 2>/dev/null && pwd -P)\"; elif [ -f \"$EXE\" ]; then D=\"$(cd \"$(dirname \"$EXE\")\" 2>/dev/null && pwd -P)\"; else D=\"\"; fi; fi; printf '%s' \"$D\""
        let d = exec(resolve_cmd)
        if len(d) > 0 {
            return d
        }
    }
    // 4) /proc/self/exe Linux fallback — argv[0] 가 비었거나 resolve 실패 시.
    //    test -L 로 symlink 존재 확인 (macOS 에서는 false → "" 반환).
    //    readlink -f 우선, fallback 으로 realpath.
    //
    // 의미론 보정: install_dir 정의 = "hexa driver 가 있는 디렉토리"
    //   (`<install_dir>/hexa.real`, `<install_dir>/self/...` layout).
    // /proc/self/exe 는 *현재 실행 중인 프로세스* binary 를 가리킨다 — R7
    // 이후 그것은 compiled `hexa.real` 이므로 dirname(REAL) = install_dir.
    // 안전 보정: basename(dirname) == "build" (구 layout 잔재) 일 때만 한
    // 단계 위로; 그 외에는 dirname 을 그대로 install_dir 로 사용.
    let proc_cmd = "if [ -L /proc/self/exe ]; then REAL=\"$(readlink -f /proc/self/exe 2>/dev/null || realpath /proc/self/exe 2>/dev/null)\"; if [ -n \"$REAL\" ] && [ -f \"$REAL\" ]; then D=\"$(cd \"$(dirname \"$REAL\")\" 2>/dev/null && pwd -P)\"; if [ \"$(basename \"$D\")\" = \"build\" ]; then D=\"$(cd \"$D/..\" 2>/dev/null && pwd -P)\"; fi; printf '%s' \"$D\"; fi; fi"
    let pd = exec(proc_cmd)
    return pd
}

// ── F-LIVE-DISPATCH (2026-05-24): multiarch hexat selection ──────────
// The committed transpiler binary is platform-specific: `self/native/hexat`
// is the Mac arm64 Mach-O (legacy name, preserved to avoid churning the
// build chain), and `self/native/hexat_linux_x86_64` is the Linux x86_64
// ELF (added PR #554). The runtime cmd_* path (cmd_build → resolve_hexat)
// previously hardcoded the legacy `hexat` name at all three probe sites, so
// a `hexa drill` (→ dispatch_absorbed → cmd_run → hexa build → cmd_build)
// dispatched to a Linux pool host invoked the Mac arm64 binary on Linux →
// SIGSEGV ("Segmentation fault (core dumped)" on the [1/2] transpile step).
//
// This is the runtime-side counterpart of tool/build_hexa_cli.hexa's
// _pick_hexat(): same (os, arch) → basename mapping, same graceful
// fallback to the legacy name when the arch-specific binary isn't committed
// yet (older clones). Kept as a sibling here (rather than imported) because
// self/main.hexa is the self-host dispatcher root and must stay flatten-clean
// without a cross-tool `use` edge into tool/.
// See [[reference_ubu_arch_transpiler_constraint]].
// _pick_hexat_with_build: CANON M3b — the transpiler is a per-machine
// build artifact at <root>/build/hexat, built by `hexa cc` from hexa_cc.c
// (Go 1.4 C-seed model), never a committed binary — so it is always
// arch-correct (this closes the committed-binary arch-leak class). Returns
// the artifact path if executable, else "" (caller bootstraps via cmd_cc).
// The committed-binary multiarch picker (_hexat_basename /
// _pick_hexat_in_dir) was removed when M3b dropped self/native/hexat +
// hexat_linux_x86_64 from git.
fn _pick_hexat_with_build(root) {
    let build_bin = root + "/build/hexat"
    let build_chk = exec("test -x '" + build_bin + "' && printf yes || printf no")
    if build_chk == "yes" {
        return build_bin
    }
    return ""
}

fn resolve_hexat() {
    // CANON M3: each probe root resolves build/hexat (cc-built artifact)
    // FIRST, then the committed self/native binary as fallback.
    // 1) argv[0] 기반 — 가장 우선 (dirname(./hexa) = repo root).
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        let argv_bin = _pick_hexat_with_build(inst)
        if len(argv_bin) > 0 {
            return argv_bin
        }
    }
    // 2) cwd-relative — 리포 루트에서 실행 시.
    let cwd_bin = _pick_hexat_with_build(".")
    if len(cwd_bin) > 0 {
        return cwd_bin
    }
    // 3) $HEXA_LANG fallback — 개발 기본 위치.
    let home_root = exec("printf '%s' \"$HEXA_LANG\"")
    if len(home_root) > 0 {
        let home_bin = _pick_hexat_with_build(home_root)
        if len(home_bin) > 0 {
            return home_bin
        }
    }
    return ""
}

// resolve_or_bootstrap_hexat: CANON M3b — resolve the transpiler artifact,
// bootstrapping it from hexa_cc.c via cmd_cc if absent. This is the go-build
// model: a fresh clone with no build/hexat self-bootstraps on first use
// instead of erroring out. cmd_cc never calls resolve_hexat, so the
// bootstrap is non-recursive.
fn resolve_or_bootstrap_hexat() {
    let v2 = resolve_hexat()
    if len(v2) > 0 {
        return v2
    }
    println("  [bootstrap] build/hexat absent — building transpiler via hexa cc")
    cmd_cc()
    return resolve_hexat()
}

// S5 native-codegen campaign: resolve the native compiler binary
// (compiler/main.hexa → built as `aprime_cc`). Mirrors resolve_hexat()'s
// probe order: env override > <install>/build/aprime_cc > ./build/aprime_cc
// > $HEXA_LANG/build/aprime_cc. Returns "" when no binary is found — the
// caller (cmd_build, HEXA_BACKEND=native) then fails LOUD, never silently
// falling back to the C path.
fn resolve_native_cc() {
    let env_cc = exec("printf '%s' \"$HEXA_APRIME_CC\"")
    if len(env_cc) > 0 {
        let env_chk = exec("test -x '" + env_cc + "' && printf yes || printf no")
        if env_chk == "yes" { return env_cc }
    }
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        let inst_cc = inst + "/build/aprime_cc"
        let inst_chk = exec("test -x '" + inst_cc + "' && printf yes || printf no")
        if inst_chk == "yes" { return inst_cc }
    }
    let cwd_chk = exec("test -x './build/aprime_cc' && printf yes || printf no")
    if cwd_chk == "yes" { return "./build/aprime_cc" }
    let home_cc = exec("printf '%s' \"$HEXA_LANG/build/aprime_cc\"")
    if len(home_cc) > 0 {
        let home_chk = exec("test -x '" + home_cc + "' && printf yes || printf no")
        if home_chk == "yes" { return home_cc }
    }
    return ""
}

// S5: fail-loud when HEXA_BACKEND=native but no native compiler binary.
fn die_no_native_cc() {
    println("error: native compiler binary (aprime_cc) not found")
    println("       HEXA_BACKEND=native requires a built aprime_cc")
    println("       searched:")
    println("         $HEXA_APRIME_CC  (env override)")
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        println("         " + inst + "/build/aprime_cc  (from argv[0])")
    }
    println("         ./build/aprime_cc  (cwd)")
    println("         $HEXA_LANG/build/aprime_cc  (dev fallback)")
    println("       build it: bash tool/build_aprime.sh -o build/aprime_cc")
    exit(1)
}

// R7 Cycle C closure — resolve_interp() and _probe_interp_at() removed.
// The tree-walking interpreter is retired (g_interp_deprecated); no code
// path resolves a build/hexa_interp binary anymore. `cmd_run` is compile-
// then-exec and `cmd_build`'s flatten step uses the compiled module_loader
// binary (resolve_module_loader_compiled, below).

// interp-retirement R7 gate #4: prefer a COMPILED module_loader binary so the
// `hexa build` flatten step runs interp-free. Probes (in order) $HEXA_MODULE_LOADER
// env override, <install>/build/hexa_module_loader, ./build/hexa_module_loader,
// $HEXA_LANG/build/hexa_module_loader. Returns "" when no compiled binary exists
// (caller then falls back to resolve_module_loader() + interp). Built via
// tool/build_hexa_cli.sh.
fn resolve_module_loader_compiled() {
    let env_ml = exec("printf '%s' \"$HEXA_MODULE_LOADER\"")
    if len(env_ml) > 0 {
        let env_chk = exec("test -x '" + env_ml + "' && printf yes || printf no")
        if env_chk == "yes" { return env_ml }
    }
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        let inst_ml = inst + "/build/hexa_module_loader"
        let inst_chk = exec("test -x '" + inst_ml + "' && printf yes || printf no")
        if inst_chk == "yes" { return inst_ml }
    }
    let cwd_chk = exec("test -x './build/hexa_module_loader' && printf yes || printf no")
    if cwd_chk == "yes" { return "./build/hexa_module_loader" }
    let home_ml = exec("printf '%s' \"$HEXA_LANG/build/hexa_module_loader\"")
    if len(home_ml) > 0 {
        let home_chk = exec("test -x '" + home_ml + "' && printf yes || printf no")
        if home_chk == "yes" { return home_ml }
    }
    return ""
}

fn resolve_module_loader() {
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        let argv_ml = inst + "/self/module_loader.hexa"
        let argv_chk = exec("test -f '" + argv_ml + "' && printf yes || printf no")
        if argv_chk == "yes" {
            return argv_ml
        }
    }
    let cwd_ml = "./self/module_loader.hexa"
    let cwd_chk = exec("test -f '" + cwd_ml + "' && printf yes || printf no")
    if cwd_chk == "yes" {
        return cwd_ml
    }
    let home_ml = exec("printf '%s' \"$HEXA_LANG/self/module_loader.hexa\"")
    let home_chk = exec("test -f '" + home_ml + "' && printf yes || printf no")
    if home_chk == "yes" {
        return home_ml
    }
    return ""
}

// orpheus FEATURE.md O-002 / F-013 — install-relative stdlib discovery.
//
// When `hexa run <module>` is invoked from cron/launchd/a subagent it
// inherits no environment, so HEXA_LANG / HEXA_STDLIB_ROOT are unset and
// `use "stdlib/*"` previously FATAL'd in the module_loader pre-flatten.
// Fix: derive the install dir from argv[0] / /proc/self/exe (via
// install_dir_from_argv0(), already used to locate the interp + the
// module_loader.hexa source) and pass it down to the module_loader child
// as HEXA_INSTALL_DIR. module_loader's ml_resolve_stdlib() then probes a
// fixed install-relative chain (<inst>/stdlib, <inst>/self/stdlib,
// <inst>/self/../stdlib — which reaches a `self -> <repo>/self` symlink's
// repo top-level stdlib/ even when <inst> has no stdlib link, e.g.
// ~/.hx/bin — the FHS <prefix>/share/hexa/stdlib, …) as a *fallback*.
// HEXA_STDLIB_ROOT / HEXA_LANG still win when set. This obsoletes
// orpheus's tool/orpheus_hexa_run.sh probe wrapper for the standard
// ~/.hx/ install.
//
// Returns a `HEXA_INSTALL_DIR='<dir>' ` shell prefix (trailing space) to
// be prepended to the `exec(...)` command that launches the module_loader
// child, or "" if the install dir isn't derivable or HEXA_INSTALL_DIR is
// already present in the environment (never clobbered).
fn module_loader_env_prefix() {
    // module_loader is a one-shot flatten — it holds the entire bundle's AST
    // in memory. The default 768 MB runtime cap (runtime.c::_hx_mem_cap_bytes)
    // bites on bundles that grow past ~1100 user-fns (observed: wilson v0.1
    // adding 4 pool helpers pushed past the cap → silent fallback to raw src
    // → codegen sees `use "..."` directives intact → `_resolve_use_emit`
    // path that emits only fn forward decls, no struct decls → clang link
    // fails on `SessionStartData` undeclared etc.). 2026-05-13 fix: raise
    // the cap for the child module_loader so flatten completes for any
    // realistic project size. The parent `hexa build` keeps the default cap
    // because hexat (the actual transpiler) is much lighter than the
    // flatten step. If a future bundle grows past 4 GB this needs revisit.
    //
    // Operator override: HEXA_MEM_CAP_MB=<N> (parent) is propagated; if
    // unset, force 4096. HEXA_MEM_UNLIMITED=1 (parent) is also propagated.
    let mut parts = []
    if len(env_var("HEXA_INSTALL_DIR")) == 0 {
        let inst = install_dir_from_argv0()
        if len(inst) > 0 {
            parts.push("HEXA_INSTALL_DIR='")
            parts.push(inst)
            parts.push("' ")
        }
    }
    // Memory-cap propagation. Don't clobber an operator-supplied value.
    if env_var("HEXA_MEM_UNLIMITED") != "1" && len(env_var("HEXA_MEM_CAP_MB")) == 0 {
        parts.push("HEXA_MEM_CAP_MB=4096 ")
    }
    return parts.join("")
}

// 실패 메시지 공통화 — silent exit 0 회귀 재발 방지.
fn die_no_hexat() {
    println("error: hexat transpiler binary not found")
    println("       searched:")
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        println("         " + inst + "/self/native/hexat  (from argv[0])")
    }
    println("         ./self/native/hexat  (cwd)")
    println("         $HEXA_LANG/self/native/hexat  (dev fallback)")
    println("       run `hexa cc` (inside hexa-lang repo) to build it")
    exit(1)
}

// ── Cross-compile target table (ROADMAP item #20) ──────────────────────
// Maps hexa target name → zig-cc -target triple. zig (>=0.11) bundles musl
// + glibc + macOS SDK and produces statically/dynamically linked output for
// all listed targets from any host. Empty return = unknown target.
fn target_zig_triple(t) {
    if t == "linux-x86_64-musl"  { return "x86_64-linux-musl" }
    if t == "linux-x86_64-glibc" { return "x86_64-linux-gnu"  }
    if t == "linux-aarch64-musl" { return "aarch64-linux-musl" }
    if t == "linux-aarch64-glibc" { return "aarch64-linux-gnu" }
    if t == "darwin-arm64"       { return "aarch64-macos-none" }
    if t == "darwin-x86_64"      { return "x86_64-macos-none"  }
    return ""
}
fn target_static_flag(t) {
    if t == "linux-x86_64-musl"  { return " -static" }
    if t == "linux-aarch64-musl" { return " -static" }
    return ""
}
fn target_supported_list() {
    return "linux-x86_64-musl, linux-x86_64-glibc, linux-aarch64-musl, linux-aarch64-glibc, darwin-arm64, darwin-x86_64"
}

// ─── MERGE: HEAD (RFC 071 P3 PATH-B) below, rfc070-g7-native-scaffold below the ━━━ ───
// ─── RFC 071 P3 — NVPTX source-derived PTX builder (PATH-B) ─────────
// Live driver-side mirror of compiler/cli/build_nvptx.hexa. Per the
// 2026-05-21 Path B probe, the 5 compiler pipeline modules (lex /
// parse / lower-to-HIR / lower-to-MIR / static_atlas) + the codegen
// entry (nvptx_target.codegen_emit_ptx_for_sm) + the MIR shapes
// (compiler/ir/mir.hexa) are all parse-clean importable from
// self/main.hexa (the dispatcher root). The `use compiler/cli/
// build_nvptx.hexa` indirection that the spec sibling described is
// NOT NEEDED — we can compose the pipeline inline here.
//
// PATH-B HONEST SCOPE (@D g3):
//   - This rewrite passes the in-hexa parse gate (`hexa parse self/
//     main.hexa` clean). Whether `hexa build self/main.hexa` survives
//     on macOS is gated by `project_compiler_selfbuild_blockers`
//     (Mac OOM on full flatten). The compiled driver is regenerated
//     by `hexa cc` on Linux pool hosts; runtime activation of the
//     PTX bridge requires that build to succeed.
//   - When the host can flatten + clang-compile self/main.hexa, the
//     emitted PTX reflects the SOURCE BODY (kernel-name marker
//     `my_test_kernel` from nvptx_p3_source_to_silicon_test.hexa)
//     instead of the P2.1 hand-MIR `vadd` fallback.
//   - Hand-MIR vec-add fallback is NOT replicated here — that path
//     lives in the spec sibling for callers that pass src_path="".
//     The live driver dispatch from cmd_build always passes a non-
//     empty src_path (the user's `hexa build foo.hexa --target=…`
//     argument), so the fallback never triggers in production.
//   - No LLVM (@F f1). No C-transpile changes (@F f2). N5/metal_*
//     untouched.

// _build_nvptx_emit_driver(src_path, sm_arch) -> int
//
// P3 live entry. Reads src_path, runs lex → parse → lower(ast_to_hir)
// → lower_hir(hir_to_mir), then calls codegen_emit_ptx_for_sm(mmod,
// sm_arch) and writes the resulting PTX to `<src_path>.ptx`.
//
// Returns: 0 on PTX write success, 1 on file-IO error.
// Side effect: writes `<src_path>.ptx` with the source-derived PTX.
fn _build_nvptx_emit_driver(src_path, sm_arch) {
    if len(src_path) == 0 { return 1 }
    if len(sm_arch)  == 0 { return 1 }
    // Pre-check source exists (cmd_build already ran the same check
    // above; duplicate for direct-callers in future tests).
    if !file_exists(src_path) { return 1 }
    // iter-2b/2e GATE: live pipeline calls lex/parse/static_atlas/lower/
    // lower_hir/codegen_emit_ptx_for_sm; bodies live in compiler/ modules
    // NOT linked by bootstrap Stage 1 -> 6 undefined symbols. Gated until
    // Path C. Standalone driver at compiler/cli/build_nvptx.hexa.
    println("[nvptx] GATED RFC071-P3-PathB src=" + src_path + " sm=" + sm_arch)
    return 1
}

// Source-block fork-storm — cross-process clang concurrency cap.
// `hexa run <probe>` spawns clang per unique input; when N parallel
// agents each probe at once, N clang's storm.  Token-ring of mkdir
// permits (mkdir is atomic on POSIX fs) caps concurrent clang to
// `cap_n`; excess invocations spin on the lock with 50ms backoff.
// Per archive/patches/fork-storm-source-block-design.md (PR #375) +
// commons g30 (no opt-out env override — guards ship without an
// off switch).
fn _hexa_clang_capped(cmd) {
    let cap_n = 2
    let lock_root = "/tmp/.hexa_clang_caps"
    exec("mkdir -p " + lock_root + " 2>/dev/null")
    let mut tok = 0
    let mut waited_ms = 0
    let mut token_dir = ""
    let mut acquired = false
    while !acquired {
        token_dir = lock_root + "/" + to_string(tok)
        let _r = exec_with_status("mkdir " + token_dir + " 2>/dev/null && printf OK")
        if _r[1] == 0 {
            acquired = true
        } else {
            tok = (tok + 1) % cap_n
            sleep_ms(50)
            waited_ms = waited_ms + 50
            // Stale-token GC — normal clang is 3-4s; if we've waited 30s
            // a holder crashed without rmdir.  Force-release slot 0.
            if waited_ms > 30000 {
                exec("rmdir " + lock_root + "/0 2>/dev/null")
                waited_ms = 0
            }
        }
    }
    let out = exec(cmd)
    exec("rmdir " + token_dir + " 2>/dev/null")
    return out
}

fn cmd_build(src, out, c_only, target, shared) {
    // RFC 070 §3.B / G7-A (Shape A flag-wiring sub-cycle, 2026-05-20)
    //   `shared` = "1" → emit a position-independent shared library
    //   (`-fPIC -shared` clang pass-through). ELF `ET_DYN` / Mach-O
    //   `MH_DYLIB` falls out of clang -shared on the respective hosts;
    //   the F-A1/F-A2 falsifier battery (PIC re-load + 1-exported-symbol
    //   nm check) is the NEXT measured sub-cycle.
    //
    //   This sub-cycle is FLAG WIRING ONLY:
    //     - `hexa build --shared <plugin>.hexa -o <plugin>.so` parses
    //     - C-path: clang invocation gets `-fPIC -shared`
    //     - HEXA_BACKEND=native: refused (native codegen PIC mode is the
    //       parallel G7-A sub-cycle that touches
    //       compiler/codegen/{arm64_darwin,x86_64_linux}.hexa; not in
    //       this commit per @D g_inbox_processing_loop Shape A)
    //     - --c-only + --shared: refused (no clang step, no -shared)
    //     - --target=<triple> + --shared: refused for this sub-cycle
    //       (cross-target PIC requires per-triple validation; gated on
    //       a separate G7-A.cross sub-cycle)
    //
    //   Hidden-visibility default + `<plugin_id>_dispatch`-only export
    //   (RFC 070 §3.B) is ALSO out of scope here — clang `-shared` alone
    //   exports every public symbol. F-A2 will measure the gap; the
    //   visibility / export-list narrowing lands as a follow-up
    //   sub-cycle once F-A2 quantifies what currently leaks.
    //
    //   Cross-link: @D g5 hexa-native-only (libc dlopen is an existing
    //   FFI consumer per RFC 070 §2 audit; `-shared` widens that
    //   consumption but does NOT add a new toolchain dependency).
// ─── END MERGE ───
    // bt 37: AOT 캐시 atomic rename.
    // 문제: 두 `hexa build` 가 동일 `out` 을 쓰면 clang 이 같은 파일을 동시에
    //       open(O_TRUNC) 하여 부분 쓰기/경합 발생 (macOS/Linux 공통). 한 쪽이
    //       실행 중인 exe 를 덮어쓰기 시도 시 ETXTBSY 도 가능.
    // 해법: `<out>.tmp.$$` 로 컴파일 + codesign 후 `mv -f` 로 atomic rename.
    //       - $$ = exec 셸 PID → 프로세스마다 서로 다른 tmp 파일.
    //       - mv 는 동일 파일시스템 rename(2) → 원자성 보장.
    //       - 마지막으로 rename 한 쪽이 승자. 두 프로세스 모두 exit 0, exe 유효.
    //
    // T28: 소스 파일 존재 확인 + hexat 경로 resolve. 둘 중 하나라도 실패하면
    //      이전처럼 clang 호출 → mv → OK 를 찍으며 exit 0 하는 silent-failure 대신
    //      명시 오류 + exit(1) 로 실패하도록 한다.
    let src_exists = exec("test -f '" + src + "' && printf yes || printf no")
    if src_exists != "yes" {
        println("error: source file not found: " + src)
        exit(1)
    }
    // ─── RFC 071 P1+P2 — NVPTX emit-driver dispatch ──────────────────────
    // RFC 071 P0 (PR #228 cb4a2e37) recognised the 3 NVPTX target strings
    // and printed an informative deferred-message + exit(1). P1+P2 lift
    // that to a real driver dispatch: detect target -> call
    // _build_nvptx_emit_driver(src, sm_arch) -> exit with its rc. The
    // driver today emits CANNED stub PTX (`_hexa_smoke` no-op kernel);
    // P2.1 wires the real codegen_emit_ptx_sm80(mir) invocation, and P3
    // wires module_loader `@gpu_kernel` discovery. CPU codegen path
    // (`--target=` empty/`linux-*`/`darwin-*`) is BYTE-IDENTICAL — the
    // dispatch branch catches before target_zig_triple lookup.
    //
    // F-RFC071-TARGET-ACCEPT (P1): the 3 nvptx target strings reach the
    //   driver, not the zig-cc table.
    // F-RFC071-EMIT-DRIVER-INVOKE (P2): driver writes a valid stub PTX
    //   file at <src>.ptx and returns 0; P2.1+ replaces with real codegen.
    if len(target) > 0 {
        let mut _nvptx_sm = ""
        if target == "nvptx64-nvidia-cuda-sm80"  { _nvptx_sm = "sm_80"  }
        if target == "nvptx64-nvidia-cuda-sm90"  { _nvptx_sm = "sm_90"  }
        if target == "nvptx64-nvidia-cuda-sm120" { _nvptx_sm = "sm_120" }
        if len(_nvptx_sm) > 0 {
            let _nv_rc = _build_nvptx_emit_driver(src, _nvptx_sm)
            exit(_nv_rc)
        }
    }
    // ─── Darwin build refusal (2026-04-20 kernel panic prevention) ──────
    // Root-cause of 2026-04-20 03:33 Mac kernel panic: a train_alm_lora.hexa
    // source was compiled to /private/tmp/train_alm_lora_mac on Darwin, then
    // executed — 49 swapfiles, LOW swap, loginwindow watchdog 91s timeout.
    //
    // Rule: on Darwin, `hexa build` refuses output paths that look like
    // "Mac-target heavy compute binaries":
    //   (a) basename ends with "_mac" / "-mac" / "_darwin"
    //   (b) output under /tmp or /private/tmp (panic trigger path)
    //   (c) source has @refuse / @heavy on fn main() (hexa-lang attr intent)
    //
    // Bypass: HEXA_MAC_BUILD_OK=1 (CI dry-run, non-heavy experiments only).
    // Correct path: ssh ubu/hetzner/htz 'cd <repo> && hexa build <src> -o <out>'
    // Cross-target bypass (ROADMAP #20): explicit `--target=...` is intentional,
    // so the kernel-panic guard does not apply to non-native builds.
    if len(target) == 0 && is_macos() && env("HEXA_MAC_BUILD_OK") != "1" {
        let out_basename = exec("basename '" + out + "' 2>/dev/null").trim()
        let mut _refuse_reason = ""
        let _olen = len(out_basename)
        if _olen >= 4 {
            let _tail4 = out_basename.substring(_olen - 4, _olen)
            if _tail4 == "_mac" { _refuse_reason = "basename ends in _mac" }
            if _tail4 == "-mac" { _refuse_reason = "basename ends in -mac" }
        }
        if _refuse_reason == "" && _olen >= 7 {
            let _tail7 = out_basename.substring(_olen - 7, _olen)
            if _tail7 == "_darwin" { _refuse_reason = "basename ends in _darwin" }
        }
        if _refuse_reason == "" {
            if out.starts_with("/tmp/") { _refuse_reason = "output under /tmp (panic trigger path)" }
            if out.starts_with("/private/tmp/") { _refuse_reason = "output under /private/tmp (panic trigger path)" }
        }
        if _refuse_reason == "" {
            let _gr_refuse = exec("grep -c -E '^@(refuse|heavy)' '" + src + "' 2>/dev/null | tr -d ' \\n'")
            if _gr_refuse != "" && _gr_refuse != "0" {
                _refuse_reason = "source has @refuse or @heavy annotation"
            }
        }
        if _refuse_reason != "" {
            println("error: hexa build REFUSED on Darwin")
            println("  src     : " + src)
            println("  out     : " + out)
            println("  reason  : " + _refuse_reason)
            println("  cause   : 2026-04-20 03:33 Mac kernel panic (train_alm_lora_mac swap exhaustion)")
            println("  fix     : ssh ubu 'cd ~/Dev/anima && hexa build " + src + " -o " + out + "'")
            println("  bypass  : HEXA_MAC_BUILD_OK=1 (CI dry-run, non-heavy only)")
            exit(1)
        }
    }
    let v2 = resolve_or_bootstrap_hexat()
    if len(v2) == 0 {
        die_no_hexat()
    }
    println("=== Building " + src + " -> " + out + " ===")
    // #12 (wilson-needs-hexa-build-out-of-tree): mirror cmd_run's flatten
    //   step — use self/module_loader.hexa (the canonical module loader
    //   `hexa run` already drives via aot_build_slot) instead of the
    //   legacy tool/flatten_imports.hexa. The legacy tool only walked
    //   top-level `use` directives and silently dropped transitive
    //   imports across stdlib + self/ trees; module_loader handles the
    //   full graph (self/stdlib/* + project-relative paths) and fails
    //   loud on missing modules (exit 2 + FATAL marker), so out-of-tree
    //   multi-module builds (wilson) get the same flatten as `hexa run`.
    //
    //   Use-vs-import probe is native read_file + scan (no /bin/sh fork)
    //   so the no-import fast path matches cmd_run's rt 33 behavior.
    let __inst = install_dir_from_argv0()
    let mut __actual_src = src
    let __src_probe = read_file(src)
    let __has_use_dir = __src_probe.contains("\nuse \"") || __src_probe.starts_with("use \"")
    let __has_imp_dir = __src_probe.contains("\nimport \"") || __src_probe.starts_with("import \"")
    // round-4 (pub-use re-export loader-trigger gate): `pub use "…"` /
    // `pub import "…"` are import directives, but the probe above only
    // matches bare `use`/`import`. Without this third class the flatten step
    // was bypassed and the re-exported inner module never loaded (clang then
    // failed on the undefined re-exported symbol). Same shape as the
    // from-directive trigger fix.
    let __has_pubuse_dir = __src_probe.contains("\npub use \"") || __src_probe.starts_with("pub use \"") || __src_probe.contains("\npub import \"") || __src_probe.starts_with("pub import \"")
    // Python-style `from "X" import a, b` is the third loader-triggering
    // directive. Without this third probe a file whose ONLY directives are
    // `from "…"` bypassed the module_loader entirely — `from` then reached
    // C codegen and clang-failed.
    let __has_from_dir = __src_probe.contains("\nfrom \"") || __src_probe.starts_with("from \"")
    if __has_use_dir || __has_imp_dir || __has_from_dir || __has_pubuse_dir {
        // R7 gate #4 / Cycle C: the COMPILED module_loader binary does
        // interp-free flatten. The interpreter is retired (R7 closed) —
        // there is no interp + module_loader.hexa fallback; an absent
        // compiled binary is a broken install.
        let __ml_compiled = resolve_module_loader_compiled()
        if len(__ml_compiled) > 0 {
            let __expanded = runtime_tmpname("hexa_build_expanded") + ".hexa"
            // orpheus O-002 / F-013: pass install dir to module_loader (see
            // module_loader_env_prefix) so stdlib/* resolves env-free.
            let __preproc = module_loader_env_prefix() + "'" + __ml_compiled + "' '" + src + "' '" + __expanded + "' 2>&1"
            println("  [flat] module_loader → " + __expanded)
            let __pair = exec_with_status(__preproc)
            let __pout = __pair[0]
            let __prc = __pair[1]
            if file_exists(__expanded) {
                __actual_src = __expanded
            } else {
                if __prc == 2 && __pout.contains("[module_loader] FATAL") {
                    // Loader fail-loud: re-emit captured stderr (merged via
                    // 2>&1) on parent stderr and exit(2). Same contract as
                    // cmd_run — CI gates rely on rc=2 for ghost imports.
                    eprint(__pout)
                    exit(2)
                }
                println("  [flat] warn: module_loader preprocess failed — falling back to raw src")
                if len(__pout) > 0 { println("    " + __pout) }
            }
        } else {
            println("  [flat] warn: compiled module_loader not found — falling back to raw src")
        }
    }
    // ─── S5 native-codegen backend selector ────────────────────────────
    // HEXA_BACKEND=native → after the flatten step above, dispatch CODEGEN
    // to the native compiler (aprime_cc) instead of the hexat transpiler.
    // ADDITIVE + env-gated: HEXA_BACKEND unset or =c is the default and runs
    // the C path below COMPLETELY UNCHANGED.
    //
    // Pipeline (native): aprime_cc --emit=asm → `<stem>.s`, then clang
    // assembles the `.s` and links it against self/runtime.c (2nd TU) — the
    // SAME final-link recipe the C path already uses. We deliberately do NOT
    // use aprime_cc's own `--emit=exec`: as of the current build its built-in
    // `ld` invocation links only the user `.o` (no runtime.o, no crt), so any
    // program touching a runtime builtin — even `exit(6*7)`, which lowers to
    // `_hexa_exit`/`_hexa_mul`/`_hexa_set_args` — fails `ld` with "symbol(s)
    // not found". Self-sufficient `--emit=exec` linking is an S1-S4 native-
    // linker-integration item; until it lands, --emit=asm + clang link is the
    // proven recipe (it is exactly what tool/build_aprime.sh stage-5 does).
    //
    // HONEST SCOPE (S5): this wires the dispatch and smoke-verifies it on a
    // trivial program. Full-corpus correctness of the native backend is
    // gated on S1-S4 (codegen perf + self-host fixpoint), still in progress.
    // The native path stays opt-in until then.
    let __backend = env("HEXA_BACKEND")
    if __backend == "native" {
        let __ncc = resolve_native_cc()
        if len(__ncc) == 0 {
            die_no_native_cc()
        }
        // --c-only has no meaning for the native path (aprime_cc emits asm,
        // not C) — refuse rather than silently ignore.
        if c_only == "1" {
            println("error: --c-only is unsupported with HEXA_BACKEND=native")
            println("       the native compiler emits assembly, not C")
            exit(1)
        }
        if len(target) > 0 {
            println("error: --target is unsupported with HEXA_BACKEND=native")
            println("       cross-compilation runs only on the C (clang/zig) path")
            exit(1)
        }
        // RFC 070 G7-A.native gate-drop (2026-05-20 — sub-cycle K2 of the
        // K1 deferred trio). The native MIR→LIR→asm codegen now emits PIC
        // GOT-load sequences in `--shared` mode (D1 arm64 `8fdb29e2` + D2
        // x86_64 `b62809f8`); the entry-fn signatures accept
        // `CodegenOptions` (C1 `06bc2ea4`); the iface struct + RELOC_*
        // constants live in `compiler/ir/lir.hexa` (iface `886977c4` —
        // worktree pick `cc5568d1`). The aprime_cc driver now forwards
        // `--shared` from CLI bopts[4] through to
        // `codegen_options_default()` overlay (Step K2.2 below in
        // `compiler/main.hexa`). What stays out of scope: hidden visibility
        // directives (`.hidden` / `.private_extern`) — measured by the
        // F-A2 falsifier in Step K2.5.
        // runtime.c resolver — same chain the C path uses below
        // ($HEXA_LANG/self > <install>/self > ./self).
        let __nenvroot = env("HEXA_LANG")
        let mut __nself = __inst + "/self"
        if len(__nenvroot) > 0 && file_exists(__nenvroot + "/self/runtime.c") {
            __nself = __nenvroot + "/self"
        } else if !file_exists(__nself + "/runtime.c") {
            if file_exists("./self/runtime.c") { __nself = "./self" }
        }
        let __nrtc = __nself + "/runtime.c"
        // Stage 1: aprime_cc --emit=asm → `<stem>.s`.
        // EXACT arg shape (confirmed against compiler/main.hexa's
        // _normalize_argv() ~L73 + flag parser ~L355-419, and the canonical
        // standalone invocation in tool/build_aprime.sh stage-5 smoke L132):
        //
        //   aprime_cc <runner>.hexa --emit=asm -o OUT.s SOURCE.hexa
        //
        // The leading `<runner>.hexa` token is REQUIRED: when aprime_cc runs
        // as a standalone Mach-O, _normalize_argv() scans argv for the first
        // arg ending in `.hexa` and treats everything up to+including it as a
        // `hexa run compiler/main.hexa …` runner prefix. Without a leading
        // `.hexa` placeholder it would consume the user's real source as the
        // prefix and drop every flag → "missing SOURCE.hexa". The placeholder
        // path need not exist; build_aprime.sh passes the literal `_drv.hexa`.
        let _nmk = exec("mkdir -p build/artifacts 2>/dev/null")
        let __nstem = basename_stem(out)
        let __nasm = "build/artifacts/" + __nstem + ".s"
        // K2.2 — `--shared` flag pass-through to aprime_cc. When set,
        // the compiler driver overlays `codegen_options_default()` with
        // `opts.shared = 1`, gating the GOT-load emit-body branches in
        // both arm64 + x86_64 codegen back-ends.
        let mut __nshared_flag = ""
        if shared == "1" { __nshared_flag = " --shared" }
        // HEXA_BACKEND flip · chunk A step 1 — enable the inline `hexa_int`
        // repr-pack on the native-backend path. aprime_cc's arm64 codegen
        // reads HEXA_INLINE_INT_BOX=1 and emits the 2-instruction x0:x1
        // repr-pack (mov x1,x0 ; movz x0,#0) instead of `bl _hexa_int`,
        // removing one runtime.c dependency. OPT-IN to this path only —
        // the default `--emit=asm` (build_aprime.sh fixpoint smoke etc.)
        // sees no env var and emits the legacy `bl hexa_int` byte-for-byte.
        let __ncmd = "HEXA_INLINE_INT_BOX=1 '" + __ncc + "' _drv.hexa --emit=asm" + __nshared_flag + " -o '" + __nasm + "' '" + __actual_src + "' 2>&1"
        println("  [native 1/2] " + __ncmd)
        let __nr = exec(__ncmd)
        if len(__nr) > 0 { println("    " + __nr) }
        let __nasm_chk = exec("test -f '" + __nasm + "' && printf yes || printf no")
        if __nasm_chk != "yes" {
            println("error: native codegen failed — asm not produced: " + __nasm)
            exit(1)
        }
        // Stage 2: clang assembles `.s` + links runtime.c → `<out>.tmp.<PID>`.
        // atomic rename mirrors the C path's bt 37 (concurrent same-out safe).
        // K2.3 — `--shared` adds `-fPIC -shared` to clang link (mirrors the
        // C-path's `_shared_cflags` block ~L2224). Output is a loadable
        // .so/.dylib (0644), not an executable (0755).
        let mut __nshared_link = ""
        if shared == "1" { __nshared_link = "-fPIC -shared " }
        let __ntmp = exec("printf '%s.tmp.%s' '" + out + "' \"$$\"")
        let __nlink = "clang -O2 " + __nshared_link + os_clang_cflags() + "-Wno-trigraphs -fbracket-depth=4096 -I '" + __nself + "' '" + __nasm + "' '" + __nrtc + "' -o '" + __ntmp + "'" + os_clang_ldflags() + " 2>&1"
        println("  [native 2/2] " + __nlink)
        let __nr2 = exec(__nlink)
        if len(__nr2) > 0 { println("    " + __nr2) }
        // K2.4 — shared output is 0644 not 0755, so `test -x` fails for
        // the .so/.dylib path. Fall back to `test -e` (existence) in
        // shared mode (mirrors C-path L2264).
        let mut __ntmp_test = "-x"
        if shared == "1" { __ntmp_test = "-e" }
        let __ntmp_chk = exec("test " + __ntmp_test + " '" + __ntmp + "' && printf yes || printf no")
        if __ntmp_chk != "yes" {
            println("error: native link failed — binary not produced: " + __ntmp)
            exit(1)
        }
        codesign_if_macos(__ntmp)
        let __nmv = exec("mv -f '" + __ntmp + "' '" + out + "' 2>&1")
        if len(__nmv) > 0 { println("    mv: " + __nmv) }
        let mut __nout_test = "-x"
        if shared == "1" { __nout_test = "-e" }
        let __nout_chk = exec("test " + __nout_test + " '" + out + "' && printf yes || printf no")
        if __nout_chk != "yes" {
            println("error: build failed — output binary missing: " + out)
            exit(1)
        }
        if shared == "1" {
            println("OK: built " + out + " (native backend, shared library — RFC 070 G7-A K2 gate-drop)")
        } else {
            println("OK: built " + out + " (native backend)")
        }
        return ""
    }
    let stem = basename_stem(out)
    let c_file = "build/artifacts/" + stem + ".c"
    // buglist#6 phase [1/2]: transpile → .c 산출물 존재 확인 필수. 과거에는
    //   trans 출력만 캡처하고 .c 미생성 여부를 검사하지 않아, clang 이 존재
    //   하지 않는 .c 를 컴파일하려 → mv 실패 → 그래도 "OK: built" 출력하는
    //   false-positive exit 0 회귀가 있었다. 이제 .c existence 를 명시 체크.
    // 산출물 디렉토리 선제 생성 (없으면 hexat 가 stderr 로 실패).
    let _mk_art = exec("mkdir -p build/artifacts 2>/dev/null")
    // hexat (transpiler) also runs into the 768 MB default RSS cap for
    // large downstream programs (wilson v0.5.x peaks ~900 MB during the
    // AST → C codegen pass). Same propagation pattern as module_loader.
    let mut v2_env = ""
    if env_var("HEXA_MEM_UNLIMITED") != "1" && len(env_var("HEXA_MEM_CAP_MB")) == 0 {
        v2_env = "HEXA_MEM_CAP_MB=4096 "
    }
    let trans = v2_env + v2 + " " + __actual_src + " " + c_file + " 2>&1"
    println("  [1/2] " + trans)
    let r1 = exec(trans)
    if len(r1) > 0 { println("    " + r1) }
    // 파싱 실패는 hexat 가 stdout 에 "Parse error" 로 찍고도 exit 0 인
    // 특성이 있어(cmd_parse 주석 참고), 출력 문자열 + .c 파일 존재로 2중 판정.
    // r1 을 셸 명령에 보간하면 출력 안의 백틱 / `$()` / `$VAR` 가 재평가되어
    // 가짜 `sh:` 진단이 새어 나온다 — `.contains` 로 in-process 판정.
    let has_perr = r1.contains("Parse error")
    if has_perr {
        println("error: transpile failed (parse error) — " + src)
        exit(1)
    }
    let c_exists = exec("test -f '" + c_file + "' && printf yes || printf no")
    if c_exists != "yes" {
        println("error: transpile failed — C file not produced: " + c_file)
        exit(1)
    }
    // RFC 070 G7-A: mutual-exclusion guards. --shared is a CLANG step
    // pass-through; --c-only skips clang entirely, --target uses zig cc
    // (per-triple PIC has not been validated this sub-cycle).
    if shared == "1" && c_only == "1" {
        println("error: --shared and --c-only are mutually exclusive")
        println("       --shared needs the clang link step; --c-only skips it")
        exit(1)
    }
    if shared == "1" && len(target) > 0 {
        println("error: --shared is not yet supported with --target=" + target)
        println("       cross-target PIC requires per-triple validation")
        println("       (G7-A.cross sub-cycle); use the native host clang path")
        exit(1)
    }
    // --c-only: transpile only. `out` 는 .c 파일 경로로 해석, clang / codesign /
    //   atomic rename 모두 skip. airgenome 등 외부 빌드 시스템이 직접 clang 을
    //   돌릴 때 유용. flatten_imports 경로는 동일하게 통과하므로 use graph 는
    //   이미 resolve 된 단일 .c 산출.
    if c_only == "1" {
        let cp_out = exec("cp '" + c_file + "' '" + out + "' 2>&1")
        if len(cp_out) > 0 { println("    cp: " + cp_out) }
        let out_ok = exec("test -f '" + out + "' && printf yes || printf no")
        if out_ok != "yes" {
            println("error: --c-only copy failed: " + out)
            exit(1)
        }
        println("OK: transpiled " + out + " (C source, no link)")
        return ""
    }
    // Stage B: clang → `<out>.tmp.<PID>` (동일 디렉토리 → 동일 FS → rename atomic)
    let tmp = exec("printf '%s.tmp.%s' '" + out + "' \"$$\"")
    // bt 54: int→ptr / implicit-fn 근본 해소 — 플래그 제거.
    // buglist#5: -I self 도 install_dir 절대경로로 — cwd 무관 runtime.c 탐색.
    // bt 74+ (20260415): -fbracket-depth=4096 for long `"a"+"b"+...` concat
    //   chains. Root cause: hexa codegen lowers left-assoc BinOp.Plus into
    //   nested hexa_add(hexa_add(...)) calls. train_alm_14b.hexa has a 500+
    //   segment embedded Python runner which exceeds clang's default 256.
    let _strict = strict_fp_cflags(c_file)
    // ROADMAP #20: native (target=="") uses host clang; cross-target uses
    // `zig cc -target <triple>` which bundles musl/glibc/macOS SDKs in the
    // ~70MB zig install. zig is detected via `command -v zig` and the build
    // fails fast with an install hint if missing.
    // #12 wilson-needs-hexa-build-out-of-tree: prefer $HEXA_LANG/self over
    //   <argv0-dir>/self for the `#include "runtime.c"` resolver. installed
    //   hexa_real at ~/.hx/bin/ has no ~/.hx/bin/self/ — out-of-tree builds
    //   (wilson) hit `fatal error: 'runtime.c' file not found` otherwise.
    let __envroot = env("HEXA_LANG")
    let mut __self_dir = __inst + "/self"
    if len(__envroot) > 0 && file_exists(__envroot + "/self/runtime.c") {
        __self_dir = __envroot + "/self"
    } else if !file_exists(__self_dir + "/runtime.c") {
        if file_exists("./self/runtime.c") { __self_dir = "./self" }
    }
    // PHASE 1.3.B (2026-05-15) follow-up: codegen now emits `#include "runtime.h"`
    // which exposes signatures only. The bodies live in runtime.c (which until
    // recently was directly #include'd from user.c, so this never came up).
    // To compile-and-link in one shot we add runtime.c to the clang invocation
    // as a second TU. Long-term (path 2 of the patch file), ship a precompiled
    // runtime.o and link against it; for now compile-from-source.
    let __runtime_c = __self_dir + "/runtime.c"
    // RFC 070 G7-A: --shared pass-through. `-fPIC -shared` instructs
    // clang to emit a position-independent shared library (ELF ET_DYN on
    // Linux, Mach-O MH_DYLIB on macOS). Falsifier F-A1 (PIC re-load at
    // non-default base) and F-A2 (single-exported-symbol nm) are the
    // next measured sub-cycle and are NOT executed here.
    let mut _shared_cflags = ""
    if shared == "1" { _shared_cflags = "-fPIC -shared " }
    let mut compile = ""
    // runtime.c content-hash object cache. runtime.c — with its ~18
    // #include'd TUs (runtime_core.c, runtime_hi_gen.c, native/*.c …) — is
    // a large, stable translation unit that was re-`clang -O2`'d on EVERY
    // `hexa build` / `hexa run`: a CPU storm under sidecar-hook fan-out
    // (timestamp-keyed cache never hit). Precompile it once to a
    // content-hash-keyed `runtime.<sha>.o` under ~/.hexa-cache and link the
    // object. The key hashes the whole runtime C-source set, so any runtime
    // edit transparently yields a fresh object; stale objects are never
    // hit. Skipped for --shared (needs -fPIC) and cross-target (zig emits
    // target-specific objects). Hash failure / no $HOME → source fallback.
    let mut _rt_obj = ""
    if shared != "1" && len(target) == 0 && len(env("HOME")) > 0 {
        let _rt_sha = exec("cat '" + __self_dir + "'/runtime*.c '" + __self_dir + "'/runtime*.h '" + __self_dir + "'/native/*.c '" + __self_dir + "'/native/*.h 2>/dev/null | shasum -a 1 2>/dev/null | cut -d' ' -f1").trim()
        if len(_rt_sha) > 0 {
            let _rt_cache = env("HOME") + "/.hexa-cache"
            let _rt_cand = _rt_cache + "/runtime." + _rt_sha + ".o"
            if !file_exists(_rt_cand) {
                exec("mkdir -p '" + _rt_cache + "' 2>/dev/null")
                // GO M1: lazy GC probe (only triggers on cache miss to
                // keep the hot `runtime.<sha>.o` hit path zero-cost).
                _hexa_cache_gc(_rt_cache, _hexa_cache_cap_mb(), _hexa_cache_ttl_days())
                let _rt_tmp = _rt_cand + ".tmp." + to_string(mono_ns())
                let _rt_cc = "clang -O2 " + os_clang_cflags() + strict_fp_cflags(__runtime_c) + "-Wno-trigraphs -fbracket-depth=4096 -I '" + __self_dir + "' -c '" + __runtime_c + "' -o '" + _rt_tmp + "' 2>&1"
                let _rt_r = exec(_rt_cc)
                if file_exists(_rt_tmp) {
                    exec("mv -f '" + _rt_tmp + "' '" + _rt_cand + "' 2>/dev/null")
                } else if len(_rt_r) > 0 {
                    println("    [runtime.o cache] compile failed — using source: " + _rt_r)
                }
            }
            if file_exists(_rt_cand) { _rt_obj = _rt_cand }
        }
    }
    // Runtime input to the final link: cached object when available, else
    // runtime.c source (first build of a given runtime, or no $HOME).
    let mut _rt_input = "'" + __runtime_c + "'"
    if len(_rt_obj) > 0 { _rt_input = "'" + _rt_obj + "'" }
    if len(target) == 0 {
        compile = "clang -O2 " + _shared_cflags + os_clang_cflags() + _strict + "-Wno-trigraphs -fbracket-depth=4096 -I '" + __self_dir + "' " + c_file + " " + _rt_input + " -o '" + tmp + "'" + os_clang_ldflags() + " 2>&1"
    } else {
        let zt = target_zig_triple(target)
        if len(zt) == 0 {
            println("error: unknown --target value: " + target)
            println("       supported: " + target_supported_list())
            exit(1)
        }
        let has_zig = exec("command -v zig >/dev/null 2>&1 && printf yes || printf no")
        if has_zig != "yes" {
            println("error: zig not found on PATH (required for --target=" + target + ")")
            println("       install: brew install zig   (or download from https://ziglang.org/download/)")
            exit(1)
        }
        let static_f = target_static_flag(target)
        // Linux targets need _GNU_SOURCE + libm; macOS targets do not. Cross
        // overrides host-uname-based os_clang_cflags()/os_clang_ldflags().
        let mut cf_target = ""
        let mut ldf_target = ""
        if target.starts_with("linux-") {
            cf_target = "-D_GNU_SOURCE "
            ldf_target = " -lm"
        }
        compile = "zig cc -O2 -target " + zt + static_f + " " + cf_target + _strict + "-Wno-trigraphs -fbracket-depth=4096 -I '" + __self_dir + "' " + c_file + " '" + __runtime_c + "' -o '" + tmp + "'" + ldf_target + " 2>&1"
    }
    println("  [2/2] " + compile)
    let r2 = _hexa_clang_capped(compile)
    if len(r2) > 0 { println("    " + r2) }
    // buglist#6 phase [2/2]: 컴파일 산출물(tmp) 존재 확인. 실패 시 조기 exit(1)
    // — mv 단계에서 '파일 없음'이 묻혀 false-positive 로 이어지지 않도록.
    // cross-target 산출물은 host 에서 실행 비트만 검사 (-x 는 chmod 만 의미).
    // RFC 070 G7-A: shared libraries (.so / .dylib) ship as 0644 not 0755
    // — clang's -shared output is not chmod +x. Relax to existence check
    // for the --shared path (the F-A1/F-A2 falsifiers will measure the
    // file type via readelf/otool in the next sub-cycle).
    let mut _tmp_test = "-x"
    if shared == "1" { _tmp_test = "-e" }
    let tmp_chk = exec("test " + _tmp_test + " '" + tmp + "' && printf yes || printf no")
    if tmp_chk != "yes" {
        let _cc_label = "clang"
        if len(target) > 0 { _cc_label = "zig cc" }
        println("error: " + _cc_label + " compile failed — binary not produced: " + tmp)
        exit(1)
    }
    // bt 40: codesign tmp (macOS Gatekeeper 호환) — rename 전에 서명.
    //   - native macOS 만 ad-hoc 서명. cross-target 은 host 가 macOS 라도 skip:
    //     Linux ELF 산출물에 codesign 은 의미가 없고, darwin-* cross 는 zig
    //     이 ad-hoc 서명을 이미 부착한다.
    if len(target) == 0 {
        codesign_if_macos(tmp)
    }
    // atomic rename: tmp → out. 실패 시 tmp 보존으로 디버깅 가능.
    let mv = exec("mv -f '" + tmp + "' '" + out + "' 2>&1")
    if len(mv) > 0 { println("    mv: " + mv) }
    // buglist#6: 최종 산출물 re-verify — clang 실패/mv 실패 등 중간 단계가
    // 어떤 이유로든 silent 하게 지나가더라도 여기서 확실히 실패 exit 하도록.
    // RFC 070 G7-A: --shared output is a 0644 .so/.dylib — see _tmp_test
    // note above for the -x → -e relaxation.
    let mut _out_test = "-x"
    if shared == "1" { _out_test = "-e" }
    let out_chk = exec("test " + _out_test + " '" + out + "' && printf yes || printf no")
    if out_chk != "yes" {
        println("error: build failed — output binary missing: " + out)
        exit(1)
    }
    if shared == "1" {
        println("OK: built " + out + " (shared library, RFC 070 G7-A flag-wiring only — F-A1/F-A2 next sub-cycle)")
    } else {
        println("OK: built " + out)
    }
}

fn runtime_tmpdir() {
    let d = "/tmp/.hexa-runtime"
    exec("mkdir -p '" + d + "' 2>/dev/null; find '" + d + "' -maxdepth 1 -type f -mmin +10 -delete 2>/dev/null")
    return d
}

// Collision-free temp path. to_string(clock()) resolves to integer seconds so
// multiple rapid cmd_run invocations within the same second collide on
// stderr_tmp / expanded-source filenames — observed as T34 "uncaught throw
// diag" flake (fix 1472b62d). mono_ns() returns CLOCK_MONOTONIC as int64 ns
// (runtime.c hexa_mono_ns), giving unique values per call without forking
// mktemp. mktemp fallback kept for safety when mono_ns() is somehow
// unavailable (pre-regen interp bootstrap).
fn runtime_tmpname(prefix) {
    let dir = runtime_tmpdir()
    return dir + "/" + prefix + "." + to_string(mono_ns()) + ".tmp"
}

// ── Streaming popen helper for cmd_run ──────────────────────
//
// Background (2026-04-25): cmd_run used `let out = exec(cmd)` which
// popen-reads the entire child stdout into one buffer before parent
// emits anything, breaking sub-200ms event latency for tools like
// hive/tool/subagent_dispatch.hexa that depend on incremental output.
//
// Replacement uses runtime.c's `hexa_exec_stream` (registered as the
// `exec_stream(cmd, on_line)` builtin) which invokes the callback per
// fgets() iteration. Each line retains its trailing `\n`, and the
// runtime sets `setvbuf(stdout, _IOLBF)` so `print(line)` flushes
// per-newline when stdout is piped. End-to-end: child writes a line →
// kernel pipe → parent fgets → on_line callback → printf(%s) → flush.
//
// Sentinel handling: every cmd_run shell command ends
// with `; echo __HEXA_RC=$?` so the FINAL line is always
// `__HEXA_RC=N\n`. We keep a 1-line lookahead buffer:
//   - on each callback: print the previously-buffered line, then
//     buffer the new one (the buffered line cannot be the sentinel
//     because we just received another line after it)
//   - after exec_stream returns: inspect the residual buffered line,
//     parse the sentinel rc if matched (and drop it from output), else
//     flush as ordinary trailing output (no-newline edge case)
//
// Mutable state lives at module scope because hexa-v2 transpiler maps
// `exec_stream(cmd, on_line)` with a top-level fn ident → C function
// pointer. Closure capture across the popen-read boundary is not
// available through this codepath, so the callback writes to module
// globals which the post-call cleanup consumes.
let mut __hexa_run_stream_buf = ""

fn __hexa_run_stream_on_line(s) {
    // Sentinel-aware streaming: forward every non-sentinel-pattern line
    // immediately (preserves sub-fgets streaming), and only buffer lines
    // that LOOK like the trailing __HEXA_RC=N sentinel — those need EOF
    // confirmation before we decide to drop or forward them.
    //
    // Why not buffer-everything-by-one-line? A 1-line lookahead lags
    // every printed line by one child fgets-iteration. For low-rate
    // emitters (pre-sleep alpha/beta then post-sleep gamma), the
    // buffered tail line stays put across the sleep gap, surfacing only
    // after the next emit — which defeats the streaming property.
    //
    // Why no false-positive risk? `__HEXA_RC=` is a deliberately weird
    // prefix the shell wrapper appends as the FINAL line. A child that
    // happens to emit a mid-stream line starting with the same prefix
    // would also be treated as a sentinel by the legacy exec()-split
    // path (it checks `last.starts_with` on whichever line is last in
    // the buffer). Our streaming variant has the SAME guarantee: any
    // earlier `__HEXA_RC=` line gets flushed when a subsequent line
    // arrives, only the truly-last one is consumed as the sentinel.
    let mark = "__HEXA_RC="
    if len(__hexa_run_stream_buf) > 0 {
        // A previously-suspected sentinel got followed by another line
        // — therefore it was NOT the final, so flush it as ordinary
        // output before processing the new line.
        print(__hexa_run_stream_buf)
        __hexa_run_stream_buf = ""
    }
    if s.starts_with(mark) {
        // Buffer for EOF-time sentinel decision in run_stream_with_sentinel.
        __hexa_run_stream_buf = s
    } else {
        // Definitely not a sentinel — forward immediately. printf("%s", s)
        // preserves the trailing \n from fgets, triggering _IOLBF flush
        // when stdout is piped (runtime.c constructor sets _IOLBF).
        print(s)
    }
}

// run_stream_with_sentinel: popen-streams `cmd`, forwards stdout
// line-by-line, extracts and returns the trailing __HEXA_RC=N exit
// code. Used by cmd_run; both must invoke this with
// identical post-conditions (stderr_tmp captured separately, sentinel
// stripped from forwarded output, byte-for-byte streaming parity).
fn run_stream_with_sentinel(cmd) {
    __hexa_run_stream_buf = ""
    let _ = exec_stream(cmd, __hexa_run_stream_on_line)
    let last = __hexa_run_stream_buf
    __hexa_run_stream_buf = ""
    let mark = "__HEXA_RC="
    let mut rc = 0
    if last.starts_with(mark) {
        // Strip trailing \n (fgets retained it) before to_int parse.
        let mut s = last
        let sl = len(s)
        if sl > 0 && s.substring(sl - 1, sl) == "\n" {
            s = s.substring(0, sl - 1)
        }
        rc = to_int(s.substring(len(mark), len(s)))
    } else {
        // No sentinel — surface the trailing partial as ordinary
        // output (matches legacy exec()→split fallback behavior).
        if len(last) > 0 { print(last) }
    }
    return rc
}

// no-hardcode9 (2026-04-28): `--no-sentinel` / HEXA_NO_SENTINEL=1 mode.
//
// Background: cmd_run inject `; echo __HEXA_RC=$?`
// into the shell wrapper so the parent dispatcher can recover the
// child rc from a popen()-captured stdout buffer. The streaming
// variant (run_stream_with_sentinel) strips that trailing line on
// EOF — but the strip is only correct when the child's last stdout
// emit ENDED in `\n`. For children that emit `print("hello")` (no
// trailing newline), fgets concatenates `hello__HEXA_RC=0\n` into a
// SINGLE trailing line; `last.starts_with("__HEXA_RC=")` then fails
// and the sentinel leaks through to the user's stdout — breaking
// `JSON.parse(stdout)` callers (hive `fake-{anima,hexa,pi-rpc}.mjs`
// fixtures spawned from .ts tests).
//
// Two ergonomic opt-outs:
//   * CLI flag:  `hexa run --no-sentinel <script>`
//   * env var:   `HEXA_NO_SENTINEL=1 hexa run <script>`
//
// In no-sentinel mode the wrapper redirects rc to a sidechannel file
// (`; echo $? > <rc_tmp>`) instead of stdout. Stdout stays byte-clean.
// After exec_stream returns we read the rc file, propagate as before.
//
// Backward compatibility: default behavior (no flag, no env) keeps
// the legacy `__HEXA_RC=N` stdout sentinel (callers that already
// strip it — e.g. tool/roadmap_integrate.hexa — see no change).
let mut cmd_run_no_sentinel_mode = false

// Lazily resolved by cmd_run — env var check is per
// invocation so a parent script can scope `HEXA_NO_SENTINEL=1` to a
// single child without restarting the dispatcher.
fn no_sentinel_active() {
    if cmd_run_no_sentinel_mode { return true }
    if env_var("HEXA_NO_SENTINEL") == "1" { return true }
    return false
}

// Streaming forwarder for no-sentinel mode: every fgets() line goes
// straight to stdout — there is no tail-line speculation because the
// child shell does NOT emit any trailing __HEXA_RC sentinel into the
// stream. rc lives in `rc_tmp` (sidechannel file).
fn __hexa_run_stream_passthrough(s) {
    print(s)
}

fn run_stream_no_sentinel(cmd, rc_tmp) {
    let _ = exec_stream(cmd, __hexa_run_stream_passthrough)
    let mut rc = 0
    if file_exists(rc_tmp) {
        let raw = read_file(rc_tmp)
        let mut s = raw
        let sl = len(s)
        if sl > 0 && s.substring(sl - 1, sl) == "\n" {
            s = s.substring(0, sl - 1)
        }
        if len(s) > 0 { rc = to_int(s) }
        exec("rm -f '" + rc_tmp + "'")
    }
    return rc
}

fn shell_quote(s) {
    // POSIX: '...'...' 으로 wrap, 내부 ' 만 '\'' 로 escape.
    // 모든 다른 문자 (", $, \, !, newline, ...) 는 single-quote 안에서 리터럴.
    return "'" + s.replace("'", "'\\''") + "'"
}

fn join_shell_args(argv) {
    let mut out = ""
    let mut i = 0
    while i < len(argv) {
        out = out + " " + shell_quote(argv[i])
        i = i + 1
    }
    return out
}

// ── ~/.hexa-cache automatic GC (GO M1) ─────────────────────────────
//
// `~/.hexa-cache/hexa_run.<sha>_<ver>-dispatch` accumulates one binary per
// (source-hash, version) pair on every `hexa run` / `hexa build` /
// `hexa batch`. Without GC the directory grows unbounded (the legacy
// `cmd_run` timestamp-keyed convention emitted unique paths per ns and
// could fill GB in a fan-out storm). `_hexa_cache_gc` is a lazy probe
// invoked at the top of each cache-using entry point.
//
// Policy:
//   - cap_mb  = HEXA_CACHE_CAP_MB  (default 2048, ie 2 GiB)
//   - ttl_days = HEXA_CACHE_TTL_DAYS (default 30)
//   - Probe is throttled by a `.gc_last` sentinel file (touched after
//     each run); skipped if newer than 60s (sub-1ms `test -nt` check).
//   - Stale `*.tmp.<ns>` orphans (>60 min, from crashed builds) are
//     always swept.
//   - TTL: `find -mtime +N -delete` for `hexa_run.*` entries.
//   - LRU: when total `du -sk` exceeds cap, delete oldest-first
//     (`ls -tr` mtime sort) until under cap.
//   - All errors swallowed (`2>/dev/null`): GC is best-effort cleanup,
//     never an entry-point failure mode.
fn _hexa_cache_gc(cache_dir, cap_mb, ttl_days) {
    // Lazy probe throttle. Skip if sentinel was touched < 60s ago.
    // `find -newer` is the POSIX-friendly mtime comparator.
    let _sent = cache_dir + "/.gc_last"
    let _skip = exec("[ -f " + shq(_sent) + " ] && find " + shq(_sent) + " -mmin -1 2>/dev/null | grep -c . || printf 0").trim()
    if _skip == "1" { return }
    // Tmp orphan sweep (>60 min). Crashed builds leave `<key>.tmp.<ns>`.
    let _tmp_cl = exec("find " + shq(cache_dir) + " -maxdepth 1 -name '*.tmp.*' -mmin +60 -delete 2>/dev/null")
    // TTL eviction.
    if ttl_days > 0 {
        let _ttl_cl = exec("find " + shq(cache_dir) + " -maxdepth 1 -name 'hexa_run.*' -mtime +" + to_string(ttl_days) + " -delete 2>/dev/null")
    }
    // LRU cap eviction. `du -sk` reports KiB; cap_mb * 1024 = cap_kb.
    if cap_mb > 0 {
        let _cap_kb = cap_mb * 1024
        let _used_s = exec("du -sk " + shq(cache_dir) + " 2>/dev/null | awk '{print $1}'").trim()
        let _used_kb = parse_int_str(_used_s)
        if _used_kb > _cap_kb {
            // Delete oldest-first until under cap. `ls -tr` = mtime
            // ascending (oldest first). Loop in shell to honor the
            // moving target (size shrinks per delete).
            let _lru = "set -e; CAP=" + to_string(_cap_kb) + "; DIR=" + shq(cache_dir) + ";"
                + " for f in $(ls -1tr \"$DIR\" 2>/dev/null | grep '^hexa_run\\.'); do"
                + "   U=$(du -sk \"$DIR\" 2>/dev/null | awk '{print $1}');"
                + "   [ \"$U\" -le \"$CAP\" ] && break;"
                + "   rm -f \"$DIR/$f\" 2>/dev/null;"
                + " done"
            let _lru_r = exec(_lru + " 2>/dev/null")
        }
    }
    // Refresh sentinel (best-effort).
    let _touch = exec("touch " + shq(_sent) + " 2>/dev/null")
}

// Cache-policy resolver: reads env overrides with defaults.
// Returns the cap in MB (env `HEXA_CACHE_CAP_MB`, default 2048).
fn _hexa_cache_cap_mb() {
    let _e = env_var("HEXA_CACHE_CAP_MB")
    if len(_e) == 0 { return 2048 }
    let _v = parse_int_str(_e)
    if _v <= 0 { return 2048 }
    return _v
}

// Returns the TTL in days (env `HEXA_CACHE_TTL_DAYS`, default 30).
fn _hexa_cache_ttl_days() {
    let _e = env_var("HEXA_CACHE_TTL_DAYS")
    if len(_e) == 0 { return 30 }
    let _v = parse_int_str(_e)
    if _v <= 0 { return 30 }
    return _v
}

// GO M2 — release/precompile/ lookup (cold-cache fork-storm mitigation,
// internal axis; pool-route 0.6.5/0.6.6 handle the external axis).
// Probes release/precompile/hexa_run.<key> at 2 anchors (in order):
//   1) $HEXA_LANG/release/precompile/   (dev / repo root)
//   2) install_dir/release/precompile/  (release-tarball install)
// Returns the first existing path, or "" on miss. Caller falls back to
// the ~/.hexa-cache compile-then-cache path on miss. Key MUST match
// tool/build_precompile.hexa (sha256(source).substring(0,16) + "_" + version_str()).
fn _precompile_lookup(key) {
    let fname = "/release/precompile/hexa_run." + key
    let h = env_var("HEXA_LANG")
    if len(h) > 0 {
        let p = h + fname
        if file_exists(p) { return p }
    }
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        let p = inst + fname
        if file_exists(p) { return p }
    }
    return ""
}

// GO M12 (RFC 093 R3) — daemon autospawn probe. Opt-in via
// `HEXA_DAEMON_AUTOSPAWN=1` (RFC §4.3 — default 0, zero behavior change).
// 3-tier fallback order in cmd_run_user_direct:
//   1. precompile lookup (M2, release-shipped binary)   — _precompile_lookup
//   2. daemon (R3, in-mem warm cache, no fork)          — THIS helper
//   3. fork-mode (`hexa build`, current default)        — caller's fall-through
//
// Returns a ready-to-exec binary path on a daemon HIT/BUILT, or "" to signal
// the caller should continue to fork-mode (F-DAEMON-R3-3 crash fallback). All
// failure modes (opt-out, socket missing + spawn fail, ERR reply, connect
// refused) degrade silently to "" — NEVER abort. The daemon's COMPILE reply
// is a plain `<TAG> <path>` line; binary path has no NUL so it round-trips
// over the R2 newline-text wire intact (net_read_raw deferred — occam g0).
fn _daemon_autospawn_path(file) {
    if env_var("HEXA_DAEMON_AUTOSPAWN") != "1" { return "" }
    let trace = env_var("HEXA_DAEMON_TRACE") == "1"
    let sock = _daemon_default_socket()
    // Probe → spawn-if-missing → 1 retry (RFC §4.3 client flow).
    if !_daemon_socket_exists(sock) {
        // Autospawn a detached daemon with a short idle TTL so it self-reaps
        // (default 600s = 10 min — long enough to amortize a hot loop, short
        // enough to not leak across an idle session).
        let mut ttl = env_var("HEXA_DAEMON_IDLE_TTL")
        if len(ttl) == 0 { ttl = "600" }
        let log_path = sock + ".log"
        let cmd = "nohup " + shq(argv0_or_hexa()) + " daemon start --socket " + shq(sock) + " --idle-ttl " + shq(ttl) + " > " + shq(log_path) + " 2>&1 &"
        let _r = exec(cmd)
        // Wait up to ~3s for the socket to appear (bind + listen).
        let mut waited = 0
        while waited < 3000 {
            if _daemon_socket_exists(sock) { break }
            sleep_ms(50)
            waited = waited + 50
        }
        if !_daemon_socket_exists(sock) {
            if trace { eprintln("[daemon] autospawn failed (socket never appeared) — fork fallback") }
            return ""
        }
        if trace { eprintln("[daemon] autospawned (socket=" + sock + ")") }
    }
    let resp = _daemon_send_line(sock, "COMPILE " + file)
    let rn = len(resp)
    if rn == 0 {
        // Connect/read failed (daemon died between probe and send — crash
        // window). Degrade to fork-mode.
        if trace { eprintln("[daemon] no reply (crash window?) — fork fallback") }
        return ""
    }
    // Parse `<TAG> <path>`: accept HIT/BUILT, reject ERR.
    let mut sp = rn
    let mut i = 0
    while i < rn {
        if resp.substring(i, i + 1) == " " { sp = i; break }
        i = i + 1
    }
    let tag = resp.substring(0, sp)
    if (tag == "HIT" || tag == "BUILT") && sp < rn {
        let bin = resp.substring(sp + 1, rn)
        if file_exists(bin) {
            if trace { eprintln("[daemon] " + tag + " " + bin) }
            return bin
        }
        if trace { eprintln("[daemon] " + tag + " but binary missing (" + bin + ") — fork fallback") }
        return ""
    }
    if trace { eprintln("[daemon] non-HIT reply '" + resp + "' — fork fallback") }
    return ""
}

// `hexa run <file>` and the `hexa://run` URL action are user-direct
// invocations; cmd_run_user_direct compiles then executes (the
// tree-walking interpreter is retired — g_interp_deprecated). The
// absorbed-verb sites (lsp / test / check / qrng / batch / …) call
// cmd_run directly.
fn cmd_run_user_direct(file, extra_args) {
    // `hexa run <file>` COMPILES then executes — the tree-walking
    // interpreter is retired (g_interp_deprecated). compile OK → exec the
    // produced binary and propagate its exit code; build fails → report
    // the compile error and exit non-zero.
    // Resolve this hexa binary to self-invoke `hexa build`.
    let __inst_r = install_dir_from_argv0()
    let mut hexa_bin = ""
    if len(__inst_r) > 0 {
        let cand = __inst_r + "/hexa"
        if file_exists(cand) { hexa_bin = cand }
    }
    if len(hexa_bin) == 0 { hexa_bin = av[0] }
    // Compiled output under $HOME/.hexa-cache (NOT /tmp — the Darwin
    // build panic-guard refuses /tmp|/private/tmp outputs; this is the
    // gitignored AOT-cache convention, persistent + guard-safe).
    let mut _cache_dir = env_var("HOME") + "/.hexa-cache"
    if len(env_var("HOME")) == 0 { _cache_dir = "./.hexa-cache" }
    let _mk = exec("mkdir -p " + shq(_cache_dir) + " 2>/dev/null")
    // GO M1: lazy GC probe (cap + TTL + tmp orphan sweep).
    _hexa_cache_gc(_cache_dir, _hexa_cache_cap_mb(), _hexa_cache_ttl_days())
    // Content-addressed cache key (inbox patch
    // hexa-run-clang-fork-cache-miss-per-invocation): sha256(source)+version.
    // Identical source → identical binary → cache hit skips clang fork.
    // When hexa is rebuilt without bumping version_str() the cache must
    // be wiped manually (`rm ~/.hexa-cache/hexa_run.*`); regeneratable.
    let _src_hash = sha256_file(file)
    let _key = _src_hash.substring(0, 16) + "_" + version_str()
    let mut tmpbin = _cache_dir + "/hexa_run." + _key
    let mut bout = ""
    let mut brc = 0
    // GO M2 — release/precompile/ probe (shipped binaries skip clang fork).
    let _pre = _precompile_lookup(_key)
    if len(_pre) > 0 {
        tmpbin = _pre
        if env_var("HEXA_PRECOMPILE_TRACE") == "1" { eprintln("[precompile] HIT " + _pre) }
    }
    // GO M12 (RFC 093 R3) — daemon autospawn tier (between precompile and
    // fork-mode). Opt-in (HEXA_DAEMON_AUTOSPAWN=1); "" → fork fallback.
    if !file_exists(tmpbin) {
        let _dbin = _daemon_autospawn_path(file)
        if len(_dbin) > 0 { tmpbin = _dbin }
    }
    if !file_exists(tmpbin) {
        let _tmp_inflight = tmpbin + ".tmp." + to_string(mono_ns())
        let bcmd = shq(hexa_bin) + " build " + shq(file) + " -o " + shq(_tmp_inflight) + " 2>&1; echo \"__HEXA_BRC__=$?\""
        bout = exec(bcmd)
        let bmark = "__HEXA_BRC__="
        let bml = len(bmark)
        let mut bmi = -1
        let mut bsj = len(bout) - bml
        while bsj >= 0 {
            if bout.substring(bsj, bsj + bml) == bmark { bmi = bsj; bsj = -1 } else { bsj = bsj - 1 }
        }
        brc = 1
        if bmi >= 0 {
            let mut rs = bout.substring(bmi + bml, len(bout))
            let rsl = len(rs)
            if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" { rs = rs.substring(0, rsl - 1) }
            brc = parse_int_str(rs)
        }
        if brc == 0 && file_exists(_tmp_inflight) {
            // Atomic-rename into place. Concurrent rebuilds race but
            // produce byte-identical binaries (same source), so the
            // loser's overwrite is benign.
            let _rn = exec("mv -f " + shq(_tmp_inflight) + " " + shq(tmpbin) + " 2>/dev/null")
        } else {
            let _cl = exec("rm -f " + shq(_tmp_inflight) + " 2>/dev/null")
        }
    }
    // Cold-cache race fix (2026-05-25): 검증 조건을 `brc == 0 && file_exists(tmpbin)`
    // → `file_exists(tmpbin)` 로 완화. tmpbin은 atomic rename(`mv -f`)로만 도달하므로
    // 존재한다면 fully-built valid binary. 자기 build 실패(brc != 0)와 peer가 만든
    // byte-identical binary는 직교 — race loser가 spurious "compile error" 보고 방지.
    // (line 2779 의 "loser's overwrite is benign" 의도 완성.)
    if file_exists(tmpbin) {
        let cli_q = shq(tmpbin)
        let mut cmd = cli_q
        let mut ai = 0
        while ai < len(extra_args) {
            let q = shq(extra_args[ai])
            cmd = cmd + " " + q
            ai = ai + 1
        }
        let out = exec(cmd + " 2>&1; echo \"__HEXA_SHIM_RC__=$?\"")
        let marker = "__HEXA_SHIM_RC__="
        let mlen = len(marker)
        let mut midx = -1
        let mut sj = len(out) - mlen
        while sj >= 0 {
            if out.substring(sj, sj + mlen) == marker { midx = sj; sj = -1 } else { sj = sj - 1 }
        }
        if midx >= 0 {
            let body = out.substring(0, midx)
            let rc_str = out.substring(midx + mlen, len(out))
            print(body)
            let mut rs2 = rc_str
            let rsl2 = len(rs2)
            if rsl2 > 0 && rs2.substring(rsl2 - 1, rsl2) == "\n" { rs2 = rs2.substring(0, rsl2 - 1) }
            let rc = parse_int_str(rs2)
            exit(rc)
        } else {
            print(out)
            exit(0)
        }
    }
    eprintln("error: `hexa build " + file + "` failed (compile error).")
    if env_var("HEXA_INTERP_QUIET") != "1" { eprintln(bout) }
    let mut _erc = brc
    if _erc == 0 { _erc = 1 }
    exit(_erc)
}

fn cmd_run(file, extra_args) {
    // The tree-walking interpreter is RETIRED (g_interp_deprecated).
    // `cmd_run` COMPILES then executes: `hexa build <file>` (which flattens
    // use/import via module_loader) → run the produced binary. The historical
    // contract is preserved — sets cmd_run_last_rc, calls auto_marker_write,
    // honors cmd_run_no_exit_mode (the batch driver), exits on non-zero rc
    // otherwise. Internal absorbed-verb sites call cmd_run directly.
    let __inst_r = install_dir_from_argv0()
    let mut hexa_bin = ""
    if len(__inst_r) > 0 {
        let cand = __inst_r + "/hexa"
        if file_exists(cand) { hexa_bin = cand }
    }
    if len(hexa_bin) == 0 { hexa_bin = av[0] }
    // Compiled output under $HOME/.hexa-cache (NOT /tmp — the Darwin
    // build panic-guard refuses /tmp|/private/tmp outputs).
    let mut _cache_dir = env_var("HOME") + "/.hexa-cache"
    if len(env_var("HOME")) == 0 { _cache_dir = "./.hexa-cache" }
    let _mk = exec("mkdir -p " + shq(_cache_dir) + " 2>/dev/null")
    // GO M1: lazy GC probe (cap + TTL + tmp orphan sweep).
    _hexa_cache_gc(_cache_dir, _hexa_cache_cap_mb(), _hexa_cache_ttl_days())
    // Content-addressed cache key — see cmd_run_user_direct above.
    let _src_hash = sha256_file(file)
    let _key = _src_hash.substring(0, 16) + "_" + version_str()
    let mut tmpbin = _cache_dir + "/hexa_run." + _key
    let mut bout = ""
    let mut brc = 0
    // GO M2 — release/precompile/ probe (see cmd_run_user_direct site).
    let _pre = _precompile_lookup(_key)
    if len(_pre) > 0 {
        tmpbin = _pre
        if env_var("HEXA_PRECOMPILE_TRACE") == "1" { eprintln("[precompile] HIT " + _pre) }
    }
    if !file_exists(tmpbin) {
        let _tmp_inflight = tmpbin + ".tmp." + to_string(mono_ns())
        let bcmd = shq(hexa_bin) + " build " + shq(file) + " -o " + shq(_tmp_inflight) + " 2>&1; echo \"__HEXA_BRC__=$?\""
        bout = exec(bcmd)
        let bmark = "__HEXA_BRC__="
        let bml = len(bmark)
        let mut bmi = -1
        let mut bsj = len(bout) - bml
        while bsj >= 0 {
            if bout.substring(bsj, bsj + bml) == bmark { bmi = bsj; bsj = -1 } else { bsj = bsj - 1 }
        }
        brc = 1
        if bmi >= 0 {
            let mut rs = bout.substring(bmi + bml, len(bout))
            let rsl = len(rs)
            if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" { rs = rs.substring(0, rsl - 1) }
            brc = parse_int_str(rs)
        }
        if brc == 0 && file_exists(_tmp_inflight) {
            let _rn = exec("mv -f " + shq(_tmp_inflight) + " " + shq(tmpbin) + " 2>/dev/null")
        } else {
            let _cl = exec("rm -f " + shq(_tmp_inflight) + " 2>/dev/null")
        }
    }
    let mut rc = 1
    // Cold-cache race fix (2026-05-25): peer-built binary 존재 시 자기 brc 무관 실행
    // (cmd_run_user_direct 와 동일 시맨틱). 상세 = 윗 site comment 참조.
    if file_exists(tmpbin) {
        let mut cmd = shq(tmpbin)
        let mut ai = 0
        while ai < len(extra_args) {
            cmd = cmd + " " + shq(extra_args[ai])
            ai = ai + 1
        }
        let out = exec(cmd + " 2>&1; echo \"__HEXA_SHIM_RC__=$?\"")
        let marker = "__HEXA_SHIM_RC__="
        let mlen = len(marker)
        let mut midx = -1
        let mut sj = len(out) - mlen
        while sj >= 0 {
            if out.substring(sj, sj + mlen) == marker { midx = sj; sj = -1 } else { sj = sj - 1 }
        }
        if midx >= 0 {
            let body = out.substring(0, midx)
            print(body)
            let mut rs2 = out.substring(midx + mlen, len(out))
            let rsl2 = len(rs2)
            if rsl2 > 0 && rs2.substring(rsl2 - 1, rsl2) == "\n" { rs2 = rs2.substring(0, rsl2 - 1) }
            rc = parse_int_str(rs2)
        } else {
            print(out)
            rc = 0
        }
    } else {
        eprintln("error: `hexa build " + file + "` failed (compile error).")
        if env_var("HEXA_INTERP_QUIET") != "1" { eprintln(bout) }
        rc = brc
        if rc == 0 { rc = 1 }
    }
    cmd_run_last_rc = rc
    auto_marker_write(file, rc)
    if cmd_run_no_exit_mode {
        return
    }
    if rc != 0 { exit(rc) }
}

// ─── ω-hexa-batch: phase A `hexa batch` ───────────────────
// `hexa batch <f1> <f2> ...` runs N .hexa scripts back-to-back inside
// ONE dispatcher process. Each script still gets its own interp child
// (full state isolation, unchanged cmd_run contract), but the host
// dispatcher's startup cost (~2-3s wall on macOS, dominated by Mach-O
// load + main.hexa boot) is paid ONCE rather than N times.
//
// Framing:
//   - Per-script:  "===BATCH_RESULT=== file=<path> rc=<n>"  (stderr)
//     (stdout/stderr of each script is forwarded as usual; the marker
//      lives on stderr so callers parsing stdout JSON aren't polluted.)
//   - Final:       "__HEXA_BATCH__ scripts=N succeeded=S failed=F wall_ms=W"
//
// Failures don't abort: cmd_run's exit-on-rc is suppressed via
// cmd_run_no_exit_mode while iterating. Final exit code = 0 if all
// succeeded, else 1 (non-zero rc summary, but specific rc values are
// in the per-script frames so callers can recover detail).
//
// Phase A scope (deferred to Phase B): manifest file format, parallel
// scheduling, per-script env isolation, in-interp script chaining.
let mut cmd_run_no_exit_mode = false
let mut cmd_run_last_rc = 0

fn _batch_run_one(file) {
    // Batch path — compile-then-exec, mirrors cmd_run_user_direct but
    // RETURNS rc instead of exit(rc) so the batch loop continues across
    // per-file failures. The tree-walking interpreter is retired
    // (g_interp_deprecated).
    let __inst_r = install_dir_from_argv0()
    let mut hexa_bin = ""
    if len(__inst_r) > 0 {
        let cand = __inst_r + "/hexa"
        if file_exists(cand) { hexa_bin = cand }
    }
    if len(hexa_bin) == 0 { hexa_bin = av[0] }
    let mut _cache_dir = env_var("HOME") + "/.hexa-cache"
    if len(env_var("HOME")) == 0 { _cache_dir = "./.hexa-cache" }
    let _mk = exec("mkdir -p " + shq(_cache_dir) + " 2>/dev/null")
    // GO M1: lazy GC probe (cap + TTL + tmp orphan sweep).
    _hexa_cache_gc(_cache_dir, _hexa_cache_cap_mb(), _hexa_cache_ttl_days())
    // Content-addressed cache (shares the hexa_run.* namespace with
    // cmd_run / cmd_run_user_direct so a `hexa batch` invocation
    // benefits from prior `hexa run` builds of the same source).
    let _src_hash = sha256_file(file)
    let _key = _src_hash.substring(0, 16) + "_" + version_str()
    let mut tmpbin = _cache_dir + "/hexa_run." + _key
    let mut bout = ""
    let mut brc = 0
    // GO M2 — release/precompile/ probe (see cmd_run_user_direct site).
    let _pre = _precompile_lookup(_key)
    if len(_pre) > 0 {
        tmpbin = _pre
        if env_var("HEXA_PRECOMPILE_TRACE") == "1" { eprintln("[precompile] HIT " + _pre) }
    }
    if !file_exists(tmpbin) {
        let _tmp_inflight = tmpbin + ".tmp." + to_string(mono_ns())
        let bcmd = shq(hexa_bin) + " build " + shq(file) + " -o " + shq(_tmp_inflight) + " 2>&1; echo \"__HEXA_BRC__=$?\""
        bout = exec(bcmd)
        let bmark = "__HEXA_BRC__="
        let bml = len(bmark)
        let mut bmi = -1
        let mut bsj = len(bout) - bml
        while bsj >= 0 {
            if bout.substring(bsj, bsj + bml) == bmark { bmi = bsj; bsj = -1 } else { bsj = bsj - 1 }
        }
        brc = 1
        if bmi >= 0 {
            let mut rs = bout.substring(bmi + bml, len(bout))
            let rsl = len(rs)
            if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" { rs = rs.substring(0, rsl - 1) }
            brc = parse_int_str(rs)
        }
        if brc == 0 && file_exists(_tmp_inflight) {
            let _rn = exec("mv -f " + shq(_tmp_inflight) + " " + shq(tmpbin) + " 2>/dev/null")
        } else {
            let _cl = exec("rm -f " + shq(_tmp_inflight) + " 2>/dev/null")
        }
    }
    // Cold-cache race fix (2026-05-25): _batch_run_one 도 동일 — peer-built binary
    // 존재 시 자기 brc 무관 실행 (cmd_run_user_direct/cmd_run 와 동일 시맨틱).
    if file_exists(tmpbin) {
        let out = exec(shq(tmpbin) + " 2>&1; echo \"__HEXA_SHIM_RC__=$?\"")
        let marker = "__HEXA_SHIM_RC__="
        let mlen = len(marker)
        let mut midx = -1
        let mut sj = len(out) - mlen
        while sj >= 0 {
            if out.substring(sj, sj + mlen) == marker { midx = sj; sj = -1 } else { sj = sj - 1 }
        }
        if midx >= 0 {
            let body = out.substring(0, midx)
            let rc_str = out.substring(midx + mlen, len(out))
            print(body)
            let mut rs2 = rc_str
            let rsl2 = len(rs2)
            if rsl2 > 0 && rs2.substring(rsl2 - 1, rsl2) == "\n" { rs2 = rs2.substring(0, rsl2 - 1) }
            return parse_int_str(rs2)
        }
        print(out)
        return 0
    }
    eprintln("error: `hexa build " + file + "` failed (compile error).")
    if env_var("HEXA_INTERP_QUIET") != "1" { eprintln(bout) }
    let mut _erc = brc
    if _erc == 0 { _erc = 1 }
    return _erc
}

fn cmd_batch(files) {
    let n = len(files)
    if n == 0 {
        eprintln("error: 'batch' requires one or more <file> arguments")
        exit(2)
    }
    let t0 = clock()
    let mut succeeded = 0
    let mut failed = 0
    let mut bi = 0
    cmd_run_no_exit_mode = true
    while bi < n {
        let f = files[bi]
        let rc = _batch_run_one(f)
        // Per-script frame on stderr — keeps stdout clean for JSON-emitting scripts.
        eprintln("===BATCH_RESULT=== file=" + f + " rc=" + to_string(rc))
        if rc == 0 {
            succeeded = succeeded + 1
        } else {
            failed = failed + 1
        }
        bi = bi + 1
    }
    cmd_run_no_exit_mode = false
    let wall_ms = (clock() - t0) * 1000.0
    // Final sentinel (stderr) — bridge_health.sh-style callers can parse.
    eprintln("__HEXA_BATCH__ scripts=" + to_string(n) + " succeeded=" + to_string(succeeded) + " failed=" + to_string(failed) + " wall_ms=" + to_string(wall_ms))
    if failed > 0 { exit(1) }
}

// ─── bt 81: hexa bench harness ────────────────────────────
// 목적: 자체 호스트 .hexa 스크립트를 N회 반복 실행하면서
//       wall_s, RSS(KB), HEXA_ALLOC_STATS 카운터를 수집하고
//       median/min/max 표 또는 JSON을 출력한다. --compare 모드는
//       동일 파일을 두 바이너리로 돌려 delta % 를 보여줌으로써
//       interp vs hexat/v3, 또는 빌드 전/후 회귀 확인 용도.
//
// 설계:
//   - 측정은 외부 `/usr/bin/time` 에 위임 — 인터프리터 외부에서
//     wall/RSS 를 객관적으로 캡처. macOS는 `-l`(BSD), Linux는 `-v`(GNU).
//   - HEXA_ALLOC_STATS=1 환경변수로 self/runtime.c 의 atexit dump를
//     stderr 로 받아 grep + awk 로 5개 카운터(array_new/push/grow/
//     map_new/map_set) 추출.
//   - median 은 외부 sort 로 정렬한 결과의 중간 인덱스. N=3 권장.
//   - JSON 직렬화는 hexa 표준 라이브러리에 직렬화기가 없어
//     문자열 직접 조립 — 키 순서/이스케이프 고정.
//
// 한계:
//   - run-to-run 분산은 BSD/GNU time 해상도(10ms)에 의해 결정.
//     ns/op 측정에는 self/bench_env_get.hexa 류의 in-process clock()
//     기반 마이크로벤치가 더 적합.
//   - 첫 회 실행은 cold (디스크 캐시) — N>=3 권장, median 사용으로 흡수.

fn bench_time_cmd(bin, file) {
    // One `/usr/bin/time` invocation; its stderr is captured to a
    // PID-tagged tmp file for wall/RSS extraction (stdout discarded).
    // tmp path is PID-tagged to avoid concurrent-call collision.
    //
    // R7 (g_interp_deprecated): the tree-walking interpreter is retired,
    // so there is no `build/hexa_interp` binary to invoke directly. The
    // run goes through `bin run <file>` (cmd_run_user_direct → compile-
    // then-exec). wall/RSS are still captured exactly by `/usr/bin/time`;
    // the HEXA_ALLOC_STATS atexit dump now belongs to the compiled child
    // process and is no longer separable from dispatcher output — wall/RSS
    // is the reliable bench signal post-R7.
    let stats_file = exec("printf '%s' \"/tmp/hexa_bench_stats.$$.$RANDOM.txt\"")
    let alloc_env = "HEXA_ALLOC_STATS=1"
    let flag = if is_macos() { "-l" } else { "-v" }
    let cmd = alloc_env + " /usr/bin/time " + flag + " '" + bin + "' run '" + file + "' > /dev/null 2> '" + stats_file + "'"
    let _ = exec(cmd)
    return stats_file
}

fn parse_wall_s(stats_file) {
    // BSD: line like "        0.07 real         0.00 user         0.01 sys"
    //   awk '/ real/ {print $1; exit}' 로 첫 토큰만.
    // GNU: "Elapsed (wall clock) time (h:mm:ss or m:ss): 0:00.07"
    //   tail token 을 ':' 로 split 후 마지막 두 필드를 60×+합산.
    if is_macos() {
        let v = exec("awk '/ real/ {print $1; exit}' '" + stats_file + "' 2>/dev/null | tr -d ' \\n'")
        if len(v) == 0 { return "0.0" }
        return v
    }
    // GNU time path
    let raw = exec("awk -F': ' '/Elapsed/ {print $NF; exit}' '" + stats_file + "' 2>/dev/null | tr -d ' \\n'")
    if len(raw) == 0 { return "0.0" }
    // raw 형식: "m:ss.cc" 또는 "h:mm:ss"
    let parsed = exec("printf '%s' '" + raw + "' | awk -F: '{ if (NF==2) printf \"%.3f\", $1*60+$2; else if (NF==3) printf \"%.3f\", $1*3600+$2*60+$3; else printf \"%s\", $0 }'")
    return parsed
}

fn parse_rss_kb(stats_file) {
    // BSD: "             1474560  maximum resident set size"  (bytes!)
    //   → divide by 1024 to get KB.
    // GNU: "Maximum resident set size (kbytes): 1234"  (already KB)
    if is_macos() {
        let bytes = exec("awk '/maximum resident set size/ {print $1; exit}' '" + stats_file + "' 2>/dev/null | tr -d ' \\n'")
        if len(bytes) == 0 { return "0" }
        let kb = exec("printf '%s' '" + bytes + "' | awk '{ printf \"%d\", $1/1024 }'")
        return kb
    }
    let v = exec("awk -F': ' '/Maximum resident set size/ {print $2; exit}' '" + stats_file + "' 2>/dev/null | tr -d ' \\n'")
    if len(v) == 0 { return "0" }
    return v
}

fn parse_alloc_counter(stats_file, key) {
    // self/runtime.c 의 atexit dump 라인은 한 줄짜리:
    //   [HEXA_ALLOC_STATS] array_new=N push=N grow=N reserve=N str_concat=N map_new=N map_set=N ...
    // 주의: `./hexa` (parent dispatcher) + interp (child interpreter) 가 둘 다
    // dump 라인을 출력해서 한 stderr 파일에 두 개가 적힌다. 첫 줄은 dispatcher
    // overhead(작은 숫자)이고, 두 번째 줄이 실제 측정 대상(스크립트). `tail -1`
    // 로 마지막 줄(=interp child) 을 잡아서 워크로드 통계를 정확히 캡처.
    let cmd = "grep '\\[HEXA_ALLOC_STATS\\]' '" + stats_file + "' 2>/dev/null | tail -1 | awk -v k='" + key + "' '{ for (i=1;i<=NF;i++) { if (index($i, k\"=\") == 1) { split($i, p, \"=\"); print p[2]; exit } } }' | tr -d ' \\n'"
    let v = exec(cmd)
    if len(v) == 0 { return "0" }
    return v
}

fn median_str(values) {
    // 문자열 숫자 배열 → median 문자열. sort -g 사용(소수점 처리).
    // empty 보호: 0 반환.
    let n = len(values)
    if n == 0 { return "0" }
    let mut joined = ""
    let mut i = 0
    while i < n {
        joined = joined + values[i] + "\n"
        i = i + 1
    }
    let mid = n / 2 + 1
    // hexat 트랜스파일러는 builtin `str()` dispatch 가 없어
    // 빈 문자열 + int 를 통한 implicit hexa_to_string 으로 변환.
    let mid_s = "" + mid
    let cmd = "printf '%s' '" + joined + "' | sort -g | sed -n '" + mid_s + "p' | tr -d ' \\n'"
    let m = exec(cmd)
    if len(m) == 0 { return values[0] }
    return m
}

fn min_str(values) {
    let n = len(values)
    if n == 0 { return "0" }
    let mut joined = ""
    let mut i = 0
    while i < n { joined = joined + values[i] + "\n"; i = i + 1 }
    let m = exec("printf '%s' '" + joined + "' | sort -g | head -1 | tr -d ' \\n'")
    if len(m) == 0 { return values[0] }
    return m
}

fn max_str(values) {
    let n = len(values)
    if n == 0 { return "0" }
    let mut joined = ""
    let mut i = 0
    while i < n { joined = joined + values[i] + "\n"; i = i + 1 }
    let m = exec("printf '%s' '" + joined + "' | sort -g | tail -1 | tr -d ' \\n'")
    if len(m) == 0 { return values[0] }
    return m
}

// 결과는 hexat 트랜스파일러가 map 리터럴을 지원하지 않아
// 11-원소 배열로 반환 (인덱스 컨벤션 — bench_idx_* 헬퍼).
//
// idx 의미:
//   0 median_wall_s   1 min_wall_s     2 max_wall_s
//   3 median_rss_kb   4 min_rss_kb     5 max_rss_kb
//   6 array_new       7 array_push     8 array_grow
//   9 map_new        10 map_set
fn bench_run_one_binary(bin, file, runs) {
    let mut wall_arr = []
    let mut rss_arr = []
    let mut an_arr = []
    let mut ap_arr = []
    let mut ag_arr = []
    let mut mn_arr = []
    let mut ms_arr = []
    let mut i = 0
    while i < runs {
        let sf = bench_time_cmd(bin, file)
        wall_arr.push(parse_wall_s(sf))
        rss_arr.push(parse_rss_kb(sf))
        an_arr.push(parse_alloc_counter(sf, "array_new"))
        ap_arr.push(parse_alloc_counter(sf, "push"))
        ag_arr.push(parse_alloc_counter(sf, "grow"))
        mn_arr.push(parse_alloc_counter(sf, "map_new"))
        ms_arr.push(parse_alloc_counter(sf, "map_set"))
        let _ = exec("rm -f '" + sf + "' 2>/dev/null")
        i = i + 1
    }
    let mut r = []
    r.push(median_str(wall_arr))
    r.push(min_str(wall_arr))
    r.push(max_str(wall_arr))
    r.push(median_str(rss_arr))
    r.push(min_str(rss_arr))
    r.push(max_str(rss_arr))
    r.push(median_str(an_arr))
    r.push(median_str(ap_arr))
    r.push(median_str(ag_arr))
    r.push(median_str(mn_arr))
    r.push(median_str(ms_arr))
    return r
}

fn bench_print_table(bin, file, runs, r) {
    println("=== hexa bench ===")
    println("  binary:    " + bin)
    println("  file:      " + file)
    println("  runs:      " + runs)
    println("")
    println("  metric                median        min           max")
    println("  ────────────────────  ────────────  ────────────  ────────────")
    println("  wall (s)              " + r[0] + "         " + r[1] + "         " + r[2])
    println("  rss  (KB)             " + r[3] + "         " + r[4] + "         " + r[5])
    println("")
    println("  HEXA_ALLOC_STATS (median)")
    println("    array_new:  " + r[6])
    println("    array_push: " + r[7])
    println("    array_grow: " + r[8])
    println("    map_new:    " + r[9])
    println("    map_set:    " + r[10])
}

fn bench_print_json(file, runs, r) {
    // 수동 직렬화 — 키 순서 고정, 값은 숫자 그대로 (인용 없음).
    // file 만 문자열로 quote. 외부 jq/python json.load 로 검증 가능.
    // hexat 트랜스파일러가 다중행 `+` 연결을 지원하지 않아 한 줄 누적.
    let mut s = "{"
    s = s + "\"file\":\"" + file + "\","
    s = s + "\"runs\":" + runs + ","
    s = s + "\"median_wall_s\":" + r[0] + ","
    s = s + "\"min_wall_s\":" + r[1] + ","
    s = s + "\"max_wall_s\":" + r[2] + ","
    s = s + "\"median_rss_kb\":" + r[3] + ","
    s = s + "\"min_rss_kb\":" + r[4] + ","
    s = s + "\"max_rss_kb\":" + r[5] + ","
    s = s + "\"alloc_stats\":{"
    s = s + "\"array_new\":" + r[6] + ","
    s = s + "\"array_push\":" + r[7] + ","
    s = s + "\"array_grow\":" + r[8] + ","
    s = s + "\"map_new\":" + r[9] + ","
    s = s + "\"map_set\":" + r[10]
    s = s + "}}"
    println(s)
}

fn bench_print_compare(file, runs, ra, rb, bin_a, bin_b) {
    // delta% = (B - A) / A * 100  ;  positive = B is slower / heavier.
    println("=== hexa bench --compare ===")
    println("  file:      " + file)
    println("  runs:      " + runs)
    println("  A:         " + bin_a)
    println("  B:         " + bin_b)
    println("")
    println("  metric         A (median)    B (median)    delta%")
    println("  ─────────────  ────────────  ────────────  ────────")
    let aw = ra[0]
    let bw = rb[0]
    let dw = exec("awk -v a='" + aw + "' -v b='" + bw + "' 'BEGIN { if (a+0==0) printf \"n/a\"; else printf \"%+.2f\", (b-a)/a*100 }'")
    let ar = ra[3]
    let br = rb[3]
    let dr = exec("awk -v a='" + ar + "' -v b='" + br + "' 'BEGIN { if (a+0==0) printf \"n/a\"; else printf \"%+.2f\", (b-a)/a*100 }'")
    println("  wall (s)       " + aw + "         " + bw + "         " + dw + "%")
    println("  rss  (KB)      " + ar + "         " + br + "         " + dr + "%")
    println("")
    println("  alloc-stats (median: A → B)")
    println("    array_new:  " + ra[6] + " → " + rb[6])
    println("    array_push: " + ra[7] + " → " + rb[7])
    println("    array_grow: " + ra[8] + " → " + rb[8])
    println("    map_new:    " + ra[9] + " → " + rb[9])
    println("    map_set:    " + ra[10] + " → " + rb[10])
}

// digit-string → int. 네이티브 hexa(dispatch+) 는 string 인덱싱이 없어 interp
// 와 다르게 s[i] 가 동작하지 않는다(hexa_index_get → hexa_array_get fall-through
// 으로 'index out of bounds' 발생). 외부 awk 위임 후 int 타입으로 누적.
fn parse_int_str(s) {
    // 1차: awk 로 양의 정수만 통과시키고 길이 캡 5(<=99999) 적용.
    let cleaned = exec("printf '%s' '" + s + "' | awk '{ if ($1 ~ /^[0-9]+$/ && length($1) <= 5) print int($1); else print 0 }' | tr -d ' \\n'")
    if len(cleaned) == 0 { return 0 }
    if cleaned == "0" { return 0 }
    // 2차: 한 번에 하나씩 trim 하면서 자릿수 누적.
    // awk 가 "23" 식으로 돌려주지만 hexa 에서 int 타입으로 끌어와야 한다.
    // sequence of `case ${s} in 1*) printf 1 ;; ...` 식의 1자리 검사로
    // string→int 변환을 우회한다. interp 에서는 직접 변환 가능.
    // hexat 트랜스파일러는 빈 string match 를 정확히 처리 못하므로
    // grep -c 로 카운트 비교를 통한 0/N 확인.
    //
    // MVP: cleaned 가 "1".."99999" 범위면 길이별로 분기, awk 로 cumulative
    // 곱셈 수행. case 문 안 쓰고 awk -v 로 처리.
    //
    // 실제로는 5번까지 1-digit 추출 후 hexa int 로 변환:
    let len_cmd = exec("printf '%s' '" + cleaned + "' | awk '{ print length($1) }' | tr -d ' \\n'")
    let mut result = 0
    if len_cmd == "1" {
        result = digit_to_int(cleaned)
    } else if len_cmd == "2" {
        let d0 = exec("printf '%s' '" + cleaned + "' | cut -c1")
        let d1 = exec("printf '%s' '" + cleaned + "' | cut -c2")
        result = digit_to_int(d0) * 10 + digit_to_int(d1)
    } else if len_cmd == "3" {
        let d0 = exec("printf '%s' '" + cleaned + "' | cut -c1")
        let d1 = exec("printf '%s' '" + cleaned + "' | cut -c2")
        let d2 = exec("printf '%s' '" + cleaned + "' | cut -c3")
        result = digit_to_int(d0) * 100 + digit_to_int(d1) * 10 + digit_to_int(d2)
    } else if len_cmd == "4" {
        let d0 = exec("printf '%s' '" + cleaned + "' | cut -c1")
        let d1 = exec("printf '%s' '" + cleaned + "' | cut -c2")
        let d2 = exec("printf '%s' '" + cleaned + "' | cut -c3")
        let d3 = exec("printf '%s' '" + cleaned + "' | cut -c4")
        result = digit_to_int(d0) * 1000 + digit_to_int(d1) * 100 + digit_to_int(d2) * 10 + digit_to_int(d3)
    }
    return result
}

fn digit_to_int(d) {
    // 한 자리 숫자 string → int. 비교 평등성으로 분기 (string indexing 없이).
    if d == "0" { return 0 }
    if d == "1" { return 1 }
    if d == "2" { return 2 }
    if d == "3" { return 3 }
    if d == "4" { return 4 }
    if d == "5" { return 5 }
    if d == "6" { return 6 }
    if d == "7" { return 7 }
    if d == "8" { return 8 }
    if d == "9" { return 9 }
    return 0
}

fn cmd_bench(file, runs, json_mode, compare_bin) {
    // 자기 자신(./hexa) 을 기본 A, --compare 인자가 있으면 그것이 B.
    // cwd 의 ./hexa 우선, 없으면 $HEXA_LANG/hexa fallback
    // (워크트리/포크에서도 동작하도록).
    let cwd_hexa = exec("printf '%s/hexa' \"$(pwd)\"")
    let cwd_chk = exec("test -x '" + cwd_hexa + "' && printf yes || printf no")
    let mut self_bin = ""
    if cwd_chk == "yes" {
        self_bin = cwd_hexa
    } else {
        self_bin = exec("printf '%s' \"$HEXA_LANG/hexa\"")
    }
    let exists = exec("test -f '" + file + "' && printf yes || printf no")
    if exists != "yes" {
        println("error: bench file not found: " + file)
        return
    }
    let bin_check = exec("test -x '" + self_bin + "' && printf yes || printf no")
    if bin_check != "yes" {
        println("error: ./hexa not executable at " + self_bin)
        return
    }
    let ra = bench_run_one_binary(self_bin, file, runs)
    if len(compare_bin) > 0 {
        let cb_check = exec("test -x '" + compare_bin + "' && printf yes || printf no")
        if cb_check != "yes" {
            println("error: --compare binary not executable: " + compare_bin)
            return
        }
        let rb = bench_run_one_binary(compare_bin, file, runs)
        if json_mode {
            // compare + json: a/b 각각의 median 만 직렬화 (단순화).
            let mut j = "{\"file\":\"" + file + "\",\"runs\":" + runs
            j = j + ",\"a\":{\"binary\":\"" + self_bin + "\",\"median_wall_s\":" + ra[0]
            j = j + ",\"median_rss_kb\":" + ra[3] + "}"
            j = j + ",\"b\":{\"binary\":\"" + compare_bin + "\",\"median_wall_s\":" + rb[0]
            j = j + ",\"median_rss_kb\":" + rb[3] + "}}"
            println(j)
        } else {
            bench_print_compare(file, runs, ra, rb, self_bin, compare_bin)
        }
        return
    }
    if json_mode {
        bench_print_json(file, runs, ra)
    } else {
        bench_print_table(self_bin, file, runs, ra)
    }
}

// ── T27: cmd_parse — parse-only verification (no exec, no codegen) ──
// 목적: L0 guard 등이 `.hexa` 파일 구문 유효성만 확인하고 싶을 때, 현재는
//       `hexa run` (실제 실행) 으로 검증하는 안전 문제가 있었다. `hexa parse`
//       는 트랜스파일러를 호출해 파싱까지만 수행하고, 결과 .c 는 버리며
//       "Parse error" 라인 존재 여부로 exit code 를 결정한다.
//
// 구현 메모:
//   - hexat 는 파싱 실패를 stdout 에 "Parse error at L:C: ..." 로 찍고도
//     exit 0 하는 특성이 있어 (codegen best-effort), 출력 문자열에 "Parse error"
//     포함 여부로 판정한다. parser hard-fail (auto-invoke 충돌 `exit(1)` 등) 은
//     비정상 종료 코드로 잡는다 — exec_with_status 로 (출력, rc) 동시 취득.
//   - 판정은 in-process (`.contains`) — 파서 출력을 셸 명령에 보간하면 출력
//     안의 백틱 / `$()` / `$VAR` 가 재평가되는 인젝션이 생긴다.
//   - 출력 .c 는 /tmp/hexa_parse_check_$$.c 로 임시. 후처리 삭제.
//   - 성공: "OK" 한 줄, exit 0. 실패: 파서 에러 라인 그대로 + exit(1).
// ─── `hexa gpu` — GPU CLI dispatcher (GPU.md §7c) ─────────────────────
// Wraps the recurring per-fire pattern: scp PTX + host C → target host →
// nvcc + ./binary → pull result.json. Single hexa-side command, no .sh
// dependency. Default target host = "ubu-2" (RTX 5070, see
// `reference_gpu_fire_infra` memory).
//
// Usage:  hexa gpu fire <kernel.ptx> <host.c> [target-host]
//
// REMOTE workdir is derived from the kernel basename (sans .ptx):
//   /tmp/hexa_gpu_fire_<basename_noext>/
//
// Pipeline (each step prints stdout, propagates non-zero rc):
//   1. ssh <host> mkdir -p $REMOTE
//   2. scp <ptx> <host_c> <host>:$REMOTE/
//   3. ssh <host> "cd $REMOTE && nvcc -O2 -arch=sm_90 -o fire_bin <host_c_basename> -lcuda && ./fire_bin <ptx_basename>"
//   4. scp <host>:$REMOTE/result.json ./<ptx_basename>.result.json   (best-effort)
//
// HEXA_GPU_DRY=1 prints the planned commands instead of executing them
// (used by the parse-gate smoke test when ssh is unreachable).
fn _gpu_basename_noext(path) {
    // basename minus a trailing `.<ext>` (single dot tail). Single-quote
    // safe because shq-style escaping is the caller's responsibility for
    // the path that goes INTO the shell; this helper just trims for the
    // workdir/result-name suffix.
    let b = exec("basename '" + path + "' 2>/dev/null | tr -d '\\n'")
    let n = len(b)
    let mut i = n - 1
    while i >= 0 {
        if b.substring(i, i + 1) == "." {
            return b.substring(0, i)
        }
        i = i - 1
    }
    return b
}

fn _gpu_basename(path) {
    return exec("basename '" + path + "' 2>/dev/null | tr -d '\\n'")
}

fn _gpu_run_step(label, cmd) {
    // Run `cmd` via exec, stream stdout, propagate rc. Returns 0 on success;
    // exits with the captured rc otherwise.
    println("[gpu " + label + "] " + cmd)
    if env_var("HEXA_GPU_DRY") == "1" {
        return 0
    }
    let out = exec(cmd + " 2>&1; echo \"__HEXA_SHIM_RC__=$?\"")
    let marker = "__HEXA_SHIM_RC__="
    let mlen = len(marker)
    let mut midx = -1
    let mut si = len(out) - mlen
    while si >= 0 {
        if out.substring(si, si + mlen) == marker {
            midx = si
            si = -1
        } else {
            si = si - 1
        }
    }
    if midx >= 0 {
        let body = out.substring(0, midx)
        let rc_str = out.substring(midx + mlen, len(out))
        print(body)
        let mut rs = rc_str
        let rsl = len(rs)
        if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" {
            rs = rs.substring(0, rsl - 1)
        }
        let rc = parse_int_str(rs)
        return rc
    } else {
        print(out)
        return 0
    }
}

// ─── `hexa gpu disasm <ptx>` ──────────────────────────────────────────
// Pure hexa PTX opcode-family histogram. No subprocess, no ptxas — read
// the text, line-split, extract leading opcode token per instruction
// line, bin by first dotted segment (ld.param.u64 → "ld"; wmma.load.a.* →
// "wmma"), print sorted-descending counts.
//
// Why pure hexa: g_commit_push_deploy + hexa-native-only (g5) + the
// 'compiled-path 사용' policy. ptxas as subprocess would fail offline.
// This is a structural read — it does NOT decode SASS, it bins PTX
// opcodes by family. Use case: confirm a PTX file contains the wmma
// instructions you expected to emit.
fn _gpu_ptx_strip_pred(tok) {
    // PTX predicate prefix: '@p' or '@!p' — strip if present so the
    // family bucketing reflects the real opcode.
    if len(tok) == 0 { return tok }
    if tok.substring(0, 1) != "@" { return tok }
    return ""  // predicated lines: we treat the @predicate token as
              // non-instruction; the real opcode is on a subsequent
              // whitespace-separated token. Caller advances.
}

fn _gpu_ptx_family(opcode) {
    // First dotted segment, or the whole token if there's no dot.
    let n = len(opcode)
    let mut i = 0
    while i < n {
        if opcode.substring(i, i + 1) == "." {
            return opcode.substring(0, i)
        }
        i = i + 1
    }
    return opcode
}

fn _gpu_ptx_extract_opcode(line) {
    // Trim left whitespace; if first non-space char is '@' (predicate),
    // skip the predicate token. Then return the leading word until the
    // next whitespace / ';' / '{' / '['. Return "" if line is empty,
    // directive ('.'), label (ends with ':' on first token), or comment.
    let trimmed = line.trim()
    if len(trimmed) == 0 { return "" }
    let first = trimmed.substring(0, 1)
    if first == "/" { return "" }       // '//' comment
    if first == "." { return "" }       // PTX directive (.version, .reg, …)
    if first == "{" { return "" }
    if first == "}" { return "" }
    if first == "(" { return "" }
    if first == ")" { return "" }
    if first == ";" { return "" }
    // Skip leading '@predicate' token (e.g. '@p1', '@!p2').
    let mut body = trimmed
    if first == "@" {
        let bn = len(body)
        let mut j = 0
        while j < bn {
            let c = body.substring(j, j + 1)
            if c == " " || c == "\t" {
                // Advance past the predicate token to the real opcode.
                body = body.substring(j + 1, bn).trim()
                j = bn  // break
            } else {
                j = j + 1
            }
        }
        if len(body) == 0 { return "" }
        let bf = body.substring(0, 1)
        if bf == "." || bf == "/" { return "" }
    }
    // Now `body` starts with the opcode. Scan until whitespace / ; / { / [
    let bn2 = len(body)
    let mut k = 0
    while k < bn2 {
        let c2 = body.substring(k, k + 1)
        if c2 == " " || c2 == "\t" || c2 == ";" || c2 == "{" || c2 == "[" || c2 == "," {
            return body.substring(0, k)
        }
        k = k + 1
    }
    return body
}

fn _gpu_hist_add(names, counts, family) {
    // Linear lookup-or-append. PTX has ~30 op families; O(N²) here is
    // a few thousand cmp ops at worst — well under any cost-bearing
    // floor.
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] == family {
            counts[i] = counts[i] + 1
            return
        }
        i = i + 1
    }
    names.push(family)
    counts.push(1)
}

fn _gpu_hist_sort_desc(names, counts) {
    // In-place insertion sort by count descending. Tiny n.
    let n = len(names)
    let mut i = 1
    while i < n {
        let mut j = i
        while j > 0 && counts[j] > counts[j - 1] {
            let tc = counts[j]
            counts[j] = counts[j - 1]
            counts[j - 1] = tc
            let tn = names[j]
            names[j] = names[j - 1]
            names[j - 1] = tn
            j = j - 1
        }
        i = i + 1
    }
}

fn cmd_gpu_disasm(args) {
    if len(args) == 0 {
        eprintln("usage: hexa gpu disasm <kernel.ptx>")
        exit(2)
    }
    let path = args[0]
    if !file_exists(path) {
        eprintln("error: ptx file not found: " + path)
        exit(1)
    }
    let text = read_file(path)
    let lines = text.split("\n")
    let total_lines = len(lines)
    let mut instr_count = 0
    let mut names = []
    let mut counts = []
    let mut li = 0
    while li < total_lines {
        let opcode = _gpu_ptx_extract_opcode(lines[li])
        if len(opcode) > 0 {
            let family = _gpu_ptx_family(opcode)
            // Skip lone fragment-register continuation lines like
            // '{%ra0, %ra1, ...}' which extract_opcode already returns "".
            if len(family) > 0 && family.substring(0, 1) != "%" {
                _gpu_hist_add(names, counts, family)
                instr_count = instr_count + 1
            }
        }
        li = li + 1
    }
    _gpu_hist_sort_desc(names, counts)
    println("[gpu disasm] " + path)
    println("[gpu disasm] " + to_string(total_lines) + " lines, " + to_string(instr_count) + " instructions, " + to_string(len(names)) + " families")
    println("")
    println("FAMILY            COUNT")
    let nf = len(names)
    let mut fi = 0
    while fi < nf {
        // Pad family name to width 16 (visual alignment; we don't have
        // printf-style formatting builtin so concat-pad).
        let nm = names[fi]
        let mut padded = nm
        let mut pi = len(nm)
        while pi < 16 {
            padded = padded + " "
            pi = pi + 1
        }
        println("  " + padded + to_string(counts[fi]))
        fi = fi + 1
    }
}

// ─── `hexa gpu lint <ptx>` ────────────────────────────────────────────
// Static checks on a PTX file:
//   (1) non-ASCII byte detection — driver JIT (cuModuleLoadDataEx)
//       rejects PTX with non-ASCII bytes in comments. Standalone ptxas
//       is lenient. See `reference_gpu_fire_infra` memory.
//   (2) sm-target presence — every PTX must carry '.target sm_NN'.
//   (3) .reg decl count — rough register-pressure indicator (PTX is
//       virtual-register, but per-thread .reg decl count correlates
//       with cubin register footprint after ptxas).
// Exit 0 = clean, 1 = at least one finding.
fn cmd_gpu_lint(args) {
    if len(args) == 0 {
        eprintln("usage: hexa gpu lint <kernel.ptx>")
        exit(2)
    }
    let path = args[0]
    if !file_exists(path) {
        eprintln("error: ptx file not found: " + path)
        exit(1)
    }
    let text = read_file(path)
    let mut findings = 0
    println("[gpu lint] " + path)

    // Check 1 — non-ASCII byte scan. hexa_str_bytes returns int per
    // byte; flag any > 127.
    let bytes = hexa_str_bytes(text)
    let nb = len(bytes)
    let mut bi = 0
    let mut lineno = 1
    let mut col = 1
    let mut nonascii_hits = 0
    let mut first_nonascii_line = 0
    let mut first_nonascii_col = 0
    let mut first_nonascii_byte = 0
    while bi < nb {
        let b = bytes[bi]
        if b > 127 {
            nonascii_hits = nonascii_hits + 1
            if first_nonascii_line == 0 {
                first_nonascii_line = lineno
                first_nonascii_col = col
                first_nonascii_byte = b
            }
        }
        if b == 10 {
            lineno = lineno + 1
            col = 1
        } else {
            col = col + 1
        }
        bi = bi + 1
    }
    if nonascii_hits > 0 {
        findings = findings + 1
        println("  [WARN] non-ASCII bytes: " + to_string(nonascii_hits)
            + " (first at L" + to_string(first_nonascii_line)
            + ":C" + to_string(first_nonascii_col)
            + " byte=0x" + hex(first_nonascii_byte) + ")")
        println("         driver JIT (cuModuleLoadDataEx) rejects non-ASCII PTX.")
    } else {
        println("  [OK]   ASCII-clean (" + to_string(nb) + " bytes)")
    }

    // Check 2 — '.target sm_NN' presence + extract NN.
    let lines = text.split("\n")
    let nl = len(lines)
    let mut sm_target = ""
    let mut sm_lineno = 0
    let mut li = 0
    while li < nl {
        let trimmed = lines[li].trim()
        if len(trimmed) >= 11 && trimmed.substring(0, 11) == ".target sm_" {
            // Strip trailing comma + features after sm_NN (e.g. ',texmode_independent').
            let rest = trimmed.substring(11, len(trimmed))
            let rn = len(rest)
            let mut ri = 0
            let mut sm_digits = ""
            while ri < rn {
                let c = rest.substring(ri, ri + 1)
                if c == "," || c == " " || c == "\t" {
                    ri = rn
                } else {
                    sm_digits = sm_digits + c
                    ri = ri + 1
                }
            }
            sm_target = sm_digits
            sm_lineno = li + 1
            li = nl
        } else {
            li = li + 1
        }
    }
    if len(sm_target) == 0 {
        findings = findings + 1
        println("  [WARN] missing '.target sm_NN' directive")
    } else {
        println("  [OK]   .target sm_" + sm_target + " (L" + to_string(sm_lineno) + ")")
    }

    // Check 3 — .reg decl count + opcode-vs-sm consistency.
    let mut reg_decls = 0
    let mut has_wmma_mma = false
    let mut has_wgmma = false
    let mut has_tcgen05 = false
    let mut has_bf16 = false
    let mut li2 = 0
    while li2 < nl {
        let ln = lines[li2].trim()
        if len(ln) >= 4 && ln.substring(0, 4) == ".reg" {
            reg_decls = reg_decls + 1
        }
        // Substring search: '.bf16' anywhere; 'wmma.mma' / 'wgmma' /
        // 'tcgen05' at start of opcode (after trim).
        let lnn = len(ln)
        if lnn >= 8 {
            let op = _gpu_ptx_extract_opcode(lines[li2])
            if len(op) >= 8 && op.substring(0, 8) == "wmma.mma" { has_wmma_mma = true }
            if len(op) >= 5 && op.substring(0, 5) == "wgmma" { has_wgmma = true }
            if len(op) >= 7 && op.substring(0, 7) == "tcgen05" { has_tcgen05 = true }
        }
        // .bf16 scan — anywhere on the line (PTX type suffix).
        let mut ci2 = 0
        while ci2 + 4 < lnn {
            if ln.substring(ci2, ci2 + 5) == ".bf16" {
                has_bf16 = true
                ci2 = lnn
            } else {
                ci2 = ci2 + 1
            }
        }
        li2 = li2 + 1
    }
    println("  [OK]   .reg decl lines: " + to_string(reg_decls))

    // sm-vs-opcode consistency.
    if len(sm_target) > 0 {
        let sm_n = parse_int_str(sm_target)
        if has_wmma_mma && sm_n < 70 {
            findings = findings + 1
            println("  [WARN] wmma.mma found but .target sm_" + sm_target + " < sm_70")
        }
        if has_bf16 && sm_n < 80 {
            findings = findings + 1
            println("  [WARN] .bf16 type found but .target sm_" + sm_target + " < sm_80")
        }
        if has_wgmma && sm_n < 90 {
            findings = findings + 1
            println("  [WARN] wgmma found but .target sm_" + sm_target + " < sm_90")
        }
        if has_tcgen05 && sm_n < 100 {
            findings = findings + 1
            println("  [WARN] tcgen05 found but .target sm_" + sm_target + " < sm_100")
        }
    }

    println("")
    if findings == 0 {
        println("[gpu lint] clean (0 findings)")
    } else {
        println("[gpu lint] " + to_string(findings) + " finding(s)")
        exit(1)
    }
}

fn cmd_gpu(args) {
    // args = av[3..]  (i.e. starts with the gpu sub-verb)
    if len(args) == 0 {
        println("usage: hexa gpu <fire|disasm|lint> ...")
        println("  GPU CLI dispatcher (GPU.md §7c)")
        println("  fire    scp PTX + host C → remote → nvcc + run → pull result.json")
        println("  disasm  PTX opcode-family histogram (pure hexa scan, no ptxas)")
        println("  lint    static checks: non-ASCII / sm-target / .reg count")
        println("  env     HEXA_GPU_DRY=1  print the planned commands, do not execute")
        exit(1)
    }
    let sub = args[0]
    if sub == "disasm" {
        let mut rest = []
        let mut ri = 1
        while ri < len(args) {
            rest.push(args[ri])
            ri = ri + 1
        }
        cmd_gpu_disasm(rest)
        return 0
    }
    if sub == "lint" {
        let mut rest2 = []
        let mut rj = 1
        while rj < len(args) {
            rest2.push(args[rj])
            rj = rj + 1
        }
        cmd_gpu_lint(rest2)
        return 0
    }
    if sub == "fire" {
        if len(args) < 3 {
            eprintln("usage: hexa gpu fire <kernel.ptx> <host.c> [target-host]")
            exit(2)
        }
        let ptx = args[1]
        let host_c = args[2]
        let mut target = "ubu-2"
        if len(args) >= 4 { target = args[3] }

        // Local existence check — fail fast before any ssh.
        if env_var("HEXA_GPU_DRY") != "1" {
            if !file_exists(ptx) {
                eprintln("error: kernel.ptx not found: " + ptx)
                exit(1)
            }
            if !file_exists(host_c) {
                eprintln("error: host.c not found: " + host_c)
                exit(1)
            }
        }

        let ptx_base = _gpu_basename(ptx)
        let host_c_base = _gpu_basename(host_c)
        let ptx_stem = _gpu_basename_noext(ptx)
        let remote_dir = "/tmp/hexa_gpu_fire_" + ptx_stem

        println("[gpu] target = " + target)
        println("[gpu] remote = " + remote_dir)
        println("[gpu] ptx    = " + ptx + " (" + ptx_base + ")")
        println("[gpu] host.c = " + host_c + " (" + host_c_base + ")")

        // Step 1 — ensure remote workdir.
        let mk_cmd = "ssh " + shq(target) + " " + shq("mkdir -p " + remote_dir)
        let rc1 = _gpu_run_step("mkdir", mk_cmd)
        if rc1 != 0 {
            eprintln("[gpu] step 1 (mkdir) failed rc=" + str(rc1))
            exit(rc1)
        }

        // Step 2 — scp both files in one transfer.
        let scp_cmd = "scp " + shq(ptx) + " " + shq(host_c) + " " + shq(target + ":" + remote_dir + "/")
        let rc2 = _gpu_run_step("scp", scp_cmd)
        if rc2 != 0 {
            eprintln("[gpu] step 2 (scp) failed rc=" + str(rc2))
            exit(rc2)
        }

        // Step 3 — remote nvcc + run. The whole remote command goes through
        // shq as a single argument; ssh re-parses it server-side as one shell
        // string. Single-quote tooling inside that string is unsupported
        // (shq enforces no embedded single quote), so use double-quoted
        // double-args downstream of the outer shq.
        let remote_cmd = "cd " + remote_dir + " && nvcc -O2 -arch=sm_90 -o fire_bin " + host_c_base + " -lcuda && ./fire_bin " + ptx_base
        let run_cmd = "ssh " + shq(target) + " " + shq(remote_cmd)
        let rc3 = _gpu_run_step("nvcc+run", run_cmd)
        if rc3 != 0 {
            eprintln("[gpu] step 3 (nvcc+run) failed rc=" + str(rc3))
            exit(rc3)
        }

        // Step 4 — best-effort pull of result.json. Don't fail the whole
        // pipeline if the host kernel didn't emit one.
        let local_result = "./" + ptx_stem + ".result.json"
        let pull_cmd = "scp " + shq(target + ":" + remote_dir + "/result.json") + " " + shq(local_result) + " 2>/dev/null"
        let rc4 = _gpu_run_step("pull-result", pull_cmd)
        if rc4 != 0 {
            println("[gpu] no result.json (rc=" + str(rc4) + ") — skipped")
        } else {
            println("[gpu] result.json → " + local_result)
        }

        println("[gpu] fire complete")
    } else if sub == "help" || sub == "--help" || sub == "-h" {
        println("hexa gpu — GPU CLI dispatcher (GPU.md §7c)")
        println("")
        println("USAGE")
        println("  hexa gpu fire   <kernel.ptx> <host.c> [target-host]")
        println("  hexa gpu disasm <kernel.ptx>")
        println("  hexa gpu lint   <kernel.ptx>")
        println("")
        println("  fire    target-host defaults to 'ubu-2' (RTX 5070, sm_120).")
        println("          Remote workdir = /tmp/hexa_gpu_fire_<basename_noext>")
        println("          Pipeline: ssh-mkdir → scp → nvcc -O2 -arch=sm_90 + run → pull result.json")
        println("  disasm  PTX opcode-family histogram (pure hexa, no ptxas).")
        println("  lint    Static checks: non-ASCII bytes / .target sm_NN / .reg count /")
        println("          opcode-vs-sm consistency (wmma.mma ≥ sm_70, .bf16 ≥ sm_80, wgmma ≥ sm_90).")
        println("")
        println("ENV")
        println("  HEXA_GPU_DRY=1   print planned commands, do not execute (fire only)")
    } else {
        eprintln("error: unknown gpu sub-verb '" + sub + "'")
        eprintln("usage: hexa gpu <fire|disasm|lint> ...")
        exit(2)
    }
}

// ─── cmd_cache — `hexa cache <subverb>` (GO M4) ──────────────────────
//
// 1st-class verb over `~/.hexa-cache/` — the AOT-cache that `cmd_run` /
// `cmd_build` populate with `runtime.<sha>.o` + `hexa_run.<key>` binary
// entries. Pre-M4 the only way to inspect / prune was raw shell — this
// brings the surface up to parity with `go clean -cache(-n)`.
//
// Subverbs:
//   stat                                 — N entries · total size · oldest age · biggest entry
//   list [--sort=mtime|size] [--limit=N] — `<name>  <size>  <mtime>  <age>` per line
//   verify                               — file_exists + size > 0 over every entry
//   clean [--prune] [--older-than=N] [--cap-mb=M]
//                                        — dry-run by default · --prune flips to delete
//
// Self-contained — does NOT depend on M1's `_hexa_cache_gc` helper (which
// may or may not have landed). Uses `find` / `stat` / `du` shell tools
// (POSIX-compatible on macOS BSD + linux GNU via `-type f` fallback).
fn _hexa_cache_dir() {
    let mut d = env_var("HOME") + "/.hexa-cache"
    if len(env_var("HOME")) == 0 { d = "./.hexa-cache" }
    return d
}

fn cmd_cache(args) {
    let dir = _hexa_cache_dir()
    let _mk = exec("mkdir -p " + shq(dir) + " 2>/dev/null")
    let sub = if len(args) >= 1 { args[0] } else { "stat" }

    if sub == "help" || sub == "-h" || sub == "--help" {
        println("usage: hexa cache <subverb>")
        println("  stat                                  total entries · size · oldest age · biggest")
        println("  list [--sort=mtime|size] [--limit=N]  per-entry: name  size  mtime  age")
        println("  verify                                file_exists + size>0 over every entry")
        println("  clean [--prune] [--older-than=N(d)] [--cap-mb=M]")
        println("                                        dry-run unless --prune; older-than days · cap MB")
        return
    }

    if sub == "stat" {
        let cnt = exec("find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' \\n'")
        let tot = exec("du -sh " + shq(dir) + " 2>/dev/null | awk '{print $1}' | tr -d '\\n'")
        // BSD `stat -f %m` / GNU `stat -c %Y`; portable fallback via `find -printf` (GNU)
        // or per-file `ls -lT` on BSD. We use find+awk pipeline that works both ways.
        let oldest = exec("find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f 2>/dev/null | while read f; do printf '%s\\n' \"$f\"; done | head -1000 | xargs -I{} stat -f '%m %N' {} 2>/dev/null || find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f -printf '%T@ %p\\n' 2>/dev/null | sort -n | head -1 | awk '{ if ($1) { now=systime(); age=now-$1; if (age<60) printf \"%ds\", age; else if (age<3600) printf \"%dm\", age/60; else if (age<86400) printf \"%dh\", age/3600; else printf \"%dd\", age/86400; } else { printf \"-\"; } }'")
        // Oldest fallback simpler — sort by mtime asc via ls -ltr.
        let oldest2 = exec("ls -ltr " + shq(dir) + " 2>/dev/null | awk 'NR>1 && $1 !~ /^total/ {print $0; exit}' | tr -d '\\n'")
        // Biggest entry — `du -k *` then sort.
        let biggest = exec("find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f -exec du -k {} \\; 2>/dev/null | sort -rn | head -1 | awk '{ size=$1; name=$2; sub(\".*/\", \"\", name); if (size>=1024) printf \"%dM  %s\", size/1024, name; else printf \"%dK  %s\", size, name }'")
        println("hexa cache stat — " + dir)
        println("  entries:   " + cnt)
        println("  total:     " + tot)
        if len(oldest2) > 0 { println("  oldest:    " + oldest2) }
        if len(biggest) > 0 { println("  biggest:   " + biggest) }
        return
    }

    if sub == "list" {
        let mut sort_flag = "mtime"
        let mut limit_str = "0"
        let mut li = 1
        while li < len(args) {
            let a = args[li]
            if a.starts_with("--sort=") {
                sort_flag = a.substring(7, len(a))
            } else if a.starts_with("--limit=") {
                limit_str = a.substring(8, len(a))
            }
            li = li + 1
        }
        // Use `ls -l` (mtime) or `ls -lS` (size) — both newest/largest first.
        let ls_flag = if sort_flag == "size" { "-lS" } else { "-lt" }
        let head_clause = if limit_str == "0" { "" } else { " | head -" + limit_str }
        let cmd = "ls " + ls_flag + " " + shq(dir) + " 2>/dev/null | awk 'NR>1 && $1 !~ /^total/ { name=$NF; size=$5; mtime=$6\" \"$7\" \"$8; printf \"%-48s  %10s  %s\\n\", name, size, mtime }'" + head_clause
        let out = exec(cmd)
        let hdr = if sort_flag == "size" { "(sort: size, largest first)" } else { "(sort: mtime, newest first)" }
        println("hexa cache list — " + dir + "  " + hdr)
        print(out)
        return
    }

    if sub == "verify" {
        // count + zero-size entries
        let cnt = exec("find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' \\n'")
        let empty = exec("find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f -size 0 2>/dev/null | wc -l | tr -d ' \\n'")
        let empty_list = exec("find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f -size 0 2>/dev/null | head -20")
        println("hexa cache verify — " + dir)
        println("  entries:        " + cnt)
        println("  empty/broken:   " + empty)
        if len(empty_list) > 0 {
            println("  empty entries (up to 20):")
            print(empty_list)
        }
        if empty != "0" { exit(1) }
        return
    }

    if sub == "clean" {
        let mut do_prune = false
        let mut older_days = ""
        let mut cap_mb = ""
        let mut ci = 1
        while ci < len(args) {
            let a = args[ci]
            if a == "--prune" {
                do_prune = true
            } else if a.starts_with("--older-than=") {
                older_days = a.substring(13, len(a))
            } else if a.starts_with("--cap-mb=") {
                cap_mb = a.substring(9, len(a))
            }
            ci = ci + 1
        }
        // Strategy: collect candidate paths via `find` filters, count + sum
        // bytes, then `xargs rm -f` iff --prune. Two policies stack:
        //   1. --older-than=N : `find -mtime +N`
        //   2. --cap-mb=M     : oldest-first prune until total size ≤ M MB
        let mut victims_cmd = "find " + shq(dir) + " -mindepth 1 -maxdepth 1 -type f"
        if len(older_days) > 0 {
            victims_cmd = victims_cmd + " -mtime +" + older_days
        }
        // For --cap-mb we want oldest-first up to running-sum > cap.
        let victims_file = exec("printf '/tmp/hexa_cache_victims.%s.txt' \"$$\"")
        if len(cap_mb) > 0 {
            // List all files oldest-first with sizes; awk accumulates from
            // newest backward; everything beyond cap is a victim.
            let cap_cmd = "ls -lt " + shq(dir) + " 2>/dev/null | awk 'NR>1 && $1 !~ /^total/ {print $5\" \"$NF}' | awk -v cap=" + cap_mb + " 'BEGIN{sum=0} {sum+=$1/1048576; if (sum>cap) print $2}' > " + victims_file
            let _ = exec(cap_cmd)
            // Merge into older_days victims if both — union.
            if len(older_days) > 0 {
                let _ = exec(victims_cmd + " -exec basename {} \\; >> " + victims_file)
                let _ = exec("sort -u -o " + victims_file + " " + victims_file)
            }
        } else {
            let _ = exec(victims_cmd + " -exec basename {} \\; > " + victims_file)
        }
        let n_victims = exec("wc -l < " + victims_file + " 2>/dev/null | tr -d ' \\n'")
        let sample = exec("head -10 " + victims_file + " 2>/dev/null")
        println("hexa cache clean — " + dir)
        println("  candidates:    " + n_victims)
        if len(older_days) > 0 { println("  filter:        --older-than=" + older_days + " (days)") }
        if len(cap_mb) > 0     { println("  filter:        --cap-mb=" + cap_mb) }
        if len(sample) > 0 {
            println("  sample (up to 10):")
            print(sample)
        }
        if do_prune {
            // Delete by basename → full path join in awk.
            let rm_cmd = "awk -v d=" + shq(dir) + " '{print d\"/\"$1}' " + victims_file + " | xargs rm -f 2>/dev/null"
            let _ = exec(rm_cmd)
            println("  PRUNED " + n_victims + " entries")
        } else {
            println("  (dry-run — pass --prune to delete)")
        }
        let _cl = exec("rm -f " + victims_file + " 2>/dev/null")
        return
    }

    println("error: unknown 'cache' subverb: " + sub)
    println("usage: hexa cache stat|list|verify|clean [...]")
    exit(2)
}

// ─── GO M10 — hexa daemon (RFC 093 Phase 1 / R1 prototype) ─────────────
//
// rfc_093_hexa_daemon.md § Phase plan R1: "socket protocol skeleton +
// verb dispatch (no compile yet)". This block lands the bare minimum:
//
//   - `hexa daemon start [--socket <path>] [--idle-ttl <sec>]`
//   - `hexa daemon start-bg [--socket <path>] [--idle-ttl <sec>]`
//   - `hexa daemon stop  [--socket <path>]`
//   - `hexa daemon status [--socket <path>]`
//   - `hexa daemon echo <text> [--socket <path>]`   (R1 loopback helper)
//
// Protocol (R1 skeleton — newline-terminated text · 1 request / conn):
//   PING            → PONG
//   ECHO <text>     → ECHO <text>
//   SHUTDOWN        → BYE   (server exits accept loop + unlinks socket)
//   <unknown>       → ERR unknown verb: <verb>
//
// R2+ upgrades the wire to length-prefixed JSON-RPC and adds the real
// {compile, run, cache_query, invalidate, status} method set. R1 wires
// only lifecycle + framing so subsequent rounds can layer logic without
// touching the verb / socket plumbing.

fn _daemon_default_socket() {
    // Per RFC §4.1: `/tmp/hexa-daemon-$UID.sock` — uid-scoped so two users on
    // a shared host get distinct sockets (F-DAEMON-5 isolation half). GO M13
    // (R4) wired the `os_getuid()` builtin so the path keys on the real numeric
    // uid rather than the spoofable `$USER` env var; `$USER` is the fallback
    // only when getuid is unavailable (should not happen on POSIX).
    // GO M12 (R3): `HEXA_DAEMON_SOCKET` override lets the autospawn path +
    // tests target an isolated socket (mirrors `--socket` for the verb).
    let _sov = env_var("HEXA_DAEMON_SOCKET")
    if len(_sov) > 0 { return _sov }
    let uid = os_getuid()
    if uid >= 0 { return "/tmp/hexa-daemon-" + to_string(uid) + ".sock" }
    let mut who = env_var("USER")
    if len(who) == 0 { who = "unknown" }
    return "/tmp/hexa-daemon-" + who + ".sock"
}

fn _daemon_parse_args(args, default_sock, default_ttl) {
    // Returns [socket_path, idle_ttl_str]. Recognises `--socket <path>` and
    // `--idle-ttl <sec>` flags anywhere in args (positional consumed).
    let mut sock_path = default_sock
    let mut ttl_str = default_ttl
    let mut i = 0
    while i < len(args) {
        let a = args[i]
        if a == "--socket" && i + 1 < len(args) {
            sock_path = args[i + 1]
            i = i + 2
            continue
        }
        if a == "--idle-ttl" && i + 1 < len(args) {
            ttl_str = args[i + 1]
            i = i + 2
            continue
        }
        i = i + 1
    }
    return [sock_path, ttl_str]
}

fn _daemon_socket_exists(sock_path) {
    // file_exists() (S_ISREG-only) returns false for socket inodes, so
    // probe via shell `test -e` which matches any inode type. Returns true
    // iff the socket file is present on disk.
    let r = exec("test -e " + shq(sock_path) + " && printf yes || printf no")
    return r == "yes"
}

fn _daemon_read_line(fd) {
    // net_read_n with terminator scan would be cleaner, but net_read's
    // single hxlcl_recv buffer is bounded at 4 KiB and reliably returns
    // the full client write for short R1 messages (< 100 B). Strip
    // trailing CR/LF so the caller sees a clean verb token.
    let raw = net_read(fd)
    let n = len(raw)
    if n == 0 { return "" }
    let mut end = n
    // trim trailing \n and \r
    while end > 0 {
        let c = raw.substring(end - 1, end)
        if c == "\n" || c == "\r" {
            end = end - 1
            continue
        }
        break
    }
    if end == n { return raw }
    return raw.substring(0, end)
}

fn _daemon_handle_line(line) {
    // R1 verb dispatcher — pure function, returns [reply_text, shutdown_flag]
    // (caller appends "\n" before write). 2-tuple over a map keeps the hot
    // path free of map_new / map_set runtime calls.
    let n = len(line)
    let mut out = ""
    let mut shutdown = 0
    if n == 0 {
        out = "ERR empty"
    } else if line == "PING" {
        out = "PONG"
    } else if line == "SHUTDOWN" {
        out = "BYE"
        shutdown = 1
    } else if n >= 5 && line.substring(0, 5) == "ECHO " {
        out = "ECHO " + line.substring(5, n)
    } else if line == "ECHO" {
        out = "ECHO "
    } else {
        // First token for the error reply — limit at first space.
        let mut tok_end = n
        let mut j = 0
        while j < n {
            if line.substring(j, j + 1) == " " {
                tok_end = j
                break
            }
            j = j + 1
        }
        out = "ERR unknown verb: " + line.substring(0, tok_end)
    }
    return [out, shutdown]
}

fn _daemon_send_line(sock_path, line) {
    // Connect → write line+\n → read response (4 KiB cap) → close.
    // Returns the response with trailing newline stripped, or "" on err.
    let addr = "unix:" + sock_path
    let fd = net_connect(addr)
    if fd < 0 { return "" }
    let _w = net_write(fd, line + "\n")
    let resp = _daemon_read_line(fd)
    let _c = net_close(fd)
    return resp
}

// ─── R2 (RFC 093 § Phase plan) — compile method + in-memory cache ──────
//
// The daemon's whole point (fork-storm internal axis) is to NOT fork the
// compiler on every call. R2 wires the first real method: `compile`. A
// client sends the source path, the daemon consults an in-process cache
// (path → built binary), and on miss builds ONCE then memoizes — so the
// 2nd+ request for the same source returns the cached binary path without
// re-running `hexa build`.
//
// Cache key is byte-IDENTICAL to cmd_run / cmd_build / _batch_run_one
// (sha256(source)[0:16] + "_" + version_str()) so daemon-built and
// fork-built binaries share the same ~/.hexa-cache/hexa_run.<key> slot
// (F-DAEMON-R2-3 determinism). M7's version_str-drift check guards this.
//
// Wire format: R2 keeps R1's newline-terminated text frame. RFC §4.1's
// binary u32-LE length-prefix is deferred to R3: the current runtime's
// net_read uses strlen(), so a length prefix whose high bytes are NUL
// (true for any small payload) would be truncated on the receive side —
// it needs a NUL-preserving net_read_raw builtin first. The `compile`
// verb is itself the framing upgrade for R2:
//
//   COMPILE <source_path>   → HIT <bin>    (in-memory cache hit, no build)
//                           → BUILT <bin>  (compiled this call + memoized)
//                           → ERR <reason> (build failed / bad request)

fn _daemon_cache_dir() {
    // Mirror cmd_run: compiled output lives under $HOME/.hexa-cache.
    let mut d = env_var("HOME") + "/.hexa-cache"
    if len(env_var("HOME")) == 0 { d = "./.hexa-cache" }
    return d
}

fn _daemon_compute_key(file) {
    // Byte-identical to cmd_run (self/main.hexa cmd_run site) — DO NOT
    // drift. sha256(source)[0:16] + "_" + version_str().
    let _src_hash = sha256_file(file)
    return _src_hash.substring(0, 16) + "_" + version_str()
}

fn _daemon_key_index(keys, key) {
    // Linear scan of the in-memory key array. Returns the matching index
    // or -1. Parallel arrays (keys/bins) over a runtime map: hexat
    // codegen doesn't reliably support map literals (see L3459), and the
    // cache is small (one entry per distinct source seen this session).
    let mut i = 0
    let n = len(keys)
    while i < n {
        if keys[i] == key { return i }
        i = i + 1
    }
    return -1
}

fn _daemon_build_binary(file, tmpbin) {
    // Compile <file> → tmpbin via `hexa build` (mirrors cmd_run's bcmd).
    // Returns 0 on success (binary present at tmpbin), non-zero rc on
    // failure. Uses the same install-dir-resolved hexa binary + inflight
    // rename so a concurrent peer build doesn't see a half-written file.
    let __inst_r = install_dir_from_argv0()
    let mut hexa_bin = ""
    if len(__inst_r) > 0 {
        let cand = __inst_r + "/hexa"
        if file_exists(cand) { hexa_bin = cand }
    }
    if len(hexa_bin) == 0 { hexa_bin = av[0] }
    let _tmp_inflight = tmpbin + ".tmp." + to_string(mono_ns())
    let bcmd = shq(hexa_bin) + " build " + shq(file) + " -o " + shq(_tmp_inflight) + " 2>&1; echo \"__HEXA_BRC__=$?\""
    let bout = exec(bcmd)
    let bmark = "__HEXA_BRC__="
    let bml = len(bmark)
    let mut bmi = -1
    let mut bsj = len(bout) - bml
    while bsj >= 0 {
        if bout.substring(bsj, bsj + bml) == bmark { bmi = bsj; bsj = -1 } else { bsj = bsj - 1 }
    }
    let mut brc = 1
    if bmi >= 0 {
        let mut rs = bout.substring(bmi + bml, len(bout))
        let rsl = len(rs)
        if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" { rs = rs.substring(0, rsl - 1) }
        brc = parse_int_str(rs)
    }
    if brc == 0 && file_exists(_tmp_inflight) {
        let _rn = exec("mv -f " + shq(_tmp_inflight) + " " + shq(tmpbin) + " 2>/dev/null")
    } else {
        let _cl = exec("rm -f " + shq(_tmp_inflight) + " 2>/dev/null")
    }
    if file_exists(tmpbin) { return 0 }
    return brc
}

// GO M14 (RFC 093 R4 · F-DAEMON-4) — atlas SSOT hash flush.
//
// PROBLEM: the daemon's in-memory cache key is sha256(source)[0:16] + "_" +
// version_str() (byte-identical to cmd_run — see _daemon_compute_key). It does
// NOT include the atlas SSOT hash. When a new node is folded into the atlas
// SSOT (compiler/atlas/embedded.gen.hexa), an atlas-citing source can compile
// to a DIFFERENT binary — but the daemon would return its stale memoized
// binary as a HIT (wrong result).
//
// FIX (Option B — daemon-only invalidation layer): the daemon hashes the
// atlas SSOT file and, when that hash changes vs the last observed value,
// flushes the entire in-memory cache (cache_keys / cache_bins). The next
// COMPILE for any source re-builds against the new atlas. cmd_run's key is
// UNCHANGED — no M7 drift-guard violation, no M2 precompile-lookup breakage.
// The flush is daemon-local and self-contained.
//
// We hash the file content (sha256_file) rather than mtime so a no-op `touch`
// does NOT spuriously flush (Option C's false-positive). Returns "" when the
// SSOT cannot be located (graceful — flush logic treats "" as "unknown", i.e.
// never flushes on a missing-atlas read so a transient resolution miss can't
// thrash the cache).

// Resolve the atlas SSOT path (compiler/atlas/embedded.gen.hexa) using the
// same precedence as the rest of the toolchain:
//   $HEXA_LANG > install_dir_from_argv0() > ./   (repo-root relative).
fn _daemon_atlas_ssot_path() {
    let rel = "/compiler/atlas/embedded.gen.hexa"
    let h = env_var("HEXA_LANG")
    if len(h) > 0 {
        let p = h + rel
        if file_exists(p) { return p }
    }
    let inst = install_dir_from_argv0()
    if len(inst) > 0 {
        let p = inst + rel
        if file_exists(p) { return p }
    }
    let cwd = "." + rel
    if file_exists(cwd) { return cwd }
    return ""
}

// Compute the current atlas SSOT content hash, or "" if the SSOT is not
// locatable. Short-form (first 16 hex chars) is enough to detect a fold.
fn _daemon_atlas_hash() {
    let p = _daemon_atlas_ssot_path()
    if len(p) == 0 { return "" }
    let full = sha256_file(p)
    if len(full) < 16 { return full }
    return full.substring(0, 16)
}

fn cmd_daemon_compile(sock_path, file) {
    // Client side of the compile method — connect, send `COMPILE <file>`,
    // print the daemon's reply (HIT/BUILT/ERR + binary path). The path is
    // emitted verbatim so a harness can `exec` it.
    if !_daemon_socket_exists(sock_path) {
        println("hexa daemon: not running (socket missing: " + sock_path + ")")
        exit(1)
    }
    let resp = _daemon_send_line(sock_path, "COMPILE " + file)
    println(resp)
}

fn cmd_daemon_status(sock_path) {
    if !_daemon_socket_exists(sock_path) {
        println("hexa daemon: not running (socket missing: " + sock_path + ")")
        exit(1)
    }
    let resp = _daemon_send_line(sock_path, "PING")
    if resp == "PONG" {
        println("hexa daemon: alive — " + sock_path)
        return
    }
    println("hexa daemon: socket present but not responding (got: " + resp + ")")
    exit(1)
}

fn cmd_daemon_stop(sock_path) {
    if !_daemon_socket_exists(sock_path) {
        println("hexa daemon: not running (socket missing: " + sock_path + ")")
        return
    }
    let resp = _daemon_send_line(sock_path, "SHUTDOWN")
    if resp == "BYE" {
        println("hexa daemon: shutdown acknowledged — " + sock_path)
        // Give the server a brief moment to unlink the socket file before
        // any follow-up status check. 250 ms is enough on local FS.
        sleep_ms(250)
        return
    }
    println("hexa daemon: stop request sent but no BYE (got: " + resp + ")")
    exit(1)
}

fn cmd_daemon_echo(sock_path, text) {
    if !_daemon_socket_exists(sock_path) {
        println("hexa daemon: not running (socket missing: " + sock_path + ")")
        exit(1)
    }
    let resp = _daemon_send_line(sock_path, "ECHO " + text)
    println(resp)
}

fn cmd_daemon_start(sock_path, idle_ttl_str) {
    // Foreground server loop — binds the unix socket and serves until
    // SHUTDOWN or idle TTL expiry. Caller wraps with `&` (or proc_fork)
    // for background spawn.
    //
    // R1 invariants:
    //   - 1 request per connection (no keepalive)
    //   - newline-terminated text frames
    //   - blocking accept with periodic idle-TTL check via net_set_nonblock
    //     + net_select on the listen fd
    //
    // RFC 093 §6.1 (F-DAEMON-5): the daemon is an arbitrary-code-execution
    // machine — the `compile`/`run` RPCs build + (R5) exec user code. A daemon
    // running as root is a privilege-escalation footgun, so refuse outright.
    // GO M13 (R4) wired `os_getuid()` to make this check real (was a no-op
    // comment in R1/R3 — no getuid builtin existed). Non-root proceeds; the
    // uid-scoped socket path + 0700 /tmp default keep cross-uid peers out.
    if os_getuid() == 0 {
        println("hexa daemon: refusing to run as root (uid 0) — RFC 093 §6.1")
        exit(1)
    }
    // Pre-flight: if a stale socket from a crashed prior daemon is on
    // disk, unlink it; otherwise bind would EADDRINUSE.
    let _rm = exec("rm -f " + shq(sock_path) + " 2>/dev/null")
    let addr = "unix:" + sock_path
    let listen_fd = net_listen(addr)
    if listen_fd < 0 {
        println("hexa daemon: bind failed for " + sock_path + " (errno=" + to_string(0 - listen_fd) + ")")
        exit(1)
    }
    // Parse TTL. 0 / empty / negative → no TTL (wait forever).
    let mut idle_ttl = 0
    if len(idle_ttl_str) > 0 {
        let mut k = 0
        let nn = len(idle_ttl_str)
        let mut acc = 0
        while k < nn {
            let cc = idle_ttl_str.substring(k, k + 1)
            let mut d = -1
            if cc == "0" { d = 0 }
            if cc == "1" { d = 1 }
            if cc == "2" { d = 2 }
            if cc == "3" { d = 3 }
            if cc == "4" { d = 4 }
            if cc == "5" { d = 5 }
            if cc == "6" { d = 6 }
            if cc == "7" { d = 7 }
            if cc == "8" { d = 8 }
            if cc == "9" { d = 9 }
            if d < 0 { break }
            acc = acc * 10 + d
            k = k + 1
        }
        idle_ttl = acc
    }
    let _nb = net_set_nonblock(listen_fd)
    // pid omitted from the listening banner — `getpid` lives in the
    // reserved POSIX name set (mangled to `u_getpid`) and isn't wired as
    // a hexa builtin yet. Callers can read PID from the spawn log if
    // needed (the bg path captures it via shell `$!`).
    println("hexa daemon: listening on " + sock_path + " (idle_ttl=" + to_string(idle_ttl) + "s)")
    let mut shutdown = false
    let mut last_activity_ns = mono_ns()
    let ns_per_sec = 1000000000
    // R2 in-memory compile cache — parallel arrays (key → binary path)
    // living for the daemon's whole lifetime. This is the fork-storm
    // payoff: COMPILE for a source seen earlier this session returns the
    // memoized binary path with NO `hexa build` fork.
    let mut cache_keys = []
    let mut cache_bins = []
    let _mkc = exec("mkdir -p " + shq(_daemon_cache_dir()) + " 2>/dev/null")
    // GO M14 (RFC 093 R4 · F-DAEMON-4) — atlas SSOT hash flush state.
    // last_atlas_hash records the atlas SSOT hash observed at the last check.
    // "" = not-yet-read / unresolvable (never triggers a flush). Checked at
    // most once per atlas_check_throttle_ns window, immediately before serving
    // a COMPILE — so an atlas fold mid-session invalidates the in-mem cache
    // before the next memoized HIT could return a stale binary. The throttle
    // keeps the sha256_file read off the hot path for back-to-back COMPILEs.
    let mut last_atlas_hash = _daemon_atlas_hash()
    let mut last_atlas_check_ns = mono_ns()
    // Throttle = 2 s default; `HEXA_DAEMON_ATLAS_THROTTLE_MS` env override (0 =
    // check every COMPILE — used by the F-DAEMON-4 test so the flush is
    // deterministic regardless of `sleep_ms` granularity). Production keeps the
    // sha256_file read off the hot path for back-to-back COMPILEs.
    let mut atlas_check_throttle_ns = 2 * ns_per_sec
    let _atlas_thr_env = env_var("HEXA_DAEMON_ATLAS_THROTTLE_MS")
    if len(_atlas_thr_env) > 0 {
        let _thr_ms = parse_int_str(_atlas_thr_env)
        if _thr_ms >= 0 { atlas_check_throttle_ns = _thr_ms * 1000000 }
    }
    while !shutdown {
        // Wait up to 1 second for an incoming connection.
        let ready = net_select([listen_fd], 1000)
        let nready = len(ready)
        if nready > 0 {
            let first = ready[0]
            if first < 0 {
                // -errno surfaced as single-element array. EINTR is benign;
                // anything else we surface but don't die — keep the loop alive.
                if first != (0 - 4) {
                    println("hexa daemon: select error " + to_string(0 - first))
                }
            } else {
                let client = net_accept(listen_fd)
                if client >= 0 {
                    let line = _daemon_read_line(client)
                    let mut reply = ""
                    let mut did_shutdown = 0
                    // R2 compile method — handled inline so it can mutate
                    // the in-memory cache arrays. All other verbs route to
                    // the pure R1 dispatcher.
                    let ln = len(line)
                    if ln >= 8 && line.substring(0, 8) == "COMPILE " {
                        // GO M14 (F-DAEMON-4) — throttled atlas SSOT hash check.
                        // If the atlas SSOT content hash changed since the last
                        // check (a node was folded into embedded.gen.hexa), drop
                        // the entire in-memory cache so this COMPILE re-builds
                        // against the new atlas instead of returning a stale HIT.
                        // A "" current-hash (SSOT unresolvable) is treated as
                        // "unknown" → never flushes (avoids cache thrash on a
                        // transient resolution miss).
                        let _atlas_now_ns = mono_ns()
                        if (_atlas_now_ns - last_atlas_check_ns) >= atlas_check_throttle_ns {
                            last_atlas_check_ns = _atlas_now_ns
                            let cur_atlas = _daemon_atlas_hash()
                            if len(cur_atlas) > 0 && len(last_atlas_hash) > 0 && cur_atlas != last_atlas_hash {
                                println("hexa daemon: atlas SSOT changed (" + last_atlas_hash + " -> " + cur_atlas + ") — flushing in-memory cache (" + to_string(len(cache_keys)) + " entries)")
                                // Also unlink the disk-mirror binaries for every
                                // flushed key. The cache key (sha256(source) +
                                // version_str) is unchanged by an atlas fold, so
                                // an un-removed ~/.hexa-cache binary would be
                                // re-found as a disk HIT on the very next COMPILE
                                // — still stale. Removing them forces a true
                                // re-build against the new atlas (F-DAEMON-4).
                                let mut _fi = 0
                                let _fn = len(cache_bins)
                                while _fi < _fn {
                                    let _rmb = exec("rm -f " + shq(cache_bins[_fi]) + " 2>/dev/null")
                                    _fi = _fi + 1
                                }
                                cache_keys = []
                                cache_bins = []
                            }
                            if len(cur_atlas) > 0 { last_atlas_hash = cur_atlas }
                        }
                        let cfile = line.substring(8, ln)
                        if !file_exists(cfile) {
                            reply = "ERR no such source: " + cfile
                        } else {
                            let key = _daemon_compute_key(cfile)
                            let tmpbin = _daemon_cache_dir() + "/hexa_run." + key
                            let idx = _daemon_key_index(cache_keys, key)
                            if idx >= 0 && file_exists(cache_bins[idx]) {
                                // In-memory HIT — no fork.
                                reply = "HIT " + cache_bins[idx]
                            } else if file_exists(tmpbin) {
                                // Disk HIT (warm ~/.hexa-cache from a prior
                                // process / call) — memoize in-memory, no fork.
                                if idx < 0 {
                                    cache_keys.push(key)
                                    cache_bins.push(tmpbin)
                                }
                                reply = "HIT " + tmpbin
                            } else {
                                // MISS — build once, then memoize + mirror.
                                let brc = _daemon_build_binary(cfile, tmpbin)
                                if brc == 0 && file_exists(tmpbin) {
                                    if idx < 0 {
                                        cache_keys.push(key)
                                        cache_bins.push(tmpbin)
                                    }
                                    reply = "BUILT " + tmpbin
                                } else {
                                    reply = "ERR build failed (rc=" + to_string(brc) + ") for " + cfile
                                }
                            }
                        }
                    } else {
                        let h = _daemon_handle_line(line)
                        reply = h[0]
                        did_shutdown = h[1]
                    }
                    let _w = net_write(client, reply + "\n")
                    let _c = net_close(client)
                    last_activity_ns = mono_ns()
                    if did_shutdown == 1 { shutdown = true }
                }
            }
        }
        // Idle TTL check (only when TTL > 0).
        if idle_ttl > 0 {
            let elapsed_ns = mono_ns() - last_activity_ns
            if elapsed_ns >= idle_ttl * ns_per_sec {
                println("hexa daemon: idle TTL reached — exiting")
                shutdown = true
            }
        }
    }
    let _close = net_close(listen_fd)
    let _unlink = exec("rm -f " + shq(sock_path) + " 2>/dev/null")
    println("hexa daemon: stopped")
}

fn cmd_daemon(args) {
    let sub = if len(args) >= 1 { args[0] } else { "help" }

    if sub == "help" || sub == "-h" || sub == "--help" {
        println("hexa daemon — long-running compile server (RFC 093 · R2)")
        println("")
        println("USAGE")
        println("  hexa daemon start    [--socket <path>] [--idle-ttl <sec>]")
        println("  hexa daemon start-bg [--socket <path>] [--idle-ttl <sec>]")
        println("  hexa daemon stop     [--socket <path>]")
        println("  hexa daemon status   [--socket <path>]")
        println("  hexa daemon echo <text>      [--socket <path>]")
        println("  hexa daemon compile <file.hexa> [--socket <path>]")
        println("")
        println("  Default socket path: /tmp/hexa-daemon-$UID.sock  (uid-scoped · RFC 093 §6.1)")
        println("  Default idle TTL:    0  (no auto-exit)")
        println("")
        println("R2/R4 SCOPE  (RFC 093 § Phase plan)")
        println("  compile method + in-memory cache (path → built binary).")
        println("  COMPILE <src> → HIT <bin> (memoized) | BUILT <bin> | ERR <reason>.")
        println("  Cache key byte-identical to `hexa run` (~/.hexa-cache mirror).")
        println("  R4 (F-DAEMON-4): atlas SSOT hash flush — a fold into")
        println("  compiler/atlas/embedded.gen.hexa auto-flushes the in-mem cache")
        println("  (+ disk mirror) on the next COMPILE so no stale binary is served.")
        println("  HEXA_DAEMON_ATLAS_THROTTLE_MS env: atlas-check throttle (default")
        println("  2000 ms; 0 = check every COMPILE).")
        return
    }

    // Slice off the subverb; remaining args feed _daemon_parse_args.
    let mut rest = []
    let mut ri = 1
    while ri < len(args) {
        rest.push(args[ri])
        ri = ri + 1
    }
    let default_sock = _daemon_default_socket()

    if sub == "start" {
        let pa = _daemon_parse_args(rest, default_sock, "0")
        cmd_daemon_start(pa[0], pa[1])
        return
    }
    if sub == "start-bg" {
        let pa = _daemon_parse_args(rest, default_sock, "0")
        // Fork + exec self as `hexa daemon start ...`. We use the shell
        // backgrounding form rather than proc_fork() so stdout/stderr are
        // detached (caller would otherwise see daemon log lines mixed in).
        // The parent returns immediately; the child runs cmd_daemon_start.
        let log_path = pa[0] + ".log"
        let cmd = "nohup " + shq(argv0_or_hexa()) + " daemon start --socket " + shq(pa[0]) + " --idle-ttl " + shq(pa[1]) + " > " + shq(log_path) + " 2>&1 &"
        let _r = exec(cmd)
        // Brief settle so the child has time to bind before the caller
        // probes via `hexa daemon status`.
        sleep_ms(200)
        println("hexa daemon: spawned (socket=" + pa[0] + " log=" + log_path + ")")
        return
    }
    if sub == "stop" {
        let pa = _daemon_parse_args(rest, default_sock, "0")
        cmd_daemon_stop(pa[0])
        return
    }
    if sub == "status" {
        let pa = _daemon_parse_args(rest, default_sock, "0")
        cmd_daemon_status(pa[0])
        return
    }
    if sub == "echo" {
        // First non-flag arg = text. Flags eaten by _daemon_parse_args.
        let mut text = ""
        let mut ej = 0
        while ej < len(rest) {
            let a = rest[ej]
            if a == "--socket" || a == "--idle-ttl" {
                ej = ej + 2
                continue
            }
            text = a
            break
        }
        let pa = _daemon_parse_args(rest, default_sock, "0")
        cmd_daemon_echo(pa[0], text)
        return
    }
    if sub == "compile" {
        // First non-flag arg = source file. Flags eaten by _daemon_parse_args.
        let mut cfile = ""
        let mut cj = 0
        while cj < len(rest) {
            let a = rest[cj]
            if a == "--socket" || a == "--idle-ttl" {
                cj = cj + 2
                continue
            }
            cfile = a
            break
        }
        if len(cfile) == 0 {
            println("error: `hexa daemon compile` needs a source file")
            exit(2)
        }
        let pa = _daemon_parse_args(rest, default_sock, "0")
        cmd_daemon_compile(pa[0], cfile)
        return
    }

    println("error: unknown 'daemon' subverb: " + sub)
    println("usage: hexa daemon start|start-bg|stop|status|echo|compile [...]")
    exit(2)
}

// argv0_or_hexa() returns the running binary's invocation path, with a
// fallback to bare "hexa" on PATH. Used by `daemon start-bg` to spawn a
// detached copy of the same driver.
fn argv0_or_hexa() {
    // Prefer the actual invocation path (args()[0]) when it points at a
    // real on-disk binary — this re-spawns the EXACT driver that's running
    // (correct in dev worktrees, renamed binaries, etc.). Only fall back
    // to install-dir / $HEXA_LANG / PATH `hexa` when argv[0] is unusable.
    let av0 = args()
    if len(av0) > 0 {
        let exe = av0[0]
        if len(exe) > 0 && file_exists(exe) { return exe }
    }
    let __i = install_dir_from_argv0()
    if len(__i) > 0 {
        let candidate = __i + "/hexa"
        if file_exists(candidate) { return candidate }
    }
    let __hxroot = env_var("HEXA_LANG")
    if len(__hxroot) > 0 {
        let candidate2 = __hxroot + "/hexa"
        if file_exists(candidate2) { return candidate2 }
    }
    return "hexa"
}

// PROBE r14 wiring (#453 follow-up): `hexa typecheck <file>` runs hexat with
// the HEXA_TYPECHECK env set so the emitted hexa-cc main runs type_check_and_emit
// between parse and codegen. The .c output is sent to /tmp and discarded — the
// user-visible signal is the stderr warn/error stream (1322-warning corpus until
// migration). Exits 0 even with warnings (#453 is warn-not-error).
fn cmd_typecheck(src) {
    let src_exists = exec("test -f '" + src + "' && printf yes || printf no")
    if src_exists != "yes" {
        println("error: source file not found: " + src)
        exit(1)
    }
    let v2 = resolve_or_bootstrap_hexat()
    if len(v2) == 0 {
        die_no_hexat()
    }
    let tmp_c = exec("printf '/tmp/hexa_typecheck.%s.c' \"$$\"")
    let trans = "HEXA_TYPECHECK=1 " + v2 + " '" + src + "' '" + tmp_c + "' 2>&1"
    let pair = exec_with_status(trans)
    let r = pair[0]
    let rc = pair[1]
    let _rm = exec("rm -f '" + tmp_c + "' 2>/dev/null")
    if rc != 0 || r.contains("Parse error") {
        println(r)
        exit(1)
    }
    if len(r) > 0 {
        println(r)
    }
    println("OK: " + src + " — typecheck complete")
}

fn cmd_parse(src) {
    let src_exists = exec("test -f '" + src + "' && printf yes || printf no")
    if src_exists != "yes" {
        println("error: source file not found: " + src)
        exit(1)
    }
    let v2 = resolve_or_bootstrap_hexat()
    if len(v2) == 0 {
        die_no_hexat()
    }
    // /tmp/hexa_parse_check.<PID>.c — 셸 PID 로 충돌 회피.
    let tmp_c = exec("printf '/tmp/hexa_parse_check.%s.c' \"$$\"")
    let trans = v2 + " '" + src + "' '" + tmp_c + "' 2>&1"
    let pair = exec_with_status(trans)
    let r = pair[0]
    let rc = pair[1]
    // 정리 — 생성되었든 안 되었든 best-effort.
    let _rm = exec("rm -f '" + tmp_c + "' 2>/dev/null")
    // 파서 실패 판정 — in-process, 셸 아웃 금지:
    //   · hexat 는 "Parse error" 를 찍어도 exit 0 (codegen best-effort) 하므로
    //     출력 문자열로 판정한다.
    //   · parser hard-fail (auto-invoke 충돌 `exit(1)` 등) 은 비정상 종료
    //     코드로 잡는다.
    //   r 을 셸 명령에 보간하면 r 안의 백틱 / `$()` / `$VAR` 가 재평가되어
    //   가짜 `sh:` 진단이 새어 나온다 — `.contains` 로 in-process 판정.
    let has_err = rc != 0 || r.contains("Parse error")
    if has_err {
        // 원본 stderr/stdout 재출력 (사용자가 라인/컬럼 정보를 볼 수 있도록).
        println(r)
        exit(1)
    }
    println("OK: " + src + " parses cleanly")
}

// == Entry ==
// RFC 062: hexa_set_args no longer doubles argv[0] — the runtime args()
// contract is now the clean [exec, sub, user-args...] layout. This CLI
// dispatcher was written against the historical [exec, exec, sub, ...] shape
// (av[0]=exec, av[2]=subcommand, av[3..]=sub-args). `av` is re-derived with
// argv[0] inserted once so the ~40 dispatch index sites stay correct without
// a behavior-neutral mass reindex — a file-local index convention, NOT the
// runtime duplication (that is removed). A later cosmetic cycle may reindex
// this dispatcher (zero behavior change). See RFC 062 / ROADMAP child 65.
let mut av: [string] = []
let _av_raw = args()
if len(_av_raw) > 0 {
    av.push(_av_raw[0])
    let mut _avi = 0
    while _avi < len(_av_raw) {
        av.push(_av_raw[_avi])
        _avi = _avi + 1
    }
}

// ─── busybox-pattern argv0 dispatch ───
// <user-home>/.hx/shared/bin/<name> is a symlink to the hexa binary.
// When invoked as that name, av[0] basename != "hexa" — we redirect to
// tool/cmd_<name>.hexa (or special cases) via `hexa run`.
let mut argv0_shim = ""
if len(av) > 0 {
    let av0 = av[0]
    // basename(av0)
    let mut slash = -1
    let mut bi = len(av0) - 1
    while bi >= 0 {
        if av0.substring(bi, bi + 1) == "/" {
            slash = bi
            bi = -1
        } else {
            bi = bi - 1
        }
    }
    let av0_base = if slash >= 0 { av0.substring(slash + 1, len(av0)) } else { av0 }
    // self-name 스킵 — hexa 바이너리 본인 이름 계열.
    // 1) "hexa" prefix — hexa, hexat, hexa_new, hexa.bak...
    // 2) common aliases — "main" only ("interp" removed post-R7,
    //    [[feedback_no_interp_use_compiled]]: build/hexa_interp 미빌드 →
    //    argv0 basename 가 "interp" 일 수 없음).
    let mut is_self = false
    if len(av0_base) >= 4 && av0_base.substring(0, 4) == "hexa" { is_self = true }
    if av0_base == "main" { is_self = true }
    if !is_self && len(av0_base) > 0 {
        argv0_shim = av0_base
    }
}

if len(argv0_shim) > 0 {
    // Resolve handler — prefer tool/cmd_<name>.hexa, then special cases.
    let inst_dir = install_dir_from_argv0()
    let mut repo = inst_dir
    if len(repo) == 0 {
        repo = exec("pwd 2>/dev/null | tr -d '\\n'")
    }
    let conv_path = repo + "/tool/cmd_" + argv0_shim + ".hexa"
    let conv_chk = exec("test -f '" + conv_path + "' && printf yes || printf no")
    let mut handler_path = ""
    if conv_chk == "yes" {
        handler_path = conv_path
    } else {
        // fallback: special cases
        if argv0_shim == "doctor" {
            handler_path = repo + "/tool/doctor.hexa"
        } else if argv0_shim == "watchd" {
            handler_path = repo + "/tool/watchd.hexa"
        } else if argv0_shim == "install-os" || argv0_shim == "install_os" {
            handler_path = repo + "/tool/install_os.hexa"
        }
    }
    if len(handler_path) == 0 {
        println("unknown shim command: " + argv0_shim)
        exit(1)
    }
    let handler_chk = exec("test -f '" + handler_path + "' && printf yes || printf no")
    if handler_chk != "yes" {
        println("shim handler not found: " + handler_path)
        exit(1)
    }
    // Re-invoke this binary as `hexa run <handler>` forwarding user args.
    // av[0] = shim path; prefer resolved canonical hexa binary.
    let mut hexa_bin = repo + "/hexa"
    let hb_chk = exec("test -x '" + hexa_bin + "' && printf yes || printf no")
    if hb_chk != "yes" {
        // fallback to argv0 (may be symlink — os executes it anyway).
        hexa_bin = av[0]
    }
    // Build command: <hexa_bin> run <handler> <user args starting at av[2]>
    // Args are shell-quoted via single-quote wrapping + ' -> '\'' escape.
    let mut cmd = "'" + hexa_bin + "' run '" + handler_path + "'"
    let mut ai = 2
    while ai < len(av) {
        let a = av[ai]
        // single-quote escape
        let mut qp: [string] = []
        let mut qi = 0
        while qi < len(a) {
            let ch = a.substring(qi, qi + 1)
            if ch == "'" {
                qp.push("'\\''")
            } else {
                qp.push(ch)
            }
            qi = qi + 1
        }
        cmd = cmd + " '" + qp.join("") + "'"
        ai = ai + 1
    }
    // Stream through — use system(); exec() captures stdout but we want
    // interactive passthrough. Use `sh -c 'cmd >&2' || true`-free path:
    // simplest = exec() and print result, propagating non-zero via grep.
    let out = exec(cmd + " 2>&1; echo \"__HEXA_SHIM_RC__=$?\"")
    // Extract trailing rc marker
    let marker = "__HEXA_SHIM_RC__="
    let mlen = len(marker)
    let mut midx = -1
    let mut si = len(out) - mlen
    while si >= 0 {
        if out.substring(si, si + mlen) == marker {
            midx = si
            si = -1
        } else {
            si = si - 1
        }
    }
    if midx >= 0 {
        let body = out.substring(0, midx)
        let rc_str = out.substring(midx + mlen, len(out))
        print(body)
        let rc = parse_int_str(rc_str)
        exit(rc)
    } else {
        println(out)
        exit(0)
    }
}
