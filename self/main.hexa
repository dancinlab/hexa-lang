    } else if sub == "loop" {
        // RFC 065 — stdlib/loop/cycle.hexa dispatch.
        // 8-stage self-growing atlas cycle (SCAN · LENS · DEDUP · GATE ·
        // FIRE · DRAFT · AUDIT · EXHAUST?) with binary built-in lens table
        // sibling to atlas (compiler/lenses/embedded.gen.hexa). Output goes
        // to archive/{atlas,lens}_candidates/ — PR-only, never direct fold.
        // Phase B-2.1: cycle/end state-file I/O wired.
        // Phase B-3   : this verb dispatch (current commit).
        // Phase C     : lens bodies + first archive/atlas_candidates/ PR.
        let __inst_lp = install_dir_from_argv0()
        let mut lp_args = []
        let mut lpi = 3
        while lpi < len(av) {
            lp_args.push(av[lpi])
            lpi = lpi + 1
        }
        let mut lp_script = "stdlib/loop/cycle.hexa"
        if len(__inst_lp) > 0 {
            let inst_path = __inst_lp + "/stdlib/loop/cycle.hexa"
            if file_exists(inst_path) { lp_script = inst_path }
        }
        cmd_run(lp_script, lp_args)
    } else if sub == "cache" {
        // GO M4 (2026-05-25): `hexa cache <subverb>` — 1st-class verb over
        // `~/.hexa-cache/`. Pre-M4 the only way to inspect / prune was raw
        // shell (`ls ~/.hexa-cache/ | wc -l`, `du -sh`, `rm`); this brings
        // parity with `go clean -cache(-n)`. See cmd_cache above for the
        // 4 subverbs (stat · list · verify · clean).
        let mut ca_args = []
        let mut cai = 3
        while cai < len(av) {
            ca_args.push(av[cai])
            cai = cai + 1
        }
        cmd_cache(ca_args)
    } else if sub == "daemon" {
        // GO M10/M11 (2026-05-25) — rfc_093 R1+R2. `hexa daemon
        // {start,start-bg,stop,status,echo,compile}` over a per-user unix
        // socket (default /tmp/hexa-daemon-$USER.sock). R1 = socket + verb
        // + lifecycle skeleton; R2 = `compile` method + in-memory cache
        // (path → built binary, byte-identical ~/.hexa-cache key). See
        // cmd_daemon above and rfc_093_hexa_daemon.md § Phase plan for the
        // R3-R4 continuation (multi-session latency → prod ship).
        let mut dm_args = []
        let mut dmi = 3
        while dmi < len(av) {
            dm_args.push(av[dmi])
            dmi = dmi + 1
        }
        cmd_daemon(dm_args)
    } else if sub == "gpu" {
        // GPU.md §7c — toolchain ergonomics. `hexa gpu fire <ptx> <host.c>
        // [target-host]` wraps the recurring remote-fire pattern (scp →
        // nvcc → run → pull result.json). See cmd_gpu() above for the
        // pipeline; default target host = "ubu-2" (RTX 5070 sm_120).
        let mut gpu_args = []
        let mut gpi = 3
        while gpi < len(av) {
            gpu_args.push(av[gpi])
            gpi = gpi + 1
        }
        cmd_gpu(gpu_args)
    } else if sub == "tool" {
        // CANON M4: go-tool-style drawer. `hexa tool [list]` indexes the
        // specialized verbs by family; `hexa tool <verb> [args]` re-dispatches
        // to `hexa <verb> [args]` (the bare verb still works — non-breaking).
        cmd_tool(av)
    } else if is_absorbed_verb(sub) {
        // nexus absorption surface (2026-05-13 final consolidation):
        //
        //   • 29 annotation analyzers     → tool/hexa_annot/hexa-<name>  (bash)
        //   • Phase 2 verifiers   (3)     → compiler/{honesty,absolute,meta_closure}/check.hexa
        //   • Phase 2 generators  (3)     → compiler/{smash,free,hyperarithmetic}/<name>.hexa
        //   • Phase 3 drill chain (13)    → compiler/{drill,chain,omega,surge,dream,swarm,
        //                                   reign,molt,wake,forge,canon_engine,debate,revive}/<name>.hexa
        //   • Phase 4 external    (19)    → compiler/{hw_probes,kick,bridges}/<name>.hexa
        //
        // Annotation tools are bash; the rest are .hexa modules invoked via
        // cmd_run (install-dir resolved via install_dir_from_argv0(), with
        // cwd fallback for in-repo runs). Library modules without a `main()`
        // entry will error at cmd_run time — that's the deferred CLI-shim
        // surface; the dispatch wiring itself is what this branch establishes.
        let mut ab_args = []
        let mut abi = 3
        while abi < len(av) { ab_args.push(av[abi]); abi = abi + 1 }
        dispatch_absorbed(sub, ab_args)
    } else if ends_with_dot_hexa(sub) {
        // 호환 모드: `hexa foo.hexa [args...]` → `hexa run foo.hexa [args...]`
        // python/node 스타일. go/cargo 처럼 엄격하지 않지만 생태계 보존.
        // bt 39: 호환 모드도 av[3..] 를 스크립트로 전달.
        let mut compat_args = []
        let mut ci = 3
        while ci < len(av) {
            compat_args.push(av[ci])
            ci = ci + 1
        }
        cmd_run(sub, compat_args)
    } else {
        println("error: unknown subcommand '" + sub + "'")
        cmd_help()
    }
}
