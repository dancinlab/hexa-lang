#!hexa lax
// RFC 071 P3 runtime activation Path B probe.
// Project-root `use "..."` style matches the convention in test/*_smoke.hexa
// and the `use` chain inside compiler/atlas/static_index.hexa (project-root
// resolution + dedupe across multiple importers). The earlier
// `import "../compiler/..."` form trip-wired the module_loader to load
// compiler/atlas/parser.hexa TWICE (once via absolute path expansion,
// once via project-root expansion from static_index's own `use` chain) —
// causing duplicate `struct AtlasNode` typedefs in the generated C.
use "compiler/lex/lexer"
use "compiler/parse/parser"
use "compiler/lower/ast_to_hir"
use "compiler/lower/hir_to_mir"
use "compiler/atlas/static_index"
use "compiler/ir/mir"
use "compiler/codegen/nvptx_target"
// ═══════════════════════════════════════════════════════════
//  self/main.hexa — HEXA CLI 엔트리 (go/cargo 스타일)
//
//  서브커맨드:
//    hexa run <file> [args...]    스크립트 실행 (compile-then-exec; interp R7 retired)
//    hexa build <file> [-o out]   .hexa → 네이티브 바이너리
//    hexa cc                      트랜스파일러(hexa_cc) 재빌드
//    hexa status                  툴체인 상태
//    hexa version                 버전
//    hexa help                    도움말
//
//  빌드 체인 (go/rust 부트스트랩 패턴):
//    dispatch = hexat self/main.hexa -> main.c -> clang -> 루트 ./hexa
//    stage2 = ./hexa build self/main.hexa -> stage2 비교 (fixpoint)
//
//  골화 레지스트리: $ANIMA/shared/hexa/hexa_toolchain.json
//    (CLI dispatcher + hexa_cc 전체 포괄)
//    ossified[]/stable[]/failing[] 3섹션. 수정 시 해당 섹션 업데이트.
//  런타임 병목 추적: doc/runtime_bottlenecks.json
// ═══════════════════════════════════════════════════════════

fn version_str() {
    return "0.1.0-dispatch"
}

