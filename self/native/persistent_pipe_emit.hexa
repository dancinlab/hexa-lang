#!hexa strict
// self/native/persistent_pipe_emit.hexa
//   B9.C-10 (.c-text · #1848 pattern) — persistent_pipe.c source emitter.
//
// runtime.c #include "native/persistent_pipe.c" — RFC 061 amalgamation fragment
// (NOT a standalone TU; references runtime.c-internal symbols). This emitter
// is the SSOT; the build regenerates self/native/persistent_pipe.c from it before
// runtime.c compiles, so the .c becomes a gitignored build artifact.
//
// Byte-identity: regenerated C is byte-for-byte the hand-written source, so
// the runtime.c TU (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// Invocation:  hexa-run self/native/persistent_pipe_emit.hexa <output-path>
// Default output path (if argv missing): "persistent_pipe.c" in cwd.
//
// Phase: B9.C-10 batch (self/native runtime.c-included .c-text · F3).

let MODULE_NAME = "persistent_pipe_emit"

fn emit_persistent_pipe_c() -> str {
    // Verbatim content of hand-written self/native/persistent_pipe.c
    let s =
            "/* self/native/persistent_pipe.c\n" +
            " *\n" +
            " * ω-runtime-1 Phase A — persistent-pipe primitive (2026-04-26).\n" +
            " *\n" +
            " * Five new builtins (handle-based bidirectional child-process API):\n" +
            " *\n" +
            " *   hexa_pipe_spawn(cmd)               : str        → int   handle id (≥0) or -1\n" +
            " *   hexa_pipe_send_line(h, payload)    : int, str   → bool  true on full write\n" +
            " *   hexa_pipe_recv_line(h, timeout_ms) : int, int   → str   line (\\n trimmed) or \"\"\n" +
            " *   hexa_pipe_close(h)                 : int        → bool  true on clean close\n" +
            " *   hexa_pipe_alive(h)                 : int        → bool  child still running\n" +
            " *\n" +
            " * Maps onto the existing hexa_exec_capture (pipe+fork+execvp+dup2)\n" +
            " * pattern from runtime.c:6010 — about 60% reusable. Difference: keeps\n" +
            " * pipes open after hxlcl_fork() instead of draining-then-closing them, and\n" +
            " * exposes the parent ends through a static handle table.\n" +
            " *\n" +
            " * Design doc: /Users/ghost/core/anima/state/omega_runtime_1_persistent_pipe_design.json\n" +
            " *\n" +
            " * Lifecycle:\n" +
            " *   - Soft cap: min(RLIMIT_NOFILE/4, 64) concurrent live handles.\n" +
            " *     Each handle eats 2 fds (stdin pipe write-end, stdout pipe read-end).\n" +
            " *   - hxlcl_close(h): SIGTERM → 100ms grace → SIGKILL → waitpid → free slot.\n" +
            " *   - atexit handler: SIGTERM all live, sleep 50ms, SIGKILL, hxlcl_waitpid(WNOHANG).\n" +
            " *\n" +
            " * v1 limitations (per design):\n" +
            " *   - line-protocol-only on recv: response >PIPE_BUF (4KB darwin) risks deadlock\n" +
            " *     for the worker if its newline-flush is delayed; the audio-worker NDJSON\n" +
            " *     responses are <256B so this is safe for the immediate consumer.\n" +
            " *   - stderr inherited (not separately captured); matches design.\n" +
            " *   - synchronous per handle (one in-flight req); concurrency across handles is\n" +
            " *     the user's problem.\n" +
            " *\n" +
            " * Included from self/runtime.c via #include \"native/persistent_pipe.c\"\n" +
            " * analogous to net.c / signal_flock.c / exec_argv_sha256.c.\n" +
            " */\n" +
            "\n" +
            "#include <stdio.h>\n" +
            "#include <stdlib.h>\n" +
            "#include <string.h>\n" +
            "#include <stdint.h>\n" +
            "#include <unistd.h>\n" +
            "#include <fcntl.h>\n" +
            "#include <errno.h>\n" +
            "#include <signal.h>\n" +
            "#include <poll.h>\n" +
            "#include <time.h>\n" +
            "#include <sys/types.h>\n" +
            "#include <sys/wait.h>\n" +
            "#include <sys/resource.h>\n" +
            "\n" +
            "/* ── handle table ───────────────────────────────────────────── */\n" +
            "\n" +
            "typedef struct {\n" +
            "    pid_t  pid;          /* 0 = free slot */\n" +
            "    int    stdin_fd;     /* parent write-end → child stdin */\n" +
            "    int    stdout_fd;    /* parent read-end  ← child stdout */\n" +
            "    int    state;        /* 0=free, 1=live, 2=dead-pending-close */\n" +
            "    int    last_exit;    /* captured exit code (waitpid) */\n" +
            "} HexaChild;\n" +
            "\n" +
            "#define HXP_MAX_HANDLES 64\n" +
            "\n" +
            "static HexaChild g_pipe_table[HXP_MAX_HANDLES];\n" +
            "static int       g_pipe_table_inited = 0;\n" +
            "static int       g_pipe_atexit_installed = 0;\n" +
            "\n" +
            "static long _hxp_now_ms(void) {\n" +
            "    struct timespec ts;\n" +
            "    hxlcl_clock_gettime(CLOCK_MONOTONIC, &ts);\n" +
            "    return (long)ts.tv_sec * 1000L + (long)(ts.tv_nsec / 1000000L);\n" +
            "}\n" +
            "\n" +
            "static void _hxp_sleep_ms(int ms) {\n" +
            "    struct timespec ts;\n" +
            "    ts.tv_sec  = ms / 1000;\n" +
            "    ts.tv_nsec = (long)(ms % 1000) * 1000000L;\n" +
            "    hxlcl_nanosleep(&ts, NULL);\n" +
            "}\n" +
            "\n" +
            "static void _hxp_atexit_cleanup(void) {\n" +
            "    for (int i = 0; i < HXP_MAX_HANDLES; i++) {\n" +
            "        HexaChild* c = &g_pipe_table[i];\n" +
            "        if (c->state == 1 && c->pid > 0) {\n" +
            "            if (c->stdin_fd  >= 0) { hxlcl_close(c->stdin_fd);  c->stdin_fd  = -1; }\n" +
            "            hxlcl_kill(c->pid, SIGTERM);\n" +
            "        }\n" +
            "    }\n" +
            "    /* short grace period for SIGTERM */\n" +
            "    _hxp_sleep_ms(50);\n" +
            "    for (int i = 0; i < HXP_MAX_HANDLES; i++) {\n" +
            "        HexaChild* c = &g_pipe_table[i];\n" +
            "        if (c->state == 1 && c->pid > 0) {\n" +
            "            hxlcl_kill(c->pid, SIGKILL);\n" +
            "            hxlcl_waitpid(c->pid, NULL, WNOHANG);\n" +
            "            if (c->stdout_fd >= 0) { hxlcl_close(c->stdout_fd); c->stdout_fd = -1; }\n" +
            "            c->state = 0;\n" +
            "        }\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "static void _hxp_init_table(void) {\n" +
            "    if (g_pipe_table_inited) return;\n" +
            "    for (int i = 0; i < HXP_MAX_HANDLES; i++) {\n" +
            "        g_pipe_table[i].pid       = 0;\n" +
            "        g_pipe_table[i].stdin_fd  = -1;\n" +
            "        g_pipe_table[i].stdout_fd = -1;\n" +
            "        g_pipe_table[i].state     = 0;\n" +
            "        g_pipe_table[i].last_exit = 0;\n" +
            "    }\n" +
            "    g_pipe_table_inited = 1;\n" +
            "    if (!g_pipe_atexit_installed) {\n" +
            "        hxlcl_atexit(_hxp_atexit_cleanup);\n" +
            "        g_pipe_atexit_installed = 1;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "static int _hxp_max_handles(void) {\n" +
            "    /* soft cap = min(RLIMIT_NOFILE/4, HXP_MAX_HANDLES). */\n" +
            "    struct rlimit rl;\n" +
            "    int cap = HXP_MAX_HANDLES;\n" +
            "    if (hxlcl_getrlimit(RLIMIT_NOFILE, &rl) == 0 && rl.rlim_cur > 0) {\n" +
            "        int soft = (int)(rl.rlim_cur / 4);\n" +
            "        if (soft > 0 && soft < cap) cap = soft;\n" +
            "    }\n" +
            "    if (cap < 1) cap = 1;\n" +
            "    return cap;\n" +
            "}\n" +
            "\n" +
            "static int _hxp_alloc_slot(void) {\n" +
            "    int cap = _hxp_max_handles();\n" +
            "    for (int i = 0; i < cap; i++) {\n" +
            "        if (g_pipe_table[i].state == 0 && g_pipe_table[i].pid == 0) return i;\n" +
            "    }\n" +
            "    return -1;\n" +
            "}\n" +
            "\n" +
            "static HexaChild* _hxp_slot(int h) {\n" +
            "    if (h < 0 || h >= HXP_MAX_HANDLES) return NULL;\n" +
            "    return &g_pipe_table[h];\n" +
            "}\n" +
            "\n" +
            "static HexaChild* _hxp_live(int h) {\n" +
            "    HexaChild* c = _hxp_slot(h);\n" +
            "    if (!c) return NULL;\n" +
            "    if (c->state != 1) return NULL;\n" +
            "    return c;\n" +
            "}\n" +
            "\n" +
            "/* ── spawn ──────────────────────────────────────────────────── */\n" +
            "\n" +
            "HexaVal hexa_pipe_spawn(HexaVal cmd_val) {\n" +
            "    _hxp_init_table();\n" +
            "    if (!HX_IS_STR(cmd_val) || !HX_STR(cmd_val)) return hexa_int(-1);\n" +
            "    const char* cmd = HX_STR(cmd_val);\n" +
            "\n" +
            "    int slot = _hxp_alloc_slot();\n" +
            "    if (slot < 0) return hexa_int(-1);\n" +
            "\n" +
            "    int in_pipe[2], out_pipe[2];\n" +
            "    if (hxlcl_pipe(in_pipe) != 0) return hexa_int(-1);\n" +
            "    if (hxlcl_pipe(out_pipe) != 0) {\n" +
            "        hxlcl_close(in_pipe[0]); hxlcl_close(in_pipe[1]);\n" +
            "        return hexa_int(-1);\n" +
            "    }\n" +
            "\n" +
            "    // 2026-05-06 — POSIX fork buffer flush (parent stdio inherited by child)\n" +
            "    fflush(NULL);\n" +
            "    pid_t pid = hxlcl_fork();\n" +
            "    if (pid < 0) {\n" +
            "        hxlcl_close(in_pipe[0]);  hxlcl_close(in_pipe[1]);\n" +
            "        hxlcl_close(out_pipe[0]); hxlcl_close(out_pipe[1]);\n" +
            "        return hexa_int(-1);\n" +
            "    }\n" +
            "    if (pid == 0) {\n" +
            "        /* child */\n" +
            "        hxlcl_dup2(in_pipe[0],  0);\n" +
            "        hxlcl_dup2(out_pipe[1], 1);\n" +
            "        hxlcl_close(in_pipe[0]);  hxlcl_close(in_pipe[1]);\n" +
            "        hxlcl_close(out_pipe[0]); hxlcl_close(out_pipe[1]);\n" +
            "        hxlcl_execl(\"/bin/sh\", \"sh\", \"-c\", cmd, (char*)NULL);\n" +
            "        _exit(127);\n" +
            "    }\n" +
            "\n" +
            "    /* parent */\n" +
            "    hxlcl_close(in_pipe[0]);   /* parent doesn't read from stdin pipe */\n" +
            "    hxlcl_close(out_pipe[1]);  /* parent doesn't write to stdout pipe */\n" +
            "\n" +
            "    /* Probe for early-exec failure: poll stdout pipe for EOF / waitpid\n" +
            "     * the child up to ~60ms total. If child died with non-zero exit\n" +
            "     * (typically 127 from /bin/sh: command not found), surface as -1.\n" +
            "     * This gives spawn() of a nonexistent command a clean failure path\n" +
            "     * (matches design \"spawn returns -1 on error\"). */\n" +
            "    int status = 0;\n" +
            "    pid_t r = 0;\n" +
            "    for (int probe = 0; probe < 6; probe++) {\n" +
            "        _hxp_sleep_ms(10);\n" +
            "        r = hxlcl_waitpid(pid, &status, WNOHANG);\n" +
            "        if (r == pid) break;\n" +
            "    }\n" +
            "    if (r == pid) {\n" +
            "        /* child already exited — likely exec failure */\n" +
            "        int ec = WIFEXITED(status) ? WEXITSTATUS(status)\n" +
            "              : (WIFSIGNALED(status) ? 128 + WTERMSIG(status) : -1);\n" +
            "        if (ec != 0) {\n" +
            "            /* non-zero exit during spawn-probe window → treat as failure.\n" +
            "             * Most commonly /bin/sh -c 'nonexistent_cmd' exits 127. */\n" +
            "            hxlcl_close(in_pipe[1]);\n" +
            "            hxlcl_close(out_pipe[0]);\n" +
            "            return hexa_int(-1);\n" +
            "        }\n" +
            "        /* child exited cleanly — keep the slot so caller can recv any\n" +
            "         * already-buffered output; record exit code. */\n" +
            "        HexaChild* c = &g_pipe_table[slot];\n" +
            "        c->pid = pid;\n" +
            "        c->stdin_fd = in_pipe[1];\n" +
            "        c->stdout_fd = out_pipe[0];\n" +
            "        c->state = 2; /* dead-pending-close */\n" +
            "        c->last_exit = ec;\n" +
            "        return hexa_int(slot);\n" +
            "    }\n" +
            "\n" +
            "    HexaChild* c = &g_pipe_table[slot];\n" +
            "    c->pid = pid;\n" +
            "    c->stdin_fd = in_pipe[1];\n" +
            "    c->stdout_fd = out_pipe[0];\n" +
            "    c->state = 1;\n" +
            "    c->last_exit = 0;\n" +
            "    return hexa_int(slot);\n" +
            "}\n" +
            "\n" +
            "/* ── send_line ──────────────────────────────────────────────── */\n" +
            "\n" +
            "HexaVal hexa_pipe_send_line(HexaVal h_val, HexaVal payload_val) {\n" +
            "    _hxp_init_table();\n" +
            "    if (!HX_IS_INT(h_val)) return hexa_int(0);\n" +
            "    int h = (int)HX_INT(h_val);\n" +
            "    HexaChild* c = _hxp_live(h);\n" +
            "    if (!c) return hexa_int(0);\n" +
            "    if (c->stdin_fd < 0) return hexa_int(0);\n" +
            "    const char* p = HX_IS_STR(payload_val) && HX_STR(payload_val) ? HX_STR(payload_val) : \"\";\n" +
            "    size_t n = strlen(p);\n" +
            "    /* write payload then trailing '\\n'. Tolerate short writes via loop. */\n" +
            "    size_t off = 0;\n" +
            "    while (off < n) {\n" +
            "        ssize_t w = hxlcl_write(c->stdin_fd, p + off, n - off);\n" +
            "        if (w < 0) {\n" +
            "            if (errno == EINTR) continue;\n" +
            "            c->state = 2;\n" +
            "            return hexa_int(0);\n" +
            "        }\n" +
            "        if (w == 0) { c->state = 2; return hexa_int(0); }\n" +
            "        off += (size_t)w;\n" +
            "    }\n" +
            "    const char nl = '\\n';\n" +
            "    while (1) {\n" +
            "        ssize_t w = hxlcl_write(c->stdin_fd, &nl, 1);\n" +
            "        if (w == 1) break;\n" +
            "        if (w < 0) {\n" +
            "            if (errno == EINTR) continue;\n" +
            "            c->state = 2;\n" +
            "            return hexa_int(0);\n" +
            "        }\n" +
            "    }\n" +
            "    return hexa_int(1);\n" +
            "}\n" +
            "\n" +
            "/* ── recv_line ──────────────────────────────────────────────── */\n" +
            "\n" +
            "HexaVal hexa_pipe_recv_line(HexaVal h_val, HexaVal timeout_val) {\n" +
            "    _hxp_init_table();\n" +
            "    if (!HX_IS_INT(h_val)) return hexa_str(\"\");\n" +
            "    int h = (int)HX_INT(h_val);\n" +
            "    HexaChild* c = _hxp_slot(h);\n" +
            "    if (!c) return hexa_str(\"\");\n" +
            "    if (c->state == 0) return hexa_str(\"\");\n" +
            "    if (c->stdout_fd < 0) return hexa_str(\"\");\n" +
            "\n" +
            "    long timeout_ms = HX_IS_INT(timeout_val) ? (long)HX_INT(timeout_val) : 5000;\n" +
            "    if (timeout_ms < 0) timeout_ms = 0;\n" +
            "\n" +
            "    long t0 = _hxp_now_ms();\n" +
            "    size_t cap = 256, len = 0;\n" +
            "    char* buf = (char*)malloc(cap);\n" +
            "    if (!buf) return hexa_str(\"\");\n" +
            "\n" +
            "    while (1) {\n" +
            "        long elapsed = _hxp_now_ms() - t0;\n" +
            "        long remain = timeout_ms - elapsed;\n" +
            "        if (remain < 0) remain = 0;\n" +
            "\n" +
            "        struct pollfd pfd;\n" +
            "        pfd.fd = c->stdout_fd;\n" +
            "        pfd.events = POLLIN;\n" +
            "        pfd.revents = 0;\n" +
            "        int pr = hxlcl_poll(&pfd, 1, (int)remain);\n" +
            "        if (pr == 0) {\n" +
            "            /* timeout — return whatever we accumulated (may be partial) */\n" +
            "            if (len == 0) { free(buf); return hexa_str(\"\"); }\n" +
            "            buf[len] = '\\0';\n" +
            "            return hexa_str_own(buf);\n" +
            "        }\n" +
            "        if (pr < 0) {\n" +
            "            if (errno == EINTR) continue;\n" +
            "            free(buf);\n" +
            "            return hexa_str(\"\");\n" +
            "        }\n" +
            "        /* data ready (or EOF on hangup) — read 1 byte to avoid over-read past '\\n' */\n" +
            "        char ch;\n" +
            "        ssize_t rd = hxlcl_read(c->stdout_fd, &ch, 1);\n" +
            "        if (rd == 0) {\n" +
            "            /* EOF — child closed stdout, likely exited */\n" +
            "            int status = 0;\n" +
            "            pid_t wr = hxlcl_waitpid(c->pid, &status, WNOHANG);\n" +
            "            if (wr == c->pid) {\n" +
            "                c->last_exit = WIFEXITED(status) ? WEXITSTATUS(status)\n" +
            "                              : (WIFSIGNALED(status) ? 128 + WTERMSIG(status) : -1);\n" +
            "                c->state = 2;\n" +
            "            }\n" +
            "            if (len == 0) { free(buf); return hexa_str(\"\"); }\n" +
            "            buf[len] = '\\0';\n" +
            "            return hexa_str_own(buf);\n" +
            "        }\n" +
            "        if (rd < 0) {\n" +
            "            if (errno == EINTR) continue;\n" +
            "            free(buf);\n" +
            "            return hexa_str(\"\");\n" +
            "        }\n" +
            "        if (ch == '\\n') {\n" +
            "            buf[len] = '\\0';\n" +
            "            return hexa_str_own(buf);\n" +
            "        }\n" +
            "        if (len + 1 >= cap) {\n" +
            "            cap *= 2;\n" +
            "            char* nb = (char*)realloc(buf, cap);\n" +
            "            if (!nb) { free(buf); return hexa_str(\"\"); }\n" +
            "            buf = nb;\n" +
            "        }\n" +
            "        buf[len++] = ch;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ── close ──────────────────────────────────────────────────── */\n" +
            "\n" +
            "HexaVal hexa_pipe_close(HexaVal h_val) {\n" +
            "    _hxp_init_table();\n" +
            "    if (!HX_IS_INT(h_val)) return hexa_int(0);\n" +
            "    int h = (int)HX_INT(h_val);\n" +
            "    HexaChild* c = _hxp_slot(h);\n" +
            "    if (!c) return hexa_int(0);\n" +
            "    if (c->state == 0) return hexa_int(0);\n" +
            "\n" +
            "    if (c->stdin_fd  >= 0) { hxlcl_close(c->stdin_fd);  c->stdin_fd  = -1; }\n" +
            "    if (c->state == 1 && c->pid > 0) {\n" +
            "        hxlcl_kill(c->pid, SIGTERM);\n" +
            "        int reaped = 0;\n" +
            "        for (int i = 0; i < 10; i++) {\n" +
            "            int status = 0;\n" +
            "            pid_t r = hxlcl_waitpid(c->pid, &status, WNOHANG);\n" +
            "            if (r == c->pid) {\n" +
            "                c->last_exit = WIFEXITED(status) ? WEXITSTATUS(status)\n" +
            "                              : (WIFSIGNALED(status) ? 128 + WTERMSIG(status) : -1);\n" +
            "                reaped = 1;\n" +
            "                break;\n" +
            "            }\n" +
            "            _hxp_sleep_ms(10);\n" +
            "        }\n" +
            "        if (!reaped) {\n" +
            "            hxlcl_kill(c->pid, SIGKILL);\n" +
            "            int status = 0;\n" +
            "            hxlcl_waitpid(c->pid, &status, 0);\n" +
            "            c->last_exit = WIFEXITED(status) ? WEXITSTATUS(status)\n" +
            "                          : (WIFSIGNALED(status) ? 128 + WTERMSIG(status) : -1);\n" +
            "        }\n" +
            "    } else if (c->state == 2 && c->pid > 0) {\n" +
            "        /* child already dead, just reap if we haven't yet */\n" +
            "        int status = 0;\n" +
            "        hxlcl_waitpid(c->pid, &status, WNOHANG);\n" +
            "    }\n" +
            "    if (c->stdout_fd >= 0) { hxlcl_close(c->stdout_fd); c->stdout_fd = -1; }\n" +
            "    c->state = 0;\n" +
            "    c->pid = 0;\n" +
            "    return hexa_int(1);\n" +
            "}\n" +
            "\n" +
            "/* ── alive ──────────────────────────────────────────────────── */\n" +
            "\n" +
            "HexaVal hexa_pipe_alive(HexaVal h_val) {\n" +
            "    _hxp_init_table();\n" +
            "    if (!HX_IS_INT(h_val)) return hexa_int(0);\n" +
            "    int h = (int)HX_INT(h_val);\n" +
            "    HexaChild* c = _hxp_slot(h);\n" +
            "    if (!c) return hexa_int(0);\n" +
            "    if (c->state != 1) return hexa_int(0);\n" +
            "    if (c->pid <= 0) return hexa_int(0);\n" +
            "    /* Reap if child has exited (non-blocking). */\n" +
            "    int status = 0;\n" +
            "    pid_t r = hxlcl_waitpid(c->pid, &status, WNOHANG);\n" +
            "    if (r == c->pid) {\n" +
            "        c->last_exit = WIFEXITED(status) ? WEXITSTATUS(status)\n" +
            "                      : (WIFSIGNALED(status) ? 128 + WTERMSIG(status) : -1);\n" +
            "        c->state = 2;\n" +
            "        return hexa_int(0);\n" +
            "    }\n" +
            "    /* Probe with hxlcl_kill(pid, 0) — distinguishes alive vs unreachable. */\n" +
            "    if (hxlcl_kill(c->pid, 0) != 0) {\n" +
            "        c->state = 2;\n" +
            "        return hexa_int(0);\n" +
            "    }\n" +
            "    return hexa_int(1);\n" +
            "}\n" +
            "\n" +
            "/* ── TAG_FN shim globals ────────────────────────────────────── */\n" +
            "\n" +
            "HexaVal hx_pipe_spawn;\n" +
            "HexaVal hx_pipe_send_line;\n" +
            "HexaVal hx_pipe_recv_line;\n" +
            "HexaVal hx_pipe_close;\n" +
            "HexaVal hx_pipe_alive;\n" +
            "\n" +
            "static void _hexa_init_persistent_pipe_fn_shims(void) {\n" +
            "    hx_pipe_spawn     = hexa_fn_new((void*)hexa_pipe_spawn,     1);\n" +
            "    hx_pipe_send_line = hexa_fn_new((void*)hexa_pipe_send_line, 2);\n" +
            "    hx_pipe_recv_line = hexa_fn_new((void*)hexa_pipe_recv_line, 2);\n" +
            "    hx_pipe_close     = hexa_fn_new((void*)hexa_pipe_close,     1);\n" +
            "    hx_pipe_alive     = hexa_fn_new((void*)hexa_pipe_alive,     1);\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "persistent_pipe.c" }
    let c_text = emit_persistent_pipe_c()
    let cmd = "cat > \"" + out_path + "\" <<'PERSISTENT_PIPE_EMIT_EOF'\n" +
              c_text + "PERSISTENT_PIPE_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[persistent_pipe_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[persistent_pipe_emit] wrote " + out_path)
    exit(0)
}
