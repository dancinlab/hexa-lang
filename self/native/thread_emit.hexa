#!hexa strict
// self/native/thread_emit.hexa
//   B9.C-10 (.c-text · #1848 pattern) — thread.c source emitter.
//
// runtime.c #include "native/thread.c" — RFC 061 amalgamation fragment
// (NOT a standalone TU; references runtime.c-internal symbols). This emitter
// is the SSOT; the build regenerates self/native/thread.c from it before
// runtime.c compiles, so the .c becomes a gitignored build artifact.
//
// Byte-identity: regenerated C is byte-for-byte the hand-written source, so
// the runtime.c TU (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// Invocation:  hexa-run self/native/thread_emit.hexa <output-path>
// Default output path (if argv missing): "thread.c" in cwd.
//
// Phase: B9.C-10 batch (self/native runtime.c-included .c-text · F3).

let MODULE_NAME = "thread_emit"

fn emit_thread_c() -> str {
    // Verbatim content of hand-written self/native/thread.c
    let s =
            "/* self/native/thread.c — POSIX pthread + channel primitives.\n" +
            " *\n" +
            " * Included from self/runtime.c via `#include \"native/thread.c\"`.\n" +
            " *\n" +
            " * Symbols exported (8 primitives via TAG_FN shims):\n" +
            " *   hexa_thread_spawn(fn_closure, arg) → tid (int >= 0) or -errno\n" +
            " *   hexa_thread_join(tid)              → result HexaVal (or \"\" on error)\n" +
            " *   hexa_channel_new()                 → ch_id (int >= 0) or -errno\n" +
            " *   hexa_channel_send(ch, val)         → 0 ok / -errno\n" +
            " *   hexa_channel_recv(ch, timeout_ms)  → val or \"\" sentinel (on timeout/closed)\n" +
            " *   hexa_channel_close(ch)             → 0 ok / -errno\n" +
            " *   hexa_sleep_ms(ms)                  → 0 (frame-budget friendly sleep)\n" +
            " *   hexa_now_ms()                      → current monotonic time in ms (int)\n" +
            " *\n" +
            " * RFC: ~/core/hexa-lang/incoming/patches/thread-channel-primitive.md\n" +
            " * Motivation: anima daemon Phase 2 (CHAT.md rev 2) — 60+ FPS frame loop\n" +
            " * needs inference offloaded to background worker thread (chat_generate\n" +
            " * ~30s/token on Mac CPU 24L) while frame_loop @ 16ms tick continues.\n" +
            " *\n" +
            " * Slot tables fixed-size (THREAD_MAX=64, CHANNEL_MAX=256, CHANNEL_CAP=1024).\n" +
            " * MVP scope — anima N<10 animas × M<100 client subscribers comfortably fits.\n" +
            " */\n" +
            "\n" +
            "#include <pthread.h>\n" +
            "#include <stdlib.h>\n" +
            "#include <string.h>\n" +
            "#include <errno.h>\n" +
            "#include <time.h>\n" +
            "\n" +
            "#define HEXA_THREAD_MAX     64\n" +
            "#define HEXA_CHANNEL_MAX    256\n" +
            "#define HEXA_CHANNEL_CAP    1024\n" +
            "\n" +
            "/* === Channel state === */\n" +
            "typedef struct HexaChannel_ {\n" +
            "    HexaVal slots[HEXA_CHANNEL_CAP];\n" +
            "    int head;\n" +
            "    int tail;\n" +
            "    int count;\n" +
            "    int closed;\n" +
            "    pthread_mutex_t lock;\n" +
            "    pthread_cond_t not_empty;\n" +
            "    pthread_cond_t not_full;\n" +
            "} HexaChannel;\n" +
            "\n" +
            "static HexaChannel* g_channels[HEXA_CHANNEL_MAX];\n" +
            "static pthread_mutex_t g_channels_lock = PTHREAD_MUTEX_INITIALIZER;\n" +
            "\n" +
            "/* === Thread state === */\n" +
            "typedef struct HexaThreadSlot_ {\n" +
            "    pthread_t tid;\n" +
            "    int active;\n" +
            "    HexaVal fn_val;\n" +
            "    HexaVal arg_val;\n" +
            "    HexaVal result;\n" +
            "    int started;\n" +
            "    int finished;\n" +
            "    pthread_mutex_t done_lock;\n" +
            "    pthread_cond_t done_cv;\n" +
            "} HexaThreadSlot;\n" +
            "\n" +
            "static HexaThreadSlot g_threads[HEXA_THREAD_MAX];\n" +
            "static pthread_mutex_t g_threads_lock = PTHREAD_MUTEX_INITIALIZER;\n" +
            "\n" +
            "/* === Thread entry — invokes closure via runtime's call mechanism === */\n" +
            "static void* _hexa_thread_entry(void* arg) {\n" +
            "    HexaThreadSlot* slot = (HexaThreadSlot*)arg;\n" +
            "    /* Use hexa_call1 if available (closure dispatch). 1-arg invocation.\n" +
            "     * NOTE: This routes through the HexaVal fn dispatch path. The fn_val\n" +
            "     * must be a TAG_FN HexaVal (closure or fn ptr). */\n" +
            "    HexaVal r = hexa_call1(slot->fn_val, slot->arg_val);\n" +
            "    hxlcl_pthread_mutex_lock(&slot->done_lock);\n" +
            "    slot->result = r;\n" +
            "    slot->finished = 1;\n" +
            "    hxlcl_pthread_cond_broadcast(&slot->done_cv);\n" +
            "    hxlcl_pthread_mutex_unlock(&slot->done_lock);\n" +
            "    return NULL;\n" +
            "}\n" +
            "\n" +
            "/* hexa_thread_spawn(fn_val, arg) → tid (>= 0) or -errno */\n" +
            "HexaVal hexa_thread_spawn(HexaVal fn_val, HexaVal arg_val) {\n" +
            "    hxlcl_pthread_mutex_lock(&g_threads_lock);\n" +
            "    int idx = -1;\n" +
            "    for (int i = 0; i < HEXA_THREAD_MAX; i++) {\n" +
            "        if (!g_threads[i].active) { idx = i; break; }\n" +
            "    }\n" +
            "    if (idx < 0) {\n" +
            "        hxlcl_pthread_mutex_unlock(&g_threads_lock);\n" +
            "        return hexa_int(-EAGAIN);\n" +
            "    }\n" +
            "    g_threads[idx].fn_val   = fn_val;\n" +
            "    g_threads[idx].arg_val  = arg_val;\n" +
            "    g_threads[idx].result   = hexa_str(\"\");\n" +
            "    g_threads[idx].started  = 1;\n" +
            "    g_threads[idx].finished = 0;\n" +
            "    hxlcl_pthread_mutex_init(&g_threads[idx].done_lock, NULL);\n" +
            "    hxlcl_pthread_cond_init(&g_threads[idx].done_cv, NULL);\n" +
            "    g_threads[idx].active = 1;\n" +
            "    if (hxlcl_pthread_create(&g_threads[idx].tid, NULL, _hexa_thread_entry, &g_threads[idx]) != 0) {\n" +
            "        int e = errno;\n" +
            "        g_threads[idx].active = 0;\n" +
            "        hxlcl_pthread_mutex_destroy(&g_threads[idx].done_lock);\n" +
            "        hxlcl_pthread_cond_destroy(&g_threads[idx].done_cv);\n" +
            "        hxlcl_pthread_mutex_unlock(&g_threads_lock);\n" +
            "        return hexa_int(-e);\n" +
            "    }\n" +
            "    hxlcl_pthread_mutex_unlock(&g_threads_lock);\n" +
            "    return hexa_int(idx);\n" +
            "}\n" +
            "\n" +
            "/* hexa_thread_join(tid) → result HexaVal (or \"\" on error) */\n" +
            "HexaVal hexa_thread_join(HexaVal tid_val) {\n" +
            "    if (!HX_IS_INT(tid_val)) return hexa_str(\"\");\n" +
            "    int idx = (int)HX_INT(tid_val);\n" +
            "    if (idx < 0 || idx >= HEXA_THREAD_MAX) return hexa_str(\"\");\n" +
            "    HexaThreadSlot* slot = &g_threads[idx];\n" +
            "    if (!slot->active) return hexa_str(\"\");\n" +
            "    /* (void*)(uintptr_t) cast bridges pthread_t platform divergence: Mac\n" +
            "       arm64 pthread_t is a pointer (compiles bare), Linux glibc pthread_t\n" +
            "       is unsigned long (bare pass = incompatible-int-to-ptr error). The\n" +
            "       hxlcl_pthread_join param is unused, so the cast is purely to satisfy\n" +
            "       the strict-clang type check on both platforms. */\n" +
            "    if (hxlcl_pthread_join((void *)(uintptr_t)slot->tid, NULL) != 0) return hexa_str(\"\");\n" +
            "    HexaVal r = slot->result;\n" +
            "    hxlcl_pthread_mutex_lock(&g_threads_lock);\n" +
            "    hxlcl_pthread_mutex_destroy(&slot->done_lock);\n" +
            "    hxlcl_pthread_cond_destroy(&slot->done_cv);\n" +
            "    slot->active = 0;\n" +
            "    hxlcl_pthread_mutex_unlock(&g_threads_lock);\n" +
            "    return r;\n" +
            "}\n" +
            "\n" +
            "/* === Channel === */\n" +
            "HexaVal hexa_channel_new(void) {\n" +
            "    hxlcl_pthread_mutex_lock(&g_channels_lock);\n" +
            "    int idx = -1;\n" +
            "    for (int i = 0; i < HEXA_CHANNEL_MAX; i++) {\n" +
            "        if (g_channels[i] == NULL) { idx = i; break; }\n" +
            "    }\n" +
            "    if (idx < 0) {\n" +
            "        hxlcl_pthread_mutex_unlock(&g_channels_lock);\n" +
            "        return hexa_int(-EAGAIN);\n" +
            "    }\n" +
            "    HexaChannel* ch = (HexaChannel*)calloc(1, sizeof(HexaChannel));\n" +
            "    if (!ch) {\n" +
            "        hxlcl_pthread_mutex_unlock(&g_channels_lock);\n" +
            "        return hexa_int(-ENOMEM);\n" +
            "    }\n" +
            "    hxlcl_pthread_mutex_init(&ch->lock, NULL);\n" +
            "    hxlcl_pthread_cond_init(&ch->not_empty, NULL);\n" +
            "    hxlcl_pthread_cond_init(&ch->not_full, NULL);\n" +
            "    g_channels[idx] = ch;\n" +
            "    hxlcl_pthread_mutex_unlock(&g_channels_lock);\n" +
            "    return hexa_int(idx);\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_channel_send(HexaVal ch_val, HexaVal v) {\n" +
            "    if (!HX_IS_INT(ch_val)) return hexa_int(-EINVAL);\n" +
            "    int idx = (int)HX_INT(ch_val);\n" +
            "    if (idx < 0 || idx >= HEXA_CHANNEL_MAX || !g_channels[idx]) return hexa_int(-EBADF);\n" +
            "    HexaChannel* ch = g_channels[idx];\n" +
            "    hxlcl_pthread_mutex_lock(&ch->lock);\n" +
            "    while (ch->count == HEXA_CHANNEL_CAP && !ch->closed) {\n" +
            "        hxlcl_pthread_cond_wait(&ch->not_full, &ch->lock);\n" +
            "    }\n" +
            "    if (ch->closed) {\n" +
            "        hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "        return hexa_int(-EPIPE);\n" +
            "    }\n" +
            "    ch->slots[ch->tail] = v;\n" +
            "    ch->tail = (ch->tail + 1) % HEXA_CHANNEL_CAP;\n" +
            "    ch->count++;\n" +
            "    hxlcl_pthread_cond_signal(&ch->not_empty);\n" +
            "    hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "    return hexa_int(0);\n" +
            "}\n" +
            "\n" +
            "/* hexa_channel_recv(ch, timeout_ms) → val OR \"\" sentinel\n" +
            " *   timeout_ms < 0  : block indefinitely\n" +
            " *   timeout_ms = 0  : non-blocking peek\n" +
            " *   timeout_ms > 0  : block up to that long\n" +
            " */\n" +
            "HexaVal hexa_channel_recv(HexaVal ch_val, HexaVal timeout_ms_val) {\n" +
            "    if (!HX_IS_INT(ch_val)) return hexa_str(\"\");\n" +
            "    int idx = (int)HX_INT(ch_val);\n" +
            "    if (idx < 0 || idx >= HEXA_CHANNEL_MAX || !g_channels[idx]) return hexa_str(\"\");\n" +
            "    HexaChannel* ch = g_channels[idx];\n" +
            "    long long ms = HX_IS_INT(timeout_ms_val) ? (long long)HX_INT(timeout_ms_val) : -1;\n" +
            "    hxlcl_pthread_mutex_lock(&ch->lock);\n" +
            "    if (ms == 0 && ch->count == 0) {\n" +
            "        hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "        return hexa_str(\"\");\n" +
            "    }\n" +
            "    if (ms < 0) {\n" +
            "        while (ch->count == 0 && !ch->closed) {\n" +
            "            hxlcl_pthread_cond_wait(&ch->not_empty, &ch->lock);\n" +
            "        }\n" +
            "    } else if (ms > 0) {\n" +
            "        struct timespec ts;\n" +
            "        hxlcl_clock_gettime(CLOCK_REALTIME, &ts);\n" +
            "        ts.tv_sec  += ms / 1000;\n" +
            "        ts.tv_nsec += (ms % 1000) * 1000000;\n" +
            "        if (ts.tv_nsec >= 1000000000) { ts.tv_sec++; ts.tv_nsec -= 1000000000; }\n" +
            "        while (ch->count == 0 && !ch->closed) {\n" +
            "            int rc = hxlcl_pthread_cond_timedwait(&ch->not_empty, &ch->lock, &ts);\n" +
            "            if (rc == ETIMEDOUT) {\n" +
            "                hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "                return hexa_str(\"\");\n" +
            "            }\n" +
            "        }\n" +
            "    }\n" +
            "    if (ch->count == 0 && ch->closed) {\n" +
            "        hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "        return hexa_str(\"\");\n" +
            "    }\n" +
            "    HexaVal v = ch->slots[ch->head];\n" +
            "    ch->head = (ch->head + 1) % HEXA_CHANNEL_CAP;\n" +
            "    ch->count--;\n" +
            "    hxlcl_pthread_cond_signal(&ch->not_full);\n" +
            "    hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_channel_close(HexaVal ch_val) {\n" +
            "    if (!HX_IS_INT(ch_val)) return hexa_int(-EINVAL);\n" +
            "    int idx = (int)HX_INT(ch_val);\n" +
            "    if (idx < 0 || idx >= HEXA_CHANNEL_MAX || !g_channels[idx]) return hexa_int(-EBADF);\n" +
            "    HexaChannel* ch = g_channels[idx];\n" +
            "    hxlcl_pthread_mutex_lock(&ch->lock);\n" +
            "    ch->closed = 1;\n" +
            "    hxlcl_pthread_cond_broadcast(&ch->not_empty);\n" +
            "    hxlcl_pthread_cond_broadcast(&ch->not_full);\n" +
            "    hxlcl_pthread_mutex_unlock(&ch->lock);\n" +
            "    return hexa_int(0);\n" +
            "}\n" +
            "\n" +
            "/* === Time helpers ===\n" +
            " * hexa_sleep_ms already exists in runtime.c (returns hexa_void); we reuse via\n" +
            " * TAG_FN shim. Only hexa_now_ms is new (anima frame loop wall-clock query).\n" +
            " */\n" +
            "HexaVal hexa_now_ms(void) {\n" +
            "    struct timespec ts;\n" +
            "    hxlcl_clock_gettime(CLOCK_MONOTONIC, &ts);\n" +
            "    long long ms = (long long)ts.tv_sec * 1000LL + (long long)(ts.tv_nsec / 1000000LL);\n" +
            "    return hexa_int((int64_t)ms);\n" +
            "}\n" +
            "\n" +
            "/* === TAG_FN shim globals ===\n" +
            " *\n" +
            " * 2026-05-13 PM: The pthread+condvar channel primitives use `thread_channel_*`\n" +
            " * names to avoid clobbering the older `stdlib/channel.hexa` FD-pipe channels\n" +
            " * (`pub fn channel_send(fd, msg)` etc.) — both APIs are otherwise valid and\n" +
            " * have separate use cases. wilson's swarm/jsonl_pool uses the FD variant;\n" +
            " * anima's frame-loop ↔ inference-worker bridge (the RFC motivation) uses\n" +
            " * these pthread variants. Distinct names = no clang \"redefinition of\n" +
            " * 'channel_close' as different kind of symbol\" link error when both end up\n" +
            " * in the same downstream binary.\n" +
            " */\n" +
            "HexaVal thread_spawn;\n" +
            "HexaVal thread_join;\n" +
            "HexaVal thread_channel_new;\n" +
            "HexaVal thread_channel_send;\n" +
            "HexaVal thread_channel_recv;\n" +
            "HexaVal thread_channel_close;\n" +
            "HexaVal sleep_ms;\n" +
            "HexaVal now_ms;\n" +
            "\n" +
            "static void _hexa_init_thread_fn_shims(void) {\n" +
            "    thread_spawn         = hexa_fn_new((void*)hexa_thread_spawn,         2);\n" +
            "    thread_join          = hexa_fn_new((void*)hexa_thread_join,          1);\n" +
            "    thread_channel_new   = hexa_fn_new((void*)hexa_channel_new,          0);\n" +
            "    thread_channel_send  = hexa_fn_new((void*)hexa_channel_send,         2);\n" +
            "    thread_channel_recv  = hexa_fn_new((void*)hexa_channel_recv,         2);\n" +
            "    thread_channel_close = hexa_fn_new((void*)hexa_channel_close,        1);\n" +
            "    sleep_ms             = hexa_fn_new((void*)hexa_sleep_ms,             1);\n" +
            "    now_ms               = hexa_fn_new((void*)hexa_now_ms,               0);\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "thread.c" }
    let c_text = emit_thread_c()
    let cmd = "cat > \"" + out_path + "\" <<'THREAD_EMIT_EOF'\n" +
              c_text + "THREAD_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[thread_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[thread_emit] wrote " + out_path)
    exit(0)
}
