#!hexa strict
// self/native/proc_fork_emit.hexa
//   B9.C-10 (.c-text · #1848 pattern) — proc_fork.c source emitter.
//
// runtime.c #include "native/proc_fork.c" — RFC 061 amalgamation fragment
// (NOT a standalone TU; references runtime.c-internal symbols). This emitter
// is the SSOT; the build regenerates self/native/proc_fork.c from it before
// runtime.c compiles, so the .c becomes a gitignored build artifact.
//
// Byte-identity: regenerated C is byte-for-byte the hand-written source, so
// the runtime.c TU (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// Invocation:  hexa-run self/native/proc_fork_emit.hexa <output-path>
// Default output path (if argv missing): "proc_fork.c" in cwd.
//
// Phase: B9.C-10 batch (self/native runtime.c-included .c-text · F3).

let MODULE_NAME = "proc_fork_emit"

fn emit_proc_fork_c() -> str {
    // Verbatim content of hand-written self/native/proc_fork.c
    let s =
            "/* self/native/proc_fork.c -- hxlcl_fork() + setsid() + sigchld reap helpers.\n" +
            " *\n" +
            " * Included from self/runtime.c (NOT a standalone TU).\n" +
            " *\n" +
            " * Exports (codegen direct-emit):\n" +
            " *   hexa_proc_fork() -> int (0 in child, child_pid in parent, -1 on error)\n" +
            " *   hexa_proc_setsid() -> int (new sid or -errno)\n" +
            " *   hexa_proc_reap_zombies() -> int (count of reaped zombies)\n" +
            " */\n" +
            "\n" +
            "#include <sys/types.h>\n" +
            "#include <sys/wait.h>\n" +
            "#include <unistd.h>\n" +
            "#include <errno.h>\n" +
            "\n" +
            "HexaVal hexa_proc_fork(void) {\n" +
            "    pid_t pid = hxlcl_fork();\n" +
            "    if (pid < 0) return hexa_int((int64_t)-errno);\n" +
            "    return hexa_int((int64_t)pid);\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_proc_setsid(void) {\n" +
            "    pid_t sid = setsid();\n" +
            "    if (sid < 0) return hexa_int((int64_t)-errno);\n" +
            "    return hexa_int((int64_t)sid);\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_proc_reap_zombies(void) {\n" +
            "    int count = 0;\n" +
            "    while (1) {\n" +
            "        int status = 0;\n" +
            "        pid_t r = hxlcl_waitpid(-1, &status, WNOHANG);\n" +
            "        if (r <= 0) break;\n" +
            "        count++;\n" +
            "    }\n" +
            "    return hexa_int((int64_t)count);\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "proc_fork.c" }
    let c_text = emit_proc_fork_c()
    let cmd = "cat > \"" + out_path + "\" <<'PROC_FORK_EMIT_EOF'\n" +
              c_text + "PROC_FORK_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[proc_fork_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[proc_fork_emit] wrote " + out_path)
    exit(0)
}
