#!hexa strict
// self/native/pty_emit.hexa
//   B9.C-10 (.c-text · #1848 pattern) — pty.c source emitter.
//
// runtime.c #include "native/pty.c" — RFC 061 amalgamation fragment
// (NOT a standalone TU; references runtime.c-internal symbols). This emitter
// is the SSOT; the build regenerates self/native/pty.c from it before
// runtime.c compiles, so the .c becomes a gitignored build artifact.
//
// Byte-identity: regenerated C is byte-for-byte the hand-written source, so
// the runtime.c TU (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// Invocation:  hexa-run self/native/pty_emit.hexa <output-path>
// Default output path (if argv missing): "pty.c" in cwd.
//
// Phase: B9.C-10 batch (self/native runtime.c-included .c-text · F3).

let MODULE_NAME = "pty_emit"

fn emit_pty_c() -> str {
    // Verbatim content of hand-written self/native/pty.c
    let s =
            "/* self/native/pty.c -- POSIX pseudo-terminal pair + termios.\n" +
            " *\n" +
            " * Included from self/runtime.c via `#include \"native/pty.c\"`. NOT a\n" +
            " * standalone TU -- relies on the runtime.c types/macros (HexaVal,\n" +
            " * HX_IS_xx, HX_INT/HX_STR, hexa_map_xx, hexa_array_xx).\n" +
            " *\n" +
            " * Symbols exported (8 primitives via TAG_FN shims):\n" +
            " *   hexa_pty_open()                              -> map {master, slave, slave_name} or {error}\n" +
            " *   hexa_pty_get_winsize(fd)                     -> map {rows, cols, xpix, ypix} or {error}\n" +
            " *   hexa_pty_set_winsize(fd, r, c, xp, yp)       -> 0 or -errno\n" +
            " *   hexa_tcgetattr(fd)                           -> map {iflag, oflag, cflag, lflag, cc[]} or {error}\n" +
            " *   hexa_tcsetattr(fd, when, attrs)              -> 0 or -errno\n" +
            " *   hexa_tty_isatty(fd)                          -> bool\n" +
            " *   hexa_tty_ttyname(fd)                         -> string or \"\"\n" +
            " *   hexa_pty_forkexec(argv, env, rows, cols)     -> map {pid, master_fd} or {error}\n" +
            " *\n" +
            " * RFC: ~/core/hexa-lang/incoming/patches/stdlib-os-pty.md\n" +
            " * Cross-platform: macOS (libsystem) + Linux (glibc/musl). NCCS = 20 on\n" +
            " * both. Flag bits differ; we pass-through the kernel's u32 values\n" +
            " * untouched -- hexa-side make_raw() applies the masks.\n" +
            " */\n" +
            "\n" +
            "#include <stdio.h>\n" +
            "#include <unistd.h>\n" +
            "#include <fcntl.h>\n" +
            "#include <termios.h>\n" +
            "#include <sys/ioctl.h>\n" +
            "#include <sys/types.h>\n" +
            "\n" +
            "#ifdef __APPLE__\n" +
            "#include <util.h>     /* forkpty on macOS */\n" +
            "#else\n" +
            "#include <pty.h>      /* forkpty on glibc -- link with -lutil */\n" +
            "#endif\n" +
            "\n" +
            "/* Helper: build a map-shape HexaVal for an error result. */\n" +
            "static HexaVal _hexa_pty_err(int en, const char* tag) {\n" +
            "    HexaVal m = hexa_map_new();\n" +
            "    char buf[128];\n" +
            "    snprintf(buf, sizeof(buf), \"%s: %s\", tag, strerror(en));\n" +
            "    hexa_map_set(m, \"error\", hexa_str(buf));\n" +
            "    hexa_map_set(m, \"errno\", hexa_int((int64_t)en));\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "/* --- pty_open: open a master/slave pair via posix_openpt + grantpt + unlockpt --- */\n" +
            "HexaVal hexa_pty_open(void) {\n" +
            "    int master = hxlcl_posix_openpt(O_RDWR | O_NOCTTY);\n" +
            "    if (master < 0) return _hexa_pty_err(errno, \"posix_openpt\");\n" +
            "    if (hxlcl_grantpt(master) < 0)  { int e = errno; hxlcl_close(master); return _hexa_pty_err(e, \"grantpt\"); }\n" +
            "    if (hxlcl_unlockpt(master) < 0) { int e = errno; hxlcl_close(master); return _hexa_pty_err(e, \"unlockpt\"); }\n" +
            "    char name_buf[256];\n" +
            "#ifdef __APPLE__\n" +
            "    /* Darwin: ptsname_r doesn't exist; ptsname is documented thread-safe on macOS. */\n" +
            "    const char* nm = hxlcl_ptsname(master);\n" +
            "    if (!nm) { int e = errno; hxlcl_close(master); return _hexa_pty_err(e, \"ptsname\"); }\n" +
            "    strncpy(name_buf, nm, sizeof(name_buf) - 1);\n" +
            "    name_buf[sizeof(name_buf) - 1] = '\\0';\n" +
            "#else\n" +
            "    if (ptsname_r(master, name_buf, sizeof(name_buf)) != 0) {\n" +
            "        int e = errno; hxlcl_close(master); return _hexa_pty_err(e, \"ptsname_r\");\n" +
            "    }\n" +
            "#endif\n" +
            "    int slave = hxlcl_open_sys(name_buf, O_RDWR | O_NOCTTY);\n" +
            "    if (slave < 0) { int e = errno; hxlcl_close(master); return _hexa_pty_err(e, \"hxlcl_open_sys(slave)\"); }\n" +
            "    HexaVal m = hexa_map_new();\n" +
            "    hexa_map_set(m, \"master\",     hexa_int((int64_t)master));\n" +
            "    hexa_map_set(m, \"slave\",      hexa_int((int64_t)slave));\n" +
            "    hexa_map_set(m, \"slave_name\", hexa_str(name_buf));\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "/* --- window-size ioctl --- */\n" +
            "HexaVal hexa_pty_get_winsize(HexaVal fd_v) {\n" +
            "    if (!HX_IS_INT(fd_v)) return _hexa_pty_err(EINVAL, \"pty_get_winsize\");\n" +
            "    int fd = (int)HX_INT(fd_v);\n" +
            "    struct winsize w;\n" +
            "    if (hxlcl_ioctl(fd, TIOCGWINSZ, &w) < 0) return _hexa_pty_err(errno, \"TIOCGWINSZ\");\n" +
            "    HexaVal m = hexa_map_new();\n" +
            "    hexa_map_set(m, \"rows\", hexa_int((int64_t)w.ws_row));\n" +
            "    hexa_map_set(m, \"cols\", hexa_int((int64_t)w.ws_col));\n" +
            "    hexa_map_set(m, \"xpix\", hexa_int((int64_t)w.ws_xpixel));\n" +
            "    hexa_map_set(m, \"ypix\", hexa_int((int64_t)w.ws_ypixel));\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_pty_set_winsize(HexaVal fd_v, HexaVal r_v, HexaVal c_v, HexaVal xp_v, HexaVal yp_v) {\n" +
            "    if (!HX_IS_INT(fd_v)) return hexa_int(-EINVAL);\n" +
            "    struct winsize w;\n" +
            "    w.ws_row    = (unsigned short)(HX_IS_INT(r_v)  ? HX_INT(r_v)  : 0);\n" +
            "    w.ws_col    = (unsigned short)(HX_IS_INT(c_v)  ? HX_INT(c_v)  : 0);\n" +
            "    w.ws_xpixel = (unsigned short)(HX_IS_INT(xp_v) ? HX_INT(xp_v) : 0);\n" +
            "    w.ws_ypixel = (unsigned short)(HX_IS_INT(yp_v) ? HX_INT(yp_v) : 0);\n" +
            "    if (hxlcl_ioctl((int)HX_INT(fd_v), TIOCSWINSZ, &w) < 0) return hexa_int((int64_t)-errno);\n" +
            "    return hexa_int(0);\n" +
            "}\n" +
            "\n" +
            "/* --- termios get/set --- */\n" +
            "HexaVal hexa_tcgetattr(HexaVal fd_v) {\n" +
            "    if (!HX_IS_INT(fd_v)) return _hexa_pty_err(EINVAL, \"tcgetattr\");\n" +
            "    struct termios t;\n" +
            "    if (hxlcl_tcgetattr((int)HX_INT(fd_v), &t) < 0) return _hexa_pty_err(errno, \"tcgetattr\");\n" +
            "    HexaVal m = hexa_map_new();\n" +
            "    hexa_map_set(m, \"iflag\", hexa_int((int64_t)t.c_iflag));\n" +
            "    hexa_map_set(m, \"oflag\", hexa_int((int64_t)t.c_oflag));\n" +
            "    hexa_map_set(m, \"cflag\", hexa_int((int64_t)t.c_cflag));\n" +
            "    hexa_map_set(m, \"lflag\", hexa_int((int64_t)t.c_lflag));\n" +
            "    /* cc array -- pack into a HexaVal array of ints. */\n" +
            "    HexaVal cc_arr = hexa_array_new();\n" +
            "    for (size_t i = 0; i < NCCS; i++) {\n" +
            "        cc_arr = hexa_array_push(cc_arr, hexa_int((int64_t)(unsigned char)t.c_cc[i]));\n" +
            "    }\n" +
            "    hexa_map_set(m, \"cc\", cc_arr);\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_tcsetattr(HexaVal fd_v, HexaVal when_v, HexaVal attrs_v) {\n" +
            "    if (!HX_IS_INT(fd_v) || !HX_IS_INT(when_v)) return hexa_int(-EINVAL);\n" +
            "    int fd = (int)HX_INT(fd_v);\n" +
            "    int when = (int)HX_INT(when_v);\n" +
            "    /* Read current settings as the base -- caller's map may not carry every field. */\n" +
            "    struct termios t;\n" +
            "    if (hxlcl_tcgetattr(fd, &t) < 0) return hexa_int((int64_t)-errno);\n" +
            "    if (HX_IS_MAP(attrs_v)) {\n" +
            "        HexaVal v;\n" +
            "        v = hexa_map_get(attrs_v, \"iflag\"); if (HX_IS_INT(v)) t.c_iflag = (tcflag_t)HX_INT(v);\n" +
            "        v = hexa_map_get(attrs_v, \"oflag\"); if (HX_IS_INT(v)) t.c_oflag = (tcflag_t)HX_INT(v);\n" +
            "        v = hexa_map_get(attrs_v, \"cflag\"); if (HX_IS_INT(v)) t.c_cflag = (tcflag_t)HX_INT(v);\n" +
            "        v = hexa_map_get(attrs_v, \"lflag\"); if (HX_IS_INT(v)) t.c_lflag = (tcflag_t)HX_INT(v);\n" +
            "        v = hexa_map_get(attrs_v, \"cc\");\n" +
            "        if (HX_IS_ARRAY(v)) {\n" +
            "            int n = HX_ARR_LEN(v);\n" +
            "            int lim = (n < (int)NCCS) ? n : (int)NCCS;\n" +
            "            for (int i = 0; i < lim; i++) {\n" +
            "                HexaVal cv = hexa_array_get(v, (int64_t)i);\n" +
            "                if (HX_IS_INT(cv)) t.c_cc[i] = (cc_t)HX_INT(cv);\n" +
            "            }\n" +
            "        }\n" +
            "    }\n" +
            "    if (hxlcl_tcsetattr(fd, when, &t) < 0) return hexa_int((int64_t)-errno);\n" +
            "    return hexa_int(0);\n" +
            "}\n" +
            "\n" +
            "/* --- tty helpers --- */\n" +
            "HexaVal hexa_tty_isatty(HexaVal fd_v) {\n" +
            "    if (!HX_IS_INT(fd_v)) return hexa_bool(0);\n" +
            "    return hexa_bool(hxlcl_isatty((int)HX_INT(fd_v)) == 1);\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_tty_ttyname(HexaVal fd_v) {\n" +
            "    if (!HX_IS_INT(fd_v)) return hexa_str(\"\");\n" +
            "    const char* nm = hxlcl_ttyname((int)HX_INT(fd_v));\n" +
            "    return hexa_str(nm ? nm : \"\");\n" +
            "}\n" +
            "\n" +
            "/* --- pty_forkexec(argv, env, rows, cols): forkpty-style spawn ---\n" +
            " * argv  : array of strings, argv[0] is the program (resolved via PATH)\n" +
            " * env   : array of \"KEY=VAL\" strings, or empty array = inherit\n" +
            " * rows  : initial pty rows  (0 = leave kernel default)\n" +
            " * cols  : initial pty cols\n" +
            " *\n" +
            " * Returns {pid, master_fd} on success, {error, errno} on failure.\n" +
            " * The slave is dup'd onto stdin/stdout/stderr in the child + made the\n" +
            " * controlling terminal; the parent only retains master_fd.\n" +
            " */\n" +
            "HexaVal hexa_pty_forkexec(HexaVal argv_v, HexaVal env_v, HexaVal rows_v, HexaVal cols_v) {\n" +
            "    if (!HX_IS_ARRAY(argv_v)) return _hexa_pty_err(EINVAL, \"pty_forkexec\");\n" +
            "    int argc = HX_ARR_LEN(argv_v);\n" +
            "    if (argc < 1) return _hexa_pty_err(EINVAL, \"pty_forkexec: empty argv\");\n" +
            "    /* Marshal argv. */\n" +
            "    char** argv = (char**)calloc((size_t)argc + 1, sizeof(char*));\n" +
            "    if (!argv) return _hexa_pty_err(ENOMEM, \"pty_forkexec\");\n" +
            "    for (int i = 0; i < argc; i++) {\n" +
            "        HexaVal s = hexa_array_get(argv_v, (int64_t)i);\n" +
            "        const char* p = HX_IS_STR(s) ? HX_STR(s) : \"\";\n" +
            "        argv[i] = strdup(p);\n" +
            "    }\n" +
            "    /* Marshal env. */\n" +
            "    char** envp = NULL;\n" +
            "    int envc = HX_IS_ARRAY(env_v) ? HX_ARR_LEN(env_v) : 0;\n" +
            "    if (envc > 0) {\n" +
            "        envp = (char**)calloc((size_t)envc + 1, sizeof(char*));\n" +
            "        for (int i = 0; i < envc; i++) {\n" +
            "            HexaVal s = hexa_array_get(env_v, (int64_t)i);\n" +
            "            envp[i] = strdup(HX_IS_STR(s) ? HX_STR(s) : \"\");\n" +
            "        }\n" +
            "    }\n" +
            "    /* Optional initial winsize. */\n" +
            "    struct winsize w;\n" +
            "    struct winsize* wp = NULL;\n" +
            "    int rows = HX_IS_INT(rows_v) ? (int)HX_INT(rows_v) : 0;\n" +
            "    int cols = HX_IS_INT(cols_v) ? (int)HX_INT(cols_v) : 0;\n" +
            "    if (rows > 0 && cols > 0) {\n" +
            "        w.ws_row = (unsigned short)rows; w.ws_col = (unsigned short)cols;\n" +
            "        w.ws_xpixel = 0; w.ws_ypixel = 0;\n" +
            "        wp = &w;\n" +
            "    }\n" +
            "    int master = -1;\n" +
            "    pid_t pid = hxlcl_forkpty(&master, NULL, NULL, wp);\n" +
            "    if (pid < 0) {\n" +
            "        int e = errno;\n" +
            "        for (int i = 0; i < argc; i++) free(argv[i]);\n" +
            "        free(argv);\n" +
            "        if (envp) { for (int i = 0; i < envc; i++) free(envp[i]); free(envp); }\n" +
            "        return _hexa_pty_err(e, \"forkpty\");\n" +
            "    }\n" +
            "    if (pid == 0) {\n" +
            "        /* child -- exec the program */\n" +
            "        if (envp) hxlcl_execve(argv[0], argv, envp); /* with env */\n" +
            "        else      hxlcl_execvp(argv[0], argv);       /* inherit env */\n" +
            "        /* exec failed -- write a tiny diag then exit. The pty is already\n" +
            "         * connected, so the parent sees this on master read. */\n" +
            "        const char* msg = \"[pty_forkexec] exec failed\\n\";\n" +
            "        ssize_t _w = hxlcl_write(STDERR_FILENO, msg, strlen(msg)); (void)_w;\n" +
            "        _exit(127);\n" +
            "    }\n" +
            "    /* parent -- cleanup our argv/env duplicates */\n" +
            "    for (int i = 0; i < argc; i++) free(argv[i]);\n" +
            "    free(argv);\n" +
            "    if (envp) { for (int i = 0; i < envc; i++) free(envp[i]); free(envp); }\n" +
            "    HexaVal m = hexa_map_new();\n" +
            "    hexa_map_set(m, \"pid\",       hexa_int((int64_t)pid));\n" +
            "    hexa_map_set(m, \"master_fd\", hexa_int((int64_t)master));\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "/* --- TAG_FN shim globals --- */\n" +
            "HexaVal pty_open;\n" +
            "HexaVal pty_get_winsize;\n" +
            "HexaVal pty_set_winsize;\n" +
            "HexaVal pty_tcgetattr;       /* aliased so it doesn't collide with libc-style hexa_tcgetattr */\n" +
            "HexaVal pty_tcsetattr;\n" +
            "HexaVal tty_isatty;\n" +
            "HexaVal tty_ttyname;\n" +
            "HexaVal pty_forkexec;\n" +
            "\n" +
            "static void _hexa_init_pty_fn_shims(void) {\n" +
            "    pty_open         = hexa_fn_new((void*)hexa_pty_open,         0);\n" +
            "    pty_get_winsize  = hexa_fn_new((void*)hexa_pty_get_winsize,  1);\n" +
            "    pty_set_winsize  = hexa_fn_new((void*)hexa_pty_set_winsize,  5);\n" +
            "    pty_tcgetattr    = hexa_fn_new((void*)hexa_tcgetattr,        1);\n" +
            "    pty_tcsetattr    = hexa_fn_new((void*)hexa_tcsetattr,        3);\n" +
            "    tty_isatty       = hexa_fn_new((void*)hexa_tty_isatty,       1);\n" +
            "    tty_ttyname      = hexa_fn_new((void*)hexa_tty_ttyname,      1);\n" +
            "    pty_forkexec     = hexa_fn_new((void*)hexa_pty_forkexec,     4);\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "pty.c" }
    let c_text = emit_pty_c()
    let cmd = "cat > \"" + out_path + "\" <<'PTY_EMIT_EOF'\n" +
              c_text + "PTY_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[pty_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[pty_emit] wrote " + out_path)
    exit(0)
}
