#!hexa strict
// self/native/mount_emit.hexa
//   B9.C-10 (.c-text · #1848 pattern) — mount.c source emitter.
//
// runtime.c #include "native/mount.c" — RFC 061 amalgamation fragment
// (NOT a standalone TU; references runtime.c-internal symbols). This emitter
// is the SSOT; the build regenerates self/native/mount.c from it before
// runtime.c compiles, so the .c becomes a gitignored build artifact.
//
// Byte-identity: regenerated C is byte-for-byte the hand-written source, so
// the runtime.c TU (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// Invocation:  hexa-run self/native/mount_emit.hexa <output-path>
// Default output path (if argv missing): "mount.c" in cwd.
//
// Phase: B9.C-10 batch (self/native runtime.c-included .c-text · F3).

let MODULE_NAME = "mount_emit"

fn emit_mount_c() -> str {
    // Verbatim content of hand-written self/native/mount.c
    let s =
            "/* self/native/mount.c -- Linux mount(2) / umount(2) syscall wrappers.\n" +
            " *\n" +
            " * Included from self/runtime.c via `#include \"native/mount.c\"`. NOT\n" +
            " * a standalone TU.\n" +
            " *\n" +
            " * Symbols exported (codegen direct-emit; no fn-value globals because\n" +
            " * the names would collide with libc declarations):\n" +
            " *   hexa_mount(source, target, fstype, flags, data)  -> 0 or -errno\n" +
            " *   hexa_umount(target, flags)                       -> 0 or -errno\n" +
            " *\n" +
            " * RFC: ~/core/hexa-lang/incoming/patches/stdlib-os-mount-linux.md\n" +
            " * Motivation: u-root/cpu port stage-B -- 9P / tmpfs / bind mounts for\n" +
            " * the cpu-pattern's child namespace setup. Fork-storm replacement\n" +
            " * (SPEC Sec16 anti-pattern: exec(\"mount ...\")).\n" +
            " *\n" +
            " * Platform behavior:\n" +
            " *   Linux  -- real syscall via sys/mount.h\n" +
            " *   macOS  -- returns -ENOSYS; the call sites in u-root/cpu are\n" +
            " *             Linux-only (session_linux.go, mount_linux.go), so the\n" +
            " *             stub is informational rather than functional.\n" +
            " */\n" +
            "\n" +
            "#ifdef __linux__\n" +
            "#include <sys/mount.h>\n" +
            "#endif\n" +
            "\n" +
            "HexaVal hexa_mount(HexaVal src_v, HexaVal tgt_v, HexaVal fs_v, HexaVal flags_v, HexaVal data_v) {\n" +
            "#ifdef __linux__\n" +
            "    if (!HX_IS_STR(src_v) || !HX_IS_STR(tgt_v) || !HX_IS_STR(fs_v))\n" +
            "        return hexa_int((int64_t)-EINVAL);\n" +
            "    const char* src = HX_STR(src_v);\n" +
            "    const char* tgt = HX_STR(tgt_v);\n" +
            "    const char* fs  = HX_STR(fs_v);\n" +
            "    unsigned long flags = HX_IS_INT(flags_v) ? (unsigned long)HX_INT(flags_v) : 0;\n" +
            "    const char* data = HX_IS_STR(data_v) ? HX_STR(data_v) : NULL;\n" +
            "    if (mount(src, tgt, fs, flags, data) < 0) return hexa_int((int64_t)-errno);\n" +
            "    return hexa_int(0);\n" +
            "#else\n" +
            "    (void)src_v; (void)tgt_v; (void)fs_v; (void)flags_v; (void)data_v;\n" +
            "    return hexa_int((int64_t)-ENOSYS);\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_umount(HexaVal tgt_v, HexaVal flags_v) {\n" +
            "#ifdef __linux__\n" +
            "    if (!HX_IS_STR(tgt_v)) return hexa_int((int64_t)-EINVAL);\n" +
            "    const char* tgt = HX_STR(tgt_v);\n" +
            "    int flags = HX_IS_INT(flags_v) ? (int)HX_INT(flags_v) : 0;\n" +
            "    if (umount2(tgt, flags) < 0) return hexa_int((int64_t)-errno);\n" +
            "    return hexa_int(0);\n" +
            "#else\n" +
            "    (void)tgt_v; (void)flags_v;\n" +
            "    return hexa_int((int64_t)-ENOSYS);\n" +
            "#endif\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "mount.c" }
    let c_text = emit_mount_c()
    let cmd = "cat > \"" + out_path + "\" <<'MOUNT_EMIT_EOF'\n" +
              c_text + "MOUNT_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[mount_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[mount_emit] wrote " + out_path)
    exit(0)
}
