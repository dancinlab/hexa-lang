// ═══════════════════════════════════════════════════════════════════
//  self/ml/tokenizer.hexa — Tokenizer: BPE + Unigram (#148)
//
//  Full implementation of byte-level BPE and Unigram tokenizers.
//
//  Components:
//    1. Byte-level BPE: start from bytes, iteratively merge most
//       frequent pairs from corpus
//    2. Merge rules: ordered list of merge operations
//    3. Vocabulary building: from corpus statistics, configurable
//       vocab_size
//    4. BPE encode: apply merge rules to tokenize text
//    5. BPE decode: reconstruct text from token IDs
//    6. Unigram model: probabilistic tokenization via maximum
//       likelihood (Viterbi) segmentation
//    7. Special tokens: BOS, EOS, PAD, UNK handling
//    8. Pre-tokenization: whitespace splitting, GPT-2 style
//    9. Encode/decode pipeline: pre-tokenize -> BPE/Unigram ->
//       add special tokens
//
//  API:
//    tok_special_id(kind)                -> int
//    tok_special_str(kind)               -> string
//    tok_pre_tokenize(text)              -> [string]
//    tok_word_to_chars(word)             -> [string]
//    tok_count_pairs(corpus_words)       -> pair_counts map
//    tok_train_bpe(corpus, vocab_size)   -> [vocab, merges]
//    tok_build_vocab_map(vocab)          -> map{str:int}
//    tok_build_merge_ranks(merges)       -> map{str:int}
//    tok_apply_bpe(symbols, merge_ranks) -> [string]
//    tok_bpe_encode(text, vocab, merges) -> [int]
//    tok_bpe_encode_special(text, vocab, merges) -> [int]
//    tok_bpe_decode(ids, vocab)          -> string
//    tok_uni_train(corpus, vocab_size, n_iter) -> [vocab, scores]
//    tok_uni_encode(text, vocab, scores) -> [int]
//    tok_uni_decode(ids, vocab)          -> string
//    tok_make_test_vocab()               -> [string]
//    tok_make_test_merges()              -> [[string,string]]
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — inner-loop encode/decode
// ═══════════════════════════════════════════════════════════════════

// ── math helpers ─────────────────────────────────────────────────

fn tok_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn tok_log(x) {
    if x <= 0.0 { return -999.0 }
    return log(x)
}

fn tok_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn tok_max_float(a, b) {
    if a > b { return a }
    return b
}

fn tok_min_int(a, b) {
    if a < b { return a }
    return b
}

// ═══════════════════════════════════════════════════════════════════
//  Special Tokens
// ═══════════════════════════════════════════════════════════════════

fn tok_bos_id() { return 0 }
fn tok_eos_id() { return 1 }
fn tok_pad_id() { return 2 }
fn tok_unk_id() { return 3 }

fn tok_bos_str() { return "<bos>" }
fn tok_eos_str() { return "<eos>" }
fn tok_pad_str() { return "<pad>" }
fn tok_unk_str() { return "<unk>" }

@pure
fn tok_special_id(kind) {
    if kind == "bos" { return 0 }
    if kind == "eos" { return 1 }
    if kind == "pad" { return 2 }
    if kind == "unk" { return 3 }
    return -1
}

@pure
fn tok_special_str(kind) {
    if kind == "bos" { return "<bos>" }
    if kind == "eos" { return "<eos>" }
    if kind == "pad" { return "<pad>" }
    if kind == "unk" { return "<unk>" }
    return ""
}

@pure
fn tok_is_special_id(id) {
    if id >= 0 {
        if id <= 3 { return true }
    }
    return false
}

@pure
fn tok_num_specials() { return 4 }

// ═══════════════════════════════════════════════════════════════════
//  Character Classification
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_is_letter(code) {
    if code >= 65 {
        if code <= 90 { return true }
    }
    if code >= 97 {
        if code <= 122 { return true }
    }
    return false
}

@pure
fn tok_is_digit(code) {
    if code >= 48 {
        if code <= 57 { return true }
    }
    return false
}

@pure
fn tok_is_whitespace(code) {
    if code == 32 { return true }
    if code == 9 { return true }
    if code == 10 { return true }
    if code == 13 { return true }
    return false
}

@pure
fn tok_is_punct(code) {
    if tok_is_letter(code) { return false }
    if tok_is_digit(code) { return false }
    if tok_is_whitespace(code) { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════════
//  Pre-tokenization (GPT-2 style)
//
//  Splits text into words. Leading space attaches to next word.
//  Punctuation is its own token.
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_pre_tokenize(text) {
    let n = len(text)
    if n == 0 { return [] }
    let mut words = []
    let mut current = ""
    let mut i = 0
    while i < n {
        let code = char_code(text, i)
        let ch = chr(code)
        if tok_is_whitespace(code) {
            if len(current) > 0 {
                words = words + [current]
                current = ""
            }
            current = " "
        } else {
            if tok_is_punct(code) {
                if len(current) > 0 {
                    words = words + [current]
                    current = ""
                }
                words = words + [ch]
            } else {
                current = current + ch
            }
        }
        i = i + 1
    }
    if len(current) > 0 {
        words = words + [current]
    }
    return words
}

// ═══════════════════════════════════════════════════════════════════
//  Word to Characters
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_word_to_chars(word) {
    let n = len(word)
    let mut chars = []
    let mut i = 0
    while i < n {
        let code = char_code(word, i)
        chars = chars + [chr(code)]
        i = i + 1
    }
    return chars
}

// ═══════════════════════════════════════════════════════════════════
//  Pair Counting — count all adjacent symbol pairs in corpus words
//
//  corpus_words: array of arrays of symbol strings
//  Returns: map { "sym_a sym_b" : count }
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_count_pairs(corpus_words) {
    let mut counts = #{}
    let nw = len(corpus_words)
    let mut wi = 0
    while wi < nw {
        let syms = corpus_words[wi]
        let ns = len(syms)
        let mut si = 0
        while si < ns - 1 {
            let key = syms[si] + " " + syms[si + 1]
            if has_key(counts, key) {
                counts[key] = counts[key] + 1
            } else {
                counts[key] = 1
            }
            si = si + 1
        }
        wi = wi + 1
    }
    return counts
}

// ═══════════════════════════════════════════════════════════════════
//  Find Best Pair — the pair with highest frequency
//
//  Returns: ["sym_a", "sym_b"] or [] if no pairs
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_best_pair(pair_counts) {
    let ks = keys(pair_counts)
    let nk = len(ks)
    if nk == 0 { return [] }
    let mut best_key = ks[0]
    let mut best_count = pair_counts[ks[0]]
    let mut i = 1
    while i < nk {
        let c = pair_counts[ks[i]]
        if c > best_count {
            best_count = c
            best_key = ks[i]
        }
        i = i + 1
    }
    let parts = best_key.split(" ")
    return [parts[0], parts[1]]
}

// ═══════════════════════════════════════════════════════════════════
//  Merge Pair in All Words
//
//  Replaces all adjacent occurrences of (a, b) with merged "ab"
//  in each word's symbol list.
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_merge_in_words(corpus_words, pair_a, pair_b) {
    let merged = pair_a + pair_b
    let nw = len(corpus_words)
    let mut result = []
    let mut wi = 0
    while wi < nw {
        let syms = corpus_words[wi]
        let ns = len(syms)
        let mut new_syms = []
        let mut si = 0
        while si < ns {
            if si < ns - 1 {
                if syms[si] == pair_a {
                    if syms[si + 1] == pair_b {
                        new_syms = new_syms + [merged]
                        si = si + 2
                        continue
                    }
                }
            }
            new_syms = new_syms + [syms[si]]
            si = si + 1
        }
        result = result + [new_syms]
        wi = wi + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Collect Unique Symbols from corpus words
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_collect_symbols(corpus_words) {
    let mut seen = #{}
    let nw = len(corpus_words)
    let mut wi = 0
    while wi < nw {
        let syms = corpus_words[wi]
        let ns = len(syms)
        let mut si = 0
        while si < ns {
            seen[syms[si]] = 1
            si = si + 1
        }
        wi = wi + 1
    }
    return keys(seen)
}

// ═══════════════════════════════════════════════════════════════════
//  BPE Training — learn merge rules from a corpus
//
//  corpus: array of text strings (training sentences)
//  vocab_size: target vocabulary size (including specials)
//
//  Returns: [vocab, merges]
//    vocab: array of token strings (id -> string)
//    merges: array of [pair_a, pair_b] merge rules in priority order
// ═══════════════════════════════════════════════════════════════════

fn tok_train_bpe(corpus, vocab_size) {
    // Step 1: pre-tokenize all corpus text into words, then chars
    let mut corpus_words = []
    let nc = len(corpus)
    let mut ci = 0
    while ci < nc {
        let words = tok_pre_tokenize(corpus[ci])
        let nw = len(words)
        let mut wi = 0
        while wi < nw {
            let chars = tok_word_to_chars(words[wi])
            corpus_words = corpus_words + [chars]
            wi = wi + 1
        }
        ci = ci + 1
    }

    // Step 2: initial vocabulary = specials + unique single chars
    let mut vocab = [tok_bos_str(), tok_eos_str(), tok_pad_str(), tok_unk_str()]
    let init_syms = tok_collect_symbols(corpus_words)
    let mut sym_set = #{}
    let nis = len(init_syms)
    let mut si = 0
    while si < nis {
        let s = init_syms[si]
        if sym_set.has(s) == false {
            vocab = vocab + [s]
            sym_set[s] = 1
        }
        si = si + 1
    }

    // Step 3: iteratively merge most frequent pair
    let mut merges = []
    let max_merges = vocab_size - len(vocab)

    let mut iter = 0
    while iter < max_merges {
        let pair_counts = tok_count_pairs(corpus_words)
        let best = tok_best_pair(pair_counts)
        if len(best) == 0 { break }

        let pa = best[0]
        let pb = best[1]
        let merged = pa + pb

        // Apply merge across all words
        corpus_words = tok_merge_in_words(corpus_words, pa, pb)

        // Add to merges list and vocab
        merges = merges + [[pa, pb]]
        if sym_set.has(merged) == false {
            vocab = vocab + [merged]
            sym_set[merged] = 1
        }

        iter = iter + 1
    }

    return [vocab, merges]
}

// ═══════════════════════════════════════════════════════════════════
//  Build Vocab Map: token_string -> token_id
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_build_vocab_map(vocab) {
    let mut m = #{}
    let n = len(vocab)
    let mut i = 0
    while i < n {
        m[vocab[i]] = i
        i = i + 1
    }
    return m
}

// ═══════════════════════════════════════════════════════════════════
//  Build Merge Ranks: "a b" -> priority (lower = merge first)
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_build_merge_ranks(merges) {
    let mut m = #{}
    let n = len(merges)
    let mut i = 0
    while i < n {
        let key = merges[i][0] + " " + merges[i][1]
        m[key] = i
        i = i + 1
    }
    return m
}

// ═══════════════════════════════════════════════════════════════════
//  Apply BPE Merges — to a single word (array of symbol strings)
//
//  Iteratively merges the pair with lowest rank (highest priority).
// ═══════════════════════════════════════════════════════════════════

@pure @hot
fn tok_apply_bpe(symbols, merge_ranks) {
    let mut syms = symbols
    let mut changed = true
    while changed {
        changed = false
        let n = len(syms)
        if n < 2 { return syms }

        let mut best_rank = 999999999
        let mut best_idx = -1
        let mut i = 0
        while i < n - 1 {
            let key = syms[i] + " " + syms[i + 1]
            if has_key(merge_ranks, key) {
                let rank = merge_ranks[key]
                if rank < best_rank {
                    best_rank = rank
                    best_idx = i
                }
            }
            i = i + 1
        }

        if best_idx >= 0 {
            let merged = syms[best_idx] + syms[best_idx + 1]
            let mut new_syms = []
            let mut j = 0
            while j < n {
                if j == best_idx {
                    new_syms = new_syms + [merged]
                    j = j + 2
                } else {
                    new_syms = new_syms + [syms[j]]
                    j = j + 1
                }
            }
            syms = new_syms
            changed = true
        }
    }
    return syms
}

// ═══════════════════════════════════════════════════════════════════
//  BPE Encode: text -> array of token IDs
//
//  Steps:
//    1. Pre-tokenize into words
//    2. Each word -> chars -> apply BPE merges
//    3. Map BPE tokens to vocab IDs (UNK fallback)
// ═══════════════════════════════════════════════════════════════════

@hot
fn tok_bpe_encode(text, vocab, merges) {
    let vocab_map = tok_build_vocab_map(vocab)
    let merge_ranks = tok_build_merge_ranks(merges)
    let words = tok_pre_tokenize(text)
    let mut token_ids = []
    let n_words = len(words)
    let mut wi = 0
    while wi < n_words {
        let word = words[wi]
        let chars = tok_word_to_chars(word)
        let bpe_tokens = tok_apply_bpe(chars, merge_ranks)
        let n_toks = len(bpe_tokens)
        let mut ti = 0
        while ti < n_toks {
            let tok = bpe_tokens[ti]
            if has_key(vocab_map, tok) {
                token_ids = token_ids + [vocab_map[tok]]
            } else {
                token_ids = token_ids + [tok_unk_id()]
            }
            ti = ti + 1
        }
        wi = wi + 1
    }
    return token_ids
}

// ═══════════════════════════════════════════════════════════════════
//  BPE Encode with Special Tokens: [BOS] + tokens + [EOS]
// ═══════════════════════════════════════════════════════════════════

@hot
fn tok_bpe_encode_special(text, vocab, merges) {
    let ids = tok_bpe_encode(text, vocab, merges)
    return [tok_bos_id()] + ids + [tok_eos_id()]
}

// ═══════════════════════════════════════════════════════════════════
//  BPE Decode: token IDs -> string
//
//  Maps IDs back to token strings, concatenates.
//  Skips BOS/PAD, stops at EOS.
// ═══════════════════════════════════════════════════════════════════

@pure @hot
fn tok_bpe_decode(ids, vocab) {
    let n = len(ids)
    let vs = len(vocab)
    let mut result = ""
    let mut i = 0
    while i < n {
        let id = ids[i]
        if id == tok_bos_id() {
            // skip BOS
        } else {
            if id == tok_eos_id() {
                return result
            } else {
                if id == tok_pad_id() {
                    // skip PAD
                } else {
                    if id >= 0 {
                        if id < vs {
                            result = result + vocab[id]
                        } else {
                            result = result + tok_unk_str()
                        }
                    } else {
                        result = result + tok_unk_str()
                    }
                }
            }
        }
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Decode without specials (raw ID -> string, no BOS/EOS skip)
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_bpe_decode_raw(ids, vocab) {
    let n = len(ids)
    let vs = len(vocab)
    let mut result = ""
    let mut i = 0
    while i < n {
        let id = ids[i]
        if id >= 0 {
            if id < vs {
                result = result + vocab[id]
            } else {
                result = result + tok_unk_str()
            }
        } else {
            result = result + tok_unk_str()
        }
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Unigram Model Training
//
//  Trains a unigram language model tokenizer:
//    1. Start with a large initial vocabulary (all substrings up to
//       max_piece length that appear in corpus)
//    2. For each vocab piece, compute log-probability from corpus freq
//    3. Iteratively prune pieces that contribute least to likelihood
//    4. Keep pruning until target vocab_size reached
//
//  corpus: array of text strings
//  vocab_size: target vocabulary size
//  n_iter: number of pruning iterations
//
//  Returns: [vocab, scores]
//    vocab: array of piece strings (id -> string)
//    scores: array of log-probability floats (id -> float)
// ═══════════════════════════════════════════════════════════════════

fn tok_uni_build_initial_vocab(corpus, max_piece_len) {
    // Count all substrings up to max_piece_len from corpus
    let mut freq = #{}
    let nc = len(corpus)
    let mut ci = 0
    while ci < nc {
        let text = corpus[ci]
        let tlen = len(text)
        let mut start = 0
        while start < tlen {
            let mut end = start + 1
            let limit = start + max_piece_len
            let mut elimit = limit
            if elimit > tlen { elimit = tlen }
            while end <= elimit {
                let piece = text.substring(start, end)
                if has_key(freq, piece) {
                    freq[piece] = freq[piece] + 1
                } else {
                    freq[piece] = 1
                }
                end = end + 1
            }
            start = start + 1
        }
        ci = ci + 1
    }
    return freq
}

fn tok_uni_train(corpus, vocab_size, n_iter) {
    // Step 1: build initial large vocab from corpus substrings
    let max_piece = 8
    let freq = tok_uni_build_initial_vocab(corpus, max_piece)
    let all_pieces = keys(freq)

    // Compute total frequency
    let mut total = 0
    let nap = len(all_pieces)
    let mut pi = 0
    while pi < nap {
        total = total + freq[all_pieces[pi]]
        pi = pi + 1
    }

    // Step 2: build initial vocab = specials + frequent pieces
    let mut vocab = [tok_bos_str(), tok_eos_str(), tok_pad_str(), tok_unk_str()]
    let mut scores = [-999.0, -999.0, -999.0, -999.0]

    // Add single characters first (always kept)
    let mut char_set = #{}
    let nc = len(corpus)
    let mut ci = 0
    while ci < nc {
        let text = corpus[ci]
        let tl = len(text)
        let mut ti = 0
        while ti < tl {
            let code = char_code(text, ti)
            let ch = chr(code)
            if char_set.has(ch) == false {
                char_set[ch] = 1
                let f = freq[ch]
                let sc = tok_log(to_float(f) / to_float(total))
                vocab = vocab + [ch]
                scores = scores + [sc]
            }
            ti = ti + 1
        }
        ci = ci + 1
    }

    // Add multi-char pieces sorted by frequency (descending)
    // Simple approach: add pieces with freq >= threshold
    let n_single = len(vocab)
    let mut multi_pieces = []
    let mut multi_scores = []
    pi = 0
    while pi < nap {
        let p = all_pieces[pi]
        if len(p) > 1 {
            let f = freq[p]
            if f >= 2 {
                let sc = tok_log(to_float(f) / to_float(total))
                multi_pieces = multi_pieces + [p]
                multi_scores = multi_scores + [sc]
            }
        }
        pi = pi + 1
    }

    // Sort multi_pieces by score descending (selection sort, small N ok)
    let nmp = len(multi_pieces)
    let mut mi = 0
    while mi < nmp - 1 {
        let mut best_j = mi
        let mut mj = mi + 1
        while mj < nmp {
            if multi_scores[mj] > multi_scores[best_j] {
                best_j = mj
            }
            mj = mj + 1
        }
        if best_j != mi {
            let tmp_p = multi_pieces[mi]
            let tmp_s = multi_scores[mi]
            multi_pieces[mi] = multi_pieces[best_j]
            multi_scores[mi] = multi_scores[best_j]
            multi_pieces[best_j] = tmp_p
            multi_scores[best_j] = tmp_s
        }
        mi = mi + 1
    }

    // Add top multi_pieces up to 2x target (will prune down)
    let add_limit = (vocab_size - n_single) * 2
    let mut add_count = tok_min_int(nmp, add_limit)
    let mut ai = 0
    while ai < add_count {
        vocab = vocab + [multi_pieces[ai]]
        scores = scores + [multi_scores[ai]]
        ai = ai + 1
    }

    // Step 3: iterative pruning
    let mut it = 0
    while it < n_iter {
        if len(vocab) <= vocab_size { break }

        // Find piece with lowest absolute contribution (highest score = most negative)
        // Never remove specials or single chars
        let mut worst_idx = -1
        let mut worst_score = 999.0
        let mut wi = n_single
        while wi < len(vocab) {
            if scores[wi] < worst_score {
                worst_score = scores[wi]
                worst_idx = wi
            }
            wi = wi + 1
        }

        if worst_idx < 0 { break }

        // Remove worst piece
        let mut new_vocab = []
        let mut new_scores = []
        let mut ri = 0
        while ri < len(vocab) {
            if ri != worst_idx {
                new_vocab = new_vocab + [vocab[ri]]
                new_scores = new_scores + [scores[ri]]
            }
            ri = ri + 1
        }
        vocab = new_vocab
        scores = new_scores

        it = it + 1
    }

    // Final trim to vocab_size
    if len(vocab) > vocab_size {
        let mut tv = []
        let mut ts = []
        let mut ti = 0
        while ti < vocab_size {
            tv = tv + [vocab[ti]]
            ts = ts + [scores[ti]]
            ti = ti + 1
        }
        vocab = tv
        scores = ts
    }

    return [vocab, scores]
}

// ═══════════════════════════════════════════════════════════════════
//  Unigram Encode — Viterbi segmentation
//
//  Given text, find the most likely segmentation under unigram model.
//  Uses dynamic programming (Viterbi-like forward pass).
//
//  text: input string
//  vocab: array of piece strings
//  scores: array of log-probabilities per piece
//
//  Returns: array of token IDs
// ═══════════════════════════════════════════════════════════════════

@hot
fn tok_uni_encode(text, vocab, scores) {
    let tlen = len(text)
    if tlen == 0 { return [] }

    // Build piece -> (id, score) map
    let vs = len(vocab)
    let mut piece_map = #{}
    let mut vi = 0
    while vi < vs {
        let p = vocab[vi]
        if piece_map.has(p) == false {
            piece_map[p] = vi
        }
        vi = vi + 1
    }

    // Viterbi forward: best[i] = best log-prob to reach position i
    // back[i] = length of best piece ending at position i
    let mut best = []
    let mut back = []
    let mut bi = 0
    while bi <= tlen {
        best = best + [-999999.0]
        back = back + [0]
        bi = bi + 1
    }
    best[0] = 0.0

    let mut pos = 0
    while pos < tlen {
        if best[pos] <= -999998.0 {
            pos = pos + 1
            continue
        }
        // Try all pieces starting at pos
        let mut plen = 1
        let max_p = tlen - pos
        let mut plimit = max_p
        if plimit > 16 { plimit = 16 }
        while plen <= plimit {
            let piece = text.substring(pos, pos + plen)
            if piece_map.has(piece) {
                let pid = piece_map[piece]
                let sc = scores[pid]
                let candidate = best[pos] + sc
                if candidate > best[pos + plen] {
                    best[pos + plen] = candidate
                    back[pos + plen] = plen
                }
            }
            plen = plen + 1
        }
        pos = pos + 1
    }

    // Backtrack to find segmentation
    let mut pieces_rev = []
    let mut bp = tlen
    while bp > 0 {
        let pl = back[bp]
        if pl <= 0 {
            // Fallback: single character as UNK
            pieces_rev = pieces_rev + [tok_unk_id()]
            bp = bp - 1
        } else {
            let piece = text.substring(bp - pl, bp)
            if piece_map.has(piece) {
                pieces_rev = pieces_rev + [piece_map[piece]]
            } else {
                pieces_rev = pieces_rev + [tok_unk_id()]
            }
            bp = bp - pl
        }
    }

    // Reverse
    let nr = len(pieces_rev)
    let mut result = []
    let mut ri = nr - 1
    while ri >= 0 {
        result = result + [pieces_rev[ri]]
        ri = ri - 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Unigram Encode with Special Tokens
// ═══════════════════════════════════════════════════════════════════

@hot
fn tok_uni_encode_special(text, vocab, scores) {
    let ids = tok_uni_encode(text, vocab, scores)
    return [tok_bos_id()] + ids + [tok_eos_id()]
}

// ═══════════════════════════════════════════════════════════════════
//  Unigram Decode: token IDs -> string
// ═══════════════════════════════════════════════════════════════════

@pure @hot
fn tok_uni_decode(ids, vocab) {
    let n = len(ids)
    let vs = len(vocab)
    let mut result = ""
    let mut i = 0
    while i < n {
        let id = ids[i]
        if id == tok_bos_id() {
            // skip
        } else {
            if id == tok_eos_id() {
                return result
            } else {
                if id == tok_pad_id() {
                    // skip
                } else {
                    if id >= 0 {
                        if id < vs {
                            result = result + vocab[id]
                        } else {
                            result = result + tok_unk_str()
                        }
                    } else {
                        result = result + tok_unk_str()
                    }
                }
            }
        }
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Padding Utility — pad a sequence to fixed length
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_pad_sequence(ids, max_len) {
    let n = len(ids)
    if n >= max_len {
        let mut out = []
        let mut i = 0
        while i < max_len {
            out = out + [ids[i]]
            i = i + 1
        }
        return out
    }
    let mut out = ids
    let mut i = n
    while i < max_len {
        out = out + [tok_pad_id()]
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Truncation Utility
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_truncate(ids, max_len) {
    let n = len(ids)
    if n <= max_len { return ids }
    let mut out = []
    let mut i = 0
    while i < max_len {
        out = out + [ids[i]]
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Batch Encode — encode multiple texts
// ═══════════════════════════════════════════════════════════════════

fn tok_bpe_batch_encode(texts, vocab, merges) {
    let n = len(texts)
    let mut batch = []
    let mut i = 0
    while i < n {
        let ids = tok_bpe_encode(texts[i], vocab, merges)
        batch = batch + [ids]
        i = i + 1
    }
    return batch
}

// ═══════════════════════════════════════════════════════════════════
//  Vocab Size Utility
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_vocab_size(vocab) {
    return len(vocab)
}

// ═══════════════════════════════════════════════════════════════════
//  Token ID <-> String Conversion
// ═══════════════════════════════════════════════════════════════════

@pure
fn tok_id_to_str(id, vocab) {
    if id >= 0 {
        if id < len(vocab) {
            return vocab[id]
        }
    }
    return tok_unk_str()
}

@pure
fn tok_str_to_id(token, vocab) {
    let m = tok_build_vocab_map(vocab)
    if has_key(m, token) {
        return m[token]
    }
    return tok_unk_id()
}

// ═══════════════════════════════════════════════════════════════════
//  Test Helpers — small vocab + merges for unit testing
// ═══════════════════════════════════════════════════════════════════

fn tok_make_test_vocab() {
    let mut vocab = [tok_bos_str(), tok_eos_str(), tok_pad_str(), tok_unk_str()]
    // Single ASCII printable chars (32-126) -> IDs 4..98
    let mut code = 32
    while code <= 126 {
        vocab = vocab + [chr(code)]
        code = code + 1
    }
    // Common merged tokens
    vocab = vocab + ["he"]
    vocab = vocab + ["ll"]
    vocab = vocab + ["lo"]
    vocab = vocab + [" w"]
    vocab = vocab + ["or"]
    vocab = vocab + ["ld"]
    vocab = vocab + ["hel"]
    vocab = vocab + ["hell"]
    vocab = vocab + ["hello"]
    vocab = vocab + [" wo"]
    vocab = vocab + ["orl"]
    vocab = vocab + ["orld"]
    vocab = vocab + [" world"]
    return vocab
}

fn tok_make_test_merges() {
    let merges = [
        ["h", "e"],
        ["l", "l"],
        ["l", "o"],
        [" ", "w"],
        ["o", "r"],
        ["l", "d"],
        ["he", "l"],
        ["hel", "l"],
        ["hell", "o"],
        [" w", "o"],
        ["or", "l"],
        ["orl", "d"],
        [" wo", "rld"]
    ]
    return merges
}

