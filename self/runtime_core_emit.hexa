    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "HexaVal hexa_eprint(HexaVal v);\n"
    buf = buf + "// M1 full · file layer (hxa-20260423-003 Step 5): codegen emits rt_file_*\n"
