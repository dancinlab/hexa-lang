    buf = buf + "    }\n"
    buf = buf + "    hxlcl_memcpy(items, HX_ARR_ITEMS(arr) + a, sizeof(HexaVal) * (size_t)m);\n"
    buf = buf + "    HX_SET_ARR_ITEMS(out, items);\n"
    buf = buf + "    HX_SET_ARR_LEN(out, m);\n"
