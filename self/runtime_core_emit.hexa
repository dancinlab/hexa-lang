    buf = buf + "\n"
    buf = buf + "// Forward decl — hexa_throw 본체는 line ~2903. OOB throw routing 을 위해\n"
    buf = buf + "// 여기서 일찍 선언.\n"
    buf = buf + "void hexa_throw(HexaVal err);\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_array_get(HexaVal arr, int64_t idx) {\n"
