    buf = buf + "HexaVal hexa_pad_left(HexaVal s, HexaVal width) {\n"
    buf = buf + "    HexaVal str = hexa_to_string(s);\n"
    buf = buf + "    return rt_pad_left(str, width);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "// Bootstrap shim: hexa-level `join(arr, sep)` free-fn idiom in SSOT modules\n"
    buf = buf + "// emits `hexa_call2(join, arr, sep)` via TAG_FN lookup. Once hexat is rebuilt\n"
    buf = buf + "// from codegen.hexa's join-builtin dispatch, this becomes unused.\n"
    buf = buf + "// (`split` was retired 2026-04-21 — codegen now emits hexa_str_split directly.)\n"
    buf = buf + "static HexaVal join;\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 51 port — pad_right symmetric to pad_left.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_pad_right(HexaVal s, HexaVal width) {\n"
    buf = buf + "    HexaVal str = hexa_to_string(s);\n"
    buf = buf + "    int w = HX_INT(width);\n"
    buf = buf + "    int cplen = utf8_cpcount(HX_STR(str));\n"
    buf = buf + "    int bytelen = (int)HX_STRLEN(str);\n"
    buf = buf + "    if (cplen >= w) return str;\n"
    buf = buf + "    int pad = w - cplen;\n"
    buf = buf + "    char* result = malloc(bytelen + pad + 1);\n"
    buf = buf + "    hxlcl_strcpy(result, HX_STR(str));\n"
    buf = buf + "    hxlcl_memset(result + bytelen, ' ', pad);\n"
    buf = buf + "    result[bytelen + pad] = 0;\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_pad_right(HexaVal s, HexaVal width);\n"
    buf = buf + "HexaVal hexa_pad_right(HexaVal s, HexaVal width) {\n"
    buf = buf + "    HexaVal str = hexa_to_string(s);\n"
    buf = buf + "    return rt_pad_right(str, width);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// B-19: Polymorphic arithmetic — T39 routes through __hx_to_double.\n"
    buf = buf + "// ROI-47: explicit float+float fast path avoids 2x __hx_to_double tag dispatch.\n"
    buf = buf + "// Bool → int coercion shared across sub/mul/div/mod (Python canonical).\n"
    buf = buf + "// Without this, `true * 5` fell to __hx_to_double which returned 0.0 (no bool\n"
    buf = buf + "// branch) → silently 0.  Now bool first promotes to int before the int/int\n"
    buf = buf + "// fast path, keeping the result type consistent with `hexa_add_slow`.\n"
    buf = buf + "#define _HX_COERCE_BOOL(_a, _b) do { \\\n"
    buf = buf + "    if (HX_IS_BOOL(_a)) _a = hexa_int(HX_BOOL(_a) ? 1 : 0); \\\n"
    buf = buf + "    if (HX_IS_BOOL(_b)) _b = hexa_int(HX_BOOL(_b) ? 1 : 0); \\\n"
    buf = buf + "} while (0)\n"
    buf = buf + "// RUNTIME.md step-4 / .c-none — arithmetic core moved C → hexa (shape-2, full\n"
    buf = buf + "// dispatch in hexa). Under HEXA_HAS_HEXA_RT_STDLIB hexa_sub delegates to hexa-\n"
    buf = buf + "// source rt_sub (stdlib/runtime/numeric.hexa); the #else C body (bit-for-bit)\n"
    buf = buf + "// stays for standalone/smoke. rt_sub returns via typed helpers (rt_sub_int/float)\n"
    buf = buf + "// so no bare-native-scalar return (the attempt-1 crash, #1214). Emit-path →\n"
    buf = buf + "// gen1≡gen2 fixpoint MUST hold (gated before merge). NOTE the throw message text\n"
    buf = buf + "// differs (hexa uses type-name strings vs C's \"tag %d\") — prefix preserved.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_sub(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_sub(HexaVal a, HexaVal b) { return rt_sub(a, b); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_sub(HexaVal a, HexaVal b) {\n"
    buf = buf + "    _HX_COERCE_BOOL(a, b);\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b)) return hexa_int(HX_INT(a) - HX_INT(b));\n"
    buf = buf + "    if (HX_IS_FLOAT(a) && HX_IS_FLOAT(b)) return hexa_float(HX_FLOAT(a) - HX_FLOAT(b));\n"
    buf = buf + "    // PROBE r16 (#807 sibling): a non-numeric operand (e.g. string) is a TYPE\n"
    buf = buf + "    // ERROR, not a silent number. Before this guard `\"ab\" - 3` quietly returned\n"
    buf = buf + "    // -3.0 because __hx_to_double() coerces a string to 0.0. Go/Rust canonical.\n"
    buf = buf + "    // Mixed int/float still promotes through the __hx_to_double fallback below.\n"
    buf = buf + "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n"
    buf = buf + "        char _buf[96];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"cannot subtract non-numeric operand (tag %d - tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return hexa_float(0.0);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_float(__hx_to_double(a) - __hx_to_double(b));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "// RUNTIME.md step-4 / .c-none — arith core op 2 moved C → hexa. Under\n"
    buf = buf + "// HEXA_HAS_HEXA_RT_STDLIB hexa_mul delegates to hexa-source rt_mul (numeric.hexa,\n"
    buf = buf + "// same shape as rt_sub #1217); #else C body kept. Emit-path → byte-identity gated.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "extern HexaVal rt_mul(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_mul(HexaVal a, HexaVal b) { return rt_mul(a, b); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_mul(HexaVal a, HexaVal b) {\n"
    buf = buf + "    _HX_COERCE_BOOL(a, b);\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b)) return hexa_int(HX_INT(a) * HX_INT(b));\n"
    buf = buf + "    if (HX_IS_FLOAT(a) && HX_IS_FLOAT(b)) return hexa_float(HX_FLOAT(a) * HX_FLOAT(b));\n"
    buf = buf + "    // PROBE r16 (2026-05-25): a non-numeric operand (e.g. string) is a TYPE\n"
    buf = buf + "    // ERROR, not a silent 0.0. Before this guard `\"ab\" * 3` quietly returned\n"
    buf = buf + "    // 0.0 because __hx_to_double() coerces a string to 0.0. Go/Rust canonical —\n"
    buf = buf + "    // `str * int` does not compile; Python's string-repeat is intentionally NOT\n"
    buf = buf + "    // adopted (hexa has no operator-overload prelude for it). Mixed int/float\n"
    buf = buf + "    // still promotes through the fallback below.\n"
    buf = buf + "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n"
    buf = buf + "        char _buf[96];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"cannot multiply non-numeric operand (tag %d * tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return hexa_float(0.0);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_float(__hx_to_double(a) * __hx_to_double(b));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "// FMA: fused multiply-add — fma(a,b,c) = a*b + c\n"
    buf = buf + "// For floats uses C99 fma() (single rounding, hardware FMA on modern CPUs).\n"
    buf = buf + "// For pure ints falls back to a*b+c with int arithmetic.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_fma(HexaVal a, HexaVal b, HexaVal c) {\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b) && HX_IS_INT(c))\n"
    buf = buf + "        return hexa_int(HX_INT(a) * HX_INT(b) + HX_INT(c));\n"
    buf = buf + "    return hexa_float(fma(__hx_to_double(a), __hx_to_double(b), __hx_to_double(c)));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_fma_int(HexaVal a, HexaVal b, HexaVal c);\n"
    buf = buf + "extern HexaVal rt_fma_float(HexaVal a, HexaVal b, HexaVal c);\n"
    buf = buf + "HexaVal hexa_fma(HexaVal a, HexaVal b, HexaVal c) {\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b) && HX_IS_INT(c))\n"
    buf = buf + "        return rt_fma_int(a, b, c);\n"
    buf = buf + "    return rt_fma_float(hexa_float(__hx_to_double(a)),\n"
    buf = buf + "                        hexa_float(__hx_to_double(b)),\n"
    buf = buf + "                        hexa_float(__hx_to_double(c)));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "// Bootstrap bridge for the __raw_idiv/__raw_imod codegen primitives. The NEW\n"
    buf = buf + "// codegen.hexa lowers these inline (hexa_int(HX_INT/HX_INT)), but a PRE-builtin\n"
    buf = buf + "// bootstrap transpiler (self/native/hexat before regen) doesn't know them and\n"
    buf = buf + "// emits the generic function-pointer form `hexa_call2(__raw_idiv, a, b)` — which\n"
    buf = buf + "// resolves to __hexa_call2_fp2(fp, a, b) → fp(a, b) via the hexa_call2 _Generic.\n"
    buf = buf + "// So these MUST be real C functions of signature HexaVal(HexaVal,HexaVal) (not\n"
    buf = buf + "// macros — a macro would not expand on the bare identifier). Same class + form\n"
    buf = buf + "// as the s4_flatc_post.py-injected static helpers (e.g. __arr_alloc_items_zero).\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// Unreferenced (harmless) once the bootstrap regenerates and inlines them.\n"
    buf = buf + "static inline HexaVal __raw_idiv(HexaVal a, HexaVal b) { return hexa_int(HX_INT(a) / HX_INT(b)); }\n"
    buf = buf + "static inline HexaVal __raw_imod(HexaVal a, HexaVal b) { return hexa_int(HX_INT(a) % HX_INT(b)); }\n"
    buf = buf + "// float modulo bridge → libm-free hxlcl_fmod (fwd-declared above the runtime_core.c\n"
    buf = buf + "// include at self/runtime.c:983). rt_mod's float path uses this instead of the `%`\n"
    buf = buf + "// operator so no `_fmod` libm extern is pulled. Mirrors hexa_mod's C body.\n"
    buf = buf + "static inline HexaVal __raw_fmod(HexaVal a, HexaVal b) { return hexa_float(hxlcl_fmod(HX_FLOAT(a), HX_FLOAT(b))); }\n"
    buf = buf + "\n"
    buf = buf + "// RUNTIME.md Step 4 .c-none arith core op 3: under HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "// hexa_div delegates to hexa-source rt_div (stdlib/runtime/numeric.hexa). The\n"
    buf = buf + "// int divide there uses the __raw_idiv codegen escape (native HX_INT/HX_INT)\n"
    buf = buf + "// since the `/` operator on known-int routes back here (recursion). The #else\n"
    buf = buf + "// C body is retained bit-for-bit for the standalone link (smoke path doesn't\n"
    buf = buf + "// define the macro). Semantics byte-identical: pure int/int + pure float/float\n"
    buf = buf + "// throw on zero; mixed int/float is IEEE (no throw).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_div(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_div(HexaVal a, HexaVal b) { return rt_div(a, b); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_div(HexaVal a, HexaVal b) {\n"
    buf = buf + "    _HX_COERCE_BOOL(a, b);\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b)) {\n"
    buf = buf + "        // 이전엔 silent 0 반환 → 버그 은폐. interp 는 이미 throw + void.\n"
    buf = buf + "        // hexa_throw 는 try-stack 이 있으면 longjmp, 없으면 stderr + exit.\n"
    buf = buf + "        if (HX_INT(b) == 0) { hexa_throw(hexa_str(\"division by zero\")); return hexa_int(0); }\n"
    buf = buf + "        return hexa_int(HX_INT(a) / HX_INT(b));\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FLOAT(a) && HX_IS_FLOAT(b)) {\n"
    buf = buf + "        if (HX_FLOAT(b) == 0.0) { hexa_throw(hexa_str(\"division by zero\")); return hexa_float(0.0); }\n"
    buf = buf + "        return hexa_float(HX_FLOAT(a) / HX_FLOAT(b));\n"
    buf = buf + "    }\n"
    buf = buf + "    // PROBE r14-DD (T follow-up): mixed int/float divide promotes int to\n"
    buf = buf + "    // double and routes to IEEE float divide.  `1 / 0.0` → +inf, `-1 / 0.0`\n"
    buf = buf + "    // → -inf, `0 / 0.0` → NaN — same canonical as Python/JS/Rust runtime.\n"
    buf = buf + "    // Pure int/int still throws (Python canonical) via the branch above.\n"
    buf = buf + "    // PR #497 (r14-T) closes the codegen literal-fold side; this closes the\n"
    buf = buf + "    // runtime-value side.\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_FLOAT(b)) {\n"
    buf = buf + "        return hexa_float((double)HX_INT(a) / HX_FLOAT(b));\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FLOAT(a) && HX_IS_INT(b)) {\n"
    buf = buf + "        return hexa_float(HX_FLOAT(a) / (double)HX_INT(b));\n"
    buf = buf + "    }\n"
    buf = buf + "    // PROBE r16 (#807 sibling): a non-numeric operand (e.g. string) is a TYPE\n"
    buf = buf + "    // ERROR, not a silent 0.0. Before this guard `\"ab\" / 3` quietly returned 0.0\n"
    buf = buf + "    // because __hx_to_double() coerces a string to 0.0. All four numeric pairings\n"
    buf = buf + "    // (int/int, float/float, mixed) are handled above; only non-numeric reaches here.\n"
    buf = buf + "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n"
    buf = buf + "        char _buf[96];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"cannot divide non-numeric operand (tag %d / tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return hexa_float(0.0);\n"
    buf = buf + "    }\n"
    buf = buf + "    double fb = __hx_to_double(b);\n"
    buf = buf + "    if (fb == 0.0) { hexa_throw(hexa_str(\"division by zero\")); return hexa_float(0.0); }\n"
    buf = buf + "    return hexa_float(__hx_to_double(a) / fb);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "// RUNTIME.md Step 4 .c-none arith core op 4: hexa_mod delegates to hexa-source\n"
    buf = buf + "// rt_mod (numeric.hexa) under HEXA_HAS_HEXA_RT_STDLIB; int modulo via __raw_imod\n"
    buf = buf + "// codegen escape (same `%`-operator recursion reason as rt_div). #else C body\n"
    buf = buf + "// kept bit-for-bit. int/int + any-numeric throw on zero; fmod for the rest.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_mod(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_mod(HexaVal a, HexaVal b) { return rt_mod(a, b); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_mod(HexaVal a, HexaVal b) {\n"
    buf = buf + "    _HX_COERCE_BOOL(a, b);\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b)) {\n"
    buf = buf + "        if (HX_INT(b) == 0) { hexa_throw(hexa_str(\"modulo by zero\")); return hexa_int(0); }\n"
    buf = buf + "        return hexa_int(HX_INT(a) % HX_INT(b));\n"
    buf = buf + "    }\n"
    buf = buf + "    // PROBE r16 (#807 sibling): a non-numeric operand (e.g. string) is a TYPE\n"
    buf = buf + "    // ERROR, not a silent 0.0. Before this guard `\"ab\" % 3` quietly returned 0.0\n"
    buf = buf + "    // because __hx_to_double() coerces a string to 0.0. Mixed int/float still\n"
    buf = buf + "    // promotes to fmod below; only non-numeric operands reach this guard.\n"
    buf = buf + "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n"
    buf = buf + "        char _buf[96];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"cannot compute modulo of non-numeric operand (tag %d %% tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return hexa_float(0.0);\n"
    buf = buf + "    }\n"
    buf = buf + "    double fb = __hx_to_double(b);\n"
    buf = buf + "    if (fb == 0.0) { hexa_throw(hexa_str(\"modulo by zero\")); return hexa_float(0.0); }\n"
    buf = buf + "    return hexa_float(hxlcl_fmod(__hx_to_double(a), fb));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ROI-44: comparison runtime helpers — replace inline GCC stmt-expr in codegen.\n"
    buf = buf + "// Semantics: TAG_FLOAT promotes to double compare; TAG_INT uses int64 compare.\n"
    buf = buf + "// 2026-04-17: TAG_VALSTRUCT (interpreter Val wrapper) routes through\n"
    buf = buf + "// __hx_to_double so wrapped ints compare on the inner value rather than\n"
    buf = buf + "// HX_INT(v) reading the .vs pointer as garbage. Symptom before fix:\n"
    buf = buf + "// `let x = 5; let z = 1 + x` returned 0xA00000005 because val_int's cache\n"
    buf = buf + "// range check `n < __VAL_INT_CACHE_LEN` mis-evaluated when one side was\n"
    buf = buf + "// a wrapped Val from the cached singleton table.\n"
    buf = buf + "// String comparisons via strcmp — 이전 경로는 __hx_to_double(\"abc\") = atof\n"
    buf = buf + "// 으로 fallthrough 해서 대부분 0.0 으로 수렴 + intern pointer 비교로 떨어져\n"
    buf = buf + "// 의미 없는 순서 (abc>abb=false 같은 오류).\n"
    buf = buf + "// PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): cross-cutting helper used\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// by lt/gt/le/ge. Returns 1 if both operands are TAG_ENUM with descriptors\n"
    buf = buf + "// from the same enum type AND writes (a_idx, b_idx) into `*out_a` / `*out_b`.\n"
    buf = buf + "// Returns 0 otherwise (caller falls through to non-enum dispatch). Same-enum\n"
    buf = buf + "// gate uses type_name pointer-eq when both descriptors live in the same TU\n"
    buf = buf + "// (codegen emits one __enum_type_name_<Name> static literal per enum), else\n"
    buf = buf + "// strcmp on the type_name string. Two distinct enums comparing must NOT\n"
    buf = buf + "// silently fold; we punt to the legacy `HX_INT < HX_INT` fallback (the .s\n"
    buf = buf + "// pointer cast to int64 — gives DEFINED-BUT-MEANINGLESS ordering that won't\n"
    buf = buf + "// crash but won't satisfy total order across enum types either, matching the\n"
    buf = buf + "// status quo for any \"compare two values of unrelated types\" call).\n"
    buf = buf + "static inline int _hexa_enum_pair_idx(HexaVal a, HexaVal b,\n"
    buf = buf + "                                      int64_t* out_a, int64_t* out_b) {\n"
    buf = buf + "    if (HX_TAG(a) != TAG_ENUM || HX_TAG(b) != TAG_ENUM) return 0;\n"
    buf = buf + "    const char* ta = _hexa_enum_type_name(a);\n"
    buf = buf + "    const char* tb = _hexa_enum_type_name(b);\n"
    buf = buf + "    if (!ta || !tb) return 0; // one or both are legacy bare-string form\n"
    buf = buf + "    if (ta != tb && hxlcl_strcmp(ta, tb) != 0) return 0; // different enum types\n"
    buf = buf + "    *out_a = _hexa_enum_idx(a);\n"
    buf = buf + "    *out_b = _hexa_enum_idx(b);\n"
    buf = buf + "    return 1;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// RFC r16 (PROBE r16): once the enum / str-str / numeric branches are\n"
    buf = buf + "// exhausted, the only operands that may legitimately read through the\n"
    buf = buf + "// `HX_INT(a) < HX_INT(b)` fall-through are those whose value lives in the\n"
    buf = buf + "// int slot — TAG_INT, TAG_BOOL, TAG_CHAR (and legacy cross-type TAG_ENUM,\n"
    buf = buf + "// whose meaningless-but-defined fallback the r14-TTTT contract preserves).\n"
    buf = buf + "// Any other tag (TAG_STR mismatched against a non-str, TAG_ARRAY, TAG_MAP,\n"
    buf = buf + "// TAG_FN, TAG_CLOSURE, TAG_VOID) would have its heap pointer read as int64\n"
    buf = buf + "// → silent meaningless ordering (`1 < \"a\"` TRUE, `\"a\" < 1` FALSE — not even\n"
    buf = buf + "// antisymmetric; `[] < []` TRUE). Such incomparable pairs are a TYPE ERROR,\n"
    buf = buf + "// mirroring the `-` `/` `%` non-numeric throw (#807 sibling) and Python3's\n"
    buf = buf + "// cross-type-order TypeError. Same-type ordering, numeric int/float promotion,\n"
    buf = buf + "// and `==`/`!=` are all unaffected (handled by the branches above this guard).\n"
    buf = buf + "static inline int _hx_int_slot_ordered(HexaVal v) {\n"
    buf = buf + "    int t = (int)HX_TAG(v);\n"
    buf = buf + "    return t == TAG_INT || t == TAG_BOOL || t == TAG_CHAR || t == TAG_ENUM;\n"
    buf = buf + "}\n"
    buf = buf + "static inline void _hx_cmp_guard(HexaVal a, HexaVal b, const char* op) {\n"
    buf = buf + "    if (!_hx_int_slot_ordered(a) || !_hx_int_slot_ordered(b)) {\n"
    buf = buf + "        char _buf[96];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"cannot compare tag %d with tag %d (operator %s)\",\n"
    buf = buf + "                 (int)HX_TAG(a), (int)HX_TAG(b), op);\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// RUNTIME.md Step 4 .c-none — comparison family (cmp_lt/gt/le/ge). Two bridges\n"
    buf = buf + "// expose the irreducible leaf ops (enum-pair ordinal · hxlcl_strcmp · float-coerce\n"
    buf = buf + "// compare needing tag introspection); the hexa rt_cmp_* (numeric.hexa) own only\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// the per-operator selection + throw.\n"
    buf = buf + "//\n"
    buf = buf + "// __raw_cmp3 returns a NON-NEGATIVE ordering code: 0 a<b · 1 a==b · 2 a>b · 3\n"
    buf = buf + "// unordered (float NaN → all comparisons false) · 4 incomparable (rt_cmp throws).\n"
    buf = buf + "// Float/valstruct is folded in HERE (native double compare, NaN-aware via the `3`\n"
    buf = buf + "// sentinel) — no per-op hexa float compare needed.\n"
    buf = buf + "//\n"
    buf = buf + "// CRITICAL — codes MUST be non-negative: a negative literal in the hexa rt_cmp\n"
    buf = buf + "// (`-1`) lowers to `hexa_sub(hexa_int(0), hexa_int(1))` (runtime subtract) → rt_sub\n"
    buf = buf + "// → `type_of==` (hexa_eq) → rt_eq → string-eq (`a<=b && a>=b`) → hexa_cmp_le →\n"
    buf = buf + "// rt_cmp_le = INFINITE RECURSION (stack overflow observed). The arith ports work\n"
    buf = buf + "// precisely because they only use non-negative kind codes (0/1/2). Likewise rt_cmp\n"
    buf = buf + "// must test the code with __raw_code_is (C int-eq) not hexa `==` (→ rt_eq → cmp).\n"
    buf = buf + "static inline HexaVal __raw_cmp3(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ia, ib;\n"
    buf = buf + "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_int(ia < ib ? 0 : (ia > ib ? 2 : 1));\n"
    buf = buf + "    if (HX_IS_STR(a) && HX_IS_STR(b)) {\n"
    buf = buf + "        int _c = hxlcl_strcmp(HX_STR(a), HX_STR(b));\n"
    buf = buf + "        return hexa_int(_c < 0 ? 0 : (_c > 0 ? 2 : 1));\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b)) {\n"
    buf = buf + "        double _x = __hx_to_double(a), _y = __hx_to_double(b);\n"
    buf = buf + "        if (_x < _y) return hexa_int(0);\n"
    buf = buf + "        if (_x > _y) return hexa_int(2);\n"
    buf = buf + "        if (_x == _y) return hexa_int(1);\n"
    buf = buf + "        return hexa_int(3); // NaN-unordered → every comparison false\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!_hx_int_slot_ordered(a) || !_hx_int_slot_ordered(b)) return hexa_int(4);\n"
    buf = buf + "    int64_t _xi = HX_INT(a), _yi = HX_INT(b);\n"
    buf = buf + "    return hexa_int(_xi < _yi ? 0 : (_xi > _yi ? 2 : 1));\n"
    buf = buf + "}\n"
    buf = buf + "static inline HexaVal __raw_code_is(HexaVal v, HexaVal k) { return hexa_bool(HX_INT(v) == HX_INT(k)); }\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_cmp_lt(HexaVal a, HexaVal b);\n"
    buf = buf + "extern HexaVal rt_cmp_gt(HexaVal a, HexaVal b);\n"
    buf = buf + "extern HexaVal rt_cmp_le(HexaVal a, HexaVal b);\n"
    buf = buf + "extern HexaVal rt_cmp_ge(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_cmp_lt(HexaVal a, HexaVal b) { return rt_cmp_lt(a, b); }\n"
    buf = buf + "HexaVal hexa_cmp_gt(HexaVal a, HexaVal b) { return rt_cmp_gt(a, b); }\n"
    buf = buf + "HexaVal hexa_cmp_le(HexaVal a, HexaVal b) { return rt_cmp_le(a, b); }\n"
    buf = buf + "HexaVal hexa_cmp_ge(HexaVal a, HexaVal b) { return rt_cmp_ge(a, b); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_cmp_lt(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ia, ib;\n"
    buf = buf + "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia < ib);\n"
    buf = buf + "    if (HX_IS_STR(a) && HX_IS_STR(b))\n"
    buf = buf + "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) < 0);\n"
    buf = buf + "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n"
    buf = buf + "        return hexa_bool(__hx_to_double(a) < __hx_to_double(b));\n"
    buf = buf + "    _hx_cmp_guard(a, b, \"<\");\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    return hexa_bool(HX_INT(a) < HX_INT(b));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_cmp_gt(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ia, ib;\n"
    buf = buf + "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia > ib);\n"
    buf = buf + "    if (HX_IS_STR(a) && HX_IS_STR(b))\n"
    buf = buf + "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) > 0);\n"
    buf = buf + "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n"
    buf = buf + "        return hexa_bool(__hx_to_double(a) > __hx_to_double(b));\n"
    buf = buf + "    _hx_cmp_guard(a, b, \">\");\n"
    buf = buf + "    return hexa_bool(HX_INT(a) > HX_INT(b));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_cmp_le(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ia, ib;\n"
    buf = buf + "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia <= ib);\n"
    buf = buf + "    if (HX_IS_STR(a) && HX_IS_STR(b))\n"
    buf = buf + "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) <= 0);\n"
    buf = buf + "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n"
    buf = buf + "        return hexa_bool(__hx_to_double(a) <= __hx_to_double(b));\n"
    buf = buf + "    _hx_cmp_guard(a, b, \"<=\");\n"
    buf = buf + "    return hexa_bool(HX_INT(a) <= HX_INT(b));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_cmp_ge(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ia, ib;\n"
    buf = buf + "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia >= ib);\n"
    buf = buf + "    if (HX_IS_STR(a) && HX_IS_STR(b))\n"
    buf = buf + "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) >= 0);\n"
    buf = buf + "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n"
    buf = buf + "        return hexa_bool(__hx_to_double(a) >= __hx_to_double(b));\n"
    buf = buf + "    _hx_cmp_guard(a, b, \">=\");\n"
    buf = buf + "    return hexa_bool(HX_INT(a) >= HX_INT(b));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 58 port — float fast-path bridge. Mixed-type arrays\n"
    buf = buf + "// stay on the polymorphic hexa_eq path. Int return preserved (codegen\n"
    buf = buf + "// wraps in `hexa_bool(...)` like starts_with). _arr_all_float helper\n"
    buf = buf + "// is inlined here (lives static in runtime.c — copy-pattern from\n"
    buf = buf + "// hexa_array_reverse above).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "int hexa_array_contains(HexaVal arr, HexaVal item) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return 0;\n"
    buf = buf + "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n"
    buf = buf + "        if (hexa_truthy(hexa_eq(HX_ARR_ITEMS(arr)[i], item))) return 1;\n"
    buf = buf + "    }\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_array_contains_float_b(HexaVal arr, HexaVal item);\n"
    buf = buf + "int hexa_array_contains(HexaVal arr, HexaVal item) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return 0;\n"
    buf = buf + "    if (HX_IS_FLOAT(item)) {\n"
    buf = buf + "        int all_float = 1;\n"
    buf = buf + "        int64_t n = HX_ARR_LEN(arr);\n"
    buf = buf + "        for (int64_t i = 0; i < n; i++) {\n"
    buf = buf + "            if (!HX_IS_FLOAT(HX_ARR_ITEMS(arr)[i])) { all_float = 0; break; }\n"
    buf = buf + "        }\n"
    buf = buf + "        if (all_float) {\n"
    buf = buf + "            return hexa_truthy(rt_array_contains_float_b(arr, item)) ? 1 : 0;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n"
    buf = buf + "        if (hexa_truthy(hexa_eq(HX_ARR_ITEMS(arr)[i], item))) return 1;\n"
    buf = buf + "    }\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// count_substr(s, substr): number of non-overlapping occurrences.\n"
    buf = buf + "// Matches interpreter's greedy advance (hexa_full.hexa:14954-14973).\n"
    buf = buf + "// Step-3 cycle 27 port.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_count_substr(HexaVal s, HexaVal sub) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return hexa_int(0);\n"
    buf = buf + "    const char* src = HX_STR(s);\n"
    buf = buf + "    const char* pat = HX_STR(sub);\n"
    buf = buf + "    int plen = (int)hxlcl_strlen(pat);\n"
    buf = buf + "    if (plen == 0) return hexa_int(0);\n"
    buf = buf + "    int64_t cnt = 0;\n"
    buf = buf + "    const char* p = src;\n"
    buf = buf + "    while ((p = hxlcl_strstr(p, pat)) != NULL) {\n"
    buf = buf + "        cnt++;\n"
    buf = buf + "        p += plen; // non-overlapping\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_int(cnt);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_count_substr(HexaVal s, HexaVal sub);\n"
    buf = buf + "HexaVal hexa_str_count_substr(HexaVal s, HexaVal sub) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return hexa_int(0);\n"
    buf = buf + "    return rt_str_count_substr(s, sub);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 60 port — snprintf \"%.*f\" replaced by hexa-source\n"
    buf = buf + "// rt_format_float_f. Caveats: works exactly for values within ±2^53\n"
    buf = buf + "// and prec ≤ 18; beyond that the int64 round-trip is lossy. The C\n"
    buf = buf + "// body remains as the no-stdlib fallback.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_format_float(HexaVal f, HexaVal prec) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    double v = __hx_to_double(f);\n"
    buf = buf + "    int p = HX_INT(prec);\n"
    buf = buf + "    char buf[64];\n"
    buf = buf + "    snprintf(buf, 64, \"%.*f\", p, v);\n"
    buf = buf + "    return hexa_str(buf);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_format_float_f(HexaVal v, HexaVal prec);\n"
    buf = buf + "HexaVal hexa_format_float(HexaVal f, HexaVal prec) {\n"
    buf = buf + "    return rt_format_float_f(hexa_float(__hx_to_double(f)), prec);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 61 port — snprintf \"%.*e\" replaced by hexa-source.\n"
    buf = buf + "// Uses rt_log10 for the exponent, rt_format_float_f for the mantissa.\n"
    buf = buf + "// Caveats: same int64 round-trip limit as cycle 60; mantissa rounding\n"
    buf = buf + "// boundary (9.99→10) is NOT renormalized.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_format_float_sci(HexaVal f, HexaVal prec) {\n"
    buf = buf + "    double v = __hx_to_double(f);\n"
    buf = buf + "    int p = HX_INT(prec);\n"
    buf = buf + "    char buf[64];\n"
    buf = buf + "    snprintf(buf, 64, \"%.*e\", p, v);\n"
    buf = buf + "    return hexa_str(buf);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_format_float_sci(HexaVal v, HexaVal prec);\n"
    buf = buf + "HexaVal hexa_format_float_sci(HexaVal f, HexaVal prec) {\n"
    buf = buf + "    return rt_format_float_sci(hexa_float(__hx_to_double(f)), prec);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    if buf.len() > 0 { _flush_runtime_core(out_path, buf) }
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "runtime_core.c" }
    emit_runtime_core_to(out_path)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[runtime_core_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[runtime_core_emit] wrote " + out_path)
    exit(0)
}
