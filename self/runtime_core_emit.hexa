    buf = buf + "        total_size += HX_STRLEN(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    size_t seplen = HX_STRLEN(sep);\n"
    buf = buf + "    total_size += (HX_ARR_LEN(arr) - 1) * seplen;\n"
    buf = buf + "    char* result = malloc(total_size + 1);\n"
    buf = buf + "    size_t total = 0;\n"
    buf = buf + "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n"
    buf = buf + "        if (i > 0) {\n"
    buf = buf + "            hxlcl_memcpy(result + total, HX_STR(sep), seplen);\n"
    buf = buf + "            total += seplen;\n"
    buf = buf + "        }\n"
    buf = buf + "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n"
    buf = buf + "        size_t slen = HX_STRLEN(s);\n"
    buf = buf + "        hxlcl_memcpy(result + total, HX_STR(s), slen);\n"
