    buf = buf + "                    hxlcl_memcpy(next_items, HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)HX_ARR_LEN(arr));\n"
    buf = buf + "                }\n"
    buf = buf + "                HX_SET_ARR_ITEMS(arr, next_items);\n"
    buf = buf + "                HX_SET_ARR_CAP(arr, -new_cap);\n"
    buf = buf + "            } else {\n"
    buf = buf + "                // Promote to heap.\n"
    buf = buf + "                if (_hx_stats_on()) _hx_stats_array_arena_promote++;\n"
    buf = buf + "                HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(arr), HX_ARR_LEN(arr), new_cap);\n"
    buf = buf + "                if (HX_UNLIKELY(!heap)) { fprintf(stderr, \"OOM in array_push (arena promote)\\n\"); exit(1); }\n"
    buf = buf + "                HX_SET_ARR_ITEMS(arr, heap);\n"
    buf = buf + "                HX_SET_ARR_CAP(arr, new_cap);  // positive → heap\n"
    buf = buf + "            }\n"
    buf = buf + "        } else {\n"
    buf = buf + "            // rt#32-N: push-arena path (cap=0 first-push or existing heap\n"
    buf = buf + "            // grow). Enabled by HEXA_ARRAY_PUSH_ARENA=1 once the transpiler\n"
    buf = buf + "            // wraps snapshot-capture sites with hexa_val_snapshot_array.\n"
    buf = buf + "            // Without snapshot-promote, Hexa pass-by-value (I1) aliasing\n"
    buf = buf + "            // makes caller snapshots invalid across callee arena rewinds.\n"
    buf = buf + "            //\n"
    buf = buf + "            // Only fires on FIRST allocation (cap==0) — subsequent grows on\n"
    buf = buf + "            // an existing heap buffer continue to realloc as before (no\n"
    buf = buf + "            // aliasing delta). When mark_top > 0 and arena is on, the fresh\n"
    buf = buf + "            // buffer is arena-allocated with cap=-new_cap.\n"
    buf = buf + "            HexaVal* next_items = NULL;\n"
    buf = buf + "            int use_arena = 0;\n"
    buf = buf + "            if (real_cap == 0\n"
    buf = buf + "                && __hexa_val_mark_top > 0\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                && hexa_array_arena_on()\n"
    buf = buf + "                && hexa_array_push_arena_on()) {\n"
    buf = buf + "                next_items = hexa_array_arena_alloc_items(new_cap);\n"
    buf = buf + "                if (next_items) {\n"
    buf = buf + "                    use_arena = 1;\n"
    buf = buf + "                    if (_hx_stats_on()) _hx_stats_array_arena_alloc++;\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            if (use_arena) {\n"
    buf = buf + "                HX_SET_ARR_ITEMS(arr, next_items);\n"
    buf = buf + "                HX_SET_ARR_CAP(arr, -new_cap);  // negative → from_arena sentinel\n"
    buf = buf + "            } else {\n"
    buf = buf + "                HexaVal* new_items = realloc(HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)new_cap);\n"
    buf = buf + "                if (HX_UNLIKELY(!new_items)) { fprintf(stderr, \"OOM in array_push\\n\"); exit(1); }\n"
    buf = buf + "                HX_SET_ARR_ITEMS(arr, new_items);\n"
    buf = buf + "                HX_SET_ARR_CAP(arr, new_cap);\n"
    buf = buf + "            }\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    // FIX 2026-05-13 (wilson-fn-arena-escapes-on-push): when pushing into an\n"
    buf = buf + "    // array whose item buffer lives on the heap (cap >= 0), and we're inside a\n"
