    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_char_count(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_int(0);\n"
    buf = buf + "    const char* p = HX_STR(s);\n"
    buf = buf + "    int64_t n = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    int64_t count = 0;\n"
    buf = buf + "    int64_t i = 0;\n"
    buf = buf + "    while (i < n) {\n"
    buf = buf + "        i += _hx_utf8_cp_len((unsigned char)p[i]);\n"
    buf = buf + "        count++;\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_int(count);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_char_count(HexaVal s);\n"
    buf = buf + "HexaVal hexa_str_char_count(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_int(0);\n"
    buf = buf + "    return rt_str_char_count(s);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Codepoint-indexed nth char as a 1-codepoint string (1..4 bytes).\n"
    buf = buf + "// Returns \"\" for negative or out-of-range n.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// Step-3 cycle 53 — dispatches to rt_str_nth_char (UTF-8 walker).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_nth_char(HexaVal s, HexaVal nv) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n"
    buf = buf + "    int64_t target = HX_INT(nv);\n"
    buf = buf + "    if (target < 0) return hexa_str(\"\");\n"
    buf = buf + "    const char* p = HX_STR(s);\n"
    buf = buf + "    int64_t sn = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    int64_t i = 0, k = 0;\n"
    buf = buf + "    while (i < sn) {\n"
    buf = buf + "        int cp = _hx_utf8_cp_len((unsigned char)p[i]);\n"
    buf = buf + "        if (k == target) {\n"
    buf = buf + "            char buf[5] = {0};\n"
    buf = buf + "            int j = 0;\n"
    buf = buf + "            while (j < cp && i + j < sn) { buf[j] = p[i + j]; j++; }\n"
    buf = buf + "            buf[j] = 0;\n"
    buf = buf + "            return hexa_str(buf);\n"
    buf = buf + "        }\n"
    buf = buf + "        i += cp;\n"
    buf = buf + "        k++;\n"
    buf = buf + "    }\n"
