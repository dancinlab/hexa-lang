    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────────────\n"
    buf = buf + "// M1-lite (hxa-20260423-003 Step 4): rt_str_* layer from runtime_hi.hexa\n"
    buf = buf + "// SSOT. Must appear AFTER hexa_str_join (depended on by pad_left/pad_right/\n"
    buf = buf + "// repeat/center) and AFTER hexa_str_substring (depended on by rt_str_split).\n"
    buf = buf + "// Shims below forward the public hexa_str_* symbols to the generated\n"
