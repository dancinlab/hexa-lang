    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Codepoint-indexed substring [start..end). `\"한글hi\".char_substring(0, 2) == \"한글\"`.\n"
    buf = buf + "// Step-3 cycle 53 — dispatches to rt_str_char_substring (UTF-8 walker\n"
    buf = buf + "// finds byte boundaries that correspond to the codepoint indices).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_char_substring(HexaVal s, HexaVal startv, HexaVal endv) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n"
