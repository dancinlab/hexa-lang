    buf = buf + "HexaVal hexa_swiglu_vec(HexaVal gate, HexaVal up);\n"
    buf = buf + "\n"
    buf = buf + "// RT-P3-1 wrapper shims — tagged-value → C-native conversion for codegen regen\n"
    buf = buf + "// path. Close Wint-conversion / Wpointer-arith categories in the\n"
    buf = buf + "// interpreter.hexa → .c baseline. See self/runtime_hexaval_DESIGN.md\n"
    buf = buf + "// §Production runtime (live).\n"
    buf = buf + "int64_t     hexa_as_num(HexaVal v);\n"
    buf = buf + "const char* hexa_to_cstring(HexaVal v);\n"
    buf = buf + "const char* hexa_str_as_ptr(HexaVal v);\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-G Phase 0: flat Val struct forward decls (implementation below).\n"
    buf = buf + "// NOTE: parameter-less typedef stays outside so the struct body later in\n"
    buf = buf + "// this file keeps using the same name. Function decls reference HexaVal\n"
    buf = buf + "// (defined below) and the fully-defined HexaValStruct — OK because the C\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// compiler only needs full types at call sites, not at forward decls.\n"
    buf = buf + "typedef struct HexaValStruct HexaValStruct;\n"
    buf = buf + "// Redesign: only the _v variant is exposed. All non-scalar arguments are\n"
    buf = buf + "// passed as HexaVal so polymorphic payloads (closures, AST bodies, struct\n"
    buf = buf + "// field maps) survive verbatim instead of being coerced to \"\".\n"
    buf = buf + "HexaVal hexa_valstruct_new_v(HexaVal, HexaVal, HexaVal, HexaVal, HexaVal,\n"
    buf = buf + "    HexaVal, HexaVal, HexaVal, HexaVal, HexaVal, HexaVal, HexaVal);\n"
    buf = buf + "HexaVal hexa_valstruct_int(HexaVal v);\n"
    buf = buf + "HexaVal hexa_valstruct_get_by_key(HexaVal v, const char* key);\n"
    buf = buf + "HexaVal hexa_valstruct_set_by_key(HexaVal v, const char* key, HexaVal val);\n"
    buf = buf + "\n"
    buf = buf + "// rt#37: inline cache for obj.field — the struct is defined here so every\n"
    buf = buf + "// generated C file (via #include \"runtime.c\") can declare `static HexaIC`\n"
    buf = buf + "// slots. The lookup itself is defined below as `static inline`.\n"
    buf = buf + "typedef struct HexaIC {\n"
    buf = buf + "    void* keys_ptr;   // last-seen m.map.keys pointer (shape id)\n"
    buf = buf + "    int   len;        // last-seen m.map.len\n"
    buf = buf + "    int   idx;        // cached field offset\n"
    buf = buf + "    uint64_t hits;\n"
    buf = buf + "    uint64_t misses;\n"
    buf = buf + "} HexaIC;\n"
    buf = buf + "\n"
    buf = buf + "// ── Tagged Value ─────────────────────────────────────────\n"
    buf = buf + "// All HEXA values are represented as tagged unions (NaN-boxing alternative)\n"
    buf = buf + "\n"
    buf = buf + "typedef enum {\n"
    buf = buf + "    TAG_INT = 0, TAG_FLOAT, TAG_BOOL, TAG_STR, TAG_VOID,\n"
    buf = buf + "    TAG_ARRAY, TAG_MAP, TAG_FN, TAG_CHAR, TAG_CLOSURE,\n"
    buf = buf + "    // rt 32-G Phase 0: flat C struct replacement for interpreter `Val` map.\n"
    buf = buf + "    // Val is the interpreter's tagged value carrier — ~3.37M constructions\n"
    buf = buf + "    // per d64 200-step run. Each map-backed Val = 1 map_new + 12 map_set =\n"
    buf = buf + "    // 13 hash-table insertions. Replacing with a flat 12-field C struct\n"
    buf = buf + "    // collapses that to a single heap alloc, eliminating 7GB+ RSS pressure.\n"
    buf = buf + "    // Fields mirror `struct Val` in self/hexa_full.hexa exactly (12 fields).\n"
    buf = buf + "    TAG_VALSTRUCT,\n"
    buf = buf + "    // PR-2.0 (enum-to-string-codegen-emit RFC, stack PR-2/3, 2026-05-24):\n"
    buf = buf + "    // dedicated tag for enum values. PR-2.0 reserves the slot + defensive\n"
    buf = buf + "    // _hexa_to_string_rec/hexa_eq/hexa_type_of branches; no emitter\n"
    buf = buf + "    // produces TAG_ENUM yet (gen2_enum_decl still emits `hexa_int(N)`).\n"
    buf = buf + "    // Slot kept LAST so existing TAG_VALSTRUCT integer value is preserved\n"
    buf = buf + "    // (no ABI shift on any pre-built object).\n"
    buf = buf + "    TAG_ENUM\n"
    buf = buf + "} HexaTag;\n"
    buf = buf + "\n"
    buf = buf + "// ── Optimization #10: Hash-map backing store ─────────────\n"
    buf = buf + "// Open-addressing hash table (Robin Hood not needed at this scale).\n"
    buf = buf + "// Stored on the heap; the HexaVal map union holds a pointer + len.\n"
    buf = buf + "// Keeps a parallel insertion-order array for keys()/values()/iter.\n"
    buf = buf + "\n"
    buf = buf + "#define HMAP_INIT_CAP   16\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#define HMAP_LOAD_MAX   75  // percent\n"
    buf = buf + "\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    char*  key;       // owned string (strdup'd) -- NULL means empty slot\n"
    buf = buf + "    uint32_t hash;    // cached FNV-1a of key\n"
    buf = buf + "    int order_idx;    // ROI-24: index into order_keys/order_vals arrays — O(1) update\n"
    buf = buf + "} HexaMapSlot;\n"
    buf = buf + "\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    HexaMapSlot* slots;   // hash table (power-of-2 sized)\n"
    buf = buf + "    HexaVal* vals;  // parallel values array (same indices as slots)\n"
    buf = buf + "    int ht_cap;            // hash table capacity (power-of-2)\n"
    buf = buf + "\n"
    buf = buf + "    // Insertion-order arrays for keys()/values()/for-in iteration\n"
    buf = buf + "    char** order_keys;     // ordered key pointers (point into slots[].key)\n"
    buf = buf + "    HexaVal* order_vals; // ordered values\n"
    buf = buf + "    int len;               // number of entries\n"
    buf = buf + "    int order_cap;         // allocated capacity for order arrays\n"
    buf = buf + "    // rt 32-L: Val-arena support. When non-zero, this table + its slot/val/\n"
    buf = buf + "    // order arrays were allocated from the bump arena (NOT malloc). Such tables\n"
    buf = buf + "    // MUST be heapified before they outlive the current scope; otherwise an\n"
    buf = buf + "    // arena rewind invalidates the backing storage. Slots' .key strings are\n"
    buf = buf + "    // ALWAYS strdup'd (heap) regardless of from_arena, because the arena is\n"
    buf = buf + "    // bulk-rewound and per-string lifetime tracking is impractical here.\n"
    buf = buf + "    int from_arena;\n"
    buf = buf + "} HexaMapTable;\n"
    buf = buf + "\n"
    buf = buf + "// ── S1-D3a: Heap descriptor structs for compound types ───\n"
    buf = buf + "// NaN-boxing prep: inline union members → heap-allocated descriptors.\n"
    buf = buf + "// sizeof(HexaVal) unchanged (largest union member is still a pointer).\n"
    buf = buf + "typedef struct HexaArr {\n"
    buf = buf + "    HexaVal* items;\n"
    buf = buf + "    int len;\n"
    buf = buf + "    int cap;\n"
    buf = buf + "} HexaArr;\n"
    buf = buf + "\n"
    // ── UNSHADOW [HEADLINE] F1: native unboxed-i64 array storage ────────────
    // The boxed HexaArr above is a 16-byte-stride array of HexaVal (the axis-A
    // closed-negative proved clang CANNOT SIMD-gather it). HexaArrI64 is the
    // native contiguous int64_t[] storage (8-byte stride, gatherable) the
    // codegen emits for a statically-proven monomorphic-i64 array. It is laid
    // out so its first member is a pointer (like HexaArr->items) so a HexaVal
    // with tag TAG_ARRAY can carry either via the SAME arr_ptr union slot — the
    // codegen + helpers always discriminate on whether the binding was proven
    // i64; the boxed path is byte-for-byte unchanged. data[] is public here so
    // codegen can emit a direct `((HexaArrI64*)a.arr_ptr)->data[i]` raw read
    // through the runtime.o C-ABI wall (the §c-class wall-piercing pattern).
    buf = buf + "typedef struct HexaArrI64 {\n"
    buf = buf + "    int64_t* data;\n"
    buf = buf + "    int len;\n"
    buf = buf + "    int cap;\n"
    buf = buf + "} HexaArrI64;\n"
    buf = buf + "\n"
    // ── UNSHADOW [HEADLINE] F1 (F64 mirror): native unboxed-f64 array storage ──
    // The double[] analogue of HexaArrI64. The boxed HexaArr is a 16-byte-stride
    // array of HexaVal (axis-A closed-negative: clang CANNOT SIMD-gather it).
    // HexaArrF64 is native contiguous double[] (8-byte stride, gatherable) the
    // codegen emits for a statically-proven monomorphic-f64 array literal. Layout
    // matches HexaArr/HexaArrI64 (ptr, int len, int cap) so a TAG_ARRAY HexaVal
    // carries it via the SAME arr_ptr union slot and polymorphic `hexa_len` reads
    // len at the same offset. data[] is public so codegen emits a direct
    // `((HexaArrF64*)a.arr_ptr)->data[i]` raw double load through the C-ABI wall.
    buf = buf + "typedef struct HexaArrF64 {\n"
    buf = buf + "    double* data;\n"
    buf = buf + "    int len;\n"
    buf = buf + "    int cap;\n"
    buf = buf + "} HexaArrF64;\n"
    buf = buf + "\n"
    buf = buf + "typedef struct HexaMap {\n"
    buf = buf + "    HexaMapTable* tbl;\n"
    buf = buf + "    int len;\n"
    buf = buf + "} HexaMap;\n"
    buf = buf + "\n"
    buf = buf + "typedef struct HexaFn {\n"
    buf = buf + "    void* fn_ptr;\n"
    buf = buf + "    int arity;\n"
    buf = buf + "} HexaFn;\n"
    buf = buf + "\n"
    buf = buf + "typedef struct HexaClo {\n"
    buf = buf + "    void* fn_ptr;\n"
    buf = buf + "    int arity;\n"
    buf = buf + "    HexaVal* env_box;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "} HexaClo;\n"
    buf = buf + "\n"
    buf = buf + "// HexaVal must be defined before HexaValStruct so that HexaValStruct's\n"
    buf = buf + "// HexaVal-by-value fields (rt 32-G redesign) have a complete type. HexaVal\n"
    buf = buf + "// only needs HexaValStruct as a *pointer* (.vs), so the forward decl above\n"
    buf = buf + "// (typedef struct HexaValStruct HexaValStruct) is sufficient here.\n"
    buf = buf + "typedef struct HexaVal_ {\n"
    buf = buf + "    HexaTag tag;\n"
    buf = buf + "    union {\n"
    buf = buf + "        int64_t i;\n"
    buf = buf + "        double f;\n"
    buf = buf + "        int b;\n"
    buf = buf + "        char* s;           // owned string (malloc'd)\n"
    buf = buf + "        HexaArr* arr_ptr;  // S1-D3a: heap descriptor (was inline struct)\n"
    buf = buf + "        HexaMap* map_ptr;  // S1-D3a: heap descriptor (was inline struct)\n"
    buf = buf + "        HexaFn*  fn_ptr_d; // S1-D3a: heap descriptor (was inline struct)\n"
    buf = buf + "        HexaClo* clo_ptr;  // S1-D3a: heap descriptor (was inline struct)\n"
    buf = buf + "        // rt 32-G: heap-allocated flat struct pointer (TAG_VALSTRUCT).\n"
    buf = buf + "        HexaValStruct* vs;\n"
    buf = buf + "    };\n"
    buf = buf + "} HexaVal;\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  STRUCTURAL-1 Phase A: NaN-boxing accessor macros\n"
    buf = buf + "//  Current: identity-map to tagged union fields (zero-cost).\n"
    buf = buf + "//  Phase B: macro bodies swap to NaN-boxed 8B representation.\n"
    buf = buf + "//  All hot-path code MUST use these instead of raw .tag/.i/.f etc.\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "#define HX_TAG(v)       ((v).tag)\n"
    buf = buf + "#define HX_INT(v)       ((v).i)\n"
    buf = buf + "#define HX_INT_U(v)     ((uint64_t)(v).i)   // unsigned read — safe for NaN-boxed pointers\n"
    buf = buf + "#define HX_FLOAT(v)     ((v).f)\n"
    buf = buf + "#define HX_BOOL(v)      ((v).b)\n"
    buf = buf + "#define HX_STR(v)       ((v).s)\n"
    buf = buf + "// S1-D3a: compound-type READ macros — dereference heap descriptors.\n"
    buf = buf + "// IMPORTANT: caller MUST ensure the tag matches before calling these;\n"
    buf = buf + "// they dereference the descriptor pointer unconditionally for performance.\n"
    buf = buf + "// The one exception is HX_MAP_TBL which is guarded because the IC\n"
    buf = buf + "// fast-path (hexa_map_get_ic) probes it before a tag check, and\n"
    buf = buf + "// hexa_map_get probes it on TAG_VALSTRUCT-routed values.\n"
    buf = buf + "#define HX_ARR_LEN(v)   ((v).arr_ptr->len)\n"
    buf = buf + "#define HX_ARR_ITEMS(v) ((v).arr_ptr->items)\n"
    buf = buf + "#define HX_ARR_CAP(v)   ((v).arr_ptr->cap)\n"
    buf = buf + "#define HX_MAP_LEN(v)   ((v).map_ptr->len)\n"
    buf = buf + "#define HX_MAP_TBL(v)   (HX_IS_MAP(v) ? (v).map_ptr->tbl : (HexaMapTable*)0)\n"
    buf = buf + "#define HX_FN_PTR(v)    ((v).fn_ptr_d->fn_ptr)\n"
    buf = buf + "#define HX_FN_ARITY(v)  ((v).fn_ptr_d->arity)\n"
    buf = buf + "#define HX_CLO_PTR(v)   ((v).clo_ptr->fn_ptr)\n"
    buf = buf + "#define HX_CLO_ARITY(v) ((v).clo_ptr->arity)\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#define HX_CLO_ENV(v)   ((v).clo_ptr->env_box)\n"
    buf = buf + "#define HX_VS(v)        ((v).vs)\n"
    buf = buf + "\n"
    buf = buf + "// ── S1-D3a: compound-type SET macros (write accessors) — heap descriptor ──\n"
    buf = buf + "#define HX_SET_ARR_ITEMS(v, p) ((v).arr_ptr->items = (p))\n"
    buf = buf + "#define HX_SET_ARR_LEN(v, n)   ((v).arr_ptr->len = (n))\n"
    buf = buf + "#define HX_SET_ARR_CAP(v, n)   ((v).arr_ptr->cap = (n))\n"
    buf = buf + "#define HX_SET_MAP_TBL(v, t)   ((v).map_ptr->tbl = (t))\n"
    buf = buf + "#define HX_SET_MAP_LEN(v, n)   ((v).map_ptr->len = (n))\n"
    buf = buf + "#define HX_SET_CLO_PTR(v, p)   ((v).clo_ptr->fn_ptr = (p))\n"
    buf = buf + "#define HX_SET_CLO_ARITY(v, n) ((v).clo_ptr->arity = (n))\n"
    buf = buf + "#define HX_SET_CLO_ENV(v, p)   ((v).clo_ptr->env_box = (p))\n"
    buf = buf + "\n"
    buf = buf + "// ── STRUCTURAL-1 Phase A: scalar + descriptor-pointer writer macros ──\n"
    buf = buf + "// Prep for NaN-boxing typedef flip (HexaVal → uint64_t). Once callers route\n"
    buf = buf + "// all writes through these macros, the macro bodies swap to encode-into-u64\n"
    buf = buf + "// in one place. Struct-initializer literals ({.tag=T, .i=n}) are OUT OF SCOPE\n"
    buf = buf + "// here — they need a different rewrite (constructor fns or the flip itself).\n"
    buf = buf + "#define HX_SET_TAG(v, t)       ((v).tag = (t))\n"
    buf = buf + "#define HX_SET_INT(v, n)       ((v).i = (n))\n"
    buf = buf + "#define HX_SET_FLOAT(v, f)     ((v).f = (f))\n"
    buf = buf + "#define HX_SET_BOOL(v, b)      ((v).b = (b))\n"
    buf = buf + "#define HX_SET_STR(v, p)       ((v).s = (p))\n"
    buf = buf + "#define HX_SET_ARR_PTR(v, p)   ((v).arr_ptr = (p))\n"
    buf = buf + "#define HX_SET_MAP_PTR(v, p)   ((v).map_ptr = (p))\n"
    buf = buf + "#define HX_SET_FN_PTR_D(v, p)  ((v).fn_ptr_d = (p))\n"
    buf = buf + "#define HX_SET_CLO_PTR_D(v, p) ((v).clo_ptr = (p))\n"
    buf = buf + "#define HX_SET_VS(v, p)        ((v).vs = (p))\n"
    buf = buf + "\n"
    buf = buf + "// HexaValStruct (inner) field access via v — routes through HX_VS so the\n"
    buf = buf + "// typedef flip can adjust the .vs bits in one spot. The inner HexaValStruct\n"
    buf = buf + "// remains a plain C struct — HX_VSF is pointer deref + member access.\n"
    buf = buf + "#define HX_VSF(v, field)       (HX_VS(v)->field)\n"
    buf = buf + "\n"
    buf = buf + "#define HX_IS_INT(v)    ((v).tag == TAG_INT)\n"
    buf = buf + "#define HX_IS_FLOAT(v)  ((v).tag == TAG_FLOAT)\n"
    buf = buf + "#define HX_IS_BOOL(v)   ((v).tag == TAG_BOOL)\n"
    buf = buf + "#define HX_IS_STR(v)    ((v).tag == TAG_STR)\n"
    buf = buf + "#define HX_IS_VOID(v)   ((v).tag == TAG_VOID)\n"
    buf = buf + "#define HX_IS_ARRAY(v)  ((v).tag == TAG_ARRAY)\n"
    buf = buf + "#define HX_IS_MAP(v)    ((v).tag == TAG_MAP)\n"
    buf = buf + "#define HX_IS_FN(v)     ((v).tag == TAG_FN)\n"
    buf = buf + "#define HX_IS_CLOSURE(v)((v).tag == TAG_CLOSURE)\n"
    buf = buf + "#define HX_IS_VALSTRUCT(v) ((v).tag == TAG_VALSTRUCT)\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-G Phase 0 (redesigned): flat C struct replacement for `Val` map.\n"
    buf = buf + "// Fields MUST mirror self/hexa_full.hexa `struct Val` exactly (order + types).\n"
    buf = buf + "// Heap-allocated once per Val construction, shared by value via pointer copy\n"
    buf = buf + "// of the containing HexaVal (no deep copy — mirrors current map.tbl pointer\n"
    buf = buf + "// sharing semantics). Lifetime: leak-compatible with current interpreter\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// (no free, same as existing map-backed Vals).\n"
    buf = buf + "//\n"
    buf = buf + "// REDESIGN (rt 32-G Phase 0 redesign): non-scalar fields are now full HexaVal\n"
    buf = buf + "// (polymorphic tagged union) instead of `const char*`. The original Phase 0\n"
    buf = buf + "// design assumed every non-scalar slot held a string, but val_fn / val_closure\n"
    buf = buf + "// store TAG_ARRAY (params) and TAG_MAP (AST body) values. The old design\n"
    buf = buf + "// silently coerced those to \"\" → closure body erased after rebootstrap.\n"
    buf = buf + "// HexaVal-by-value adds ~24B per slot but eliminates the data loss.\n"
    buf = buf + "typedef struct HexaValStruct {\n"
    buf = buf + "    int64_t tag_i;          // Hexa-level Val.tag (TAG_INT / TAG_FLOAT / ...)\n"
    buf = buf + "    int64_t int_val;\n"
    buf = buf + "    double  float_val;\n"
    buf = buf + "    int     bool_val;\n"
    buf = buf + "    // rt 32-L: 1 = allocated from the bump arena, 0 = malloc heap. Arena\n"
    buf = buf + "    // VALSTRUCTs MUST be heapified before they outlive the current scope.\n"
    buf = buf + "    // Sits in the alignment padding between bool_val (4B) and the first\n"
    buf = buf + "    // HexaVal (24B aligned to 8) — zero size cost in practice.\n"
    buf = buf + "    int     from_arena;\n"
    buf = buf + "    // Polymorphic slots — store the original HexaVal verbatim. For TAG_STR\n"
    buf = buf + "    // payloads this is just s/tag; for arrays/maps the .arr / .map / .vs\n"
    buf = buf + "    // member survives intact. Empty/missing fields use TAG_VOID.\n"
    buf = buf + "    HexaVal str_val;\n"
    buf = buf + "    HexaVal char_val;\n"
    buf = buf + "    HexaVal array_val;     // crucial for AST body propagation\n"
    buf = buf + "    HexaVal fn_name;\n"
    buf = buf + "    HexaVal fn_params;     // TAG_ARRAY (closure param list)\n"
    buf = buf + "    HexaVal fn_body;       // TAG_MAP / TAG_ARRAY (AST body)\n"
    buf = buf + "    HexaVal struct_name;\n"
    buf = buf + "    HexaVal struct_fields; // TAG_MAP (struct field map)\n"
    buf = buf + "} HexaValStruct;\n"
    buf = buf + "\n"
    buf = buf + "// ── C3 Closure helpers ───────────────────────────────────\n"
    buf = buf + "// Build a closure value. Captured values are provided as an already-built\n"
    buf = buf + "// TAG_ARRAY HexaVal; we heap-box it so the closure remains valid after copies.\n"
    buf = buf + "// NOTE: extern (not `static inline`) — the aprime_cc separate-compilation path\n"
    buf = buf + "// links test programs against a standalone runtime.o, and closure codegen\n"
    buf = buf + "// emits `bl _hexa_closure_new`; an internal-linkage definition is invisible\n"
    buf = buf + "// across that TU boundary. The runtime.h copy stays `static inline` for\n"
    buf = buf + "// header-only includers (no conflict — runtime.c does not include runtime.h).\n"
    buf = buf + "HexaVal hexa_closure_new(void* fn_ptr, int arity, HexaVal env_arr) {\n"
    buf = buf + "    HexaVal v = {.tag=TAG_CLOSURE};\n"
    buf = buf + "    HX_SET_CLO_PTR_D(v, (HexaClo*)calloc(1, sizeof(HexaClo)));\n"
    buf = buf + "    HX_SET_CLO_PTR(v, fn_ptr);\n"
    buf = buf + "    HX_SET_CLO_ARITY(v, arity);\n"
    buf = buf + "    HX_SET_CLO_ENV(v, (HexaVal*)malloc(sizeof(HexaVal)));\n"
    buf = buf + "    *HX_CLO_ENV(v) = env_arr;\n"
    buf = buf + "    // H03 B25: count closure descriptor allocs + LRU dup signal (pool-reuse\n"
    buf = buf + "    // opportunity — same fn_ptr seen recently → cache would have hit).\n"
    buf = buf + "    if (_hx_stats_on()) {\n"
    buf = buf + "        _hx_stats_closure_alloc++;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        if (_hx_stats_lru_check(_hx_stats_clo_lru, &_hx_stats_clo_lru_pos, fn_ptr)) {\n"
    buf = buf + "            _hx_stats_clo_alloc_dup++;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// S1-D2: NaN-boxing-safe constructor for TAG_FN values.\n"
    buf = buf + "// S1-D3a: allocates HexaFn heap descriptor (was inline .fn={...} struct literal).\n"
    buf = buf + "static inline HexaVal hexa_fn_new(void* fn_ptr, int arity) {\n"
    buf = buf + "    HexaVal v = {.tag=TAG_FN};\n"
    buf = buf + "    HX_SET_FN_PTR_D(v, (HexaFn*)calloc(1, sizeof(HexaFn)));\n"
    buf = buf + "    HX_FN_PTR(v) = fn_ptr;\n"
    buf = buf + "    HX_FN_ARITY(v) = arity;\n"
    buf = buf + "    // H03 B25: count fn descriptor allocs + LRU dup signal.\n"
    buf = buf + "    if (_hx_stats_on()) {\n"
    buf = buf + "        _hx_stats_fn_alloc++;\n"
    buf = buf + "        if (_hx_stats_lru_check(_hx_stats_fn_lru, &_hx_stats_fn_lru_pos, fn_ptr)) {\n"
    buf = buf + "            _hx_stats_fn_alloc_dup++;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline HexaVal hexa_closure_env(HexaVal c) {\n"
    buf = buf + "    if (!HX_IS_CLOSURE(c) || !HX_CLO_ENV(c)) return hexa_array_new();\n"
    buf = buf + "    return *HX_CLO_ENV(c);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// PROBE r12 #17: calling a non-fn / non-closure value used to silently\n"
    buf = buf + "// return void → hides type errors like `42()` or `let x = nil; x()`.\n"
    buf = buf + "// Throw with the actual tag so the user sees \"you called an int\" not\n"
    buf = buf + "// a mystery void result.  hexa_throw routes through try/catch.\n"
    buf = buf + "// PROBE r14-D unblock: forward-decl hexa_throw / hexa_str — both are\n"
    buf = buf + "// defined later in this TU (lines ~1374 / ~2003) and would otherwise hit\n"
    buf = buf + "// `-Werror=implicit-function-declaration` under modern clang.\n"
    buf = buf + "extern HexaVal hexa_str(const char* s);\n"
    buf = buf + "extern void hexa_throw(HexaVal err);\n"
    buf = buf + "static void __hexa_call_non_fn_throw(int tag, int arity) {\n"
    buf = buf + "    char _buf[128];\n"
    buf = buf + "    snprintf(_buf, sizeof(_buf), \"not callable: tag=%d (arity=%d)\", tag, arity);\n"
    buf = buf + "    hexa_throw(hexa_str(_buf));\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Dispatched call helpers — one per arity we support (0..4).\n"
    buf = buf + "static inline HexaVal hexa_call0(HexaVal f) {\n"
    buf = buf + "    if (HX_IS_CLOSURE(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal) = (HexaVal(*)(HexaVal))HX_CLO_PTR(f);\n"
    buf = buf + "        return fp(hexa_closure_env(f));\n"
    buf = buf + "    }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    if (HX_IS_FN(f)) {\n"
    buf = buf + "        HexaVal (*fp)(void) = (HexaVal(*)(void))HX_FN_PTR(f);\n"
    buf = buf + "        return fp();\n"
    buf = buf + "    }\n"
    buf = buf + "    __hexa_call_non_fn_throw((int)HX_TAG(f), 0);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "static inline HexaVal hexa_call1_hv(HexaVal f, HexaVal a1) {\n"
    buf = buf + "    if (HX_IS_CLOSURE(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal))HX_CLO_PTR(f);\n"
    buf = buf + "        return fp(hexa_closure_env(f), a1);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FN(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal) = (HexaVal(*)(HexaVal))HX_FN_PTR(f);\n"
    buf = buf + "        return fp(a1);\n"
    buf = buf + "    }\n"
    buf = buf + "    __hexa_call_non_fn_throw((int)HX_TAG(f), 1);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "// Raw C function-pointer overload (KI-4 fix 2026-05-01): codegen emits\n"
    buf = buf + "// `hexa_call1(exec_stream_async, cmd)` with raw symbol. _Generic dispatches\n"
    buf = buf + "// to the function-pointer path; HexaVal path keeps original lowering.\n"
    buf = buf + "static inline HexaVal __hexa_call1_fp1(HexaVal (*fp)(HexaVal), HexaVal a1) {\n"
    buf = buf + "    return fp(a1);\n"
    buf = buf + "}\n"
    buf = buf + "#define hexa_call1(f, a1) _Generic((f), \\\n"
    buf = buf + "    HexaVal: hexa_call1_hv, \\\n"
    buf = buf + "    HexaVal (*)(HexaVal): __hexa_call1_fp1, \\\n"
    buf = buf + "    default: hexa_call1_hv)((f), (a1))\n"
    buf = buf + "static inline HexaVal hexa_call2_hv(HexaVal f, HexaVal a1, HexaVal a2) {\n"
    buf = buf + "    if (HX_IS_CLOSURE(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal))HX_CLO_PTR(f);\n"
    buf = buf + "        return fp(hexa_closure_env(f), a1, a2);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FN(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal))HX_FN_PTR(f);\n"
    buf = buf + "        return fp(a1, a2);\n"
    buf = buf + "    }\n"
    buf = buf + "    __hexa_call_non_fn_throw((int)HX_TAG(f), 2);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "// Raw C function-pointer overload (FIX-2 unblock 2026-05-04): mirrors the\n"
    buf = buf + "// hexa_call1 _Generic pattern so codegen emitting `hexa_call2(bytes_to_f32_le,\n"
    buf = buf + "// arr, off)` from a precompiled hexat (which doesn't know the symbol is a\n"
    buf = buf + "// builtin) resolves to the direct C function call. Without this, the call\n"
    buf = buf + "// goes through hexa_call2_hv expecting a HexaVal first arg and fails to link.\n"
    buf = buf + "static inline HexaVal __hexa_call2_fp2(HexaVal (*fp)(HexaVal, HexaVal), HexaVal a1, HexaVal a2) {\n"
    buf = buf + "    return fp(a1, a2);\n"
    buf = buf + "}\n"
    buf = buf + "#define hexa_call2(f, a1, a2) _Generic((f), \\\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    HexaVal: hexa_call2_hv, \\\n"
    buf = buf + "    HexaVal (*)(HexaVal, HexaVal): __hexa_call2_fp2, \\\n"
    buf = buf + "    default: hexa_call2_hv)((f), (a1), (a2))\n"
    buf = buf + "static inline HexaVal hexa_call3(HexaVal f, HexaVal a1, HexaVal a2, HexaVal a3) {\n"
    buf = buf + "    if (HX_IS_CLOSURE(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal, HexaVal))HX_CLO_PTR(f);\n"
    buf = buf + "        return fp(hexa_closure_env(f), a1, a2, a3);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FN(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal))HX_FN_PTR(f);\n"
    buf = buf + "        return fp(a1, a2, a3);\n"
    buf = buf + "    }\n"
    buf = buf + "    __hexa_call_non_fn_throw((int)HX_TAG(f), 3);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "static inline HexaVal hexa_call4(HexaVal f, HexaVal a1, HexaVal a2, HexaVal a3, HexaVal a4) {\n"
    buf = buf + "    if (HX_IS_CLOSURE(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal, HexaVal, HexaVal))HX_CLO_PTR(f);\n"
    buf = buf + "        return fp(hexa_closure_env(f), a1, a2, a3, a4);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_FN(f)) {\n"
    buf = buf + "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal, HexaVal))HX_FN_PTR(f);\n"
    buf = buf + "        return fp(a1, a2, a3, a4);\n"
    buf = buf + "    }\n"
    buf = buf + "    __hexa_call_non_fn_throw((int)HX_TAG(f), 4);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Constructors ─────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// F3 ACTIVATION RUNBOOK · Path A — HexaVal struct-return ctor self-emit slots\n"
    buf = buf + "// (B9.6 class-D, the FIRST x0:x1 register-pair self-emit increment).\n"
    buf = buf + "//\n"
    buf = buf + "// Each of hexa_int / hexa_bool / hexa_void returns a 16-byte HexaVal BY VALUE;\n"
    buf = buf + "// on AAPCS arm64 that is the x0:x1 register PAIR (NRRP — no hidden x8 pointer).\n"
    buf = buf + "// x0 = the tag (low 8 B), x1 = the union value (high 8 B). Every prior\n"
    buf = buf + "// self-emit leaf returns a single x0 scalar — these are the first emitters\n"
    buf = buf + "// of the struct-return sequence, the infra that unblocks the ~350-450\n"
    buf = buf + "// HexaVal-producing class-D primitives.\n"
    buf = buf + "//\n"
    buf = buf + "// DEFAULT build (HEXA_RT_SELFEMIT undefined): the direct C aggregate-literal\n"
    buf = buf + "// bodies below are used — clang inlines them at internal call sites and the\n"
    buf = buf + "// driver/module_loader extern set is UNCHANGED (0-libc-extern invariant; these\n"
    buf = buf + "// were never libc symbols). This is the unchanged behavior.\n"
    buf = buf + "//\n"
    buf = buf + "// SELF-EMIT build (HEXA_RT_SELFEMIT defined): each becomes an `extern`\n"
    buf = buf + "// declaration (no body here); the strong external `_hexa_int` / `_hexa_bool`\n"
    buf = buf + "// / `_hexa_void` symbols are provided by the hexa-emitted Mach-O .o\n"
    buf = buf + "// (test/native_build/emit_hexa_val_ctors_o.hexa → rt_hexa_void/int/bool's\n"
    buf = buf + "// 12-byte x0:x1 sequences), ahead-linked. ld64 binds every callsite to the\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// self-emitted bytes — verified byte-identical to `as -arch arm64` AND\n"
    buf = buf + "// JIT-exec-correct (the returned {tag,value} reads back correct for all\n"
    buf = buf + "// inputs incl. INT64_MIN/MAX, bool 0/1; see the emit driver's §HONESTY).\n"
    buf = buf + "//\n"
    buf = buf + "// B9.6-D2 scale-out: hexa_float / hexa_enum_str / hexa_enum_str_v JOIN the\n"
    buf = buf + "// self-emit set (see runtime_arm64.hexa rt_hexa_float / rt_hexa_enum_str /\n"
    buf = buf + "// rt_hexa_enum_str_v + the extended emit_hexa_val_ctors_o.hexa bundle).\n"
    buf = buf + "//   hexa_float      : fmov x1,d0 / mov w0,#1  / ret  (FP-arg d0 -> x1 raw bits)\n"
    buf = buf + "//   hexa_enum_str   : mov x1,x0  / mov w0,#11 / ret  (ptr stored verbatim, no malloc)\n"
    buf = buf + "//   hexa_enum_str_v : mov x1,x0  / mov w0,#11 / ret  (byte-identical to enum_str)\n"
    buf = buf + "// Each is JIT-exec verified (returned {tag,value} correct for all inputs incl.\n"
    buf = buf + "// float NaN/Inf/±0/DBL_MAX/MIN + NULL/literal pointers) — the x0:x1 (and\n"
    buf = buf + "// fmov-bridged x1) struct-return ABI is correct at runtime, not just byte-equal.\n"
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_int(int64_t n);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_int(int64_t n) { return (HexaVal){.tag=TAG_INT, .i=n}; }\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_float(double f);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_float(double f) { return (HexaVal){.tag=TAG_FLOAT, .f=f}; }\n"
    buf = buf + "#endif\n"
    // f64<->bits reinterpret primitives (RFC 061 §4.1 HexaVal representation
    // bits). union-pun, tagged in/out. SSOT for hexa_float_to_bits /
    // hexa_bits_to_float + their bare-name aliases (the const-fold &fn-ptr
    // path in self/main.hexa emits the UNPREFIXED symbol). Without these the
    // float-pun codegen (anima quantization / AKIDA int4) link-fails on a
    // fresh clone (proto-only in runtime.h, body had no emitter — INBOX fix).
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_float_to_bits(HexaVal x);\n"
    buf = buf + "extern HexaVal hexa_bits_to_float(HexaVal x);\n"
    buf = buf + "extern HexaVal float_to_bits(HexaVal x);\n"
    buf = buf + "extern HexaVal bits_to_float(HexaVal x);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_float_to_bits(HexaVal x) { union { double d; int64_t i; } u; u.d = HX_FLOAT(x); return hexa_int(u.i); }\n"
    buf = buf + "HexaVal hexa_bits_to_float(HexaVal x) { union { int64_t i; double d; } u; u.i = HX_INT(x); return hexa_float(u.d); }\n"
    buf = buf + "HexaVal float_to_bits(HexaVal x) { return hexa_float_to_bits(x); }\n"
    buf = buf + "HexaVal bits_to_float(HexaVal x) { return hexa_bits_to_float(x); }\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_bool(int b);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_bool(int b) { return (HexaVal){.tag=TAG_BOOL, .b=b}; }\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_void(void);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_void() { return (HexaVal){.tag=TAG_VOID}; }\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// PR-2.1 (enum-to-string-codegen-emit RFC, stack PR-2/3, 2026-05-24): live\n"
    buf = buf + "// constructor for a single migrated unit-variant enum (Direction). `display`\n"
    buf = buf + "// is the codegen-emitted \"<Type>::<Variant>\" string literal (e.g.\n"
    buf = buf + "// \"Direction::Left\"); it is stored in the `.s` slot so `_hexa_to_string_rec`\n"
    buf = buf + "// renders it directly and `hexa_eq` compares it. Pointer is a read-only\n"
    buf = buf + "// static literal — never freed (matches the wider runtime no-free contract).\n"
    buf = buf + "// PR-2.2 will widen the codegen gate to all unit-variant enums; PR-3 will\n"
    buf = buf + "// switch the renderer to the `__enum_<Name>_names[]` table (#555) once the\n"
    buf = buf + "// per-variant (type_id, variant_idx) carrier lands.\n"
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_enum_str(const char* display);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_enum_str(const char* display) { return (HexaVal){.tag=TAG_ENUM, .s=(char*)display}; }\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): TAG_ENUM descriptor — codegen\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// emits one static const HexaEnumDesc per variant, and the `#define <Name>_<V>`\n"
    buf = buf + "// expands to `hexa_enum_str_v(&__enum_desc_<Name>_<V>)`. `.s` slot of the\n"
    buf = buf + "// returned HexaVal points at the descriptor; the renderer + eq paths route\n"
    buf = buf + "// through `_hexa_enum_display` / `_hexa_enum_idx` helpers which check the\n"
    buf = buf + "// magic sentinel to distinguish descriptor pointers from legacy bare-display\n"
    buf = buf + "// pointers (`hexa_enum_str(display)`) so both forms remain valid simultaneously.\n"
    buf = buf + "//\n"
    buf = buf + "// magic = 0x484E5544U (\"DUNH\" — Descriptor of Unit-variant eNum, Hexa) — chosen\n"
    buf = buf + "// because no ASCII printable string starts with these 4 bytes in\n"
    buf = buf + "// little-endian, so probing `*(uint32_t*)p == magic` reliably distinguishes\n"
    buf = buf + "// descriptor-from-bare. Layout: magic FIRST so the same probe works on any\n"
    buf = buf + "// future descriptor extension.\n"
    buf = buf + "#define HEXA_ENUM_DESC_MAGIC 0x484E5544U\n"
    buf = buf + "typedef struct HexaEnumDesc {\n"
    buf = buf + "    uint32_t    magic;       // = HEXA_ENUM_DESC_MAGIC, identifies descriptor\n"
    buf = buf + "    uint32_t    variant_idx; // 0-based declaration order\n"
    buf = buf + "    const char* display;     // \"<Type>::<Variant>\"\n"
    buf = buf + "    const char* type_name;   // \"<Type>\" (display prefix, no \"::\") — same-enum gate\n"
    buf = buf + "} HexaEnumDesc;\n"
    buf = buf + "\n"
    buf = buf + "#ifdef HEXA_RT_SELFEMIT\n"
    buf = buf + "extern HexaVal hexa_enum_str_v(const HexaEnumDesc* desc);\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_enum_str_v(const HexaEnumDesc* desc) {\n"
    buf = buf + "    return (HexaVal){.tag=TAG_ENUM, .s=(char*)desc};\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Internal helpers. Descriptor pointers begin with HEXA_ENUM_DESC_MAGIC (a\n"
    buf = buf + "// 4-byte sentinel). Legacy bare-string pointers begin with a printable ASCII\n"
    buf = buf + "// byte (e.g. \"Color::Red\" → 'C' = 0x43); the magic's low byte is 0x44 ('D'),\n"
    buf = buf + "// so we use the full 4-byte uint32 probe — guaranteed mismatch against any\n"
    buf = buf + "// real string literal that doesn't itself start with the exact sequence\n"
    buf = buf + "// \"DNHU\" (no such display literal because we emit \"<Type>::<Variant>\").\n"
    buf = buf + "static inline int _hexa_enum_is_desc(HexaVal v) {\n"
    buf = buf + "    const void* p = (const void*)HX_STR(v);\n"
    buf = buf + "    if (!p) return 0;\n"
    buf = buf + "    // Misaligned bare-string pointer would crash a 4-byte read on strict-\n"
    buf = buf + "    // alignment ISAs; descriptor pointers come from `static const HexaEnumDesc`\n"
    buf = buf + "    // which the C compiler 4B-aligns. Use memcpy for safety.\n"
    buf = buf + "    uint32_t first4 = 0;\n"
    buf = buf + "    hxlcl_memcpy(&first4, p, 4);\n"
    buf = buf + "    return first4 == HEXA_ENUM_DESC_MAGIC;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline const char* _hexa_enum_display(HexaVal v) {\n"
    buf = buf + "    if (!HX_STR(v)) return \"<enum>\";\n"
    buf = buf + "    if (_hexa_enum_is_desc(v)) return ((const HexaEnumDesc*)HX_STR(v))->display;\n"
    buf = buf + "    return HX_STR(v); // legacy bare display\n"
    buf = buf + "}\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "\n"
    buf = buf + "static inline int64_t _hexa_enum_idx(HexaVal v) {\n"
    buf = buf + "    if (!HX_STR(v) || !_hexa_enum_is_desc(v)) return -1;\n"
    buf = buf + "    return (int64_t)((const HexaEnumDesc*)HX_STR(v))->variant_idx;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline const char* _hexa_enum_type_name(HexaVal v) {\n"
    buf = buf + "    if (!HX_STR(v) || !_hexa_enum_is_desc(v)) return NULL;\n"
    buf = buf + "    return ((const HexaEnumDesc*)HX_STR(v))->type_name;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// T32: unwrap a HexaVal (possibly VALSTRUCT-wrapped by the interpreter) into\n"
    buf = buf + "// a raw C double. The prior inline `v.tag==TAG_FLOAT?v.f:(double)v.i` read\n"
    buf = buf + "// only the outer tag, so interpreter values (which carry TAG_VALSTRUCT with\n"
    buf = buf + "// the real tag in vs->tag_i) fell through and cast the vs pointer bits to\n"
    buf = buf + "// double — producing garbage. Centralising here lets to_float / exp / sin /\n"
    buf = buf + "// cos / log / log10 / round share one correct unwrap.\n"
    buf = buf + "/* PHASE 1.2.B (2026-05-15): de-staticized. Was `static inline`; runtime.h-built\n"
    buf = buf + " * user.c needs cross-TU access for hexa_add_slow + float arithmetic. Loses\n"
    buf = buf + " * inlining for cross-TU callers — acceptable (cold-ish path). */\n"
    buf = buf + "double __hx_to_double(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_FLOAT(v)) return HX_FLOAT(v);\n"
    buf = buf + "    if (HX_IS_INT(v))   return (double)HX_INT(v);\n"
    buf = buf + "    // Bool → numeric coercion (Python canonical: True=1, False=0).  Without\n"
    buf = buf + "    // this, `true * 5` fell through to `return 0.0` → silently `0`.  The\n"
    buf = buf + "    // sibling static `_hexa_f` (runtime.c:4474) already had this branch for\n"
    buf = buf + "    // the math family; aligning the slow path here.  Round-7 probe finding.\n"
    buf = buf + "    if (HX_IS_BOOL(v))  return HX_BOOL(v) ? 1.0 : 0.0;\n"
    buf = buf + "    // ComptimeConst eval: to_float(\"3.14\") at compile time needs string parsing.\n"
    buf = buf + "    // Without this branch, returned 0.0, silently producing wrong constants.\n"
    buf = buf + "    // atof handles both ints and floats correctly (\"3\" → 3.0, \"3.14\" → 3.14).\n"
    buf = buf + "    if (HX_IS_STR(v) && HX_STR(v))   return hxlcl_atof(HX_STR(v));\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_FLOAT) return HX_VSF(v, float_val);\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_INT)   return (double)HX_VSF(v, int_val);\n"
    buf = buf + "    }\n"
    buf = buf + "    return 0.0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// RT-P3-1 wrapper shims. Non-owning returns; cstring/str_as_ptr use static\n"
    buf = buf + "// thread-unsafe buffers for scalar formatting — callers that persist the\n"
    buf = buf + "// pointer beyond the next scalar-path call MUST copy.\n"
    buf = buf + "int64_t hexa_as_num(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_INT(v))   return HX_INT(v);\n"
    buf = buf + "    if (HX_IS_FLOAT(v)) return (int64_t)HX_FLOAT(v);\n"
    buf = buf + "    if (HX_IS_BOOL(v))  return (int64_t)HX_BOOL(v);\n"
    buf = buf + "    // P39 fix: auto-detect 0x/0X prefix in string coercion\n"
    buf = buf + "    if (HX_IS_STR(v) && HX_STR(v)) {\n"
    buf = buf + "        const char* cs = HX_STR(v); const char* p = cs;\n"
    buf = buf + "        if (*p == '+' || *p == '-') p++;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        int base = (p[0] == '0' && (p[1] == 'x' || p[1] == 'X')) ? 16 : 10;\n"
    buf = buf + "        return hxlcl_strtoll(cs, NULL, base);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_INT)   return HX_VSF(v, int_val);\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_FLOAT) return (int64_t)HX_VSF(v, float_val);\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_BOOL)  return (int64_t)HX_VSF(v, bool_val);\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_STR && HX_STR(HX_VSF(v, str_val))) {\n"
    buf = buf + "            const char* cs = HX_STR(HX_VSF(v, str_val)); const char* p = cs;\n"
    buf = buf + "            if (*p == '+' || *p == '-') p++;\n"
    buf = buf + "            int base = (p[0] == '0' && (p[1] == 'x' || p[1] == 'X')) ? 16 : 10;\n"
    buf = buf + "            return hxlcl_strtoll(cs, NULL, base);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "const char* hexa_to_cstring(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_STR(v) && HX_STR(v)) return HX_STR(v);\n"
    buf = buf + "    if (HX_IS_VOID(v)) return \"void\";\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_STR && HX_STR(HX_VSF(v, str_val))) return HX_STR(HX_VSF(v, str_val));\n"
    buf = buf + "        static char vbuf[64];\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_INT)   { snprintf(vbuf, 64, \"%lld\", (long long)HX_VSF(v, int_val)); return vbuf; }\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_FLOAT) {\n"
    buf = buf + "            // trk.27 fix 2026-05-06: preserve `.0` for whole-valued floats (Val struct fast path).\n"
    buf = buf + "            double f = HX_VSF(v, float_val);\n"
    buf = buf + "            if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n"
    buf = buf + "                snprintf(vbuf, 64, \"%.1f\", f);\n"
    buf = buf + "            } else {\n"
    buf = buf + "                snprintf(vbuf, 64, \"%g\", f);\n"
    buf = buf + "            }\n"
    buf = buf + "            return vbuf;\n"
    buf = buf + "        }\n"
    buf = buf + "        if (HX_VSF(v, tag_i) == TAG_BOOL)  return HX_VSF(v, bool_val) ? \"true\" : \"false\";\n"
    buf = buf + "    }\n"
    buf = buf + "    static char buf[64];\n"
    buf = buf + "    if (HX_IS_INT(v))   { snprintf(buf, 64, \"%lld\", (long long)HX_INT(v)); return buf; }\n"
    buf = buf + "    if (HX_IS_FLOAT(v)) {\n"
    buf = buf + "        // trk.27 fix 2026-05-06: preserve `.0` for whole-valued floats (HexaVal fast path).\n"
    buf = buf + "        double f = HX_FLOAT(v);\n"
    buf = buf + "        if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n"
    buf = buf + "            snprintf(buf, 64, \"%.1f\", f);\n"
    buf = buf + "        } else {\n"
    buf = buf + "            snprintf(buf, 64, \"%g\", f);\n"
    buf = buf + "        }\n"
    buf = buf + "        return buf;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_BOOL(v))  return HX_BOOL(v) ? \"true\" : \"false\";\n"
    buf = buf + "    // 2026-04-20 silent-fallback audit: prior code returned the literal\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    // \"<value>\" for TAG_ARRAY / TAG_MAP / TAG_FN / TAG_CHAR / TAG_CLOSURE.\n"
    buf = buf + "    // Callers include codegen-emitted `map.has/get/set(k)` paths and FFI\n"
    buf = buf + "    // entry points (net.c) — a literal \"<value>\" string silently collides\n"
    buf = buf + "    // across every bad callsite (all array/map/fn keys hash to the same\n"
    buf = buf + "    // bucket). Delegate to hexa_to_string for a structural repr that at\n"
    buf = buf + "    // least preserves distinctness (\"[1, 2]\" != \"[3, 4]\") and surface the\n"
    buf = buf + "    // root cause in logs rather than corrupting the map. The returned\n"
    buf = buf + "    // pointer points into the intern table (hexa_to_string → hexa_str),\n"
    buf = buf + "    // so lifetime matches the legacy static-buf contract for callers that\n"
    buf = buf + "    // treat the result as short-lived.\n"
    buf = buf + "    HexaVal s = hexa_to_string(v);\n"
    buf = buf + "    if (HX_IS_STR(s) && HX_STR(s)) return HX_STR(s);\n"
    buf = buf + "    return \"<value>\";\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "const char* hexa_str_as_ptr(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_STR(v) && HX_STR(v)) return HX_STR(v);\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v) && HX_VSF(v, tag_i) == TAG_STR && HX_STR(HX_VSF(v, str_val)))\n"
    buf = buf + "        return HX_STR(HX_VSF(v, str_val));\n"
    buf = buf + "    return NULL;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Null coalescing: a ?? b — if a is void or empty string, return b\n"
    buf = buf + "HexaVal hexa_null_coal(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (HX_IS_VOID(a)) return b;\n"
    buf = buf + "    if (HX_IS_STR(a) && (HX_STR(a) == NULL || HX_STR(a)[0] == '\\0')) return b;\n"
    buf = buf + "    return a;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_str(const char* s) {\n"
    buf = buf + "    HexaVal v = {.tag=TAG_STR};\n"
    buf = buf + "    // Optimization #11: intern short strings for pointer-equality comparison\n"
    buf = buf + "    const char* interned = hexa_intern(s);\n"
    buf = buf + "    if (interned) {\n"
    buf = buf + "        HX_SET_STR(v, (char*)interned);  // owned by intern table, not caller\n"
    buf = buf + "    } else {\n"
    buf = buf + "        // Long/unique strings: header-allocate so HX_STRLEN is O(1) instead of strlen.\n"
    buf = buf + "        size_t slen = hxlcl_strlen(s);\n"
    buf = buf + "        HX_SET_STR(v, hexa_strbuf_dup_n(s, slen));\n"
    buf = buf + "    }\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Take ownership of a malloc'd-or-arena'd C string. Backward-compat shim\n"
    buf = buf + "// that transparently rewraps `s` into a header-allocated buffer so\n"
    buf = buf + "// HX_STRLEN is O(1) on the resulting value. The input `s` is intentionally\n"
    buf = buf + "// NOT freed — callers (notably hexa_concat under arena_on) may pass arena-\n"
    buf = buf + "// allocated buffers where free() would be UB, and the wider runtime leaks\n"
    buf = buf + "// strings by design (zero free(HX_STR(...)) call sites repo-wide). Hot\n"
    buf = buf + "// allocators that know `len` upfront should call hexa_str_own_with_len()\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// to skip the input strlen.\n"
    buf = buf + "HexaVal hexa_str_own(char* s) {\n"
    buf = buf + "    if (!s) return (HexaVal){.tag=TAG_STR, .s=NULL};\n"
    buf = buf + "    size_t len = hxlcl_strlen(s);\n"
    buf = buf + "    char* buf = hexa_strbuf_dup_n(s, len);\n"
    buf = buf + "    return (HexaVal){.tag=TAG_STR, .s=buf};\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Length-known fast path. Same leak semantics as hexa_str_own.\n"
    buf = buf + "HexaVal hexa_str_own_with_len(char* s, size_t len) {\n"
    buf = buf + "    if (!s) return (HexaVal){.tag=TAG_STR, .s=NULL};\n"
    buf = buf + "    char* buf = hexa_strbuf_dup_n(s, len);\n"
    buf = buf + "    return (HexaVal){.tag=TAG_STR, .s=buf};\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Even faster path: skip the input copy entirely. Caller writes directly\n"
    buf = buf + "// into the returned data buffer (size `len`), then wraps via hexa_str_own_buf.\n"
    buf = buf + "// `data` MUST be a pointer returned by hexa_strbuf_alloc(len).\n"
    buf = buf + "static inline HexaVal hexa_str_own_buf(char* data) {\n"
    buf = buf + "    return (HexaVal){.tag=TAG_STR, .s=data};\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  ROI-33: Pre-interned string cache\n"
    buf = buf + "//  \"true\",\"false\",\"void\" (+ type_of strings) are used on every\n"
    buf = buf + "//  hexa_to_string / hexa_type_of call.  Cache them as static\n"
    buf = buf + "//  HexaVal so we skip strlen+hash+probe entirely.\n"
    buf = buf + "//  Lazy-init on first access (no constructor needed).\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "static HexaVal _cached_str_true;\n"
    buf = buf + "static HexaVal _cached_str_false;\n"
    buf = buf + "static HexaVal _cached_str_void;\n"
    buf = buf + "static HexaVal _cached_str_int;\n"
    buf = buf + "static HexaVal _cached_str_float;\n"
    buf = buf + "static HexaVal _cached_str_bool;\n"
    buf = buf + "static HexaVal _cached_str_string;\n"
    buf = buf + "static HexaVal _cached_str_array;\n"
    buf = buf + "static HexaVal _cached_str_map;\n"
    buf = buf + "static HexaVal _cached_str_struct;\n"
    buf = buf + "static HexaVal _cached_str_fn;\n"
    buf = buf + "static HexaVal _cached_str_char;\n"
    buf = buf + "static HexaVal _cached_str_closure;\n"
    buf = buf + "static HexaVal _cached_str_unknown;\n"
    buf = buf + "static HexaVal _cached_str_value;  // \"<value>\" fallback\n"
    buf = buf + "// PR-2.0 (enum-to-string-codegen-emit RFC, 2026-05-24): cached \"enum\" tag\n"
    buf = buf + "// label for `type_of()` on a TAG_ENUM value. PR-2.1 will produce TAG_ENUM\n"
    buf = buf + "// HexaVals; until then this is dead under the unreachable TAG_ENUM branch\n"
    buf = buf + "// of hexa_type_of, but mirrors the cache-init contract followed by every\n"
    buf = buf + "// other tag (initialized in _hexa_init_cached_strs, used via switch case).\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "static HexaVal _cached_str_enum;\n"
    buf = buf + "static int     _cached_strs_ready = 0;\n"
    buf = buf + "// S1-D2 Blocker C: forward decl — defined after bt73 wrappers near EOF.\n"
    buf = buf + "static void _hexa_init_fn_shims(void);\n"
    buf = buf + "\n"
    buf = buf + "static void _hexa_init_cached_strs(void) {\n"
    buf = buf + "    if (_cached_strs_ready) return;\n"
    buf = buf + "    _cached_str_true    = hexa_str(\"true\");\n"
    buf = buf + "    _cached_str_false   = hexa_str(\"false\");\n"
    buf = buf + "    _cached_str_void    = hexa_str(\"void\");\n"
    buf = buf + "    _cached_str_int     = hexa_str(\"int\");\n"
    buf = buf + "    _cached_str_float   = hexa_str(\"float\");\n"
    buf = buf + "    _cached_str_bool    = hexa_str(\"bool\");\n"
    buf = buf + "    _cached_str_string  = hexa_str(\"string\");\n"
    buf = buf + "    _cached_str_array   = hexa_str(\"array\");\n"
    buf = buf + "    _cached_str_map     = hexa_str(\"map\");\n"
    buf = buf + "    _cached_str_struct  = hexa_str(\"struct\");\n"
    buf = buf + "    _cached_str_fn      = hexa_str(\"fn\");\n"
    buf = buf + "    _cached_str_char    = hexa_str(\"char\");\n"
    buf = buf + "    _cached_str_closure = hexa_str(\"closure\");\n"
    buf = buf + "    _cached_str_unknown = hexa_str(\"unknown\");\n"
    buf = buf + "    _cached_str_value   = hexa_str(\"<value>\");\n"
    buf = buf + "    _cached_str_enum    = hexa_str(\"enum\");\n"
    buf = buf + "    _cached_strs_ready  = 1;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Small-int to_string cache: [-1, 0..255] covers >90% of int-to-string\n"
    buf = buf + "#define SMALL_INT_CACHE_MIN  (-1)\n"
    buf = buf + "#define SMALL_INT_CACHE_MAX  255\n"
    buf = buf + "#define SMALL_INT_CACHE_SIZE (SMALL_INT_CACHE_MAX - SMALL_INT_CACHE_MIN + 1)\n"
    buf = buf + "static HexaVal _cached_small_ints[SMALL_INT_CACHE_SIZE];\n"
    buf = buf + "static int     _cached_small_ints_ready = 0;\n"
    buf = buf + "\n"
    buf = buf + "static void _hexa_init_small_int_cache(void) {\n"
    buf = buf + "    if (_cached_small_ints_ready) return;\n"
    buf = buf + "    char buf[16];\n"
    buf = buf + "    for (int i = 0; i < SMALL_INT_CACHE_SIZE; i++) {\n"
    buf = buf + "        int64_t n = (int64_t)(i + SMALL_INT_CACHE_MIN);\n"
    buf = buf + "        snprintf(buf, 16, \"%lld\", (long long)n);\n"
    buf = buf + "        _cached_small_ints[i] = hexa_str(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    _cached_small_ints_ready = 1;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Array operations ─────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// rt 32: alloc/COW stats (HEXA_ALLOC_STATS=1 env enables atexit dump).\n"
    buf = buf + "// Counts hot-path C runtime allocations so we can diagnose where 10GB\n"
    buf = buf + "// RSS ML microbench pressure originates without sample/leaks tooling.\n"
    buf = buf + "static int64_t _hx_stats_array_new      = 0;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "static int64_t _hx_stats_array_push     = 0;\n"
    buf = buf + "static int64_t _hx_stats_array_grow     = 0;   // realloc that actually grows cap\n"
    buf = buf + "static int64_t _hx_stats_str_concat     = 0;\n"
    buf = buf + "static int64_t _hx_stats_array_reserve  = 0;\n"
    buf = buf + "static int64_t _hx_stats_map_new        = 0;\n"
    buf = buf + "static int64_t _hx_stats_map_set        = 0;\n"
    buf = buf + "// STRUCTURAL-7 Phase A: codegen emits __hexa_fn_arena_enter/return for\n"
    buf = buf + "// per-function arena scoping. Forward declarations here; real implementations\n"
    buf = buf + "// below after all arena dependencies (hexa_val_arena_on, hexa_val_heapify,\n"
    buf = buf + "// hexa_val_arena_scope_push/pop) are defined.\n"
    buf = buf + "void __hexa_fn_arena_enter(void);\n"
    buf = buf + "HexaVal __hexa_fn_arena_return(HexaVal v);\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-D: arena allocator stats (str_concat hot-path)\n"
    buf = buf + "static int64_t _hx_stats_arena_alloc    = 0;   // total arena bump allocations\n"
    buf = buf + "static int64_t _hx_stats_arena_blocks   = 0;   // blocks created\n"
    buf = buf + "static int64_t _hx_stats_arena_bytes    = 0;   // bytes currently reserved in blocks\n"
    buf = buf + "static int64_t _hx_stats_str_concat_arena = 0; // str_concat calls that hit arena\n"
    buf = buf + "// rt 32-M: array arena counters\n"
    buf = buf + "static int64_t _hx_stats_array_arena_alloc   = 0; // push that went arena (initial slot buf)\n"
    buf = buf + "static int64_t _hx_stats_array_arena_promote = 0; // arena→heap promotions on grow\n"
    buf = buf + "static int64_t _hx_stats_array_arena_heapify = 0; // heapify copies of arena item buffers\n"
    buf = buf + "// M4: string arena heapify stats\n"
    buf = buf + "static int64_t _hx_stats_str_arena_heapify   = 0; // arena→heap string promotions\n"
    buf = buf + "// M4-edge: RSS peak sampler — opt-in via HEXA_ALLOC_STATS. Sampled only on\n"
    buf = buf + "// arena new-block (rare: every 4MB+), so getrusage overhead is negligible.\n"
    buf = buf + "static int64_t _hx_stats_rss_peak_bytes      = 0;\n"
    buf = buf + "// H03 (2026-05-06): extended observability counters — log2 size histogram,\n"
    buf = buf + "// arena block churn (max chain depth), string intern hit/miss, closure/fn\n"
    buf = buf + "// descriptor pool reuse signals. All updates are inside _hx_stats_on()\n"
    buf = buf + "// guards so the unset-env hot path remains a single predicted branch + RET.\n"
    buf = buf + "//\n"
    buf = buf + "// Histogram buckets (10 slots, log2-style edges in bytes):\n"
    buf = buf + "//   [0]<16  [1]<64  [2]<256  [3]<1K  [4]<4K  [5]<16K  [6]<64K  [7]<256K\n"
    buf = buf + "//   [8]<1M  [9]>=1M\n"
    buf = buf + "// Each slot accumulates the count of arena-bump allocations in that range\n"
    buf = buf + "// (covers the dominant runtime allocator — slab/size decisions for B17).\n"
    buf = buf + "#define HX_HIST_BUCKETS 10\n"
    buf = buf + "static int64_t _hx_stats_size_hist[HX_HIST_BUCKETS] = {0};\n"
    buf = buf + "// Arena block-chain churn. _arena_block_max_chain tracks longest observed\n"
    buf = buf + "// linked-list length. _arena_block_reuse counts how many times the alloc\n"
    buf = buf + "// path satisfied a request by walking forward into a previously rewound\n"
    buf = buf + "// (used=0) tail block instead of malloc'ing a new one.\n"
    buf = buf + "static int64_t _hx_stats_arena_block_max_chain = 0;\n"
    buf = buf + "static int64_t _hx_stats_arena_block_reuse     = 0;\n"
    buf = buf + "// String intern Q9 (hit/miss/skip/grow) and closure/fn pool counters (B25)\n"
    buf = buf + "// are forward-declared at top of file (above hexa_intern) — tentative defs\n"
    buf = buf + "// per C99 §6.9.2 implicitly zero-initialize; no separate defining decl needed.\n"
    buf = buf + "//\n"
    buf = buf + "// Closure / fn pool counters — storage matches the forward decls at top of\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// file (above hexa_intern). Tentative-definition rule: top-of-file decls\n"
    buf = buf + "// have no initializer; these defining declarations carry the `= 0` zero-init.\n"
    buf = buf + "// Note: HX_POOL_LRU and the ring buffers are also forward-declared above —\n"
    buf = buf + "// the declarations there are tentative (no init), so these defining declarations\n"
    buf = buf + "// (with explicit `= {0}` / `= 0`) coexist legally per C99 §6.9.2.\n"
    buf = buf + "// (HX_POOL_LRU macro is also defined at the top, do not redefine here.)\n"
    buf = buf + "// We do NOT redeclare _hx_stats_lru_check here — it's defined in the forward\n"
    buf = buf + "// block (static inline) and used by hexa_closure_new / hexa_fn_new.\n"
    buf = buf + "static int _hx_stats_enabled = -1;             // lazy probe of env\n"
    buf = buf + "\n"
    buf = buf + "// H03: log2 bucket index for n bytes — branch-free-ish; called only inside\n"
    buf = buf + "// _hx_stats_on() so cost is irrelevant when env unset.\n"
    buf = buf + "static inline int _hx_stats_size_bucket(size_t n) {\n"
    buf = buf + "    if (n < 16)            return 0;\n"
    buf = buf + "    if (n < 64)            return 1;\n"
    buf = buf + "    if (n < 256)           return 2;\n"
    buf = buf + "    if (n < 1024)          return 3;\n"
    buf = buf + "    if (n < 4096)          return 4;\n"
    buf = buf + "    if (n < 16384)         return 5;\n"
    buf = buf + "    if (n < 65536)         return 6;\n"
    buf = buf + "    if (n < 262144)        return 7;\n"
    buf = buf + "    if (n < 1048576)       return 8;\n"
    buf = buf + "    return 9;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static void _hx_stats_sample_rss(void) {\n"
    buf = buf + "    struct rusage ru;\n"
    buf = buf + "    if (hxlcl_getrusage(RUSAGE_SELF, &ru) != 0) return;\n"
    buf = buf + "#if defined(__APPLE__)\n"
    buf = buf + "    int64_t rss_bytes = (int64_t)ru.ru_maxrss;        // macOS: bytes\n"
    buf = buf + "#else\n"
    buf = buf + "    int64_t rss_bytes = (int64_t)ru.ru_maxrss * 1024; // Linux: kilobytes\n"
    buf = buf + "#endif\n"
    buf = buf + "    if (rss_bytes > _hx_stats_rss_peak_bytes) _hx_stats_rss_peak_bytes = rss_bytes;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static void _hx_stats_dump(void) {\n"
    buf = buf + "    _hx_stats_sample_rss();\n"
    buf = buf + "    fprintf(stderr, \"[HEXA_ALLOC_STATS] array_new=%lld push=%lld grow=%lld reserve=%lld str_concat=%lld map_new=%lld map_set=%lld arena_alloc=%lld arena_blocks=%lld arena_bytes=%lld str_concat_arena=%lld arr_arena_alloc=%lld arr_arena_promote=%lld arr_arena_heapify=%lld str_arena_heapify=%lld rss_peak_mb=%lld\\n\",\n"
    buf = buf + "        (long long)_hx_stats_array_new,\n"
    buf = buf + "        (long long)_hx_stats_array_push,\n"
    buf = buf + "        (long long)_hx_stats_array_grow,\n"
    buf = buf + "        (long long)_hx_stats_array_reserve,\n"
    buf = buf + "        (long long)_hx_stats_str_concat,\n"
    buf = buf + "        (long long)_hx_stats_map_new,\n"
    buf = buf + "        (long long)_hx_stats_map_set,\n"
    buf = buf + "        (long long)_hx_stats_arena_alloc,\n"
    buf = buf + "        (long long)_hx_stats_arena_blocks,\n"
    buf = buf + "        (long long)_hx_stats_arena_bytes,\n"
    buf = buf + "        (long long)_hx_stats_str_concat_arena,\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        (long long)_hx_stats_array_arena_alloc,\n"
    buf = buf + "        (long long)_hx_stats_array_arena_promote,\n"
    buf = buf + "        (long long)_hx_stats_array_arena_heapify,\n"
    buf = buf + "        (long long)_hx_stats_str_arena_heapify,\n"
    buf = buf + "        (long long)(_hx_stats_rss_peak_bytes / (1024 * 1024)));\n"
    buf = buf + "\n"
    buf = buf + "    // H03: appended sections (append-only — does not break existing fields).\n"
    buf = buf + "    // Section S1: arena-allocation size histogram (B17 slab-decision input).\n"
    buf = buf + "    fprintf(stderr,\n"
    buf = buf + "        \"[HEXA_ALLOC_STATS_HIST] <16=%lld <64=%lld <256=%lld <1K=%lld <4K=%lld <16K=%lld <64K=%lld <256K=%lld <1M=%lld >=1M=%lld\\n\",\n"
    buf = buf + "        (long long)_hx_stats_size_hist[0],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[1],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[2],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[3],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[4],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[5],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[6],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[7],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[8],\n"
    buf = buf + "        (long long)_hx_stats_size_hist[9]);\n"
    buf = buf + "\n"
    buf = buf + "    // Section S2: arena block churn — max chain depth, reuse rate.\n"
    buf = buf + "    fprintf(stderr,\n"
    buf = buf + "        \"[HEXA_ALLOC_STATS_ARENA] block_max_chain=%lld block_reuse=%lld block_alloc=%lld\\n\",\n"
    buf = buf + "        (long long)_hx_stats_arena_block_max_chain,\n"
    buf = buf + "        (long long)_hx_stats_arena_block_reuse,\n"
    buf = buf + "        (long long)_hx_stats_arena_blocks);\n"
    buf = buf + "\n"
    buf = buf + "    // Section S3: string intern hit/miss/skip (Q9 — INTERN_INIT_CAP sizing).\n"
    buf = buf + "    int64_t intern_total = _hx_stats_intern_hit + _hx_stats_intern_miss;\n"
    buf = buf + "    long ratio_x100 = intern_total > 0\n"
    buf = buf + "        ? (long)((_hx_stats_intern_hit * 100) / intern_total)\n"
    buf = buf + "        : 0L;\n"
    buf = buf + "    fprintf(stderr,\n"
    buf = buf + "        \"[HEXA_ALLOC_STATS_INTERN] hit=%lld miss=%lld skip=%lld grow=%lld hit_ratio_pct=%ld\\n\",\n"
    buf = buf + "        (long long)_hx_stats_intern_hit,\n"
    buf = buf + "        (long long)_hx_stats_intern_miss,\n"
    buf = buf + "        (long long)_hx_stats_intern_skip,\n"
    buf = buf + "        (long long)_hx_stats_intern_grow,\n"
    buf = buf + "        ratio_x100);\n"
    buf = buf + "\n"
    buf = buf + "    // Section S4: closure / fn descriptor pool reuse opportunity (B25).\n"
    buf = buf + "    long fn_dup_pct  = _hx_stats_fn_alloc > 0\n"
    buf = buf + "        ? (long)((_hx_stats_fn_alloc_dup * 100) / _hx_stats_fn_alloc) : 0L;\n"
    buf = buf + "    long clo_dup_pct = _hx_stats_closure_alloc > 0\n"
    buf = buf + "        ? (long)((_hx_stats_clo_alloc_dup * 100) / _hx_stats_closure_alloc) : 0L;\n"
    buf = buf + "    fprintf(stderr,\n"
    buf = buf + "        \"[HEXA_ALLOC_STATS_POOL] fn_alloc=%lld fn_alloc_dup=%lld fn_dup_pct=%ld clo_alloc=%lld clo_alloc_dup=%lld clo_dup_pct=%ld\\n\",\n"
    buf = buf + "        (long long)_hx_stats_fn_alloc,\n"
    buf = buf + "        (long long)_hx_stats_fn_alloc_dup,\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        fn_dup_pct,\n"
    buf = buf + "        (long long)_hx_stats_closure_alloc,\n"
    buf = buf + "        (long long)_hx_stats_clo_alloc_dup,\n"
    buf = buf + "        clo_dup_pct);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static int _hx_stats_on(void) {\n"
    buf = buf + "    if (_hx_stats_enabled < 0) {\n"
    buf = buf + "        const char* e = hxlcl_getenv(\"HEXA_ALLOC_STATS\");\n"
    buf = buf + "        _hx_stats_enabled = (e && e[0] && e[0] != '0') ? 1 : 0;\n"
    buf = buf + "        if (_hx_stats_enabled) {\n"
    buf = buf + "            hxlcl_atexit(_hx_stats_dump);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return _hx_stats_enabled;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── rt 32-M: Array arena allocator ──────────────────────\n"
    buf = buf + "// Bump-allocate the array slot buffer (HexaVal*) from the shared bump arena\n"
    buf = buf + "// during an active fn-call mark (__hexa_val_mark_top > 0). On grow beyond the\n"
    buf = buf + "// initial slot capacity, promote the buffer to malloc (can't realloc an arena\n"
    buf = buf + "// region). On heapify, deep-copy the item buffer to malloc before the arena\n"
    buf = buf + "// rewind point.\n"
    buf = buf + "//\n"
    buf = buf + "// Encoding: negative cap = from_arena (arr.items points into arena). This\n"
    buf = buf + "// preserves HexaVal width/ABI — no new field in the .arr struct. Consumers\n"
    buf = buf + "// that read .cap positively must treat (cap < 0) as |cap|.\n"
    buf = buf + "//\n"
    buf = buf + "// Gate: HEXA_ARRAY_ARENA env var. Default ON. Set =0 to fall back to pure\n"
    buf = buf + "// malloc/realloc path bit-for-bit.\n"
    buf = buf + "//\n"
    buf = buf + "// Rationale: fib(20)×30 shows array_new=4.6M, push=28.9M, grow=4.6M — the\n"
    buf = buf + "// dominant RSS driver. rt 32-L heapified HexaValStruct but left the array\n"
    buf = buf + "// .items buffer on the malloc heap (rt 32-L comment explicitly calls this\n"
    buf = buf + "// out: \"Array .items lives on heap — hexa_array_push uses realloc\"). This\n"
    buf = buf + "// change addresses that gap.\n"
    buf = buf + "extern int __hexa_val_mark_top;  // shared with rt 32-L Val arena\n"
    buf = buf + "extern int __hexa_val_force_heap; // T33-fix-2: force heap in valstruct_new_v\n"
    buf = buf + "static int hexa_val_arena_on(void);\n"
    buf = buf + "static void* hexa_val_arena_calloc(size_t n);\n"
    buf = buf + "void* hexa_arena_alloc(size_t n);  // rt 32-D bump allocator (shared block chain)\n"
    buf = buf + "\n"
    buf = buf + "static int __hexa_array_arena_enabled = -1;\n"
    buf = buf + "static int hexa_array_arena_on(void) {\n"
    buf = buf + "    if (__hexa_array_arena_enabled < 0) {\n"
    buf = buf + "        const char* e = hxlcl_getenv(\"HEXA_ARRAY_ARENA\");\n"
    buf = buf + "        // Default ON. Export HEXA_ARRAY_ARENA=0 to disable.\n"
    buf = buf + "        if (!e || !e[0]) __hexa_array_arena_enabled = 1;\n"
    buf = buf + "        else             __hexa_array_arena_enabled = (e[0] != '0') ? 1 : 0;\n"
    buf = buf + "    }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    return __hexa_array_arena_enabled;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Arena-alloc a HexaVal slot buffer. Caller sets cap to -n so the \"from_arena\"\n"
    buf = buf + "// sentinel survives the return. Returns NULL if arena is off / not in scope.\n"
    buf = buf + "// Does NOT zero the buffer — caller memcpy's over it (slice_fast) or writes\n"
    buf = buf + "// len items before reading. Skipping the memset is a measurable win on hot\n"
    buf = buf + "// paths (the Val arena's calloc variant memset'd a 4MB block front-to-back\n"
    buf = buf + "// every few thousand calls, costing ~8% wall on fib K=30).\n"
    buf = buf + "static HexaVal* hexa_array_arena_alloc_items(int n) {\n"
    buf = buf + "    if (!hexa_array_arena_on()) return NULL;\n"
    buf = buf + "    // Must be inside a live scope mark — otherwise there's no rewind point to\n"
    buf = buf + "    // catch the allocation (module-init arrays stay on heap).\n"
    buf = buf + "    if (__hexa_val_mark_top <= 0) return NULL;\n"
    buf = buf + "    // Reuse the shared bump allocator (same block chain as rt 32-L). The\n"
    buf = buf + "    // existing rt 32-L scope-push/pop discipline automatically reclaims the\n"
    buf = buf + "    // array buffers too — no parallel mark stack needed.\n"
    buf = buf + "    HexaVal* p = (HexaVal*)hexa_arena_alloc((size_t)n * sizeof(HexaVal));\n"
    buf = buf + "    return p;  // NULL if arena OOM — caller falls back to malloc\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Promote an arena-backed slot buffer to malloc. len = current live slot count\n"
    buf = buf + "// to copy; new_cap = target capacity. Used by grow (new_cap > |old_cap|) and\n"
    buf = buf + "// heapify (new_cap == |old_cap|). Returns NULL on OOM (caller handles).\n"
    buf = buf + "static HexaVal* hexa_array_promote_to_heap(HexaVal* arena_items, int len, int new_cap) {\n"
    buf = buf + "    HexaVal* heap = (HexaVal*)malloc(sizeof(HexaVal) * (size_t)new_cap);\n"
    buf = buf + "    if (!heap) return NULL;\n"
    buf = buf + "    if (arena_items && len > 0) {\n"
    buf = buf + "        hxlcl_memcpy(heap, arena_items, sizeof(HexaVal) * (size_t)len);\n"
    buf = buf + "    }\n"
    buf = buf + "    return heap;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_array_new() {\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_array_new++;\n"
    buf = buf + "    HexaVal v = {.tag=TAG_ARRAY};\n"
    buf = buf + "    HX_SET_ARR_PTR(v, (HexaArr*)calloc(1, sizeof(HexaArr)));\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    // ── UNSHADOW [HEADLINE] F1: native-i64 array storage helpers ────────────
    // Native contiguous int64_t[] (8-byte stride), the storage the codegen emits
    // for a statically-proven monomorphic-i64 array. Carried in a HexaVal as a
    // TAG_ARRAY via the arr_ptr union slot (the descriptor is HexaArrI64*, the
    // codegen always knows when a binding is the proven-i64 form). data[] is
    // public in runtime.h so a proven in-range read `((HexaArrI64*)a.arr_ptr)
    // ->data[i]` is a raw native load through the runtime.o wall (§c-class).
    buf = buf + "HexaVal hexa_arr_i64_new(int cap) {\n"
    buf = buf + "    HexaArrI64* a = (HexaArrI64*)malloc(sizeof(HexaArrI64));\n"
    buf = buf + "    if (!a) { fprintf(stderr, \"OOM in arr_i64_new\\n\"); exit(1); }\n"
    buf = buf + "    if (cap < 1) cap = 1;\n"
    buf = buf + "    a->data = (int64_t*)malloc(sizeof(int64_t) * (size_t)cap);\n"
    buf = buf + "    if (!a->data) { fprintf(stderr, \"OOM in arr_i64_new data\\n\"); exit(1); }\n"
    buf = buf + "    a->len = 0; a->cap = cap;\n"
    buf = buf + "    HexaVal v = {.tag=TAG_ARRAY};\n"
    buf = buf + "    HX_SET_ARR_PTR(v, (HexaArr*)a);\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_arr_i64_push(HexaVal v, int64_t x) {\n"
    buf = buf + "    HexaArrI64* a = (HexaArrI64*)v.arr_ptr;\n"
    buf = buf + "    if (a->len >= a->cap) {\n"
    buf = buf + "        a->cap *= 2;\n"
    buf = buf + "        a->data = (int64_t*)realloc(a->data, sizeof(int64_t) * (size_t)a->cap);\n"
    buf = buf + "        if (!a->data) { fprintf(stderr, \"OOM in arr_i64_push\\n\"); exit(1); }\n"
    buf = buf + "    }\n"
    buf = buf + "    a->data[a->len++] = x;\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "int hexa_arr_i64_len(HexaVal v) { return ((HexaArrI64*)v.arr_ptr)->len; }\n"
    buf = buf + "HexaVal hexa_arr_i64_box(HexaVal v, int64_t i) {\n"
    buf = buf + "    HexaArrI64* a = (HexaArrI64*)v.arr_ptr;\n"
    buf = buf + "    if (i < 0 || i >= a->len) { hexa_throw(hexa_str(\"index out of bounds\")); }\n"
    buf = buf + "    return hexa_int(a->data[i]);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    // ── UNSHADOW [HEADLINE] F1 (F64 mirror): native-f64 array storage helpers ──
    // Native contiguous double[] (8-byte stride), the storage codegen emits for a
    // statically-proven monomorphic-f64 array. Carried in a HexaVal as TAG_ARRAY
    // via the arr_ptr union slot (descriptor is HexaArrF64*). data[] is public in
    // runtime.h so a proven in-range read `((HexaArrF64*)a.arr_ptr)->data[i]` is a
    // raw native double load through the runtime.o wall (§c-class). The box helper
    // is used at the dynamic boundary (a typed-f64 array flowing to a polymorphic
    // site re-boxes each element correctly as a TAG_FLOAT HexaVal).
    buf = buf + "HexaVal hexa_arr_f64_new(int cap) {\n"
    buf = buf + "    HexaArrF64* a = (HexaArrF64*)malloc(sizeof(HexaArrF64));\n"
    buf = buf + "    if (!a) { fprintf(stderr, \"OOM in arr_f64_new\\n\"); exit(1); }\n"
    buf = buf + "    if (cap < 1) cap = 1;\n"
    buf = buf + "    a->data = (double*)malloc(sizeof(double) * (size_t)cap);\n"
    buf = buf + "    if (!a->data) { fprintf(stderr, \"OOM in arr_f64_new data\\n\"); exit(1); }\n"
    buf = buf + "    a->len = 0; a->cap = cap;\n"
    buf = buf + "    HexaVal v = {.tag=TAG_ARRAY};\n"
    buf = buf + "    HX_SET_ARR_PTR(v, (HexaArr*)a);\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_arr_f64_push(HexaVal v, double x) {\n"
    buf = buf + "    HexaArrF64* a = (HexaArrF64*)v.arr_ptr;\n"
    buf = buf + "    if (a->len >= a->cap) {\n"
    buf = buf + "        a->cap *= 2;\n"
    buf = buf + "        a->data = (double*)realloc(a->data, sizeof(double) * (size_t)a->cap);\n"
    buf = buf + "        if (!a->data) { fprintf(stderr, \"OOM in arr_f64_push\\n\"); exit(1); }\n"
    buf = buf + "    }\n"
    buf = buf + "    a->data[a->len++] = x;\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "int hexa_arr_f64_len(HexaVal v) { return ((HexaArrF64*)v.arr_ptr)->len; }\n"
    buf = buf + "HexaVal hexa_arr_f64_box(HexaVal v, int64_t i) {\n"
    buf = buf + "    HexaArrF64* a = (HexaArrF64*)v.arr_ptr;\n"
    buf = buf + "    if (i < 0 || i >= a->len) { hexa_throw(hexa_str(\"index out of bounds\")); }\n"
    buf = buf + "    return hexa_float(a->data[i]);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ROI #148: shallow-clone a TAG_ARRAY. Gives the caller a fresh HexaArr\n"
    buf = buf + "// descriptor (own len/cap) and a fresh items buffer of the same logical\n"
    buf = buf + "// contents. Inner HexaVals (ints/strs/nested arrays) are copied as-is —\n"
    buf = buf + "// nested arrays remain aliased, matching standard \"one level ownership\"\n"
    buf = buf + "// semantics. Non-array inputs are returned unchanged.\n"
    buf = buf + "//\n"
    buf = buf + "// Used by hexa_struct_pack_map to break caller→struct-field aliasing on\n"
    buf = buf + "// struct construction: `Box { items: xs }` stores xs's contents into a\n"
    buf = buf + "// NEW descriptor so that subsequent hexa_array_push on one struct's\n"
    buf = buf + "// .items cannot leak into a sibling struct initialized from the same xs.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "HexaVal hexa_array_shallow_clone(HexaVal v) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(v)) return v;\n"
    buf = buf + "    int n = HX_ARR_LEN(v);\n"
    buf = buf + "    int src_cap = HX_ARR_CAP(v);\n"
    buf = buf + "    int real_cap = src_cap < 0 ? -src_cap : src_cap;\n"
    buf = buf + "    HexaVal out = {.tag=TAG_ARRAY};\n"
    buf = buf + "    HexaArr* d = (HexaArr*)calloc(1, sizeof(HexaArr));\n"
    buf = buf + "    if (!d) { fprintf(stderr, \"OOM in array_shallow_clone\\n\"); exit(1); }\n"
    buf = buf + "    HX_SET_ARR_PTR(out, d);\n"
    buf = buf + "    if (n == 0 && real_cap == 0) {\n"
    buf = buf + "        // Empty: leave items NULL, cap 0. Push from here behaves like fresh.\n"
    buf = buf + "        return out;\n"
    buf = buf + "    }\n"
    buf = buf + "    // Always allocate a heap buffer (positive cap) sized to hold the\n"
    buf = buf + "    // current contents. Avoid the arena-sentinel so downstream push/grow\n"
    buf = buf + "    // can realloc freely without aliasing the source arena slab.\n"
    buf = buf + "    int new_cap = real_cap > 0 ? real_cap : (n > 0 ? n : 8);\n"
    buf = buf + "    if (new_cap < n) new_cap = n;\n"
    buf = buf + "    HexaVal* items = (HexaVal*)malloc(sizeof(HexaVal) * (size_t)new_cap);\n"
    buf = buf + "    if (!items) { fprintf(stderr, \"OOM in array_shallow_clone items\\n\"); exit(1); }\n"
    buf = buf + "    if (n > 0 && HX_ARR_ITEMS(v)) {\n"
    buf = buf + "        hxlcl_memcpy(items, HX_ARR_ITEMS(v), sizeof(HexaVal) * (size_t)n);\n"
    buf = buf + "    }\n"
    buf = buf + "    HX_SET_ARR_ITEMS(out, items);\n"
    buf = buf + "    HX_SET_ARR_LEN(out, n);\n"
    buf = buf + "    HX_SET_ARR_CAP(out, new_cap);\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// rt#32-N: snapshot-promote helper. Invoked by the transpiler around every\n"
    buf = buf + "// `let y = x` and fn-argument expression where x may be a TAG_ARRAY whose items\n"
    buf = buf + "// buffer is arena-allocated (cap < 0). Deep-copies arena items to malloc so\n"
    buf = buf + "// the snapshot is insulated from subsequent arena rewinds + callee arena\n"
    buf = buf + "// re-allocations. Passthrough for non-array / non-arena values.\n"
    buf = buf + "//\n"
    buf = buf + "// Rationale: Hexa is pass-by-value at the HexaVal level (I1), but the .items\n"
    buf = buf + "// pointer inside arr.* is shared. rt#32-M enabled arena-alloc only for the\n"
    buf = buf + "// slice_fast path because a caller-local snapshot of a persistent global could\n"
    buf = buf + "// alias the same arena buffer that the callee subsequently re-arena-alloc'd\n"
    buf = buf + "// (ABA). Snapshot-promote cuts the alias by forcing the caller's copy onto\n"
    buf = buf + "// the malloc heap at capture time.\n"
    buf = buf + "HexaVal hexa_val_snapshot_array(HexaVal v) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(v)) return v;\n"
    buf = buf + "    if (HX_ARR_CAP(v) >= 0) return v;  // heap-backed — no aliasing with arena rewind\n"
    buf = buf + "    // cap < 0: arena-backed — promote to heap.\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_array_arena_heapify++;\n"
    buf = buf + "    int real_cap = -HX_ARR_CAP(v);\n"
    buf = buf + "    HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(v), HX_ARR_LEN(v), real_cap);\n"
    buf = buf + "    if (!heap) return v;  // OOM — best-effort, caller may see stale pointer\n"
    buf = buf + "    HX_SET_ARR_ITEMS(v, heap);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    HX_SET_ARR_CAP(v, real_cap);  // positive → heap\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// rt#32-N: push-arena gate. Default OFF until snapshot-promote is fully wired\n"
    buf = buf + "// into the transpiler + interpreter source (self/hexa_full.hexa). Set\n"
    buf = buf + "// HEXA_ARRAY_PUSH_ARENA=1 to enable arena-alloc on first push (cap=0 → cap=-8)\n"
    buf = buf + "// after snapshot-promote is proven safe.\n"
    buf = buf + "static int __hexa_array_push_arena_enabled = -1;\n"
    buf = buf + "static int hexa_array_push_arena_on(void) {\n"
    buf = buf + "    if (__hexa_array_push_arena_enabled < 0) {\n"
    buf = buf + "        const char* e = hxlcl_getenv(\"HEXA_ARRAY_PUSH_ARENA\");\n"
    buf = buf + "        if (!e || !e[0]) __hexa_array_push_arena_enabled = 0;  // default OFF\n"
    buf = buf + "        else             __hexa_array_push_arena_enabled = (e[0] != '0') ? 1 : 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    return __hexa_array_push_arena_enabled;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Optimization #12: reserve capacity up front when size is known.\n"
    buf = buf + "// rt 32-M: respect arena-backed items (cap<0) — promote to heap on grow.\n"
    buf = buf + "HexaVal hexa_array_reserve(HexaVal arr, int n) {\n"
    buf = buf + "    int real_cap = HX_ARR_CAP(arr) < 0 ? -HX_ARR_CAP(arr) : HX_ARR_CAP(arr);\n"
    buf = buf + "    if (n <= real_cap) return arr;\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_array_reserve++;\n"
    buf = buf + "    if (HX_ARR_CAP(arr) < 0) {\n"
    buf = buf + "        if (_hx_stats_on()) _hx_stats_array_arena_promote++;\n"
    buf = buf + "        HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(arr), HX_ARR_LEN(arr), n);\n"
    buf = buf + "        if (!heap) { fprintf(stderr, \"OOM in array_reserve\\n\"); exit(1); }\n"
    buf = buf + "        HX_SET_ARR_ITEMS(arr, heap);\n"
    buf = buf + "        HX_SET_ARR_CAP(arr, n);\n"
