    buf = buf + "    if (HX_ARR_CAP(arr) >= 0 && __hexa_val_mark_top > 0) {\n"
    buf = buf + "        item = hexa_val_heapify(item);\n"
    buf = buf + "    }\n"
    buf = buf + "    HX_ARR_ITEMS(arr)[HX_ARR_LEN(arr)] = item;\n"
    buf = buf + "    HX_SET_ARR_LEN(arr, HX_ARR_LEN(arr) + 1);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-B: reusable-buffer scratch push. Semantics identical to hexa_array_push\n"
    buf = buf + "// except it does NOT bump _hx_stats_array_push / _hx_stats_array_grow (those\n"
    buf = buf + "// counters are reserved for \"true\" per-call allocs). Used by the NK_CALL args\n"
    buf = buf + "// accumulator (call_arg_buf) which is a single long-lived buffer — its growth\n"
    buf = buf + "// amortises across the whole program and should not inflate the per-call\n"
    buf = buf + "// push/grow histogram.\n"
    buf = buf + "HexaVal hexa_array_push_nostat(HexaVal arr, HexaVal item) {\n"
    buf = buf + "    // rt 32-M: stays on heap (call_arg_buf is long-lived — arena rewind would\n"
    buf = buf + "    // invalidate it). If an arena buffer somehow lands here, promote to heap.\n"
    buf = buf + "    int real_cap = HX_ARR_CAP(arr) < 0 ? -HX_ARR_CAP(arr) : HX_ARR_CAP(arr);\n"
