    buf = buf + "        if (HX_ARR_CAP(arr) < 0) {\n"
    buf = buf + "            HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(arr), HX_ARR_LEN(arr), new_cap);\n"
    buf = buf + "            if (!heap) { fprintf(stderr, \"OOM in array_push_nostat\\n\"); exit(1); }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            HX_SET_ARR_ITEMS(arr, heap);\n"
    buf = buf + "            HX_SET_ARR_CAP(arr, new_cap);\n"
    buf = buf + "        } else {\n"
    buf = buf + "            HexaVal* new_items = realloc(HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)new_cap);\n"
    buf = buf + "            if (!new_items) { fprintf(stderr, \"OOM in array_push_nostat\\n\"); exit(1); }\n"
    buf = buf + "            HX_SET_ARR_ITEMS(arr, new_items);\n"
    buf = buf + "            HX_SET_ARR_CAP(arr, new_cap);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    HX_ARR_ITEMS(arr)[HX_ARR_LEN(arr)] = item;\n"
    buf = buf + "    HX_SET_ARR_LEN(arr, HX_ARR_LEN(arr) + 1);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-B: bulk slice primitive — single malloc + memcpy, counts as exactly\n"
    buf = buf + "// ONE array_new (not N array_push). Used to hand a per-call args view out of\n"
    buf = buf + "// the shared call_arg_buf so the callee receives an independent backing store\n"
    buf = buf + "// that is not disturbed by subsequent NK_CALL recursion mutating the buffer.\n"
    buf = buf + "HexaVal hexa_array_slice_fast(HexaVal arr, HexaVal start, HexaVal end) {\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_array_new++;\n"
