    buf = buf + "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n"
    buf = buf + "    return rt_str_char_at(s, idx);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Byte value at offset i (0..255), or -1 if out-of-range. JS-analog\n"
    buf = buf + "// `.char_code_at` expects UTF-16 code units; we expose raw byte\n"
    buf = buf + "// values since hexa strings are byte-sequenced. A later UTF-8\n"
    buf = buf + "// codepoint API (`.code_point_at`) can layer on if needed.\n"
    buf = buf + "// Step-3 cycle 52 NOTE — hexa_str_char_code_at is intentionally NOT\n"
    buf = buf + "// ported. The chain `s.byte_at(i)` → hexa_str_byte_at(s, idx) →\n"
    buf = buf + "// hexa_str_char_code_at(s, idx) (see line 4327) means any hexa-source\n"
    buf = buf + "// rt_str_char_code_at body would infinite-recurse through the byte_at\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// builtin. Stays C-only; the 4-line body has no real porting value.\n"
    buf = buf + "HexaVal hexa_str_char_code_at(HexaVal s, HexaVal idx) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_int(-1);\n"
    buf = buf + "    int64_t i = HX_INT(idx);\n"
    buf = buf + "    int64_t n = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    if (i < 0) i += n;  // 음수 wraparound — char_at 과 align\n"
    buf = buf + "    if (i < 0 || i >= n) return hexa_int(-1);\n"
    buf = buf + "    return hexa_int((int64_t)(unsigned char)HX_STR(s)[i]);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── UTF-8 char-aware string methods (parity-gate t45b: 2026-05-19) ──\n"
    buf = buf + "// hexa strings are byte-sequenced UTF-8. `.char_at(i)` / `.byte_at(i)` /\n"
    buf = buf + "// `.char_code_at(i)` are byte-indexed; the methods below are codepoint-\n"
    buf = buf + "// indexed for true UTF-8 char-aware iteration (한글, emoji, etc.). The\n"
    buf = buf + "// runtime was missing these (interp does the codepoint walking via\n"
    buf = buf + "// tree-walker); deletion-gate requires the compiled path to match.\n"
    buf = buf + "static int _hx_utf8_cp_len(unsigned char b) {\n"
    buf = buf + "    if (b < 0x80) return 1;\n"
    buf = buf + "    if ((b & 0xE0) == 0xC0) return 2;\n"
    buf = buf + "    if ((b & 0xF0) == 0xE0) return 3;\n"
    buf = buf + "    if ((b & 0xF8) == 0xF0) return 4;\n"
    buf = buf + "    return 1;  // invalid lead byte — advance by 1 (don't infinite-loop)\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Count UTF-8 codepoints. `\"한글hi\".char_count() == 4` etc.\n"
    buf = buf + "// Step-3 cycle 52 — dispatches to rt_str_char_count (reuses\n"
