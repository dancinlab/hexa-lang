#!hexa strict
// runtime_core_emit.hexa
//   B9.C (.c-text · #1850 pattern) — runtime_core.c source emitter.
//
// RFC 061 amalgamation CORE-tier fragment — self/runtime.c #include "runtime_core.c". Written via buffered-flush (per-command exec size limit on linux).
//
// Emits runtime_core.c VERBATIM. The hexa build regenerates the .c from
// this emitter before compiling, so the emitter becomes the SSOT and the
// .c becomes a build artifact. Byte-identity (gate-1 source-SHA, proven by
// runtime_core_byte_diff.hexa) ⇒ identical .o/.so ⇒ PERF UNCHANGED.
//
// GENERATED by tool/gen_c_text_emitter.hexa — do not hand-edit; re-run the
// generator against the hand-written .c if it ever changes.
//
// Invocation:  hexa-run runtime_core_emit.hexa <output-path>
// Default output path (if argv missing): "runtime_core.c" in cwd.

let MODULE_NAME = "runtime_core_emit"

fn _flush_runtime_core(out_path: str, buf: str) {
    let _ = exec("cat >> \"" + out_path + "\" <<'GEN_runtime_core_EOF'\n" + buf + "GEN_runtime_core_EOF")
}

fn emit_runtime_core_to(out_path: str) {
    // Verbatim content of hand-written self/native/runtime_core.c, streamed in
    // size-bounded chunks (see generator note on the per-command exec limit).
    let _ = exec("printf '' > \"" + out_path + "\"")
    let mut buf = ""
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  HEXA C Runtime — CORE tier (runtime_core.c)\n"
    buf = buf + "//  RFC 061 Phase P1: 2-layer split, phase 1.\n"
    buf = buf + "//\n"
    buf = buf + "//  This file is the irreducible C core of the hexa runtime per the\n"
    buf = buf + "//  RFC 061 §4.1 boundary criterion: HexaVal representation bits\n"
    buf = buf + "//  (NaN-box tag macros, the struct/union layout), the allocator hot\n"
    buf = buf + "//  path (arena, malloc wrappers, array/map primitive memory ops),\n"
    buf = buf + "//  the universal codegen-emitted primitives (hexa_int/float/str/bool/\n"
    buf = buf + "//  void constructors, hexa_add and the arithmetic/comparison family,\n"
    buf = buf + "//  hexa_index_get, hexa_len, hexa_array_new/push/get/set, hexa_map_*),\n"
    buf = buf + "//  and their transitive closure (string interning, branch-hint macros,\n"
    buf = buf + "//  RSS cap, fuel telemetry — all referenced on the core path).\n"
    buf = buf + "//\n"
    buf = buf + "//  It is #include-d (NOT separately compiled) by self/runtime.c right\n"
    buf = buf + "//  after the system #include block; the preprocessor concatenation of\n"
    buf = buf + "//  runtime.c's system headers + this file + runtime.c's HI tier yields\n"
    buf = buf + "//  a translation unit byte-identical to the pre-split runtime.c.\n"
    buf = buf + "//\n"
    buf = buf + "//  HI-tier functions (FFI, struct-pack, trampoline, term/exec/json/\n"
    buf = buf + "//  regex, farr, safetensors, tensor, autograd, the ML numerics) stay\n"
    buf = buf + "//  in runtime.c — RFC 061 P2/P3 migrate those to hexa source.\n"
    buf = buf + "//\n"
    buf = buf + "//  NOTE on size: a clean *contiguous-prefix* split lands the core at\n"
    buf = buf + "//  ~6.0 k lines, larger than the RFC §5b per-function projection\n"
    buf = buf + "//  (≈2.4-3 k). The prefix cut is deliberate — it is provably\n"
    buf = buf + "//  zero-behavior-change (pure file partition; no function reorder, so\n"
    buf = buf + "//  no risk to internal forward-decl / file-scope-static ordering).\n"
    buf = buf + "//  A small number of string/math/format helpers that §5b classifies\n"
    buf = buf + "//  HI sit in this prefix; they are exactly the P2/P3 migration\n"
    buf = buf + "//  tranches and will leave this file when rewritten in hexa.\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  Branch hints + cold attribute + cacheline prefetch\n"
    buf = buf + "//  (A17 / A18 / Z20 — docs/hexa_speedup_brainstorm_2026_05_06.ai.md)\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "// HX_LIKELY / HX_UNLIKELY: __builtin_expect wrappers for hot-path bias.\n"
    buf = buf + "//   Only wrap branches whose taken-direction is dominated (>~80%) by a\n"
    buf = buf + "//   single arm in measured workloads — wrong-way hints can hurt by 1-2%.\n"
    buf = buf + "// HX_COLD: function attribute that pushes the body into the cold .text\n"
    buf = buf + "//   section so it doesn't pollute icache on the common path.\n"
    buf = buf + "// HX_PREFETCH: cacheline prefetch hint (no-op on archs without builtin).\n"
    buf = buf + "// All three are zero-cost no-ops under non-GCC/Clang compilers.\n"
    buf = buf + "#if defined(__GNUC__) || defined(__clang__)\n"
    buf = buf + "#  ifndef HX_LIKELY\n"
    buf = buf + "#    define HX_LIKELY(x)   __builtin_expect(!!(x), 1)\n"
    buf = buf + "#  endif\n"
    buf = buf + "#  ifndef HX_UNLIKELY\n"
    buf = buf + "#    define HX_UNLIKELY(x) __builtin_expect(!!(x), 0)\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#  endif\n"
    buf = buf + "#  ifndef HX_COLD\n"
    buf = buf + "#    define HX_COLD __attribute__((cold))\n"
    buf = buf + "#  endif\n"
    buf = buf + "#  ifndef HX_PREFETCH\n"
    buf = buf + "#    define HX_PREFETCH(addr) __builtin_prefetch((const void*)(addr), 0, 1)\n"
    buf = buf + "#  endif\n"
    buf = buf + "#else\n"
    buf = buf + "#  ifndef HX_LIKELY\n"
    buf = buf + "#    define HX_LIKELY(x)   (x)\n"
    buf = buf + "#  endif\n"
    buf = buf + "#  ifndef HX_UNLIKELY\n"
    buf = buf + "#    define HX_UNLIKELY(x) (x)\n"
    buf = buf + "#  endif\n"
    buf = buf + "#  ifndef HX_COLD\n"
    buf = buf + "#    define HX_COLD\n"
    buf = buf + "#  endif\n"
    buf = buf + "#  ifndef HX_PREFETCH\n"
    buf = buf + "#    define HX_PREFETCH(addr) ((void)0)\n"
    buf = buf + "#  endif\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// hexa_pipe_buf_enlarge — TL;DR #4 pipe buffer optimization (2026-05-06).\n"
    buf = buf + "// Two variants because the optimal lever differs by read pattern:\n"
    buf = buf + "//\n"
    buf = buf + "//   _kernel — Linux F_SETPIPE_SZ only (1 MB kernel pipe). No-op on macOS.\n"
    buf = buf + "//             Use for fread()-based bulk drain paths (hexa_exec,\n"
    buf = buf + "//             hexa_exec_with_status). The userland setvbuf path costs more\n"
    buf = buf + "//             than it saves there: caller already does fread() into a 4 KB\n"
    buf = buf + "//             stack buf, and macOS adds a 256 KB malloc + memcpy hop per\n"
    buf = buf + "//             popen with no syscall reduction (measured 2x regression on\n"
    buf = buf + "//             50 MB `yes | head` stream, 2026-05-06).\n"
    buf = buf + "//\n"
    buf = buf + "//   _full   — F_SETPIPE_SZ on Linux + setvbuf 256 KB userland on all\n"
    buf = buf + "//             platforms. Use for fgets()-based streaming paths\n"
    buf = buf + "//             (hexa_exec_stream_impl). Streaming reads line-at-a-time, so\n"
    buf = buf + "//             a large refill buffer behind fgets() amortizes the syscall.\n"
    buf = buf + "//\n"
    buf = buf + "// Linux F_SETPIPE_SZ may be rejected (EPERM if pipe-max-size exceeded,\n"
    buf = buf + "// EINVAL on old kernels) — silently fall back, never fail the caller.\n"
    buf = buf + "// Must be called immediately after popen() and before any I/O on fp —\n"
    buf = buf + "// setvbuf() requires a fresh stream.\n"
    buf = buf + "static inline void hexa_pipe_buf_enlarge_kernel(FILE* fp) {\n"
    buf = buf + "    if (!fp) return;\n"
    buf = buf + "#ifdef __linux__\n"
    buf = buf + "#ifdef F_SETPIPE_SZ\n"
    buf = buf + "    int fd = fileno(fp);\n"
    buf = buf + "    if (fd >= 0) {\n"
    buf = buf + "        (void)hxlcl_fcntl(fd, F_SETPIPE_SZ, 1 << 20);\n"
    buf = buf + "        // Ignore errno (EPERM/EINVAL) — kernel may reject; default size\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        // still works correctly, only throughput differs.\n"
    buf = buf + "    }\n"
    buf = buf + "#endif\n"
    buf = buf + "#else\n"
    buf = buf + "    (void)fp;  // macOS: F_SETPIPE_SZ unsupported, leave default.\n"
    buf = buf + "#endif\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline void hexa_pipe_buf_enlarge_full(FILE* fp) {\n"
    buf = buf + "    if (!fp) return;\n"
    buf = buf + "    hexa_pipe_buf_enlarge_kernel(fp);\n"
    buf = buf + "    // Userland FILE* buffer: 256 KB fully-buffered. Helps fgets() amortize\n"
    buf = buf + "    // the read() syscall over many lines.\n"
    buf = buf + "    (void)setvbuf(fp, NULL, _IOFBF, 256 * 1024);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// 2026-05-06 audit closure:\n"
    buf = buf + "//   - stdout: _IOLBF (line-buffered) — flushes on newline when redirected to\n"
    buf = buf + "//     file/pipe so subprocess prompts and progress aren't held mid-line.\n"
    buf = buf + "//   - stderr: _IONBF (unbuffered) — POSIX default for stderr is unbuffered\n"
    buf = buf + "//     so diagnostics appear immediately even on partial-line writes (e.g.\n"
    buf = buf + "//     \"loading…\" without newline). Earlier _IOLBF setting was over-buffered.\n"
    buf = buf + "//   - SIGPIPE: SIG_IGN — when a child closes its stdin while the parent is\n"
    buf = buf + "//     mid-write (interactive prompts, build pipelines), the default SIGPIPE\n"
    buf = buf + "//     would kill the runtime. Ignoring it lets write() return EPIPE and the\n"
    buf = buf + "//     caller decide how to handle the broken-pipe case.\n"
    buf = buf + "__attribute__((constructor))\n"
    buf = buf + "static void _hexa_init_stdio(void) {\n"
    buf = buf + "    setvbuf(stdout, NULL, _IOLBF, 0);\n"
    buf = buf + "    setvbuf(stderr, NULL, _IONBF, 0);\n"
    buf = buf + "    hxlcl_signal(SIGPIPE, SIG_IGN);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  PATH augmentation for macOS — Homebrew / MacPorts visibility\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//\n"
    buf = buf + "// Background: hexa modules call exec(\"timeout 30 ...\") / exec(\"python3 -c ...\")\n"
    buf = buf + "// expecting that subshells (popen → /bin/sh -c) can find binaries on the\n"
    buf = buf + "// operator's normal PATH. On macOS, common operator tools (timeout, gtimeout,\n"
    buf = buf + "// python3, qrencode, jq, ripgrep, ...) live under /opt/homebrew/bin (Apple\n"
    buf = buf + "// Silicon) or /usr/local/bin (Intel + linuxbrew). When hexa is invoked from a\n"
    buf = buf + "// context where the parent's PATH was sanitized (launchd, cron, system\n"
    buf = buf + "// services that bypass the user shell, or any caller that exec'd hexa with a\n"
    buf = buf + "// minimal env), popen() faithfully passes that minimal PATH through to\n"
    buf = buf + "// /bin/sh, and \"timeout\" / \"python3\" disappear — surfacing as silent failures\n"
    buf = buf + "// or 127 exit codes inside hexa modules.\n"
    buf = buf + "//\n"
    buf = buf + "// Pragmatic root-cause fix: on macOS, pre-pend the standard package-manager\n"
    buf = buf + "// prefixes to PATH at runtime startup so every popen()/fork+exec child\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// inherits a path that can resolve the operator's everyday tools. This\n"
    buf = buf + "// matches what an interactive shell startup (zsh + /etc/zprofile + path_helper)\n"
    buf = buf + "// would do, except we apply it inside the hexa process even when launched\n"
    buf = buf + "// from a non-shell parent. Linux is left untouched (its FHS layout already\n"
    buf = buf + "// has /usr/local/bin in the default PATH on most distros, and Homebrew on\n"
    buf = buf + "// Linux installs to /home/linuxbrew/.linuxbrew/bin which the operator's\n"
    buf = buf + "// shell rc already injects).\n"
    buf = buf + "//\n"
    buf = buf + "// Escape hatch:\n"
    buf = buf + "//   HEXA_PATH_NO_AUGMENT=1   → disable; child sees parent PATH verbatim.\n"
    buf = buf + "//\n"
    buf = buf + "// Idempotency: each candidate is added only if not already present\n"
    buf = buf + "// (substring match against `:`-delimited segments). Order: candidates are\n"
    buf = buf + "// pre-pended in the order listed below, so /opt/homebrew/bin wins over\n"
    buf = buf + "// /usr/local/bin (matches Apple Silicon Homebrew priority over linuxbrew /\n"
    buf = buf + "// stale Intel installs).\n"
    buf = buf + "//\n"
    buf = buf + "// Security boundary: this changes which directories popen() searches; it\n"
    buf = buf + "// does NOT introduce a new shell-injection vector (callers still pass a\n"
    buf = buf + "// quoted command to popen as before). An operator who explicitly wants the\n"
    buf = buf + "// minimal PATH (e.g. for sandbox testing) sets HEXA_PATH_NO_AUGMENT=1.\n"
    buf = buf + "__attribute__((constructor))\n"
    buf = buf + "static void _hexa_init_path_augment(void) {\n"
    buf = buf + "#if defined(__APPLE__)\n"
    buf = buf + "    const char* opt = hxlcl_getenv(\"HEXA_PATH_NO_AUGMENT\");\n"
    buf = buf + "    if (opt && opt[0] == '1' && opt[1] == '\\0') return;\n"
    buf = buf + "\n"
    buf = buf + "    const char* old = hxlcl_getenv(\"PATH\");\n"
    buf = buf + "    if (!old) old = \"\";\n"
    buf = buf + "\n"
    buf = buf + "    // Candidates pre-pended in order. /opt/homebrew first (Apple Silicon\n"
    buf = buf + "    // Homebrew default), /usr/local next (Intel Homebrew + manual installs),\n"
    buf = buf + "    // /opt/local last (MacPorts). sbin variants included for tools like\n"
    buf = buf + "    // pfctl wrappers shipped under sbin in some bottles.\n"
    buf = buf + "    static const char* const candidates[] = {\n"
    buf = buf + "        \"/opt/homebrew/bin\",\n"
    buf = buf + "        \"/opt/homebrew/sbin\",\n"
    buf = buf + "        \"/usr/local/bin\",\n"
    buf = buf + "        \"/usr/local/sbin\",\n"
    buf = buf + "        \"/opt/local/bin\",\n"
    buf = buf + "        \"/opt/local/sbin\",\n"
    buf = buf + "        NULL\n"
    buf = buf + "    };\n"
    buf = buf + "\n"
    buf = buf + "    // Build new PATH = <missing candidates joined by ':'> + ':' + old.\n"
    buf = buf + "    // Worst-case length: sum of all candidates + separators + old + NUL.\n"
    buf = buf + "    size_t cap = hxlcl_strlen(old) + 1;\n"
    buf = buf + "    for (int i = 0; candidates[i]; i++) cap += hxlcl_strlen(candidates[i]) + 1;\n"
    buf = buf + "    char* buf = (char*)malloc(cap);\n"
    buf = buf + "    if (!buf) return;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    buf[0] = '\\0';\n"
    buf = buf + "\n"
    buf = buf + "    for (int i = 0; candidates[i]; i++) {\n"
    buf = buf + "        const char* c = candidates[i];\n"
    buf = buf + "        size_t clen = hxlcl_strlen(c);\n"
    buf = buf + "        // Substring search for \":<c>:\", \"<c>:\" (start), or \":<c>\" (end), or\n"
    buf = buf + "        // exact match. Cheap O(n*m) scan — PATH is rarely > 4 KB and this\n"
    buf = buf + "        // runs once at process start.\n"
    buf = buf + "        int found = 0;\n"
    buf = buf + "        const char* p = old;\n"
    buf = buf + "        while (*p) {\n"
    buf = buf + "            const char* q = hxlcl_strchr(p, ':');\n"
    buf = buf + "            size_t seg = q ? (size_t)(q - p) : hxlcl_strlen(p);\n"
    buf = buf + "            if (seg == clen && hxlcl_memcmp(p, c, clen) == 0) { found = 1; break; }\n"
    buf = buf + "            if (!q) break;\n"
    buf = buf + "            p = q + 1;\n"
    buf = buf + "        }\n"
    buf = buf + "        if (!found) {\n"
    buf = buf + "            hxlcl_strcat(buf, c);\n"
    buf = buf + "            hxlcl_strcat(buf, \":\");\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    hxlcl_strcat(buf, old);\n"
    buf = buf + "\n"
    buf = buf + "    // Only call setenv if we actually added something (buf longer than old).\n"
    buf = buf + "    if (hxlcl_strlen(buf) > hxlcl_strlen(old)) {\n"
    buf = buf + "        hxlcl_setenv(\"PATH\", buf, 1);\n"
    buf = buf + "    }\n"
    buf = buf + "    free(buf);\n"
    buf = buf + "#endif\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  RSS soft cap — runtime guard against runaway memory\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//\n"
    buf = buf + "// Background: macOS rejects setrlimit(RLIMIT_AS|DATA|RSS,...) with EINVAL,\n"
    buf = buf + "// so the only effective in-process cap is polling self-RSS via task_info()\n"
    buf = buf + "// (Darwin) or /proc/self/statm (Linux). When exceeded, we exit(77) with a\n"
    buf = buf + "// clear stderr trailer instead of letting the process grow until jetsam\n"
    buf = buf + "// SIGKILL or system swap pressure.\n"
    buf = buf + "//\n"
    buf = buf + "// Tick model: hot paths (hexa_arena_alloc / hexa_array_push / hexa_strbuf_alloc)\n"
    buf = buf + "// call _hx_mem_tick(). Internally a counter modulo (every 2^16 calls) decides\n"
    buf = buf + "// whether to actually syscall. Per-call overhead ≈ 1 increment + 1 mask + 1\n"
    buf = buf + "// branch; the syscall is amortized to ~once per tens of MB of allocation.\n"
    buf = buf + "//\n"
    buf = buf + "// Defaults & overrides (2026-05-16 — opt-IN model):\n"
    buf = buf + "//   default               → NO cap. A legitimate heavy compile (the\n"
    buf = buf + "//                            compiler self-compile peaks ~30 GB) is more\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "//                            common than a runaway, and a spurious\n"
    buf = buf + "//                            exit(77) kills real work — worse than\n"
    buf = buf + "//                            letting the OS arbitrate. The cap is OFF\n"
    buf = buf + "//                            unless explicitly asked for.\n"
    buf = buf + "//   HEXA_MEM_LIMIT=<N>     → opt in to a cap of N MB (must be >0). The\n"
    buf = buf + "//                            primary knob — e.g. HEXA_MEM_LIMIT=4096\n"
    buf = buf + "//                            asserts a 4 GB ceiling for a footprint test.\n"
    buf = buf + "//   HEXA_MEM_CAP_MB=<N>    → legacy alias of HEXA_MEM_LIMIT (still honored).\n"
    buf = buf + "//   HEXA_MEM_UNLIMITED=1   → legacy explicit-disable; now also the default,\n"
    buf = buf + "//                            kept so old wrappers/scripts stay valid no-ops.\n"
    buf = buf + "//\n"
    buf = buf + "// Pre-2026-05-16 this defaulted to a 4096 MB cap (raised over time\n"
    buf = buf + "// 768→2048→4096 as the embedded atlas grew). That default is removed —\n"
    buf = buf + "// callers wanting a ceiling now set HEXA_MEM_LIMIT explicitly.\n"
    buf = buf + "//\n"
    buf = buf + "// CLI flags (parsed by the hexa wrapper script, exported as env above):\n"
    buf = buf + "//   --mem-limit=<N> / --mem-cap=<N> → HEXA_MEM_LIMIT / HEXA_MEM_CAP_MB\n"
    buf = buf + "//   --mem-unlimited                 → HEXA_MEM_UNLIMITED=1 (now a no-op)\n"
    buf = buf + "\n"
    buf = buf + "static size_t _hx_mem_cap_bytes = 4096ull * 1024ull * 1024ull;  // used only when a cap is opted in\n"
    buf = buf + "static int    _hx_mem_cap_disabled = 1;  // 2026-05-16: NO cap by default\n"
    buf = buf + "static volatile uint64_t _hx_mem_tick_ctr = 0;\n"
    buf = buf + "\n"
    buf = buf + "__attribute__((constructor))\n"
    buf = buf + "static void _hexa_init_mem_cap(void) {\n"
    buf = buf + "    // Opt-in cap. HEXA_MEM_LIMIT is the primary knob; HEXA_MEM_CAP_MB is\n"
    buf = buf + "    // a legacy alias. Either one, set to a positive MB value, enables the\n"
    buf = buf + "    // cap. HEXA_MEM_UNLIMITED=1 forces it back off (and is the default).\n"
    buf = buf + "    const char* lim = hxlcl_getenv(\"HEXA_MEM_LIMIT\");\n"
    buf = buf + "    if (lim && lim[0] != '\\0') {\n"
    buf = buf + "        long long mb = hxlcl_atoll(lim);\n"
    buf = buf + "        if (mb > 0) {\n"
    buf = buf + "            _hx_mem_cap_bytes = (size_t)mb * 1024ull * 1024ull;\n"
    buf = buf + "            _hx_mem_cap_disabled = 0;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    const char* cap = hxlcl_getenv(\"HEXA_MEM_CAP_MB\");\n"
    buf = buf + "    if (cap && cap[0] != '\\0') {\n"
    buf = buf + "        long long mb = hxlcl_atoll(cap);\n"
    buf = buf + "        if (mb > 0) {\n"
    buf = buf + "            _hx_mem_cap_bytes = (size_t)mb * 1024ull * 1024ull;\n"
    buf = buf + "            _hx_mem_cap_disabled = 0;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    const char* unl = hxlcl_getenv(\"HEXA_MEM_UNLIMITED\");\n"
    buf = buf + "    if (unl && unl[0] == '1' && unl[1] == '\\0') {\n"
    buf = buf + "        _hx_mem_cap_disabled = 1;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  glibc malloc tuning — per-step RSS monotonic-growth mitigation\n"
    buf = buf + "//  (HEXA-TRAIN-FLOOR M1 finding, PR #2119 → M3)\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "// The hexa-native trainer grows RSS ~200-325 MB/step monotonically. M1\n"
    buf = buf + "// localized the prime suspect to the host-farr path: hexa_farr_zeros ->\n"
    buf = buf + "// calloc / hexa_farr_free -> free, with ZERO mallopt/malloc_trim calls\n"
    buf = buf + "// anywhere in the runtime. Per-step the trainer allocs large packed-double\n"
    buf = buf + "// farr chunks (V*8B ~ 1.2 MB) interleaved with small weight-extract chunks\n"
    buf = buf + "// (32-128 KB); under glibc the small chunks pin the main-arena top chunk so\n"
    buf = buf + "// free'd large chunks accumulate (fragmentation) instead of returning to\n"
    buf = buf + "// the OS -> monotonic RSS climb.\n"
    buf = buf + "//\n"
    buf = buf + "// Fix (glibc-only, env-gated, conservative): when HEXA_FARR_TRIM=1, lower\n"
    buf = buf + "// M_MMAP_THRESHOLD so the large farr chunks are mmap-backed -- free() then\n"
    buf = buf + "// munmaps them straight back to the OS, bypassing the main arena entirely\n"
    buf = buf + "// -- and lower M_TRIM_THRESHOLD so the arena top chunk is released eagerly.\n"
    buf = buf + "// This is a one-time startup mallopt (no per-free cost), so it cannot\n"
    buf = buf + "// regress steady-state throughput; the only tradeoff is that mmap-backed\n"
    buf = buf + "// allocs cost a syscall per large alloc/free, acceptable for a trainer that\n"
    buf = buf + "// reuses a small set of large buffers per step.\n"
    buf = buf + "//\n"
    buf = buf + "// Default OFF: leaving it opt-in keeps the inference path (AKIDA-int4) and\n"
    buf = buf + "// the compiler self-compile (which WANT a fat retained arena) untouched;\n"
    buf = buf + "// only the training driver opts in. Thresholds are env-overridable in KiB\n"
    buf = buf + "// via HEXA_FARR_MMAP_KB / HEXA_FARR_TRIM_KB for the M4 measurement sweep.\n"
    buf = buf + "#if defined(__linux__) && defined(__GLIBC__)\n"
    buf = buf + "// runtime.c installs libc-rename shims `#define malloc(n) hxlcl_malloc(...)`\n"
    buf = buf + "// (+ free/realloc/calloc) BEFORE this TU is textually #include'd. <malloc.h>'s\n"
    buf = buf + "// glibc prototype `extern void *malloc(size_t)` would macro-expand to\n"
    buf = buf + "// `hxlcl_malloc((size_t)(size_t __size))` -> 'function cannot return function\n"
    buf = buf + "// type' (10-error cascade, Linux-glibc only; PR #2119/#2123 regression). Same\n"
    buf = buf + "// hazard the seed's ctype/exit shims dodge: #undef the rename across the\n"
    buf = buf + "// system header, then re-establish it -- runtime_core.c is ALWAYS amalgamated\n"
    buf = buf + "// under the shim (never a standalone TU, per runtime_core_byte_diff.hexa), so\n"
    buf = buf + "// the rest of this fragment must keep routing malloc-family through hxlcl_*.\n"
    buf = buf + "#undef malloc\n"
    buf = buf + "#undef free\n"
    buf = buf + "#undef realloc\n"
    buf = buf + "#undef calloc\n"
    buf = buf + "#include <malloc.h>\n"
    buf = buf + "// mallopt/malloc_trim below take the REAL libc allocator on purpose (they\n"
    buf = buf + "// are not shimmed); re-arm the rename for downstream runtime_core.c call sites.\n"
    buf = buf + "#define malloc(n)     hxlcl_malloc((size_t)(n))\n"
    buf = buf + "#define free(p)       hxlcl_free((void *)(p))\n"
    buf = buf + "#define realloc(p,n)  hxlcl_realloc((void *)(p), (size_t)(n))\n"
    buf = buf + "#define calloc(nm,sz) hxlcl_calloc((size_t)(nm), (size_t)(sz))\n"
    buf = buf + "#endif\n"
    buf = buf + "__attribute__((constructor))\n"
    buf = buf + "static void _hexa_init_malloc_tuning(void) {\n"
    buf = buf + "#if defined(__linux__) && defined(__GLIBC__)\n"
    buf = buf + "    const char* on = hxlcl_getenv(\"HEXA_FARR_TRIM\");\n"
    buf = buf + "    if (!(on && on[0] == '1' && on[1] == '\\0')) return;\n"
    buf = buf + "    // Default: any alloc >= 256 KiB is mmap-backed (so the 1.2 MB packed-\n"
    buf = buf + "    // double farr chunks munmap on free). 256 KiB sits below the smallest\n"
    buf = buf + "    // per-step large farr yet above transient string/array churn.\n"
    buf = buf + "    long mmap_kb = 256;\n"
    buf = buf + "    long trim_kb = 256;\n"
    buf = buf + "    const char* mk = hxlcl_getenv(\"HEXA_FARR_MMAP_KB\");\n"
    buf = buf + "    if (mk && mk[0] != '\\0') { long v = (long)hxlcl_atoll(mk); if (v > 0) mmap_kb = v; }\n"
    buf = buf + "    const char* tk = hxlcl_getenv(\"HEXA_FARR_TRIM_KB\");\n"
    buf = buf + "    if (tk && tk[0] != '\\0') { long v = (long)hxlcl_atoll(tk); if (v > 0) trim_kb = v; }\n"
    buf = buf + "    (void)mallopt(M_MMAP_THRESHOLD, (int)(mmap_kb * 1024));\n"
    buf = buf + "    (void)mallopt(M_TRIM_THRESHOLD, (int)(trim_kb * 1024));\n"
    buf = buf + "#endif\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "static size_t _hx_self_rss_bytes(void) {\n"
    buf = buf + "#if defined(__APPLE__)\n"
    buf = buf + "    mach_task_basic_info_data_t info;\n"
    buf = buf + "    mach_msg_type_number_t cnt = MACH_TASK_BASIC_INFO_COUNT;\n"
    buf = buf + "    if (hxlcl_task_info(mach_task_self(), MACH_TASK_BASIC_INFO,\n"
    buf = buf + "                  (task_info_t)&info, &cnt) != KERN_SUCCESS) return 0;\n"
    buf = buf + "    return (size_t)info.resident_size;\n"
    buf = buf + "#elif defined(__linux__)\n"
    buf = buf + "    // libc-unhook safe: self/runtime.c `#define fopen → hxlcl_fopen` returns a\n"
    buf = buf + "    // (void*)(fd+1) shim, NOT a real glibc FILE*. `fscanf` is NOT remapped, so\n"
    buf = buf + "    // handing it that shim deref'd a small-int as a FILE* → SIGSEGV — fired on\n"
    buf = buf + "    // every mem-cap-enabled transpile of a non-trivial input (the [1/2] step of\n"
    buf = buf + "    // `hexa drill` dispatched to a Linux pool host injects HEXA_MEM_CAP_MB=4096,\n"
    buf = buf + "    // so the RSS tick poller crashed instead of measuring). Read /proc/self/statm\n"
    buf = buf + "    // via the unhooked syscall wrappers (hxlcl_open_sys/hxlcl_read) and parse the\n"
    buf = buf + "    // second whitespace-separated field (resident pages) inline — no stdio.\n"
    buf = buf + "    int fd = hxlcl_open_sys(\"/proc/self/statm\", O_RDONLY);\n"
    buf = buf + "    if (fd < 0) return 0;\n"
    buf = buf + "    char buf[128];\n"
    buf = buf + "    long n = (long)hxlcl_read(fd, buf, sizeof(buf) - 1);\n"
    buf = buf + "    hxlcl_close(fd);\n"
    buf = buf + "    if (n <= 0) return 0;\n"
    buf = buf + "    buf[n] = '\\0';\n"
    buf = buf + "    // statm: \"<total> <resident> <shared> ...\" — skip field 1, parse field 2.\n"
    buf = buf + "    const char* p = buf;\n"
    buf = buf + "    while (*p == ' ') p++;\n"
    buf = buf + "    while (*p && *p != ' ') p++;           // skip total\n"
    buf = buf + "    while (*p == ' ') p++;\n"
    buf = buf + "    long pages_rss = 0;\n"
    buf = buf + "    while (*p >= '0' && *p <= '9') {        // parse resident\n"
    buf = buf + "        pages_rss = pages_rss * 10 + (*p - '0');\n"
    buf = buf + "        p++;\n"
    buf = buf + "    }\n"
    buf = buf + "    long ps = sysconf(_SC_PAGESIZE);\n"
    buf = buf + "    if (ps <= 0) ps = 4096;\n"
    buf = buf + "    return (size_t)pages_rss * (size_t)ps;\n"
    buf = buf + "#else\n"
    buf = buf + "    return 0;\n"
    buf = buf + "#endif\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  Fuel-abort telemetry emitter — atlas/anima ledger pipeline\n"
    buf = buf + "//  hxa-2026-05-06 fuel_abort_telemetry stub (worker fuel-emit-pipeline)\n"
    buf = buf + "//\n"
    buf = buf + "//  Schema: hexa-lang/runtime_fuel_abort/1\n"
    buf = buf + "//  Target: $HEXA_LANG/state/hx_runtime_fuel_abort.jsonl  (append-only JSONL)\n"
    buf = buf + "//\n"
    buf = buf + "//  Triggered from any abort path (mem-cap; future cpu/wall fuel exhaustion).\n"
    buf = buf + "//  Payload: ts, kind (\"mem\"|\"cpu\"|\"wall\"|\"oom\"), exit_code, binary path,\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "//           argv[1..N], rss_mb, cap_mb, fuel_count, top_frame,\n"
    buf = buf + "//           rusage (utime_us+stime_us+maxrss_kb).\n"
    buf = buf + "//  Best-effort: any failure (state dir missing, fd starvation) is silently\n"
    buf = buf + "//  swallowed — never let telemetry break an abort path.\n"
    buf = buf + "//\n"
    buf = buf + "//  TODO(fuel-worker): when interpreter fuel lands, call _hx_emit_fuel_abort\n"
    buf = buf + "//  from interpreter.hexa abort site too (kind=\"cpu\" / \"wall\"); pass\n"
    buf = buf + "//  top_frame string (function name + line) once interp exposes it.\n"
    buf = buf + "//  TODO(fuel-worker): switch to atomic O_APPEND + flock for safe parallel\n"
    buf = buf + "//  AOT processes hitting the cap simultaneously.\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "// Forward-decl globals (defined ~line 4632) so the emitter can read argv.\n"
    buf = buf + "static int _hexa_argc;\n"
    buf = buf + "static char** _hexa_argv;\n"
    buf = buf + "\n"
    buf = buf + "// JSON-escape into caller's buffer; returns bytes written (excl. NUL).\n"
    buf = buf + "// Truncates at cap-1 to guarantee NUL term. Bounded so we don't allocate.\n"
    buf = buf + "static size_t _hx_fuel_json_esc(char* dst, size_t cap, const char* s) {\n"
    buf = buf + "    if (!dst || cap == 0) return 0;\n"
    buf = buf + "    size_t out = 0;\n"
    buf = buf + "    if (!s) { dst[0] = '\\0'; return 0; }\n"
    buf = buf + "    for (; *s && out + 2 < cap; s++) {\n"
    buf = buf + "        unsigned char c = (unsigned char)*s;\n"
    buf = buf + "        if (c == '\\\\' || c == '\"') {\n"
    buf = buf + "            if (out + 3 >= cap) break;\n"
    buf = buf + "            dst[out++] = '\\\\';\n"
    buf = buf + "            dst[out++] = (char)c;\n"
    buf = buf + "        } else if (c == '\\n') {\n"
    buf = buf + "            if (out + 3 >= cap) break;\n"
    buf = buf + "            dst[out++] = '\\\\'; dst[out++] = 'n';\n"
    buf = buf + "        } else if (c == '\\r') {\n"
    buf = buf + "            if (out + 3 >= cap) break;\n"
    buf = buf + "            dst[out++] = '\\\\'; dst[out++] = 'r';\n"
    buf = buf + "        } else if (c == '\\t') {\n"
    buf = buf + "            if (out + 3 >= cap) break;\n"
    buf = buf + "            dst[out++] = '\\\\'; dst[out++] = 't';\n"
    buf = buf + "        } else if (c < 0x20) {\n"
    buf = buf + "            if (out + 7 >= cap) break;\n"
    buf = buf + "            int n = snprintf(dst + out, cap - out, \"\\\\u%04x\", c);\n"
    buf = buf + "            if (n <= 0) break;\n"
    buf = buf + "            out += (size_t)n;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            dst[out++] = (char)c;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    dst[out] = '\\0';\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// Public entry. kind ∈ {\"mem\",\"cpu\",\"wall\",\"oom\"}. Best-effort emit.\n"
    buf = buf + "// Non-static so future Hexa-side callers (interp fuel) can FFI it via\n"
    buf = buf + "// the existing dlsym pathway; meanwhile internal callers use it directly.\n"
    buf = buf + "void _hx_emit_fuel_abort(const char* kind,\n"
    buf = buf + "                         int exit_code,\n"
    buf = buf + "                         long long fuel_count,\n"
    buf = buf + "                         size_t rss_bytes,\n"
    buf = buf + "                         size_t cap_bytes,\n"
    buf = buf + "                         const char* top_frame) {\n"
    buf = buf + "    if (!kind) kind = \"unknown\";\n"
    buf = buf + "    if (!top_frame) top_frame = \"\";\n"
    buf = buf + "\n"
    buf = buf + "    // Resolve ledger path. Honor HEXA_FUEL_LEDGER override (tests / dry-run);\n"
    buf = buf + "    // fall back to $HEXA_LANG/state/, then $HOME/core/hexa-lang/state/.\n"
    buf = buf + "    char path[1024];\n"
    buf = buf + "    const char* override_p = hxlcl_getenv(\"HEXA_FUEL_LEDGER\");\n"
    buf = buf + "    if (override_p && override_p[0]) {\n"
    buf = buf + "        snprintf(path, sizeof(path), \"%s\", override_p);\n"
    buf = buf + "    } else {\n"
    buf = buf + "        const char* root = hxlcl_getenv(\"HEXA_LANG\");\n"
    buf = buf + "        if (!root || !root[0]) {\n"
    buf = buf + "            const char* home = hxlcl_getenv(\"HOME\");\n"
    buf = buf + "            if (!home || !home[0]) home = \"/tmp\";\n"
    buf = buf + "            snprintf(path, sizeof(path),\n"
    buf = buf + "                     \"%s/core/hexa-lang/state/hx_runtime_fuel_abort.jsonl\", home);\n"
    buf = buf + "        } else {\n"
    buf = buf + "            snprintf(path, sizeof(path),\n"
    buf = buf + "                     \"%s/state/hx_runtime_fuel_abort.jsonl\", root);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // ISO-8601 UTC timestamp (no exec; format inline).\n"
    buf = buf + "    char ts[32];\n"
    buf = buf + "    time_t now = hxlcl_time(NULL);\n"
    buf = buf + "    struct tm tmv;\n"
    buf = buf + "#if defined(_WIN32)\n"
    buf = buf + "    gmtime_s(&tmv, &now);\n"
    buf = buf + "#else\n"
    buf = buf + "    gmtime_r(&now, &tmv);\n"
    buf = buf + "#endif\n"
    buf = buf + "    hxlcl_strftime(ts, sizeof(ts), \"%Y-%m-%dT%H:%M:%SZ\", &tmv);\n"
    buf = buf + "\n"
    buf = buf + "    // RUSAGE snapshot (best-effort; on failure leave zeros).\n"
    buf = buf + "    long utime_us = 0, stime_us = 0, maxrss_kb = 0;\n"
    buf = buf + "    struct rusage ru;\n"
    buf = buf + "    if (hxlcl_getrusage(RUSAGE_SELF, &ru) == 0) {\n"
    buf = buf + "        utime_us = (long)ru.ru_utime.tv_sec * 1000000L + (long)ru.ru_utime.tv_usec;\n"
    buf = buf + "        stime_us = (long)ru.ru_stime.tv_sec * 1000000L + (long)ru.ru_stime.tv_usec;\n"
    buf = buf + "        // ru_maxrss: Linux=KB, macOS=bytes. Normalize to KB.\n"
    buf = buf + "        maxrss_kb = (long)ru.ru_maxrss;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#if defined(__APPLE__)\n"
    buf = buf + "        maxrss_kb /= 1024L;\n"
    buf = buf + "#endif\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Binary path = argv[0]; user args = argv[2..argc-1] (argv[1] is dup of argv[0]).\n"
    buf = buf + "    const char* binary = (_hexa_argv && _hexa_argc > 0) ? _hexa_argv[0] : \"\";\n"
    buf = buf + "    if (!binary) binary = \"\";\n"
    buf = buf + "\n"
    buf = buf + "    // Build args array string: [\"a\",\"b\",...]\n"
    buf = buf + "    char args_buf[1024];\n"
    buf = buf + "    args_buf[0] = '['; args_buf[1] = '\\0';\n"
    buf = buf + "    size_t apos = 1;\n"
    buf = buf + "    int args_start = (_hexa_argc >= 2) ? 2 : _hexa_argc;\n"
    buf = buf + "    int wrote = 0;\n"
    buf = buf + "    for (int i = args_start; i < _hexa_argc && _hexa_argv && _hexa_argv[i]; i++) {\n"
    buf = buf + "        if (apos + 4 >= sizeof(args_buf)) break;\n"
    buf = buf + "        if (wrote) { args_buf[apos++] = ','; }\n"
    buf = buf + "        args_buf[apos++] = '\"';\n"
    buf = buf + "        char esc[256];\n"
    buf = buf + "        _hx_fuel_json_esc(esc, sizeof(esc), _hexa_argv[i]);\n"
    buf = buf + "        size_t elen = hxlcl_strlen(esc);\n"
    buf = buf + "        if (apos + elen + 2 >= sizeof(args_buf)) { apos--; break; }\n"
    buf = buf + "        hxlcl_memcpy(args_buf + apos, esc, elen); apos += elen;\n"
    buf = buf + "        args_buf[apos++] = '\"';\n"
    buf = buf + "        wrote = 1;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (apos + 1 < sizeof(args_buf)) args_buf[apos++] = ']';\n"
    buf = buf + "    args_buf[apos] = '\\0';\n"
    buf = buf + "\n"
    buf = buf + "    // JSON-escape variable strings.\n"
    buf = buf + "    char binary_esc[512];\n"
    buf = buf + "    char top_esc[256];\n"
    buf = buf + "    char kind_esc[32];\n"
    buf = buf + "    _hx_fuel_json_esc(binary_esc, sizeof(binary_esc), binary);\n"
    buf = buf + "    _hx_fuel_json_esc(top_esc, sizeof(top_esc), top_frame);\n"
    buf = buf + "    _hx_fuel_json_esc(kind_esc, sizeof(kind_esc), kind);\n"
    buf = buf + "\n"
    buf = buf + "    // Compose the JSONL line.\n"
    buf = buf + "    char line[3072];\n"
    buf = buf + "    int n = snprintf(line, sizeof(line),\n"
    buf = buf + "        \"{\\\"schema\\\":\\\"hexa-lang/runtime_fuel_abort/1\\\"\"\n"
    buf = buf + "        \",\\\"ts\\\":\\\"%s\\\"\"\n"
    buf = buf + "        \",\\\"event\\\":\\\"hexa.runtime.fuel_abort\\\"\"\n"
    buf = buf + "        \",\\\"kind\\\":\\\"%s\\\"\"\n"
    buf = buf + "        \",\\\"exit_code\\\":%d\"\n"
    buf = buf + "        \",\\\"binary\\\":\\\"%s\\\"\"\n"
    buf = buf + "        \",\\\"args\\\":%s\"\n"
    buf = buf + "        \",\\\"fuel_count\\\":%lld\"\n"
    buf = buf + "        \",\\\"rss_mb\\\":%llu\"\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        \",\\\"cap_mb\\\":%llu\"\n"
    buf = buf + "        \",\\\"top_frame\\\":\\\"%s\\\"\"\n"
    buf = buf + "        \",\\\"rusage\\\":{\\\"utime_us\\\":%ld,\\\"stime_us\\\":%ld,\\\"maxrss_kb\\\":%ld}\"\n"
    buf = buf + "        \"}\\n\",\n"
    buf = buf + "        ts, kind_esc, exit_code, binary_esc, args_buf,\n"
    buf = buf + "        fuel_count,\n"
    buf = buf + "        (unsigned long long)(rss_bytes / (1024ull * 1024ull)),\n"
    buf = buf + "        (unsigned long long)(cap_bytes / (1024ull * 1024ull)),\n"
    buf = buf + "        top_esc,\n"
    buf = buf + "        utime_us, stime_us, maxrss_kb);\n"
    buf = buf + "    if (n <= 0) return;\n"
    buf = buf + "    if ((size_t)n >= sizeof(line)) n = (int)sizeof(line) - 1;\n"
    buf = buf + "\n"
    buf = buf + "    // Best-effort mkdir of immediate parent dir; silent on failure.\n"
    buf = buf + "    {\n"
    buf = buf + "        char dir[1024];\n"
    buf = buf + "        size_t pl = hxlcl_strlen(path);\n"
    buf = buf + "        size_t cut = pl;\n"
    buf = buf + "        while (cut > 0 && path[cut - 1] != '/') cut--;\n"
    buf = buf + "        if (cut > 0 && cut < sizeof(dir)) {\n"
    buf = buf + "            hxlcl_memcpy(dir, path, cut - 1);\n"
    buf = buf + "            dir[cut - 1] = '\\0';\n"
    buf = buf + "            // TODO(fuel-worker): full mkdir -p chain. state/ usually exists.\n"
    buf = buf + "            (void)hxlcl_mkdir(dir, 0755);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    FILE* f = fopen(path, \"a\");\n"
    buf = buf + "    if (!f) {\n"
    buf = buf + "        // Last-resort: stderr trailer so external watchers still see it.\n"
    buf = buf + "        fprintf(stderr, \"[hexa-runtime/fuel_abort] %s\", line);\n"
    buf = buf + "        return;\n"
    buf = buf + "    }\n"
    buf = buf + "    fwrite(line, 1, (size_t)n, f);\n"
    buf = buf + "    fflush(f);\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "__attribute__((noinline))\n"
    buf = buf + "static void _hx_mem_cap_fire(size_t rss) {\n"
    buf = buf + "    fprintf(stderr,\n"
    buf = buf + "        \"[hexa-runtime] memory cap exceeded: rss=%zuMB > cap=%zuMB\\n\"\n"
    buf = buf + "        \"[hexa-runtime] hint: this cap is opt-in (HEXA_MEM_LIMIT/HEXA_MEM_CAP_MB) — \"\n"
    buf = buf + "        \"raise HEXA_MEM_LIMIT=<MB>, or unset it for no cap (the default).\\n\",\n"
    buf = buf + "        (size_t)(rss / (1024ull*1024ull)),\n"
    buf = buf + "        (size_t)(_hx_mem_cap_bytes / (1024ull*1024ull)));\n"
    buf = buf + "    // Telemetry: ledger emit before exit. Best-effort; never blocks the abort.\n"
    buf = buf + "    // fuel_count = -1 (n/a for memory cap; future interp fuel passes int).\n"
    buf = buf + "    _hx_emit_fuel_abort(\"mem\", 77, -1, rss, _hx_mem_cap_bytes, \"\");\n"
    buf = buf + "    exit(77);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline void _hx_mem_tick(void) {\n"
    buf = buf + "    if (_hx_mem_cap_disabled) return;\n"
    buf = buf + "    // 2026-05-05: 0xFFFF (65 536 calls) → 0x0FFF (4 096 calls) — 16× more\n"
    buf = buf + "    // frequent. Tightens overshoot bound on bursty allocators (the\n"
    buf = buf + "    // observed runaways went 1 → 5 GB inside one 30s watcher window).\n"
    buf = buf + "    if ((++_hx_mem_tick_ctr & 0x0FFFu) != 0) return;\n"
    buf = buf + "    size_t rss = _hx_self_rss_bytes();\n"
    buf = buf + "    if (rss > _hx_mem_cap_bytes) _hx_mem_cap_fire(rss);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── H03 (2026-05-06): forward decls for HEXA_ALLOC_STATS extensions ──\n"
    buf = buf + "// Storage + main definitions live alongside the rt 32 stats block (~line 1080+).\n"
    buf = buf + "// We declare them up-front so early callers (hexa_intern, hexa_closure_new,\n"
    buf = buf + "// hexa_fn_new — all defined before the stats block) can reference them.\n"
    buf = buf + "// `_hx_stats_on()` is the central guard; everything else is only touched\n"
    buf = buf + "// inside that guard, so unset-env paths are a single predicted branch + RET.\n"
    buf = buf + "static int _hx_stats_on(void);\n"
    buf = buf + "#define HX_POOL_LRU 8\n"
    buf = buf + "static int64_t _hx_stats_intern_hit;     // file-scope tentative defs (zero-init)\n"
    buf = buf + "static int64_t _hx_stats_intern_miss;\n"
    buf = buf + "static int64_t _hx_stats_intern_skip;\n"
    buf = buf + "static int64_t _hx_stats_intern_grow;\n"
    buf = buf + "static int64_t _hx_stats_closure_alloc;\n"
    buf = buf + "static int64_t _hx_stats_fn_alloc;\n"
    buf = buf + "static int64_t _hx_stats_fn_alloc_dup;\n"
    buf = buf + "static int64_t _hx_stats_clo_alloc_dup;\n"
    buf = buf + "static void* _hx_stats_fn_lru[HX_POOL_LRU];\n"
    buf = buf + "static void* _hx_stats_clo_lru[HX_POOL_LRU];\n"
    buf = buf + "static int   _hx_stats_fn_lru_pos;\n"
    buf = buf + "static int   _hx_stats_clo_lru_pos;\n"
    buf = buf + "static inline int _hx_stats_lru_check(void** ring, int* pos, void* p) {\n"
    buf = buf + "    for (int i = 0; i < HX_POOL_LRU; i++) {\n"
    buf = buf + "        if (ring[i] == p) return 1;\n"
    buf = buf + "    }\n"
    buf = buf + "    ring[*pos] = p;\n"
    buf = buf + "    *pos = (*pos + 1) % HX_POOL_LRU;\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  Optimization #11: String Interning\n"
    buf = buf + "//  Hash-set of unique strings. Short strings (< 64 chars)\n"
    buf = buf + "//  are interned; comparison becomes pointer equality (==).\n"
    buf = buf + "//  Lazily initialized on first hexa_intern() call.\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "#define INTERN_INIT_CAP   1024\n"
    buf = buf + "#define INTERN_MAX_LEN    64\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#define INTERN_LOAD_MAX   75   // percent\n"
    buf = buf + "\n"
    buf = buf + "static uint32_t hexa_fnv1a(const char* s, size_t len) {\n"
    buf = buf + "    uint32_t h = 2166136261u;\n"
    buf = buf + "    for (size_t i = 0; i < len; i++) {\n"
    buf = buf + "        h ^= (uint8_t)s[i];\n"
    buf = buf + "        h *= 16777619u;\n"
    buf = buf + "    }\n"
    buf = buf + "    return h;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Also used by the hash-map (#10)\n"
    buf = buf + "uint32_t hexa_fnv1a_str(const char* s) {\n"
    buf = buf + "    uint32_t h = 2166136261u;\n"
    buf = buf + "    for (; *s; s++) {\n"
    buf = buf + "        h ^= (uint8_t)*s;\n"
    buf = buf + "        h *= 16777619u;\n"
    buf = buf + "    }\n"
    buf = buf + "    return h;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    char** buckets;      // array of interned string pointers (NULL = empty)\n"
    buf = buf + "    uint32_t* hashes;    // cached hash per slot\n"
    buf = buf + "    int cap;             // power-of-2 capacity\n"
    buf = buf + "    int count;           // number of occupied slots\n"
    buf = buf + "} HexaInternTable;\n"
    buf = buf + "\n"
    buf = buf + "static HexaInternTable __hexa_intern = {NULL, NULL, 0, 0};\n"
    buf = buf + "\n"
    buf = buf + "static void hexa_intern_init(void) {\n"
    buf = buf + "    __hexa_intern.cap = INTERN_INIT_CAP;\n"
    buf = buf + "    __hexa_intern.count = 0;\n"
    buf = buf + "    __hexa_intern.buckets = (char**)calloc(INTERN_INIT_CAP, sizeof(char*));\n"
    buf = buf + "    __hexa_intern.hashes  = (uint32_t*)calloc(INTERN_INIT_CAP, sizeof(uint32_t));\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static void hexa_intern_grow(void) {\n"
    buf = buf + "    int old_cap = __hexa_intern.cap;\n"
    buf = buf + "    char** old_buckets = __hexa_intern.buckets;\n"
    buf = buf + "    uint32_t* old_hashes = __hexa_intern.hashes;\n"
    buf = buf + "    int new_cap = old_cap * 2;\n"
    buf = buf + "    char** new_buckets = (char**)calloc(new_cap, sizeof(char*));\n"
    buf = buf + "    uint32_t* new_hashes = (uint32_t*)calloc(new_cap, sizeof(uint32_t));\n"
    buf = buf + "    uint32_t mask = (uint32_t)(new_cap - 1);\n"
    buf = buf + "    for (int i = 0; i < old_cap; i++) {\n"
    buf = buf + "        if (old_buckets[i]) {\n"
    buf = buf + "            uint32_t idx = old_hashes[i] & mask;\n"
    buf = buf + "            while (new_buckets[idx]) idx = (idx + 1) & mask;\n"
    buf = buf + "            new_buckets[idx] = old_buckets[i];\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            new_hashes[idx] = old_hashes[i];\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    free(old_buckets);\n"
    buf = buf + "    free(old_hashes);\n"
    buf = buf + "    __hexa_intern.buckets = new_buckets;\n"
    buf = buf + "    __hexa_intern.hashes  = new_hashes;\n"
    buf = buf + "    __hexa_intern.cap = new_cap;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "//  String length-header (perf-31, 2026-04-26)\n"
    buf = buf + "//\n"
    buf = buf + "//  Embed an 8-byte size_t length immediately before each owned\n"
    buf = buf + "//  string buffer. HX_STR(v) still returns the data pointer (no\n"
    buf = buf + "//  caller change), but HX_STRLEN(v) reads the cached length in\n"
    buf = buf + "//  O(1) — eliminating the per-call strlen() that turned every\n"
    buf = buf + "//  hot string fn (substring, char_at, replace, …) into O(n²).\n"
    buf = buf + "//\n"
    buf = buf + "//  Magic-byte guard lets HX_STRLEN safely fall back to strlen()\n"
    buf = buf + "//  when called with a pointer that did NOT come from a header\n"
    buf = buf + "//  allocator (e.g. arena-allocated map keys at runtime.c:1364\n"
    buf = buf + "//  which can't reasonably grow a header — those are short type\n"
    buf = buf + "//  names where strlen is cheap anyway).\n"
    buf = buf + "// ═══════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "#define HEXA_STR_MAGIC ((uint64_t)0xC0DECAFE0F58A7E1ULL)\n"
    buf = buf + "\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    uint64_t magic;\n"
    buf = buf + "    size_t   len;\n"
    buf = buf + "    char     data[];   // C99 flexible array — actual bytes follow\n"
    buf = buf + "} HexaStrHdr;\n"
    buf = buf + "\n"
    buf = buf + "// Allocate a string buffer with embedded length header. Returns the\n"
    buf = buf + "// data pointer (caller stores in HexaVal.s); the header sits at\n"
    buf = buf + "// (data - sizeof(HexaStrHdr)). data[len] is pre-NUL-terminated so\n"
    buf = buf + "// callers can fill bytes 0..len-1 and immediately treat as C string.\n"
    buf = buf + "static inline char* hexa_strbuf_alloc(size_t len) {\n"
    buf = buf + "    _hx_mem_tick();\n"
    buf = buf + "    HexaStrHdr* hdr = (HexaStrHdr*)malloc(sizeof(HexaStrHdr) + len + 1);\n"
    buf = buf + "    if (!hdr) return NULL;\n"
    buf = buf + "    hdr->magic = HEXA_STR_MAGIC;\n"
    buf = buf + "    hdr->len = len;\n"
    buf = buf + "    hdr->data[len] = '\\0';\n"
    buf = buf + "    return hdr->data;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Allocate header buffer + memcpy from src. src may be NULL when len==0.\n"
    buf = buf + "static inline char* hexa_strbuf_dup_n(const char* src, size_t len) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    char* buf = hexa_strbuf_alloc(len);\n"
    buf = buf + "    if (!buf) return NULL;\n"
    buf = buf + "    if (len > 0 && src) hxlcl_memcpy(buf, src, len);\n"
    buf = buf + "    return buf;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// O(1) length read. Reads 16 bytes before s and matches HEXA_STR_MAGIC\n"
    buf = buf + "// to confirm header presence; falls back to strlen otherwise. Reading\n"
    buf = buf + "// before s is safe in practice because every code path that puts a\n"
    buf = buf + "// pointer into HexaVal.s uses heap-allocated memory (malloc / strdup /\n"
    buf = buf + "// arena_alloc), all of which sit on heap chunks with ≥16 bytes of\n"
    buf = buf + "// allocator metadata in front, so the load won't fault.\n"
    buf = buf + "static inline size_t hexa_strlen_v_inline(const char* s) {\n"
    buf = buf + "    if (!s) return 0;\n"
    buf = buf + "    // sizeof(struct{...; char data[]}) == offset of flex array → header size\n"
    buf = buf + "    HexaStrHdr* hdr = (HexaStrHdr*)((const char*)s - sizeof(HexaStrHdr));\n"
    buf = buf + "    if (hdr->magic == HEXA_STR_MAGIC) return hdr->len;\n"
    buf = buf + "    return hxlcl_strlen(s);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "#define HX_STRLEN(v)    hexa_strlen_v_inline(HX_STR(v))\n"
    buf = buf + "#define HX_STRLEN_S(s)  hexa_strlen_v_inline(s)\n"
    buf = buf + "\n"
    buf = buf + "// Intern a string: returns a canonical pointer.\n"
    buf = buf + "// If the string is already interned, returns the existing pointer.\n"
    buf = buf + "// Only interns strings shorter than INTERN_MAX_LEN.\n"
    buf = buf + "// The returned pointer is owned by the intern table -- callers must NOT free it.\n"
    buf = buf + "static const char* hexa_intern(const char* s) {\n"
    buf = buf + "    if (HX_UNLIKELY(!s)) return s;\n"
    buf = buf + "    size_t slen = hxlcl_strlen(s);\n"
    buf = buf + "    if (HX_UNLIKELY(slen >= INTERN_MAX_LEN)) {\n"
    buf = buf + "        // H03 Q9: count strings rejected by length cap.\n"
    buf = buf + "        if (_hx_stats_on()) _hx_stats_intern_skip++;\n"
    buf = buf + "        return NULL;  // too long, skip interning\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Lazy init — fires once per process; everything after is hot-path.\n"
    buf = buf + "    if (HX_UNLIKELY(!__hexa_intern.buckets)) hexa_intern_init();\n"
    buf = buf + "\n"
    buf = buf + "    uint32_t h = hexa_fnv1a(s, slen);\n"
    buf = buf + "    uint32_t mask = (uint32_t)(__hexa_intern.cap - 1);\n"
    buf = buf + "    uint32_t idx = h & mask;\n"
    buf = buf + "\n"
    buf = buf + "    // A17: most workloads exhibit a heavy hit-rate (>90%) on hexa_intern —\n"
    buf = buf + "    // self-hosting parser interns identifiers + keywords repeatedly. Hint\n"
    buf = buf + "    // the slot-occupied loop and the hash-equal+strcmp-hit branch as taken.\n"
    buf = buf + "    while (HX_LIKELY(__hexa_intern.buckets[idx] != NULL)) {\n"
    buf = buf + "        if (HX_LIKELY(__hexa_intern.hashes[idx] == h) &&\n"
    buf = buf + "            hxlcl_strcmp(__hexa_intern.buckets[idx], s) == 0) {\n"
    buf = buf + "            // H03 Q9: hit — table contained an equal canonical pointer.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            if (_hx_stats_on()) _hx_stats_intern_hit++;\n"
    buf = buf + "            return __hexa_intern.buckets[idx];  // already interned\n"
    buf = buf + "        }\n"
    buf = buf + "        idx = (idx + 1) & mask;\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Not found -- insert (header-allocated so HX_STRLEN works on interned strings)\n"
    buf = buf + "    // Grow path is rare (amortised O(log N) over program lifetime).\n"
    buf = buf + "    if (HX_UNLIKELY(__hexa_intern.count * 100 / __hexa_intern.cap >= INTERN_LOAD_MAX)) {\n"
    buf = buf + "        hexa_intern_grow();\n"
    buf = buf + "        if (_hx_stats_on()) _hx_stats_intern_grow++;\n"
    buf = buf + "        // Recompute slot after grow\n"
    buf = buf + "        mask = (uint32_t)(__hexa_intern.cap - 1);\n"
    buf = buf + "        idx = h & mask;\n"
    buf = buf + "        while (__hexa_intern.buckets[idx]) idx = (idx + 1) & mask;\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    char* dup = hexa_strbuf_dup_n(s, slen);\n"
    buf = buf + "    __hexa_intern.buckets[idx] = dup;\n"
    buf = buf + "    __hexa_intern.hashes[idx]  = h;\n"
    buf = buf + "    __hexa_intern.count++;\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_intern_miss++;\n"
    buf = buf + "    return dup;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Forward declarations for all runtime functions\n"
    buf = buf + "// S1-D3b-beta: struct tag renamed to HexaVal_ so typedef HexaVal can flip\n"
    buf = buf + "// to uint64_t (NaN-boxed) without touching field access patterns.\n"
    buf = buf + "typedef struct HexaVal_ HexaVal;\n"
