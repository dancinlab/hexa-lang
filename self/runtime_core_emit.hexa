    buf = buf + "// empty array, matching Rust semantics where `.last()` on an empty slice\n"
    buf = buf + "// returns None but hexa has no Option in prelude — explicit OOB is the\n"
    buf = buf + "// closest canonical signal.\n"
    buf = buf + "HexaVal hexa_array_last(HexaVal arr) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) {\n"
    buf = buf + "        char _buf[128];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"array.last(): container is not an array (tag=%d)\", (int)HX_TAG(arr));\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return hexa_void();\n"
    buf = buf + "    }\n"
    buf = buf + "    int n = HX_ARR_LEN(arr);\n"
    buf = buf + "    if (n == 0) {\n"
    buf = buf + "        hexa_throw(hexa_str(\"array.last(): empty array\"));\n"
    buf = buf + "        return hexa_void();\n"
    buf = buf + "    }\n"
    buf = buf + "    return HX_ARR_ITEMS(arr)[n - 1];\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ω-interp-2 forward decl: defined later but needed here as a setter side-effect.\n"
    buf = buf + "extern int __hexa_arena_slot_dirty;\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_array_set(HexaVal arr, int64_t idx, HexaVal val) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) {\n"
    buf = buf + "        char _buf[128];\n"
    buf = buf + "        // Strings hit this branch when the user writes `s[i] = v`. Emit a\n"
    buf = buf + "        // string-specific diagnostic instead of the generic \"container is\n"
    buf = buf + "        // not an array (tag=3)\" — hexa strings are immutable.\n"
    buf = buf + "        if (HX_IS_STR(arr)) {\n"
    buf = buf + "            snprintf(_buf, sizeof(_buf), \"s[%lld] = …: strings are immutable\", (long long)idx);\n"
    buf = buf + "        } else {\n"
    buf = buf + "            snprintf(_buf, sizeof(_buf), \"array_set[%lld]: container is not an array (tag=%d)\", (long long)idx, (int)HX_TAG(arr));\n"
    buf = buf + "        }\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        return arr;\n"
    buf = buf + "    }\n"
    buf = buf + "    int64_t _orig_idx_s = idx;\n"
    buf = buf + "    // PROBE r15-D12: negative array index = OOB (Go/Rust canonical), not wrap.\n"
    buf = buf + "    // Mirror of the get path above — `xs[-1] = v` panics.\n"
    buf = buf + "    if (idx < 0 || idx >= HX_ARR_LEN(arr)) {\n"
    buf = buf + "        char _buf[128];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"index %lld out of bounds (len %d)\", (long long)_orig_idx_s, HX_ARR_LEN(arr));\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return arr;\n"
    buf = buf + "    }\n"
    buf = buf + "    // In-place mutate (no copy — caller reassigns)\n"
    buf = buf + "    HX_ARR_ITEMS(arr)[idx] = val;\n"
    buf = buf + "    // ω-interp-2: SETTER for the per-frame \"dirty\" flag. Any direct write to\n"
    buf = buf + "    // a host-array element is the canonical \"slot may now contain arena Vals\"\n"
    buf = buf + "    // event — covers `array_store[idx] = items.push(item)` from\n"
    buf = buf + "    // array_push_inplace, plus map_store / struct_store assignments. Marking\n"
    buf = buf + "    // here is a single-store fast path with no branch on arr identity (the\n"
    buf = buf + "    // checker in hexa_val_heapify scopes the work to the actual store walked).\n"
    buf = buf + "    __hexa_arena_slot_dirty = 1;\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// bt 55 — in-place truncate. Used by env_pop_scope to avoid the\n"
    buf = buf + "// `new_vars.push` rebuild loop which realloc-leaks the old backing buffer\n"
    buf = buf + "// every scope pop. Retains capacity for amortized re-growth.\n"
    buf = buf + "// No free of arr.items here (HexaVal entries may still be shared); we only\n"
    buf = buf + "// shrink the logical length. Safe because the slots beyond `new_len` become\n"
    buf = buf + "// unreachable through this handle.\n"
    buf = buf + "HexaVal hexa_array_truncate(HexaVal arr, HexaVal new_len_v) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return arr;\n"
    buf = buf + "    int64_t new_len = HX_IS_INT(new_len_v) ? HX_INT(new_len_v) : (int64_t)HX_INT(new_len_v);\n"
    buf = buf + "    if (new_len < 0) new_len = 0;\n"
    buf = buf + "    if (new_len > HX_ARR_LEN(arr)) new_len = HX_ARR_LEN(arr);\n"
    buf = buf + "    HX_SET_ARR_LEN(arr, (int)new_len);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Step-4 cycle 99 port — hexa_len polymorphic dispatch ports to\n"
    buf = buf + "// hexa-source rt_len (stdlib/runtime/numeric.hexa). rt_len body delegates\n"
    buf = buf + "// to `byte_len(v) as int`, which lowers to `hexa_to_int(hexa_byte_len(v))`\n"
    buf = buf + "// — a parallel C symbol with identical 3-way tag dispatch (str/arr/map →\n"
    buf = buf + "// length, else 0). C body retained under #ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "// for the runtime.c standalone link (smoke prog.hexa, where the macro is\n"
    buf = buf + "// not defined).\n"
    buf = buf + "//\n"
    buf = buf + "// Recursion safety: rt_len's body uses `byte_len` (→ hexa_byte_len), not\n"
    buf = buf + "// `len` (→ hexa_len). hexa_byte_len does not call hexa_len. hexa_to_int\n"
    buf = buf + "// does not call hexa_len. Verified safe.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "extern HexaVal rt_len(HexaVal v);\n"
    buf = buf + "int hexa_len(HexaVal v) {\n"
    buf = buf + "    return (int)HX_INT(rt_len(v));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "int hexa_len(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_STR(v)) return (int)HX_STRLEN(v);\n"
    buf = buf + "    if (HX_IS_ARRAY(v)) return HX_ARR_LEN(v);\n"
    buf = buf + "    if (HX_IS_MAP(v)) return HX_MAP_LEN(v);\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ── Map operations (Optimization #10: hash table) ───────\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-L: forward decls — Val arena lives below the str_concat arena\n"
    buf = buf + "// (shared block chain via hexa_arena_alloc) but maintains its own scope-mark\n"
    buf = buf + "// stack so str-concat marks aren't perturbed by Val scope push/pop.\n"
    buf = buf + "void* hexa_arena_alloc(size_t n);  // defined below; forward decl for hmap_alloc_ex.\n"
    buf = buf + "static int hexa_val_arena_on(void);\n"
    buf = buf + "static void* hexa_val_arena_calloc(size_t n);\n"
    buf = buf + "extern int __hexa_val_mark_top;  // defined later; gate guard for module-init Vals.\n"
    buf = buf + "extern int __hexa_val_force_heap; // T33-fix-2\n"
    buf = buf + "\n"
    buf = buf + "// Allocate a new HexaMapTable with given hash-table capacity.\n"
    buf = buf + "// rt 32-L: when from_arena=1, use bump-arena instead of malloc/calloc. Caller\n"
    buf = buf + "// guarantees the table will be heapified (via hexa_val_heapify) before the\n"
    buf = buf + "// arena rewind point catches up. When from_arena=0, behavior is unchanged.\n"
    buf = buf + "static HexaMapTable* hmap_alloc_ex(int ht_cap, int from_arena) {\n"
    buf = buf + "    HexaMapTable* t;\n"
    buf = buf + "    int order_init = ht_cap < 8 ? 8 : ht_cap;\n"
    buf = buf + "    if (from_arena) {\n"
    buf = buf + "        // All four allocations satisfied from the same bump frontier — single\n"
    buf = buf + "        // O(1) reset frees them in bulk. Zeroing via memset is required to\n"
    buf = buf + "        // satisfy the pre-existing calloc guarantees that hmap_find / load-\n"
    buf = buf + "        // factor checks rely on (slots[].key == NULL means empty).\n"
    buf = buf + "        t = (HexaMapTable*)hexa_val_arena_calloc(sizeof(HexaMapTable));\n"
    buf = buf + "        t->slots = (HexaMapSlot*)hexa_val_arena_calloc(ht_cap * sizeof(HexaMapSlot));\n"
    buf = buf + "        t->vals  = (HexaVal*)hexa_val_arena_calloc(ht_cap * sizeof(HexaVal));\n"
    buf = buf + "        t->order_keys = (char**)hexa_val_arena_calloc(sizeof(char*) * order_init);\n"
    buf = buf + "        t->order_vals = (HexaVal*)hexa_val_arena_calloc(sizeof(HexaVal) * order_init);\n"
    buf = buf + "        t->from_arena = 1;\n"
    buf = buf + "    } else {\n"
    buf = buf + "        t = (HexaMapTable*)calloc(1, sizeof(HexaMapTable));\n"
    buf = buf + "        t->slots = (HexaMapSlot*)calloc(ht_cap, sizeof(HexaMapSlot));\n"
    buf = buf + "        t->vals  = (HexaVal*)calloc(ht_cap, sizeof(HexaVal));\n"
    buf = buf + "        t->order_keys = (char**)malloc(sizeof(char*) * order_init);\n"
    buf = buf + "        t->order_vals = (HexaVal*)malloc(sizeof(HexaVal) * order_init);\n"
    buf = buf + "        t->from_arena = 0;\n"
    buf = buf + "    }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    t->ht_cap = ht_cap;\n"
    buf = buf + "    t->order_cap = order_init;\n"
    buf = buf + "    t->len = 0;\n"
    buf = buf + "    return t;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Backward-compat wrapper — preserves the heap-only signature for callers that\n"
    buf = buf + "// must guarantee long-lived storage (env caches, fn body maps, etc.).\n"
    buf = buf + "static HexaMapTable* hmap_alloc(int ht_cap) {\n"
    buf = buf + "    return hmap_alloc_ex(ht_cap, 0);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Rehash the table to double its capacity.\n"
    buf = buf + "static void hmap_grow(HexaMapTable* t) {\n"
    buf = buf + "    int old_cap = t->ht_cap;\n"
    buf = buf + "    HexaMapSlot* old_slots = t->slots;\n"
    buf = buf + "    HexaVal* old_vals = t->vals;\n"
    buf = buf + "    int new_cap = old_cap * 2;\n"
    buf = buf + "    HexaMapSlot* new_slots = (HexaMapSlot*)calloc(new_cap, sizeof(HexaMapSlot));\n"
    buf = buf + "    HexaVal* new_vals = (HexaVal*)calloc(new_cap, sizeof(HexaVal));\n"
    buf = buf + "    uint32_t mask = (uint32_t)(new_cap - 1);\n"
    buf = buf + "    for (int i = 0; i < old_cap; i++) {\n"
    buf = buf + "        if (old_slots[i].key) {\n"
    buf = buf + "            uint32_t idx = old_slots[i].hash & mask;\n"
    buf = buf + "            while (new_slots[idx].key) idx = (idx + 1) & mask;\n"
    buf = buf + "            new_slots[idx] = old_slots[i];\n"
    buf = buf + "            new_vals[idx]  = old_vals[i];\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    // T33: do NOT free arena-allocated old buffers — free() on arena mem is UB.\n"
    buf = buf + "    // The arena will reclaim them on scope pop.\n"
    buf = buf + "    if (!t->from_arena) {\n"
    buf = buf + "        free(old_slots);\n"
    buf = buf + "        free(old_vals);\n"
    buf = buf + "    }\n"
    buf = buf + "    t->slots = new_slots;\n"
    buf = buf + "    t->vals  = new_vals;\n"
    buf = buf + "    t->ht_cap = new_cap;\n"
    buf = buf + "    // Mark table as heap-backed for future growth/free decisions — the slots/\n"
    buf = buf + "    // vals/order arrays may still be arena, but new_slots/new_vals here are\n"
    buf = buf + "    // heap, so subsequent free(t->slots) after arena pop would be safe. Keep\n"
    buf = buf + "    // from_arena unchanged since order_keys/order_vals still carry the\n"
    buf = buf + "    // original allocation site.\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Find slot index for key, or -1 if not found.\n"
    buf = buf + "int hmap_find(HexaMapTable* t, const char* key, uint32_t h) {\n"
    buf = buf + "    uint32_t mask = (uint32_t)(t->ht_cap - 1);\n"
    buf = buf + "    uint32_t idx = h & mask;\n"
    buf = buf + "    while (t->slots[idx].key) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        if (t->slots[idx].hash == h && hxlcl_strcmp(t->slots[idx].key, key) == 0)\n"
    buf = buf + "            return (int)idx;\n"
    buf = buf + "        idx = (idx + 1) & mask;\n"
    buf = buf + "    }\n"
    buf = buf + "    return -1;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "/* Step 3 cycle 107 - map basic-op opaque-pointer escape (RUNTIME.md\n"
    buf = buf + " * remaining #5 partial discharge: contains_key + keys + values + get-by-\n"
    buf = buf + " * cstr ported, set/remove remain CORE-final). The inline builtins\n"
    buf = buf + " * __map_has_cstr_v / __map_get_cstr_v / __map_order_key_at /\n"
    buf = buf + " * __map_order_val_at lower to direct accesses on HexaMapTable fields +\n"
    buf = buf + " * hmap_find / hexa_fnv1a_str (de-staticized above). No new runtime\n"
    buf = buf + " * symbol; helpers compose existing primitives.\n"
    buf = buf + " *\n"
    buf = buf + " * Placed in runtime_core.c (not runtime.h) so user-transpiled TUs which\n"
    buf = buf + " * sed-include runtime.c (build_aprime stage 3) see the symbols. The\n"
    buf = buf + " * codegen-inline emit in self/codegen.hexa fully expands the call\n"
    buf = buf + " * site to a direct invocation of these helpers; stale hexat binaries\n"
    buf = buf + " * emit hexa_call2(__map_has_cstr_v, m, k) which resolves via the\n"
    buf = buf + " * _Generic fn-ptr lane (HexaVal (*)(HexaVal, HexaVal)). */\n"
    buf = buf + "static inline HexaVal __map_has_cstr_v(HexaVal m, HexaVal key) {\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (!t) return hexa_bool(0);\n"
    buf = buf + "    const char* k = HX_STR(key);\n"
    buf = buf + "    if (!k) return hexa_bool(0);\n"
    buf = buf + "    return hexa_bool(hmap_find(t, k, hexa_fnv1a_str(k)) >= 0);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline HexaVal __map_get_cstr_v(HexaVal m, HexaVal key) {\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (!t) return hexa_void();\n"
    buf = buf + "    const char* k = HX_STR(key);\n"
    buf = buf + "    if (!k) return hexa_void();\n"
    buf = buf + "    int si = hmap_find(t, k, hexa_fnv1a_str(k));\n"
    buf = buf + "    if (si < 0) return hexa_void();\n"
    buf = buf + "    return t->vals[si];\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline HexaVal __map_order_key_at(HexaVal m, HexaVal i) {\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (!t) return hexa_void();\n"
    buf = buf + "    int idx = (int)HX_INT(i);\n"
    buf = buf + "    if (idx < 0 || idx >= t->len) return hexa_void();\n"
    buf = buf + "    return hexa_str(t->order_keys[idx]);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline HexaVal __map_order_val_at(HexaVal m, HexaVal i) {\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (!t) return hexa_void();\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    int idx = (int)HX_INT(i);\n"
    buf = buf + "    if (idx < 0 || idx >= t->len) return hexa_void();\n"
    buf = buf + "    return t->order_vals[idx];\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "/* RUNTIME.md step-3 cycle 108 — map set/remove ALIASING PORTS (잔여 #5\n"
    buf = buf + " * full surface closure 6/6). Honest @D g3 scope: the Robin Hood insert/\n"
    buf = buf + " * delete + key intern (hxlcl_strdup) + hmap_grow / order array realloc\n"
    buf = buf + " * + free logic stays in C as `hexa_map_set_impl` / `hexa_map_remove_impl`\n"
    buf = buf + " * (the renamed legacy bodies — irreducible allocator floor). The hexa-\n"
    buf = buf + " * source `rt_map_set` / `rt_map_remove` are passthroughs through the\n"
    buf = buf + " * opaque builtins below; they add NO new logic. Gain = surface\n"
    buf = buf + " * function dispatchable from hexa source + all 6 잔여 #5 ops now\n"
    buf = buf + " * have hexa-source presence; future surface refactor (e.g. instrumenta-\n"
    buf = buf + " * tion, alternate policy) becomes a hexa edit. NOT gained = C-floor\n"
    buf = buf + " * reduction or retirement % bump beyond +0.4% (2 surface fns flip,\n"
    buf = buf + " * impl unchanged).\n"
    buf = buf + " *\n"
    buf = buf + " * Static-inline lowering: codegen emits\n"
    buf = buf + " *   __map_set_cstr_v(m, k, v) → hexa_map_set_impl(<m>, HX_STR(<k>), <v>)\n"
    buf = buf + " *   __map_remove_cstr_v(m, k) → hexa_map_remove_impl(<m>, HX_STR(<k>))\n"
    buf = buf + " * Stale hexat binaries that don't yet inline the builtin take the\n"
    buf = buf + " * hexa_call2/3 _Generic fn-ptr lane through these helpers. */\n"
    buf = buf + "HexaVal hexa_map_set_impl(HexaVal m, const char* key, HexaVal val);\n"
    buf = buf + "HexaVal hexa_map_remove_impl(HexaVal m, const char* key);\n"
    buf = buf + "\n"
    buf = buf + "static inline HexaVal __map_set_cstr_v(HexaVal m, HexaVal key, HexaVal val) {\n"
    buf = buf + "    const char* k = HX_STR(key);\n"
    buf = buf + "    if (!k) return m;\n"
    buf = buf + "    return hexa_map_set_impl(m, k, val);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline HexaVal __map_remove_cstr_v(HexaVal m, HexaVal key) {\n"
    buf = buf + "    const char* k = HX_STR(key);\n"
    buf = buf + "    if (!k) return m;\n"
    buf = buf + "    return hexa_map_remove_impl(m, k);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_map_new() {\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_map_new++;\n"
    buf = buf + "    HexaVal v = {.tag=TAG_MAP};\n"
    buf = buf + "    HX_SET_MAP_PTR(v, (HexaMap*)calloc(1, sizeof(HexaMap)));\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-A: bulk struct constructor — collapses 1 map_new + N map_set into a\n"
    buf = buf + "// single pre-sized table allocation + tight insertion loop. Used by\n"
    buf = buf + "// gen2_struct_decl for `Val { ... }` and other struct literals. Avoids N\n"
    buf = buf + "// successive hexa_map_set calls (each with its own stats bump + load-factor\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// check). Key array is NOT freed; strings must be string literals (stable).\n"
    buf = buf + "HexaVal hexa_struct_pack_map(const char* type_name, int n,\n"
    buf = buf + "                             const char* const* keys, const HexaVal* vals) {\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_map_new++;\n"
    buf = buf + "    HexaVal v = {.tag=TAG_MAP};\n"
    buf = buf + "    HX_SET_MAP_PTR(v, (HexaMap*)calloc(1, sizeof(HexaMap)));\n"
    buf = buf + "    // Pre-size: (n+1) entries including __type__, target load < HMAP_LOAD_MAX/100.\n"
    buf = buf + "    // Solve for smallest power-of-2 cap where (n+1)*100/cap < HMAP_LOAD_MAX.\n"
    buf = buf + "    int need = (n + 1) * 100 / HMAP_LOAD_MAX + 1;\n"
    buf = buf + "    int cap = HMAP_INIT_CAP;\n"
    buf = buf + "    while (cap < need) cap <<= 1;\n"
    buf = buf + "    // rt 32-L: opt-in arena allocation for struct literals. Anonymous map\n"
    buf = buf + "    // literals (type_name == \"\" or NULL) are excluded — they often back\n"
    buf = buf + "    // long-lived data (config, AST nodes, registries) where the heapify\n"
    buf = buf + "    // discipline is not currently wired. Type_named struct literals are the\n"
    buf = buf + "    // hot fib path (every Val{...} in the interpreter) and the primary RSS\n"
    buf = buf + "    // contributor at K=30. The arena gate is HEXA_VAL_ARENA (separate from\n"
    buf = buf + "    // HEXA_STR_ARENA so the two can be tuned independently).\n"
    buf = buf + "    int from_arena = (type_name && type_name[0]) ?\n"
    buf = buf + "                     (hexa_val_arena_on() && __hexa_val_mark_top > 0) : 0;\n"
    buf = buf + "    HexaMapTable* t = hmap_alloc_ex(cap, from_arena);\n"
    buf = buf + "    HX_SET_MAP_TBL(v, t);\n"
    buf = buf + "    uint32_t mask = (uint32_t)(cap - 1);\n"
    buf = buf + "    // Insert __type__ first (skip for anonymous map literals where\n"
    buf = buf + "    // type_name is \"\" — they don't carry a __type__ field).\n"
    buf = buf + "    if (type_name && type_name[0]) {\n"
    buf = buf + "        uint32_t h = hexa_fnv1a_str(\"__type__\");\n"
    buf = buf + "        uint32_t idx = h & mask;\n"
    buf = buf + "        while (t->slots[idx].key) idx = (idx + 1) & mask;\n"
    buf = buf + "        // Keys/values strdup'd into heap regardless of from_arena: heapify()\n"
    buf = buf + "        // can shallow-share these strings (keys are usually literal-like and\n"
    buf = buf + "        // the arena would otherwise force per-string heap copies on every\n"
    buf = buf + "        // heapify call, defeating the win). The TAG_STR value `tv` payload is\n"
    buf = buf + "        // also strdup'd; for arena path we instead arena-alloc to keep the\n"
    buf = buf + "        // bulk-free property.\n"
    buf = buf + "        if (from_arena) {\n"
    buf = buf + "            char* kdup = (char*)hexa_arena_alloc(hxlcl_strlen(\"__type__\") + 1);\n"
    buf = buf + "            hxlcl_memcpy(kdup, \"__type__\", 9);\n"
    buf = buf + "            t->slots[idx].key = kdup;\n"
    buf = buf + "            // perf-31: even on the arena path, the VALUE string must use the\n"
    buf = buf + "            // heap header allocator — HX_STRLEN reads bytes [-16] before the\n"
    buf = buf + "            // data pointer, and arena memory has no allocator-metadata pad\n"
    buf = buf + "            // (could segfault at the start of a fresh arena block). Map keys\n"
    buf = buf + "            // stay in arena since they're never read via HX_STRLEN (slot.key\n"
    buf = buf + "            // is a raw char* used only for strcmp during lookup).\n"
    buf = buf + "            size_t tnl = hxlcl_strlen(type_name);\n"
    buf = buf + "            HexaVal tv = {.tag=TAG_STR, .s=hexa_strbuf_dup_n(type_name, tnl)};\n"
    buf = buf + "            t->slots[idx].hash = h;\n"
    buf = buf + "            t->slots[idx].order_idx = t->len;  // ROI-24\n"
    buf = buf + "            t->vals[idx] = tv;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            t->order_keys[t->len] = t->slots[idx].key;\n"
    buf = buf + "            t->order_vals[t->len] = tv;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            t->slots[idx].key = hxlcl_strdup(\"__type__\");\n"
    buf = buf + "            t->slots[idx].hash = h;\n"
    buf = buf + "            t->slots[idx].order_idx = t->len;  // ROI-24\n"
    buf = buf + "            // perf-31: header-alloc replaces strdup so HX_STRLEN is O(1).\n"
    buf = buf + "            size_t tnl = hxlcl_strlen(type_name);\n"
    buf = buf + "            HexaVal tv = {.tag=TAG_STR, .s=hexa_strbuf_dup_n(type_name, tnl)};\n"
    buf = buf + "            t->vals[idx] = tv;\n"
    buf = buf + "            t->order_keys[t->len] = t->slots[idx].key;\n"
    buf = buf + "            t->order_vals[t->len] = tv;\n"
    buf = buf + "        }\n"
    buf = buf + "        t->len++;\n"
    buf = buf + "    }\n"
    buf = buf + "    for (int i = 0; i < n; i++) {\n"
    buf = buf + "        const char* k = keys[i];\n"
    buf = buf + "        uint32_t h = hexa_fnv1a_str(k);\n"
    buf = buf + "        uint32_t idx = h & mask;\n"
    buf = buf + "        while (t->slots[idx].key) idx = (idx + 1) & mask;\n"
    buf = buf + "        if (from_arena) {\n"
    buf = buf + "            size_t kl = hxlcl_strlen(k);\n"
    buf = buf + "            char* kdup = (char*)hexa_arena_alloc(kl + 1);\n"
    buf = buf + "            hxlcl_memcpy(kdup, k, kl + 1);\n"
    buf = buf + "            t->slots[idx].key = kdup;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            t->slots[idx].key = hxlcl_strdup(k);\n"
    buf = buf + "        }\n"
    buf = buf + "        t->slots[idx].hash = h;\n"
    buf = buf + "        t->slots[idx].order_idx = t->len;  // ROI-24\n"
    buf = buf + "        // ROI #148: break caller→struct-field array aliasing. A struct\n"
    buf = buf + "        // literal's array fields must own a private backing buffer so\n"
    buf = buf + "        // that `.push` mutations on one instance cannot leak into a\n"
    buf = buf + "        // sibling struct built from the same source array.\n"
    buf = buf + "        // Type-named struct literals only — anonymous map literals\n"
    buf = buf + "        // (type_name==\"\") preserve raw-store semantics (map of scalars,\n"
    buf = buf + "        // no ownership contract).\n"
    buf = buf + "        HexaVal stored = vals[i];\n"
    buf = buf + "        if (type_name && type_name[0] && HX_IS_ARRAY(stored)) {\n"
    buf = buf + "            stored = hexa_array_shallow_clone(stored);\n"
    buf = buf + "        }\n"
    buf = buf + "        t->vals[idx] = stored;\n"
    buf = buf + "        t->order_keys[t->len] = t->slots[idx].key;\n"
    buf = buf + "        t->order_vals[t->len] = stored;\n"
    buf = buf + "        t->len++;\n"
    buf = buf + "    }\n"
    buf = buf + "    HX_SET_MAP_LEN(v, t->len);\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "/* RUNTIME.md step-3 cycle 108 — aliasing port. The body below is the\n"
    buf = buf + " * legacy hexa_map_set Robin Hood insert + intern + grow; renamed to\n"
    buf = buf + " * `_impl` so the hexa-source `rt_map_set` (which lowers to\n"
    buf = buf + " * __map_set_cstr_v → hexa_map_set_impl) can call it without recursing\n"
    buf = buf + " * through its own surface symbol. The `hexa_map_set` symbol now lives\n"
    buf = buf + " * further down as a thin dispatch wrapper that prefers `rt_map_set`\n"
    buf = buf + " * when HEXA_HAS_HEXA_RT_STDLIB is defined. */\n"
    buf = buf + "HexaVal hexa_map_set_impl(HexaVal m, const char* key, HexaVal val) {\n"
    buf = buf + "    // rt 32-G: route Val field mutation to flat struct.\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(m)) {\n"
    buf = buf + "        return hexa_valstruct_set_by_key(m, key, val);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_map_set++;\n"
    buf = buf + "    // Lazy-alloc table on first insert\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) {\n"
    buf = buf + "        HX_SET_MAP_TBL(m, hmap_alloc(HMAP_INIT_CAP));\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    uint32_t h = hexa_fnv1a_str(key);\n"
    buf = buf + "\n"
    buf = buf + "    // Check if key exists (O(1) average)\n"
    buf = buf + "    int si = hmap_find(t, key, h);\n"
    buf = buf + "    if (si >= 0) {\n"
    buf = buf + "        t->vals[si] = val;\n"
    buf = buf + "        // ROI-24: O(1) order-array update via cached order_idx\n"
    buf = buf + "        t->order_vals[t->slots[si].order_idx] = val;\n"
    buf = buf + "        return m;\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Grow hash table if needed\n"
    buf = buf + "    if (t->len * 100 / t->ht_cap >= HMAP_LOAD_MAX) {\n"
    buf = buf + "        hmap_grow(t);\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Insert into hash table\n"
    buf = buf + "    uint32_t mask = (uint32_t)(t->ht_cap - 1);\n"
    buf = buf + "    uint32_t idx = h & mask;\n"
    buf = buf + "    while (t->slots[idx].key) idx = (idx + 1) & mask;\n"
    buf = buf + "    t->slots[idx].key  = hxlcl_strdup(key);\n"
    buf = buf + "    t->slots[idx].hash = h;\n"
    buf = buf + "    t->slots[idx].order_idx = t->len;  // ROI-24: record order position\n"
    buf = buf + "    t->vals[idx] = val;\n"
    buf = buf + "\n"
    buf = buf + "    // Append to insertion-order arrays\n"
    buf = buf + "    if (t->len >= t->order_cap) {\n"
    buf = buf + "        int new_cap = t->order_cap * 2;\n"
    buf = buf + "        if (t->from_arena) {\n"
    buf = buf + "            // T33: arena-backed tables cannot realloc — promote order arrays\n"
    buf = buf + "            // to heap before grow. After promotion from_arena stays 1 for\n"
    buf = buf + "            // slots/vals (still arena) but the order_* arrays are now heap.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            // The final heapify() will malloc-copy everything anyway; this\n"
    buf = buf + "            // only handles the mid-scope growth case.\n"
    buf = buf + "            char** new_keys = (char**)malloc(sizeof(char*) * new_cap);\n"
    buf = buf + "            HexaVal* new_vals = (HexaVal*)malloc(sizeof(HexaVal) * new_cap);\n"
    buf = buf + "            if (!new_keys || !new_vals) { fprintf(stderr, \"OOM in map_set grow\\n\"); exit(1); }\n"
    buf = buf + "            hxlcl_memcpy(new_keys, t->order_keys, sizeof(char*) * t->len);\n"
    buf = buf + "            hxlcl_memcpy(new_vals, t->order_vals, sizeof(HexaVal) * t->len);\n"
    buf = buf + "            t->order_keys = new_keys;\n"
    buf = buf + "            t->order_vals = new_vals;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            t->order_keys = (char**)realloc(t->order_keys, sizeof(char*) * new_cap);\n"
    buf = buf + "            t->order_vals = (HexaVal*)realloc(t->order_vals, sizeof(HexaVal) * new_cap);\n"
    buf = buf + "        }\n"
    buf = buf + "        t->order_cap = new_cap;\n"
    buf = buf + "    }\n"
    buf = buf + "    t->order_keys[t->len] = t->slots[idx].key;  // shared pointer, not a copy\n"
    buf = buf + "    t->order_vals[t->len] = val;\n"
    buf = buf + "    t->len++;\n"
    buf = buf + "    HX_SET_MAP_LEN(m, t->len);\n"
    buf = buf + "    return m;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// RUNTIME.md step-3 cycle 108 — map set aliasing port (잔여 #5 100%\n"
    buf = buf + "// surface closure 6/6). Honest @D g3 scope: rt_map_set is a passthrough\n"
    buf = buf + "// to __map_set_cstr_v which inlines to hexa_map_set_impl above. The\n"
    buf = buf + "// allocator/Robin Hood logic remains in C; only the surface dispatch\n"
    buf = buf + "// moves through hexa source. VALSTRUCT routing is delegated to the\n"
    buf = buf + "// impl (it already short-circuits at its head). Stale-binary lane:\n"
    buf = buf + "// new opaque builtin `__map_set_cstr_v` lowers inline; legacy hexat\n"
    buf = buf + "// emitted hexa_call3 takes the static-inline shim through the _Generic\n"
    buf = buf + "// fn-ptr lane (HexaVal (*)(HexaVal, HexaVal, HexaVal)).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_set(HexaVal m, HexaVal key, HexaVal val);\n"
    buf = buf + "HexaVal hexa_map_set(HexaVal m, const char* key, HexaVal val) {\n"
    buf = buf + "    // Keep VALSTRUCT routing on the C side so the hexa-source rt_map_set\n"
    buf = buf + "    // never needs to express flat-struct field mutation (it can't — the\n"
    buf = buf + "    // valstruct path edits a non-HexaMap shape).\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(m)) {\n"
    buf = buf + "        return hexa_valstruct_set_by_key(m, key, val);\n"
    buf = buf + "    }\n"
    buf = buf + "    return rt_map_set(m, hexa_str(key), val);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_set(HexaVal m, const char* key, HexaVal val) {\n"
    buf = buf + "    return hexa_map_set_impl(m, key, val);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n"
    buf = buf + "// dispatch the hash-lookup branch to rt_map_get_v when hexa-source\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// stdlib is present. VALSTRUCT routing + miss-diagnostic stays C-side\n"
    buf = buf + "// (cycle-38 pattern: HexaVal-typed surface, C handles tag-dispatch +\n"
    buf = buf + "// fprintf). rt_map_get_v returns void on miss; C wrapper detects\n"
    buf = buf + "// TAG_VOID and emits the diagnostic (matches the legacy semantic\n"
    buf = buf + "// exactly).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_get_v(HexaVal m, HexaVal key);\n"
    buf = buf + "HexaVal hexa_map_get(HexaVal m, const char* key) {\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(m)) {\n"
    buf = buf + "        return hexa_valstruct_get_by_key(m, key);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) {\n"
    buf = buf + "        fprintf(stderr, \"map key '%s' not found\\n\", key);\n"
    buf = buf + "        return hexa_void();\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal v = rt_map_get_v(m, hexa_str(key));\n"
    buf = buf + "    if (HX_TAG(v) == TAG_VOID) {\n"
    buf = buf + "        fprintf(stderr, \"map key '%s' not found\\n\", key);\n"
    buf = buf + "    }\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_get(HexaVal m, const char* key) {\n"
    buf = buf + "    // rt 32-G: route Val field access to flat struct accessor.\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(m)) {\n"
    buf = buf + "        return hexa_valstruct_get_by_key(m, key);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) {\n"
    buf = buf + "        fprintf(stderr, \"map key '%s' not found\\n\", key);\n"
    buf = buf + "        return hexa_void();\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    uint32_t h = hexa_fnv1a_str(key);\n"
    buf = buf + "    int si = hmap_find(t, key, h);\n"
    buf = buf + "    if (si >= 0) return t->vals[si];\n"
    buf = buf + "    fprintf(stderr, \"map key '%s' not found\\n\", key);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ── rt#37: Inline cache for field access ─────────────────\n"
    buf = buf + "// Each call site of `obj.field` gets a static HexaIC slot. On hit, we skip\n"
    buf = buf + "// the strcmp-chain and return m.map.vals[ic->idx] directly. On miss we fall\n"
    buf = buf + "// back to hexa_map_get and repopulate. Shape check uses (keys_ptr, len) —\n"
    buf = buf + "// a struct constructor inserts keys in a fixed order, so once its (keys, len)\n"
    buf = buf + "// is stable, idx is valid for every subsequent access.\n"
    buf = buf + "//\n"
    buf = buf + "// Invalidation: if keys pointer or len differ, we treat it as a miss. That\n"
    buf = buf + "// covers (a) a different struct instance reused through the same call site\n"
    buf = buf + "// and (b) a struct mutated via hexa_map_set (which may realloc the keys\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// array). A monomorphic call site converges to ~100% hit rate after 1 call.\n"
    buf = buf + "//\n"
    buf = buf + "// Gate: HEXA_IC_STATS=1 dumps per-process hit/miss totals at exit.\n"
    buf = buf + "\n"
    buf = buf + "/* PHASE 1.2.B (2026-05-15): hits + stats_enabled de-staticized for cross-TU\n"
    buf = buf + " * use by the hexa_map_get_ic macro emitted into runtime.h. misses stays\n"
    buf = buf + " * static (only read inside this TU's hexa_ic_dump_stats). */\n"
    buf = buf + "uint64_t g_hexa_ic_hits   = 0;\n"
    buf = buf + "static uint64_t g_hexa_ic_misses = 0;\n"
    buf = buf + "int      g_hexa_ic_stats_enabled   = -1; // -1=unchecked, 0=off, 1=on\n"
    buf = buf + "static int      g_hexa_ic_stats_installed = 0;\n"
    buf = buf + "\n"
    buf = buf + "static void hexa_ic_dump_stats(void) {\n"
    buf = buf + "    uint64_t total = g_hexa_ic_hits + g_hexa_ic_misses;\n"
    buf = buf + "    double rate = total ? (100.0 * (double)g_hexa_ic_hits / (double)total) : 0.0;\n"
    buf = buf + "    fprintf(stderr,\n"
    buf = buf + "        \"[rt#37 IC] hits=%llu misses=%llu total=%llu hit_rate=%.2f%%\\n\",\n"
    buf = buf + "        (unsigned long long)g_hexa_ic_hits,\n"
    buf = buf + "        (unsigned long long)g_hexa_ic_misses,\n"
    buf = buf + "        (unsigned long long)total,\n"
    buf = buf + "        rate);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static inline int hexa_ic_stats_on(void) {\n"
    buf = buf + "    if (g_hexa_ic_stats_enabled < 0) {\n"
    buf = buf + "        const char* on = hxlcl_getenv(\"HEXA_IC_STATS\");\n"
    buf = buf + "        g_hexa_ic_stats_enabled = (on && on[0] != '0' && on[0] != '\\0') ? 1 : 0;\n"
    buf = buf + "        if (g_hexa_ic_stats_enabled && !g_hexa_ic_stats_installed) {\n"
    buf = buf + "            g_hexa_ic_stats_installed = 1;\n"
    buf = buf + "            hxlcl_atexit(hexa_ic_dump_stats);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return g_hexa_ic_stats_enabled;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Slow path: full scan + update cache. Kept out-of-line to shrink the inline\n"
    buf = buf + "// hot path macro footprint. Stats bump lives here so hits stay counter-free\n"
    buf = buf + "// when HEXA_IC_STATS is unset.\n"
    buf = buf + "// rt#32-N build-fix: rt#37 referenced m.map.{keys,vals} which were removed by\n"
    buf = buf + "// rt#32-G when map storage moved to HexaMapTable. Redirect through .tbl.\n"
    buf = buf + "/* PHASE 1.2.B (2026-05-15): de-staticized. Slow-path fallback for the\n"
    buf = buf + " * hexa_map_get_ic hot-path macro emitted into runtime.h — user.c TUs link\n"
    buf = buf + " * against this. */\n"
    buf = buf + "/* PROBE r14: Range repr accessors. Defined later in runtime.c (after the\n"
    buf = buf + " * textual #include of this file); forward-declared so the array-receiver\n"
    buf = buf + " * fallback below resolves at compile time. */\n"
    buf = buf + "HexaVal hexa_range_field(HexaVal v, const char* key);\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_map_get_ic_slow(HexaVal m, const char* key, HexaIC* ic) {\n"
    buf = buf + "    if (hexa_ic_stats_on()) { ic->misses++; g_hexa_ic_misses++; }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    if (HX_IS_MAP(m) && HX_MAP_TBL(m)) {\n"
    buf = buf + "        HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "        // ROI-43: O(1) avg via hmap_find instead of O(n) linear scan.\n"
    buf = buf + "        uint32_t h = hexa_fnv1a_str(key);\n"
    buf = buf + "        int si = hmap_find(t, key, h);\n"
    buf = buf + "        if (si >= 0) {\n"
    buf = buf + "            int oi = t->slots[si].order_idx;  // ROI-24 cached order index\n"
    buf = buf + "            ic->keys_ptr = (void*)t->order_keys;\n"
    buf = buf + "            ic->len      = t->len;\n"
    buf = buf + "            ic->idx      = oi;\n"
    buf = buf + "            return t->order_vals[oi];\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    // PROBE r14: Range repr — `.start` / `.end` / `.len` field access on a\n"
    buf = buf + "    // materialized range value (an int array, see hexa_range_array). Map\n"
    buf = buf + "    // receivers never reach here for these keys (handled above), so this\n"
    buf = buf + "    // only fires for array receivers, recovering the range bounds that were\n"
    buf = buf + "    // previously lost (\"map key 'start' not found\" → void). Non-range arrays\n"
    buf = buf + "    // gain harmless `.len`/`.start`/`.end` field accessors as a side effect.\n"
    buf = buf + "    if (HX_IS_ARRAY(m) &&\n"
    buf = buf + "        (strcmp(key, \"start\") == 0 || strcmp(key, \"end\") == 0 || strcmp(key, \"len\") == 0)) {\n"
    buf = buf + "        return hexa_range_field(m, key);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_map_get(m, key);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Hot path as a MACRO so the fast path avoids the 32-byte HexaVal call ABI\n"
    buf = buf + "// altogether. We evaluate `m` exactly once via __ic_m to be safe with side\n"
    buf = buf + "// effects, then:\n"
    buf = buf + "//   - if (m.map.keys == ic->keys_ptr && m.map.len == ic->len) -> return cached\n"
    buf = buf + "//   - else                                                   -> slow fallback\n"
    buf = buf + "// The stat bump on the hot path is compiled out when HEXA_IC_STATS is unset\n"
    buf = buf + "// because g_hexa_ic_stats_enabled flips to 0 on first slow path miss.\n"
    buf = buf + "// rt#32-N build-fix: m.map.{keys,vals} -> m.map.tbl->{order_keys,order_vals}\n"
    buf = buf + "#define hexa_map_get_ic(M, KEY, IC) \\\n"
    buf = buf + "    ({ HexaVal __ic_m = (M); HexaIC* __ic = (IC); \\\n"
    buf = buf + "       (HX_MAP_TBL(__ic_m) \\\n"
    buf = buf + "        && (void*)HX_MAP_TBL(__ic_m)->order_keys == __ic->keys_ptr \\\n"
    buf = buf + "        && HX_MAP_TBL(__ic_m)->len == __ic->len \\\n"
    buf = buf + "        && __ic->idx < __ic->len) \\\n"
    buf = buf + "           ? (g_hexa_ic_stats_enabled > 0 \\\n"
    buf = buf + "              ? (__ic->hits++, g_hexa_ic_hits++, HX_MAP_TBL(__ic_m)->order_vals[__ic->idx]) \\\n"
    buf = buf + "              : HX_MAP_TBL(__ic_m)->order_vals[__ic->idx]) \\\n"
    buf = buf + "           : hexa_map_get_ic_slow(__ic_m, (KEY), __ic); })\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n"
    buf = buf + "// dispatch to rt_map_keys when hexa-source stdlib is present. C body\n"
    buf = buf + "// retained for runtime.c standalone link.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "extern HexaVal rt_map_keys(HexaVal m);\n"
    buf = buf + "HexaVal hexa_map_keys(HexaVal m) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_array_new();\n"
    buf = buf + "    return rt_map_keys(m);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_keys(HexaVal m) {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return arr;\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    arr = hexa_array_reserve(arr, t->len);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_str(t->order_keys[i]));\n"
    buf = buf + "    }\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n"
    buf = buf + "// dispatch to rt_map_values when hexa-source stdlib is present.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_values(HexaVal m);\n"
    buf = buf + "HexaVal hexa_map_values(HexaVal m) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_array_new();\n"
    buf = buf + "    return rt_map_values(m);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_values(HexaVal m) {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return arr;\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    arr = hexa_array_reserve(arr, t->len);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        arr = hexa_array_push(arr, t->order_vals[i]);\n"
    buf = buf + "    }\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n"
    buf = buf + "// dispatch to rt_map_contains_key_b when hexa-source stdlib is present.\n"
    buf = buf + "// C wrapper handles the const char* -> HexaVal string boxing so the hexa\n"
    buf = buf + "// port can stay HexaVal-typed end-to-end.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "// rt_ port returns HexaVal (bool tag wrapper); hexa_truthy unwraps to int\n"
    buf = buf + "// (cycle-54 int-return bridge pattern).\n"
    buf = buf + "extern HexaVal rt_map_contains_key_b(HexaVal m, HexaVal key);\n"
    buf = buf + "int hexa_map_contains_key(HexaVal m, const char* key) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return 0;\n"
    buf = buf + "    return hexa_truthy(rt_map_contains_key_b(m, hexa_str(key)));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "int hexa_map_contains_key(HexaVal m, const char* key) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return 0;\n"
    buf = buf + "    uint32_t h = hexa_fnv1a_str(key);\n"
    buf = buf + "    return hmap_find(HX_MAP_TBL(m), key, h) >= 0;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// entries: flat array of [key, value] pairs. Keys come out as strings\n"
    buf = buf + "// (HexaMap stores keys as char*). Matches interpreter semantics at\n"
    buf = buf + "// self/hexa_full.hexa:15558-15568.\n"
    buf = buf + "// Step-3 cycle 38 port — dispatch to rt_map_entries when hexa-source\n"
    buf = buf + "// stdlib is present. C body retained for runtime.c standalone link.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_entries(HexaVal m);\n"
    buf = buf + "HexaVal hexa_map_entries(HexaVal m) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_array_new();\n"
    buf = buf + "    return rt_map_entries(m);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_entries(HexaVal m) {\n"
    buf = buf + "    HexaVal out = hexa_array_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return out;\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        HexaVal pair = hexa_array_new();\n"
    buf = buf + "        pair = hexa_array_push(pair, hexa_str(t->order_keys[i]));\n"
    buf = buf + "        pair = hexa_array_push(pair, t->order_vals[i]);\n"
    buf = buf + "        out = hexa_array_push(out, pair);\n"
    buf = buf + "    }\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// to_array: same shape as entries() — keeps names consistent with\n"
    buf = buf + "// interpreter dispatch (self/hexa_full.hexa:15611-15620).\n"
    buf = buf + "// Step-3 cycle 38 — falls through to hexa_map_entries which itself\n"
    buf = buf + "// dispatches; no separate rt_ wiring needed.\n"
    buf = buf + "HexaVal hexa_map_to_array(HexaVal m) {\n"
    buf = buf + "    return hexa_map_entries(m);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// merge: overlay other's entries onto self. Other wins on key collision.\n"
    buf = buf + "// Matches interpreter at self/hexa_full.hexa:15570-15583. Non-map `other`\n"
    buf = buf + "// returns self unchanged.\n"
    buf = buf + "// Step-3 cycle 38 port — map_merge dispatch to hexa-source rt_map_merge.\n"
    buf = buf + "// The hexa body iterates b.keys() (array of strings) and calls b.get(k) /\n"
    buf = buf + "// out.set(k, v); codegen lowers those to hexa_map_get/set with\n"
    buf = buf + "// hexa_to_cstring(key), so the const-char* signature blocker is bypassed\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// without a HexaVal-keyed C wrapper. C body retained for runtime.c\n"
    buf = buf + "// standalone link (smoke test path doesn't define HEXA_HAS_HEXA_RT_STDLIB).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_merge(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_map_merge(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (!HX_MAP_TBL(a)) return a;\n"
    buf = buf + "    if (!HX_MAP_TBL(b)) return a;\n"
    buf = buf + "    return rt_map_merge(a, b);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_merge(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (!HX_MAP_TBL(a)) return a;\n"
    buf = buf + "    if (!HX_MAP_TBL(b)) return a;\n"
    buf = buf + "    HexaVal out = a;\n"
    buf = buf + "    HexaMapTable* tb = HX_MAP_TBL(b);\n"
    buf = buf + "    for (int i = 0; i < tb->len; i++) {\n"
    buf = buf + "        out = hexa_map_set(out, tb->order_keys[i], tb->order_vals[i]);\n"
    buf = buf + "    }\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-4 cycle 95 ports — map_values + filter_keys via hexa source.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_map_values(HexaVal m, HexaVal fn, HexaVal empty);\n"
    buf = buf + "extern HexaVal rt_map_filter_keys(HexaVal m, HexaVal fn, HexaVal empty);\n"
    buf = buf + "HexaVal hexa_map_map_values(HexaVal m, HexaVal fn) {\n"
    buf = buf + "    HexaVal empty = hexa_map_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return empty;\n"
    buf = buf + "    return rt_map_map_values(m, fn, empty);\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_map_filter_keys(HexaVal m, HexaVal fn) {\n"
    buf = buf + "    HexaVal empty = hexa_map_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return empty;\n"
    buf = buf + "    return rt_map_filter_keys(m, fn, empty);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_map_values(HexaVal m, HexaVal fn) {\n"
    buf = buf + "    HexaVal out = hexa_map_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return out;\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        HexaVal new_val = hexa_call1(fn, t->order_vals[i]);\n"
    buf = buf + "        out = hexa_map_set(out, t->order_keys[i], new_val);\n"
    buf = buf + "    }\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_map_filter_keys(HexaVal m, HexaVal fn) {\n"
    buf = buf + "    HexaVal out = hexa_map_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return out;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        HexaVal key_val = hexa_str(t->order_keys[i]);\n"
    buf = buf + "        if (hexa_truthy(hexa_call1(fn, key_val))) {\n"
    buf = buf + "            out = hexa_map_set(out, t->order_keys[i], t->order_vals[i]);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// invert: swap k<->v. Values get stringified via hexa_to_string to serve\n"
    buf = buf + "// as new keys (HexaMap keys are char*); original keys become string vals.\n"
    buf = buf + "// Matches interpreter at self/hexa_full.hexa:15641-15645.\n"
    buf = buf + "// Step-4 cycle 93 port — invert via hexa source. C wrapper supplies the\n"
    buf = buf + "// empty starting map (avoids bare hexa_map_new() call0 trap).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_invert(HexaVal m, HexaVal empty);\n"
    buf = buf + "HexaVal hexa_map_invert(HexaVal m) {\n"
    buf = buf + "    HexaVal empty = hexa_map_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return empty;\n"
    buf = buf + "    return rt_map_invert(m, empty);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_invert(HexaVal m) {\n"
    buf = buf + "    HexaVal out = hexa_map_new();\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return out;\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        const char* new_key = hexa_str_as_ptr(hexa_to_string(t->order_vals[i]));\n"
    buf = buf + "        if (!new_key) continue;\n"
    buf = buf + "        out = hexa_map_set(out, new_key, hexa_str(t->order_keys[i]));\n"
    buf = buf + "    }\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// from_array: build a map from an array of [k, v] pair arrays. Receiver\n"
    buf = buf + "// is ignored (called as-method on an empty map per interpreter dispatch).\n"
    buf = buf + "// Malformed pairs (non-array or <2 elements) are skipped. Keys are\n"
    buf = buf + "// stringified. Matches interpreter at self/hexa_full.hexa:15622-15640.\n"
    buf = buf + "// Step-4 cycle 93 port — from_array via hexa source.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_from_array(HexaVal arr, HexaVal empty);\n"
    buf = buf + "HexaVal hexa_map_from_array(HexaVal self_map, HexaVal arr) {\n"
    buf = buf + "    (void)self_map;\n"
    buf = buf + "    HexaVal empty = hexa_map_new();\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return empty;\n"
    buf = buf + "    return rt_map_from_array(arr, empty);\n"
    buf = buf + "}\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_from_array(HexaVal self_map, HexaVal arr) {\n"
    buf = buf + "    (void)self_map;\n"
    buf = buf + "    HexaVal out = hexa_map_new();\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return out;\n"
    buf = buf + "    int n = HX_ARR_LEN(arr);\n"
    buf = buf + "    for (int i = 0; i < n; i++) {\n"
    buf = buf + "        HexaVal pair = HX_ARR_ITEMS(arr)[i];\n"
    buf = buf + "        if (!HX_IS_ARRAY(pair) || HX_ARR_LEN(pair) < 2) continue;\n"
    buf = buf + "        HexaVal k = HX_ARR_ITEMS(pair)[0];\n"
    buf = buf + "        HexaVal v = HX_ARR_ITEMS(pair)[1];\n"
    buf = buf + "        const char* k_str = hexa_str_as_ptr(hexa_to_string(k));\n"
    buf = buf + "        if (!k_str) continue;\n"
    buf = buf + "        out = hexa_map_set(out, k_str, v);\n"
    buf = buf + "    }\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// count(pred): pred is 2-arg fn(key, value) returning truthy for hits.\n"
    buf = buf + "// No-pred variant (arg is void sentinel) returns total entry count.\n"
    buf = buf + "// Keys are exposed to the predicate as TAG_STR per interpreter semantics.\n"
    buf = buf + "// Matches interpreter at self/hexa_full.hexa:15689-15704.\n"
    buf = buf + "// Step-4 cycle 94 port — count/any/all with predicate callback via\n"
    buf = buf + "// hexa source (cycle-63 callback POC). C wrapper handles HX_MAP_TBL\n"
    buf = buf + "// guard + void-pred fallback (no-pred returns total count / false / true).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_count_pred(HexaVal m, HexaVal pred);\n"
    buf = buf + "extern HexaVal rt_map_any_pred_b(HexaVal m, HexaVal pred);\n"
    buf = buf + "extern HexaVal rt_map_all_pred_b(HexaVal m, HexaVal pred);\n"
    buf = buf + "HexaVal hexa_map_count(HexaVal m, HexaVal pred) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_int(0);\n"
    buf = buf + "    if (HX_IS_VOID(pred)) return hexa_int(HX_MAP_TBL(m)->len);\n"
    buf = buf + "    return hexa_int(HX_INT(rt_map_count_pred(m, pred)));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_map_any(HexaVal m, HexaVal pred) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_bool(0);\n"
    buf = buf + "    if (HX_IS_VOID(pred)) return hexa_bool(0);\n"
    buf = buf + "    return hexa_bool(hexa_truthy(rt_map_any_pred_b(m, pred)));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_map_all(HexaVal m, HexaVal pred) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_bool(1);\n"
    buf = buf + "    if (HX_IS_VOID(pred)) return hexa_bool(1);\n"
    buf = buf + "    return hexa_bool(hexa_truthy(rt_map_all_pred_b(m, pred)));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_count(HexaVal m, HexaVal pred) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_int(0);\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (HX_IS_VOID(pred)) return hexa_int(t->len);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    int cnt = 0;\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        HexaVal key_val = hexa_str(t->order_keys[i]);\n"
    buf = buf + "        HexaVal r = hexa_call2(pred, key_val, t->order_vals[i]);\n"
    buf = buf + "        if (hexa_truthy(r)) cnt++;\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_int(cnt);\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_map_any(HexaVal m, HexaVal pred) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_bool(0);\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (HX_IS_VOID(pred)) return hexa_bool(0);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        HexaVal key_val = hexa_str(t->order_keys[i]);\n"
    buf = buf + "        HexaVal r = hexa_call2(pred, key_val, t->order_vals[i]);\n"
    buf = buf + "        if (hexa_truthy(r)) return hexa_bool(1);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_bool(0);\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_map_all(HexaVal m, HexaVal pred) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return hexa_bool(1);\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    if (HX_IS_VOID(pred)) return hexa_bool(1);\n"
    buf = buf + "    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "        HexaVal key_val = hexa_str(t->order_keys[i]);\n"
    buf = buf + "        HexaVal r = hexa_call2(pred, key_val, t->order_vals[i]);\n"
    buf = buf + "        if (!hexa_truthy(r)) return hexa_bool(0);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_bool(1);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "/* RUNTIME.md step-3 cycle 108 — aliasing port. Robin Hood deletion +\n"
    buf = buf + " * free + order-array compact stays in C (irreducible allocator floor).\n"
    buf = buf + " * Renamed from hexa_map_remove so the hexa-source rt_map_remove can\n"
    buf = buf + " * call this without recursing through its own surface symbol. */\n"
    buf = buf + "HexaVal hexa_map_remove_impl(HexaVal m, const char* key) {\n"
    buf = buf + "    if (!HX_MAP_TBL(m)) return m;\n"
    buf = buf + "    HexaMapTable* t = HX_MAP_TBL(m);\n"
    buf = buf + "    uint32_t h = hexa_fnv1a_str(key);\n"
    buf = buf + "    int si = hmap_find(t, key, h);\n"
    buf = buf + "    if (si < 0) return m;\n"
    buf = buf + "\n"
    buf = buf + "    // ROI-24: O(1) locate in order array via cached order_idx, then shift\n"
    buf = buf + "    int oi = t->slots[si].order_idx;\n"
    buf = buf + "    for (int j = oi; j < t->len - 1; j++) {\n"
    buf = buf + "        t->order_keys[j] = t->order_keys[j+1];\n"
    buf = buf + "        t->order_vals[j] = t->order_vals[j+1];\n"
    buf = buf + "    }\n"
    buf = buf + "    // Fix order_idx for all hash-table slots whose order position shifted\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    for (int j = 0; j < t->ht_cap; j++) {\n"
    buf = buf + "        if (t->slots[j].key && t->slots[j].order_idx > oi) {\n"
    buf = buf + "            t->slots[j].order_idx--;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Remove from hash table: mark slot empty and re-insert displaced entries\n"
    buf = buf + "    free(t->slots[si].key);\n"
    buf = buf + "    t->slots[si].key = NULL;\n"
    buf = buf + "    t->slots[si].hash = 0;\n"
    buf = buf + "    // Robin Hood deletion: re-probe subsequent slots\n"
    buf = buf + "    uint32_t mask = (uint32_t)(t->ht_cap - 1);\n"
    buf = buf + "    uint32_t ci = ((uint32_t)si + 1) & mask;\n"
    buf = buf + "    while (t->slots[ci].key) {\n"
    buf = buf + "        // Remove and re-insert this entry\n"
    buf = buf + "        HexaMapSlot saved_slot = t->slots[ci];\n"
    buf = buf + "        HexaVal saved_val = t->vals[ci];\n"
    buf = buf + "        t->slots[ci].key = NULL;\n"
    buf = buf + "        t->slots[ci].hash = 0;\n"
    buf = buf + "        uint32_t ri = saved_slot.hash & mask;\n"
    buf = buf + "        while (t->slots[ri].key) ri = (ri + 1) & mask;\n"
    buf = buf + "        t->slots[ri] = saved_slot;  // ROI-24: order_idx carried in struct copy\n"
    buf = buf + "        t->vals[ri] = saved_val;\n"
    buf = buf + "        ci = (ci + 1) & mask;\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    t->len--;\n"
    buf = buf + "    HX_SET_MAP_LEN(m, t->len);\n"
    buf = buf + "    return m;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// RUNTIME.md step-3 cycle 108 — map remove aliasing port (잔여 #5 100%\n"
    buf = buf + "// surface closure 6/6). Honest @D g3 scope: rt_map_remove is a\n"
    buf = buf + "// passthrough to __map_remove_cstr_v which inlines to hexa_map_remove_impl\n"
    buf = buf + "// above. No new logic added; the surface fn merely flips dispatch site.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_map_remove(HexaVal m, HexaVal key);\n"
    buf = buf + "HexaVal hexa_map_remove(HexaVal m, const char* key) {\n"
    buf = buf + "    return rt_map_remove(m, hexa_str(key));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_map_remove(HexaVal m, const char* key) {\n"
    buf = buf + "    return hexa_map_remove_impl(m, key);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Polymorphic index get: array[int] or map[string]\n"
    buf = buf + "HexaVal hexa_index_get(HexaVal container, HexaVal key) {\n"
    buf = buf + "    if (HX_IS_MAP(container) && HX_IS_STR(key)) {\n"
    buf = buf + "        return hexa_map_get(container, HX_STR(key));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    }\n"
    buf = buf + "    // PROBE r16 Q4: maps are fundamentally string→value (keys are interned\n"
    buf = buf + "    // c-strings). A non-string key on a map (e.g. `m[5]`) previously fell to the\n"
    buf = buf + "    // array path and aborted \"container is not an array (tag=6)\". Stringify the\n"
    buf = buf + "    // key consistently (mirrors hexa_index_set + the int-key map-literal codegen)\n"
    buf = buf + "    // so `m[5]` and `m[\"5\"]` agree. hexa_to_cstring returns a short-lived static\n"
    buf = buf + "    // buffer; hexa_map_get only reads it, so the lifetime is safe here.\n"
    buf = buf + "    if (HX_IS_MAP(container)) {\n"
    buf = buf + "        return hexa_map_get(container, hexa_to_cstring(key));\n"
    buf = buf + "    }\n"
    buf = buf + "    // 2026-04-17: unwrap interpreter Val wrapper (TAG_VALSTRUCT) so HX_INT\n"
    buf = buf + "    // doesn't read .vs as a pointer-as-int garbage index. Same root as the\n"
    buf = buf + "    // hexa_cmp_* fix — without this, val_int's `__VAL_INT_CACHE[n]` lookup\n"
    buf = buf + "    // OOB-aborted when n was a wrapped Val.\n"
    buf = buf + "    int64_t idx;\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(key) && HX_VS(key)) {\n"
    buf = buf + "        idx = (HX_VSF(key, tag_i) == TAG_INT)\n"
    buf = buf + "            ? HX_VSF(key, int_val)\n"
    buf = buf + "            : (int64_t)__hx_to_double(key);\n"
    buf = buf + "    } else {\n"
    buf = buf + "        idx = HX_INT(key);\n"
    buf = buf + "    }\n"
    buf = buf + "    // hxa-20260423-015: str[i] support. The AOT codegen lowers every\n"
    buf = buf + "    // IndexGet to hexa_index_get(), so without this branch a `path[i]`\n"
    buf = buf + "    // on a string (e.g. self/module_loader.hexa:ml_dirname) reached\n"
    buf = buf + "    // hexa_array_get() and aborted with \"array[N]: container is not\n"
    buf = buf + "    // an array (tag=3)\". The interp interpreter has its own string-\n"
    buf = buf + "    // index path; this mirrors it for the AOT path.\n"
    buf = buf + "    if (HX_IS_STR(container)) {\n"
    buf = buf + "        return hexa_str_char_at(container, hexa_int(idx));\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_array_get(container, idx);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// For-in dispatch: array -> element, map -> key as string.\n"
    buf = buf + "// Uses insertion-order arrays so maps iterate in insertion order (Python-style).\n"
    buf = buf + "HexaVal hexa_iter_get(HexaVal v, int64_t idx) {\n"
    buf = buf + "    if (HX_IS_MAP(v)) {\n"
    buf = buf + "        if (!HX_MAP_TBL(v) || idx < 0 || idx >= HX_MAP_LEN(v)) {\n"
    buf = buf + "            fprintf(stderr, \"map iter index %lld out of bounds (len %d)\\n\", (long long)idx, HX_MAP_LEN(v));\n"
    buf = buf + "            exit(1);\n"
    buf = buf + "        }\n"
    buf = buf + "        return hexa_str(HX_MAP_TBL(v)->order_keys[idx]);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_array_get(v, idx);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Polymorphic index set: array[int]=val or map[string]=val\n"
    buf = buf + "HexaVal hexa_index_set(HexaVal container, HexaVal key, HexaVal val) {\n"
    buf = buf + "    if (HX_IS_MAP(container) && HX_IS_STR(key)) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        return hexa_map_set(container, HX_STR(key), val);\n"
    buf = buf + "    }\n"
    buf = buf + "    // PROBE r16 Q4: a non-string key on a map (e.g. `m[5] = 100`) previously\n"
    buf = buf + "    // fell to the array path and aborted \"container is not an array (tag=6)\".\n"
    buf = buf + "    // Stringify the key (mirrors hexa_index_get + the int-key map-literal codegen)\n"
    buf = buf + "    // so `m[5]=v` and `m[\"5\"]` agree. hexa_map_set_impl strdup's the key, so the\n"
    buf = buf + "    // short-lived hexa_to_cstring static buffer is safe.\n"
    buf = buf + "    if (HX_IS_MAP(container)) {\n"
    buf = buf + "        return hexa_map_set(container, hexa_to_cstring(key), val);\n"
    buf = buf + "    }\n"
    buf = buf + "    // 2026-04-17: unwrap VALSTRUCT same as hexa_index_get — without this,\n"
    buf = buf + "    // HX_INT reads raw .vs pointer as index → \"index 105553... out of bounds\"\n"
    buf = buf + "    int64_t idx;\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(key) && HX_VS(key)) {\n"
    buf = buf + "        idx = (HX_VSF(key, tag_i) == TAG_INT)\n"
    buf = buf + "            ? HX_VSF(key, int_val)\n"
    buf = buf + "            : (int64_t)__hx_to_double(key);\n"
    buf = buf + "    } else {\n"
    buf = buf + "        idx = HX_INT(key);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_array_set(container, idx, val);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Silent type check for struct method dispatch (codegen ImplBlock support).\n"
    buf = buf + "// Returns 1 if v is a TAG_MAP carrying a \"__type__\" field equal to type_name,\n"
    buf = buf + "// or TAG_VALSTRUCT (always type \"Val\" — rt 32-G flat struct).\n"
    buf = buf + "// Uses hash lookup instead of linear scan.\n"
    buf = buf + "int hexa_is_type(HexaVal v, const char* type_name) {\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v)) {\n"
    buf = buf + "        return type_name && hxlcl_strcmp(type_name, \"Val\") == 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!HX_IS_MAP(v) || !HX_MAP_TBL(v)) return 0;\n"
    buf = buf + "    uint32_t h = hexa_fnv1a_str(\"__type__\");\n"
    buf = buf + "    int si = hmap_find(HX_MAP_TBL(v), \"__type__\", h);\n"
    buf = buf + "    if (si < 0) return 0;\n"
    buf = buf + "    HexaVal t = HX_MAP_TBL(v)->vals[si];\n"
    buf = buf + "    return HX_IS_STR(t) && HX_STR(t) && hxlcl_strcmp(HX_STR(t), type_name) == 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────────────────\n"
    buf = buf + "// RFC-022 §4.2 — `await x` runtime helper (G2 codegen integration).\n"
    buf = buf + "//\n"
    buf = buf + "// Mirrors the interpreter's Await branch at self/hexa_full.hexa:8048-8057:\n"
    buf = buf + "//\n"
    buf = buf + "//     if v.tag == TAG_STRUCT && v.struct_name == \"Future\" {\n"
    buf = buf + "//         let fields = get_struct_fields(v)\n"
    buf = buf + "//         if type_of(fields) == \"map\" { return map_get(fields, \"value\") }\n"
    buf = buf + "//     }\n"
    buf = buf + "//     return v\n"
    buf = buf + "//\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// Native runtime represents user structs as TAG_MAP carrying a \"__type__\"\n"
    buf = buf + "// field (see hexa_struct_pack_map / hexa_is_type above). So the equivalent\n"
    buf = buf + "// of \"v.struct_name == \"Future\"\" is hexa_is_type(v, \"Future\"). Once we\n"
    buf = buf + "// confirm that shape we extract the \"value\" field via hexa_map_get; if\n"
    buf = buf + "// the field is missing or void/null, fall back to identity (matches\n"
    buf = buf + "// interp's stage-1 \"already-resolved\" optimisation).\n"
    buf = buf + "//\n"
    buf = buf + "// For non-Future or non-struct values, await is identity — every `await x`\n"
    buf = buf + "// in user code that lowers through native codegen wraps the inner expr in\n"
    buf = buf + "// a hexa_await_unwrap() call (see self/codegen.hexa gen2_expr Await\n"
    buf = buf + "// branch). This keeps the interp ↔ native parity contract from RFC-022 §3.1.\n"
    buf = buf + "HexaVal hexa_await_unwrap(HexaVal v) {\n"
    buf = buf + "    if (hexa_is_type(v, \"Future\")) {\n"
    buf = buf + "        if (HX_IS_MAP(v) && HX_MAP_TBL(v)) {\n"
    buf = buf + "            uint32_t h = hexa_fnv1a_str(\"value\");\n"
    buf = buf + "            int si = hmap_find(HX_MAP_TBL(v), \"value\", h);\n"
    buf = buf + "            if (si >= 0) {\n"
    buf = buf + "                HexaVal inner = HX_MAP_TBL(v)->vals[si];\n"
    buf = buf + "                if (inner.tag != TAG_VOID) {\n"
    buf = buf + "                    return inner;\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return v;  // identity for non-Future or already-resolved values\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ══════════════════════════════════════════════════════════════\n"
    buf = buf + "//  rt 32-G Phase 0: flat Val struct implementations\n"
    buf = buf + "// ══════════════════════════════════════════════════════════════\n"
    buf = buf + "\n"
    buf = buf + "// Redesigned constructor: every non-scalar arg is HexaVal-by-value so the\n"
    buf = buf + "// payload (string s, array, map, valstruct pointer) is preserved verbatim.\n"
    buf = buf + "// Scalars (tag/int/float/bool) still get coerced — those slots only ever\n"
    buf = buf + "// see TAG_INT / TAG_FLOAT / TAG_BOOL in the interpreter.\n"
    buf = buf + "HexaVal hexa_valstruct_new_v(\n"
    buf = buf + "    HexaVal tag_v, HexaVal int_v, HexaVal float_v, HexaVal bool_v,\n"
    buf = buf + "    HexaVal str_v, HexaVal char_v, HexaVal array_v,\n"
    buf = buf + "    HexaVal fn_name_v, HexaVal fn_params_v, HexaVal fn_body_v,\n"
    buf = buf + "    HexaVal struct_name_v, HexaVal struct_fields_v)\n"
    buf = buf + "{\n"
    buf = buf + "    // rt 32-L: the dominant fib RSS contributor — every Val{...} construction\n"
    buf = buf + "    // in the interpreter (val_int / val_float / val_str / val_void / and ALL\n"
    buf = buf + "    // user-side Val literals) ends up here. Arena-allocate when HEXA_VAL_ARENA\n"
    buf = buf + "    // is on AND at least one scope mark is live (i.e. we're inside a fn call).\n"
    buf = buf + "    // Module-init time allocations (cached singletons __VAL_VOID/__VAL_TRUE/\n"
    buf = buf + "    // __VAL_INT_CACHE etc.) go through the heap path so the first scope pop\n"
    buf = buf + "    // doesn't wipe them.\n"
    buf = buf + "    // T33-fix-2: DISABLE arena for ValStruct. fn_arena_return only heapifies\n"
    buf = buf + "    // the return value; globals (__VAL_INT_CACHE, env) escape unheapified.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    int from_arena = 0;\n"
    buf = buf + "    HexaValStruct* s;\n"
    buf = buf + "    if (from_arena) {\n"
    buf = buf + "        s = (HexaValStruct*)hexa_val_arena_calloc(sizeof(HexaValStruct));\n"
    buf = buf + "        s->from_arena = 1;\n"
    buf = buf + "    } else {\n"
    buf = buf + "        s = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n"
    buf = buf + "        if (!s) { fprintf(stderr, \"OOM in valstruct_new_v\\n\"); exit(1); }\n"
    buf = buf + "        s->from_arena = 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    s->tag_i     = HX_IS_INT(tag_v) ? HX_INT(tag_v) : 0;\n"
    buf = buf + "    s->int_val   = HX_IS_INT(int_v) ? HX_INT(int_v) : 0;\n"
    buf = buf + "    s->float_val = HX_IS_FLOAT(float_v) ? HX_FLOAT(float_v) :\n"
    buf = buf + "                   (HX_IS_INT(float_v) ? (double)HX_INT(float_v) : 0.0);\n"
    buf = buf + "    s->bool_val  = HX_IS_BOOL(bool_v) ? HX_BOOL(bool_v) :\n"
    buf = buf + "                   (HX_IS_INT(bool_v) ? (int)HX_INT(bool_v) : 0);\n"
    buf = buf + "    // Polymorphic slots — store HexaVal verbatim. Closures / AST bodies /\n"
    buf = buf + "    // struct field maps now survive Val construction intact.\n"
    buf = buf + "    s->str_val       = str_v;\n"
    buf = buf + "    s->char_val      = char_v;\n"
    buf = buf + "    s->array_val     = array_v;\n"
    buf = buf + "    s->fn_name       = fn_name_v;\n"
    buf = buf + "    s->fn_params     = fn_params_v;\n"
    buf = buf + "    s->fn_body       = fn_body_v;\n"
    buf = buf + "    s->struct_name   = struct_name_v;\n"
    buf = buf + "    s->struct_fields = struct_fields_v;\n"
    buf = buf + "    HexaVal v = {.tag = TAG_VALSTRUCT};\n"
    buf = buf + "    HX_SET_VS(v, s);\n"
    buf = buf + "    return v;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Helper: scalar accessors (tag/int/float/bool) still return primitive Vals.\n"
    buf = buf + "// NOTE: hexa_valstruct_int kept — referenced internally by rt_write_bytes_v helpers.\n"
    buf = buf + "HexaVal hexa_valstruct_int(HexaVal v) {\n"
    buf = buf + "    if (!HX_IS_VALSTRUCT(v) || !HX_VS(v)) return hexa_int(0);\n"
    buf = buf + "    return hexa_int(HX_VSF(v, int_val));\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Key-string dispatch — branches on key[0] to amortize strcmp.\n"
    buf = buf + "// Polymorphic fields return raw HexaVal so closure bodies (TAG_MAP) and\n"
    buf = buf + "// param lists (TAG_ARRAY) propagate through .fn_body / .fn_params reads.\n"
    buf = buf + "HexaVal hexa_valstruct_get_by_key(HexaVal v, const char* key) {\n"
    buf = buf + "    if (!HX_IS_VALSTRUCT(v) || !HX_VS(v)) {\n"
    buf = buf + "        fprintf(stderr, \"valstruct_get: not a TAG_VALSTRUCT\\n\");\n"
    buf = buf + "        return hexa_void();\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!key) return hexa_void();\n"
    buf = buf + "    switch (key[0]) {\n"
    buf = buf + "        case 't':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"tag\"))           return hexa_int(HX_VSF(v, tag_i));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            break;\n"
    buf = buf + "        case 'i':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"int_val\"))       return hexa_int(HX_VSF(v, int_val));\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'f':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"float_val\"))     return hexa_float(HX_VSF(v, float_val));\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"fn_name\"))       return HX_VSF(v, fn_name);\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"fn_params\"))     return HX_VSF(v, fn_params);\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"fn_body\"))       return HX_VSF(v, fn_body);\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'b':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"bool_val\"))      return hexa_bool(HX_VSF(v, bool_val));\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 's':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"str_val\"))       return HX_VSF(v, str_val);\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"struct_name\"))   return HX_VSF(v, struct_name);\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"struct_fields\")) return HX_VSF(v, struct_fields);\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'c':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"char_val\"))      return HX_VSF(v, char_val);\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'a':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"array_val\"))     return HX_VSF(v, array_val);\n"
    buf = buf + "            break;\n"
    buf = buf + "        case '_':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"__type__\"))      return hexa_str(\"Val\");\n"
    buf = buf + "            break;\n"
    buf = buf + "    }\n"
    buf = buf + "    fprintf(stderr, \"valstruct_get: unknown key '%s'\\n\", key);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Setter accepts any HexaVal payload — no TAG_STR gating, mirrors getter.\n"
    buf = buf + "// 2026-04-17: COW — __VAL_INT_CACHE/float/bool singletons share ValStruct\n"
    buf = buf + "// pointers. In-place mutation corrupts ALL users of that cache slot.\n"
    buf = buf + "// Always shallow-copy before writing; old ValStruct leaked (no refcounting).\n"
    buf = buf + "__attribute__((no_builtin(\"memcpy\")))\n"
    buf = buf + "HexaVal hexa_valstruct_set_by_key(HexaVal v, const char* key, HexaVal val) {\n"
    buf = buf + "    if (!HX_IS_VALSTRUCT(v) || !HX_VS(v)) {\n"
    buf = buf + "        fprintf(stderr, \"valstruct_set: not a TAG_VALSTRUCT\\n\");\n"
    buf = buf + "        return v;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!key) return v;\n"
    buf = buf + "    // COW: allocate a fresh copy\n"
    buf = buf + "    HexaValStruct* orig = HX_VS(v);\n"
    buf = buf + "    int use_arena = hexa_val_arena_on() && __hexa_val_mark_top > 0;\n"
    buf = buf + "    HexaValStruct* cow;\n"
    buf = buf + "    if (use_arena) {\n"
    buf = buf + "        cow = (HexaValStruct*)hexa_val_arena_calloc(sizeof(HexaValStruct));\n"
    buf = buf + "    } else {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        cow = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n"
    buf = buf + "        if (!cow) { fprintf(stderr, \"OOM in valstruct COW\\n\"); exit(1); }\n"
    buf = buf + "    }\n"
    buf = buf + "    // cycle 73: aggregate struct copy -> memcpy macro (-> hxlcl_memcpy)\n"
    buf = buf + "    memcpy(cow, orig, sizeof(HexaValStruct));\n"
    buf = buf + "    cow->from_arena = use_arena;\n"
    buf = buf + "    HexaVal out = v;\n"
    buf = buf + "    HX_SET_VS(out, cow);\n"
    buf = buf + "    switch (key[0]) {\n"
    buf = buf + "        case 't':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"tag\")) {\n"
    buf = buf + "                cow->tag_i = HX_IS_INT(val) ? HX_INT(val) : cow->tag_i;\n"
    buf = buf + "                return out;\n"
    buf = buf + "            }\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'i':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"int_val\")) {\n"
    buf = buf + "                cow->int_val = HX_IS_INT(val) ? HX_INT(val) : cow->int_val;\n"
    buf = buf + "                return out;\n"
    buf = buf + "            }\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'f':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"float_val\")) {\n"
    buf = buf + "                if (HX_IS_FLOAT(val)) cow->float_val = HX_FLOAT(val);\n"
    buf = buf + "                else if (HX_IS_INT(val)) cow->float_val = (double)HX_INT(val);\n"
    buf = buf + "                return out;\n"
    buf = buf + "            }\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"fn_name\"))   { cow->fn_name   = val; return out; }\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"fn_params\")) { cow->fn_params = val; return out; }\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"fn_body\"))   { cow->fn_body   = val; return out; }\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'b':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"bool_val\")) {\n"
    buf = buf + "                cow->bool_val = HX_IS_BOOL(val) ? HX_BOOL(val) :\n"
    buf = buf + "                                 (HX_IS_INT(val) ? (int)HX_INT(val) : cow->bool_val);\n"
    buf = buf + "                return out;\n"
    buf = buf + "            }\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 's':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"str_val\"))       { cow->str_val       = val; return out; }\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"struct_name\"))   { cow->struct_name   = val; return out; }\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"struct_fields\")) { cow->struct_fields = val; return out; }\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'c':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"char_val\"))  { cow->char_val  = val; return out; }\n"
    buf = buf + "            break;\n"
    buf = buf + "        case 'a':\n"
    buf = buf + "            if (!hxlcl_strcmp(key, \"array_val\")) { cow->array_val = val; return out; }\n"
    buf = buf + "            break;\n"
    buf = buf + "    }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    fprintf(stderr, \"valstruct_set: unknown key '%s'\\n\", key);\n"
    buf = buf + "    return out;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── rt 32-D: scope-local arena allocator ─────────────────\n"
    buf = buf + "// Problem: hexa_str_concat was doing `malloc(strlen(a)+strlen(b)+1)` per call\n"
    buf = buf + "// with no free (no GC). d64 ML micro calls it 10^5+ times → heap fragmentation\n"
    buf = buf + "// and accumulated RSS pressure even if individual strings are short-lived.\n"
    buf = buf + "//\n"
    buf = buf + "// Solution: linked-block bump allocator. Each hexa_arena_alloc() returns\n"
    buf = buf + "// memory from the current block; when full, we chain a new block (default 4MB,\n"
    buf = buf + "// or large enough for the request). `hexa_arena_mark()` + `hexa_arena_rewind()`\n"
    buf = buf + "// give O(1) bulk-free semantics so a caller (env_push_scope / env_pop_scope or\n"
    buf = buf + "// a future FFI binding) can dispose an entire scope's worth of string\n"
    buf = buf + "// temporaries in one pointer reset.\n"
    buf = buf + "//\n"
    buf = buf + "// M4 16GB optimization: HEXA_STR_ARENA=1 by default (was OFF). The fn-arena\n"
    buf = buf + "// scoping (STRUCTURAL-7: __hexa_fn_arena_enter/return) now handles escape\n"
    buf = buf + "// analysis for return values, and hexa_val_heapify handles arena strings in\n"
    buf = buf + "// maps/arrays/closures. Set HEXA_STR_ARENA=0 to disable if regressions appear.\n"
    buf = buf + "//\n"
    buf = buf + "// P2 scope (accepted partial): mark/rewind API + opt-in gate only. Hexa-level\n"
    buf = buf + "// wiring into env_push_scope/env_pop_scope is a follow-up (requires\n"
    buf = buf + "// hexa_full.hexa edits + interp rebuild, deferred per task description).\n"
    buf = buf + "\n"
    buf = buf + "#define HEXA_ARENA_BLOCK_SIZE (512 * 1024)   // 512KB default block (was 4MB: per-fn arena chains a fresh block; 4MB*N-fns OOM'd self-host obj-emit at ~5.8GB)\n"
    buf = buf + "\n"
    buf = buf + "typedef struct HexaArenaBlock {\n"
    buf = buf + "    struct HexaArenaBlock* next;   // NULL for last block\n"
    buf = buf + "    size_t cap;                    // usable bytes in data[]\n"
    buf = buf + "    size_t used;                   // bytes allocated from this block\n"
    buf = buf + "    char   data[];                 // flexible; cap bytes follow the header\n"
    buf = buf + "} HexaArenaBlock;\n"
    buf = buf + "\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    HexaArenaBlock* head;   // first block (never freed until hexa_arena_destroy)\n"
    buf = buf + "    HexaArenaBlock* cur;    // current bump block\n"
    buf = buf + "} HexaArena;\n"
    buf = buf + "\n"
    buf = buf + "// Arena mark: captures current allocation frontier for O(1) rewind.\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    HexaArenaBlock* block;\n"
    buf = buf + "    size_t used;\n"
    buf = buf + "} HexaArenaMark;\n"
    buf = buf + "\n"
    buf = buf + "static HexaArena __hexa_arena = {NULL, NULL};\n"
    buf = buf + "static int __hexa_arena_enabled = -1;     // lazy env probe\n"
    buf = buf + "\n"
    buf = buf + "// perf: arena address envelope — O(1) pointer-range reject for heapify.\n"
    buf = buf + "// Every bump-arena block's data[] lies within [__hx_arena_lo,__hx_arena_hi);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// a string pointer outside this range is provably heap-resident, so\n"
    buf = buf + "// hexa_val_heapify's TAG_STR path can return immediately instead of walking\n"
    buf = buf + "// the whole block chain per string. This collapses the O(n²) re-heapify of\n"
    buf = buf + "// already-heapified strings that 02af1622 worked around by default-disabling\n"
    buf = buf + "// the Val arena (HEXA_VAL_ARENA=0 → 10-16GB self-compile RSS). With the\n"
    buf = buf + "// envelope, the arena can stay ON → memory-bounded compiles.\n"
    buf = buf + "// Sentinel lo=MAX, hi=0 ⇒ empty range ⇒ every pointer rejected (correct: no\n"
    buf = buf + "// arena string exists yet). Monotonic: blocks are never unmapped.\n"
    buf = buf + "static uintptr_t __hx_arena_lo = (uintptr_t)-1;\n"
    buf = buf + "static uintptr_t __hx_arena_hi = 0;\n"
    buf = buf + "\n"
    buf = buf + "static int hexa_arena_on(void) {\n"
    buf = buf + "    if (__hexa_arena_enabled < 0) {\n"
    buf = buf + "        const char* e = hxlcl_getenv(\"HEXA_STR_ARENA\");\n"
    buf = buf + "        // M4: default ON (was OFF). Env var HEXA_STR_ARENA=0 disables.\n"
    buf = buf + "        __hexa_arena_enabled = (e && e[0] == '0') ? 0 : 1;\n"
    buf = buf + "    }\n"
    buf = buf + "    return __hexa_arena_enabled;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static HexaArenaBlock* hexa_arena_new_block(size_t min_cap) {\n"
    buf = buf + "    size_t cap = min_cap > HEXA_ARENA_BLOCK_SIZE ? min_cap : HEXA_ARENA_BLOCK_SIZE;\n"
    buf = buf + "    HexaArenaBlock* b = (HexaArenaBlock*)malloc(sizeof(HexaArenaBlock) + cap);\n"
    buf = buf + "    if (!b) return NULL;\n"
    buf = buf + "    b->next = NULL;\n"
    buf = buf + "    b->cap = cap;\n"
    buf = buf + "    b->used = 0;\n"
    buf = buf + "    // Extend the arena address envelope (see __hx_arena_lo/hi above).\n"
    buf = buf + "    {\n"
    buf = buf + "        uintptr_t base = (uintptr_t)b->data;\n"
    buf = buf + "        if (base < __hx_arena_lo)        __hx_arena_lo = base;\n"
    buf = buf + "        if (base + cap > __hx_arena_hi)  __hx_arena_hi = base + cap;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (_hx_stats_on()) {\n"
    buf = buf + "        _hx_stats_arena_blocks++;\n"
    buf = buf + "        _hx_stats_arena_bytes += (int64_t)(sizeof(HexaArenaBlock) + cap);\n"
    buf = buf + "        _hx_stats_sample_rss();\n"
    buf = buf + "    }\n"
    buf = buf + "    return b;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Allocate `n` bytes from the arena, 8-byte aligned. Returns NULL on OOM.\n"
    buf = buf + "// Public so future FFI consumers (env_push/pop_scope, parser temporaries)\n"
    buf = buf + "// can opt in. Thread-safety: single-threaded runtime; no locks needed.\n"
    buf = buf + "void* hexa_arena_alloc(size_t n) {\n"
    buf = buf + "    _hx_mem_tick();\n"
    buf = buf + "    // Round up to 8-byte alignment so we can safely return the pointer to\n"
    buf = buf + "    // any caller that may store it where alignment matters.\n"
    buf = buf + "    n = (n + 7u) & ~(size_t)7u;\n"
    buf = buf + "    if (n == 0) n = 8;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    if (!__hexa_arena.head) {\n"
    buf = buf + "        __hexa_arena.head = hexa_arena_new_block(n);\n"
    buf = buf + "        __hexa_arena.cur = __hexa_arena.head;\n"
    buf = buf + "        if (!__hexa_arena.head) return NULL;\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaArenaBlock* b = __hexa_arena.cur;\n"
    buf = buf + "    if (b->used + n > b->cap) {\n"
    buf = buf + "        // Walk forward first: rewind may have left empty tail blocks we can reuse.\n"
    buf = buf + "        HexaArenaBlock* nb = b->next;\n"
    buf = buf + "        while (nb && nb->cap < n) nb = nb->next;\n"
    buf = buf + "        if (!nb) {\n"
    buf = buf + "            nb = hexa_arena_new_block(n);\n"
    buf = buf + "            if (!nb) return NULL;\n"
    buf = buf + "            // Append to end of chain (preserve any rewound-empty tail blocks).\n"
    buf = buf + "            HexaArenaBlock* tail = __hexa_arena.cur;\n"
    buf = buf + "            int64_t chain_len = 1;\n"
    buf = buf + "            while (tail->next) { tail = tail->next; chain_len++; }\n"
    buf = buf + "            tail->next = nb;\n"
    buf = buf + "            chain_len++;  // include the just-appended block\n"
    buf = buf + "            if (_hx_stats_on()) {\n"
    buf = buf + "                if (chain_len > _hx_stats_arena_block_max_chain) {\n"
    buf = buf + "                    _hx_stats_arena_block_max_chain = chain_len;\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "        } else {\n"
    buf = buf + "            // Reused a previously rewound tail block (no malloc).\n"
    buf = buf + "            if (_hx_stats_on()) _hx_stats_arena_block_reuse++;\n"
    buf = buf + "        }\n"
    buf = buf + "        nb->used = 0;\n"
    buf = buf + "        __hexa_arena.cur = nb;\n"
    buf = buf + "        b = nb;\n"
    buf = buf + "    }\n"
    buf = buf + "    void* p = (void*)(b->data + b->used);\n"
    buf = buf + "    b->used += n;\n"
    buf = buf + "    if (_hx_stats_on()) {\n"
    buf = buf + "        _hx_stats_arena_alloc++;\n"
    buf = buf + "        // H03: log2 size bucket histogram (B17 slab decision input).\n"
    buf = buf + "        _hx_stats_size_hist[_hx_stats_size_bucket(n)]++;\n"
    buf = buf + "    }\n"
    buf = buf + "    return p;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Save current allocation frontier. Callers pair with hexa_arena_rewind.\n"
    buf = buf + "HexaArenaMark hexa_arena_mark(void) {\n"
    buf = buf + "    HexaArenaMark m;\n"
    buf = buf + "    m.block = __hexa_arena.cur;\n"
    buf = buf + "    m.used = __hexa_arena.cur ? __hexa_arena.cur->used : 0;\n"
    buf = buf + "    return m;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// Rewind arena to a previously captured mark. O(1). Blocks after `mark.block`\n"
    buf = buf + "// retain their backing memory (for reuse on next alloc) but are logically\n"
    buf = buf + "// empty.\n"
    buf = buf + "void hexa_arena_rewind(HexaArenaMark m) {\n"
    buf = buf + "    if (!m.block) {\n"
    buf = buf + "        if (__hexa_arena.head) {\n"
    buf = buf + "            __hexa_arena.head->used = 0;\n"
    buf = buf + "            __hexa_arena.cur = __hexa_arena.head;\n"
    buf = buf + "        }\n"
    buf = buf + "        return;\n"
    buf = buf + "    }\n"
    buf = buf + "    m.block->used = m.used;\n"
    buf = buf + "    // Mark all subsequent blocks as empty (they stay linked, reusable).\n"
    buf = buf + "    for (HexaArenaBlock* b = m.block->next; b; b = b->next) b->used = 0;\n"
    buf = buf + "    __hexa_arena.cur = m.block;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Rewind to beginning (keep blocks for reuse). Public for follow-up wiring.\n"
    buf = buf + "void hexa_arena_reset(void) {\n"
    buf = buf + "    if (!__hexa_arena.head) return;\n"
    buf = buf + "    for (HexaArenaBlock* b = __hexa_arena.head; b; b = b->next) b->used = 0;\n"
    buf = buf + "    __hexa_arena.cur = __hexa_arena.head;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── rt 32-L: Val arena scope stack + heapify ─────────────\n"
    buf = buf + "// Goal: bump-allocate short-lived `Val { ... }` struct literals (the dominant\n"
    buf = buf + "// HexaMapTable churn in fib-style recursive interpreted programs) and free\n"
    buf = buf + "// them in O(1) per scope pop. Reuses the existing block chain from rt 32-D\n"
    buf = buf + "// (hexa_arena_alloc) so str-concat and val-pack share a single bump frontier.\n"
    buf = buf + "//\n"
    buf = buf + "// Lifetime model: a per-scope mark stack mirrors env_push_scope / env_pop_scope\n"
    buf = buf + "// in hexa_full.hexa. On scope pop, any Val that survives the scope (the fn\n"
    buf = buf + "// return value, env_set targets in the parent scope, closure captures) MUST\n"
    buf = buf + "// be heapified BEFORE the rewind so its backing storage moves to malloc. We\n"
    buf = buf + "// expose mark/pop/heapify via the `env(...)` builtin path with reserved\n"
    buf = buf + "// `__HEXA_ARENA_*` keys — no transpiler edit needed.\n"
    buf = buf + "//\n"
    buf = buf + "// Gate: HEXA_VAL_ARENA env var. Default ON as of S7-B (2026-04-16) —\n"
    buf = buf + "// Phase A wired codegen __hexa_fn_arena_enter/return on all fn\n"
    buf = buf + "// boundaries; T33 corruption fixed; full regression suite verified.\n"
    buf = buf + "// Opt-out: HEXA_VAL_ARENA=0.\n"
    buf = buf + "//\n"
    buf = buf + "// T33 audit (2026-04-14): minimum repro still failing is array-passthrough\n"
    buf = buf + "// through two nested user fns — e.g.\n"
    buf = buf + "//     fn wrap(){return [\"a\",\"b\",\"c\"]}  fn touch(x){return x}\n"
    buf = buf + "//     fn inner(){let l=wrap(); let z=touch(l); println(type_of(l[0]))}\n"
    buf = buf + "// prints \"map\" under ARENA=1 (expect \"str\"). Symptom: array_store slot gets\n"
    buf = buf + "// reclaimed (array_store[K] = []) even though `l` and `z` still hold it —\n"
    buf = buf + "// consistent with a missed env_pop_scope decref path that operates on a\n"
    buf = buf + "// stale-tag HexaValStruct after arena rewind. Canary test: T33b-on in\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// tests/regression.hexa. Fix is blocked on the interp rebuild\n"
    buf = buf + "// regression (codegen FnDecl + forward-decl issue; see task tracker).\n"
    buf = buf + "// Keep default OFF until both the canary flips PASS and the module_loader\n"
    buf = buf + "// use-path smoke (see ml_resolve heapify discussion above) goes green.\n"
    buf = buf + "\n"
    buf = buf + "// Per-scope mark stack. Sized for deep recursion (fib(30) ≈ 30 frames; we\n"
    buf = buf + "// budget 64K to cover ML stack depths). Overflow falls back to silently\n"
    buf = buf + "// skipping the rewind for that scope (correctness preserved; arena just\n"
    buf = buf + "// grows until the outer scope pops and rewinds).\n"
    buf = buf + "#define HEXA_VAL_MARK_STACK_CAP 65536\n"
    buf = buf + "\n"
    buf = buf + "typedef struct {\n"
    buf = buf + "    HexaArenaBlock* block;\n"
    buf = buf + "    size_t used;\n"
    buf = buf + "} HexaValMark;\n"
    buf = buf + "\n"
    buf = buf + "static HexaValMark __hexa_val_marks[HEXA_VAL_MARK_STACK_CAP];\n"
    buf = buf + "int __hexa_val_mark_top = 0;            // count of pushed marks (extern-visible)\n"
    buf = buf + "int __hexa_val_force_heap = 0;          // when set, valstruct_new_v uses heap (codegen refs this)\n"
    buf = buf + "static int __hexa_val_arena_enabled = -1;  // -1 = lazy probe\n"
    buf = buf + "// F6 option A — A3 (PLAN-stage3-footprint-F6-optA.md). When non-zero,\n"
    buf = buf + "// __hexa_fn_arena_return routes its return through\n"
    buf = buf + "// hexa_val_arena_heapify_to_parent (region-promote into the caller's\n"
    buf = buf + "// arena frame) instead of hexa_val_heapify (escape to malloc). Default\n"
    buf = buf + "// 0 — behaviour byte-identical to pre-A3. Toggled at the streaming-loop\n"
    buf = buf + "// boundary via env(\"__HEXA_ARENA_RETURN_REGION_ON__\" / \"_OFF__\").\n"
    buf = buf + "static int __hexa_val_region_returns_enabled = 0;\n"
    buf = buf + "\n"
    buf = buf + "static int hexa_val_arena_on(void) {\n"
    buf = buf + "    if (__hexa_val_arena_enabled < 0) {\n"
    buf = buf + "        const char* e = hxlcl_getenv(\"HEXA_VAL_ARENA\");\n"
    buf = buf + "        // S7-B: default ON (2026-04-16). Phase A wired codegen\n"
    buf = buf + "        // __hexa_fn_arena_enter/return; T33 corruption fixed; full 236-example\n"
    buf = buf + "        // + 16-case dispatch regression suite passed 0-regression under ARENA=1.\n"
    buf = buf + "        // Opt-out: HEXA_VAL_ARENA=0.\n"
    buf = buf + "        if (!e || !e[0]) {\n"
    buf = buf + "            __hexa_val_arena_enabled = 1;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            __hexa_val_arena_enabled = (e[0] == '1' || e[0] == 'y' || e[0] == 'Y') ? 1 : 0;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return __hexa_val_arena_enabled;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Zeroed allocation from the bump arena. Falls back to calloc on OOM so the\n"
    buf = buf + "// caller never sees a NULL — keeps the hot path branch-free and correct.\n"
    buf = buf + "static void* hexa_val_arena_calloc(size_t n) {\n"
    buf = buf + "    void* p = hexa_arena_alloc(n);\n"
    buf = buf + "    if (!p) return calloc(1, n);\n"
    buf = buf + "    hxlcl_memset(p, 0, n);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    return p;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Forward decl — defined just below. Needed by scope_push for ω-interp-2 reset.\n"
    buf = buf + "extern int __hexa_arena_slot_dirty;\n"
    buf = buf + "\n"
    buf = buf + "// ω-interp-2: per-frame arena watermark. The walks in hexa_val_heapify are\n"
    buf = buf + "// only meaningful when an arena allocation has occurred inside the current\n"
    buf = buf + "// frame — otherwise every Val reachable from a slot is heap-resident and the\n"
    buf = buf + "// walk is wasted O(N) work. Snapshot at scope_push, compare at heapify.\n"
    buf = buf + "// Saturating: a single int \"active block changed since push\" + saved used.\n"
    buf = buf + "static HexaArenaBlock* __hexa_arena_frame_block = NULL;\n"
    buf = buf + "static size_t          __hexa_arena_frame_used  = 0;\n"
    buf = buf + "\n"
    buf = buf + "// Push current arena frontier as a scope mark. Called on env_push_scope via\n"
    buf = buf + "// the env(\"__HEXA_ARENA_PUSH__\") interception in hexa_env_var. Saturating: if\n"
    buf = buf + "// the mark stack is full, we silently no-op rather than crashing.\n"
    buf = buf + "static void hexa_val_arena_scope_push(void) {\n"
    buf = buf + "    if (__hexa_val_mark_top >= HEXA_VAL_MARK_STACK_CAP) return;\n"
    buf = buf + "    HexaValMark* m = &__hexa_val_marks[__hexa_val_mark_top++];\n"
    buf = buf + "    m->block = __hexa_arena.cur;\n"
    buf = buf + "    m->used = __hexa_arena.cur ? __hexa_arena.cur->used : 0;\n"
    buf = buf + "    // ω-interp-2 RESET: each new frame starts clean — no slot writes have\n"
    buf = buf + "    // occurred inside this frame yet. Subsequent hexa_array_set calls will\n"
    buf = buf + "    // re-set the flag if any write happens. Safe because heapify always runs\n"
    buf = buf + "    // BEFORE scope_pop (which is the consumer); a fresh push means we're\n"
    buf = buf + "    // entering a new lifetime window.\n"
    buf = buf + "    __hexa_arena_slot_dirty = 0;\n"
    buf = buf + "    __hexa_arena_frame_block = __hexa_arena.cur;\n"
    buf = buf + "    __hexa_arena_frame_used  = __hexa_arena.cur ? __hexa_arena.cur->used : 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ω-interp-2: precise check for \"no arena allocation occurred in current frame\".\n"
    buf = buf + "// True when active block + used pointer match the scope_push snapshot. False\n"
    buf = buf + "// when any arena_alloc has run (block advanced or used grew). When true, no\n"
    buf = buf + "// Val written into any slot inside this frame can be arena-resident, so the\n"
    buf = buf + "// heapify slot walks are bit-equivalent to no-ops and can be skipped.\n"
    buf = buf + "static int hexa_arena_frame_clean(void) {\n"
    buf = buf + "    return __hexa_arena.cur == __hexa_arena_frame_block\n"
    buf = buf + "        && (__hexa_arena.cur ? __hexa_arena.cur->used : 0) == __hexa_arena_frame_used;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ω-interp-1 (2026-04-26): per-frame \"dirty\" flag — gates the expensive T33\n"
    buf = buf + "// Fix 4 walk over array_store[idx] in hexa_val_heapify. Set whenever a push\n"
    buf = buf + "// (or any other path that may store an arena-allocated child Val into a\n"
    buf = buf + "// slot's items buffer) occurs inside an active arena frame. Cleared on\n"
    buf = buf + "// scope_push so each frame starts clean.\n"
    buf = buf + "//\n"
    buf = buf + "// Without this, every fn-arena return for a TAG_ARRAY interpreter Val\n"
    buf = buf + "// triggered the slot walk unconditionally, turning tight push loops\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// (anima_audio.hexa vocal_hexa() — 4800 .push() calls per call) into O(N²).\n"
    buf = buf + "// Repro: /tmp/test_push_n.hexa.\n"
    buf = buf + "//\n"
    buf = buf + "// ω-interp-2 (2026-04-26): WIRED.\n"
    buf = buf + "//   SETTER  : hexa_array_set (line ~1187) — every host-array element write\n"
    buf = buf + "//             marks dirty. Covers `array_store[idx] = items.push(item)` in\n"
    buf = buf + "//             array_push_inplace plus map_store / struct_store assignments.\n"
    buf = buf + "//   CHECKER : hexa_val_heapify TAG_VALSTRUCT path (line ~2515) — guards the\n"
    buf = buf + "//             array_store / map_store / struct_store walks. When clean we\n"
    buf = buf + "//             skip the walk entirely (the slot's contents have not been\n"
    buf = buf + "//             reseated since the last heapify). Flag is cleared after the\n"
    buf = buf + "//             walk so subsequent fn returns in the same frame stay cheap.\n"
    buf = buf + "//   RESET   : hexa_val_arena_scope_push (line ~2272) — new frame starts\n"
    buf = buf + "//             clean. Subsequent writes re-set as needed.\n"
    buf = buf + "// Removed `static` so it's externally visible to the setter sitting above\n"
    buf = buf + "// the original declaration in this TU; both references resolve to the same\n"
    buf = buf + "// global.\n"
    buf = buf + "int __hexa_arena_slot_dirty = 0;\n"
    buf = buf + "\n"
    buf = buf + "// Pop scope mark and rewind arena to it. Caller must have heapified any Val\n"
    buf = buf + "// that escapes the popped scope BEFORE calling this. If the stack is empty\n"
    buf = buf + "// (under-pop), no-op (defensive).\n"
    buf = buf + "//\n"
    buf = buf + "// rt 32-M: array arena currently fires only for slice_fast (lifetime-safe\n"
    buf = buf + "// by construction — the slice is consumed by call_user_fn's args parameter\n"
    buf = buf + "// and never stored persistently). Push-arena (first-push into arena) was\n"
    buf = buf + "// prototyped + reverted; see hexa_array_push comment for the Hexa\n"
    buf = buf + "// pass-by-value / snapshot-ABA blocker.\n"
    buf = buf + "static void hexa_val_arena_scope_pop(void) {\n"
    buf = buf + "    if (__hexa_val_mark_top <= 0) return;\n"
    buf = buf + "    HexaValMark m = __hexa_val_marks[--__hexa_val_mark_top];\n"
    buf = buf + "    if (!m.block) {\n"
    buf = buf + "        // Mark predates any allocation — full reset.\n"
    buf = buf + "        if (__hexa_arena.head) {\n"
    buf = buf + "            for (HexaArenaBlock* b = __hexa_arena.head; b; b = b->next) b->used = 0;\n"
    buf = buf + "            __hexa_arena.cur = __hexa_arena.head;\n"
    buf = buf + "        }\n"
    buf = buf + "        return;\n"
    buf = buf + "    }\n"
    buf = buf + "    m.block->used = m.used;\n"
    buf = buf + "    for (HexaArenaBlock* b = m.block->next; b; b = b->next) b->used = 0;\n"
    buf = buf + "    __hexa_arena.cur = m.block;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Forward decl — heapify itself is recursive over nested arena maps.\n"
    buf = buf + "HexaVal hexa_val_heapify(HexaVal v);\n"
    buf = buf + "\n"
    buf = buf + "// ω-interp-2: per-slot high-water mark for incremental heapify of array_store.\n"
    buf = buf + "// Tracks \"items[0..water[idx]] are known to be heap-resident\". Walks only\n"
    buf = buf + "// process items[water..len), then update water := len. This breaks the per-push\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// O(N) walk in tight push loops (`bytes.push(i)` × 4800) into amortized O(1).\n"
    buf = buf + "//\n"
    buf = buf + "// Storage: a parallel int array sized to the high-water-mark of any idx ever\n"
    buf = buf + "// touched. Grows on demand via realloc. Reset to 0 on entries we don't yet\n"
    buf = buf + "// have storage for (defensive — first walk reprocesses the full slot, which\n"
    buf = buf + "// is correct).\n"
    buf = buf + "static int*    __hexa_array_water     = NULL;\n"
    buf = buf + "static int64_t __hexa_array_water_cap = 0;\n"
    buf = buf + "\n"
    buf = buf + "static int hexa_array_water_get(int64_t idx) {\n"
    buf = buf + "    if (idx < 0 || idx >= __hexa_array_water_cap) return 0;\n"
    buf = buf + "    return __hexa_array_water[idx];\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "static void hexa_array_water_set(int64_t idx, int n) {\n"
    buf = buf + "    if (idx < 0) return;\n"
    buf = buf + "    if (idx >= __hexa_array_water_cap) {\n"
    buf = buf + "        int64_t new_cap = __hexa_array_water_cap > 0 ? __hexa_array_water_cap : 64;\n"
    buf = buf + "        while (new_cap <= idx) new_cap *= 2;\n"
    buf = buf + "        int* p = (int*)realloc(__hexa_array_water, sizeof(int) * (size_t)new_cap);\n"
    buf = buf + "        if (!p) return;  // OOM — defensive no-op (next walk will reprocess)\n"
    buf = buf + "        // Zero-init new tail.\n"
    buf = buf + "        for (int64_t k = __hexa_array_water_cap; k < new_cap; k++) p[k] = 0;\n"
    buf = buf + "        __hexa_array_water = p;\n"
    buf = buf + "        __hexa_array_water_cap = new_cap;\n"
    buf = buf + "    }\n"
    buf = buf + "    __hexa_array_water[idx] = n;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ω-interp-2: invalidate the water mark for a slot when it is overwritten by\n"
    buf = buf + "// a non-append (truncate, COW, slice). Forces the next walk to reprocess\n"
    buf = buf + "// items[0..len). For now we only call this from cow paths that explicitly\n"
    buf = buf + "// reseat array_store[idx] — for the dominant push path the water grows\n"
    buf = buf + "// monotonically with len.\n"
    buf = buf + "//\n"
    buf = buf + "// Note: the water mark for slot S is left stale when array_decref drops S\n"
    buf = buf + "// to 0; M4-fix freelist disabled means S won't be reused, so the stale\n"
    buf = buf + "// value is harmless.\n"
    buf = buf + "\n"
    buf = buf + "// T33 Fix 4: weak-link to the interpreter's array_store / map_store globals.\n"
    buf = buf + "// These are emitted as `HexaVal array_store;` / `HexaVal map_store;` by the\n"
    buf = buf + "// codegen for `pub let mut array_store = []` in interpreter.hexa. They are\n"
    buf = buf + "// host-array TAG_ARRAY HexaVals that hold the *contents* of every interpreter\n"
    buf = buf + "// array / map (the wrapped HexaValStruct only carries a slot index in\n"
    buf = buf + "// vs->int_val). Because hexa_val_heapify previously stopped at the index-\n"
    buf = buf + "// holding VALSTRUCT, arena-allocated child elements stored *inside*\n"
    buf = buf + "// array_store[idx] / map_store[idx] were never deep-copied — when the arena\n"
    buf = buf + "// rewound on scope-pop, those elements turned into dangling memory that\n"
    buf = buf + "// later prints as \"index 5702266960 out of bounds\" or as the wrong tag.\n"
    buf = buf + "//\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// We weak-link so this object can also link into translation units that\n"
    buf = buf + "// don't include hexa_full.hexa (e.g. the bootstrap_compiler.c stub or\n"
    buf = buf + "// standalone test harnesses). At runtime we NULL-check before deref.\n"
    buf = buf + "extern HexaVal array_store  __attribute__((weak_import, weak));\n"
    buf = buf + "extern HexaVal map_store    __attribute__((weak_import, weak));\n"
    buf = buf + "extern HexaVal struct_store __attribute__((weak_import, weak));\n"
    buf = buf + "__attribute__((weak)) HexaVal array_store  __attribute__((common));\n"
    buf = buf + "__attribute__((weak)) HexaVal map_store    __attribute__((common));\n"
    buf = buf + "__attribute__((weak)) HexaVal struct_store __attribute__((common));\n"
    buf = buf + "\n"
    buf = buf + "// Interpreter-level Val.tag constants (see self/interpreter.hexa lines 20-30).\n"
    buf = buf + "// Hardcoded here because the hexa-side `let TAG_ARRAY = 5` is emitted as a\n"
    buf = buf + "// HexaVal, not a C #define. Mismatch with runtime.c's HexaTag enum is\n"
    buf = buf + "// intentional — these are *interpreter Val tags* (vs->tag_i), not the\n"
    buf = buf + "// outer HexaVal.tag.\n"
    buf = buf + "#define HEXA_INTERP_TAG_ARRAY  5\n"
    buf = buf + "#define HEXA_INTERP_TAG_STRUCT 7\n"
    buf = buf + "#define HEXA_INTERP_TAG_MAP    10\n"
    buf = buf + "\n"
    buf = buf + "// Deep-copy an arena-allocated HexaMapTable to malloc'd storage. Recursive\n"
    buf = buf + "// over nested values (TAG_MAP and TAG_ARRAY descend; scalars + already-heap\n"
    buf = buf + "// strings are bit-copied; TAG_STR with arena-pointing s gets strdup'd).\n"
    buf = buf + "static HexaMapTable* hmap_heapify(HexaMapTable* src) {\n"
    buf = buf + "    if (!src) return NULL;\n"
    buf = buf + "    HexaMapTable* dst = hmap_alloc_ex(src->ht_cap, 0);\n"
    buf = buf + "    // Re-insert by walking the order arrays so insertion order survives the\n"
    buf = buf + "    // copy. The destination is freshly empty; we use the same hash for direct\n"
    buf = buf + "    // slot placement (no rehash necessary because ht_cap matches).\n"
    buf = buf + "    uint32_t mask = (uint32_t)(dst->ht_cap - 1);\n"
    buf = buf + "    if (dst->order_cap < src->order_cap) {\n"
    buf = buf + "        // Grow order arrays to match source capacity (dst->order_cap was\n"
    buf = buf + "        // sized off ht_cap; src may have grown beyond that via push paths).\n"
    buf = buf + "        dst->order_keys = (char**)realloc(dst->order_keys, sizeof(char*) * src->order_cap);\n"
    buf = buf + "        dst->order_vals = (HexaVal*)realloc(dst->order_vals, sizeof(HexaVal) * src->order_cap);\n"
    buf = buf + "        dst->order_cap = src->order_cap;\n"
    buf = buf + "    }\n"
    buf = buf + "    for (int i = 0; i < src->len; i++) {\n"
    buf = buf + "        const char* k = src->order_keys[i];\n"
    buf = buf + "        if (!k) continue;\n"
    buf = buf + "        uint32_t h = hexa_fnv1a_str(k);\n"
    buf = buf + "        uint32_t idx = h & mask;\n"
    buf = buf + "        while (dst->slots[idx].key) idx = (idx + 1) & mask;\n"
    buf = buf + "        dst->slots[idx].key = hxlcl_strdup(k);\n"
    buf = buf + "        dst->slots[idx].hash = h;\n"
    buf = buf + "        dst->slots[idx].order_idx = dst->len;  // ROI-24\n"
    buf = buf + "        HexaVal nv = hexa_val_heapify(src->order_vals[i]);\n"
    buf = buf + "        dst->vals[idx] = nv;\n"
    buf = buf + "        dst->order_keys[dst->len] = dst->slots[idx].key;\n"
    buf = buf + "        dst->order_vals[dst->len] = nv;\n"
    buf = buf + "        dst->len++;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    }\n"
    buf = buf + "    return dst;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Public: heapify a HexaVal. Idempotent on already-heap values. Recursively\n"
    buf = buf + "// processes nested TAG_MAP / TAG_ARRAY / TAG_STR payloads. Scalar tags\n"
    buf = buf + "// (INT/FLOAT/BOOL/VOID) are returned as-is. TAG_FN / TAG_VALSTRUCT / TAG_CLOSURE\n"
    buf = buf + "// retain their pointer identity (those allocators don't currently use the\n"
    buf = buf + "// arena, so heapify is a no-op for them).\n"
    buf = buf + "// Valid heap/arena pointers on macOS/Linux live well above the NULL page.\n"
    buf = buf + "// Any pointer under 0x1000 is a sign of corrupted Val slot (small-int bleed\n"
    buf = buf + "// through the union, uninitialized stack, or freed memory with zeroed bits).\n"
    buf = buf + "// Treat as no-op rather than dereferencing garbage.\n"
    buf = buf + "// 2026-04-17: codegen_c2_extended driver repro produced recursive heapify\n"
    buf = buf + "// calls with v.arr_ptr / v.vs / v.map_ptr = 0x0E causing SIGSEGV at offset\n"
    buf = buf + "// +504 of hexa_val_heapify. Root cause is upstream Val corruption but the\n"
    buf = buf + "// fault mode (sub-page deref) is easy to guard here.\n"
    buf = buf + "#define HX_PTR_OK(p) ((uintptr_t)(p) >= 0x1000)\n"
    buf = buf + "\n"
    buf = buf + "// Cycle 51: `__attribute__((no_builtin(\"memcpy\")))` attempted on this\n"
    buf = buf + "// fn (and hexa_valstruct_set_by_key below) to defeat clang's 160-byte\n"
    buf = buf + "// HexaValStruct aggregate-assign lowering into libc _memcpy — kept\n"
    buf = buf + "// because the attribute IS valid and harmless, but the aggregate-copy\n"
    buf = buf + "// pass fires below the attribute scope. Real closure needs source-\n"
    buf = buf + "// level rewrite of `*dst = *src` to explicit byte-loop or\n"
    buf = buf + "// `__builtin_memcpy_inline`. Defer to a cycle that touches the source\n"
    buf = buf + "// pattern directly.\n"
    buf = buf + "__attribute__((no_builtin(\"memcpy\")))\n"
    buf = buf + "HexaVal hexa_val_heapify(HexaVal v) {\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_MAP:\n"
    buf = buf + "            if (HX_MAP_TBL(v) && HX_MAP_TBL(v)->from_arena) {\n"
    buf = buf + "                HexaMapTable* heap_tbl = hmap_heapify(HX_MAP_TBL(v));\n"
    buf = buf + "                HX_SET_MAP_TBL(v, heap_tbl);\n"
    buf = buf + "                HX_SET_MAP_LEN(v, heap_tbl ? heap_tbl->len : 0);\n"
    buf = buf + "            } else if (HX_MAP_TBL(v)) {\n"
    buf = buf + "                // perf-3B-A1: slots[].order_idx (ROI-24, line 931) is O(1)-maintained\n"
    buf = buf + "                // by every map-set path, so the slot→order index is already known.\n"
    buf = buf + "                // Original used hmap_find (FNV1a + strcmp probe) per entry — the\n"
    buf = buf + "                // sample profile attributed ~32 % of stack-presence to +1108 (the\n"
    buf = buf + "                // post-recursive store) and ~5 % to _platform_strcmp. Forward-walk\n"
    buf = buf + "                // slots[] instead: one heapify per non-empty slot, fan-out to both\n"
    buf = buf + "                // arrays from a single computed index. No hash, no probe, no strcmp.\n"
    buf = buf + "                HexaMapTable* t = HX_MAP_TBL(v);\n"
    buf = buf + "                for (int si = 0; si < t->ht_cap; si++) {\n"
    buf = buf + "                    HexaMapSlot* s = &t->slots[si];\n"
    buf = buf + "                    if (!s->key) continue;\n"
    buf = buf + "                    int oi = s->order_idx;\n"
    buf = buf + "                    HexaVal nv = hexa_val_heapify(t->order_vals[oi]);\n"
    buf = buf + "                    t->order_vals[oi] = nv;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                    t->vals[si] = nv;\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            return v;\n"
    buf = buf + "        case TAG_ARRAY: {\n"
    buf = buf + "            // rt 32-M: if cap<0, items buffer is arena-backed — deep-copy to\n"
    buf = buf + "            // malloc before the rewind. Then heapify nested elements (rt 32-L\n"
    buf = buf + "            // handles nested arena maps / valstructs / strings).\n"
    buf = buf + "            if (HX_ARR_CAP(v) < 0 && HX_ARR_ITEMS(v)) {\n"
    buf = buf + "                if (_hx_stats_on()) _hx_stats_array_arena_heapify++;\n"
    buf = buf + "                int real_cap = -HX_ARR_CAP(v);\n"
    buf = buf + "                HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(v), HX_ARR_LEN(v), real_cap);\n"
    buf = buf + "                if (heap) {\n"
    buf = buf + "                    HX_SET_ARR_ITEMS(v, heap);\n"
    buf = buf + "                    HX_SET_ARR_CAP(v, real_cap);  // positive → heap\n"
    buf = buf + "                }\n"
    buf = buf + "                // On OOM we leave the arena pointer; caller may see invalid\n"
    buf = buf + "                // memory after rewind — best-effort semantics match Val arena.\n"
    buf = buf + "            }\n"
    buf = buf + "            for (int i = 0; i < HX_ARR_LEN(v); i++) {\n"
    buf = buf + "                HX_ARR_ITEMS(v)[i] = hexa_val_heapify(HX_ARR_ITEMS(v)[i]);\n"
    buf = buf + "            }\n"
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_STR: {\n"
    buf = buf + "            // Conservative: if the arena owns the string (i.e. between any\n"
    buf = buf + "            // arena block start and frontier), strdup it. Detection via\n"
    buf = buf + "            // pointer-range check across active blocks.\n"
    buf = buf + "            if (!HX_STR(v)) return v;\n"
    buf = buf + "            // perf: O(1) envelope reject — a pointer outside the union of\n"
    buf = buf + "            // all arena blocks is provably heap-resident, so skip the\n"
    buf = buf + "            // block-chain walk. Collapses the O(n²) re-heapify of\n"
    buf = buf + "            // already-heapified strings documented in 02af1622. A heap\n"
    buf = buf + "            // pointer that happens to fall in a gap between blocks still\n"
    buf = buf + "            // walks (and is correctly found in no block) — sound, just\n"
    buf = buf + "            // not accelerated for that rare case.\n"
    buf = buf + "            {\n"
    buf = buf + "                uintptr_t p = (uintptr_t)HX_STR(v);\n"
    buf = buf + "                if (p < __hx_arena_lo || p >= __hx_arena_hi) return v;\n"
    buf = buf + "            }\n"
    buf = buf + "            for (HexaArenaBlock* b = __hexa_arena.head; b; b = b->next) {\n"
    buf = buf + "                char* base = b->data;\n"
    buf = buf + "                char* end = base + b->cap;\n"
    buf = buf + "                if (HX_STR(v) >= base && HX_STR(v) < end) {\n"
    buf = buf + "                    // perf-31: heapify into header-allocated buffer so the\n"
    buf = buf + "                    // surviving HexaVal supports O(1) HX_STRLEN.\n"
    buf = buf + "                    size_t arena_len = hxlcl_strlen(HX_STR(v));\n"
    buf = buf + "                    HX_SET_STR(v, hexa_strbuf_dup_n(HX_STR(v), arena_len));\n"
    buf = buf + "                    if (_hx_stats_on()) _hx_stats_str_arena_heapify++;\n"
    buf = buf + "                    break;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_CLOSURE: {\n"
    buf = buf + "            // env_box itself is malloc'd in hexa_closure_new — never arena.\n"
    buf = buf + "            // But the captured array stored inside it may transitively contain\n"
    buf = buf + "            // arena maps (params/body/captures). Recurse into env_box's value.\n"
    buf = buf + "            if (HX_CLO_ENV(v)) {\n"
    buf = buf + "                *HX_CLO_ENV(v) = hexa_val_heapify(*HX_CLO_ENV(v));\n"
    buf = buf + "            }\n"
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_VALSTRUCT: {\n"
    buf = buf + "            // rt 32-L: deep-copy arena-allocated HexaValStruct (the dominant\n"
    buf = buf + "            // fib hot path) to malloc'd storage. Polymorphic field slots are\n"
    buf = buf + "            // recursively heapified — closure bodies / param arrays / nested\n"
    buf = buf + "            // structs all need the same treatment.\n"
    buf = buf + "            if (!HX_PTR_OK(HX_VS(v))) return v;\n"
    buf = buf + "            // ω-interp-2 fast path: when this frame has not allocated ANY\n"
    buf = buf + "            // arena memory (cur block + used unchanged from scope_push),\n"
    buf = buf + "            // the VS itself is guaranteed heap (from_arena=0) and all of\n"
    buf = buf + "            // its sub-Vals must also be heap (no arena allocation could\n"
    buf = buf + "            // have happened). Skip the entire shallow-copy + recursive\n"
    buf = buf + "            // heapify chain AND the store walks below.\n"
    buf = buf + "            //\n"
    buf = buf + "            // Correctness: if a child Val could be arena, some arena_alloc\n"
    buf = buf + "            // would have run since scope_push, advancing cur or used. We\n"
    buf = buf + "            // ignore inner-frame allocations because their pop rewinds\n"
    buf = buf + "            // cur+used back to the snapshot.\n"
    buf = buf + "            //\n"
    buf = buf + "            // This addresses the dominant cost in tight push loops where\n"
    buf = buf + "            // the value being heapified is a TAG_ARRAY VS whose backing\n"
    buf = buf + "            // slot holds heap-only items: previously each fn return ran\n"
    buf = buf + "            // a shallow-copy of the wrapping VS (malloc + 8 recursive\n"
    buf = buf + "            // heapify calls) plus the per-item walk over up to N items.\n"
    buf = buf + "            // With the gate, all of it collapses to a single comparison\n"
    buf = buf + "            // + return.\n"
    buf = buf + "            if (!HX_VSF(v, from_arena) && hexa_arena_frame_clean()) {\n"
    buf = buf + "                return v;\n"
    buf = buf + "            }\n"
    buf = buf + "            if (HX_VSF(v, from_arena)) {\n"
    buf = buf + "                HexaValStruct* dst = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n"
    buf = buf + "                if (!dst) return v;  // OOM — caller will see arena pointer (best-effort)\n"
    buf = buf + "                dst->tag_i        = HX_VSF(v, tag_i);\n"
    buf = buf + "                dst->int_val      = HX_VSF(v, int_val);\n"
    buf = buf + "                dst->float_val    = HX_VSF(v, float_val);\n"
    buf = buf + "                dst->bool_val     = HX_VSF(v, bool_val);\n"
    buf = buf + "                dst->from_arena   = 0;\n"
    buf = buf + "                dst->str_val      = hexa_val_heapify(HX_VSF(v, str_val));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                dst->char_val     = hexa_val_heapify(HX_VSF(v, char_val));\n"
    buf = buf + "                dst->array_val    = hexa_val_heapify(HX_VSF(v, array_val));\n"
    buf = buf + "                dst->fn_name      = hexa_val_heapify(HX_VSF(v, fn_name));\n"
    buf = buf + "                dst->fn_params    = hexa_val_heapify(HX_VSF(v, fn_params));\n"
    buf = buf + "                dst->fn_body      = hexa_val_heapify(HX_VSF(v, fn_body));\n"
    buf = buf + "                dst->struct_name  = hexa_val_heapify(HX_VSF(v, struct_name));\n"
    buf = buf + "                dst->struct_fields= hexa_val_heapify(HX_VSF(v, struct_fields));\n"
    buf = buf + "                HX_SET_VS(v, dst);\n"
    buf = buf + "            } else {\n"
    buf = buf + "                // Heap valstruct may still hold arena children (e.g. an arena\n"
    buf = buf + "                // string was assigned to .str_val). Recurse for safety.\n"
    buf = buf + "                // 2026-04-17 COW: __VAL_INT_CACHE singletons are heap valstructs\n"
    buf = buf + "                // shared across the program. In-place mutation corrupts the cache.\n"
    buf = buf + "                // Shallow-copy before heapifying children.\n"
    buf = buf + "                //\n"
    buf = buf + "                // ω-interp-2: scalar-only fast path. The dominant value class\n"
    buf = buf + "                // in numeric push loops is val_int / val_float / val_bool — all\n"
    buf = buf + "                // 8 polymorphic fields are __E (TAG_VOID placeholders). Skip\n"
    buf = buf + "                // the malloc + 8 recursive heapify calls when every field's\n"
    buf = buf + "                // outer tag is a scalar. This avoids 4800-per-push mallocs\n"
    buf = buf + "                // in the vocal_hexa() hot path, where the slot walk iterates\n"
    buf = buf + "                // through cached val_int items.\n"
    buf = buf + "                #define HX_SCALAR_TAG(t) ((t) == TAG_INT || (t) == TAG_FLOAT \\\n"
    buf = buf + "                                          || (t) == TAG_BOOL || (t) == TAG_VOID)\n"
    buf = buf + "                HexaValStruct* vs0 = HX_VS(v);\n"
    buf = buf + "                if (HX_SCALAR_TAG(vs0->str_val.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->char_val.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->array_val.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->fn_name.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->fn_params.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->fn_body.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->struct_name.tag)\n"
    buf = buf + "                    && HX_SCALAR_TAG(vs0->struct_fields.tag)) {\n"
    buf = buf + "                    return v;\n"
    buf = buf + "                }\n"
    buf = buf + "                #undef HX_SCALAR_TAG\n"
    buf = buf + "                HexaValStruct* hcow = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n"
    buf = buf + "                if (hcow) {\n"
    buf = buf + "                    // cycle 73: aggregate `*dst = *src` reverse-libcalls\n"
    buf = buf + "                    // to libc memcpy below the #define layer; route via the\n"
    buf = buf + "                    // memcpy macro (-> hxlcl_memcpy) so no _memcpy extern.\n"
    buf = buf + "                    memcpy(hcow, HX_VS(v), sizeof(HexaValStruct));\n"
    buf = buf + "                    hcow->from_arena = 0;\n"
    buf = buf + "                    hcow->str_val      = hexa_val_heapify(hcow->str_val);\n"
    buf = buf + "                    hcow->char_val     = hexa_val_heapify(hcow->char_val);\n"
    buf = buf + "                    hcow->array_val    = hexa_val_heapify(hcow->array_val);\n"
    buf = buf + "                    hcow->fn_name      = hexa_val_heapify(hcow->fn_name);\n"
    buf = buf + "                    hcow->fn_params    = hexa_val_heapify(hcow->fn_params);\n"
    buf = buf + "                    hcow->fn_body      = hexa_val_heapify(hcow->fn_body);\n"
    buf = buf + "                    hcow->struct_name  = hexa_val_heapify(hcow->struct_name);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                    hcow->struct_fields= hexa_val_heapify(hcow->struct_fields);\n"
    buf = buf + "                    HX_SET_VS(v, hcow);\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            // T33 Fix 4: when the interpreter Val is a TAG_ARRAY (5) or\n"
    buf = buf + "            // TAG_MAP (10), its contents live in array_store / map_store\n"
    buf = buf + "            // indexed by vs->int_val — NOT in the VALSTRUCT itself. Heapify\n"
    buf = buf + "            // the host array slot so each element survives arena rewind.\n"
    buf = buf + "            //\n"
    buf = buf + "            // We only descend if the corresponding global symbol is linked\n"
    buf = buf + "            // (weak_import: &foo == NULL when absent — e.g. bootstrap stub).\n"
    buf = buf + "            // Bounds-check against the host array length to defend against\n"
    buf = buf + "            // freed / reused slot indices observed during T33 repro.\n"
    buf = buf + "            // ω-interp-2 CHECKER: dual gate on (dirty flag) AND (arena grew\n"
    buf = buf + "            // in current frame). The dirty flag fires on any slot write, but\n"
    buf = buf + "            // the slot's items are only at risk of being arena-resident when\n"
    buf = buf + "            // an arena allocation has actually occurred in this frame —\n"
    buf = buf + "            // pushing scalar/cached/heap Vals (the dominant `bytes.push(i)`\n"
    buf = buf + "            // pattern) writes the slot but does NOT advance the arena\n"
    buf = buf + "            // watermark, so the walk is provably unnecessary.\n"
    buf = buf + "            //\n"
    buf = buf + "            // The arena watermark (block ptr + used) is snapshotted at\n"
    buf = buf + "            // scope_push and compared here; equal → no allocation occurred →\n"
    buf = buf + "            // every Val transitively reachable from any modified slot in\n"
    buf = buf + "            // this frame must already be heap (or cached) → skip.\n"
    buf = buf + "            //\n"
    buf = buf + "            // Without this dual gate the dirty-only check still walks once\n"
    buf = buf + "            // per slot-touching frame (call_method's per-push frame in the\n"
    buf = buf + "            // 4800-push hot path), preserving the O(N²) item-walk cost. With\n"
    buf = buf + "            // the arena gate, only frames that genuinely allocated arena Vals\n"
    buf = buf + "            // pay for the walk — for vocal_hexa() that's effectively zero.\n"
    buf = buf + "            //\n"
    buf = buf + "            // We do NOT clear the flag here (see ω-interp-2 design notes\n"
    buf = buf + "            // above re: multi-VS heapify within one frame).\n"
    buf = buf + "            if (__hexa_arena_slot_dirty && !hexa_arena_frame_clean()) {\n"
    buf = buf + "                if (HX_VSF(v, tag_i) == HEXA_INTERP_TAG_ARRAY && &array_store != 0) {\n"
    buf = buf + "                    if (HX_IS_ARRAY(array_store) && HX_ARR_ITEMS(array_store)) {\n"
    buf = buf + "                        int64_t idx = HX_VSF(v, int_val);\n"
    buf = buf + "                        if (idx >= 0 && idx < (int64_t)HX_ARR_LEN(array_store)) {\n"
    buf = buf + "                            // ω-interp-2: incremental walk for push hot path.\n"
    buf = buf + "                            // Calling hexa_val_heapify on the items_array\n"
    buf = buf + "                            // would re-iterate ALL N items per walk → O(N²)\n"
    buf = buf + "                            // for tight push loops. Instead, bypass the\n"
    buf = buf + "                            // outer-array recurse and walk only items in\n"
    buf = buf + "                            // [last_water .. current_len) directly. Earlier\n"
    buf = buf + "                            // items were heapified on prior fn returns and\n"
    buf = buf + "                            // are heap-resident already.\n"
    buf = buf + "                            //\n"
    buf = buf + "                            // The high-water mark lives alongside the items\n"
    buf = buf + "                            // array as the lower 16 bits of a sidecar entry\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                            // we maintain in __hexa_array_water (parallel to\n"
    buf = buf + "                            // array_store). When absent (idx >= water_len),\n"
    buf = buf + "                            // default 0 → first walk processes the full slot.\n"
    buf = buf + "                            HexaVal items_v = HX_ARR_ITEMS(array_store)[idx];\n"
    buf = buf + "                            if (HX_IS_ARRAY(items_v) && HX_ARR_ITEMS(items_v)) {\n"
    buf = buf + "                                if (HX_ARR_CAP(items_v) < 0) {\n"
    buf = buf + "                                    // Arena items buffer — must promote in full.\n"
    buf = buf + "                                    HX_ARR_ITEMS(array_store)[idx] =\n"
    buf = buf + "                                        hexa_val_heapify(items_v);\n"
    buf = buf + "                                } else {\n"
    buf = buf + "                                    int n = HX_ARR_LEN(items_v);\n"
    buf = buf + "                                    int water = hexa_array_water_get(idx);\n"
    buf = buf + "                                    if (water > n) water = n;\n"
    buf = buf + "                                    for (int i = water; i < n; i++) {\n"
    buf = buf + "                                        HX_ARR_ITEMS(items_v)[i] =\n"
    buf = buf + "                                            hexa_val_heapify(HX_ARR_ITEMS(items_v)[i]);\n"
    buf = buf + "                                    }\n"
    buf = buf + "                                    hexa_array_water_set(idx, n);\n"
    buf = buf + "                                }\n"
    buf = buf + "                            } else {\n"
    buf = buf + "                                // Defensive: not a heap items array — fall\n"
    buf = buf + "                                // back to full heapify (rare path).\n"
    buf = buf + "                                HX_ARR_ITEMS(array_store)[idx] =\n"
    buf = buf + "                                    hexa_val_heapify(items_v);\n"
    buf = buf + "                            }\n"
    buf = buf + "                        }\n"
    buf = buf + "                    }\n"
    buf = buf + "                } else if (HX_VSF(v, tag_i) == HEXA_INTERP_TAG_MAP && &map_store != 0) {\n"
    buf = buf + "                    if (HX_IS_ARRAY(map_store) && HX_ARR_ITEMS(map_store)) {\n"
    buf = buf + "                        int64_t idx = HX_VSF(v, int_val);\n"
    buf = buf + "                        if (idx >= 0 && idx < (int64_t)HX_ARR_LEN(map_store)) {\n"
    buf = buf + "                            // map_store[idx] is a TAG_ARRAY of length 2:\n"
    buf = buf + "                            // [keys_array, values_array]. Heapifying the outer\n"
    buf = buf + "                            // array walks both keys and values transitively.\n"
    buf = buf + "                            HX_ARR_ITEMS(map_store)[idx] =\n"
    buf = buf + "                                hexa_val_heapify(HX_ARR_ITEMS(map_store)[idx]);\n"
    buf = buf + "                        }\n"
    buf = buf + "                    }\n"
    buf = buf + "                } else if (HX_VSF(v, tag_i) == HEXA_INTERP_TAG_STRUCT && &struct_store != 0) {\n"
    buf = buf + "                    // rt 36-D: struct_store[idx] is a TAG_MAP (field map).\n"
    buf = buf + "                    // Heapify it so closure-captured structs survive scope pop.\n"
    buf = buf + "                    if (HX_IS_ARRAY(struct_store) && HX_ARR_ITEMS(struct_store)) {\n"
    buf = buf + "                        int64_t idx = HX_VSF(v, int_val);\n"
    buf = buf + "                        if (idx >= 0 && idx < (int64_t)HX_ARR_LEN(struct_store)) {\n"
    buf = buf + "                            HX_ARR_ITEMS(struct_store)[idx] =\n"
    buf = buf + "                                hexa_val_heapify(HX_ARR_ITEMS(struct_store)[idx]);\n"
    buf = buf + "                        }\n"
    buf = buf + "                    }\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        default:\n"
    buf = buf + "            return v;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────\n"
    buf = buf + "// hexa_val_free_tree — recursive free of a malloc'd HexaVal tree.\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────\n"
    buf = buf + "//\n"
    buf = buf + "// PLAN-stage3-footprint-F6.md option C (P0-then-C). Used by the\n"
    buf = buf + "// streaming codegen loop to reclaim per-function MFunc/LFunc once their\n"
    buf = buf + "// asm text has been emitted. Caller asserts the value is unshared at\n"
    buf = buf + "// the drop point — for the streaming loop this holds via the P0a-P0e\n"
    buf = buf + "// escape-edge audit (string leaves forced-copied at every cross-\n"
    buf = buf + "// lifetime store; container arrays/structs built fresh per pass).\n"
    buf = buf + "//\n"
    buf = buf + "// Conservative discipline:\n"
    buf = buf + "//   - VALSTRUCT / ARRAY / MAP heap containers: recurse + free.\n"
    buf = buf + "//   - from_arena=1 (VALSTRUCT, MapTable) or cap<0 (Array): SKIPPED —\n"
    buf = buf + "//     arena-resident, lifetime owned by the scope pop, not free()-able.\n"
    buf = buf + "//   - TAG_STR: NOT freed. Static literals (`hexa_str(\"...\")` in\n"
    buf = buf + "//     transpiled source) and runtime-allocated buffers are not\n"
    buf = buf + "//     statically distinguishable, and per-string overhead is small\n"
    buf = buf + "//     versus the IR struct shells we DO reclaim.\n"
    buf = buf + "//   - TAG_INT / FLOAT / BOOL / VOID / CHAR / FN / CLOSURE: no-op.\n"
    buf = buf + "//\n"
    buf = buf + "// Returns hexa_void() so it composes as an expression.\n"
    buf = buf + "HexaVal hexa_val_free_tree(HexaVal v) {\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_VALSTRUCT: {\n"
    buf = buf + "            HexaValStruct* vs = HX_VS(v);\n"
    buf = buf + "            if (!HX_PTR_OK(vs)) return hexa_void();\n"
    buf = buf + "            if (vs->from_arena) return hexa_void();\n"
    buf = buf + "            hexa_val_free_tree(vs->str_val);\n"
    buf = buf + "            hexa_val_free_tree(vs->char_val);\n"
    buf = buf + "            hexa_val_free_tree(vs->array_val);\n"
    buf = buf + "            hexa_val_free_tree(vs->fn_name);\n"
    buf = buf + "            hexa_val_free_tree(vs->fn_params);\n"
    buf = buf + "            hexa_val_free_tree(vs->fn_body);\n"
    buf = buf + "            hexa_val_free_tree(vs->struct_name);\n"
    buf = buf + "            hexa_val_free_tree(vs->struct_fields);\n"
    buf = buf + "            free(vs);\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_ARRAY: {\n"
    buf = buf + "            if (!HX_PTR_OK(v.arr_ptr)) return hexa_void();\n"
    buf = buf + "            int cap = HX_ARR_CAP(v);\n"
    buf = buf + "            if (cap < 0) return hexa_void();  // arena-backed\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            int len = HX_ARR_LEN(v);\n"
    buf = buf + "            HexaVal* items = HX_ARR_ITEMS(v);\n"
    buf = buf + "            if (items) {\n"
    buf = buf + "                for (int i = 0; i < len; i++) {\n"
    buf = buf + "                    hexa_val_free_tree(items[i]);\n"
    buf = buf + "                }\n"
    buf = buf + "                free(items);\n"
    buf = buf + "            }\n"
    buf = buf + "            free(v.arr_ptr);\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "            HexaMap* mp = v.map_ptr;\n"
    buf = buf + "            if (!HX_PTR_OK(mp)) return hexa_void();\n"
    buf = buf + "            HexaMapTable* t = mp->tbl;\n"
    buf = buf + "            if (t && !t->from_arena) {\n"
    buf = buf + "                // Slot keys are strdup'd (heap) regardless of from_arena,\n"
    buf = buf + "                // per the HexaMapTable comment.\n"
    buf = buf + "                if (t->slots) {\n"
    buf = buf + "                    for (int i = 0; i < t->ht_cap; i++) {\n"
    buf = buf + "                        if (t->slots[i].key) free(t->slots[i].key);\n"
    buf = buf + "                    }\n"
    buf = buf + "                    free(t->slots);\n"
    buf = buf + "                }\n"
    buf = buf + "                if (t->order_vals) {\n"
    buf = buf + "                    for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "                        hexa_val_free_tree(t->order_vals[i]);\n"
    buf = buf + "                    }\n"
    buf = buf + "                    free(t->order_vals);\n"
    buf = buf + "                }\n"
    buf = buf + "                if (t->vals)       free(t->vals);\n"
    buf = buf + "                if (t->order_keys) free(t->order_keys);\n"
    buf = buf + "                free(t);\n"
    buf = buf + "            }\n"
    buf = buf + "            free(mp);\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        default: break;\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────\n"
    buf = buf + "// hexa_val_copy_into_arena — recursive copy: malloc tree → arena tree\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────\n"
    buf = buf + "//\n"
    buf = buf + "// PLAN-stage3-footprint-F6-optA.md A1. Foundational primitive for the\n"
    buf = buf + "// region-promote-on-return path. Mirrors hexa_val_heapify *in reverse*:\n"
    buf = buf + "// where heapify copies arena→malloc, copy_into_arena copies malloc→\n"
    buf = buf + "// arena and stamps from_arena=1 on every new heap-resident struct it\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// makes. Allocations come from hexa_val_arena_calloc (bump arena);\n"
    buf = buf + "// caller is responsible for the surrounding scope discipline.\n"
    buf = buf + "//\n"
    buf = buf + "// Dormant infrastructure — wired by A2 (heapify_to_parent wrapper) and\n"
    buf = buf + "// A3 (the opt-in fn-return variant). Nothing calls this yet.\n"
    buf = buf + "//\n"
    buf = buf + "// Discipline:\n"
    buf = buf + "//   - VALSTRUCT: alloc fresh in arena (from_arena=1), recurse each field.\n"
    buf = buf + "//   - ARRAY: alloc HexaArr + items[] in arena (cap encoded as -real_cap\n"
    buf = buf + "//     per rt 32-M arena-array marker), recurse each item.\n"
    buf = buf + "//   - STR: copy bytes into a fresh arena buffer.\n"
    buf = buf + "//   - MAP / CLOSURE / FN: passthrough unchanged. The streaming-loop IR\n"
    buf = buf + "//     (MFunc / LFunc trees of VALSTRUCT + ARRAY + STR leaves) does not\n"
    buf = buf + "//     materialise these tags inside the per-iteration region; if a\n"
    buf = buf + "//     future caller needs them, add the mirror of hmap_heapify here.\n"
    buf = buf + "//   - Primitives: passthrough.\n"
    buf = buf + "//\n"
    buf = buf + "// OOM-safe: arena alloc returning NULL falls back to the source value\n"
    buf = buf + "// (caller still sees a consistent tree; the caller is responsible for\n"
    buf = buf + "// keeping the source alive in that case — see A2 for the temp-buffer\n"
    buf = buf + "// approach that makes this fall-back trivially correct).\n"
    buf = buf + "HexaVal hexa_val_copy_into_arena(HexaVal v) {\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_VALSTRUCT: {\n"
    buf = buf + "            HexaValStruct* src = HX_VS(v);\n"
    buf = buf + "            if (!HX_PTR_OK(src)) return v;\n"
    buf = buf + "            HexaValStruct* dst =\n"
    buf = buf + "                (HexaValStruct*)hexa_val_arena_calloc(sizeof(HexaValStruct));\n"
    buf = buf + "            if (!dst) return v;  // arena OOM — pass source through\n"
    buf = buf + "            dst->tag_i      = src->tag_i;\n"
    buf = buf + "            dst->int_val    = src->int_val;\n"
    buf = buf + "            dst->float_val  = src->float_val;\n"
    buf = buf + "            dst->bool_val   = src->bool_val;\n"
    buf = buf + "            dst->from_arena = 1;\n"
    buf = buf + "            dst->str_val       = hexa_val_copy_into_arena(src->str_val);\n"
    buf = buf + "            dst->char_val      = hexa_val_copy_into_arena(src->char_val);\n"
    buf = buf + "            dst->array_val     = hexa_val_copy_into_arena(src->array_val);\n"
    buf = buf + "            dst->fn_name       = hexa_val_copy_into_arena(src->fn_name);\n"
    buf = buf + "            dst->fn_params     = hexa_val_copy_into_arena(src->fn_params);\n"
    buf = buf + "            dst->fn_body       = hexa_val_copy_into_arena(src->fn_body);\n"
    buf = buf + "            dst->struct_name   = hexa_val_copy_into_arena(src->struct_name);\n"
    buf = buf + "            dst->struct_fields = hexa_val_copy_into_arena(src->struct_fields);\n"
    buf = buf + "            HX_SET_VS(v, dst);\n"
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_ARRAY: {\n"
    buf = buf + "            HexaArr* src = v.arr_ptr;\n"
    buf = buf + "            if (!HX_PTR_OK(src)) return v;\n"
    buf = buf + "            int len = src->len;\n"
    buf = buf + "            HexaArr* dst = (HexaArr*)hexa_val_arena_calloc(sizeof(HexaArr));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            if (!dst) return v;  // arena OOM\n"
    buf = buf + "            HexaVal* items = NULL;\n"
    buf = buf + "            if (len > 0) {\n"
    buf = buf + "                items = (HexaVal*)hexa_val_arena_calloc((size_t)len * sizeof(HexaVal));\n"
    buf = buf + "                if (!items) return v;  // arena OOM\n"
    buf = buf + "                for (int i = 0; i < len; i++) {\n"
    buf = buf + "                    items[i] = hexa_val_copy_into_arena(src->items[i]);\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            dst->items = items;\n"
    buf = buf + "            dst->len = len;\n"
    buf = buf + "            // rt 32-M: cap<0 marks arena-backed items buffer. Use -len so\n"
    buf = buf + "            // future array_push paths recognise this as non-heap storage.\n"
    buf = buf + "            dst->cap = (len > 0) ? -len : 0;\n"
    buf = buf + "            v.arr_ptr = dst;\n"
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_STR: {\n"
    buf = buf + "            if (!HX_STR(v)) return v;\n"
    buf = buf + "            size_t slen = HX_STRLEN(v);\n"
    buf = buf + "            char* buf = (char*)hexa_arena_alloc(slen + 1);\n"
    buf = buf + "            if (!buf) return v;  // arena OOM\n"
    buf = buf + "            if (slen > 0) hxlcl_memcpy(buf, HX_STR(v), slen);\n"
    buf = buf + "            buf[slen] = '\\0';\n"
    buf = buf + "            HX_SET_STR(v, buf);\n"
    buf = buf + "            return v;\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "            // A6 ROOT-CAUSE FIX (2026-05-16): in this value model a hexa\n"
    buf = buf + "            // `struct` is lowered to a TAG_MAP (field access =\n"
    buf = buf + "            // hexa_map_get). A1's earlier MAP passthrough made the\n"
    buf = buf + "            // arena copy SHARE the source map with the A2 malloc temp;\n"
    buf = buf + "            // the temp-buffer free_tree(temp) then freed it, and\n"
    buf = buf + "            // _new_block's hexa_map_get on the dangling LowerCtx map\n"
    buf = buf + "            // SIGSEGV'd. Deep-copy into a fresh map so the result is\n"
    buf = buf + "            // fully owned and independent of the temp.\n"
    buf = buf + "            HexaMap* mp = v.map_ptr;\n"
    buf = buf + "            if (!HX_PTR_OK(mp) || !mp->tbl) return v;\n"
    buf = buf + "            HexaMapTable* t = mp->tbl;\n"
    buf = buf + "            HexaVal nm = hexa_map_new();\n"
    buf = buf + "            for (int i = 0; i < t->len; i++) {\n"
    buf = buf + "                const char* k = t->order_keys ? t->order_keys[i] : (const char*)0;\n"
    buf = buf + "                if (!k) continue;\n"
    buf = buf + "                HexaVal vc = hexa_val_copy_into_arena(t->order_vals[i]);\n"
    buf = buf + "                nm = hexa_map_set(nm, k, vc);\n"
    buf = buf + "            }\n"
    buf = buf + "            return nm;\n"
    buf = buf + "        }\n"
    buf = buf + "        default:\n"
    buf = buf + "            // CLOSURE / FN / primitives — passthrough. The streaming-loop\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            // IR (LowerCtx/MFunc/LFunc trees) does not materialise\n"
    buf = buf + "            // closures inside the per-iteration region; extend here if a\n"
    buf = buf + "            // future caller needs them (same share-then-free hazard).\n"
    buf = buf + "            return v;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────\n"
    buf = buf + "// hexa_val_arena_heapify_to_parent — temp-buffered region promote\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────\n"
    buf = buf + "//\n"
    buf = buf + "// PLAN-stage3-footprint-F6-optA.md A2. Promotes a Val that lives in the\n"
    buf = buf + "// CURRENT arena frame into the PARENT frame's arena. The naive\n"
    buf = buf + "// \"scope_pop then copy\" overlaps source and destination (the parent's\n"
    buf = buf + "// frontier grows into where the callee's data sits, overwriting source\n"
    buf = buf + "// mid-copy — see the optA doc \"Bump-arena overlap problem\"). The safe\n"
    buf = buf + "// sequence routes the copy via a malloc temp:\n"
    buf = buf + "//\n"
    buf = buf + "//   1. heapify(v)         arena → malloc deep-copy (no overlap).\n"
    buf = buf + "//   2. scope_pop()        rewind callee region; frontier at parent's mark.\n"
    buf = buf + "//   3. copy_into_arena()  malloc → parent arena.\n"
    buf = buf + "//   4. free_tree(temp)    release the malloc temp.\n"
    buf = buf + "//\n"
    buf = buf + "// Cost: 2× memory briefly (the malloc temp and the arena copy coexist\n"
    buf = buf + "// for one recursion). Benefit: provably overlap-free, and the malloc\n"
    buf = buf + "// temp goes through hexa_val_heapify whose recursion is the same the\n"
    buf = buf + "// runtime uses on every fn-return today — no new aliasing surface.\n"
    buf = buf + "//\n"
    buf = buf + "// Caller contract: the per-fn arena scope mark is currently the\n"
    buf = buf + "// callee's; this function pops that mark internally. Calling without a\n"
    buf = buf + "// matching push is a defensive no-op (forwards v unchanged).\n"
    buf = buf + "//\n"
    buf = buf + "// Dormant infrastructure — wired by A3 (the opt-in fn-return variant).\n"
    buf = buf + "HexaVal hexa_val_arena_heapify_to_parent(HexaVal v) {\n"
    buf = buf + "    if (__hexa_val_mark_top <= 0) return v;  // no callee scope — no-op\n"
    buf = buf + "    HexaVal temp = hexa_val_heapify(v);          // (1) malloc deep-copy\n"
    buf = buf + "    hexa_val_arena_scope_pop();                  // (2) rewind callee region\n"
    buf = buf + "    HexaVal arena_copy = hexa_val_copy_into_arena(temp); // (3) into parent\n"
    buf = buf + "    hexa_val_free_tree(temp);                    // (4) release temp\n"
    buf = buf + "    return arena_copy;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Public C entry — exposed for the env(\"__HEXA_ARENA_HEAPIFY_RETURN__\") path.\n"
    buf = buf + "// Heapifies the global return_val (a hexa_full.hexa pub let mut, emitted as a\n"
    buf = buf + "// C global). Declared extern; the symbol is provided by the generated C from\n"
    buf = buf + "// hexa_full.hexa. Guarded by a weak-link check at call time so this object can\n"
    buf = buf + "// link standalone (e.g. test harnesses that don't include hexa_full.hexa).\n"
    buf = buf + "// rt#32-N build-fix: on macOS arm64 clang drops the weak attribute through\n"
    buf = buf + "// plain extern; add weak_import so unresolved → NULL at runtime. Also provide\n"
    buf = buf + "// a weak fallback definition so programs without a global `return_val` (like\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// hexa_cc.c's own build) still link. When hexa_full.hexa's generated C\n"
    buf = buf + "// defines `HexaVal return_val;` later, the strong definition wins (weak\n"
    buf = buf + "// resolves to the strong one). A duplicate-weak -Wignored-attributes warning\n"
    buf = buf + "// is harmless.\n"
    buf = buf + "extern HexaVal return_val __attribute__((weak_import, weak));\n"
    buf = buf + "__attribute__((weak)) HexaVal return_val __attribute__((common));\n"
    buf = buf + "static void hexa_val_arena_heapify_return(void) {\n"
    buf = buf + "    if (&return_val) {\n"
    buf = buf + "        return_val = hexa_val_heapify(return_val);\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── STRUCTURAL-7 Phase A: codegen fn-boundary arena enter/return ──\n"
    buf = buf + "// Implementations for the forward declarations near line 579. When the arena\n"
    buf = buf + "// is OFF (HEXA_VAL_ARENA=0), both are no-ops. When ON (default since S7-B),\n"
    buf = buf + "// enter() pushes an arena scope mark and return() heapifies the return value\n"
    buf = buf + "// (promoting any arena-allocated memory to the heap) then pops the scope.\n"
    buf = buf + "void __hexa_fn_arena_enter(void) {\n"
    buf = buf + "    if (!hexa_val_arena_on()) return;\n"
    buf = buf + "    hexa_val_arena_scope_push();\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal __hexa_fn_arena_return(HexaVal ret) {\n"
    buf = buf + "    if (!hexa_val_arena_on()) return ret;\n"
    buf = buf + "    if (__hexa_val_mark_top <= 0) return ret;  // no matching push — defensive\n"
    buf = buf + "    // perf-3B: primitive tags carry no arena-backed storage, so the\n"
    buf = buf + "    // hexa_val_heapify call + its switch dispatch is pure overhead.\n"
    buf = buf + "    // Pratt-descent parser fns return int/bool dozens of times per token,\n"
    buf = buf + "    // and sample showed __hexa_fn_arena_return + hexa_val_heapify ≈ 23% of\n"
    buf = buf + "    // hexat user-time on codegen.hexa. Short-circuit primitives here.\n"
    buf = buf + "    int tag = HX_TAG(ret);\n"
    buf = buf + "    if (tag == TAG_INT || tag == TAG_FLOAT || tag == TAG_BOOL || tag == TAG_VOID) {\n"
    buf = buf + "        hexa_val_arena_scope_pop();\n"
    buf = buf + "        return ret;\n"
    buf = buf + "    }\n"
    buf = buf + "    // F6 option A — A3: when region returns are enabled (default OFF;\n"
    buf = buf + "    // streaming loop toggles via env hook), promote into the caller's\n"
    buf = buf + "    // arena frame instead of escaping to malloc. hexa_val_arena_heapify_\n"
    buf = buf + "    // to_parent does the scope_pop itself, so we return immediately.\n"
    buf = buf + "    if (__hexa_val_region_returns_enabled) {\n"
    buf = buf + "        return hexa_val_arena_heapify_to_parent(ret);\n"
    buf = buf + "    }\n"
    buf = buf + "    ret = hexa_val_heapify(ret);\n"
    buf = buf + "    hexa_val_arena_scope_pop();\n"
    buf = buf + "    return ret;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── String operations ────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// rt 32-D: optional arena path. Under HEXA_STR_ARENA=1, temporary concat\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// results are bump-allocated from the scope arena instead of malloc'd\n"
    buf = buf + "// individually. Safety: strings that escape the arena's lifetime (returns,\n"
    buf = buf + "// map inserts, closure captures) must be copied into the persistent heap\n"
    buf = buf + "// by the caller — for now we do NOT perform automatic escape analysis, so\n"
    buf = buf + "// the gate defaults to OFF. With the gate OFF behavior is bit-identical to\n"
    buf = buf + "// pre-rt-32-D (every concat still does its own malloc).\n"
    buf = buf + "HexaVal hexa_str_concat(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (_hx_stats_on()) _hx_stats_str_concat++;\n"
    buf = buf + "    // A17: both operands string is the dominant case in self-hosting parser\n"
    buf = buf + "    // (token + token, prefix + name). Hint truthy on HX_IS_STR.\n"
    buf = buf + "    char* sa = HX_LIKELY(HX_IS_STR(a)) ? HX_STR(a) : \"\";\n"
    buf = buf + "    char* sb = HX_LIKELY(HX_IS_STR(b)) ? HX_STR(b) : \"\";\n"
    buf = buf + "    size_t la = hxlcl_strlen(sa);\n"
    buf = buf + "    size_t lb = hxlcl_strlen(sb);\n"
    buf = buf + "    // ROI-36: empty-string elision — skip alloc+memcpy when one side is \"\".\n"
    buf = buf + "    // Empty-side is uncommon on the hot self-host path (parser keyword\n"
    buf = buf + "    // accumulator), so hint the non-empty arms.\n"
    buf = buf + "    if (HX_UNLIKELY(la == 0)) return HX_IS_STR(b) ? b : hexa_str(sb);\n"
    buf = buf + "    if (HX_UNLIKELY(lb == 0)) return HX_IS_STR(a) ? a : hexa_str(sa);\n"
    buf = buf + "    size_t total = la + lb + 1;\n"
    buf = buf + "    char* result;\n"
    buf = buf + "    if (HX_LIKELY(hexa_arena_on())) {\n"
    buf = buf + "        result = (char*)hexa_arena_alloc(total);\n"
    buf = buf + "        if (HX_UNLIKELY(!result)) {\n"
    buf = buf + "            // Fallback: arena OOM → heap malloc so we stay correct.\n"
    buf = buf + "            result = (char*)malloc(total);\n"
    buf = buf + "        } else {\n"
    buf = buf + "            if (_hx_stats_on()) _hx_stats_str_concat_arena++;\n"
    buf = buf + "        }\n"
    buf = buf + "    } else {\n"
    buf = buf + "        result = (char*)malloc(total);\n"
    buf = buf + "    }\n"
    buf = buf + "    // memcpy avoids the strcpy+strcat double walk.\n"
    buf = buf + "    hxlcl_memcpy(result, sa, la);\n"
    buf = buf + "    hxlcl_memcpy(result + la, sb, lb);\n"
    buf = buf + "    result[la + lb] = '\\0';\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// L4 ω-cycle (lossless) — byte-index scan ASCII fast-path.\n"
    buf = buf + "//\n"
    buf = buf + "// Original: 1 hexa_str(buf) intern call per byte → FNV1a hash + linear probe\n"
    buf = buf + "// + (first-time) strdup. For an N-byte source the lexer's hot path\n"
    buf = buf + "// (`chars = source.chars()`) does N intern lookups even when all 256 single-\n"
    buf = buf + "// byte values are already cached. On 842KB ai_native_pass.hexa baseline that\n"
    buf = buf + "// is ~840k FNV1a calls + ~840k array_push calls inside parse phase.\n"
    buf = buf + "//\n"
    buf = buf + "// New: lazy-init a 256-entry HexaVal cache for single-byte strings, and have\n"
    buf = buf + "// hexa_str_chars do a direct table lookup per byte. Output is byte-equivalent\n"
    buf = buf + "// (same interned pointer that hexa_str(buf) would have returned anyway, since\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// 1-byte strings hash into the intern table the same way), so token stream is\n"
    buf = buf + "// preserved bitwise.\n"
    buf = buf + "//\n"
    buf = buf + "// Lossless axes:\n"
    buf = buf + "//   performance: hexa_str(buf) result identity is preserved (same intern\n"
    buf = buf + "//                pointer → same hexa_eq behavior).\n"
    buf = buf + "//   resource:    +256*sizeof(HexaVal) static = ~4KB BSS one-shot.\n"
    buf = buf + "//   speed:       O(1) table lookup vs hash + probe.\n"
    buf = buf + "static HexaVal _cached_byte_str[256];\n"
    buf = buf + "static int     _cached_byte_str_ready = 0;\n"
    buf = buf + "\n"
    buf = buf + "static void _hexa_init_byte_str_cache(void) {\n"
    buf = buf + "    if (_cached_byte_str_ready) return;\n"
    buf = buf + "    char buf[2];\n"
    buf = buf + "    buf[1] = '\\0';\n"
    buf = buf + "    for (int i = 0; i < 256; i++) {\n"
    buf = buf + "        buf[0] = (char)(unsigned char)i;\n"
    buf = buf + "        // For NUL byte we still produce the canonical empty-string interned\n"
    buf = buf + "        // value so hexa_eq matches whatever hexa_str(\"\") returns elsewhere.\n"
    buf = buf + "        _cached_byte_str[i] = hexa_str(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    _cached_byte_str_ready = 1;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Forward decl — defined further down. Needed here because hexa_str_chars\n"
    buf = buf + "// (immediately below) uses it to walk UTF-8 codepoints.\n"
    buf = buf + "static int _hx_utf8_cp_len(unsigned char b);\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 47 port — UTF-8 codepoint walker dispatches to\n"
    buf = buf + "// rt_str_chars (ctype.hexa). The hexa body inlines the\n"
    buf = buf + "// `_hx_utf8_cp_len` bit-pattern table as if/else-if checks; the\n"
    buf = buf + "// returned array contains 1-codepoint strings (not bytes).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_chars(HexaVal s) {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (!HX_IS_STR(s)) return arr;\n"
    buf = buf + "    // 2026-05-19 parity-gate t45b: walk UTF-8 codepoints so\n"
    buf = buf + "    // `\"한글hi\".chars().len() == 4` (4 codepoints), not 8 (bytes).\n"
    buf = buf + "    // ASCII behavior is unchanged (codepoint == byte for ASCII). For\n"
    buf = buf + "    // raw byte iteration use the separate `.bytes()` / hexa_str_bytes\n"
    buf = buf + "    // path. The old byte-level chars() was the buggy-oracle behavior\n"
    buf = buf + "    // that interp doesn't have — deletion-gate alignment.\n"
    buf = buf + "    const char* p = HX_STR(s);\n"
    buf = buf + "    int64_t n = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    int64_t i = 0;\n"
    buf = buf + "    while (i < n) {\n"
    buf = buf + "        int cp = _hx_utf8_cp_len((unsigned char)p[i]);\n"
    buf = buf + "        char buf[5] = {0};\n"
    buf = buf + "        int j = 0;\n"
    buf = buf + "        while (j < cp && i + j < n) { buf[j] = p[i + j]; j++; }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        buf[j] = 0;\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_str(buf));\n"
    buf = buf + "        i += cp;\n"
    buf = buf + "    }\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_chars(HexaVal s);\n"
    buf = buf + "HexaVal hexa_str_chars(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_array_new();\n"
    buf = buf + "    return rt_str_chars(s);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ── UAX-29 extended grapheme cluster segmentation (PROBE r15-D10) ──────\n"
    buf = buf + "// `.graphemes()` / `.grapheme_count()`.  Prior to r15-D10 `.graphemes()`\n"
    buf = buf + "// was a DEGRADED stub aliased to `.chars()` (codepoint walk) — wrong for\n"
    buf = buf + "// combining marks, ZWJ emoji families, regional-indicator flags, and\n"
    buf = buf + "// conjoining Hangul.  This implements the Unicode Text Segmentation\n"
    buf = buf + "// (UAX-29) extended grapheme cluster boundary rules via a pure-C\n"
    buf = buf + "// GraphemeBreak property classifier — no external dependency, matching\n"
    buf = buf + "// hexa's no-LLVM / generated-table identity (RFC §5 option 5-A).\n"
    buf = buf + "//\n"
    buf = buf + "// Covered GB rules:  GB1/GB2 (sot/eot), GB3 (CR × LF), GB4/GB5\n"
    buf = buf + "// (Control/CR/LF break), GB6/GB7/GB8 (Hangul L/V/T/LV/LVT), GB9\n"
    buf = buf + "// (× Extend, × ZWJ), GB9a (× SpacingMark), GB11 (Extended_Pictographic\n"
    buf = buf + "// Extend* ZWJ × Extended_Pictographic — emoji families), GB12/GB13\n"
    buf = buf + "// (regional-indicator pairs), GB999 (otherwise break).\n"
    buf = buf + "// Deferred (rare; not in the r15-D9 acceptance set):  GB9b (Prepend ×).\n"
    buf = buf + "//\n"
    buf = buf + "// The property tables are range-compressed and cover the classes that\n"
    buf = buf + "// drive real boundaries (Extend / SpacingMark / ZWJ / Regional_Indicator\n"
    buf = buf + "// / Extended_Pictographic / Hangul L·V·T·LV·LVT / Control / CR / LF).\n"
    buf = buf + "// Unlisted codepoints classify as \"Other\" → boundary on both sides\n"
    buf = buf + "// (GB999), which is the correct default for the vast majority of text.\n"
    buf = buf + "\n"
    buf = buf + "// GraphemeBreak property classes (internal enum).\n"
    buf = buf + "#define HXGB_OTHER   0\n"
    buf = buf + "#define HXGB_CR      1\n"
    buf = buf + "#define HXGB_LF      2\n"
    buf = buf + "#define HXGB_CONTROL 3\n"
    buf = buf + "#define HXGB_EXTEND  4\n"
    buf = buf + "#define HXGB_ZWJ     5\n"
    buf = buf + "#define HXGB_RI      6   /* Regional_Indicator */\n"
    buf = buf + "#define HXGB_PREPEND 7\n"
    buf = buf + "#define HXGB_SPMARK  8   /* SpacingMark */\n"
    buf = buf + "#define HXGB_L       9\n"
    buf = buf + "#define HXGB_V       10\n"
    buf = buf + "#define HXGB_T       11\n"
    buf = buf + "#define HXGB_LV      12\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#define HXGB_LVT     13\n"
    buf = buf + "#define HXGB_EXTPICT 14  /* Extended_Pictographic */\n"
    buf = buf + "\n"
    buf = buf + "// Decode the UTF-8 codepoint starting at p[i] (n = total bytes). Writes\n"
    buf = buf + "// the byte length of the sequence into *outlen. Invalid lead bytes decode\n"
    buf = buf + "// as the raw byte with length 1 (never infinite-loop). Mirrors the\n"
    buf = buf + "// _hx_utf8_cp_len length table used elsewhere in this file.\n"
    buf = buf + "static int32_t _hx_utf8_decode(const char* p, int64_t n, int64_t i, int* outlen) {\n"
    buf = buf + "    unsigned char b0 = (unsigned char)p[i];\n"
    buf = buf + "    if (b0 < 0x80) { *outlen = 1; return b0; }\n"
    buf = buf + "    if ((b0 & 0xE0) == 0xC0) {\n"
    buf = buf + "        if (i + 1 < n) {\n"
    buf = buf + "            *outlen = 2;\n"
    buf = buf + "            return ((b0 & 0x1F) << 6) | ((unsigned char)p[i + 1] & 0x3F);\n"
    buf = buf + "        }\n"
    buf = buf + "        *outlen = 1; return b0;\n"
    buf = buf + "    }\n"
    buf = buf + "    if ((b0 & 0xF0) == 0xE0) {\n"
    buf = buf + "        if (i + 2 < n) {\n"
    buf = buf + "            *outlen = 3;\n"
    buf = buf + "            return ((b0 & 0x0F) << 12) | (((unsigned char)p[i + 1] & 0x3F) << 6)\n"
    buf = buf + "                 | ((unsigned char)p[i + 2] & 0x3F);\n"
    buf = buf + "        }\n"
    buf = buf + "        *outlen = 1; return b0;\n"
    buf = buf + "    }\n"
    buf = buf + "    if ((b0 & 0xF8) == 0xF0) {\n"
    buf = buf + "        if (i + 3 < n) {\n"
    buf = buf + "            *outlen = 4;\n"
    buf = buf + "            return ((b0 & 0x07) << 18) | (((unsigned char)p[i + 1] & 0x3F) << 12)\n"
    buf = buf + "                 | (((unsigned char)p[i + 2] & 0x3F) << 6)\n"
    buf = buf + "                 | ((unsigned char)p[i + 3] & 0x3F);\n"
    buf = buf + "        }\n"
    buf = buf + "        *outlen = 1; return b0;\n"
    buf = buf + "    }\n"
    buf = buf + "    *outlen = 1; return b0;  // invalid lead byte\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Classify a codepoint into its GraphemeBreak property. Range-compressed;\n"
    buf = buf + "// reasonably-scoped coverage (full UCD not required — the unlisted\n"
    buf = buf + "// majority is HXGB_OTHER, the correct default).\n"
    buf = buf + "static int _hx_gb_class(int32_t c) {\n"
    buf = buf + "    // CR / LF / Control (GB3/GB4/GB5)\n"
    buf = buf + "    if (c == 0x0D) return HXGB_CR;\n"
    buf = buf + "    if (c == 0x0A) return HXGB_LF;\n"
    buf = buf + "    if (c == 0x200D) return HXGB_ZWJ;                       // ZERO WIDTH JOINER\n"
    buf = buf + "    if (c < 0x20 || (c >= 0x7F && c <= 0x9F)) return HXGB_CONTROL;\n"
    buf = buf + "    if (c == 0x00AD) return HXGB_CONTROL;                   // SOFT HYPHEN\n"
    buf = buf + "    if (c == 0x200B || c == 0x200C) return HXGB_CONTROL;    // ZWSP / ZWNJ\n"
    buf = buf + "    if (c >= 0x2028 && c <= 0x202E) return HXGB_CONTROL;    // line/para sep + bidi\n"
    buf = buf + "    if (c == 0xFEFF) return HXGB_CONTROL;                   // BOM / ZWNBSP\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "\n"
    buf = buf + "    // Regional_Indicator (GB12/GB13)\n"
    buf = buf + "    if (c >= 0x1F1E6 && c <= 0x1F1FF) return HXGB_RI;\n"
    buf = buf + "\n"
    buf = buf + "    // Hangul conjoining jamo + precomposed syllables (GB6/GB7/GB8)\n"
    buf = buf + "    if (c >= 0x1100 && c <= 0x115F) return HXGB_L;          // L (leading)\n"
    buf = buf + "    if (c >= 0xA960 && c <= 0xA97C) return HXGB_L;          // L (extended-A)\n"
    buf = buf + "    if (c >= 0x1160 && c <= 0x11A7) return HXGB_V;          // V (vowel)\n"
    buf = buf + "    if (c >= 0xD7B0 && c <= 0xD7C6) return HXGB_V;          // V (extended-B)\n"
    buf = buf + "    if (c >= 0x11A8 && c <= 0x11FF) return HXGB_T;          // T (trailing)\n"
    buf = buf + "    if (c >= 0xD7CB && c <= 0xD7FB) return HXGB_T;          // T (extended-B)\n"
    buf = buf + "    if (c >= 0xAC00 && c <= 0xD7A3) {                       // precomposed syllable\n"
    buf = buf + "        return ((c - 0xAC00) % 28 == 0) ? HXGB_LV : HXGB_LVT;\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // Extend — combining marks / variation selectors (GB9). Range-compressed\n"
    buf = buf + "    // major blocks; covers the common scripts plus emoji modifiers.\n"
    buf = buf + "    if (c >= 0x0300 && c <= 0x036F) return HXGB_EXTEND;     // combining diacritical\n"
    buf = buf + "    if (c >= 0x0483 && c <= 0x0489) return HXGB_EXTEND;     // Cyrillic combining\n"
    buf = buf + "    if (c >= 0x0591 && c <= 0x05BD) return HXGB_EXTEND;     // Hebrew points\n"
    buf = buf + "    if (c == 0x05BF || c == 0x05C1 || c == 0x05C2 || c == 0x05C4 || c == 0x05C5 || c == 0x05C7)\n"
    buf = buf + "        return HXGB_EXTEND;                                 // Hebrew points\n"
    buf = buf + "    if (c >= 0x0610 && c <= 0x061A) return HXGB_EXTEND;     // Arabic\n"
    buf = buf + "    if (c >= 0x064B && c <= 0x065F) return HXGB_EXTEND;     // Arabic diacritics\n"
    buf = buf + "    if (c == 0x0670) return HXGB_EXTEND;                    // Arabic superscript alef\n"
    buf = buf + "    if (c >= 0x06D6 && c <= 0x06DC) return HXGB_EXTEND;     // Arabic small high\n"
    buf = buf + "    if (c >= 0x06DF && c <= 0x06E4) return HXGB_EXTEND;\n"
    buf = buf + "    if (c == 0x06E7 || c == 0x06E8) return HXGB_EXTEND;\n"
    buf = buf + "    if (c >= 0x06EA && c <= 0x06ED) return HXGB_EXTEND;\n"
    buf = buf + "    if (c >= 0x0900 && c <= 0x0903) return HXGB_EXTEND;     // Devanagari (approx)\n"
    buf = buf + "    if (c >= 0x093A && c <= 0x094F) return HXGB_EXTEND;\n"
    buf = buf + "    if (c >= 0x0951 && c <= 0x0957) return HXGB_EXTEND;\n"
    buf = buf + "    if (c >= 0x0E31 && c <= 0x0E3A) return HXGB_EXTEND;     // Thai (approx)\n"
    buf = buf + "    if (c >= 0x0E47 && c <= 0x0E4E) return HXGB_EXTEND;\n"
    buf = buf + "    if (c >= 0x0F71 && c <= 0x0F84) return HXGB_EXTEND;     // Tibetan (approx)\n"
    buf = buf + "    if (c >= 0x135D && c <= 0x135F) return HXGB_EXTEND;     // Ethiopic combining\n"
    buf = buf + "    if (c >= 0x1AB0 && c <= 0x1AFF) return HXGB_EXTEND;     // combining diacritical ext\n"
    buf = buf + "    if (c >= 0x1DC0 && c <= 0x1DFF) return HXGB_EXTEND;     // combining diacritical supp\n"
    buf = buf + "    if (c >= 0x20D0 && c <= 0x20FF) return HXGB_EXTEND;     // combining for symbols\n"
    buf = buf + "    if (c >= 0xFE00 && c <= 0xFE0F) return HXGB_EXTEND;     // variation selectors\n"
    buf = buf + "    if (c >= 0xFE20 && c <= 0xFE2F) return HXGB_EXTEND;     // combining half marks\n"
    buf = buf + "    if (c >= 0xE0100 && c <= 0xE01EF) return HXGB_EXTEND;   // variation selectors supp\n"
    buf = buf + "    if (c >= 0x1F3FB && c <= 0x1F3FF) return HXGB_EXTEND;   // emoji skin-tone modifiers\n"
    buf = buf + "\n"
    buf = buf + "    // Extended_Pictographic (GB11) — emoji. Range-compressed broad blocks.\n"
    buf = buf + "    if (c >= 0x1F000 && c <= 0x1FAFF) {\n"
    buf = buf + "        if (c >= 0x1F1E6 && c <= 0x1F1FF) return HXGB_RI;   // (RI handled above; guard)\n"
    buf = buf + "        return HXGB_EXTPICT;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (c >= 0x2600 && c <= 0x26FF) return HXGB_EXTPICT;    // misc symbols\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    if (c >= 0x2700 && c <= 0x27BF) return HXGB_EXTPICT;    // dingbats\n"
    buf = buf + "    if (c == 0x2049 || c == 0x203C) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c >= 0x2194 && c <= 0x21AA) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c >= 0x231A && c <= 0x231B) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c == 0x2328 || c == 0x23CF) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c >= 0x23E9 && c <= 0x23FA) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c == 0x24C2) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c >= 0x25AA && c <= 0x25FE) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c == 0x2B50 || c == 0x2B55 || c == 0x2B1B || c == 0x2B1C) return HXGB_EXTPICT;\n"
    buf = buf + "    if (c == 0x3030 || c == 0x303D || c == 0x3297 || c == 0x3299) return HXGB_EXTPICT;\n"
    buf = buf + "\n"
    buf = buf + "    return HXGB_OTHER;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Determine whether there is a grapheme cluster boundary BETWEEN the\n"
    buf = buf + "// codepoint with class `prev` and the codepoint with class `cur`.\n"
    buf = buf + "// `ri_odd` = number of consecutive Regional_Indicators so far before\n"
    buf = buf + "// `cur` is odd (GB12/GB13 — break only between RI pairs, not within).\n"
    buf = buf + "// `after_zwj_pict` = the previous codepoint was a ZWJ that was itself\n"
    buf = buf + "// preceded by an Extended_Pictographic (Extend*) run (GB11).\n"
    buf = buf + "// Returns 1 if a boundary exists (cluster break), 0 if no break (join).\n"
    buf = buf + "static int _hx_gb_is_boundary(int prev, int cur, int ri_odd, int after_zwj_pict) {\n"
    buf = buf + "    // GB3: CR × LF — no break inside a CRLF pair.\n"
    buf = buf + "    if (prev == HXGB_CR && cur == HXGB_LF) return 0;\n"
    buf = buf + "    // GB4: (Control | CR | LF) ÷  — break after.\n"
    buf = buf + "    if (prev == HXGB_CONTROL || prev == HXGB_CR || prev == HXGB_LF) return 1;\n"
    buf = buf + "    // GB5: ÷ (Control | CR | LF) — break before.\n"
    buf = buf + "    if (cur == HXGB_CONTROL || cur == HXGB_CR || cur == HXGB_LF) return 1;\n"
    buf = buf + "\n"
    buf = buf + "    // GB6: L × (L | V | LV | LVT)\n"
    buf = buf + "    if (prev == HXGB_L && (cur == HXGB_L || cur == HXGB_V || cur == HXGB_LV || cur == HXGB_LVT))\n"
    buf = buf + "        return 0;\n"
    buf = buf + "    // GB7: (LV | V) × (V | T)\n"
    buf = buf + "    if ((prev == HXGB_LV || prev == HXGB_V) && (cur == HXGB_V || cur == HXGB_T))\n"
    buf = buf + "        return 0;\n"
    buf = buf + "    // GB8: (LVT | T) × T\n"
    buf = buf + "    if ((prev == HXGB_LVT || prev == HXGB_T) && cur == HXGB_T)\n"
    buf = buf + "        return 0;\n"
    buf = buf + "\n"
    buf = buf + "    // GB9: × (Extend | ZWJ) — never break before Extend or ZWJ.\n"
    buf = buf + "    if (cur == HXGB_EXTEND || cur == HXGB_ZWJ) return 0;\n"
    buf = buf + "    // GB9a: × SpacingMark\n"
    buf = buf + "    if (cur == HXGB_SPMARK) return 0;\n"
    buf = buf + "    // GB9b: Prepend ×  (no break after Prepend) — deferred/partial.\n"
    buf = buf + "    if (prev == HXGB_PREPEND) return 0;\n"
    buf = buf + "\n"
    buf = buf + "    // GB11: Extended_Pictographic Extend* ZWJ × Extended_Pictographic\n"
    buf = buf + "    if (after_zwj_pict && cur == HXGB_EXTPICT) return 0;\n"
    buf = buf + "\n"
    buf = buf + "    // GB12/GB13: RI × RI only between an even-then-odd RI (i.e. join the\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    // first of a pair). `ri_odd` true means `cur` (an RI) is the 2nd of a\n"
    buf = buf + "    // pair → no break; else break.\n"
    buf = buf + "    if (prev == HXGB_RI && cur == HXGB_RI) {\n"
    buf = buf + "        return ri_odd ? 0 : 1;\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    // GB999: otherwise, break.\n"
    buf = buf + "    return 1;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Core walker: invokes a callback at each cluster boundary. Shared by\n"
    buf = buf + "// hexa_str_graphemes (collect substrings) and hexa_str_grapheme_count.\n"
    buf = buf + "// Counts clusters in [p, p+n). Returns the cluster count; if `out_arr` is\n"
    buf = buf + "// non-NULL, pushes each cluster substring onto it.\n"
    buf = buf + "static int64_t _hx_grapheme_walk(const char* p, int64_t n, HexaVal* out_arr) {\n"
    buf = buf + "    int64_t count = 0;\n"
    buf = buf + "    int64_t i = 0;\n"
    buf = buf + "    int64_t cluster_start = 0;\n"
    buf = buf + "    int prev_class = -1;\n"
    buf = buf + "    int ri_count = 0;            // consecutive RI run length (for GB12/13 parity)\n"
    buf = buf + "    int pict_pending = 0;        // saw Extended_Pictographic then only Extend* since\n"
    buf = buf + "    int after_zwj_pict = 0;      // previous cp was ZWJ closing a pictographic run\n"
    buf = buf + "    while (i < n) {\n"
    buf = buf + "        int cplen = 0;\n"
    buf = buf + "        int32_t cp = _hx_utf8_decode(p, n, i, &cplen);\n"
    buf = buf + "        int cls = _hx_gb_class(cp);\n"
    buf = buf + "        if (prev_class < 0) {\n"
    buf = buf + "            // sot — first codepoint opens the first cluster (GB1).\n"
    buf = buf + "            cluster_start = i;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            int ri_odd = (ri_count % 2 == 1);\n"
    buf = buf + "            if (_hx_gb_is_boundary(prev_class, cls, ri_odd, after_zwj_pict)) {\n"
    buf = buf + "                // Emit the cluster [cluster_start, i).\n"
    buf = buf + "                if (out_arr) {\n"
    buf = buf + "                    int64_t clen = i - cluster_start;\n"
    buf = buf + "                    char* cbuf = (char*)malloc((size_t)clen + 1);\n"
    buf = buf + "                    if (cbuf) {\n"
    buf = buf + "                        memcpy(cbuf, p + cluster_start, (size_t)clen);\n"
    buf = buf + "                        cbuf[clen] = 0;\n"
    buf = buf + "                        *out_arr = hexa_array_push(*out_arr, hexa_str(cbuf));\n"
    buf = buf + "                        free(cbuf);\n"
    buf = buf + "                    }\n"
    buf = buf + "                }\n"
    buf = buf + "                count++;\n"
    buf = buf + "                cluster_start = i;\n"
    buf = buf + "            }\n"
    buf = buf + "        }\n"
    buf = buf + "        // Update GB11 pictographic-ZWJ state.\n"
    buf = buf + "        if (cls == HXGB_EXTPICT) {\n"
    buf = buf + "            pict_pending = 1;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            after_zwj_pict = 0;\n"
    buf = buf + "        } else if (cls == HXGB_EXTEND) {\n"
    buf = buf + "            // Extend* keeps the pictographic run alive (GB11 allows Extend*).\n"
    buf = buf + "            after_zwj_pict = 0;\n"
    buf = buf + "        } else if (cls == HXGB_ZWJ) {\n"
    buf = buf + "            after_zwj_pict = pict_pending;   // ZWJ closes a pictographic run iff one was pending\n"
    buf = buf + "        } else {\n"
    buf = buf + "            pict_pending = 0;\n"
    buf = buf + "            after_zwj_pict = 0;\n"
    buf = buf + "        }\n"
    buf = buf + "        // Update RI parity run (GB12/13): consecutive RIs.\n"
    buf = buf + "        if (cls == HXGB_RI) {\n"
    buf = buf + "            ri_count++;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            ri_count = 0;\n"
    buf = buf + "        }\n"
    buf = buf + "        prev_class = cls;\n"
    buf = buf + "        i += cplen;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (prev_class >= 0) {\n"
    buf = buf + "        // Emit the final cluster (eot, GB2).\n"
    buf = buf + "        if (out_arr) {\n"
    buf = buf + "            int64_t clen = n - cluster_start;\n"
    buf = buf + "            char* cbuf = (char*)malloc((size_t)clen + 1);\n"
    buf = buf + "            if (cbuf) {\n"
    buf = buf + "                memcpy(cbuf, p + cluster_start, (size_t)clen);\n"
    buf = buf + "                cbuf[clen] = 0;\n"
    buf = buf + "                *out_arr = hexa_array_push(*out_arr, hexa_str(cbuf));\n"
    buf = buf + "                free(cbuf);\n"
    buf = buf + "            }\n"
    buf = buf + "        }\n"
    buf = buf + "        count++;\n"
    buf = buf + "    }\n"
    buf = buf + "    return count;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// `.graphemes()` — array of UAX-29 extended grapheme cluster substrings.\n"
    buf = buf + "HexaVal hexa_str_graphemes(HexaVal s) {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (!HX_IS_STR(s)) return arr;\n"
    buf = buf + "    const char* p = HX_STR(s);\n"
    buf = buf + "    int64_t n = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    _hx_grapheme_walk(p, n, &arr);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// `.grapheme_count()` — count-only fast-path (no array allocation).\n"
    buf = buf + "HexaVal hexa_str_grapheme_count(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_int(0);\n"
    buf = buf + "    const char* p = HX_STR(s);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    int64_t n = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    return hexa_int(_hx_grapheme_walk(p, n, NULL));\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 57 port — int-return bridge through rt_str_contains_b.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "int hexa_str_contains(HexaVal s, HexaVal sub) {\n"
    buf = buf + "    return hxlcl_strstr(HX_STR(s), HX_STR(sub)) != NULL;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_contains_b(HexaVal s, HexaVal sub);\n"
    buf = buf + "int hexa_str_contains(HexaVal s, HexaVal sub) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return 0;\n"
    buf = buf + "    return hexa_truthy(rt_str_contains_b(s, sub)) ? 1 : 0;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 57 port — int-return bridge through rt_str_eq_b. The\n"
    buf = buf + "// pointer-equality fast-path for interned strings stays C-side (hexa\n"
    buf = buf + "// source can't observe HX_STR identity).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "int hexa_str_eq(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (!HX_IS_STR(a) || !HX_IS_STR(b)) return 0;\n"
    buf = buf + "    // Optimization #11: interned strings share pointers\n"
    buf = buf + "    if (HX_STR(a) == HX_STR(b)) return 1;\n"
    buf = buf + "    return hxlcl_strcmp(HX_STR(a), HX_STR(b)) == 0;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_eq_b(HexaVal a, HexaVal b);\n"
    buf = buf + "int hexa_str_eq(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (!HX_IS_STR(a) || !HX_IS_STR(b)) return 0;\n"
    buf = buf + "    if (HX_STR(a) == HX_STR(b)) return 1;  // intern fast-path stays C\n"
    buf = buf + "    return hexa_truthy(rt_str_eq_b(a, b)) ? 1 : 0;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// M1 full · str_ext Step 5 (hxa-20260423-003): rt_str_starts_with/ends_with —\n"
    buf = buf + "// codegen emits rt_str_* directly; hexa_str_starts_with/ends_with shims retired.\n"
    buf = buf + "// Step-3 cycle 56 port — int-return bridge through rt_str_*_b (hexa\n"
    buf = buf + "// source returns bool; the `_b` suffix avoids name collision with the\n"
    buf = buf + "// C int-return symbol that codegen wraps via `hexa_bool(...)`).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "int rt_str_starts_with(HexaVal s, HexaVal prefix) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(prefix)) return 0;\n"
    buf = buf + "    size_t plen = HX_STRLEN(prefix);\n"
    buf = buf + "    return hxlcl_strncmp(HX_STR(s), HX_STR(prefix), plen) == 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "int rt_str_ends_with(HexaVal s, HexaVal suffix) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(suffix)) return 0;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    size_t slen = HX_STRLEN(s);\n"
    buf = buf + "    size_t sfxlen = HX_STRLEN(suffix);\n"
    buf = buf + "    if (sfxlen > slen) return 0;\n"
    buf = buf + "    return hxlcl_strcmp(HX_STR(s) + slen - sfxlen, HX_STR(suffix)) == 0;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_starts_with_b(HexaVal s, HexaVal prefix);\n"
    buf = buf + "extern HexaVal rt_str_ends_with_b(HexaVal s, HexaVal suffix);\n"
    buf = buf + "int rt_str_starts_with(HexaVal s, HexaVal prefix) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(prefix)) return 0;\n"
    buf = buf + "    return hexa_truthy(rt_str_starts_with_b(s, prefix)) ? 1 : 0;\n"
    buf = buf + "}\n"
    buf = buf + "int rt_str_ends_with(HexaVal s, HexaVal suffix) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(suffix)) return 0;\n"
    buf = buf + "    return hexa_truthy(rt_str_ends_with_b(s, suffix)) ? 1 : 0;\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_str_substring(HexaVal s, HexaVal start, HexaVal end) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n"
    buf = buf + "    int64_t slen = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    int64_t a = HX_INT(start), b = HX_INT(end);\n"
    buf = buf + "    if (a < 0) a = 0;\n"
    buf = buf + "    if (b > slen) b = slen;\n"
    buf = buf + "    if (a >= b) return hexa_str(\"\");\n"
    buf = buf + "    // perf-31: write straight into header-allocated buffer — eliminates the\n"
    buf = buf + "    // hexa_str_own copy that would otherwise re-strlen + re-malloc + memcpy.\n"
    buf = buf + "    char* buf = hexa_strbuf_alloc((size_t)(b - a));\n"
    buf = buf + "    hxlcl_memcpy(buf, HX_STR(s) + a, (size_t)(b - a));\n"
    buf = buf + "    return (HexaVal){.tag=TAG_STR, .s=buf};\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 54 port — int64_t-returning fn bridged through hexa-source\n"
    buf = buf + "// `rt_str_index_of` (returns int → HexaVal at C ABI). The C wrapper\n"
    buf = buf + "// preserves the int64_t signature so codegen wrapping\n"
    buf = buf + "// `hexa_int(hexa_str_index_of(...))` keeps working.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "int64_t hexa_str_index_of(HexaVal s, HexaVal sub) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n"
