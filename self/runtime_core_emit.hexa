#!hexa strict
// self/runtime_core_emit.hexa
//   B9.C-10 (.c-text · #1866 pattern) — runtime_core.c source emitter (F3).
//
// self/runtime.c `#include "runtime_core.c"` (line 1762) — RFC 061 amalgamation
// CORE-tier fragment (NOT a standalone TU; references runtime.c-internal symbols
// HexaVal/hxlcl_*/hexa_int/…). This emitter is the SSOT; the build regenerates
// self/runtime_core.c from it before runtime.c compiles, so the .c becomes a
// gitignored build artifact.
//
// Byte-identity: regenerated C is byte-for-byte the hand-written source (verified
// via self/runtime_core_byte_diff.hexa, gate-1 source-SHA), so the runtime.c TU
// (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// Invocation:  hexa-run self/runtime_core_emit.hexa <output-path>
// Default output path (if argv missing): "runtime_core.c" in cwd.
//
// Phase: B9.C-10 batch (runtime.c-included .c-text · F3 — the amalgamation core).

let MODULE_NAME = "runtime_core_emit"

fn emit_runtime_core_c() -> str {
    // Verbatim content of hand-written self/runtime_core.c
    let s =
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  HEXA C Runtime — CORE tier (runtime_core.c)\n" +
            "//  RFC 061 Phase P1: 2-layer split, phase 1.\n" +
            "//\n" +
            "//  This file is the irreducible C core of the hexa runtime per the\n" +
            "//  RFC 061 §4.1 boundary criterion: HexaVal representation bits\n" +
            "//  (NaN-box tag macros, the struct/union layout), the allocator hot\n" +
            "//  path (arena, malloc wrappers, array/map primitive memory ops),\n" +
            "//  the universal codegen-emitted primitives (hexa_int/float/str/bool/\n" +
            "//  void constructors, hexa_add and the arithmetic/comparison family,\n" +
            "//  hexa_index_get, hexa_len, hexa_array_new/push/get/set, hexa_map_*),\n" +
            "//  and their transitive closure (string interning, branch-hint macros,\n" +
            "//  RSS cap, fuel telemetry — all referenced on the core path).\n" +
            "//\n" +
            "//  It is #include-d (NOT separately compiled) by self/runtime.c right\n" +
            "//  after the system #include block; the preprocessor concatenation of\n" +
            "//  runtime.c's system headers + this file + runtime.c's HI tier yields\n" +
            "//  a translation unit byte-identical to the pre-split runtime.c.\n" +
            "//\n" +
            "//  HI-tier functions (FFI, struct-pack, trampoline, term/exec/json/\n" +
            "//  regex, farr, safetensors, tensor, autograd, the ML numerics) stay\n" +
            "//  in runtime.c — RFC 061 P2/P3 migrate those to hexa source.\n" +
            "//\n" +
            "//  NOTE on size: a clean *contiguous-prefix* split lands the core at\n" +
            "//  ~6.0 k lines, larger than the RFC §5b per-function projection\n" +
            "//  (≈2.4-3 k). The prefix cut is deliberate — it is provably\n" +
            "//  zero-behavior-change (pure file partition; no function reorder, so\n" +
            "//  no risk to internal forward-decl / file-scope-static ordering).\n" +
            "//  A small number of string/math/format helpers that §5b classifies\n" +
            "//  HI sit in this prefix; they are exactly the P2/P3 migration\n" +
            "//  tranches and will leave this file when rewritten in hexa.\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  Branch hints + cold attribute + cacheline prefetch\n" +
            "//  (A17 / A18 / Z20 — docs/hexa_speedup_brainstorm_2026_05_06.ai.md)\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "// HX_LIKELY / HX_UNLIKELY: __builtin_expect wrappers for hot-path bias.\n" +
            "//   Only wrap branches whose taken-direction is dominated (>~80%) by a\n" +
            "//   single arm in measured workloads — wrong-way hints can hurt by 1-2%.\n" +
            "// HX_COLD: function attribute that pushes the body into the cold .text\n" +
            "//   section so it doesn't pollute icache on the common path.\n" +
            "// HX_PREFETCH: cacheline prefetch hint (no-op on archs without builtin).\n" +
            "// All three are zero-cost no-ops under non-GCC/Clang compilers.\n" +
            "#if defined(__GNUC__) || defined(__clang__)\n" +
            "#  ifndef HX_LIKELY\n" +
            "#    define HX_LIKELY(x)   __builtin_expect(!!(x), 1)\n" +
            "#  endif\n" +
            "#  ifndef HX_UNLIKELY\n" +
            "#    define HX_UNLIKELY(x) __builtin_expect(!!(x), 0)\n" +
            "#  endif\n" +
            "#  ifndef HX_COLD\n" +
            "#    define HX_COLD __attribute__((cold))\n" +
            "#  endif\n" +
            "#  ifndef HX_PREFETCH\n" +
            "#    define HX_PREFETCH(addr) __builtin_prefetch((const void*)(addr), 0, 1)\n" +
            "#  endif\n" +
            "#else\n" +
            "#  ifndef HX_LIKELY\n" +
            "#    define HX_LIKELY(x)   (x)\n" +
            "#  endif\n" +
            "#  ifndef HX_UNLIKELY\n" +
            "#    define HX_UNLIKELY(x) (x)\n" +
            "#  endif\n" +
            "#  ifndef HX_COLD\n" +
            "#    define HX_COLD\n" +
            "#  endif\n" +
            "#  ifndef HX_PREFETCH\n" +
            "#    define HX_PREFETCH(addr) ((void)0)\n" +
            "#  endif\n" +
            "#endif\n" +
            "\n" +
            "// hexa_pipe_buf_enlarge — TL;DR #4 pipe buffer optimization (2026-05-06).\n" +
            "// Two variants because the optimal lever differs by read pattern:\n" +
            "//\n" +
            "//   _kernel — Linux F_SETPIPE_SZ only (1 MB kernel pipe). No-op on macOS.\n" +
            "//             Use for fread()-based bulk drain paths (hexa_exec,\n" +
            "//             hexa_exec_with_status). The userland setvbuf path costs more\n" +
            "//             than it saves there: caller already does fread() into a 4 KB\n" +
            "//             stack buf, and macOS adds a 256 KB malloc + memcpy hop per\n" +
            "//             popen with no syscall reduction (measured 2x regression on\n" +
            "//             50 MB `yes | head` stream, 2026-05-06).\n" +
            "//\n" +
            "//   _full   — F_SETPIPE_SZ on Linux + setvbuf 256 KB userland on all\n" +
            "//             platforms. Use for fgets()-based streaming paths\n" +
            "//             (hexa_exec_stream_impl). Streaming reads line-at-a-time, so\n" +
            "//             a large refill buffer behind fgets() amortizes the syscall.\n" +
            "//\n" +
            "// Linux F_SETPIPE_SZ may be rejected (EPERM if pipe-max-size exceeded,\n" +
            "// EINVAL on old kernels) — silently fall back, never fail the caller.\n" +
            "// Must be called immediately after popen() and before any I/O on fp —\n" +
            "// setvbuf() requires a fresh stream.\n" +
            "static inline void hexa_pipe_buf_enlarge_kernel(FILE* fp) {\n" +
            "    if (!fp) return;\n" +
            "#ifdef __linux__\n" +
            "#ifdef F_SETPIPE_SZ\n" +
            "    int fd = fileno(fp);\n" +
            "    if (fd >= 0) {\n" +
            "        (void)hxlcl_fcntl(fd, F_SETPIPE_SZ, 1 << 20);\n" +
            "        // Ignore errno (EPERM/EINVAL) — kernel may reject; default size\n" +
            "        // still works correctly, only throughput differs.\n" +
            "    }\n" +
            "#endif\n" +
            "#else\n" +
            "    (void)fp;  // macOS: F_SETPIPE_SZ unsupported, leave default.\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "static inline void hexa_pipe_buf_enlarge_full(FILE* fp) {\n" +
            "    if (!fp) return;\n" +
            "    hexa_pipe_buf_enlarge_kernel(fp);\n" +
            "    // Userland FILE* buffer: 256 KB fully-buffered. Helps fgets() amortize\n" +
            "    // the read() syscall over many lines.\n" +
            "    (void)setvbuf(fp, NULL, _IOFBF, 256 * 1024);\n" +
            "}\n" +
            "\n" +
            "// 2026-05-06 audit closure:\n" +
            "//   - stdout: _IOLBF (line-buffered) — flushes on newline when redirected to\n" +
            "//     file/pipe so subprocess prompts and progress aren't held mid-line.\n" +
            "//   - stderr: _IONBF (unbuffered) — POSIX default for stderr is unbuffered\n" +
            "//     so diagnostics appear immediately even on partial-line writes (e.g.\n" +
            "//     \"loading…\" without newline). Earlier _IOLBF setting was over-buffered.\n" +
            "//   - SIGPIPE: SIG_IGN — when a child closes its stdin while the parent is\n" +
            "//     mid-write (interactive prompts, build pipelines), the default SIGPIPE\n" +
            "//     would kill the runtime. Ignoring it lets write() return EPIPE and the\n" +
            "//     caller decide how to handle the broken-pipe case.\n" +
            "__attribute__((constructor))\n" +
            "static void _hexa_init_stdio(void) {\n" +
            "    setvbuf(stdout, NULL, _IOLBF, 0);\n" +
            "    setvbuf(stderr, NULL, _IONBF, 0);\n" +
            "    hxlcl_signal(SIGPIPE, SIG_IGN);\n" +
            "}\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  PATH augmentation for macOS — Homebrew / MacPorts visibility\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//\n" +
            "// Background: hexa modules call exec(\"timeout 30 ...\") / exec(\"python3 -c ...\")\n" +
            "// expecting that subshells (popen → /bin/sh -c) can find binaries on the\n" +
            "// operator's normal PATH. On macOS, common operator tools (timeout, gtimeout,\n" +
            "// python3, qrencode, jq, ripgrep, ...) live under /opt/homebrew/bin (Apple\n" +
            "// Silicon) or /usr/local/bin (Intel + linuxbrew). When hexa is invoked from a\n" +
            "// context where the parent's PATH was sanitized (launchd, cron, system\n" +
            "// services that bypass the user shell, or any caller that exec'd hexa with a\n" +
            "// minimal env), popen() faithfully passes that minimal PATH through to\n" +
            "// /bin/sh, and \"timeout\" / \"python3\" disappear — surfacing as silent failures\n" +
            "// or 127 exit codes inside hexa modules.\n" +
            "//\n" +
            "// Pragmatic root-cause fix: on macOS, pre-pend the standard package-manager\n" +
            "// prefixes to PATH at runtime startup so every popen()/fork+exec child\n" +
            "// inherits a path that can resolve the operator's everyday tools. This\n" +
            "// matches what an interactive shell startup (zsh + /etc/zprofile + path_helper)\n" +
            "// would do, except we apply it inside the hexa process even when launched\n" +
            "// from a non-shell parent. Linux is left untouched (its FHS layout already\n" +
            "// has /usr/local/bin in the default PATH on most distros, and Homebrew on\n" +
            "// Linux installs to /home/linuxbrew/.linuxbrew/bin which the operator's\n" +
            "// shell rc already injects).\n" +
            "//\n" +
            "// Escape hatch:\n" +
            "//   HEXA_PATH_NO_AUGMENT=1   → disable; child sees parent PATH verbatim.\n" +
            "//\n" +
            "// Idempotency: each candidate is added only if not already present\n" +
            "// (substring match against `:`-delimited segments). Order: candidates are\n" +
            "// pre-pended in the order listed below, so /opt/homebrew/bin wins over\n" +
            "// /usr/local/bin (matches Apple Silicon Homebrew priority over linuxbrew /\n" +
            "// stale Intel installs).\n" +
            "//\n" +
            "// Security boundary: this changes which directories popen() searches; it\n" +
            "// does NOT introduce a new shell-injection vector (callers still pass a\n" +
            "// quoted command to popen as before). An operator who explicitly wants the\n" +
            "// minimal PATH (e.g. for sandbox testing) sets HEXA_PATH_NO_AUGMENT=1.\n" +
            "__attribute__((constructor))\n" +
            "static void _hexa_init_path_augment(void) {\n" +
            "#if defined(__APPLE__)\n" +
            "    const char* opt = hxlcl_getenv(\"HEXA_PATH_NO_AUGMENT\");\n" +
            "    if (opt && opt[0] == '1' && opt[1] == '\\0') return;\n" +
            "\n" +
            "    const char* old = hxlcl_getenv(\"PATH\");\n" +
            "    if (!old) old = \"\";\n" +
            "\n" +
            "    // Candidates pre-pended in order. /opt/homebrew first (Apple Silicon\n" +
            "    // Homebrew default), /usr/local next (Intel Homebrew + manual installs),\n" +
            "    // /opt/local last (MacPorts). sbin variants included for tools like\n" +
            "    // pfctl wrappers shipped under sbin in some bottles.\n" +
            "    static const char* const candidates[] = {\n" +
            "        \"/opt/homebrew/bin\",\n" +
            "        \"/opt/homebrew/sbin\",\n" +
            "        \"/usr/local/bin\",\n" +
            "        \"/usr/local/sbin\",\n" +
            "        \"/opt/local/bin\",\n" +
            "        \"/opt/local/sbin\",\n" +
            "        NULL\n" +
            "    };\n" +
            "\n" +
            "    // Build new PATH = <missing candidates joined by ':'> + ':' + old.\n" +
            "    // Worst-case length: sum of all candidates + separators + old + NUL.\n" +
            "    size_t cap = hxlcl_strlen(old) + 1;\n" +
            "    for (int i = 0; candidates[i]; i++) cap += hxlcl_strlen(candidates[i]) + 1;\n" +
            "    char* buf = (char*)malloc(cap);\n" +
            "    if (!buf) return;\n" +
            "    buf[0] = '\\0';\n" +
            "\n" +
            "    for (int i = 0; candidates[i]; i++) {\n" +
            "        const char* c = candidates[i];\n" +
            "        size_t clen = hxlcl_strlen(c);\n" +
            "        // Substring search for \":<c>:\", \"<c>:\" (start), or \":<c>\" (end), or\n" +
            "        // exact match. Cheap O(n*m) scan — PATH is rarely > 4 KB and this\n" +
            "        // runs once at process start.\n" +
            "        int found = 0;\n" +
            "        const char* p = old;\n" +
            "        while (*p) {\n" +
            "            const char* q = hxlcl_strchr(p, ':');\n" +
            "            size_t seg = q ? (size_t)(q - p) : hxlcl_strlen(p);\n" +
            "            if (seg == clen && hxlcl_memcmp(p, c, clen) == 0) { found = 1; break; }\n" +
            "            if (!q) break;\n" +
            "            p = q + 1;\n" +
            "        }\n" +
            "        if (!found) {\n" +
            "            hxlcl_strcat(buf, c);\n" +
            "            hxlcl_strcat(buf, \":\");\n" +
            "        }\n" +
            "    }\n" +
            "    hxlcl_strcat(buf, old);\n" +
            "\n" +
            "    // Only call setenv if we actually added something (buf longer than old).\n" +
            "    if (hxlcl_strlen(buf) > hxlcl_strlen(old)) {\n" +
            "        hxlcl_setenv(\"PATH\", buf, 1);\n" +
            "    }\n" +
            "    free(buf);\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  RSS soft cap — runtime guard against runaway memory\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//\n" +
            "// Background: macOS rejects setrlimit(RLIMIT_AS|DATA|RSS,...) with EINVAL,\n" +
            "// so the only effective in-process cap is polling self-RSS via task_info()\n" +
            "// (Darwin) or /proc/self/statm (Linux). When exceeded, we exit(77) with a\n" +
            "// clear stderr trailer instead of letting the process grow until jetsam\n" +
            "// SIGKILL or system swap pressure.\n" +
            "//\n" +
            "// Tick model: hot paths (hexa_arena_alloc / hexa_array_push / hexa_strbuf_alloc)\n" +
            "// call _hx_mem_tick(). Internally a counter modulo (every 2^16 calls) decides\n" +
            "// whether to actually syscall. Per-call overhead ≈ 1 increment + 1 mask + 1\n" +
            "// branch; the syscall is amortized to ~once per tens of MB of allocation.\n" +
            "//\n" +
            "// Defaults & overrides (2026-05-16 — opt-IN model):\n" +
            "//   default               → NO cap. A legitimate heavy compile (the\n" +
            "//                            compiler self-compile peaks ~30 GB) is more\n" +
            "//                            common than a runaway, and a spurious\n" +
            "//                            exit(77) kills real work — worse than\n" +
            "//                            letting the OS arbitrate. The cap is OFF\n" +
            "//                            unless explicitly asked for.\n" +
            "//   HEXA_MEM_LIMIT=<N>     → opt in to a cap of N MB (must be >0). The\n" +
            "//                            primary knob — e.g. HEXA_MEM_LIMIT=4096\n" +
            "//                            asserts a 4 GB ceiling for a footprint test.\n" +
            "//   HEXA_MEM_CAP_MB=<N>    → legacy alias of HEXA_MEM_LIMIT (still honored).\n" +
            "//   HEXA_MEM_UNLIMITED=1   → legacy explicit-disable; now also the default,\n" +
            "//                            kept so old wrappers/scripts stay valid no-ops.\n" +
            "//\n" +
            "// Pre-2026-05-16 this defaulted to a 4096 MB cap (raised over time\n" +
            "// 768→2048→4096 as the embedded atlas grew). That default is removed —\n" +
            "// callers wanting a ceiling now set HEXA_MEM_LIMIT explicitly.\n" +
            "//\n" +
            "// CLI flags (parsed by the hexa wrapper script, exported as env above):\n" +
            "//   --mem-limit=<N> / --mem-cap=<N> → HEXA_MEM_LIMIT / HEXA_MEM_CAP_MB\n" +
            "//   --mem-unlimited                 → HEXA_MEM_UNLIMITED=1 (now a no-op)\n" +
            "\n" +
            "static size_t _hx_mem_cap_bytes = 4096ull * 1024ull * 1024ull;  // used only when a cap is opted in\n" +
            "static int    _hx_mem_cap_disabled = 1;  // 2026-05-16: NO cap by default\n" +
            "static volatile uint64_t _hx_mem_tick_ctr = 0;\n" +
            "\n" +
            "__attribute__((constructor))\n" +
            "static void _hexa_init_mem_cap(void) {\n" +
            "    // Opt-in cap. HEXA_MEM_LIMIT is the primary knob; HEXA_MEM_CAP_MB is\n" +
            "    // a legacy alias. Either one, set to a positive MB value, enables the\n" +
            "    // cap. HEXA_MEM_UNLIMITED=1 forces it back off (and is the default).\n" +
            "    const char* lim = hxlcl_getenv(\"HEXA_MEM_LIMIT\");\n" +
            "    if (lim && lim[0] != '\\0') {\n" +
            "        long long mb = hxlcl_atoll(lim);\n" +
            "        if (mb > 0) {\n" +
            "            _hx_mem_cap_bytes = (size_t)mb * 1024ull * 1024ull;\n" +
            "            _hx_mem_cap_disabled = 0;\n" +
            "        }\n" +
            "    }\n" +
            "    const char* cap = hxlcl_getenv(\"HEXA_MEM_CAP_MB\");\n" +
            "    if (cap && cap[0] != '\\0') {\n" +
            "        long long mb = hxlcl_atoll(cap);\n" +
            "        if (mb > 0) {\n" +
            "            _hx_mem_cap_bytes = (size_t)mb * 1024ull * 1024ull;\n" +
            "            _hx_mem_cap_disabled = 0;\n" +
            "        }\n" +
            "    }\n" +
            "    const char* unl = hxlcl_getenv(\"HEXA_MEM_UNLIMITED\");\n" +
            "    if (unl && unl[0] == '1' && unl[1] == '\\0') {\n" +
            "        _hx_mem_cap_disabled = 1;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "static size_t _hx_self_rss_bytes(void) {\n" +
            "#if defined(__APPLE__)\n" +
            "    mach_task_basic_info_data_t info;\n" +
            "    mach_msg_type_number_t cnt = MACH_TASK_BASIC_INFO_COUNT;\n" +
            "    if (hxlcl_task_info(mach_task_self(), MACH_TASK_BASIC_INFO,\n" +
            "                  (task_info_t)&info, &cnt) != KERN_SUCCESS) return 0;\n" +
            "    return (size_t)info.resident_size;\n" +
            "#elif defined(__linux__)\n" +
            "    // libc-unhook safe: self/runtime.c `#define fopen → hxlcl_fopen` returns a\n" +
            "    // (void*)(fd+1) shim, NOT a real glibc FILE*. `fscanf` is NOT remapped, so\n" +
            "    // handing it that shim deref'd a small-int as a FILE* → SIGSEGV — fired on\n" +
            "    // every mem-cap-enabled transpile of a non-trivial input (the [1/2] step of\n" +
            "    // `hexa drill` dispatched to a Linux pool host injects HEXA_MEM_CAP_MB=4096,\n" +
            "    // so the RSS tick poller crashed instead of measuring). Read /proc/self/statm\n" +
            "    // via the unhooked syscall wrappers (hxlcl_open_sys/hxlcl_read) and parse the\n" +
            "    // second whitespace-separated field (resident pages) inline — no stdio.\n" +
            "    int fd = hxlcl_open_sys(\"/proc/self/statm\", O_RDONLY);\n" +
            "    if (fd < 0) return 0;\n" +
            "    char buf[128];\n" +
            "    long n = (long)hxlcl_read(fd, buf, sizeof(buf) - 1);\n" +
            "    hxlcl_close(fd);\n" +
            "    if (n <= 0) return 0;\n" +
            "    buf[n] = '\\0';\n" +
            "    // statm: \"<total> <resident> <shared> ...\" — skip field 1, parse field 2.\n" +
            "    const char* p = buf;\n" +
            "    while (*p == ' ') p++;\n" +
            "    while (*p && *p != ' ') p++;           // skip total\n" +
            "    while (*p == ' ') p++;\n" +
            "    long pages_rss = 0;\n" +
            "    while (*p >= '0' && *p <= '9') {        // parse resident\n" +
            "        pages_rss = pages_rss * 10 + (*p - '0');\n" +
            "        p++;\n" +
            "    }\n" +
            "    long ps = sysconf(_SC_PAGESIZE);\n" +
            "    if (ps <= 0) ps = 4096;\n" +
            "    return (size_t)pages_rss * (size_t)ps;\n" +
            "#else\n" +
            "    return 0;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  Fuel-abort telemetry emitter — atlas/anima ledger pipeline\n" +
            "//  hxa-2026-05-06 fuel_abort_telemetry stub (worker fuel-emit-pipeline)\n" +
            "//\n" +
            "//  Schema: hexa-lang/runtime_fuel_abort/1\n" +
            "//  Target: $HEXA_LANG/state/hx_runtime_fuel_abort.jsonl  (append-only JSONL)\n" +
            "//\n" +
            "//  Triggered from any abort path (mem-cap; future cpu/wall fuel exhaustion).\n" +
            "//  Payload: ts, kind (\"mem\"|\"cpu\"|\"wall\"|\"oom\"), exit_code, binary path,\n" +
            "//           argv[1..N], rss_mb, cap_mb, fuel_count, top_frame,\n" +
            "//           rusage (utime_us+stime_us+maxrss_kb).\n" +
            "//  Best-effort: any failure (state dir missing, fd starvation) is silently\n" +
            "//  swallowed — never let telemetry break an abort path.\n" +
            "//\n" +
            "//  TODO(fuel-worker): when interpreter fuel lands, call _hx_emit_fuel_abort\n" +
            "//  from interpreter.hexa abort site too (kind=\"cpu\" / \"wall\"); pass\n" +
            "//  top_frame string (function name + line) once interp exposes it.\n" +
            "//  TODO(fuel-worker): switch to atomic O_APPEND + flock for safe parallel\n" +
            "//  AOT processes hitting the cap simultaneously.\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "\n" +
            "// Forward-decl globals (defined ~line 4632) so the emitter can read argv.\n" +
            "static int _hexa_argc;\n" +
            "static char** _hexa_argv;\n" +
            "\n" +
            "// JSON-escape into caller's buffer; returns bytes written (excl. NUL).\n" +
            "// Truncates at cap-1 to guarantee NUL term. Bounded so we don't allocate.\n" +
            "static size_t _hx_fuel_json_esc(char* dst, size_t cap, const char* s) {\n" +
            "    if (!dst || cap == 0) return 0;\n" +
            "    size_t out = 0;\n" +
            "    if (!s) { dst[0] = '\\0'; return 0; }\n" +
            "    for (; *s && out + 2 < cap; s++) {\n" +
            "        unsigned char c = (unsigned char)*s;\n" +
            "        if (c == '\\\\' || c == '\"') {\n" +
            "            if (out + 3 >= cap) break;\n" +
            "            dst[out++] = '\\\\';\n" +
            "            dst[out++] = (char)c;\n" +
            "        } else if (c == '\\n') {\n" +
            "            if (out + 3 >= cap) break;\n" +
            "            dst[out++] = '\\\\'; dst[out++] = 'n';\n" +
            "        } else if (c == '\\r') {\n" +
            "            if (out + 3 >= cap) break;\n" +
            "            dst[out++] = '\\\\'; dst[out++] = 'r';\n" +
            "        } else if (c == '\\t') {\n" +
            "            if (out + 3 >= cap) break;\n" +
            "            dst[out++] = '\\\\'; dst[out++] = 't';\n" +
            "        } else if (c < 0x20) {\n" +
            "            if (out + 7 >= cap) break;\n" +
            "            int n = snprintf(dst + out, cap - out, \"\\\\u%04x\", c);\n" +
            "            if (n <= 0) break;\n" +
            "            out += (size_t)n;\n" +
            "        } else {\n" +
            "            dst[out++] = (char)c;\n" +
            "        }\n" +
            "    }\n" +
            "    dst[out] = '\\0';\n" +
            "    return out;\n" +
            "}\n" +
            "\n" +
            "// Public entry. kind ∈ {\"mem\",\"cpu\",\"wall\",\"oom\"}. Best-effort emit.\n" +
            "// Non-static so future Hexa-side callers (interp fuel) can FFI it via\n" +
            "// the existing dlsym pathway; meanwhile internal callers use it directly.\n" +
            "void _hx_emit_fuel_abort(const char* kind,\n" +
            "                         int exit_code,\n" +
            "                         long long fuel_count,\n" +
            "                         size_t rss_bytes,\n" +
            "                         size_t cap_bytes,\n" +
            "                         const char* top_frame) {\n" +
            "    if (!kind) kind = \"unknown\";\n" +
            "    if (!top_frame) top_frame = \"\";\n" +
            "\n" +
            "    // Resolve ledger path. Honor HEXA_FUEL_LEDGER override (tests / dry-run);\n" +
            "    // fall back to $HEXA_LANG/state/, then $HOME/core/hexa-lang/state/.\n" +
            "    char path[1024];\n" +
            "    const char* override_p = hxlcl_getenv(\"HEXA_FUEL_LEDGER\");\n" +
            "    if (override_p && override_p[0]) {\n" +
            "        snprintf(path, sizeof(path), \"%s\", override_p);\n" +
            "    } else {\n" +
            "        const char* root = hxlcl_getenv(\"HEXA_LANG\");\n" +
            "        if (!root || !root[0]) {\n" +
            "            const char* home = hxlcl_getenv(\"HOME\");\n" +
            "            if (!home || !home[0]) home = \"/tmp\";\n" +
            "            snprintf(path, sizeof(path),\n" +
            "                     \"%s/core/hexa-lang/state/hx_runtime_fuel_abort.jsonl\", home);\n" +
            "        } else {\n" +
            "            snprintf(path, sizeof(path),\n" +
            "                     \"%s/state/hx_runtime_fuel_abort.jsonl\", root);\n" +
            "        }\n" +
            "    }\n" +
            "\n" +
            "    // ISO-8601 UTC timestamp (no exec; format inline).\n" +
            "    char ts[32];\n" +
            "    time_t now = hxlcl_time(NULL);\n" +
            "    struct tm tmv;\n" +
            "#if defined(_WIN32)\n" +
            "    gmtime_s(&tmv, &now);\n" +
            "#else\n" +
            "    gmtime_r(&now, &tmv);\n" +
            "#endif\n" +
            "    hxlcl_strftime(ts, sizeof(ts), \"%Y-%m-%dT%H:%M:%SZ\", &tmv);\n" +
            "\n" +
            "    // RUSAGE snapshot (best-effort; on failure leave zeros).\n" +
            "    long utime_us = 0, stime_us = 0, maxrss_kb = 0;\n" +
            "    struct rusage ru;\n" +
            "    if (hxlcl_getrusage(RUSAGE_SELF, &ru) == 0) {\n" +
            "        utime_us = (long)ru.ru_utime.tv_sec * 1000000L + (long)ru.ru_utime.tv_usec;\n" +
            "        stime_us = (long)ru.ru_stime.tv_sec * 1000000L + (long)ru.ru_stime.tv_usec;\n" +
            "        // ru_maxrss: Linux=KB, macOS=bytes. Normalize to KB.\n" +
            "        maxrss_kb = (long)ru.ru_maxrss;\n" +
            "#if defined(__APPLE__)\n" +
            "        maxrss_kb /= 1024L;\n" +
            "#endif\n" +
            "    }\n" +
            "\n" +
            "    // Binary path = argv[0]; user args = argv[2..argc-1] (argv[1] is dup of argv[0]).\n" +
            "    const char* binary = (_hexa_argv && _hexa_argc > 0) ? _hexa_argv[0] : \"\";\n" +
            "    if (!binary) binary = \"\";\n" +
            "\n" +
            "    // Build args array string: [\"a\",\"b\",...]\n" +
            "    char args_buf[1024];\n" +
            "    args_buf[0] = '['; args_buf[1] = '\\0';\n" +
            "    size_t apos = 1;\n" +
            "    int args_start = (_hexa_argc >= 2) ? 2 : _hexa_argc;\n" +
            "    int wrote = 0;\n" +
            "    for (int i = args_start; i < _hexa_argc && _hexa_argv && _hexa_argv[i]; i++) {\n" +
            "        if (apos + 4 >= sizeof(args_buf)) break;\n" +
            "        if (wrote) { args_buf[apos++] = ','; }\n" +
            "        args_buf[apos++] = '\"';\n" +
            "        char esc[256];\n" +
            "        _hx_fuel_json_esc(esc, sizeof(esc), _hexa_argv[i]);\n" +
            "        size_t elen = hxlcl_strlen(esc);\n" +
            "        if (apos + elen + 2 >= sizeof(args_buf)) { apos--; break; }\n" +
            "        hxlcl_memcpy(args_buf + apos, esc, elen); apos += elen;\n" +
            "        args_buf[apos++] = '\"';\n" +
            "        wrote = 1;\n" +
            "    }\n" +
            "    if (apos + 1 < sizeof(args_buf)) args_buf[apos++] = ']';\n" +
            "    args_buf[apos] = '\\0';\n" +
            "\n" +
            "    // JSON-escape variable strings.\n" +
            "    char binary_esc[512];\n" +
            "    char top_esc[256];\n" +
            "    char kind_esc[32];\n" +
            "    _hx_fuel_json_esc(binary_esc, sizeof(binary_esc), binary);\n" +
            "    _hx_fuel_json_esc(top_esc, sizeof(top_esc), top_frame);\n" +
            "    _hx_fuel_json_esc(kind_esc, sizeof(kind_esc), kind);\n" +
            "\n" +
            "    // Compose the JSONL line.\n" +
            "    char line[3072];\n" +
            "    int n = snprintf(line, sizeof(line),\n" +
            "        \"{\\\"schema\\\":\\\"hexa-lang/runtime_fuel_abort/1\\\"\"\n" +
            "        \",\\\"ts\\\":\\\"%s\\\"\"\n" +
            "        \",\\\"event\\\":\\\"hexa.runtime.fuel_abort\\\"\"\n" +
            "        \",\\\"kind\\\":\\\"%s\\\"\"\n" +
            "        \",\\\"exit_code\\\":%d\"\n" +
            "        \",\\\"binary\\\":\\\"%s\\\"\"\n" +
            "        \",\\\"args\\\":%s\"\n" +
            "        \",\\\"fuel_count\\\":%lld\"\n" +
            "        \",\\\"rss_mb\\\":%llu\"\n" +
            "        \",\\\"cap_mb\\\":%llu\"\n" +
            "        \",\\\"top_frame\\\":\\\"%s\\\"\"\n" +
            "        \",\\\"rusage\\\":{\\\"utime_us\\\":%ld,\\\"stime_us\\\":%ld,\\\"maxrss_kb\\\":%ld}\"\n" +
            "        \"}\\n\",\n" +
            "        ts, kind_esc, exit_code, binary_esc, args_buf,\n" +
            "        fuel_count,\n" +
            "        (unsigned long long)(rss_bytes / (1024ull * 1024ull)),\n" +
            "        (unsigned long long)(cap_bytes / (1024ull * 1024ull)),\n" +
            "        top_esc,\n" +
            "        utime_us, stime_us, maxrss_kb);\n" +
            "    if (n <= 0) return;\n" +
            "    if ((size_t)n >= sizeof(line)) n = (int)sizeof(line) - 1;\n" +
            "\n" +
            "    // Best-effort mkdir of immediate parent dir; silent on failure.\n" +
            "    {\n" +
            "        char dir[1024];\n" +
            "        size_t pl = hxlcl_strlen(path);\n" +
            "        size_t cut = pl;\n" +
            "        while (cut > 0 && path[cut - 1] != '/') cut--;\n" +
            "        if (cut > 0 && cut < sizeof(dir)) {\n" +
            "            hxlcl_memcpy(dir, path, cut - 1);\n" +
            "            dir[cut - 1] = '\\0';\n" +
            "            // TODO(fuel-worker): full mkdir -p chain. state/ usually exists.\n" +
            "            (void)hxlcl_mkdir(dir, 0755);\n" +
            "        }\n" +
            "    }\n" +
            "\n" +
            "    FILE* f = fopen(path, \"a\");\n" +
            "    if (!f) {\n" +
            "        // Last-resort: stderr trailer so external watchers still see it.\n" +
            "        fprintf(stderr, \"[hexa-runtime/fuel_abort] %s\", line);\n" +
            "        return;\n" +
            "    }\n" +
            "    fwrite(line, 1, (size_t)n, f);\n" +
            "    fflush(f);\n" +
            "    fclose(f);\n" +
            "}\n" +
            "\n" +
            "__attribute__((noinline))\n" +
            "static void _hx_mem_cap_fire(size_t rss) {\n" +
            "    fprintf(stderr,\n" +
            "        \"[hexa-runtime] memory cap exceeded: rss=%zuMB > cap=%zuMB\\n\"\n" +
            "        \"[hexa-runtime] hint: this cap is opt-in (HEXA_MEM_LIMIT/HEXA_MEM_CAP_MB) — \"\n" +
            "        \"raise HEXA_MEM_LIMIT=<MB>, or unset it for no cap (the default).\\n\",\n" +
            "        (size_t)(rss / (1024ull*1024ull)),\n" +
            "        (size_t)(_hx_mem_cap_bytes / (1024ull*1024ull)));\n" +
            "    // Telemetry: ledger emit before exit. Best-effort; never blocks the abort.\n" +
            "    // fuel_count = -1 (n/a for memory cap; future interp fuel passes int).\n" +
            "    _hx_emit_fuel_abort(\"mem\", 77, -1, rss, _hx_mem_cap_bytes, \"\");\n" +
            "    exit(77);\n" +
            "}\n" +
            "\n" +
            "static inline void _hx_mem_tick(void) {\n" +
            "    if (_hx_mem_cap_disabled) return;\n" +
            "    // 2026-05-05: 0xFFFF (65 536 calls) → 0x0FFF (4 096 calls) — 16× more\n" +
            "    // frequent. Tightens overshoot bound on bursty allocators (the\n" +
            "    // observed runaways went 1 → 5 GB inside one 30s watcher window).\n" +
            "    if ((++_hx_mem_tick_ctr & 0x0FFFu) != 0) return;\n" +
            "    size_t rss = _hx_self_rss_bytes();\n" +
            "    if (rss > _hx_mem_cap_bytes) _hx_mem_cap_fire(rss);\n" +
            "}\n" +
            "\n" +
            "// ── H03 (2026-05-06): forward decls for HEXA_ALLOC_STATS extensions ──\n" +
            "// Storage + main definitions live alongside the rt 32 stats block (~line 1080+).\n" +
            "// We declare them up-front so early callers (hexa_intern, hexa_closure_new,\n" +
            "// hexa_fn_new — all defined before the stats block) can reference them.\n" +
            "// `_hx_stats_on()` is the central guard; everything else is only touched\n" +
            "// inside that guard, so unset-env paths are a single predicted branch + RET.\n" +
            "static int _hx_stats_on(void);\n" +
            "#define HX_POOL_LRU 8\n" +
            "static int64_t _hx_stats_intern_hit;     // file-scope tentative defs (zero-init)\n" +
            "static int64_t _hx_stats_intern_miss;\n" +
            "static int64_t _hx_stats_intern_skip;\n" +
            "static int64_t _hx_stats_intern_grow;\n" +
            "static int64_t _hx_stats_closure_alloc;\n" +
            "static int64_t _hx_stats_fn_alloc;\n" +
            "static int64_t _hx_stats_fn_alloc_dup;\n" +
            "static int64_t _hx_stats_clo_alloc_dup;\n" +
            "static void* _hx_stats_fn_lru[HX_POOL_LRU];\n" +
            "static void* _hx_stats_clo_lru[HX_POOL_LRU];\n" +
            "static int   _hx_stats_fn_lru_pos;\n" +
            "static int   _hx_stats_clo_lru_pos;\n" +
            "static inline int _hx_stats_lru_check(void** ring, int* pos, void* p) {\n" +
            "    for (int i = 0; i < HX_POOL_LRU; i++) {\n" +
            "        if (ring[i] == p) return 1;\n" +
            "    }\n" +
            "    ring[*pos] = p;\n" +
            "    *pos = (*pos + 1) % HX_POOL_LRU;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  Optimization #11: String Interning\n" +
            "//  Hash-set of unique strings. Short strings (< 64 chars)\n" +
            "//  are interned; comparison becomes pointer equality (==).\n" +
            "//  Lazily initialized on first hexa_intern() call.\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "\n" +
            "#define INTERN_INIT_CAP   1024\n" +
            "#define INTERN_MAX_LEN    64\n" +
            "#define INTERN_LOAD_MAX   75   // percent\n" +
            "\n" +
            "static uint32_t hexa_fnv1a(const char* s, size_t len) {\n" +
            "    uint32_t h = 2166136261u;\n" +
            "    for (size_t i = 0; i < len; i++) {\n" +
            "        h ^= (uint8_t)s[i];\n" +
            "        h *= 16777619u;\n" +
            "    }\n" +
            "    return h;\n" +
            "}\n" +
            "\n" +
            "// Also used by the hash-map (#10)\n" +
            "uint32_t hexa_fnv1a_str(const char* s) {\n" +
            "    uint32_t h = 2166136261u;\n" +
            "    for (; *s; s++) {\n" +
            "        h ^= (uint8_t)*s;\n" +
            "        h *= 16777619u;\n" +
            "    }\n" +
            "    return h;\n" +
            "}\n" +
            "\n" +
            "typedef struct {\n" +
            "    char** buckets;      // array of interned string pointers (NULL = empty)\n" +
            "    uint32_t* hashes;    // cached hash per slot\n" +
            "    int cap;             // power-of-2 capacity\n" +
            "    int count;           // number of occupied slots\n" +
            "} HexaInternTable;\n" +
            "\n" +
            "static HexaInternTable __hexa_intern = {NULL, NULL, 0, 0};\n" +
            "\n" +
            "static void hexa_intern_init(void) {\n" +
            "    __hexa_intern.cap = INTERN_INIT_CAP;\n" +
            "    __hexa_intern.count = 0;\n" +
            "    __hexa_intern.buckets = (char**)calloc(INTERN_INIT_CAP, sizeof(char*));\n" +
            "    __hexa_intern.hashes  = (uint32_t*)calloc(INTERN_INIT_CAP, sizeof(uint32_t));\n" +
            "}\n" +
            "\n" +
            "static void hexa_intern_grow(void) {\n" +
            "    int old_cap = __hexa_intern.cap;\n" +
            "    char** old_buckets = __hexa_intern.buckets;\n" +
            "    uint32_t* old_hashes = __hexa_intern.hashes;\n" +
            "    int new_cap = old_cap * 2;\n" +
            "    char** new_buckets = (char**)calloc(new_cap, sizeof(char*));\n" +
            "    uint32_t* new_hashes = (uint32_t*)calloc(new_cap, sizeof(uint32_t));\n" +
            "    uint32_t mask = (uint32_t)(new_cap - 1);\n" +
            "    for (int i = 0; i < old_cap; i++) {\n" +
            "        if (old_buckets[i]) {\n" +
            "            uint32_t idx = old_hashes[i] & mask;\n" +
            "            while (new_buckets[idx]) idx = (idx + 1) & mask;\n" +
            "            new_buckets[idx] = old_buckets[i];\n" +
            "            new_hashes[idx] = old_hashes[i];\n" +
            "        }\n" +
            "    }\n" +
            "    free(old_buckets);\n" +
            "    free(old_hashes);\n" +
            "    __hexa_intern.buckets = new_buckets;\n" +
            "    __hexa_intern.hashes  = new_hashes;\n" +
            "    __hexa_intern.cap = new_cap;\n" +
            "}\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  String length-header (perf-31, 2026-04-26)\n" +
            "//\n" +
            "//  Embed an 8-byte size_t length immediately before each owned\n" +
            "//  string buffer. HX_STR(v) still returns the data pointer (no\n" +
            "//  caller change), but HX_STRLEN(v) reads the cached length in\n" +
            "//  O(1) — eliminating the per-call strlen() that turned every\n" +
            "//  hot string fn (substring, char_at, replace, …) into O(n²).\n" +
            "//\n" +
            "//  Magic-byte guard lets HX_STRLEN safely fall back to strlen()\n" +
            "//  when called with a pointer that did NOT come from a header\n" +
            "//  allocator (e.g. arena-allocated map keys at runtime.c:1364\n" +
            "//  which can't reasonably grow a header — those are short type\n" +
            "//  names where strlen is cheap anyway).\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "\n" +
            "#define HEXA_STR_MAGIC ((uint64_t)0xC0DECAFE0F58A7E1ULL)\n" +
            "\n" +
            "typedef struct {\n" +
            "    uint64_t magic;\n" +
            "    size_t   len;\n" +
            "    char     data[];   // C99 flexible array — actual bytes follow\n" +
            "} HexaStrHdr;\n" +
            "\n" +
            "// Allocate a string buffer with embedded length header. Returns the\n" +
            "// data pointer (caller stores in HexaVal.s); the header sits at\n" +
            "// (data - sizeof(HexaStrHdr)). data[len] is pre-NUL-terminated so\n" +
            "// callers can fill bytes 0..len-1 and immediately treat as C string.\n" +
            "static inline char* hexa_strbuf_alloc(size_t len) {\n" +
            "    _hx_mem_tick();\n" +
            "    HexaStrHdr* hdr = (HexaStrHdr*)malloc(sizeof(HexaStrHdr) + len + 1);\n" +
            "    if (!hdr) return NULL;\n" +
            "    hdr->magic = HEXA_STR_MAGIC;\n" +
            "    hdr->len = len;\n" +
            "    hdr->data[len] = '\\0';\n" +
            "    return hdr->data;\n" +
            "}\n" +
            "\n" +
            "// Allocate header buffer + memcpy from src. src may be NULL when len==0.\n" +
            "static inline char* hexa_strbuf_dup_n(const char* src, size_t len) {\n" +
            "    char* buf = hexa_strbuf_alloc(len);\n" +
            "    if (!buf) return NULL;\n" +
            "    if (len > 0 && src) hxlcl_memcpy(buf, src, len);\n" +
            "    return buf;\n" +
            "}\n" +
            "\n" +
            "// O(1) length read. Reads 16 bytes before s and matches HEXA_STR_MAGIC\n" +
            "// to confirm header presence; falls back to strlen otherwise. Reading\n" +
            "// before s is safe in practice because every code path that puts a\n" +
            "// pointer into HexaVal.s uses heap-allocated memory (malloc / strdup /\n" +
            "// arena_alloc), all of which sit on heap chunks with ≥16 bytes of\n" +
            "// allocator metadata in front, so the load won't fault.\n" +
            "static inline size_t hexa_strlen_v_inline(const char* s) {\n" +
            "    if (!s) return 0;\n" +
            "    // sizeof(struct{...; char data[]}) == offset of flex array → header size\n" +
            "    HexaStrHdr* hdr = (HexaStrHdr*)((const char*)s - sizeof(HexaStrHdr));\n" +
            "    if (hdr->magic == HEXA_STR_MAGIC) return hdr->len;\n" +
            "    return hxlcl_strlen(s);\n" +
            "}\n" +
            "\n" +
            "#define HX_STRLEN(v)    hexa_strlen_v_inline(HX_STR(v))\n" +
            "#define HX_STRLEN_S(s)  hexa_strlen_v_inline(s)\n" +
            "\n" +
            "// Intern a string: returns a canonical pointer.\n" +
            "// If the string is already interned, returns the existing pointer.\n" +
            "// Only interns strings shorter than INTERN_MAX_LEN.\n" +
            "// The returned pointer is owned by the intern table -- callers must NOT free it.\n" +
            "static const char* hexa_intern(const char* s) {\n" +
            "    if (HX_UNLIKELY(!s)) return s;\n" +
            "    size_t slen = hxlcl_strlen(s);\n" +
            "    if (HX_UNLIKELY(slen >= INTERN_MAX_LEN)) {\n" +
            "        // H03 Q9: count strings rejected by length cap.\n" +
            "        if (_hx_stats_on()) _hx_stats_intern_skip++;\n" +
            "        return NULL;  // too long, skip interning\n" +
            "    }\n" +
            "\n" +
            "    // Lazy init — fires once per process; everything after is hot-path.\n" +
            "    if (HX_UNLIKELY(!__hexa_intern.buckets)) hexa_intern_init();\n" +
            "\n" +
            "    uint32_t h = hexa_fnv1a(s, slen);\n" +
            "    uint32_t mask = (uint32_t)(__hexa_intern.cap - 1);\n" +
            "    uint32_t idx = h & mask;\n" +
            "\n" +
            "    // A17: most workloads exhibit a heavy hit-rate (>90%) on hexa_intern —\n" +
            "    // self-hosting parser interns identifiers + keywords repeatedly. Hint\n" +
            "    // the slot-occupied loop and the hash-equal+strcmp-hit branch as taken.\n" +
            "    while (HX_LIKELY(__hexa_intern.buckets[idx] != NULL)) {\n" +
            "        if (HX_LIKELY(__hexa_intern.hashes[idx] == h) &&\n" +
            "            hxlcl_strcmp(__hexa_intern.buckets[idx], s) == 0) {\n" +
            "            // H03 Q9: hit — table contained an equal canonical pointer.\n" +
            "            if (_hx_stats_on()) _hx_stats_intern_hit++;\n" +
            "            return __hexa_intern.buckets[idx];  // already interned\n" +
            "        }\n" +
            "        idx = (idx + 1) & mask;\n" +
            "    }\n" +
            "\n" +
            "    // Not found -- insert (header-allocated so HX_STRLEN works on interned strings)\n" +
            "    // Grow path is rare (amortised O(log N) over program lifetime).\n" +
            "    if (HX_UNLIKELY(__hexa_intern.count * 100 / __hexa_intern.cap >= INTERN_LOAD_MAX)) {\n" +
            "        hexa_intern_grow();\n" +
            "        if (_hx_stats_on()) _hx_stats_intern_grow++;\n" +
            "        // Recompute slot after grow\n" +
            "        mask = (uint32_t)(__hexa_intern.cap - 1);\n" +
            "        idx = h & mask;\n" +
            "        while (__hexa_intern.buckets[idx]) idx = (idx + 1) & mask;\n" +
            "    }\n" +
            "\n" +
            "    char* dup = hexa_strbuf_dup_n(s, slen);\n" +
            "    __hexa_intern.buckets[idx] = dup;\n" +
            "    __hexa_intern.hashes[idx]  = h;\n" +
            "    __hexa_intern.count++;\n" +
            "    if (_hx_stats_on()) _hx_stats_intern_miss++;\n" +
            "    return dup;\n" +
            "}\n" +
            "\n" +
            "// Forward declarations for all runtime functions\n" +
            "// S1-D3b-beta: struct tag renamed to HexaVal_ so typedef HexaVal can flip\n" +
            "// to uint64_t (NaN-boxed) without touching field access patterns.\n" +
            "typedef struct HexaVal_ HexaVal;\n" +
            "HexaVal hexa_add(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_concat_many(int n, HexaVal* parts);\n" +
            "int hexa_truthy(HexaVal v);\n" +
            "HexaVal hexa_sub(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_mul(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_div(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_mod(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_fma(HexaVal a, HexaVal b, HexaVal c);\n" +
            "HexaVal hexa_eq(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_cmp_lt(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_cmp_gt(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_cmp_le(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_cmp_ge(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_to_string(HexaVal v);\n" +
            "HexaVal hexa_str_concat(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_abs(HexaVal v);\n" +
            "HexaVal hexa_pad_left(HexaVal s, HexaVal width);\n" +
            "HexaVal hexa_pad_right(HexaVal s, HexaVal width);\n" +
            "HexaVal hexa_str_char_at(HexaVal s, HexaVal idx);\n" +
            "HexaVal hexa_str_char_code_at(HexaVal s, HexaVal idx);\n" +
            "HexaVal hexa_eprintln(HexaVal v);\n" +
            "HexaVal hexa_eprint(HexaVal v);\n" +
            "// M1 full · file layer (hxa-20260423-003 Step 5): codegen emits rt_file_*\n" +
            "// directly; hexa_file_* shims retired. rt_file_* are the SSOT (hand-port\n" +
            "// libc primitives — file I/O not meaningful to compose in .hexa).\n" +
            "HexaVal rt_read_file(HexaVal path);\n" +
            "HexaVal rt_write_file(HexaVal path, HexaVal content);\n" +
            "HexaVal rt_file_exists(HexaVal path);\n" +
            "HexaVal rt_write_bytes(HexaVal path, HexaVal arr);\n" +
            "HexaVal rt_write_bytes_v(HexaVal path, HexaVal arr);\n" +
            "HexaVal rt_read_file_bytes(HexaVal path);\n" +
            "HexaVal rt_read_bytes_at(HexaVal path, HexaVal offset, HexaVal nbytes);\n" +
            "HexaVal rt_write_bytes_append(HexaVal path, HexaVal arr);\n" +
            "HexaVal rt_write_bytes_append_v(HexaVal path, HexaVal arr);\n" +
            "HexaVal rt_file_size(HexaVal path);\n" +
            "HexaVal rt_read_lines(HexaVal path);\n" +
            "HexaVal rt_delete_file(HexaVal path);\n" +
            "HexaVal rt_append_file(HexaVal path, HexaVal content);\n" +
            "// M1 full · str_ext layer (hxa-20260423-003 Step 3/5): rt_str_* hand-port\n" +
            "// in runtime.c; hexa_str_* wrappers removed — codegen emits rt_str_*\n" +
            "// directly. ABI: rt_str_trim/trim_start/trim_end/to_upper/to_lower return\n" +
            "// HexaVal; rt_str_starts_with/ends_with return int (same as hexa_*).\n" +
            "HexaVal rt_str_trim(HexaVal s);\n" +
            "HexaVal rt_str_trim_start(HexaVal s);\n" +
            "HexaVal rt_str_trim_end(HexaVal s);\n" +
            "HexaVal rt_str_to_upper(HexaVal s);\n" +
            "HexaVal rt_str_to_lower(HexaVal s);\n" +
            "int rt_str_starts_with(HexaVal s, HexaVal prefix);\n" +
            "int rt_str_ends_with(HexaVal s, HexaVal suffix);\n" +
            "HexaVal hexa_str_split(HexaVal s, HexaVal delim);\n" +
            "HexaVal hexa_str_replace(HexaVal s, HexaVal old, HexaVal new_s);\n" +
            "HexaVal hexa_str_join(HexaVal arr, HexaVal sep);\n" +
            "HexaVal hexa_str_chars(HexaVal s);\n" +
            "HexaVal hexa_format_n(HexaVal fmt, HexaVal args);\n" +
            "HexaVal hexa_str_parse_int(HexaVal s);\n" +
            "HexaVal hexa_str_parse_float(HexaVal s);\n" +
            "HexaVal hexa_str_slice(HexaVal s, HexaVal start, HexaVal end);\n" +
            "HexaVal hexa_str_bytes(HexaVal s);\n" +
            "HexaVal hexa_array_slice(HexaVal arr, HexaVal start, HexaVal end);\n" +
            "HexaVal hexa_array_map(HexaVal arr, HexaVal fn);\n" +
            "HexaVal hexa_array_filter(HexaVal arr, HexaVal fn);\n" +
            "HexaVal hexa_array_fold(HexaVal arr, HexaVal init, HexaVal fn);\n" +
            "HexaVal hexa_array_index_of(HexaVal arr, HexaVal item);\n" +
            "HexaVal hexa_array_new(void);\n" +
            "HexaVal hexa_void(void);\n" +
            "HexaVal hexa_null_coal(HexaVal a, HexaVal b);\n" +
            "int hexa_is_type(HexaVal v, const char* type_name);\n" +
            "// rt 32-A: bulk struct constructor (see below for docstring).\n" +
            "HexaVal hexa_struct_pack_map(const char* type_name, int n,\n" +
            "                             const char* const* keys, const HexaVal* vals);\n" +
            "// rt 32-B: scratch-buffer primitives for reusable args vector (NK_CALL path).\n" +
            "HexaVal hexa_array_push_nostat(HexaVal arr, HexaVal item);\n" +
            "HexaVal hexa_val_snapshot_array(HexaVal v);  // rt#32-N forward decl\n" +
            "HexaVal hexa_array_shallow_clone(HexaVal v); // ROI #148 forward decl\n" +
            "HexaVal hexa_array_slice_fast(HexaVal arr, HexaVal start, HexaVal end);\n" +
            "HexaVal __hexa_range_array(HexaVal start, HexaVal end, int inclusive);\n" +
            "HexaVal hexa_matvec(HexaVal w, HexaVal x, HexaVal rows_v, HexaVal cols_v);\n" +
            "HexaVal hexa_math_abs(HexaVal x);\n" +
            "HexaVal hexa_math_sqrt(HexaVal x);\n" +
            "HexaVal hexa_math_floor(HexaVal x);\n" +
            "HexaVal hexa_math_ceil(HexaVal x);\n" +
            "HexaVal hexa_math_round(HexaVal x);\n" +
            "HexaVal hexa_math_pow(HexaVal b, HexaVal e);\n" +
            "// 2026-05-20 (blocker-3 fmod-shim): direct libm fmod() entry point.\n" +
            "HexaVal hexa_math_fmod(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_math_min(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_math_max(HexaVal a, HexaVal b);\n" +
            "// G1-FLOAT-PRIM 2026-05-06: Beta-Binomial Bayesian audit + calibration stability.\n" +
            "HexaVal hexa_math_lgamma(HexaVal x);\n" +
            "HexaVal hexa_math_isnan(HexaVal x);\n" +
            "HexaVal hexa_math_isinf(HexaVal x);\n" +
            "HexaVal hexa_math_isfinite(HexaVal x);\n" +
            "// FIX-A (Anima serving unblock): time_ms / byte_len / dict_keys builtin C syms.\n" +
            "HexaVal hexa_time_ms(void);\n" +
            "HexaVal hexa_byte_len(HexaVal v);\n" +
            "HexaVal hexa_dict_keys(HexaVal m);\n" +
            "// FIX-A (Anima ML eval unblock): 8 tensor_* fallback builtins.\n" +
            "HexaVal hexa_tensor_zeros(HexaVal n);\n" +
            "HexaVal hexa_tensor_slice(HexaVal a, HexaVal lo, HexaVal hi);\n" +
            "HexaVal hexa_tensor_add(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_tensor_dot(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_tensor_mul_scalar(HexaVal a, HexaVal s);\n" +
            "HexaVal hexa_rms_norm(HexaVal x, HexaVal gamma, HexaVal eps);\n" +
            "HexaVal hexa_softmax(HexaVal a);\n" +
            "HexaVal hexa_matmul(HexaVal a, HexaVal b, HexaVal m, HexaVal k, HexaVal n);\n" +
            "// FIX-A 2nd batch (2026-04-19): tensor_ones + swiglu_vec for anima serving/training.\n" +
            "HexaVal hexa_tensor_ones(HexaVal n);\n" +
            "HexaVal hexa_swiglu_vec(HexaVal gate, HexaVal up);\n" +
            "\n" +
            "// RT-P3-1 wrapper shims — tagged-value → C-native conversion for codegen regen\n" +
            "// path. Close Wint-conversion / Wpointer-arith categories in the\n" +
            "// interpreter.hexa → .c baseline. See self/runtime_hexaval_DESIGN.md\n" +
            "// §Production runtime (live).\n" +
            "int64_t     hexa_as_num(HexaVal v);\n" +
            "const char* hexa_to_cstring(HexaVal v);\n" +
            "const char* hexa_str_as_ptr(HexaVal v);\n" +
            "\n" +
            "// rt 32-G Phase 0: flat Val struct forward decls (implementation below).\n" +
            "// NOTE: parameter-less typedef stays outside so the struct body later in\n" +
            "// this file keeps using the same name. Function decls reference HexaVal\n" +
            "// (defined below) and the fully-defined HexaValStruct — OK because the C\n" +
            "// compiler only needs full types at call sites, not at forward decls.\n" +
            "typedef struct HexaValStruct HexaValStruct;\n" +
            "// Redesign: only the _v variant is exposed. All non-scalar arguments are\n" +
            "// passed as HexaVal so polymorphic payloads (closures, AST bodies, struct\n" +
            "// field maps) survive verbatim instead of being coerced to \"\".\n" +
            "HexaVal hexa_valstruct_new_v(HexaVal, HexaVal, HexaVal, HexaVal, HexaVal,\n" +
            "    HexaVal, HexaVal, HexaVal, HexaVal, HexaVal, HexaVal, HexaVal);\n" +
            "HexaVal hexa_valstruct_int(HexaVal v);\n" +
            "HexaVal hexa_valstruct_get_by_key(HexaVal v, const char* key);\n" +
            "HexaVal hexa_valstruct_set_by_key(HexaVal v, const char* key, HexaVal val);\n" +
            "\n" +
            "// rt#37: inline cache for obj.field — the struct is defined here so every\n" +
            "// generated C file (via #include \"runtime.c\") can declare `static HexaIC`\n" +
            "// slots. The lookup itself is defined below as `static inline`.\n" +
            "typedef struct HexaIC {\n" +
            "    void* keys_ptr;   // last-seen m.map.keys pointer (shape id)\n" +
            "    int   len;        // last-seen m.map.len\n" +
            "    int   idx;        // cached field offset\n" +
            "    uint64_t hits;\n" +
            "    uint64_t misses;\n" +
            "} HexaIC;\n" +
            "\n" +
            "// ── Tagged Value ─────────────────────────────────────────\n" +
            "// All HEXA values are represented as tagged unions (NaN-boxing alternative)\n" +
            "\n" +
            "typedef enum {\n" +
            "    TAG_INT = 0, TAG_FLOAT, TAG_BOOL, TAG_STR, TAG_VOID,\n" +
            "    TAG_ARRAY, TAG_MAP, TAG_FN, TAG_CHAR, TAG_CLOSURE,\n" +
            "    // rt 32-G Phase 0: flat C struct replacement for interpreter `Val` map.\n" +
            "    // Val is the interpreter's tagged value carrier — ~3.37M constructions\n" +
            "    // per d64 200-step run. Each map-backed Val = 1 map_new + 12 map_set =\n" +
            "    // 13 hash-table insertions. Replacing with a flat 12-field C struct\n" +
            "    // collapses that to a single heap alloc, eliminating 7GB+ RSS pressure.\n" +
            "    // Fields mirror `struct Val` in self/hexa_full.hexa exactly (12 fields).\n" +
            "    TAG_VALSTRUCT,\n" +
            "    // PR-2.0 (enum-to-string-codegen-emit RFC, stack PR-2/3, 2026-05-24):\n" +
            "    // dedicated tag for enum values. PR-2.0 reserves the slot + defensive\n" +
            "    // _hexa_to_string_rec/hexa_eq/hexa_type_of branches; no emitter\n" +
            "    // produces TAG_ENUM yet (gen2_enum_decl still emits `hexa_int(N)`).\n" +
            "    // Slot kept LAST so existing TAG_VALSTRUCT integer value is preserved\n" +
            "    // (no ABI shift on any pre-built object).\n" +
            "    TAG_ENUM\n" +
            "} HexaTag;\n" +
            "\n" +
            "// ── Optimization #10: Hash-map backing store ─────────────\n" +
            "// Open-addressing hash table (Robin Hood not needed at this scale).\n" +
            "// Stored on the heap; the HexaVal map union holds a pointer + len.\n" +
            "// Keeps a parallel insertion-order array for keys()/values()/iter.\n" +
            "\n" +
            "#define HMAP_INIT_CAP   16\n" +
            "#define HMAP_LOAD_MAX   75  // percent\n" +
            "\n" +
            "typedef struct {\n" +
            "    char*  key;       // owned string (strdup'd) -- NULL means empty slot\n" +
            "    uint32_t hash;    // cached FNV-1a of key\n" +
            "    int order_idx;    // ROI-24: index into order_keys/order_vals arrays — O(1) update\n" +
            "} HexaMapSlot;\n" +
            "\n" +
            "typedef struct {\n" +
            "    HexaMapSlot* slots;   // hash table (power-of-2 sized)\n" +
            "    HexaVal* vals;  // parallel values array (same indices as slots)\n" +
            "    int ht_cap;            // hash table capacity (power-of-2)\n" +
            "\n" +
            "    // Insertion-order arrays for keys()/values()/for-in iteration\n" +
            "    char** order_keys;     // ordered key pointers (point into slots[].key)\n" +
            "    HexaVal* order_vals; // ordered values\n" +
            "    int len;               // number of entries\n" +
            "    int order_cap;         // allocated capacity for order arrays\n" +
            "    // rt 32-L: Val-arena support. When non-zero, this table + its slot/val/\n" +
            "    // order arrays were allocated from the bump arena (NOT malloc). Such tables\n" +
            "    // MUST be heapified before they outlive the current scope; otherwise an\n" +
            "    // arena rewind invalidates the backing storage. Slots' .key strings are\n" +
            "    // ALWAYS strdup'd (heap) regardless of from_arena, because the arena is\n" +
            "    // bulk-rewound and per-string lifetime tracking is impractical here.\n" +
            "    int from_arena;\n" +
            "} HexaMapTable;\n" +
            "\n" +
            "// ── S1-D3a: Heap descriptor structs for compound types ───\n" +
            "// NaN-boxing prep: inline union members → heap-allocated descriptors.\n" +
            "// sizeof(HexaVal) unchanged (largest union member is still a pointer).\n" +
            "typedef struct HexaArr {\n" +
            "    HexaVal* items;\n" +
            "    int len;\n" +
            "    int cap;\n" +
            "} HexaArr;\n" +
            "\n" +
            "typedef struct HexaMap {\n" +
            "    HexaMapTable* tbl;\n" +
            "    int len;\n" +
            "} HexaMap;\n" +
            "\n" +
            "typedef struct HexaFn {\n" +
            "    void* fn_ptr;\n" +
            "    int arity;\n" +
            "} HexaFn;\n" +
            "\n" +
            "typedef struct HexaClo {\n" +
            "    void* fn_ptr;\n" +
            "    int arity;\n" +
            "    HexaVal* env_box;\n" +
            "} HexaClo;\n" +
            "\n" +
            "// HexaVal must be defined before HexaValStruct so that HexaValStruct's\n" +
            "// HexaVal-by-value fields (rt 32-G redesign) have a complete type. HexaVal\n" +
            "// only needs HexaValStruct as a *pointer* (.vs), so the forward decl above\n" +
            "// (typedef struct HexaValStruct HexaValStruct) is sufficient here.\n" +
            "typedef struct HexaVal_ {\n" +
            "    HexaTag tag;\n" +
            "    union {\n" +
            "        int64_t i;\n" +
            "        double f;\n" +
            "        int b;\n" +
            "        char* s;           // owned string (malloc'd)\n" +
            "        HexaArr* arr_ptr;  // S1-D3a: heap descriptor (was inline struct)\n" +
            "        HexaMap* map_ptr;  // S1-D3a: heap descriptor (was inline struct)\n" +
            "        HexaFn*  fn_ptr_d; // S1-D3a: heap descriptor (was inline struct)\n" +
            "        HexaClo* clo_ptr;  // S1-D3a: heap descriptor (was inline struct)\n" +
            "        // rt 32-G: heap-allocated flat struct pointer (TAG_VALSTRUCT).\n" +
            "        HexaValStruct* vs;\n" +
            "    };\n" +
            "} HexaVal;\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  STRUCTURAL-1 Phase A: NaN-boxing accessor macros\n" +
            "//  Current: identity-map to tagged union fields (zero-cost).\n" +
            "//  Phase B: macro bodies swap to NaN-boxed 8B representation.\n" +
            "//  All hot-path code MUST use these instead of raw .tag/.i/.f etc.\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "\n" +
            "#define HX_TAG(v)       ((v).tag)\n" +
            "#define HX_INT(v)       ((v).i)\n" +
            "#define HX_INT_U(v)     ((uint64_t)(v).i)   // unsigned read — safe for NaN-boxed pointers\n" +
            "#define HX_FLOAT(v)     ((v).f)\n" +
            "#define HX_BOOL(v)      ((v).b)\n" +
            "#define HX_STR(v)       ((v).s)\n" +
            "// S1-D3a: compound-type READ macros — dereference heap descriptors.\n" +
            "// IMPORTANT: caller MUST ensure the tag matches before calling these;\n" +
            "// they dereference the descriptor pointer unconditionally for performance.\n" +
            "// The one exception is HX_MAP_TBL which is guarded because the IC\n" +
            "// fast-path (hexa_map_get_ic) probes it before a tag check, and\n" +
            "// hexa_map_get probes it on TAG_VALSTRUCT-routed values.\n" +
            "#define HX_ARR_LEN(v)   ((v).arr_ptr->len)\n" +
            "#define HX_ARR_ITEMS(v) ((v).arr_ptr->items)\n" +
            "#define HX_ARR_CAP(v)   ((v).arr_ptr->cap)\n" +
            "#define HX_MAP_LEN(v)   ((v).map_ptr->len)\n" +
            "#define HX_MAP_TBL(v)   (HX_IS_MAP(v) ? (v).map_ptr->tbl : (HexaMapTable*)0)\n" +
            "#define HX_FN_PTR(v)    ((v).fn_ptr_d->fn_ptr)\n" +
            "#define HX_FN_ARITY(v)  ((v).fn_ptr_d->arity)\n" +
            "#define HX_CLO_PTR(v)   ((v).clo_ptr->fn_ptr)\n" +
            "#define HX_CLO_ARITY(v) ((v).clo_ptr->arity)\n" +
            "#define HX_CLO_ENV(v)   ((v).clo_ptr->env_box)\n" +
            "#define HX_VS(v)        ((v).vs)\n" +
            "\n" +
            "// ── S1-D3a: compound-type SET macros (write accessors) — heap descriptor ──\n" +
            "#define HX_SET_ARR_ITEMS(v, p) ((v).arr_ptr->items = (p))\n" +
            "#define HX_SET_ARR_LEN(v, n)   ((v).arr_ptr->len = (n))\n" +
            "#define HX_SET_ARR_CAP(v, n)   ((v).arr_ptr->cap = (n))\n" +
            "#define HX_SET_MAP_TBL(v, t)   ((v).map_ptr->tbl = (t))\n" +
            "#define HX_SET_MAP_LEN(v, n)   ((v).map_ptr->len = (n))\n" +
            "#define HX_SET_CLO_PTR(v, p)   ((v).clo_ptr->fn_ptr = (p))\n" +
            "#define HX_SET_CLO_ARITY(v, n) ((v).clo_ptr->arity = (n))\n" +
            "#define HX_SET_CLO_ENV(v, p)   ((v).clo_ptr->env_box = (p))\n" +
            "\n" +
            "// ── STRUCTURAL-1 Phase A: scalar + descriptor-pointer writer macros ──\n" +
            "// Prep for NaN-boxing typedef flip (HexaVal → uint64_t). Once callers route\n" +
            "// all writes through these macros, the macro bodies swap to encode-into-u64\n" +
            "// in one place. Struct-initializer literals ({.tag=T, .i=n}) are OUT OF SCOPE\n" +
            "// here — they need a different rewrite (constructor fns or the flip itself).\n" +
            "#define HX_SET_TAG(v, t)       ((v).tag = (t))\n" +
            "#define HX_SET_INT(v, n)       ((v).i = (n))\n" +
            "#define HX_SET_FLOAT(v, f)     ((v).f = (f))\n" +
            "#define HX_SET_BOOL(v, b)      ((v).b = (b))\n" +
            "#define HX_SET_STR(v, p)       ((v).s = (p))\n" +
            "#define HX_SET_ARR_PTR(v, p)   ((v).arr_ptr = (p))\n" +
            "#define HX_SET_MAP_PTR(v, p)   ((v).map_ptr = (p))\n" +
            "#define HX_SET_FN_PTR_D(v, p)  ((v).fn_ptr_d = (p))\n" +
            "#define HX_SET_CLO_PTR_D(v, p) ((v).clo_ptr = (p))\n" +
            "#define HX_SET_VS(v, p)        ((v).vs = (p))\n" +
            "\n" +
            "// HexaValStruct (inner) field access via v — routes through HX_VS so the\n" +
            "// typedef flip can adjust the .vs bits in one spot. The inner HexaValStruct\n" +
            "// remains a plain C struct — HX_VSF is pointer deref + member access.\n" +
            "#define HX_VSF(v, field)       (HX_VS(v)->field)\n" +
            "\n" +
            "#define HX_IS_INT(v)    ((v).tag == TAG_INT)\n" +
            "#define HX_IS_FLOAT(v)  ((v).tag == TAG_FLOAT)\n" +
            "#define HX_IS_BOOL(v)   ((v).tag == TAG_BOOL)\n" +
            "#define HX_IS_STR(v)    ((v).tag == TAG_STR)\n" +
            "#define HX_IS_VOID(v)   ((v).tag == TAG_VOID)\n" +
            "#define HX_IS_ARRAY(v)  ((v).tag == TAG_ARRAY)\n" +
            "#define HX_IS_MAP(v)    ((v).tag == TAG_MAP)\n" +
            "#define HX_IS_FN(v)     ((v).tag == TAG_FN)\n" +
            "#define HX_IS_CLOSURE(v)((v).tag == TAG_CLOSURE)\n" +
            "#define HX_IS_VALSTRUCT(v) ((v).tag == TAG_VALSTRUCT)\n" +
            "\n" +
            "// rt 32-G Phase 0 (redesigned): flat C struct replacement for `Val` map.\n" +
            "// Fields MUST mirror self/hexa_full.hexa `struct Val` exactly (order + types).\n" +
            "// Heap-allocated once per Val construction, shared by value via pointer copy\n" +
            "// of the containing HexaVal (no deep copy — mirrors current map.tbl pointer\n" +
            "// sharing semantics). Lifetime: leak-compatible with current interpreter\n" +
            "// (no free, same as existing map-backed Vals).\n" +
            "//\n" +
            "// REDESIGN (rt 32-G Phase 0 redesign): non-scalar fields are now full HexaVal\n" +
            "// (polymorphic tagged union) instead of `const char*`. The original Phase 0\n" +
            "// design assumed every non-scalar slot held a string, but val_fn / val_closure\n" +
            "// store TAG_ARRAY (params) and TAG_MAP (AST body) values. The old design\n" +
            "// silently coerced those to \"\" → closure body erased after rebootstrap.\n" +
            "// HexaVal-by-value adds ~24B per slot but eliminates the data loss.\n" +
            "typedef struct HexaValStruct {\n" +
            "    int64_t tag_i;          // Hexa-level Val.tag (TAG_INT / TAG_FLOAT / ...)\n" +
            "    int64_t int_val;\n" +
            "    double  float_val;\n" +
            "    int     bool_val;\n" +
            "    // rt 32-L: 1 = allocated from the bump arena, 0 = malloc heap. Arena\n" +
            "    // VALSTRUCTs MUST be heapified before they outlive the current scope.\n" +
            "    // Sits in the alignment padding between bool_val (4B) and the first\n" +
            "    // HexaVal (24B aligned to 8) — zero size cost in practice.\n" +
            "    int     from_arena;\n" +
            "    // Polymorphic slots — store the original HexaVal verbatim. For TAG_STR\n" +
            "    // payloads this is just s/tag; for arrays/maps the .arr / .map / .vs\n" +
            "    // member survives intact. Empty/missing fields use TAG_VOID.\n" +
            "    HexaVal str_val;\n" +
            "    HexaVal char_val;\n" +
            "    HexaVal array_val;     // crucial for AST body propagation\n" +
            "    HexaVal fn_name;\n" +
            "    HexaVal fn_params;     // TAG_ARRAY (closure param list)\n" +
            "    HexaVal fn_body;       // TAG_MAP / TAG_ARRAY (AST body)\n" +
            "    HexaVal struct_name;\n" +
            "    HexaVal struct_fields; // TAG_MAP (struct field map)\n" +
            "} HexaValStruct;\n" +
            "\n" +
            "// ── C3 Closure helpers ───────────────────────────────────\n" +
            "// Build a closure value. Captured values are provided as an already-built\n" +
            "// TAG_ARRAY HexaVal; we heap-box it so the closure remains valid after copies.\n" +
            "// NOTE: extern (not `static inline`) — the aprime_cc separate-compilation path\n" +
            "// links test programs against a standalone runtime.o, and closure codegen\n" +
            "// emits `bl _hexa_closure_new`; an internal-linkage definition is invisible\n" +
            "// across that TU boundary. The runtime.h copy stays `static inline` for\n" +
            "// header-only includers (no conflict — runtime.c does not include runtime.h).\n" +
            "HexaVal hexa_closure_new(void* fn_ptr, int arity, HexaVal env_arr) {\n" +
            "    HexaVal v = {.tag=TAG_CLOSURE};\n" +
            "    HX_SET_CLO_PTR_D(v, (HexaClo*)calloc(1, sizeof(HexaClo)));\n" +
            "    HX_SET_CLO_PTR(v, fn_ptr);\n" +
            "    HX_SET_CLO_ARITY(v, arity);\n" +
            "    HX_SET_CLO_ENV(v, (HexaVal*)malloc(sizeof(HexaVal)));\n" +
            "    *HX_CLO_ENV(v) = env_arr;\n" +
            "    // H03 B25: count closure descriptor allocs + LRU dup signal (pool-reuse\n" +
            "    // opportunity — same fn_ptr seen recently → cache would have hit).\n" +
            "    if (_hx_stats_on()) {\n" +
            "        _hx_stats_closure_alloc++;\n" +
            "        if (_hx_stats_lru_check(_hx_stats_clo_lru, &_hx_stats_clo_lru_pos, fn_ptr)) {\n" +
            "            _hx_stats_clo_alloc_dup++;\n" +
            "        }\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "// S1-D2: NaN-boxing-safe constructor for TAG_FN values.\n" +
            "// S1-D3a: allocates HexaFn heap descriptor (was inline .fn={...} struct literal).\n" +
            "static inline HexaVal hexa_fn_new(void* fn_ptr, int arity) {\n" +
            "    HexaVal v = {.tag=TAG_FN};\n" +
            "    HX_SET_FN_PTR_D(v, (HexaFn*)calloc(1, sizeof(HexaFn)));\n" +
            "    HX_FN_PTR(v) = fn_ptr;\n" +
            "    HX_FN_ARITY(v) = arity;\n" +
            "    // H03 B25: count fn descriptor allocs + LRU dup signal.\n" +
            "    if (_hx_stats_on()) {\n" +
            "        _hx_stats_fn_alloc++;\n" +
            "        if (_hx_stats_lru_check(_hx_stats_fn_lru, &_hx_stats_fn_lru_pos, fn_ptr)) {\n" +
            "            _hx_stats_fn_alloc_dup++;\n" +
            "        }\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "static inline HexaVal hexa_closure_env(HexaVal c) {\n" +
            "    if (!HX_IS_CLOSURE(c) || !HX_CLO_ENV(c)) return hexa_array_new();\n" +
            "    return *HX_CLO_ENV(c);\n" +
            "}\n" +
            "\n" +
            "// PROBE r12 #17: calling a non-fn / non-closure value used to silently\n" +
            "// return void → hides type errors like `42()` or `let x = nil; x()`.\n" +
            "// Throw with the actual tag so the user sees \"you called an int\" not\n" +
            "// a mystery void result.  hexa_throw routes through try/catch.\n" +
            "// PROBE r14-D unblock: forward-decl hexa_throw / hexa_str — both are\n" +
            "// defined later in this TU (lines ~1374 / ~2003) and would otherwise hit\n" +
            "// `-Werror=implicit-function-declaration` under modern clang.\n" +
            "extern HexaVal hexa_str(const char* s);\n" +
            "extern void hexa_throw(HexaVal err);\n" +
            "static void __hexa_call_non_fn_throw(int tag, int arity) {\n" +
            "    char _buf[128];\n" +
            "    snprintf(_buf, sizeof(_buf), \"not callable: tag=%d (arity=%d)\", tag, arity);\n" +
            "    hexa_throw(hexa_str(_buf));\n" +
            "}\n" +
            "\n" +
            "// Dispatched call helpers — one per arity we support (0..4).\n" +
            "static inline HexaVal hexa_call0(HexaVal f) {\n" +
            "    if (HX_IS_CLOSURE(f)) {\n" +
            "        HexaVal (*fp)(HexaVal) = (HexaVal(*)(HexaVal))HX_CLO_PTR(f);\n" +
            "        return fp(hexa_closure_env(f));\n" +
            "    }\n" +
            "    if (HX_IS_FN(f)) {\n" +
            "        HexaVal (*fp)(void) = (HexaVal(*)(void))HX_FN_PTR(f);\n" +
            "        return fp();\n" +
            "    }\n" +
            "    __hexa_call_non_fn_throw((int)HX_TAG(f), 0);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "static inline HexaVal hexa_call1_hv(HexaVal f, HexaVal a1) {\n" +
            "    if (HX_IS_CLOSURE(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal))HX_CLO_PTR(f);\n" +
            "        return fp(hexa_closure_env(f), a1);\n" +
            "    }\n" +
            "    if (HX_IS_FN(f)) {\n" +
            "        HexaVal (*fp)(HexaVal) = (HexaVal(*)(HexaVal))HX_FN_PTR(f);\n" +
            "        return fp(a1);\n" +
            "    }\n" +
            "    __hexa_call_non_fn_throw((int)HX_TAG(f), 1);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "// Raw C function-pointer overload (KI-4 fix 2026-05-01): codegen emits\n" +
            "// `hexa_call1(exec_stream_async, cmd)` with raw symbol. _Generic dispatches\n" +
            "// to the function-pointer path; HexaVal path keeps original lowering.\n" +
            "static inline HexaVal __hexa_call1_fp1(HexaVal (*fp)(HexaVal), HexaVal a1) {\n" +
            "    return fp(a1);\n" +
            "}\n" +
            "#define hexa_call1(f, a1) _Generic((f), \\\n" +
            "    HexaVal: hexa_call1_hv, \\\n" +
            "    HexaVal (*)(HexaVal): __hexa_call1_fp1, \\\n" +
            "    default: hexa_call1_hv)((f), (a1))\n" +
            "static inline HexaVal hexa_call2_hv(HexaVal f, HexaVal a1, HexaVal a2) {\n" +
            "    if (HX_IS_CLOSURE(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal))HX_CLO_PTR(f);\n" +
            "        return fp(hexa_closure_env(f), a1, a2);\n" +
            "    }\n" +
            "    if (HX_IS_FN(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal))HX_FN_PTR(f);\n" +
            "        return fp(a1, a2);\n" +
            "    }\n" +
            "    __hexa_call_non_fn_throw((int)HX_TAG(f), 2);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "// Raw C function-pointer overload (FIX-2 unblock 2026-05-04): mirrors the\n" +
            "// hexa_call1 _Generic pattern so codegen emitting `hexa_call2(bytes_to_f32_le,\n" +
            "// arr, off)` from a precompiled hexat (which doesn't know the symbol is a\n" +
            "// builtin) resolves to the direct C function call. Without this, the call\n" +
            "// goes through hexa_call2_hv expecting a HexaVal first arg and fails to link.\n" +
            "static inline HexaVal __hexa_call2_fp2(HexaVal (*fp)(HexaVal, HexaVal), HexaVal a1, HexaVal a2) {\n" +
            "    return fp(a1, a2);\n" +
            "}\n" +
            "#define hexa_call2(f, a1, a2) _Generic((f), \\\n" +
            "    HexaVal: hexa_call2_hv, \\\n" +
            "    HexaVal (*)(HexaVal, HexaVal): __hexa_call2_fp2, \\\n" +
            "    default: hexa_call2_hv)((f), (a1), (a2))\n" +
            "static inline HexaVal hexa_call3(HexaVal f, HexaVal a1, HexaVal a2, HexaVal a3) {\n" +
            "    if (HX_IS_CLOSURE(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal, HexaVal))HX_CLO_PTR(f);\n" +
            "        return fp(hexa_closure_env(f), a1, a2, a3);\n" +
            "    }\n" +
            "    if (HX_IS_FN(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal))HX_FN_PTR(f);\n" +
            "        return fp(a1, a2, a3);\n" +
            "    }\n" +
            "    __hexa_call_non_fn_throw((int)HX_TAG(f), 3);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "static inline HexaVal hexa_call4(HexaVal f, HexaVal a1, HexaVal a2, HexaVal a3, HexaVal a4) {\n" +
            "    if (HX_IS_CLOSURE(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal, HexaVal, HexaVal))HX_CLO_PTR(f);\n" +
            "        return fp(hexa_closure_env(f), a1, a2, a3, a4);\n" +
            "    }\n" +
            "    if (HX_IS_FN(f)) {\n" +
            "        HexaVal (*fp)(HexaVal, HexaVal, HexaVal, HexaVal) = (HexaVal(*)(HexaVal, HexaVal, HexaVal, HexaVal))HX_FN_PTR(f);\n" +
            "        return fp(a1, a2, a3, a4);\n" +
            "    }\n" +
            "    __hexa_call_non_fn_throw((int)HX_TAG(f), 4);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "\n" +
            "// ── Constructors ─────────────────────────────────────────\n" +
            "\n" +
            "// F3 ACTIVATION RUNBOOK · Path A — HexaVal struct-return ctor self-emit slots\n" +
            "// (B9.6 class-D, the FIRST x0:x1 register-pair self-emit increment).\n" +
            "//\n" +
            "// Each of hexa_int / hexa_bool / hexa_void returns a 16-byte HexaVal BY VALUE;\n" +
            "// on AAPCS arm64 that is the x0:x1 register PAIR (NRRP — no hidden x8 pointer).\n" +
            "// x0 = the tag (low 8 B), x1 = the union value (high 8 B). Every prior\n" +
            "// self-emit leaf returns a single x0 scalar — these are the first emitters\n" +
            "// of the struct-return sequence, the infra that unblocks the ~350-450\n" +
            "// HexaVal-producing class-D primitives.\n" +
            "//\n" +
            "// DEFAULT build (HEXA_RT_SELFEMIT undefined): the direct C aggregate-literal\n" +
            "// bodies below are used — clang inlines them at internal call sites and the\n" +
            "// driver/module_loader extern set is UNCHANGED (0-libc-extern invariant; these\n" +
            "// were never libc symbols). This is the unchanged behavior.\n" +
            "//\n" +
            "// SELF-EMIT build (HEXA_RT_SELFEMIT defined): each becomes an `extern`\n" +
            "// declaration (no body here); the strong external `_hexa_int` / `_hexa_bool`\n" +
            "// / `_hexa_void` symbols are provided by the hexa-emitted Mach-O .o\n" +
            "// (test/native_build/emit_hexa_val_ctors_o.hexa → rt_hexa_void/int/bool's\n" +
            "// 12-byte x0:x1 sequences), ahead-linked. ld64 binds every callsite to the\n" +
            "// self-emitted bytes — verified byte-identical to `as -arch arm64` AND\n" +
            "// JIT-exec-correct (the returned {tag,value} reads back correct for all\n" +
            "// inputs incl. INT64_MIN/MAX, bool 0/1; see the emit driver's §HONESTY).\n" +
            "//\n" +
            "// B9.6-D2 scale-out: hexa_float / hexa_enum_str / hexa_enum_str_v JOIN the\n" +
            "// self-emit set (see runtime_arm64.hexa rt_hexa_float / rt_hexa_enum_str /\n" +
            "// rt_hexa_enum_str_v + the extended emit_hexa_val_ctors_o.hexa bundle).\n" +
            "//   hexa_float      : fmov x1,d0 / mov w0,#1  / ret  (FP-arg d0 -> x1 raw bits)\n" +
            "//   hexa_enum_str   : mov x1,x0  / mov w0,#11 / ret  (ptr stored verbatim, no malloc)\n" +
            "//   hexa_enum_str_v : mov x1,x0  / mov w0,#11 / ret  (byte-identical to enum_str)\n" +
            "// Each is JIT-exec verified (returned {tag,value} correct for all inputs incl.\n" +
            "// float NaN/Inf/±0/DBL_MAX/MIN + NULL/literal pointers) — the x0:x1 (and\n" +
            "// fmov-bridged x1) struct-return ABI is correct at runtime, not just byte-equal.\n" +
            "#ifdef HEXA_RT_SELFEMIT\n" +
            "extern HexaVal hexa_int(int64_t n);\n" +
            "#else\n" +
            "HexaVal hexa_int(int64_t n) { return (HexaVal){.tag=TAG_INT, .i=n}; }\n" +
            "#endif\n" +
            "#ifdef HEXA_RT_SELFEMIT\n" +
            "extern HexaVal hexa_float(double f);\n" +
            "#else\n" +
            "HexaVal hexa_float(double f) { return (HexaVal){.tag=TAG_FLOAT, .f=f}; }\n" +
            "#endif\n" +
            "#ifdef HEXA_RT_SELFEMIT\n" +
            "extern HexaVal hexa_bool(int b);\n" +
            "#else\n" +
            "HexaVal hexa_bool(int b) { return (HexaVal){.tag=TAG_BOOL, .b=b}; }\n" +
            "#endif\n" +
            "#ifdef HEXA_RT_SELFEMIT\n" +
            "extern HexaVal hexa_void(void);\n" +
            "#else\n" +
            "HexaVal hexa_void() { return (HexaVal){.tag=TAG_VOID}; }\n" +
            "#endif\n" +
            "\n" +
            "// PR-2.1 (enum-to-string-codegen-emit RFC, stack PR-2/3, 2026-05-24): live\n" +
            "// constructor for a single migrated unit-variant enum (Direction). `display`\n" +
            "// is the codegen-emitted \"<Type>::<Variant>\" string literal (e.g.\n" +
            "// \"Direction::Left\"); it is stored in the `.s` slot so `_hexa_to_string_rec`\n" +
            "// renders it directly and `hexa_eq` compares it. Pointer is a read-only\n" +
            "// static literal — never freed (matches the wider runtime no-free contract).\n" +
            "// PR-2.2 will widen the codegen gate to all unit-variant enums; PR-3 will\n" +
            "// switch the renderer to the `__enum_<Name>_names[]` table (#555) once the\n" +
            "// per-variant (type_id, variant_idx) carrier lands.\n" +
            "#ifdef HEXA_RT_SELFEMIT\n" +
            "extern HexaVal hexa_enum_str(const char* display);\n" +
            "#else\n" +
            "HexaVal hexa_enum_str(const char* display) { return (HexaVal){.tag=TAG_ENUM, .s=(char*)display}; }\n" +
            "#endif\n" +
            "\n" +
            "// PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): TAG_ENUM descriptor — codegen\n" +
            "// emits one static const HexaEnumDesc per variant, and the `#define <Name>_<V>`\n" +
            "// expands to `hexa_enum_str_v(&__enum_desc_<Name>_<V>)`. `.s` slot of the\n" +
            "// returned HexaVal points at the descriptor; the renderer + eq paths route\n" +
            "// through `_hexa_enum_display` / `_hexa_enum_idx` helpers which check the\n" +
            "// magic sentinel to distinguish descriptor pointers from legacy bare-display\n" +
            "// pointers (`hexa_enum_str(display)`) so both forms remain valid simultaneously.\n" +
            "//\n" +
            "// magic = 0x484E5544U (\"DUNH\" — Descriptor of Unit-variant eNum, Hexa) — chosen\n" +
            "// because no ASCII printable string starts with these 4 bytes in\n" +
            "// little-endian, so probing `*(uint32_t*)p == magic` reliably distinguishes\n" +
            "// descriptor-from-bare. Layout: magic FIRST so the same probe works on any\n" +
            "// future descriptor extension.\n" +
            "#define HEXA_ENUM_DESC_MAGIC 0x484E5544U\n" +
            "typedef struct HexaEnumDesc {\n" +
            "    uint32_t    magic;       // = HEXA_ENUM_DESC_MAGIC, identifies descriptor\n" +
            "    uint32_t    variant_idx; // 0-based declaration order\n" +
            "    const char* display;     // \"<Type>::<Variant>\"\n" +
            "    const char* type_name;   // \"<Type>\" (display prefix, no \"::\") — same-enum gate\n" +
            "} HexaEnumDesc;\n" +
            "\n" +
            "#ifdef HEXA_RT_SELFEMIT\n" +
            "extern HexaVal hexa_enum_str_v(const HexaEnumDesc* desc);\n" +
            "#else\n" +
            "HexaVal hexa_enum_str_v(const HexaEnumDesc* desc) {\n" +
            "    return (HexaVal){.tag=TAG_ENUM, .s=(char*)desc};\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Internal helpers. Descriptor pointers begin with HEXA_ENUM_DESC_MAGIC (a\n" +
            "// 4-byte sentinel). Legacy bare-string pointers begin with a printable ASCII\n" +
            "// byte (e.g. \"Color::Red\" → 'C' = 0x43); the magic's low byte is 0x44 ('D'),\n" +
            "// so we use the full 4-byte uint32 probe — guaranteed mismatch against any\n" +
            "// real string literal that doesn't itself start with the exact sequence\n" +
            "// \"DNHU\" (no such display literal because we emit \"<Type>::<Variant>\").\n" +
            "static inline int _hexa_enum_is_desc(HexaVal v) {\n" +
            "    const void* p = (const void*)HX_STR(v);\n" +
            "    if (!p) return 0;\n" +
            "    // Misaligned bare-string pointer would crash a 4-byte read on strict-\n" +
            "    // alignment ISAs; descriptor pointers come from `static const HexaEnumDesc`\n" +
            "    // which the C compiler 4B-aligns. Use memcpy for safety.\n" +
            "    uint32_t first4 = 0;\n" +
            "    hxlcl_memcpy(&first4, p, 4);\n" +
            "    return first4 == HEXA_ENUM_DESC_MAGIC;\n" +
            "}\n" +
            "\n" +
            "static inline const char* _hexa_enum_display(HexaVal v) {\n" +
            "    if (!HX_STR(v)) return \"<enum>\";\n" +
            "    if (_hexa_enum_is_desc(v)) return ((const HexaEnumDesc*)HX_STR(v))->display;\n" +
            "    return HX_STR(v); // legacy bare display\n" +
            "}\n" +
            "\n" +
            "static inline int64_t _hexa_enum_idx(HexaVal v) {\n" +
            "    if (!HX_STR(v) || !_hexa_enum_is_desc(v)) return -1;\n" +
            "    return (int64_t)((const HexaEnumDesc*)HX_STR(v))->variant_idx;\n" +
            "}\n" +
            "\n" +
            "static inline const char* _hexa_enum_type_name(HexaVal v) {\n" +
            "    if (!HX_STR(v) || !_hexa_enum_is_desc(v)) return NULL;\n" +
            "    return ((const HexaEnumDesc*)HX_STR(v))->type_name;\n" +
            "}\n" +
            "\n" +
            "// T32: unwrap a HexaVal (possibly VALSTRUCT-wrapped by the interpreter) into\n" +
            "// a raw C double. The prior inline `v.tag==TAG_FLOAT?v.f:(double)v.i` read\n" +
            "// only the outer tag, so interpreter values (which carry TAG_VALSTRUCT with\n" +
            "// the real tag in vs->tag_i) fell through and cast the vs pointer bits to\n" +
            "// double — producing garbage. Centralising here lets to_float / exp / sin /\n" +
            "// cos / log / log10 / round share one correct unwrap.\n" +
            "/* PHASE 1.2.B (2026-05-15): de-staticized. Was `static inline`; runtime.h-built\n" +
            " * user.c needs cross-TU access for hexa_add_slow + float arithmetic. Loses\n" +
            " * inlining for cross-TU callers — acceptable (cold-ish path). */\n" +
            "double __hx_to_double(HexaVal v) {\n" +
            "    if (HX_IS_FLOAT(v)) return HX_FLOAT(v);\n" +
            "    if (HX_IS_INT(v))   return (double)HX_INT(v);\n" +
            "    // Bool → numeric coercion (Python canonical: True=1, False=0).  Without\n" +
            "    // this, `true * 5` fell through to `return 0.0` → silently `0`.  The\n" +
            "    // sibling static `_hexa_f` (runtime.c:4474) already had this branch for\n" +
            "    // the math family; aligning the slow path here.  Round-7 probe finding.\n" +
            "    if (HX_IS_BOOL(v))  return HX_BOOL(v) ? 1.0 : 0.0;\n" +
            "    // ComptimeConst eval: to_float(\"3.14\") at compile time needs string parsing.\n" +
            "    // Without this branch, returned 0.0, silently producing wrong constants.\n" +
            "    // atof handles both ints and floats correctly (\"3\" → 3.0, \"3.14\" → 3.14).\n" +
            "    if (HX_IS_STR(v) && HX_STR(v))   return hxlcl_atof(HX_STR(v));\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        if (HX_VSF(v, tag_i) == TAG_FLOAT) return HX_VSF(v, float_val);\n" +
            "        if (HX_VSF(v, tag_i) == TAG_INT)   return (double)HX_VSF(v, int_val);\n" +
            "    }\n" +
            "    return 0.0;\n" +
            "}\n" +
            "\n" +
            "// RT-P3-1 wrapper shims. Non-owning returns; cstring/str_as_ptr use static\n" +
            "// thread-unsafe buffers for scalar formatting — callers that persist the\n" +
            "// pointer beyond the next scalar-path call MUST copy.\n" +
            "int64_t hexa_as_num(HexaVal v) {\n" +
            "    if (HX_IS_INT(v))   return HX_INT(v);\n" +
            "    if (HX_IS_FLOAT(v)) return (int64_t)HX_FLOAT(v);\n" +
            "    if (HX_IS_BOOL(v))  return (int64_t)HX_BOOL(v);\n" +
            "    // P39 fix: auto-detect 0x/0X prefix in string coercion\n" +
            "    if (HX_IS_STR(v) && HX_STR(v)) {\n" +
            "        const char* cs = HX_STR(v); const char* p = cs;\n" +
            "        if (*p == '+' || *p == '-') p++;\n" +
            "        int base = (p[0] == '0' && (p[1] == 'x' || p[1] == 'X')) ? 16 : 10;\n" +
            "        return hxlcl_strtoll(cs, NULL, base);\n" +
            "    }\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        if (HX_VSF(v, tag_i) == TAG_INT)   return HX_VSF(v, int_val);\n" +
            "        if (HX_VSF(v, tag_i) == TAG_FLOAT) return (int64_t)HX_VSF(v, float_val);\n" +
            "        if (HX_VSF(v, tag_i) == TAG_BOOL)  return (int64_t)HX_VSF(v, bool_val);\n" +
            "        if (HX_VSF(v, tag_i) == TAG_STR && HX_STR(HX_VSF(v, str_val))) {\n" +
            "            const char* cs = HX_STR(HX_VSF(v, str_val)); const char* p = cs;\n" +
            "            if (*p == '+' || *p == '-') p++;\n" +
            "            int base = (p[0] == '0' && (p[1] == 'x' || p[1] == 'X')) ? 16 : 10;\n" +
            "            return hxlcl_strtoll(cs, NULL, base);\n" +
            "        }\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "const char* hexa_to_cstring(HexaVal v) {\n" +
            "    if (HX_IS_STR(v) && HX_STR(v)) return HX_STR(v);\n" +
            "    if (HX_IS_VOID(v)) return \"void\";\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        if (HX_VSF(v, tag_i) == TAG_STR && HX_STR(HX_VSF(v, str_val))) return HX_STR(HX_VSF(v, str_val));\n" +
            "        static char vbuf[64];\n" +
            "        if (HX_VSF(v, tag_i) == TAG_INT)   { snprintf(vbuf, 64, \"%lld\", (long long)HX_VSF(v, int_val)); return vbuf; }\n" +
            "        if (HX_VSF(v, tag_i) == TAG_FLOAT) {\n" +
            "            // trk.27 fix 2026-05-06: preserve `.0` for whole-valued floats (Val struct fast path).\n" +
            "            double f = HX_VSF(v, float_val);\n" +
            "            if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n" +
            "                snprintf(vbuf, 64, \"%.1f\", f);\n" +
            "            } else {\n" +
            "                snprintf(vbuf, 64, \"%g\", f);\n" +
            "            }\n" +
            "            return vbuf;\n" +
            "        }\n" +
            "        if (HX_VSF(v, tag_i) == TAG_BOOL)  return HX_VSF(v, bool_val) ? \"true\" : \"false\";\n" +
            "    }\n" +
            "    static char buf[64];\n" +
            "    if (HX_IS_INT(v))   { snprintf(buf, 64, \"%lld\", (long long)HX_INT(v)); return buf; }\n" +
            "    if (HX_IS_FLOAT(v)) {\n" +
            "        // trk.27 fix 2026-05-06: preserve `.0` for whole-valued floats (HexaVal fast path).\n" +
            "        double f = HX_FLOAT(v);\n" +
            "        if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n" +
            "            snprintf(buf, 64, \"%.1f\", f);\n" +
            "        } else {\n" +
            "            snprintf(buf, 64, \"%g\", f);\n" +
            "        }\n" +
            "        return buf;\n" +
            "    }\n" +
            "    if (HX_IS_BOOL(v))  return HX_BOOL(v) ? \"true\" : \"false\";\n" +
            "    // 2026-04-20 silent-fallback audit: prior code returned the literal\n" +
            "    // \"<value>\" for TAG_ARRAY / TAG_MAP / TAG_FN / TAG_CHAR / TAG_CLOSURE.\n" +
            "    // Callers include codegen-emitted `map.has/get/set(k)` paths and FFI\n" +
            "    // entry points (net.c) — a literal \"<value>\" string silently collides\n" +
            "    // across every bad callsite (all array/map/fn keys hash to the same\n" +
            "    // bucket). Delegate to hexa_to_string for a structural repr that at\n" +
            "    // least preserves distinctness (\"[1, 2]\" != \"[3, 4]\") and surface the\n" +
            "    // root cause in logs rather than corrupting the map. The returned\n" +
            "    // pointer points into the intern table (hexa_to_string → hexa_str),\n" +
            "    // so lifetime matches the legacy static-buf contract for callers that\n" +
            "    // treat the result as short-lived.\n" +
            "    HexaVal s = hexa_to_string(v);\n" +
            "    if (HX_IS_STR(s) && HX_STR(s)) return HX_STR(s);\n" +
            "    return \"<value>\";\n" +
            "}\n" +
            "\n" +
            "const char* hexa_str_as_ptr(HexaVal v) {\n" +
            "    if (HX_IS_STR(v) && HX_STR(v)) return HX_STR(v);\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v) && HX_VSF(v, tag_i) == TAG_STR && HX_STR(HX_VSF(v, str_val)))\n" +
            "        return HX_STR(HX_VSF(v, str_val));\n" +
            "    return NULL;\n" +
            "}\n" +
            "\n" +
            "// Null coalescing: a ?? b — if a is void or empty string, return b\n" +
            "HexaVal hexa_null_coal(HexaVal a, HexaVal b) {\n" +
            "    if (HX_IS_VOID(a)) return b;\n" +
            "    if (HX_IS_STR(a) && (HX_STR(a) == NULL || HX_STR(a)[0] == '\\0')) return b;\n" +
            "    return a;\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_str(const char* s) {\n" +
            "    HexaVal v = {.tag=TAG_STR};\n" +
            "    // Optimization #11: intern short strings for pointer-equality comparison\n" +
            "    const char* interned = hexa_intern(s);\n" +
            "    if (interned) {\n" +
            "        HX_SET_STR(v, (char*)interned);  // owned by intern table, not caller\n" +
            "    } else {\n" +
            "        // Long/unique strings: header-allocate so HX_STRLEN is O(1) instead of strlen.\n" +
            "        size_t slen = hxlcl_strlen(s);\n" +
            "        HX_SET_STR(v, hexa_strbuf_dup_n(s, slen));\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "// Take ownership of a malloc'd-or-arena'd C string. Backward-compat shim\n" +
            "// that transparently rewraps `s` into a header-allocated buffer so\n" +
            "// HX_STRLEN is O(1) on the resulting value. The input `s` is intentionally\n" +
            "// NOT freed — callers (notably hexa_concat under arena_on) may pass arena-\n" +
            "// allocated buffers where free() would be UB, and the wider runtime leaks\n" +
            "// strings by design (zero free(HX_STR(...)) call sites repo-wide). Hot\n" +
            "// allocators that know `len` upfront should call hexa_str_own_with_len()\n" +
            "// to skip the input strlen.\n" +
            "HexaVal hexa_str_own(char* s) {\n" +
            "    if (!s) return (HexaVal){.tag=TAG_STR, .s=NULL};\n" +
            "    size_t len = hxlcl_strlen(s);\n" +
            "    char* buf = hexa_strbuf_dup_n(s, len);\n" +
            "    return (HexaVal){.tag=TAG_STR, .s=buf};\n" +
            "}\n" +
            "\n" +
            "// Length-known fast path. Same leak semantics as hexa_str_own.\n" +
            "HexaVal hexa_str_own_with_len(char* s, size_t len) {\n" +
            "    if (!s) return (HexaVal){.tag=TAG_STR, .s=NULL};\n" +
            "    char* buf = hexa_strbuf_dup_n(s, len);\n" +
            "    return (HexaVal){.tag=TAG_STR, .s=buf};\n" +
            "}\n" +
            "\n" +
            "// Even faster path: skip the input copy entirely. Caller writes directly\n" +
            "// into the returned data buffer (size `len`), then wraps via hexa_str_own_buf.\n" +
            "// `data` MUST be a pointer returned by hexa_strbuf_alloc(len).\n" +
            "static inline HexaVal hexa_str_own_buf(char* data) {\n" +
            "    return (HexaVal){.tag=TAG_STR, .s=data};\n" +
            "}\n" +
            "\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "//  ROI-33: Pre-interned string cache\n" +
            "//  \"true\",\"false\",\"void\" (+ type_of strings) are used on every\n" +
            "//  hexa_to_string / hexa_type_of call.  Cache them as static\n" +
            "//  HexaVal so we skip strlen+hash+probe entirely.\n" +
            "//  Lazy-init on first access (no constructor needed).\n" +
            "// ═══════════════════════════════════════════════════════════\n" +
            "\n" +
            "static HexaVal _cached_str_true;\n" +
            "static HexaVal _cached_str_false;\n" +
            "static HexaVal _cached_str_void;\n" +
            "static HexaVal _cached_str_int;\n" +
            "static HexaVal _cached_str_float;\n" +
            "static HexaVal _cached_str_bool;\n" +
            "static HexaVal _cached_str_string;\n" +
            "static HexaVal _cached_str_array;\n" +
            "static HexaVal _cached_str_map;\n" +
            "static HexaVal _cached_str_struct;\n" +
            "static HexaVal _cached_str_fn;\n" +
            "static HexaVal _cached_str_char;\n" +
            "static HexaVal _cached_str_closure;\n" +
            "static HexaVal _cached_str_unknown;\n" +
            "static HexaVal _cached_str_value;  // \"<value>\" fallback\n" +
            "// PR-2.0 (enum-to-string-codegen-emit RFC, 2026-05-24): cached \"enum\" tag\n" +
            "// label for `type_of()` on a TAG_ENUM value. PR-2.1 will produce TAG_ENUM\n" +
            "// HexaVals; until then this is dead under the unreachable TAG_ENUM branch\n" +
            "// of hexa_type_of, but mirrors the cache-init contract followed by every\n" +
            "// other tag (initialized in _hexa_init_cached_strs, used via switch case).\n" +
            "static HexaVal _cached_str_enum;\n" +
            "static int     _cached_strs_ready = 0;\n" +
            "// S1-D2 Blocker C: forward decl — defined after bt73 wrappers near EOF.\n" +
            "static void _hexa_init_fn_shims(void);\n" +
            "\n" +
            "static void _hexa_init_cached_strs(void) {\n" +
            "    if (_cached_strs_ready) return;\n" +
            "    _cached_str_true    = hexa_str(\"true\");\n" +
            "    _cached_str_false   = hexa_str(\"false\");\n" +
            "    _cached_str_void    = hexa_str(\"void\");\n" +
            "    _cached_str_int     = hexa_str(\"int\");\n" +
            "    _cached_str_float   = hexa_str(\"float\");\n" +
            "    _cached_str_bool    = hexa_str(\"bool\");\n" +
            "    _cached_str_string  = hexa_str(\"string\");\n" +
            "    _cached_str_array   = hexa_str(\"array\");\n" +
            "    _cached_str_map     = hexa_str(\"map\");\n" +
            "    _cached_str_struct  = hexa_str(\"struct\");\n" +
            "    _cached_str_fn      = hexa_str(\"fn\");\n" +
            "    _cached_str_char    = hexa_str(\"char\");\n" +
            "    _cached_str_closure = hexa_str(\"closure\");\n" +
            "    _cached_str_unknown = hexa_str(\"unknown\");\n" +
            "    _cached_str_value   = hexa_str(\"<value>\");\n" +
            "    _cached_str_enum    = hexa_str(\"enum\");\n" +
            "    _cached_strs_ready  = 1;\n" +
            "}\n" +
            "\n" +
            "// Small-int to_string cache: [-1, 0..255] covers >90% of int-to-string\n" +
            "#define SMALL_INT_CACHE_MIN  (-1)\n" +
            "#define SMALL_INT_CACHE_MAX  255\n" +
            "#define SMALL_INT_CACHE_SIZE (SMALL_INT_CACHE_MAX - SMALL_INT_CACHE_MIN + 1)\n" +
            "static HexaVal _cached_small_ints[SMALL_INT_CACHE_SIZE];\n" +
            "static int     _cached_small_ints_ready = 0;\n" +
            "\n" +
            "static void _hexa_init_small_int_cache(void) {\n" +
            "    if (_cached_small_ints_ready) return;\n" +
            "    char buf[16];\n" +
            "    for (int i = 0; i < SMALL_INT_CACHE_SIZE; i++) {\n" +
            "        int64_t n = (int64_t)(i + SMALL_INT_CACHE_MIN);\n" +
            "        snprintf(buf, 16, \"%lld\", (long long)n);\n" +
            "        _cached_small_ints[i] = hexa_str(buf);\n" +
            "    }\n" +
            "    _cached_small_ints_ready = 1;\n" +
            "}\n" +
            "\n" +
            "// ── Array operations ─────────────────────────────────────\n" +
            "\n" +
            "// rt 32: alloc/COW stats (HEXA_ALLOC_STATS=1 env enables atexit dump).\n" +
            "// Counts hot-path C runtime allocations so we can diagnose where 10GB\n" +
            "// RSS ML microbench pressure originates without sample/leaks tooling.\n" +
            "static int64_t _hx_stats_array_new      = 0;\n" +
            "static int64_t _hx_stats_array_push     = 0;\n" +
            "static int64_t _hx_stats_array_grow     = 0;   // realloc that actually grows cap\n" +
            "static int64_t _hx_stats_str_concat     = 0;\n" +
            "static int64_t _hx_stats_array_reserve  = 0;\n" +
            "static int64_t _hx_stats_map_new        = 0;\n" +
            "static int64_t _hx_stats_map_set        = 0;\n" +
            "// STRUCTURAL-7 Phase A: codegen emits __hexa_fn_arena_enter/return for\n" +
            "// per-function arena scoping. Forward declarations here; real implementations\n" +
            "// below after all arena dependencies (hexa_val_arena_on, hexa_val_heapify,\n" +
            "// hexa_val_arena_scope_push/pop) are defined.\n" +
            "void __hexa_fn_arena_enter(void);\n" +
            "HexaVal __hexa_fn_arena_return(HexaVal v);\n" +
            "\n" +
            "// rt 32-D: arena allocator stats (str_concat hot-path)\n" +
            "static int64_t _hx_stats_arena_alloc    = 0;   // total arena bump allocations\n" +
            "static int64_t _hx_stats_arena_blocks   = 0;   // blocks created\n" +
            "static int64_t _hx_stats_arena_bytes    = 0;   // bytes currently reserved in blocks\n" +
            "static int64_t _hx_stats_str_concat_arena = 0; // str_concat calls that hit arena\n" +
            "// rt 32-M: array arena counters\n" +
            "static int64_t _hx_stats_array_arena_alloc   = 0; // push that went arena (initial slot buf)\n" +
            "static int64_t _hx_stats_array_arena_promote = 0; // arena→heap promotions on grow\n" +
            "static int64_t _hx_stats_array_arena_heapify = 0; // heapify copies of arena item buffers\n" +
            "// M4: string arena heapify stats\n" +
            "static int64_t _hx_stats_str_arena_heapify   = 0; // arena→heap string promotions\n" +
            "// M4-edge: RSS peak sampler — opt-in via HEXA_ALLOC_STATS. Sampled only on\n" +
            "// arena new-block (rare: every 4MB+), so getrusage overhead is negligible.\n" +
            "static int64_t _hx_stats_rss_peak_bytes      = 0;\n" +
            "// H03 (2026-05-06): extended observability counters — log2 size histogram,\n" +
            "// arena block churn (max chain depth), string intern hit/miss, closure/fn\n" +
            "// descriptor pool reuse signals. All updates are inside _hx_stats_on()\n" +
            "// guards so the unset-env hot path remains a single predicted branch + RET.\n" +
            "//\n" +
            "// Histogram buckets (10 slots, log2-style edges in bytes):\n" +
            "//   [0]<16  [1]<64  [2]<256  [3]<1K  [4]<4K  [5]<16K  [6]<64K  [7]<256K\n" +
            "//   [8]<1M  [9]>=1M\n" +
            "// Each slot accumulates the count of arena-bump allocations in that range\n" +
            "// (covers the dominant runtime allocator — slab/size decisions for B17).\n" +
            "#define HX_HIST_BUCKETS 10\n" +
            "static int64_t _hx_stats_size_hist[HX_HIST_BUCKETS] = {0};\n" +
            "// Arena block-chain churn. _arena_block_max_chain tracks longest observed\n" +
            "// linked-list length. _arena_block_reuse counts how many times the alloc\n" +
            "// path satisfied a request by walking forward into a previously rewound\n" +
            "// (used=0) tail block instead of malloc'ing a new one.\n" +
            "static int64_t _hx_stats_arena_block_max_chain = 0;\n" +
            "static int64_t _hx_stats_arena_block_reuse     = 0;\n" +
            "// String intern Q9 (hit/miss/skip/grow) and closure/fn pool counters (B25)\n" +
            "// are forward-declared at top of file (above hexa_intern) — tentative defs\n" +
            "// per C99 §6.9.2 implicitly zero-initialize; no separate defining decl needed.\n" +
            "//\n" +
            "// Closure / fn pool counters — storage matches the forward decls at top of\n" +
            "// file (above hexa_intern). Tentative-definition rule: top-of-file decls\n" +
            "// have no initializer; these defining declarations carry the `= 0` zero-init.\n" +
            "// Note: HX_POOL_LRU and the ring buffers are also forward-declared above —\n" +
            "// the declarations there are tentative (no init), so these defining declarations\n" +
            "// (with explicit `= {0}` / `= 0`) coexist legally per C99 §6.9.2.\n" +
            "// (HX_POOL_LRU macro is also defined at the top, do not redefine here.)\n" +
            "// We do NOT redeclare _hx_stats_lru_check here — it's defined in the forward\n" +
            "// block (static inline) and used by hexa_closure_new / hexa_fn_new.\n" +
            "static int _hx_stats_enabled = -1;             // lazy probe of env\n" +
            "\n" +
            "// H03: log2 bucket index for n bytes — branch-free-ish; called only inside\n" +
            "// _hx_stats_on() so cost is irrelevant when env unset.\n" +
            "static inline int _hx_stats_size_bucket(size_t n) {\n" +
            "    if (n < 16)            return 0;\n" +
            "    if (n < 64)            return 1;\n" +
            "    if (n < 256)           return 2;\n" +
            "    if (n < 1024)          return 3;\n" +
            "    if (n < 4096)          return 4;\n" +
            "    if (n < 16384)         return 5;\n" +
            "    if (n < 65536)         return 6;\n" +
            "    if (n < 262144)        return 7;\n" +
            "    if (n < 1048576)       return 8;\n" +
            "    return 9;\n" +
            "}\n" +
            "\n" +
            "static void _hx_stats_sample_rss(void) {\n" +
            "    struct rusage ru;\n" +
            "    if (hxlcl_getrusage(RUSAGE_SELF, &ru) != 0) return;\n" +
            "#if defined(__APPLE__)\n" +
            "    int64_t rss_bytes = (int64_t)ru.ru_maxrss;        // macOS: bytes\n" +
            "#else\n" +
            "    int64_t rss_bytes = (int64_t)ru.ru_maxrss * 1024; // Linux: kilobytes\n" +
            "#endif\n" +
            "    if (rss_bytes > _hx_stats_rss_peak_bytes) _hx_stats_rss_peak_bytes = rss_bytes;\n" +
            "}\n" +
            "\n" +
            "static void _hx_stats_dump(void) {\n" +
            "    _hx_stats_sample_rss();\n" +
            "    fprintf(stderr, \"[HEXA_ALLOC_STATS] array_new=%lld push=%lld grow=%lld reserve=%lld str_concat=%lld map_new=%lld map_set=%lld arena_alloc=%lld arena_blocks=%lld arena_bytes=%lld str_concat_arena=%lld arr_arena_alloc=%lld arr_arena_promote=%lld arr_arena_heapify=%lld str_arena_heapify=%lld rss_peak_mb=%lld\\n\",\n" +
            "        (long long)_hx_stats_array_new,\n" +
            "        (long long)_hx_stats_array_push,\n" +
            "        (long long)_hx_stats_array_grow,\n" +
            "        (long long)_hx_stats_array_reserve,\n" +
            "        (long long)_hx_stats_str_concat,\n" +
            "        (long long)_hx_stats_map_new,\n" +
            "        (long long)_hx_stats_map_set,\n" +
            "        (long long)_hx_stats_arena_alloc,\n" +
            "        (long long)_hx_stats_arena_blocks,\n" +
            "        (long long)_hx_stats_arena_bytes,\n" +
            "        (long long)_hx_stats_str_concat_arena,\n" +
            "        (long long)_hx_stats_array_arena_alloc,\n" +
            "        (long long)_hx_stats_array_arena_promote,\n" +
            "        (long long)_hx_stats_array_arena_heapify,\n" +
            "        (long long)_hx_stats_str_arena_heapify,\n" +
            "        (long long)(_hx_stats_rss_peak_bytes / (1024 * 1024)));\n" +
            "\n" +
            "    // H03: appended sections (append-only — does not break existing fields).\n" +
            "    // Section S1: arena-allocation size histogram (B17 slab-decision input).\n" +
            "    fprintf(stderr,\n" +
            "        \"[HEXA_ALLOC_STATS_HIST] <16=%lld <64=%lld <256=%lld <1K=%lld <4K=%lld <16K=%lld <64K=%lld <256K=%lld <1M=%lld >=1M=%lld\\n\",\n" +
            "        (long long)_hx_stats_size_hist[0],\n" +
            "        (long long)_hx_stats_size_hist[1],\n" +
            "        (long long)_hx_stats_size_hist[2],\n" +
            "        (long long)_hx_stats_size_hist[3],\n" +
            "        (long long)_hx_stats_size_hist[4],\n" +
            "        (long long)_hx_stats_size_hist[5],\n" +
            "        (long long)_hx_stats_size_hist[6],\n" +
            "        (long long)_hx_stats_size_hist[7],\n" +
            "        (long long)_hx_stats_size_hist[8],\n" +
            "        (long long)_hx_stats_size_hist[9]);\n" +
            "\n" +
            "    // Section S2: arena block churn — max chain depth, reuse rate.\n" +
            "    fprintf(stderr,\n" +
            "        \"[HEXA_ALLOC_STATS_ARENA] block_max_chain=%lld block_reuse=%lld block_alloc=%lld\\n\",\n" +
            "        (long long)_hx_stats_arena_block_max_chain,\n" +
            "        (long long)_hx_stats_arena_block_reuse,\n" +
            "        (long long)_hx_stats_arena_blocks);\n" +
            "\n" +
            "    // Section S3: string intern hit/miss/skip (Q9 — INTERN_INIT_CAP sizing).\n" +
            "    int64_t intern_total = _hx_stats_intern_hit + _hx_stats_intern_miss;\n" +
            "    long ratio_x100 = intern_total > 0\n" +
            "        ? (long)((_hx_stats_intern_hit * 100) / intern_total)\n" +
            "        : 0L;\n" +
            "    fprintf(stderr,\n" +
            "        \"[HEXA_ALLOC_STATS_INTERN] hit=%lld miss=%lld skip=%lld grow=%lld hit_ratio_pct=%ld\\n\",\n" +
            "        (long long)_hx_stats_intern_hit,\n" +
            "        (long long)_hx_stats_intern_miss,\n" +
            "        (long long)_hx_stats_intern_skip,\n" +
            "        (long long)_hx_stats_intern_grow,\n" +
            "        ratio_x100);\n" +
            "\n" +
            "    // Section S4: closure / fn descriptor pool reuse opportunity (B25).\n" +
            "    long fn_dup_pct  = _hx_stats_fn_alloc > 0\n" +
            "        ? (long)((_hx_stats_fn_alloc_dup * 100) / _hx_stats_fn_alloc) : 0L;\n" +
            "    long clo_dup_pct = _hx_stats_closure_alloc > 0\n" +
            "        ? (long)((_hx_stats_clo_alloc_dup * 100) / _hx_stats_closure_alloc) : 0L;\n" +
            "    fprintf(stderr,\n" +
            "        \"[HEXA_ALLOC_STATS_POOL] fn_alloc=%lld fn_alloc_dup=%lld fn_dup_pct=%ld clo_alloc=%lld clo_alloc_dup=%lld clo_dup_pct=%ld\\n\",\n" +
            "        (long long)_hx_stats_fn_alloc,\n" +
            "        (long long)_hx_stats_fn_alloc_dup,\n" +
            "        fn_dup_pct,\n" +
            "        (long long)_hx_stats_closure_alloc,\n" +
            "        (long long)_hx_stats_clo_alloc_dup,\n" +
            "        clo_dup_pct);\n" +
            "}\n" +
            "\n" +
            "static int _hx_stats_on(void) {\n" +
            "    if (_hx_stats_enabled < 0) {\n" +
            "        const char* e = hxlcl_getenv(\"HEXA_ALLOC_STATS\");\n" +
            "        _hx_stats_enabled = (e && e[0] && e[0] != '0') ? 1 : 0;\n" +
            "        if (_hx_stats_enabled) {\n" +
            "            hxlcl_atexit(_hx_stats_dump);\n" +
            "        }\n" +
            "    }\n" +
            "    return _hx_stats_enabled;\n" +
            "}\n" +
            "\n" +
            "// ── rt 32-M: Array arena allocator ──────────────────────\n" +
            "// Bump-allocate the array slot buffer (HexaVal*) from the shared bump arena\n" +
            "// during an active fn-call mark (__hexa_val_mark_top > 0). On grow beyond the\n" +
            "// initial slot capacity, promote the buffer to malloc (can't realloc an arena\n" +
            "// region). On heapify, deep-copy the item buffer to malloc before the arena\n" +
            "// rewind point.\n" +
            "//\n" +
            "// Encoding: negative cap = from_arena (arr.items points into arena). This\n" +
            "// preserves HexaVal width/ABI — no new field in the .arr struct. Consumers\n" +
            "// that read .cap positively must treat (cap < 0) as |cap|.\n" +
            "//\n" +
            "// Gate: HEXA_ARRAY_ARENA env var. Default ON. Set =0 to fall back to pure\n" +
            "// malloc/realloc path bit-for-bit.\n" +
            "//\n" +
            "// Rationale: fib(20)×30 shows array_new=4.6M, push=28.9M, grow=4.6M — the\n" +
            "// dominant RSS driver. rt 32-L heapified HexaValStruct but left the array\n" +
            "// .items buffer on the malloc heap (rt 32-L comment explicitly calls this\n" +
            "// out: \"Array .items lives on heap — hexa_array_push uses realloc\"). This\n" +
            "// change addresses that gap.\n" +
            "extern int __hexa_val_mark_top;  // shared with rt 32-L Val arena\n" +
            "extern int __hexa_val_force_heap; // T33-fix-2: force heap in valstruct_new_v\n" +
            "static int hexa_val_arena_on(void);\n" +
            "static void* hexa_val_arena_calloc(size_t n);\n" +
            "void* hexa_arena_alloc(size_t n);  // rt 32-D bump allocator (shared block chain)\n" +
            "\n" +
            "static int __hexa_array_arena_enabled = -1;\n" +
            "static int hexa_array_arena_on(void) {\n" +
            "    if (__hexa_array_arena_enabled < 0) {\n" +
            "        const char* e = hxlcl_getenv(\"HEXA_ARRAY_ARENA\");\n" +
            "        // Default ON. Export HEXA_ARRAY_ARENA=0 to disable.\n" +
            "        if (!e || !e[0]) __hexa_array_arena_enabled = 1;\n" +
            "        else             __hexa_array_arena_enabled = (e[0] != '0') ? 1 : 0;\n" +
            "    }\n" +
            "    return __hexa_array_arena_enabled;\n" +
            "}\n" +
            "\n" +
            "// Arena-alloc a HexaVal slot buffer. Caller sets cap to -n so the \"from_arena\"\n" +
            "// sentinel survives the return. Returns NULL if arena is off / not in scope.\n" +
            "// Does NOT zero the buffer — caller memcpy's over it (slice_fast) or writes\n" +
            "// len items before reading. Skipping the memset is a measurable win on hot\n" +
            "// paths (the Val arena's calloc variant memset'd a 4MB block front-to-back\n" +
            "// every few thousand calls, costing ~8% wall on fib K=30).\n" +
            "static HexaVal* hexa_array_arena_alloc_items(int n) {\n" +
            "    if (!hexa_array_arena_on()) return NULL;\n" +
            "    // Must be inside a live scope mark — otherwise there's no rewind point to\n" +
            "    // catch the allocation (module-init arrays stay on heap).\n" +
            "    if (__hexa_val_mark_top <= 0) return NULL;\n" +
            "    // Reuse the shared bump allocator (same block chain as rt 32-L). The\n" +
            "    // existing rt 32-L scope-push/pop discipline automatically reclaims the\n" +
            "    // array buffers too — no parallel mark stack needed.\n" +
            "    HexaVal* p = (HexaVal*)hexa_arena_alloc((size_t)n * sizeof(HexaVal));\n" +
            "    return p;  // NULL if arena OOM — caller falls back to malloc\n" +
            "}\n" +
            "\n" +
            "// Promote an arena-backed slot buffer to malloc. len = current live slot count\n" +
            "// to copy; new_cap = target capacity. Used by grow (new_cap > |old_cap|) and\n" +
            "// heapify (new_cap == |old_cap|). Returns NULL on OOM (caller handles).\n" +
            "static HexaVal* hexa_array_promote_to_heap(HexaVal* arena_items, int len, int new_cap) {\n" +
            "    HexaVal* heap = (HexaVal*)malloc(sizeof(HexaVal) * (size_t)new_cap);\n" +
            "    if (!heap) return NULL;\n" +
            "    if (arena_items && len > 0) {\n" +
            "        hxlcl_memcpy(heap, arena_items, sizeof(HexaVal) * (size_t)len);\n" +
            "    }\n" +
            "    return heap;\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_array_new() {\n" +
            "    if (_hx_stats_on()) _hx_stats_array_new++;\n" +
            "    HexaVal v = {.tag=TAG_ARRAY};\n" +
            "    HX_SET_ARR_PTR(v, (HexaArr*)calloc(1, sizeof(HexaArr)));\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "// ROI #148: shallow-clone a TAG_ARRAY. Gives the caller a fresh HexaArr\n" +
            "// descriptor (own len/cap) and a fresh items buffer of the same logical\n" +
            "// contents. Inner HexaVals (ints/strs/nested arrays) are copied as-is —\n" +
            "// nested arrays remain aliased, matching standard \"one level ownership\"\n" +
            "// semantics. Non-array inputs are returned unchanged.\n" +
            "//\n" +
            "// Used by hexa_struct_pack_map to break caller→struct-field aliasing on\n" +
            "// struct construction: `Box { items: xs }` stores xs's contents into a\n" +
            "// NEW descriptor so that subsequent hexa_array_push on one struct's\n" +
            "// .items cannot leak into a sibling struct initialized from the same xs.\n" +
            "HexaVal hexa_array_shallow_clone(HexaVal v) {\n" +
            "    if (!HX_IS_ARRAY(v)) return v;\n" +
            "    int n = HX_ARR_LEN(v);\n" +
            "    int src_cap = HX_ARR_CAP(v);\n" +
            "    int real_cap = src_cap < 0 ? -src_cap : src_cap;\n" +
            "    HexaVal out = {.tag=TAG_ARRAY};\n" +
            "    HexaArr* d = (HexaArr*)calloc(1, sizeof(HexaArr));\n" +
            "    if (!d) { fprintf(stderr, \"OOM in array_shallow_clone\\n\"); exit(1); }\n" +
            "    HX_SET_ARR_PTR(out, d);\n" +
            "    if (n == 0 && real_cap == 0) {\n" +
            "        // Empty: leave items NULL, cap 0. Push from here behaves like fresh.\n" +
            "        return out;\n" +
            "    }\n" +
            "    // Always allocate a heap buffer (positive cap) sized to hold the\n" +
            "    // current contents. Avoid the arena-sentinel so downstream push/grow\n" +
            "    // can realloc freely without aliasing the source arena slab.\n" +
            "    int new_cap = real_cap > 0 ? real_cap : (n > 0 ? n : 8);\n" +
            "    if (new_cap < n) new_cap = n;\n" +
            "    HexaVal* items = (HexaVal*)malloc(sizeof(HexaVal) * (size_t)new_cap);\n" +
            "    if (!items) { fprintf(stderr, \"OOM in array_shallow_clone items\\n\"); exit(1); }\n" +
            "    if (n > 0 && HX_ARR_ITEMS(v)) {\n" +
            "        hxlcl_memcpy(items, HX_ARR_ITEMS(v), sizeof(HexaVal) * (size_t)n);\n" +
            "    }\n" +
            "    HX_SET_ARR_ITEMS(out, items);\n" +
            "    HX_SET_ARR_LEN(out, n);\n" +
            "    HX_SET_ARR_CAP(out, new_cap);\n" +
            "    return out;\n" +
            "}\n" +
            "\n" +
            "// rt#32-N: snapshot-promote helper. Invoked by the transpiler around every\n" +
            "// `let y = x` and fn-argument expression where x may be a TAG_ARRAY whose items\n" +
            "// buffer is arena-allocated (cap < 0). Deep-copies arena items to malloc so\n" +
            "// the snapshot is insulated from subsequent arena rewinds + callee arena\n" +
            "// re-allocations. Passthrough for non-array / non-arena values.\n" +
            "//\n" +
            "// Rationale: Hexa is pass-by-value at the HexaVal level (I1), but the .items\n" +
            "// pointer inside arr.* is shared. rt#32-M enabled arena-alloc only for the\n" +
            "// slice_fast path because a caller-local snapshot of a persistent global could\n" +
            "// alias the same arena buffer that the callee subsequently re-arena-alloc'd\n" +
            "// (ABA). Snapshot-promote cuts the alias by forcing the caller's copy onto\n" +
            "// the malloc heap at capture time.\n" +
            "HexaVal hexa_val_snapshot_array(HexaVal v) {\n" +
            "    if (!HX_IS_ARRAY(v)) return v;\n" +
            "    if (HX_ARR_CAP(v) >= 0) return v;  // heap-backed — no aliasing with arena rewind\n" +
            "    // cap < 0: arena-backed — promote to heap.\n" +
            "    if (_hx_stats_on()) _hx_stats_array_arena_heapify++;\n" +
            "    int real_cap = -HX_ARR_CAP(v);\n" +
            "    HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(v), HX_ARR_LEN(v), real_cap);\n" +
            "    if (!heap) return v;  // OOM — best-effort, caller may see stale pointer\n" +
            "    HX_SET_ARR_ITEMS(v, heap);\n" +
            "    HX_SET_ARR_CAP(v, real_cap);  // positive → heap\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "// rt#32-N: push-arena gate. Default OFF until snapshot-promote is fully wired\n" +
            "// into the transpiler + interpreter source (self/hexa_full.hexa). Set\n" +
            "// HEXA_ARRAY_PUSH_ARENA=1 to enable arena-alloc on first push (cap=0 → cap=-8)\n" +
            "// after snapshot-promote is proven safe.\n" +
            "static int __hexa_array_push_arena_enabled = -1;\n" +
            "static int hexa_array_push_arena_on(void) {\n" +
            "    if (__hexa_array_push_arena_enabled < 0) {\n" +
            "        const char* e = hxlcl_getenv(\"HEXA_ARRAY_PUSH_ARENA\");\n" +
            "        if (!e || !e[0]) __hexa_array_push_arena_enabled = 0;  // default OFF\n" +
            "        else             __hexa_array_push_arena_enabled = (e[0] != '0') ? 1 : 0;\n" +
            "    }\n" +
            "    return __hexa_array_push_arena_enabled;\n" +
            "}\n" +
            "\n" +
            "// Optimization #12: reserve capacity up front when size is known.\n" +
            "// rt 32-M: respect arena-backed items (cap<0) — promote to heap on grow.\n" +
            "HexaVal hexa_array_reserve(HexaVal arr, int n) {\n" +
            "    int real_cap = HX_ARR_CAP(arr) < 0 ? -HX_ARR_CAP(arr) : HX_ARR_CAP(arr);\n" +
            "    if (n <= real_cap) return arr;\n" +
            "    if (_hx_stats_on()) _hx_stats_array_reserve++;\n" +
            "    if (HX_ARR_CAP(arr) < 0) {\n" +
            "        if (_hx_stats_on()) _hx_stats_array_arena_promote++;\n" +
            "        HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(arr), HX_ARR_LEN(arr), n);\n" +
            "        if (!heap) { fprintf(stderr, \"OOM in array_reserve\\n\"); exit(1); }\n" +
            "        HX_SET_ARR_ITEMS(arr, heap);\n" +
            "        HX_SET_ARR_CAP(arr, n);\n" +
            "    } else {\n" +
            "        HexaVal* new_items = realloc(HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)n);\n" +
            "        if (!new_items) { fprintf(stderr, \"OOM in array_reserve\\n\"); exit(1); }\n" +
            "        HX_SET_ARR_ITEMS(arr, new_items);\n" +
            "        HX_SET_ARR_CAP(arr, n);\n" +
            "    }\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// Optimization #12: grow from current cap (2x), not from new_len.\n" +
            "// Only realloc when len exceeds cap; growth factor 2x amortizes cost.\n" +
            "// rt 32-M: arena-alloc the initial slot buffer when a fn-call scope mark is\n" +
            "// live (HEXA_ARRAY_ARENA=1 default). On grow beyond the arena buffer, promote\n" +
            "// to heap with malloc+memcpy — the arena region cannot be realloc'd. Negative\n" +
            "// `cap` encodes from_arena; abs(cap) is the real capacity.\n" +
            "// Forward declaration — real impl at the per-scope-arena section below. Needed\n" +
            "// so the FIX 2026-05-13 heapify call inside hexa_array_push compiles cleanly.\n" +
            "HexaVal hexa_val_heapify(HexaVal v);\n" +
            "\n" +
            "HexaVal hexa_array_push(HexaVal arr, HexaVal item) {\n" +
            "    _hx_mem_tick();\n" +
            "    if (_hx_stats_on()) _hx_stats_array_push++;\n" +
            "    int real_cap = HX_ARR_CAP(arr) < 0 ? -HX_ARR_CAP(arr) : HX_ARR_CAP(arr);\n" +
            "    // A17: amortised geometric grow → grow path fires O(log N) times; the\n" +
            "    // common case is len < cap (no realloc). Hint the no-grow path.\n" +
            "    // Z20: prefetch the slot we are about to write so the store retires\n" +
            "    // without a fill miss when the array is large and was last touched\n" +
            "    // outside the L1 working set.\n" +
            "    HX_PREFETCH(&HX_ARR_ITEMS(arr)[HX_ARR_LEN(arr)]);\n" +
            "    if (HX_UNLIKELY(HX_ARR_LEN(arr) >= real_cap)) {\n" +
            "        if (_hx_stats_on()) _hx_stats_array_grow++;\n" +
            "        int new_cap = real_cap < 8 ? 8 : real_cap * 2;\n" +
            "        if (HX_ARR_CAP(arr) < 0) {\n" +
            "            // Arena-backed buffer: cannot realloc. Allocate a NEW arena slab\n" +
            "            // if still inside a live mark and there's room; else promote to\n" +
            "            // malloc heap. Keeping it arena-resident preserves the RSS win\n" +
            "            // for arrays that grow incrementally inside the same scope.\n" +
            "            HexaVal* next_items = NULL;\n" +
            "            if (__hexa_val_mark_top > 0 && hexa_array_arena_on()) {\n" +
            "                next_items = hexa_array_arena_alloc_items(new_cap);\n" +
            "            }\n" +
            "            if (next_items) {\n" +
            "                if (HX_ARR_LEN(arr) > 0) {\n" +
            "                    hxlcl_memcpy(next_items, HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)HX_ARR_LEN(arr));\n" +
            "                }\n" +
            "                HX_SET_ARR_ITEMS(arr, next_items);\n" +
            "                HX_SET_ARR_CAP(arr, -new_cap);\n" +
            "            } else {\n" +
            "                // Promote to heap.\n" +
            "                if (_hx_stats_on()) _hx_stats_array_arena_promote++;\n" +
            "                HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(arr), HX_ARR_LEN(arr), new_cap);\n" +
            "                if (HX_UNLIKELY(!heap)) { fprintf(stderr, \"OOM in array_push (arena promote)\\n\"); exit(1); }\n" +
            "                HX_SET_ARR_ITEMS(arr, heap);\n" +
            "                HX_SET_ARR_CAP(arr, new_cap);  // positive → heap\n" +
            "            }\n" +
            "        } else {\n" +
            "            // rt#32-N: push-arena path (cap=0 first-push or existing heap\n" +
            "            // grow). Enabled by HEXA_ARRAY_PUSH_ARENA=1 once the transpiler\n" +
            "            // wraps snapshot-capture sites with hexa_val_snapshot_array.\n" +
            "            // Without snapshot-promote, Hexa pass-by-value (I1) aliasing\n" +
            "            // makes caller snapshots invalid across callee arena rewinds.\n" +
            "            //\n" +
            "            // Only fires on FIRST allocation (cap==0) — subsequent grows on\n" +
            "            // an existing heap buffer continue to realloc as before (no\n" +
            "            // aliasing delta). When mark_top > 0 and arena is on, the fresh\n" +
            "            // buffer is arena-allocated with cap=-new_cap.\n" +
            "            HexaVal* next_items = NULL;\n" +
            "            int use_arena = 0;\n" +
            "            if (real_cap == 0\n" +
            "                && __hexa_val_mark_top > 0\n" +
            "                && hexa_array_arena_on()\n" +
            "                && hexa_array_push_arena_on()) {\n" +
            "                next_items = hexa_array_arena_alloc_items(new_cap);\n" +
            "                if (next_items) {\n" +
            "                    use_arena = 1;\n" +
            "                    if (_hx_stats_on()) _hx_stats_array_arena_alloc++;\n" +
            "                }\n" +
            "            }\n" +
            "            if (use_arena) {\n" +
            "                HX_SET_ARR_ITEMS(arr, next_items);\n" +
            "                HX_SET_ARR_CAP(arr, -new_cap);  // negative → from_arena sentinel\n" +
            "            } else {\n" +
            "                HexaVal* new_items = realloc(HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)new_cap);\n" +
            "                if (HX_UNLIKELY(!new_items)) { fprintf(stderr, \"OOM in array_push\\n\"); exit(1); }\n" +
            "                HX_SET_ARR_ITEMS(arr, new_items);\n" +
            "                HX_SET_ARR_CAP(arr, new_cap);\n" +
            "            }\n" +
            "        }\n" +
            "    }\n" +
            "    // FIX 2026-05-13 (wilson-fn-arena-escapes-on-push): when pushing into an\n" +
            "    // array whose item buffer lives on the heap (cap >= 0), and we're inside a\n" +
            "    // live fn-arena scope (mark_top > 0), the item being pushed may have been\n" +
            "    // allocated in the *current* fn's arena and will be freed on\n" +
            "    // __hexa_fn_arena_return — leaving a dangling handle in the heap array. Run\n" +
            "    // heapify on the item so its underlying storage is promoted to the heap\n" +
            "    // before insertion. Arena-resident arrays (cap < 0) share the callee's\n" +
            "    // lifetime by construction and don't need this.\n" +
            "    if (HX_ARR_CAP(arr) >= 0 && __hexa_val_mark_top > 0) {\n" +
            "        item = hexa_val_heapify(item);\n" +
            "    }\n" +
            "    HX_ARR_ITEMS(arr)[HX_ARR_LEN(arr)] = item;\n" +
            "    HX_SET_ARR_LEN(arr, HX_ARR_LEN(arr) + 1);\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// rt 32-B: reusable-buffer scratch push. Semantics identical to hexa_array_push\n" +
            "// except it does NOT bump _hx_stats_array_push / _hx_stats_array_grow (those\n" +
            "// counters are reserved for \"true\" per-call allocs). Used by the NK_CALL args\n" +
            "// accumulator (call_arg_buf) which is a single long-lived buffer — its growth\n" +
            "// amortises across the whole program and should not inflate the per-call\n" +
            "// push/grow histogram.\n" +
            "HexaVal hexa_array_push_nostat(HexaVal arr, HexaVal item) {\n" +
            "    // rt 32-M: stays on heap (call_arg_buf is long-lived — arena rewind would\n" +
            "    // invalidate it). If an arena buffer somehow lands here, promote to heap.\n" +
            "    int real_cap = HX_ARR_CAP(arr) < 0 ? -HX_ARR_CAP(arr) : HX_ARR_CAP(arr);\n" +
            "    if (HX_ARR_LEN(arr) >= real_cap) {\n" +
            "        int new_cap = real_cap < 8 ? 8 : real_cap * 2;\n" +
            "        if (HX_ARR_CAP(arr) < 0) {\n" +
            "            HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(arr), HX_ARR_LEN(arr), new_cap);\n" +
            "            if (!heap) { fprintf(stderr, \"OOM in array_push_nostat\\n\"); exit(1); }\n" +
            "            HX_SET_ARR_ITEMS(arr, heap);\n" +
            "            HX_SET_ARR_CAP(arr, new_cap);\n" +
            "        } else {\n" +
            "            HexaVal* new_items = realloc(HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)new_cap);\n" +
            "            if (!new_items) { fprintf(stderr, \"OOM in array_push_nostat\\n\"); exit(1); }\n" +
            "            HX_SET_ARR_ITEMS(arr, new_items);\n" +
            "            HX_SET_ARR_CAP(arr, new_cap);\n" +
            "        }\n" +
            "    }\n" +
            "    HX_ARR_ITEMS(arr)[HX_ARR_LEN(arr)] = item;\n" +
            "    HX_SET_ARR_LEN(arr, HX_ARR_LEN(arr) + 1);\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// rt 32-B: bulk slice primitive — single malloc + memcpy, counts as exactly\n" +
            "// ONE array_new (not N array_push). Used to hand a per-call args view out of\n" +
            "// the shared call_arg_buf so the callee receives an independent backing store\n" +
            "// that is not disturbed by subsequent NK_CALL recursion mutating the buffer.\n" +
            "HexaVal hexa_array_slice_fast(HexaVal arr, HexaVal start, HexaVal end) {\n" +
            "    if (_hx_stats_on()) _hx_stats_array_new++;\n" +
            "    HexaVal out = {.tag=TAG_ARRAY};\n" +
            "    HX_SET_ARR_PTR(out, (HexaArr*)calloc(1, sizeof(HexaArr)));\n" +
            "    if (!HX_IS_ARRAY(arr)) return out;\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    int a = (int)HX_INT(start), b = (int)HX_INT(end);\n" +
            "    if (a < 0) a = 0;\n" +
            "    if (b > n) b = n;\n" +
            "    if (a > b) a = b;\n" +
            "    int m = b - a;\n" +
            "    if (m <= 0) return out;\n" +
            "    // rt 32-M: arena-allocate slice items when inside a live fn-scope mark.\n" +
            "    // Slice_fast is used primarily for the NK_CALL scratch-args pattern (rt 32-B)\n" +
            "    // where the slice is immediately handed to call_user_fn as args, consumed\n" +
            "    // (each element copied into env_define), and discarded on fn return — a\n" +
            "    // lifetime that fits exactly within the callee's mark frontier.\n" +
            "    //\n" +
            "    // Safety: call_stack.slice(...) at call_user_fn exit happens BEFORE the\n" +
            "    // __HEXA_ARENA_POP__, so the caller sees a slice whose items pointer is\n" +
            "    // NOT rewound. But call_stack.slice is built from truncation on line 8341\n" +
            "    // AFTER the pop — so it runs at outer mark. We guard by only arena-\n" +
            "    // allocating when mark_top > 0 AND the SOURCE array is heap (cap >= 0).\n" +
            "    // For call_stack.slice(0, len-1) after pop, the source is heap; the result\n" +
            "    // lives at the outer's arena frontier which the outer's pop eventually\n" +
            "    // reclaims — call_stack is reassigned every call anyway, so the old slice\n" +
            "    // is unreachable by the next cycle. Heapify-on-return handles fn-return\n" +
            "    // escapes.\n" +
            "    HexaVal* items = NULL;\n" +
            "    int use_arena = 0;\n" +
            "    if (hexa_array_arena_on() && __hexa_val_mark_top > 0) {\n" +
            "        items = hexa_array_arena_alloc_items(m);\n" +
            "        if (items) { use_arena = 1; if (_hx_stats_on()) _hx_stats_array_arena_alloc++; }\n" +
            "    }\n" +
            "    if (!items) {\n" +
            "        items = (HexaVal*)malloc(sizeof(HexaVal) * (size_t)m);\n" +
            "        if (!items) { fprintf(stderr, \"OOM in array_slice_fast\\n\"); exit(1); }\n" +
            "    }\n" +
            "    hxlcl_memcpy(items, HX_ARR_ITEMS(arr) + a, sizeof(HexaVal) * (size_t)m);\n" +
            "    HX_SET_ARR_ITEMS(out, items);\n" +
            "    HX_SET_ARR_LEN(out, m);\n" +
            "    HX_SET_ARR_CAP(out, use_arena ? -m : m);\n" +
            "    return out;\n" +
            "}\n" +
            "\n" +
            "// Forward decl — hexa_throw 본체는 line ~2903. OOB throw routing 을 위해\n" +
            "// 여기서 일찍 선언.\n" +
            "void hexa_throw(HexaVal err);\n" +
            "\n" +
            "HexaVal hexa_array_get(HexaVal arr, int64_t idx) {\n" +
            "    // B13: tag guard — without this, a TAG_STR (from hexa_add fallthrough)\n" +
            "    // reaches here and we read .arr.len from an unrelated union slot\n" +
            "    // (uninitialized stack residue). 이전 exit(1) 대신 hexa_throw 로 라우팅\n" +
            "    // 해서 try/catch 로 recovery 가능.\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        // PROBE r12 #10: chained missing-key access `m[\"a\"][\"b\"]` where\n" +
            "        // m[\"a\"] returned void emits a confusing \"array[4428665856]: container\n" +
            "        // is not an array (tag=4)\" — the bare idx int is a corrupted memory\n" +
            "        // value from the void-as-key dispatch.  Surface void / map / str\n" +
            "        // separately so the user sees the chain-end type, not the noise int.\n" +
            "        if (HX_IS_VOID(arr)) {\n" +
            "            snprintf(_buf, sizeof(_buf), \"index access on void (chained missing-key?)\");\n" +
            "        } else if (HX_IS_MAP(arr)) {\n" +
            "            snprintf(_buf, sizeof(_buf), \"index access on map with int %lld — use map[\\\"key\\\"] string syntax\", (long long)idx);\n" +
            "        } else if (HX_IS_STR(arr)) {\n" +
            "            snprintf(_buf, sizeof(_buf), \"string[%lld]: use .chars()[%lld] or substring\", (long long)idx, (long long)idx);\n" +
            "        } else {\n" +
            "            snprintf(_buf, sizeof(_buf), \"array[%lld]: container is not an array (tag=%d)\", (long long)idx, (int)HX_TAG(arr));\n" +
            "        }\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    int64_t _orig_idx_g = idx;\n" +
            "    // PROBE r15-D12 (2026-05-24): negative array index is OUT OF BOUNDS, not a\n" +
            "    // Python-style wrap. Go/Rust/Swift canonical — `xs[-1]` panics rather than\n" +
            "    // aliasing the last element. Consistent with the positive OOB throw below\n" +
            "    // and #467 (string OOB throws). Use `.last()` for the last element. The\n" +
            "    // wrap (`idx += len`) was removed so any idx<0 falls straight to the throw,\n" +
            "    // surfacing the ORIGINAL negative index in the message (_orig_idx_g).\n" +
            "    if (idx < 0 || idx >= HX_ARR_LEN(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"index %lld out of bounds (len %d)\", (long long)_orig_idx_g, HX_ARR_LEN(arr));\n" +
            "        if (hxlcl_getenv(\"HEXA_OOB_TRACE\")) {\n" +
            "            // RUNTIME.md Tier-A.4: hexa-native frame-walker stubs (defined\n" +
            "            // in runtime.c before this TU is #include'd) — drops the libc\n" +
            "            // _backtrace / _backtrace_symbols_fd externs from aprime_cc.\n" +
            "            void* _bt[32]; int _n = hxlcl_backtrace(_bt, 32);\n" +
            "            fprintf(stderr, \"[OOB] %s\\n\", _buf);\n" +
            "            hxlcl_backtrace_symbols_fd(_bt, _n, 2);\n" +
            "        }\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    return HX_ARR_ITEMS(arr)[idx];\n" +
            "}\n" +
            "\n" +
            "// .last() codegen helper — single-eval the obj expression (HX_ARR_LEN is a\n" +
            "// runtime-internal macro unavailable in user.c).  Throws on non-array or\n" +
            "// empty array, matching Rust semantics where `.last()` on an empty slice\n" +
            "// returns None but hexa has no Option in prelude — explicit OOB is the\n" +
            "// closest canonical signal.\n" +
            "HexaVal hexa_array_last(HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"array.last(): container is not an array (tag=%d)\", (int)HX_TAG(arr));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    if (n == 0) {\n" +
            "        hexa_throw(hexa_str(\"array.last(): empty array\"));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    return HX_ARR_ITEMS(arr)[n - 1];\n" +
            "}\n" +
            "\n" +
            "// ω-interp-2 forward decl: defined later but needed here as a setter side-effect.\n" +
            "extern int __hexa_arena_slot_dirty;\n" +
            "\n" +
            "HexaVal hexa_array_set(HexaVal arr, int64_t idx, HexaVal val) {\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        // Strings hit this branch when the user writes `s[i] = v`. Emit a\n" +
            "        // string-specific diagnostic instead of the generic \"container is\n" +
            "        // not an array (tag=3)\" — hexa strings are immutable.\n" +
            "        if (HX_IS_STR(arr)) {\n" +
            "            snprintf(_buf, sizeof(_buf), \"s[%lld] = …: strings are immutable\", (long long)idx);\n" +
            "        } else {\n" +
            "            snprintf(_buf, sizeof(_buf), \"array_set[%lld]: container is not an array (tag=%d)\", (long long)idx, (int)HX_TAG(arr));\n" +
            "        }\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return arr;\n" +
            "    }\n" +
            "    int64_t _orig_idx_s = idx;\n" +
            "    // PROBE r15-D12: negative array index = OOB (Go/Rust canonical), not wrap.\n" +
            "    // Mirror of the get path above — `xs[-1] = v` panics.\n" +
            "    if (idx < 0 || idx >= HX_ARR_LEN(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"index %lld out of bounds (len %d)\", (long long)_orig_idx_s, HX_ARR_LEN(arr));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return arr;\n" +
            "    }\n" +
            "    // In-place mutate (no copy — caller reassigns)\n" +
            "    HX_ARR_ITEMS(arr)[idx] = val;\n" +
            "    // ω-interp-2: SETTER for the per-frame \"dirty\" flag. Any direct write to\n" +
            "    // a host-array element is the canonical \"slot may now contain arena Vals\"\n" +
            "    // event — covers `array_store[idx] = items.push(item)` from\n" +
            "    // array_push_inplace, plus map_store / struct_store assignments. Marking\n" +
            "    // here is a single-store fast path with no branch on arr identity (the\n" +
            "    // checker in hexa_val_heapify scopes the work to the actual store walked).\n" +
            "    __hexa_arena_slot_dirty = 1;\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// bt 55 — in-place truncate. Used by env_pop_scope to avoid the\n" +
            "// `new_vars.push` rebuild loop which realloc-leaks the old backing buffer\n" +
            "// every scope pop. Retains capacity for amortized re-growth.\n" +
            "// No free of arr.items here (HexaVal entries may still be shared); we only\n" +
            "// shrink the logical length. Safe because the slots beyond `new_len` become\n" +
            "// unreachable through this handle.\n" +
            "HexaVal hexa_array_truncate(HexaVal arr, HexaVal new_len_v) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return arr;\n" +
            "    int64_t new_len = HX_IS_INT(new_len_v) ? HX_INT(new_len_v) : (int64_t)HX_INT(new_len_v);\n" +
            "    if (new_len < 0) new_len = 0;\n" +
            "    if (new_len > HX_ARR_LEN(arr)) new_len = HX_ARR_LEN(arr);\n" +
            "    HX_SET_ARR_LEN(arr, (int)new_len);\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// Step-4 cycle 99 port — hexa_len polymorphic dispatch ports to\n" +
            "// hexa-source rt_len (stdlib/runtime/numeric.hexa). rt_len body delegates\n" +
            "// to `byte_len(v) as int`, which lowers to `hexa_to_int(hexa_byte_len(v))`\n" +
            "// — a parallel C symbol with identical 3-way tag dispatch (str/arr/map →\n" +
            "// length, else 0). C body retained under #ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "// for the runtime.c standalone link (smoke prog.hexa, where the macro is\n" +
            "// not defined).\n" +
            "//\n" +
            "// Recursion safety: rt_len's body uses `byte_len` (→ hexa_byte_len), not\n" +
            "// `len` (→ hexa_len). hexa_byte_len does not call hexa_len. hexa_to_int\n" +
            "// does not call hexa_len. Verified safe.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_len(HexaVal v);\n" +
            "int hexa_len(HexaVal v) {\n" +
            "    return (int)HX_INT(rt_len(v));\n" +
            "}\n" +
            "#else\n" +
            "int hexa_len(HexaVal v) {\n" +
            "    if (HX_IS_STR(v)) return (int)HX_STRLEN(v);\n" +
            "    if (HX_IS_ARRAY(v)) return HX_ARR_LEN(v);\n" +
            "    if (HX_IS_MAP(v)) return HX_MAP_LEN(v);\n" +
            "    return 0;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ── Map operations (Optimization #10: hash table) ───────\n" +
            "\n" +
            "// rt 32-L: forward decls — Val arena lives below the str_concat arena\n" +
            "// (shared block chain via hexa_arena_alloc) but maintains its own scope-mark\n" +
            "// stack so str-concat marks aren't perturbed by Val scope push/pop.\n" +
            "void* hexa_arena_alloc(size_t n);  // defined below; forward decl for hmap_alloc_ex.\n" +
            "static int hexa_val_arena_on(void);\n" +
            "static void* hexa_val_arena_calloc(size_t n);\n" +
            "extern int __hexa_val_mark_top;  // defined later; gate guard for module-init Vals.\n" +
            "extern int __hexa_val_force_heap; // T33-fix-2\n" +
            "\n" +
            "// Allocate a new HexaMapTable with given hash-table capacity.\n" +
            "// rt 32-L: when from_arena=1, use bump-arena instead of malloc/calloc. Caller\n" +
            "// guarantees the table will be heapified (via hexa_val_heapify) before the\n" +
            "// arena rewind point catches up. When from_arena=0, behavior is unchanged.\n" +
            "static HexaMapTable* hmap_alloc_ex(int ht_cap, int from_arena) {\n" +
            "    HexaMapTable* t;\n" +
            "    int order_init = ht_cap < 8 ? 8 : ht_cap;\n" +
            "    if (from_arena) {\n" +
            "        // All four allocations satisfied from the same bump frontier — single\n" +
            "        // O(1) reset frees them in bulk. Zeroing via memset is required to\n" +
            "        // satisfy the pre-existing calloc guarantees that hmap_find / load-\n" +
            "        // factor checks rely on (slots[].key == NULL means empty).\n" +
            "        t = (HexaMapTable*)hexa_val_arena_calloc(sizeof(HexaMapTable));\n" +
            "        t->slots = (HexaMapSlot*)hexa_val_arena_calloc(ht_cap * sizeof(HexaMapSlot));\n" +
            "        t->vals  = (HexaVal*)hexa_val_arena_calloc(ht_cap * sizeof(HexaVal));\n" +
            "        t->order_keys = (char**)hexa_val_arena_calloc(sizeof(char*) * order_init);\n" +
            "        t->order_vals = (HexaVal*)hexa_val_arena_calloc(sizeof(HexaVal) * order_init);\n" +
            "        t->from_arena = 1;\n" +
            "    } else {\n" +
            "        t = (HexaMapTable*)calloc(1, sizeof(HexaMapTable));\n" +
            "        t->slots = (HexaMapSlot*)calloc(ht_cap, sizeof(HexaMapSlot));\n" +
            "        t->vals  = (HexaVal*)calloc(ht_cap, sizeof(HexaVal));\n" +
            "        t->order_keys = (char**)malloc(sizeof(char*) * order_init);\n" +
            "        t->order_vals = (HexaVal*)malloc(sizeof(HexaVal) * order_init);\n" +
            "        t->from_arena = 0;\n" +
            "    }\n" +
            "    t->ht_cap = ht_cap;\n" +
            "    t->order_cap = order_init;\n" +
            "    t->len = 0;\n" +
            "    return t;\n" +
            "}\n" +
            "\n" +
            "// Backward-compat wrapper — preserves the heap-only signature for callers that\n" +
            "// must guarantee long-lived storage (env caches, fn body maps, etc.).\n" +
            "static HexaMapTable* hmap_alloc(int ht_cap) {\n" +
            "    return hmap_alloc_ex(ht_cap, 0);\n" +
            "}\n" +
            "\n" +
            "// Rehash the table to double its capacity.\n" +
            "static void hmap_grow(HexaMapTable* t) {\n" +
            "    int old_cap = t->ht_cap;\n" +
            "    HexaMapSlot* old_slots = t->slots;\n" +
            "    HexaVal* old_vals = t->vals;\n" +
            "    int new_cap = old_cap * 2;\n" +
            "    HexaMapSlot* new_slots = (HexaMapSlot*)calloc(new_cap, sizeof(HexaMapSlot));\n" +
            "    HexaVal* new_vals = (HexaVal*)calloc(new_cap, sizeof(HexaVal));\n" +
            "    uint32_t mask = (uint32_t)(new_cap - 1);\n" +
            "    for (int i = 0; i < old_cap; i++) {\n" +
            "        if (old_slots[i].key) {\n" +
            "            uint32_t idx = old_slots[i].hash & mask;\n" +
            "            while (new_slots[idx].key) idx = (idx + 1) & mask;\n" +
            "            new_slots[idx] = old_slots[i];\n" +
            "            new_vals[idx]  = old_vals[i];\n" +
            "        }\n" +
            "    }\n" +
            "    // T33: do NOT free arena-allocated old buffers — free() on arena mem is UB.\n" +
            "    // The arena will reclaim them on scope pop.\n" +
            "    if (!t->from_arena) {\n" +
            "        free(old_slots);\n" +
            "        free(old_vals);\n" +
            "    }\n" +
            "    t->slots = new_slots;\n" +
            "    t->vals  = new_vals;\n" +
            "    t->ht_cap = new_cap;\n" +
            "    // Mark table as heap-backed for future growth/free decisions — the slots/\n" +
            "    // vals/order arrays may still be arena, but new_slots/new_vals here are\n" +
            "    // heap, so subsequent free(t->slots) after arena pop would be safe. Keep\n" +
            "    // from_arena unchanged since order_keys/order_vals still carry the\n" +
            "    // original allocation site.\n" +
            "}\n" +
            "\n" +
            "// Find slot index for key, or -1 if not found.\n" +
            "int hmap_find(HexaMapTable* t, const char* key, uint32_t h) {\n" +
            "    uint32_t mask = (uint32_t)(t->ht_cap - 1);\n" +
            "    uint32_t idx = h & mask;\n" +
            "    while (t->slots[idx].key) {\n" +
            "        if (t->slots[idx].hash == h && hxlcl_strcmp(t->slots[idx].key, key) == 0)\n" +
            "            return (int)idx;\n" +
            "        idx = (idx + 1) & mask;\n" +
            "    }\n" +
            "    return -1;\n" +
            "}\n" +
            "\n" +
            "/* Step 3 cycle 107 - map basic-op opaque-pointer escape (RUNTIME.md\n" +
            " * remaining #5 partial discharge: contains_key + keys + values + get-by-\n" +
            " * cstr ported, set/remove remain CORE-final). The inline builtins\n" +
            " * __map_has_cstr_v / __map_get_cstr_v / __map_order_key_at /\n" +
            " * __map_order_val_at lower to direct accesses on HexaMapTable fields +\n" +
            " * hmap_find / hexa_fnv1a_str (de-staticized above). No new runtime\n" +
            " * symbol; helpers compose existing primitives.\n" +
            " *\n" +
            " * Placed in runtime_core.c (not runtime.h) so user-transpiled TUs which\n" +
            " * sed-include runtime.c (build_aprime stage 3) see the symbols. The\n" +
            " * codegen-inline emit in self/codegen.hexa fully expands the call\n" +
            " * site to a direct invocation of these helpers; stale hexat binaries\n" +
            " * emit hexa_call2(__map_has_cstr_v, m, k) which resolves via the\n" +
            " * _Generic fn-ptr lane (HexaVal (*)(HexaVal, HexaVal)). */\n" +
            "static inline HexaVal __map_has_cstr_v(HexaVal m, HexaVal key) {\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (!t) return hexa_bool(0);\n" +
            "    const char* k = HX_STR(key);\n" +
            "    if (!k) return hexa_bool(0);\n" +
            "    return hexa_bool(hmap_find(t, k, hexa_fnv1a_str(k)) >= 0);\n" +
            "}\n" +
            "\n" +
            "static inline HexaVal __map_get_cstr_v(HexaVal m, HexaVal key) {\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (!t) return hexa_void();\n" +
            "    const char* k = HX_STR(key);\n" +
            "    if (!k) return hexa_void();\n" +
            "    int si = hmap_find(t, k, hexa_fnv1a_str(k));\n" +
            "    if (si < 0) return hexa_void();\n" +
            "    return t->vals[si];\n" +
            "}\n" +
            "\n" +
            "static inline HexaVal __map_order_key_at(HexaVal m, HexaVal i) {\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (!t) return hexa_void();\n" +
            "    int idx = (int)HX_INT(i);\n" +
            "    if (idx < 0 || idx >= t->len) return hexa_void();\n" +
            "    return hexa_str(t->order_keys[idx]);\n" +
            "}\n" +
            "\n" +
            "static inline HexaVal __map_order_val_at(HexaVal m, HexaVal i) {\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (!t) return hexa_void();\n" +
            "    int idx = (int)HX_INT(i);\n" +
            "    if (idx < 0 || idx >= t->len) return hexa_void();\n" +
            "    return t->order_vals[idx];\n" +
            "}\n" +
            "\n" +
            "/* RUNTIME.md step-3 cycle 108 — map set/remove ALIASING PORTS (잔여 #5\n" +
            " * full surface closure 6/6). Honest @D g3 scope: the Robin Hood insert/\n" +
            " * delete + key intern (hxlcl_strdup) + hmap_grow / order array realloc\n" +
            " * + free logic stays in C as `hexa_map_set_impl` / `hexa_map_remove_impl`\n" +
            " * (the renamed legacy bodies — irreducible allocator floor). The hexa-\n" +
            " * source `rt_map_set` / `rt_map_remove` are passthroughs through the\n" +
            " * opaque builtins below; they add NO new logic. Gain = surface\n" +
            " * function dispatchable from hexa source + all 6 잔여 #5 ops now\n" +
            " * have hexa-source presence; future surface refactor (e.g. instrumenta-\n" +
            " * tion, alternate policy) becomes a hexa edit. NOT gained = C-floor\n" +
            " * reduction or retirement % bump beyond +0.4% (2 surface fns flip,\n" +
            " * impl unchanged).\n" +
            " *\n" +
            " * Static-inline lowering: codegen emits\n" +
            " *   __map_set_cstr_v(m, k, v) → hexa_map_set_impl(<m>, HX_STR(<k>), <v>)\n" +
            " *   __map_remove_cstr_v(m, k) → hexa_map_remove_impl(<m>, HX_STR(<k>))\n" +
            " * Stale hexat binaries that don't yet inline the builtin take the\n" +
            " * hexa_call2/3 _Generic fn-ptr lane through these helpers. */\n" +
            "HexaVal hexa_map_set_impl(HexaVal m, const char* key, HexaVal val);\n" +
            "HexaVal hexa_map_remove_impl(HexaVal m, const char* key);\n" +
            "\n" +
            "static inline HexaVal __map_set_cstr_v(HexaVal m, HexaVal key, HexaVal val) {\n" +
            "    const char* k = HX_STR(key);\n" +
            "    if (!k) return m;\n" +
            "    return hexa_map_set_impl(m, k, val);\n" +
            "}\n" +
            "\n" +
            "static inline HexaVal __map_remove_cstr_v(HexaVal m, HexaVal key) {\n" +
            "    const char* k = HX_STR(key);\n" +
            "    if (!k) return m;\n" +
            "    return hexa_map_remove_impl(m, k);\n" +
            "}\n" +
            "\n" +
            "\n" +
            "HexaVal hexa_map_new() {\n" +
            "    if (_hx_stats_on()) _hx_stats_map_new++;\n" +
            "    HexaVal v = {.tag=TAG_MAP};\n" +
            "    HX_SET_MAP_PTR(v, (HexaMap*)calloc(1, sizeof(HexaMap)));\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "// rt 32-A: bulk struct constructor — collapses 1 map_new + N map_set into a\n" +
            "// single pre-sized table allocation + tight insertion loop. Used by\n" +
            "// gen2_struct_decl for `Val { ... }` and other struct literals. Avoids N\n" +
            "// successive hexa_map_set calls (each with its own stats bump + load-factor\n" +
            "// check). Key array is NOT freed; strings must be string literals (stable).\n" +
            "HexaVal hexa_struct_pack_map(const char* type_name, int n,\n" +
            "                             const char* const* keys, const HexaVal* vals) {\n" +
            "    if (_hx_stats_on()) _hx_stats_map_new++;\n" +
            "    HexaVal v = {.tag=TAG_MAP};\n" +
            "    HX_SET_MAP_PTR(v, (HexaMap*)calloc(1, sizeof(HexaMap)));\n" +
            "    // Pre-size: (n+1) entries including __type__, target load < HMAP_LOAD_MAX/100.\n" +
            "    // Solve for smallest power-of-2 cap where (n+1)*100/cap < HMAP_LOAD_MAX.\n" +
            "    int need = (n + 1) * 100 / HMAP_LOAD_MAX + 1;\n" +
            "    int cap = HMAP_INIT_CAP;\n" +
            "    while (cap < need) cap <<= 1;\n" +
            "    // rt 32-L: opt-in arena allocation for struct literals. Anonymous map\n" +
            "    // literals (type_name == \"\" or NULL) are excluded — they often back\n" +
            "    // long-lived data (config, AST nodes, registries) where the heapify\n" +
            "    // discipline is not currently wired. Type_named struct literals are the\n" +
            "    // hot fib path (every Val{...} in the interpreter) and the primary RSS\n" +
            "    // contributor at K=30. The arena gate is HEXA_VAL_ARENA (separate from\n" +
            "    // HEXA_STR_ARENA so the two can be tuned independently).\n" +
            "    int from_arena = (type_name && type_name[0]) ?\n" +
            "                     (hexa_val_arena_on() && __hexa_val_mark_top > 0) : 0;\n" +
            "    HexaMapTable* t = hmap_alloc_ex(cap, from_arena);\n" +
            "    HX_SET_MAP_TBL(v, t);\n" +
            "    uint32_t mask = (uint32_t)(cap - 1);\n" +
            "    // Insert __type__ first (skip for anonymous map literals where\n" +
            "    // type_name is \"\" — they don't carry a __type__ field).\n" +
            "    if (type_name && type_name[0]) {\n" +
            "        uint32_t h = hexa_fnv1a_str(\"__type__\");\n" +
            "        uint32_t idx = h & mask;\n" +
            "        while (t->slots[idx].key) idx = (idx + 1) & mask;\n" +
            "        // Keys/values strdup'd into heap regardless of from_arena: heapify()\n" +
            "        // can shallow-share these strings (keys are usually literal-like and\n" +
            "        // the arena would otherwise force per-string heap copies on every\n" +
            "        // heapify call, defeating the win). The TAG_STR value `tv` payload is\n" +
            "        // also strdup'd; for arena path we instead arena-alloc to keep the\n" +
            "        // bulk-free property.\n" +
            "        if (from_arena) {\n" +
            "            char* kdup = (char*)hexa_arena_alloc(hxlcl_strlen(\"__type__\") + 1);\n" +
            "            hxlcl_memcpy(kdup, \"__type__\", 9);\n" +
            "            t->slots[idx].key = kdup;\n" +
            "            // perf-31: even on the arena path, the VALUE string must use the\n" +
            "            // heap header allocator — HX_STRLEN reads bytes [-16] before the\n" +
            "            // data pointer, and arena memory has no allocator-metadata pad\n" +
            "            // (could segfault at the start of a fresh arena block). Map keys\n" +
            "            // stay in arena since they're never read via HX_STRLEN (slot.key\n" +
            "            // is a raw char* used only for strcmp during lookup).\n" +
            "            size_t tnl = hxlcl_strlen(type_name);\n" +
            "            HexaVal tv = {.tag=TAG_STR, .s=hexa_strbuf_dup_n(type_name, tnl)};\n" +
            "            t->slots[idx].hash = h;\n" +
            "            t->slots[idx].order_idx = t->len;  // ROI-24\n" +
            "            t->vals[idx] = tv;\n" +
            "            t->order_keys[t->len] = t->slots[idx].key;\n" +
            "            t->order_vals[t->len] = tv;\n" +
            "        } else {\n" +
            "            t->slots[idx].key = hxlcl_strdup(\"__type__\");\n" +
            "            t->slots[idx].hash = h;\n" +
            "            t->slots[idx].order_idx = t->len;  // ROI-24\n" +
            "            // perf-31: header-alloc replaces strdup so HX_STRLEN is O(1).\n" +
            "            size_t tnl = hxlcl_strlen(type_name);\n" +
            "            HexaVal tv = {.tag=TAG_STR, .s=hexa_strbuf_dup_n(type_name, tnl)};\n" +
            "            t->vals[idx] = tv;\n" +
            "            t->order_keys[t->len] = t->slots[idx].key;\n" +
            "            t->order_vals[t->len] = tv;\n" +
            "        }\n" +
            "        t->len++;\n" +
            "    }\n" +
            "    for (int i = 0; i < n; i++) {\n" +
            "        const char* k = keys[i];\n" +
            "        uint32_t h = hexa_fnv1a_str(k);\n" +
            "        uint32_t idx = h & mask;\n" +
            "        while (t->slots[idx].key) idx = (idx + 1) & mask;\n" +
            "        if (from_arena) {\n" +
            "            size_t kl = hxlcl_strlen(k);\n" +
            "            char* kdup = (char*)hexa_arena_alloc(kl + 1);\n" +
            "            hxlcl_memcpy(kdup, k, kl + 1);\n" +
            "            t->slots[idx].key = kdup;\n" +
            "        } else {\n" +
            "            t->slots[idx].key = hxlcl_strdup(k);\n" +
            "        }\n" +
            "        t->slots[idx].hash = h;\n" +
            "        t->slots[idx].order_idx = t->len;  // ROI-24\n" +
            "        // ROI #148: break caller→struct-field array aliasing. A struct\n" +
            "        // literal's array fields must own a private backing buffer so\n" +
            "        // that `.push` mutations on one instance cannot leak into a\n" +
            "        // sibling struct built from the same source array.\n" +
            "        // Type-named struct literals only — anonymous map literals\n" +
            "        // (type_name==\"\") preserve raw-store semantics (map of scalars,\n" +
            "        // no ownership contract).\n" +
            "        HexaVal stored = vals[i];\n" +
            "        if (type_name && type_name[0] && HX_IS_ARRAY(stored)) {\n" +
            "            stored = hexa_array_shallow_clone(stored);\n" +
            "        }\n" +
            "        t->vals[idx] = stored;\n" +
            "        t->order_keys[t->len] = t->slots[idx].key;\n" +
            "        t->order_vals[t->len] = stored;\n" +
            "        t->len++;\n" +
            "    }\n" +
            "    HX_SET_MAP_LEN(v, t->len);\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "/* RUNTIME.md step-3 cycle 108 — aliasing port. The body below is the\n" +
            " * legacy hexa_map_set Robin Hood insert + intern + grow; renamed to\n" +
            " * `_impl` so the hexa-source `rt_map_set` (which lowers to\n" +
            " * __map_set_cstr_v → hexa_map_set_impl) can call it without recursing\n" +
            " * through its own surface symbol. The `hexa_map_set` symbol now lives\n" +
            " * further down as a thin dispatch wrapper that prefers `rt_map_set`\n" +
            " * when HEXA_HAS_HEXA_RT_STDLIB is defined. */\n" +
            "HexaVal hexa_map_set_impl(HexaVal m, const char* key, HexaVal val) {\n" +
            "    // rt 32-G: route Val field mutation to flat struct.\n" +
            "    if (HX_IS_VALSTRUCT(m)) {\n" +
            "        return hexa_valstruct_set_by_key(m, key, val);\n" +
            "    }\n" +
            "    if (_hx_stats_on()) _hx_stats_map_set++;\n" +
            "    // Lazy-alloc table on first insert\n" +
            "    if (!HX_MAP_TBL(m)) {\n" +
            "        HX_SET_MAP_TBL(m, hmap_alloc(HMAP_INIT_CAP));\n" +
            "    }\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    uint32_t h = hexa_fnv1a_str(key);\n" +
            "\n" +
            "    // Check if key exists (O(1) average)\n" +
            "    int si = hmap_find(t, key, h);\n" +
            "    if (si >= 0) {\n" +
            "        t->vals[si] = val;\n" +
            "        // ROI-24: O(1) order-array update via cached order_idx\n" +
            "        t->order_vals[t->slots[si].order_idx] = val;\n" +
            "        return m;\n" +
            "    }\n" +
            "\n" +
            "    // Grow hash table if needed\n" +
            "    if (t->len * 100 / t->ht_cap >= HMAP_LOAD_MAX) {\n" +
            "        hmap_grow(t);\n" +
            "    }\n" +
            "\n" +
            "    // Insert into hash table\n" +
            "    uint32_t mask = (uint32_t)(t->ht_cap - 1);\n" +
            "    uint32_t idx = h & mask;\n" +
            "    while (t->slots[idx].key) idx = (idx + 1) & mask;\n" +
            "    t->slots[idx].key  = hxlcl_strdup(key);\n" +
            "    t->slots[idx].hash = h;\n" +
            "    t->slots[idx].order_idx = t->len;  // ROI-24: record order position\n" +
            "    t->vals[idx] = val;\n" +
            "\n" +
            "    // Append to insertion-order arrays\n" +
            "    if (t->len >= t->order_cap) {\n" +
            "        int new_cap = t->order_cap * 2;\n" +
            "        if (t->from_arena) {\n" +
            "            // T33: arena-backed tables cannot realloc — promote order arrays\n" +
            "            // to heap before grow. After promotion from_arena stays 1 for\n" +
            "            // slots/vals (still arena) but the order_* arrays are now heap.\n" +
            "            // The final heapify() will malloc-copy everything anyway; this\n" +
            "            // only handles the mid-scope growth case.\n" +
            "            char** new_keys = (char**)malloc(sizeof(char*) * new_cap);\n" +
            "            HexaVal* new_vals = (HexaVal*)malloc(sizeof(HexaVal) * new_cap);\n" +
            "            if (!new_keys || !new_vals) { fprintf(stderr, \"OOM in map_set grow\\n\"); exit(1); }\n" +
            "            hxlcl_memcpy(new_keys, t->order_keys, sizeof(char*) * t->len);\n" +
            "            hxlcl_memcpy(new_vals, t->order_vals, sizeof(HexaVal) * t->len);\n" +
            "            t->order_keys = new_keys;\n" +
            "            t->order_vals = new_vals;\n" +
            "        } else {\n" +
            "            t->order_keys = (char**)realloc(t->order_keys, sizeof(char*) * new_cap);\n" +
            "            t->order_vals = (HexaVal*)realloc(t->order_vals, sizeof(HexaVal) * new_cap);\n" +
            "        }\n" +
            "        t->order_cap = new_cap;\n" +
            "    }\n" +
            "    t->order_keys[t->len] = t->slots[idx].key;  // shared pointer, not a copy\n" +
            "    t->order_vals[t->len] = val;\n" +
            "    t->len++;\n" +
            "    HX_SET_MAP_LEN(m, t->len);\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "// RUNTIME.md step-3 cycle 108 — map set aliasing port (잔여 #5 100%\n" +
            "// surface closure 6/6). Honest @D g3 scope: rt_map_set is a passthrough\n" +
            "// to __map_set_cstr_v which inlines to hexa_map_set_impl above. The\n" +
            "// allocator/Robin Hood logic remains in C; only the surface dispatch\n" +
            "// moves through hexa source. VALSTRUCT routing is delegated to the\n" +
            "// impl (it already short-circuits at its head). Stale-binary lane:\n" +
            "// new opaque builtin `__map_set_cstr_v` lowers inline; legacy hexat\n" +
            "// emitted hexa_call3 takes the static-inline shim through the _Generic\n" +
            "// fn-ptr lane (HexaVal (*)(HexaVal, HexaVal, HexaVal)).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_set(HexaVal m, HexaVal key, HexaVal val);\n" +
            "HexaVal hexa_map_set(HexaVal m, const char* key, HexaVal val) {\n" +
            "    // Keep VALSTRUCT routing on the C side so the hexa-source rt_map_set\n" +
            "    // never needs to express flat-struct field mutation (it can't — the\n" +
            "    // valstruct path edits a non-HexaMap shape).\n" +
            "    if (HX_IS_VALSTRUCT(m)) {\n" +
            "        return hexa_valstruct_set_by_key(m, key, val);\n" +
            "    }\n" +
            "    return rt_map_set(m, hexa_str(key), val);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_set(HexaVal m, const char* key, HexaVal val) {\n" +
            "    return hexa_map_set_impl(m, key, val);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n" +
            "// dispatch the hash-lookup branch to rt_map_get_v when hexa-source\n" +
            "// stdlib is present. VALSTRUCT routing + miss-diagnostic stays C-side\n" +
            "// (cycle-38 pattern: HexaVal-typed surface, C handles tag-dispatch +\n" +
            "// fprintf). rt_map_get_v returns void on miss; C wrapper detects\n" +
            "// TAG_VOID and emits the diagnostic (matches the legacy semantic\n" +
            "// exactly).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_get_v(HexaVal m, HexaVal key);\n" +
            "HexaVal hexa_map_get(HexaVal m, const char* key) {\n" +
            "    if (HX_IS_VALSTRUCT(m)) {\n" +
            "        return hexa_valstruct_get_by_key(m, key);\n" +
            "    }\n" +
            "    if (!HX_MAP_TBL(m)) {\n" +
            "        fprintf(stderr, \"map key '%s' not found\\n\", key);\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    HexaVal v = rt_map_get_v(m, hexa_str(key));\n" +
            "    if (HX_TAG(v) == TAG_VOID) {\n" +
            "        fprintf(stderr, \"map key '%s' not found\\n\", key);\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_get(HexaVal m, const char* key) {\n" +
            "    // rt 32-G: route Val field access to flat struct accessor.\n" +
            "    if (HX_IS_VALSTRUCT(m)) {\n" +
            "        return hexa_valstruct_get_by_key(m, key);\n" +
            "    }\n" +
            "    if (!HX_MAP_TBL(m)) {\n" +
            "        fprintf(stderr, \"map key '%s' not found\\n\", key);\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    uint32_t h = hexa_fnv1a_str(key);\n" +
            "    int si = hmap_find(t, key, h);\n" +
            "    if (si >= 0) return t->vals[si];\n" +
            "    fprintf(stderr, \"map key '%s' not found\\n\", key);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ── rt#37: Inline cache for field access ─────────────────\n" +
            "// Each call site of `obj.field` gets a static HexaIC slot. On hit, we skip\n" +
            "// the strcmp-chain and return m.map.vals[ic->idx] directly. On miss we fall\n" +
            "// back to hexa_map_get and repopulate. Shape check uses (keys_ptr, len) —\n" +
            "// a struct constructor inserts keys in a fixed order, so once its (keys, len)\n" +
            "// is stable, idx is valid for every subsequent access.\n" +
            "//\n" +
            "// Invalidation: if keys pointer or len differ, we treat it as a miss. That\n" +
            "// covers (a) a different struct instance reused through the same call site\n" +
            "// and (b) a struct mutated via hexa_map_set (which may realloc the keys\n" +
            "// array). A monomorphic call site converges to ~100% hit rate after 1 call.\n" +
            "//\n" +
            "// Gate: HEXA_IC_STATS=1 dumps per-process hit/miss totals at exit.\n" +
            "\n" +
            "/* PHASE 1.2.B (2026-05-15): hits + stats_enabled de-staticized for cross-TU\n" +
            " * use by the hexa_map_get_ic macro emitted into runtime.h. misses stays\n" +
            " * static (only read inside this TU's hexa_ic_dump_stats). */\n" +
            "uint64_t g_hexa_ic_hits   = 0;\n" +
            "static uint64_t g_hexa_ic_misses = 0;\n" +
            "int      g_hexa_ic_stats_enabled   = -1; // -1=unchecked, 0=off, 1=on\n" +
            "static int      g_hexa_ic_stats_installed = 0;\n" +
            "\n" +
            "static void hexa_ic_dump_stats(void) {\n" +
            "    uint64_t total = g_hexa_ic_hits + g_hexa_ic_misses;\n" +
            "    double rate = total ? (100.0 * (double)g_hexa_ic_hits / (double)total) : 0.0;\n" +
            "    fprintf(stderr,\n" +
            "        \"[rt#37 IC] hits=%llu misses=%llu total=%llu hit_rate=%.2f%%\\n\",\n" +
            "        (unsigned long long)g_hexa_ic_hits,\n" +
            "        (unsigned long long)g_hexa_ic_misses,\n" +
            "        (unsigned long long)total,\n" +
            "        rate);\n" +
            "}\n" +
            "\n" +
            "static inline int hexa_ic_stats_on(void) {\n" +
            "    if (g_hexa_ic_stats_enabled < 0) {\n" +
            "        const char* on = hxlcl_getenv(\"HEXA_IC_STATS\");\n" +
            "        g_hexa_ic_stats_enabled = (on && on[0] != '0' && on[0] != '\\0') ? 1 : 0;\n" +
            "        if (g_hexa_ic_stats_enabled && !g_hexa_ic_stats_installed) {\n" +
            "            g_hexa_ic_stats_installed = 1;\n" +
            "            hxlcl_atexit(hexa_ic_dump_stats);\n" +
            "        }\n" +
            "    }\n" +
            "    return g_hexa_ic_stats_enabled;\n" +
            "}\n" +
            "\n" +
            "// Slow path: full scan + update cache. Kept out-of-line to shrink the inline\n" +
            "// hot path macro footprint. Stats bump lives here so hits stay counter-free\n" +
            "// when HEXA_IC_STATS is unset.\n" +
            "// rt#32-N build-fix: rt#37 referenced m.map.{keys,vals} which were removed by\n" +
            "// rt#32-G when map storage moved to HexaMapTable. Redirect through .tbl.\n" +
            "/* PHASE 1.2.B (2026-05-15): de-staticized. Slow-path fallback for the\n" +
            " * hexa_map_get_ic hot-path macro emitted into runtime.h — user.c TUs link\n" +
            " * against this. */\n" +
            "/* PROBE r14: Range repr accessors. Defined later in runtime.c (after the\n" +
            " * textual #include of this file); forward-declared so the array-receiver\n" +
            " * fallback below resolves at compile time. */\n" +
            "HexaVal hexa_range_field(HexaVal v, const char* key);\n" +
            "\n" +
            "HexaVal hexa_map_get_ic_slow(HexaVal m, const char* key, HexaIC* ic) {\n" +
            "    if (hexa_ic_stats_on()) { ic->misses++; g_hexa_ic_misses++; }\n" +
            "    if (HX_IS_MAP(m) && HX_MAP_TBL(m)) {\n" +
            "        HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "        // ROI-43: O(1) avg via hmap_find instead of O(n) linear scan.\n" +
            "        uint32_t h = hexa_fnv1a_str(key);\n" +
            "        int si = hmap_find(t, key, h);\n" +
            "        if (si >= 0) {\n" +
            "            int oi = t->slots[si].order_idx;  // ROI-24 cached order index\n" +
            "            ic->keys_ptr = (void*)t->order_keys;\n" +
            "            ic->len      = t->len;\n" +
            "            ic->idx      = oi;\n" +
            "            return t->order_vals[oi];\n" +
            "        }\n" +
            "    }\n" +
            "    // PROBE r14: Range repr — `.start` / `.end` / `.len` field access on a\n" +
            "    // materialized range value (an int array, see hexa_range_array). Map\n" +
            "    // receivers never reach here for these keys (handled above), so this\n" +
            "    // only fires for array receivers, recovering the range bounds that were\n" +
            "    // previously lost (\"map key 'start' not found\" → void). Non-range arrays\n" +
            "    // gain harmless `.len`/`.start`/`.end` field accessors as a side effect.\n" +
            "    if (HX_IS_ARRAY(m) &&\n" +
            "        (strcmp(key, \"start\") == 0 || strcmp(key, \"end\") == 0 || strcmp(key, \"len\") == 0)) {\n" +
            "        return hexa_range_field(m, key);\n" +
            "    }\n" +
            "    return hexa_map_get(m, key);\n" +
            "}\n" +
            "\n" +
            "// Hot path as a MACRO so the fast path avoids the 32-byte HexaVal call ABI\n" +
            "// altogether. We evaluate `m` exactly once via __ic_m to be safe with side\n" +
            "// effects, then:\n" +
            "//   - if (m.map.keys == ic->keys_ptr && m.map.len == ic->len) -> return cached\n" +
            "//   - else                                                   -> slow fallback\n" +
            "// The stat bump on the hot path is compiled out when HEXA_IC_STATS is unset\n" +
            "// because g_hexa_ic_stats_enabled flips to 0 on first slow path miss.\n" +
            "// rt#32-N build-fix: m.map.{keys,vals} -> m.map.tbl->{order_keys,order_vals}\n" +
            "#define hexa_map_get_ic(M, KEY, IC) \\\n" +
            "    ({ HexaVal __ic_m = (M); HexaIC* __ic = (IC); \\\n" +
            "       (HX_MAP_TBL(__ic_m) \\\n" +
            "        && (void*)HX_MAP_TBL(__ic_m)->order_keys == __ic->keys_ptr \\\n" +
            "        && HX_MAP_TBL(__ic_m)->len == __ic->len \\\n" +
            "        && __ic->idx < __ic->len) \\\n" +
            "           ? (g_hexa_ic_stats_enabled > 0 \\\n" +
            "              ? (__ic->hits++, g_hexa_ic_hits++, HX_MAP_TBL(__ic_m)->order_vals[__ic->idx]) \\\n" +
            "              : HX_MAP_TBL(__ic_m)->order_vals[__ic->idx]) \\\n" +
            "           : hexa_map_get_ic_slow(__ic_m, (KEY), __ic); })\n" +
            "\n" +
            "\n" +
            "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n" +
            "// dispatch to rt_map_keys when hexa-source stdlib is present. C body\n" +
            "// retained for runtime.c standalone link.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_keys(HexaVal m);\n" +
            "HexaVal hexa_map_keys(HexaVal m) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_array_new();\n" +
            "    return rt_map_keys(m);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_keys(HexaVal m) {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (!HX_MAP_TBL(m)) return arr;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    arr = hexa_array_reserve(arr, t->len);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        arr = hexa_array_push(arr, hexa_str(t->order_keys[i]));\n" +
            "    }\n" +
            "    return arr;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n" +
            "// dispatch to rt_map_values when hexa-source stdlib is present.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_values(HexaVal m);\n" +
            "HexaVal hexa_map_values(HexaVal m) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_array_new();\n" +
            "    return rt_map_values(m);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_values(HexaVal m) {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (!HX_MAP_TBL(m)) return arr;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    arr = hexa_array_reserve(arr, t->len);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        arr = hexa_array_push(arr, t->order_vals[i]);\n" +
            "    }\n" +
            "    return arr;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 107 port (RUNTIME.md remaining #5 partial discharge):\n" +
            "// dispatch to rt_map_contains_key_b when hexa-source stdlib is present.\n" +
            "// C wrapper handles the const char* -> HexaVal string boxing so the hexa\n" +
            "// port can stay HexaVal-typed end-to-end.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "// rt_ port returns HexaVal (bool tag wrapper); hexa_truthy unwraps to int\n" +
            "// (cycle-54 int-return bridge pattern).\n" +
            "extern HexaVal rt_map_contains_key_b(HexaVal m, HexaVal key);\n" +
            "int hexa_map_contains_key(HexaVal m, const char* key) {\n" +
            "    if (!HX_MAP_TBL(m)) return 0;\n" +
            "    return hexa_truthy(rt_map_contains_key_b(m, hexa_str(key)));\n" +
            "}\n" +
            "#else\n" +
            "int hexa_map_contains_key(HexaVal m, const char* key) {\n" +
            "    if (!HX_MAP_TBL(m)) return 0;\n" +
            "    uint32_t h = hexa_fnv1a_str(key);\n" +
            "    return hmap_find(HX_MAP_TBL(m), key, h) >= 0;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// entries: flat array of [key, value] pairs. Keys come out as strings\n" +
            "// (HexaMap stores keys as char*). Matches interpreter semantics at\n" +
            "// self/hexa_full.hexa:15558-15568.\n" +
            "// Step-3 cycle 38 port — dispatch to rt_map_entries when hexa-source\n" +
            "// stdlib is present. C body retained for runtime.c standalone link.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_entries(HexaVal m);\n" +
            "HexaVal hexa_map_entries(HexaVal m) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_array_new();\n" +
            "    return rt_map_entries(m);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_entries(HexaVal m) {\n" +
            "    HexaVal out = hexa_array_new();\n" +
            "    if (!HX_MAP_TBL(m)) return out;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        HexaVal pair = hexa_array_new();\n" +
            "        pair = hexa_array_push(pair, hexa_str(t->order_keys[i]));\n" +
            "        pair = hexa_array_push(pair, t->order_vals[i]);\n" +
            "        out = hexa_array_push(out, pair);\n" +
            "    }\n" +
            "    return out;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// to_array: same shape as entries() — keeps names consistent with\n" +
            "// interpreter dispatch (self/hexa_full.hexa:15611-15620).\n" +
            "// Step-3 cycle 38 — falls through to hexa_map_entries which itself\n" +
            "// dispatches; no separate rt_ wiring needed.\n" +
            "HexaVal hexa_map_to_array(HexaVal m) {\n" +
            "    return hexa_map_entries(m);\n" +
            "}\n" +
            "\n" +
            "// merge: overlay other's entries onto self. Other wins on key collision.\n" +
            "// Matches interpreter at self/hexa_full.hexa:15570-15583. Non-map `other`\n" +
            "// returns self unchanged.\n" +
            "// Step-3 cycle 38 port — map_merge dispatch to hexa-source rt_map_merge.\n" +
            "// The hexa body iterates b.keys() (array of strings) and calls b.get(k) /\n" +
            "// out.set(k, v); codegen lowers those to hexa_map_get/set with\n" +
            "// hexa_to_cstring(key), so the const-char* signature blocker is bypassed\n" +
            "// without a HexaVal-keyed C wrapper. C body retained for runtime.c\n" +
            "// standalone link (smoke test path doesn't define HEXA_HAS_HEXA_RT_STDLIB).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_merge(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_map_merge(HexaVal a, HexaVal b) {\n" +
            "    if (!HX_MAP_TBL(a)) return a;\n" +
            "    if (!HX_MAP_TBL(b)) return a;\n" +
            "    return rt_map_merge(a, b);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_merge(HexaVal a, HexaVal b) {\n" +
            "    if (!HX_MAP_TBL(a)) return a;\n" +
            "    if (!HX_MAP_TBL(b)) return a;\n" +
            "    HexaVal out = a;\n" +
            "    HexaMapTable* tb = HX_MAP_TBL(b);\n" +
            "    for (int i = 0; i < tb->len; i++) {\n" +
            "        out = hexa_map_set(out, tb->order_keys[i], tb->order_vals[i]);\n" +
            "    }\n" +
            "    return out;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-4 cycle 95 ports — map_values + filter_keys via hexa source.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_map_values(HexaVal m, HexaVal fn, HexaVal empty);\n" +
            "extern HexaVal rt_map_filter_keys(HexaVal m, HexaVal fn, HexaVal empty);\n" +
            "HexaVal hexa_map_map_values(HexaVal m, HexaVal fn) {\n" +
            "    HexaVal empty = hexa_map_new();\n" +
            "    if (!HX_MAP_TBL(m)) return empty;\n" +
            "    return rt_map_map_values(m, fn, empty);\n" +
            "}\n" +
            "HexaVal hexa_map_filter_keys(HexaVal m, HexaVal fn) {\n" +
            "    HexaVal empty = hexa_map_new();\n" +
            "    if (!HX_MAP_TBL(m)) return empty;\n" +
            "    return rt_map_filter_keys(m, fn, empty);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_map_values(HexaVal m, HexaVal fn) {\n" +
            "    HexaVal out = hexa_map_new();\n" +
            "    if (!HX_MAP_TBL(m)) return out;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        HexaVal new_val = hexa_call1(fn, t->order_vals[i]);\n" +
            "        out = hexa_map_set(out, t->order_keys[i], new_val);\n" +
            "    }\n" +
            "    return out;\n" +
            "}\n" +
            "HexaVal hexa_map_filter_keys(HexaVal m, HexaVal fn) {\n" +
            "    HexaVal out = hexa_map_new();\n" +
            "    if (!HX_MAP_TBL(m)) return out;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        HexaVal key_val = hexa_str(t->order_keys[i]);\n" +
            "        if (hexa_truthy(hexa_call1(fn, key_val))) {\n" +
            "            out = hexa_map_set(out, t->order_keys[i], t->order_vals[i]);\n" +
            "        }\n" +
            "    }\n" +
            "    return out;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// invert: swap k<->v. Values get stringified via hexa_to_string to serve\n" +
            "// as new keys (HexaMap keys are char*); original keys become string vals.\n" +
            "// Matches interpreter at self/hexa_full.hexa:15641-15645.\n" +
            "// Step-4 cycle 93 port — invert via hexa source. C wrapper supplies the\n" +
            "// empty starting map (avoids bare hexa_map_new() call0 trap).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_invert(HexaVal m, HexaVal empty);\n" +
            "HexaVal hexa_map_invert(HexaVal m) {\n" +
            "    HexaVal empty = hexa_map_new();\n" +
            "    if (!HX_MAP_TBL(m)) return empty;\n" +
            "    return rt_map_invert(m, empty);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_invert(HexaVal m) {\n" +
            "    HexaVal out = hexa_map_new();\n" +
            "    if (!HX_MAP_TBL(m)) return out;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        const char* new_key = hexa_str_as_ptr(hexa_to_string(t->order_vals[i]));\n" +
            "        if (!new_key) continue;\n" +
            "        out = hexa_map_set(out, new_key, hexa_str(t->order_keys[i]));\n" +
            "    }\n" +
            "    return out;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// from_array: build a map from an array of [k, v] pair arrays. Receiver\n" +
            "// is ignored (called as-method on an empty map per interpreter dispatch).\n" +
            "// Malformed pairs (non-array or <2 elements) are skipped. Keys are\n" +
            "// stringified. Matches interpreter at self/hexa_full.hexa:15622-15640.\n" +
            "// Step-4 cycle 93 port — from_array via hexa source.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_from_array(HexaVal arr, HexaVal empty);\n" +
            "HexaVal hexa_map_from_array(HexaVal self_map, HexaVal arr) {\n" +
            "    (void)self_map;\n" +
            "    HexaVal empty = hexa_map_new();\n" +
            "    if (!HX_IS_ARRAY(arr)) return empty;\n" +
            "    return rt_map_from_array(arr, empty);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_from_array(HexaVal self_map, HexaVal arr) {\n" +
            "    (void)self_map;\n" +
            "    HexaVal out = hexa_map_new();\n" +
            "    if (!HX_IS_ARRAY(arr)) return out;\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    for (int i = 0; i < n; i++) {\n" +
            "        HexaVal pair = HX_ARR_ITEMS(arr)[i];\n" +
            "        if (!HX_IS_ARRAY(pair) || HX_ARR_LEN(pair) < 2) continue;\n" +
            "        HexaVal k = HX_ARR_ITEMS(pair)[0];\n" +
            "        HexaVal v = HX_ARR_ITEMS(pair)[1];\n" +
            "        const char* k_str = hexa_str_as_ptr(hexa_to_string(k));\n" +
            "        if (!k_str) continue;\n" +
            "        out = hexa_map_set(out, k_str, v);\n" +
            "    }\n" +
            "    return out;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// count(pred): pred is 2-arg fn(key, value) returning truthy for hits.\n" +
            "// No-pred variant (arg is void sentinel) returns total entry count.\n" +
            "// Keys are exposed to the predicate as TAG_STR per interpreter semantics.\n" +
            "// Matches interpreter at self/hexa_full.hexa:15689-15704.\n" +
            "// Step-4 cycle 94 port — count/any/all with predicate callback via\n" +
            "// hexa source (cycle-63 callback POC). C wrapper handles HX_MAP_TBL\n" +
            "// guard + void-pred fallback (no-pred returns total count / false / true).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_count_pred(HexaVal m, HexaVal pred);\n" +
            "extern HexaVal rt_map_any_pred_b(HexaVal m, HexaVal pred);\n" +
            "extern HexaVal rt_map_all_pred_b(HexaVal m, HexaVal pred);\n" +
            "HexaVal hexa_map_count(HexaVal m, HexaVal pred) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_int(0);\n" +
            "    if (HX_IS_VOID(pred)) return hexa_int(HX_MAP_TBL(m)->len);\n" +
            "    return hexa_int(HX_INT(rt_map_count_pred(m, pred)));\n" +
            "}\n" +
            "HexaVal hexa_map_any(HexaVal m, HexaVal pred) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_bool(0);\n" +
            "    if (HX_IS_VOID(pred)) return hexa_bool(0);\n" +
            "    return hexa_bool(hexa_truthy(rt_map_any_pred_b(m, pred)));\n" +
            "}\n" +
            "HexaVal hexa_map_all(HexaVal m, HexaVal pred) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_bool(1);\n" +
            "    if (HX_IS_VOID(pred)) return hexa_bool(1);\n" +
            "    return hexa_bool(hexa_truthy(rt_map_all_pred_b(m, pred)));\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_count(HexaVal m, HexaVal pred) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_int(0);\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (HX_IS_VOID(pred)) return hexa_int(t->len);\n" +
            "    int cnt = 0;\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        HexaVal key_val = hexa_str(t->order_keys[i]);\n" +
            "        HexaVal r = hexa_call2(pred, key_val, t->order_vals[i]);\n" +
            "        if (hexa_truthy(r)) cnt++;\n" +
            "    }\n" +
            "    return hexa_int(cnt);\n" +
            "}\n" +
            "HexaVal hexa_map_any(HexaVal m, HexaVal pred) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_bool(0);\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (HX_IS_VOID(pred)) return hexa_bool(0);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        HexaVal key_val = hexa_str(t->order_keys[i]);\n" +
            "        HexaVal r = hexa_call2(pred, key_val, t->order_vals[i]);\n" +
            "        if (hexa_truthy(r)) return hexa_bool(1);\n" +
            "    }\n" +
            "    return hexa_bool(0);\n" +
            "}\n" +
            "HexaVal hexa_map_all(HexaVal m, HexaVal pred) {\n" +
            "    if (!HX_MAP_TBL(m)) return hexa_bool(1);\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    if (HX_IS_VOID(pred)) return hexa_bool(1);\n" +
            "    for (int i = 0; i < t->len; i++) {\n" +
            "        HexaVal key_val = hexa_str(t->order_keys[i]);\n" +
            "        HexaVal r = hexa_call2(pred, key_val, t->order_vals[i]);\n" +
            "        if (!hexa_truthy(r)) return hexa_bool(0);\n" +
            "    }\n" +
            "    return hexa_bool(1);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "/* RUNTIME.md step-3 cycle 108 — aliasing port. Robin Hood deletion +\n" +
            " * free + order-array compact stays in C (irreducible allocator floor).\n" +
            " * Renamed from hexa_map_remove so the hexa-source rt_map_remove can\n" +
            " * call this without recursing through its own surface symbol. */\n" +
            "HexaVal hexa_map_remove_impl(HexaVal m, const char* key) {\n" +
            "    if (!HX_MAP_TBL(m)) return m;\n" +
            "    HexaMapTable* t = HX_MAP_TBL(m);\n" +
            "    uint32_t h = hexa_fnv1a_str(key);\n" +
            "    int si = hmap_find(t, key, h);\n" +
            "    if (si < 0) return m;\n" +
            "\n" +
            "    // ROI-24: O(1) locate in order array via cached order_idx, then shift\n" +
            "    int oi = t->slots[si].order_idx;\n" +
            "    for (int j = oi; j < t->len - 1; j++) {\n" +
            "        t->order_keys[j] = t->order_keys[j+1];\n" +
            "        t->order_vals[j] = t->order_vals[j+1];\n" +
            "    }\n" +
            "    // Fix order_idx for all hash-table slots whose order position shifted\n" +
            "    for (int j = 0; j < t->ht_cap; j++) {\n" +
            "        if (t->slots[j].key && t->slots[j].order_idx > oi) {\n" +
            "            t->slots[j].order_idx--;\n" +
            "        }\n" +
            "    }\n" +
            "\n" +
            "    // Remove from hash table: mark slot empty and re-insert displaced entries\n" +
            "    free(t->slots[si].key);\n" +
            "    t->slots[si].key = NULL;\n" +
            "    t->slots[si].hash = 0;\n" +
            "    // Robin Hood deletion: re-probe subsequent slots\n" +
            "    uint32_t mask = (uint32_t)(t->ht_cap - 1);\n" +
            "    uint32_t ci = ((uint32_t)si + 1) & mask;\n" +
            "    while (t->slots[ci].key) {\n" +
            "        // Remove and re-insert this entry\n" +
            "        HexaMapSlot saved_slot = t->slots[ci];\n" +
            "        HexaVal saved_val = t->vals[ci];\n" +
            "        t->slots[ci].key = NULL;\n" +
            "        t->slots[ci].hash = 0;\n" +
            "        uint32_t ri = saved_slot.hash & mask;\n" +
            "        while (t->slots[ri].key) ri = (ri + 1) & mask;\n" +
            "        t->slots[ri] = saved_slot;  // ROI-24: order_idx carried in struct copy\n" +
            "        t->vals[ri] = saved_val;\n" +
            "        ci = (ci + 1) & mask;\n" +
            "    }\n" +
            "\n" +
            "    t->len--;\n" +
            "    HX_SET_MAP_LEN(m, t->len);\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "// RUNTIME.md step-3 cycle 108 — map remove aliasing port (잔여 #5 100%\n" +
            "// surface closure 6/6). Honest @D g3 scope: rt_map_remove is a\n" +
            "// passthrough to __map_remove_cstr_v which inlines to hexa_map_remove_impl\n" +
            "// above. No new logic added; the surface fn merely flips dispatch site.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_map_remove(HexaVal m, HexaVal key);\n" +
            "HexaVal hexa_map_remove(HexaVal m, const char* key) {\n" +
            "    return rt_map_remove(m, hexa_str(key));\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_map_remove(HexaVal m, const char* key) {\n" +
            "    return hexa_map_remove_impl(m, key);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Polymorphic index get: array[int] or map[string]\n" +
            "HexaVal hexa_index_get(HexaVal container, HexaVal key) {\n" +
            "    if (HX_IS_MAP(container) && HX_IS_STR(key)) {\n" +
            "        return hexa_map_get(container, HX_STR(key));\n" +
            "    }\n" +
            "    // PROBE r16 Q4: maps are fundamentally string→value (keys are interned\n" +
            "    // c-strings). A non-string key on a map (e.g. `m[5]`) previously fell to the\n" +
            "    // array path and aborted \"container is not an array (tag=6)\". Stringify the\n" +
            "    // key consistently (mirrors hexa_index_set + the int-key map-literal codegen)\n" +
            "    // so `m[5]` and `m[\"5\"]` agree. hexa_to_cstring returns a short-lived static\n" +
            "    // buffer; hexa_map_get only reads it, so the lifetime is safe here.\n" +
            "    if (HX_IS_MAP(container)) {\n" +
            "        return hexa_map_get(container, hexa_to_cstring(key));\n" +
            "    }\n" +
            "    // 2026-04-17: unwrap interpreter Val wrapper (TAG_VALSTRUCT) so HX_INT\n" +
            "    // doesn't read .vs as a pointer-as-int garbage index. Same root as the\n" +
            "    // hexa_cmp_* fix — without this, val_int's `__VAL_INT_CACHE[n]` lookup\n" +
            "    // OOB-aborted when n was a wrapped Val.\n" +
            "    int64_t idx;\n" +
            "    if (HX_IS_VALSTRUCT(key) && HX_VS(key)) {\n" +
            "        idx = (HX_VSF(key, tag_i) == TAG_INT)\n" +
            "            ? HX_VSF(key, int_val)\n" +
            "            : (int64_t)__hx_to_double(key);\n" +
            "    } else {\n" +
            "        idx = HX_INT(key);\n" +
            "    }\n" +
            "    // hxa-20260423-015: str[i] support. The AOT codegen lowers every\n" +
            "    // IndexGet to hexa_index_get(), so without this branch a `path[i]`\n" +
            "    // on a string (e.g. self/module_loader.hexa:ml_dirname) reached\n" +
            "    // hexa_array_get() and aborted with \"array[N]: container is not\n" +
            "    // an array (tag=3)\". The interp interpreter has its own string-\n" +
            "    // index path; this mirrors it for the AOT path.\n" +
            "    if (HX_IS_STR(container)) {\n" +
            "        return hexa_str_char_at(container, hexa_int(idx));\n" +
            "    }\n" +
            "    return hexa_array_get(container, idx);\n" +
            "}\n" +
            "\n" +
            "// For-in dispatch: array -> element, map -> key as string.\n" +
            "// Uses insertion-order arrays so maps iterate in insertion order (Python-style).\n" +
            "HexaVal hexa_iter_get(HexaVal v, int64_t idx) {\n" +
            "    if (HX_IS_MAP(v)) {\n" +
            "        if (!HX_MAP_TBL(v) || idx < 0 || idx >= HX_MAP_LEN(v)) {\n" +
            "            fprintf(stderr, \"map iter index %lld out of bounds (len %d)\\n\", (long long)idx, HX_MAP_LEN(v));\n" +
            "            exit(1);\n" +
            "        }\n" +
            "        return hexa_str(HX_MAP_TBL(v)->order_keys[idx]);\n" +
            "    }\n" +
            "    return hexa_array_get(v, idx);\n" +
            "}\n" +
            "\n" +
            "// Polymorphic index set: array[int]=val or map[string]=val\n" +
            "HexaVal hexa_index_set(HexaVal container, HexaVal key, HexaVal val) {\n" +
            "    if (HX_IS_MAP(container) && HX_IS_STR(key)) {\n" +
            "        return hexa_map_set(container, HX_STR(key), val);\n" +
            "    }\n" +
            "    // PROBE r16 Q4: a non-string key on a map (e.g. `m[5] = 100`) previously\n" +
            "    // fell to the array path and aborted \"container is not an array (tag=6)\".\n" +
            "    // Stringify the key (mirrors hexa_index_get + the int-key map-literal codegen)\n" +
            "    // so `m[5]=v` and `m[\"5\"]` agree. hexa_map_set_impl strdup's the key, so the\n" +
            "    // short-lived hexa_to_cstring static buffer is safe.\n" +
            "    if (HX_IS_MAP(container)) {\n" +
            "        return hexa_map_set(container, hexa_to_cstring(key), val);\n" +
            "    }\n" +
            "    // 2026-04-17: unwrap VALSTRUCT same as hexa_index_get — without this,\n" +
            "    // HX_INT reads raw .vs pointer as index → \"index 105553... out of bounds\"\n" +
            "    int64_t idx;\n" +
            "    if (HX_IS_VALSTRUCT(key) && HX_VS(key)) {\n" +
            "        idx = (HX_VSF(key, tag_i) == TAG_INT)\n" +
            "            ? HX_VSF(key, int_val)\n" +
            "            : (int64_t)__hx_to_double(key);\n" +
            "    } else {\n" +
            "        idx = HX_INT(key);\n" +
            "    }\n" +
            "    return hexa_array_set(container, idx, val);\n" +
            "}\n" +
            "\n" +
            "// Silent type check for struct method dispatch (codegen ImplBlock support).\n" +
            "// Returns 1 if v is a TAG_MAP carrying a \"__type__\" field equal to type_name,\n" +
            "// or TAG_VALSTRUCT (always type \"Val\" — rt 32-G flat struct).\n" +
            "// Uses hash lookup instead of linear scan.\n" +
            "int hexa_is_type(HexaVal v, const char* type_name) {\n" +
            "    if (HX_IS_VALSTRUCT(v)) {\n" +
            "        return type_name && hxlcl_strcmp(type_name, \"Val\") == 0;\n" +
            "    }\n" +
            "    if (!HX_IS_MAP(v) || !HX_MAP_TBL(v)) return 0;\n" +
            "    uint32_t h = hexa_fnv1a_str(\"__type__\");\n" +
            "    int si = hmap_find(HX_MAP_TBL(v), \"__type__\", h);\n" +
            "    if (si < 0) return 0;\n" +
            "    HexaVal t = HX_MAP_TBL(v)->vals[si];\n" +
            "    return HX_IS_STR(t) && HX_STR(t) && hxlcl_strcmp(HX_STR(t), type_name) == 0;\n" +
            "}\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────────────────\n" +
            "// RFC-022 §4.2 — `await x` runtime helper (G2 codegen integration).\n" +
            "//\n" +
            "// Mirrors the interpreter's Await branch at self/hexa_full.hexa:8048-8057:\n" +
            "//\n" +
            "//     if v.tag == TAG_STRUCT && v.struct_name == \"Future\" {\n" +
            "//         let fields = get_struct_fields(v)\n" +
            "//         if type_of(fields) == \"map\" { return map_get(fields, \"value\") }\n" +
            "//     }\n" +
            "//     return v\n" +
            "//\n" +
            "// Native runtime represents user structs as TAG_MAP carrying a \"__type__\"\n" +
            "// field (see hexa_struct_pack_map / hexa_is_type above). So the equivalent\n" +
            "// of \"v.struct_name == \"Future\"\" is hexa_is_type(v, \"Future\"). Once we\n" +
            "// confirm that shape we extract the \"value\" field via hexa_map_get; if\n" +
            "// the field is missing or void/null, fall back to identity (matches\n" +
            "// interp's stage-1 \"already-resolved\" optimisation).\n" +
            "//\n" +
            "// For non-Future or non-struct values, await is identity — every `await x`\n" +
            "// in user code that lowers through native codegen wraps the inner expr in\n" +
            "// a hexa_await_unwrap() call (see self/codegen.hexa gen2_expr Await\n" +
            "// branch). This keeps the interp ↔ native parity contract from RFC-022 §3.1.\n" +
            "HexaVal hexa_await_unwrap(HexaVal v) {\n" +
            "    if (hexa_is_type(v, \"Future\")) {\n" +
            "        if (HX_IS_MAP(v) && HX_MAP_TBL(v)) {\n" +
            "            uint32_t h = hexa_fnv1a_str(\"value\");\n" +
            "            int si = hmap_find(HX_MAP_TBL(v), \"value\", h);\n" +
            "            if (si >= 0) {\n" +
            "                HexaVal inner = HX_MAP_TBL(v)->vals[si];\n" +
            "                if (inner.tag != TAG_VOID) {\n" +
            "                    return inner;\n" +
            "                }\n" +
            "            }\n" +
            "        }\n" +
            "    }\n" +
            "    return v;  // identity for non-Future or already-resolved values\n" +
            "}\n" +
            "\n" +
            "// ══════════════════════════════════════════════════════════════\n" +
            "//  rt 32-G Phase 0: flat Val struct implementations\n" +
            "// ══════════════════════════════════════════════════════════════\n" +
            "\n" +
            "// Redesigned constructor: every non-scalar arg is HexaVal-by-value so the\n" +
            "// payload (string s, array, map, valstruct pointer) is preserved verbatim.\n" +
            "// Scalars (tag/int/float/bool) still get coerced — those slots only ever\n" +
            "// see TAG_INT / TAG_FLOAT / TAG_BOOL in the interpreter.\n" +
            "HexaVal hexa_valstruct_new_v(\n" +
            "    HexaVal tag_v, HexaVal int_v, HexaVal float_v, HexaVal bool_v,\n" +
            "    HexaVal str_v, HexaVal char_v, HexaVal array_v,\n" +
            "    HexaVal fn_name_v, HexaVal fn_params_v, HexaVal fn_body_v,\n" +
            "    HexaVal struct_name_v, HexaVal struct_fields_v)\n" +
            "{\n" +
            "    // rt 32-L: the dominant fib RSS contributor — every Val{...} construction\n" +
            "    // in the interpreter (val_int / val_float / val_str / val_void / and ALL\n" +
            "    // user-side Val literals) ends up here. Arena-allocate when HEXA_VAL_ARENA\n" +
            "    // is on AND at least one scope mark is live (i.e. we're inside a fn call).\n" +
            "    // Module-init time allocations (cached singletons __VAL_VOID/__VAL_TRUE/\n" +
            "    // __VAL_INT_CACHE etc.) go through the heap path so the first scope pop\n" +
            "    // doesn't wipe them.\n" +
            "    // T33-fix-2: DISABLE arena for ValStruct. fn_arena_return only heapifies\n" +
            "    // the return value; globals (__VAL_INT_CACHE, env) escape unheapified.\n" +
            "    int from_arena = 0;\n" +
            "    HexaValStruct* s;\n" +
            "    if (from_arena) {\n" +
            "        s = (HexaValStruct*)hexa_val_arena_calloc(sizeof(HexaValStruct));\n" +
            "        s->from_arena = 1;\n" +
            "    } else {\n" +
            "        s = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n" +
            "        if (!s) { fprintf(stderr, \"OOM in valstruct_new_v\\n\"); exit(1); }\n" +
            "        s->from_arena = 0;\n" +
            "    }\n" +
            "    s->tag_i     = HX_IS_INT(tag_v) ? HX_INT(tag_v) : 0;\n" +
            "    s->int_val   = HX_IS_INT(int_v) ? HX_INT(int_v) : 0;\n" +
            "    s->float_val = HX_IS_FLOAT(float_v) ? HX_FLOAT(float_v) :\n" +
            "                   (HX_IS_INT(float_v) ? (double)HX_INT(float_v) : 0.0);\n" +
            "    s->bool_val  = HX_IS_BOOL(bool_v) ? HX_BOOL(bool_v) :\n" +
            "                   (HX_IS_INT(bool_v) ? (int)HX_INT(bool_v) : 0);\n" +
            "    // Polymorphic slots — store HexaVal verbatim. Closures / AST bodies /\n" +
            "    // struct field maps now survive Val construction intact.\n" +
            "    s->str_val       = str_v;\n" +
            "    s->char_val      = char_v;\n" +
            "    s->array_val     = array_v;\n" +
            "    s->fn_name       = fn_name_v;\n" +
            "    s->fn_params     = fn_params_v;\n" +
            "    s->fn_body       = fn_body_v;\n" +
            "    s->struct_name   = struct_name_v;\n" +
            "    s->struct_fields = struct_fields_v;\n" +
            "    HexaVal v = {.tag = TAG_VALSTRUCT};\n" +
            "    HX_SET_VS(v, s);\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "// Helper: scalar accessors (tag/int/float/bool) still return primitive Vals.\n" +
            "// NOTE: hexa_valstruct_int kept — referenced internally by rt_write_bytes_v helpers.\n" +
            "HexaVal hexa_valstruct_int(HexaVal v) {\n" +
            "    if (!HX_IS_VALSTRUCT(v) || !HX_VS(v)) return hexa_int(0);\n" +
            "    return hexa_int(HX_VSF(v, int_val));\n" +
            "}\n" +
            "\n" +
            "// Key-string dispatch — branches on key[0] to amortize strcmp.\n" +
            "// Polymorphic fields return raw HexaVal so closure bodies (TAG_MAP) and\n" +
            "// param lists (TAG_ARRAY) propagate through .fn_body / .fn_params reads.\n" +
            "HexaVal hexa_valstruct_get_by_key(HexaVal v, const char* key) {\n" +
            "    if (!HX_IS_VALSTRUCT(v) || !HX_VS(v)) {\n" +
            "        fprintf(stderr, \"valstruct_get: not a TAG_VALSTRUCT\\n\");\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    if (!key) return hexa_void();\n" +
            "    switch (key[0]) {\n" +
            "        case 't':\n" +
            "            if (!hxlcl_strcmp(key, \"tag\"))           return hexa_int(HX_VSF(v, tag_i));\n" +
            "            break;\n" +
            "        case 'i':\n" +
            "            if (!hxlcl_strcmp(key, \"int_val\"))       return hexa_int(HX_VSF(v, int_val));\n" +
            "            break;\n" +
            "        case 'f':\n" +
            "            if (!hxlcl_strcmp(key, \"float_val\"))     return hexa_float(HX_VSF(v, float_val));\n" +
            "            if (!hxlcl_strcmp(key, \"fn_name\"))       return HX_VSF(v, fn_name);\n" +
            "            if (!hxlcl_strcmp(key, \"fn_params\"))     return HX_VSF(v, fn_params);\n" +
            "            if (!hxlcl_strcmp(key, \"fn_body\"))       return HX_VSF(v, fn_body);\n" +
            "            break;\n" +
            "        case 'b':\n" +
            "            if (!hxlcl_strcmp(key, \"bool_val\"))      return hexa_bool(HX_VSF(v, bool_val));\n" +
            "            break;\n" +
            "        case 's':\n" +
            "            if (!hxlcl_strcmp(key, \"str_val\"))       return HX_VSF(v, str_val);\n" +
            "            if (!hxlcl_strcmp(key, \"struct_name\"))   return HX_VSF(v, struct_name);\n" +
            "            if (!hxlcl_strcmp(key, \"struct_fields\")) return HX_VSF(v, struct_fields);\n" +
            "            break;\n" +
            "        case 'c':\n" +
            "            if (!hxlcl_strcmp(key, \"char_val\"))      return HX_VSF(v, char_val);\n" +
            "            break;\n" +
            "        case 'a':\n" +
            "            if (!hxlcl_strcmp(key, \"array_val\"))     return HX_VSF(v, array_val);\n" +
            "            break;\n" +
            "        case '_':\n" +
            "            if (!hxlcl_strcmp(key, \"__type__\"))      return hexa_str(\"Val\");\n" +
            "            break;\n" +
            "    }\n" +
            "    fprintf(stderr, \"valstruct_get: unknown key '%s'\\n\", key);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "\n" +
            "// Setter accepts any HexaVal payload — no TAG_STR gating, mirrors getter.\n" +
            "// 2026-04-17: COW — __VAL_INT_CACHE/float/bool singletons share ValStruct\n" +
            "// pointers. In-place mutation corrupts ALL users of that cache slot.\n" +
            "// Always shallow-copy before writing; old ValStruct leaked (no refcounting).\n" +
            "__attribute__((no_builtin(\"memcpy\")))\n" +
            "HexaVal hexa_valstruct_set_by_key(HexaVal v, const char* key, HexaVal val) {\n" +
            "    if (!HX_IS_VALSTRUCT(v) || !HX_VS(v)) {\n" +
            "        fprintf(stderr, \"valstruct_set: not a TAG_VALSTRUCT\\n\");\n" +
            "        return v;\n" +
            "    }\n" +
            "    if (!key) return v;\n" +
            "    // COW: allocate a fresh copy\n" +
            "    HexaValStruct* orig = HX_VS(v);\n" +
            "    int use_arena = hexa_val_arena_on() && __hexa_val_mark_top > 0;\n" +
            "    HexaValStruct* cow;\n" +
            "    if (use_arena) {\n" +
            "        cow = (HexaValStruct*)hexa_val_arena_calloc(sizeof(HexaValStruct));\n" +
            "    } else {\n" +
            "        cow = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n" +
            "        if (!cow) { fprintf(stderr, \"OOM in valstruct COW\\n\"); exit(1); }\n" +
            "    }\n" +
            "    // cycle 73: aggregate struct copy -> memcpy macro (-> hxlcl_memcpy)\n" +
            "    memcpy(cow, orig, sizeof(HexaValStruct));\n" +
            "    cow->from_arena = use_arena;\n" +
            "    HexaVal out = v;\n" +
            "    HX_SET_VS(out, cow);\n" +
            "    switch (key[0]) {\n" +
            "        case 't':\n" +
            "            if (!hxlcl_strcmp(key, \"tag\")) {\n" +
            "                cow->tag_i = HX_IS_INT(val) ? HX_INT(val) : cow->tag_i;\n" +
            "                return out;\n" +
            "            }\n" +
            "            break;\n" +
            "        case 'i':\n" +
            "            if (!hxlcl_strcmp(key, \"int_val\")) {\n" +
            "                cow->int_val = HX_IS_INT(val) ? HX_INT(val) : cow->int_val;\n" +
            "                return out;\n" +
            "            }\n" +
            "            break;\n" +
            "        case 'f':\n" +
            "            if (!hxlcl_strcmp(key, \"float_val\")) {\n" +
            "                if (HX_IS_FLOAT(val)) cow->float_val = HX_FLOAT(val);\n" +
            "                else if (HX_IS_INT(val)) cow->float_val = (double)HX_INT(val);\n" +
            "                return out;\n" +
            "            }\n" +
            "            if (!hxlcl_strcmp(key, \"fn_name\"))   { cow->fn_name   = val; return out; }\n" +
            "            if (!hxlcl_strcmp(key, \"fn_params\")) { cow->fn_params = val; return out; }\n" +
            "            if (!hxlcl_strcmp(key, \"fn_body\"))   { cow->fn_body   = val; return out; }\n" +
            "            break;\n" +
            "        case 'b':\n" +
            "            if (!hxlcl_strcmp(key, \"bool_val\")) {\n" +
            "                cow->bool_val = HX_IS_BOOL(val) ? HX_BOOL(val) :\n" +
            "                                 (HX_IS_INT(val) ? (int)HX_INT(val) : cow->bool_val);\n" +
            "                return out;\n" +
            "            }\n" +
            "            break;\n" +
            "        case 's':\n" +
            "            if (!hxlcl_strcmp(key, \"str_val\"))       { cow->str_val       = val; return out; }\n" +
            "            if (!hxlcl_strcmp(key, \"struct_name\"))   { cow->struct_name   = val; return out; }\n" +
            "            if (!hxlcl_strcmp(key, \"struct_fields\")) { cow->struct_fields = val; return out; }\n" +
            "            break;\n" +
            "        case 'c':\n" +
            "            if (!hxlcl_strcmp(key, \"char_val\"))  { cow->char_val  = val; return out; }\n" +
            "            break;\n" +
            "        case 'a':\n" +
            "            if (!hxlcl_strcmp(key, \"array_val\")) { cow->array_val = val; return out; }\n" +
            "            break;\n" +
            "    }\n" +
            "    fprintf(stderr, \"valstruct_set: unknown key '%s'\\n\", key);\n" +
            "    return out;\n" +
            "}\n" +
            "\n" +
            "// ── rt 32-D: scope-local arena allocator ─────────────────\n" +
            "// Problem: hexa_str_concat was doing `malloc(strlen(a)+strlen(b)+1)` per call\n" +
            "// with no free (no GC). d64 ML micro calls it 10^5+ times → heap fragmentation\n" +
            "// and accumulated RSS pressure even if individual strings are short-lived.\n" +
            "//\n" +
            "// Solution: linked-block bump allocator. Each hexa_arena_alloc() returns\n" +
            "// memory from the current block; when full, we chain a new block (default 4MB,\n" +
            "// or large enough for the request). `hexa_arena_mark()` + `hexa_arena_rewind()`\n" +
            "// give O(1) bulk-free semantics so a caller (env_push_scope / env_pop_scope or\n" +
            "// a future FFI binding) can dispose an entire scope's worth of string\n" +
            "// temporaries in one pointer reset.\n" +
            "//\n" +
            "// M4 16GB optimization: HEXA_STR_ARENA=1 by default (was OFF). The fn-arena\n" +
            "// scoping (STRUCTURAL-7: __hexa_fn_arena_enter/return) now handles escape\n" +
            "// analysis for return values, and hexa_val_heapify handles arena strings in\n" +
            "// maps/arrays/closures. Set HEXA_STR_ARENA=0 to disable if regressions appear.\n" +
            "//\n" +
            "// P2 scope (accepted partial): mark/rewind API + opt-in gate only. Hexa-level\n" +
            "// wiring into env_push_scope/env_pop_scope is a follow-up (requires\n" +
            "// hexa_full.hexa edits + interp rebuild, deferred per task description).\n" +
            "\n" +
            "#define HEXA_ARENA_BLOCK_SIZE (4 * 1024 * 1024)   // 4MB default block\n" +
            "\n" +
            "typedef struct HexaArenaBlock {\n" +
            "    struct HexaArenaBlock* next;   // NULL for last block\n" +
            "    size_t cap;                    // usable bytes in data[]\n" +
            "    size_t used;                   // bytes allocated from this block\n" +
            "    char   data[];                 // flexible; cap bytes follow the header\n" +
            "} HexaArenaBlock;\n" +
            "\n" +
            "typedef struct {\n" +
            "    HexaArenaBlock* head;   // first block (never freed until hexa_arena_destroy)\n" +
            "    HexaArenaBlock* cur;    // current bump block\n" +
            "} HexaArena;\n" +
            "\n" +
            "// Arena mark: captures current allocation frontier for O(1) rewind.\n" +
            "typedef struct {\n" +
            "    HexaArenaBlock* block;\n" +
            "    size_t used;\n" +
            "} HexaArenaMark;\n" +
            "\n" +
            "static HexaArena __hexa_arena = {NULL, NULL};\n" +
            "static int __hexa_arena_enabled = -1;     // lazy env probe\n" +
            "\n" +
            "// perf: arena address envelope — O(1) pointer-range reject for heapify.\n" +
            "// Every bump-arena block's data[] lies within [__hx_arena_lo,__hx_arena_hi);\n" +
            "// a string pointer outside this range is provably heap-resident, so\n" +
            "// hexa_val_heapify's TAG_STR path can return immediately instead of walking\n" +
            "// the whole block chain per string. This collapses the O(n²) re-heapify of\n" +
            "// already-heapified strings that 02af1622 worked around by default-disabling\n" +
            "// the Val arena (HEXA_VAL_ARENA=0 → 10-16GB self-compile RSS). With the\n" +
            "// envelope, the arena can stay ON → memory-bounded compiles.\n" +
            "// Sentinel lo=MAX, hi=0 ⇒ empty range ⇒ every pointer rejected (correct: no\n" +
            "// arena string exists yet). Monotonic: blocks are never unmapped.\n" +
            "static uintptr_t __hx_arena_lo = (uintptr_t)-1;\n" +
            "static uintptr_t __hx_arena_hi = 0;\n" +
            "\n" +
            "static int hexa_arena_on(void) {\n" +
            "    if (__hexa_arena_enabled < 0) {\n" +
            "        const char* e = hxlcl_getenv(\"HEXA_STR_ARENA\");\n" +
            "        // M4: default ON (was OFF). Env var HEXA_STR_ARENA=0 disables.\n" +
            "        __hexa_arena_enabled = (e && e[0] == '0') ? 0 : 1;\n" +
            "    }\n" +
            "    return __hexa_arena_enabled;\n" +
            "}\n" +
            "\n" +
            "static HexaArenaBlock* hexa_arena_new_block(size_t min_cap) {\n" +
            "    size_t cap = min_cap > HEXA_ARENA_BLOCK_SIZE ? min_cap : HEXA_ARENA_BLOCK_SIZE;\n" +
            "    HexaArenaBlock* b = (HexaArenaBlock*)malloc(sizeof(HexaArenaBlock) + cap);\n" +
            "    if (!b) return NULL;\n" +
            "    b->next = NULL;\n" +
            "    b->cap = cap;\n" +
            "    b->used = 0;\n" +
            "    // Extend the arena address envelope (see __hx_arena_lo/hi above).\n" +
            "    {\n" +
            "        uintptr_t base = (uintptr_t)b->data;\n" +
            "        if (base < __hx_arena_lo)        __hx_arena_lo = base;\n" +
            "        if (base + cap > __hx_arena_hi)  __hx_arena_hi = base + cap;\n" +
            "    }\n" +
            "    if (_hx_stats_on()) {\n" +
            "        _hx_stats_arena_blocks++;\n" +
            "        _hx_stats_arena_bytes += (int64_t)(sizeof(HexaArenaBlock) + cap);\n" +
            "        _hx_stats_sample_rss();\n" +
            "    }\n" +
            "    return b;\n" +
            "}\n" +
            "\n" +
            "// Allocate `n` bytes from the arena, 8-byte aligned. Returns NULL on OOM.\n" +
            "// Public so future FFI consumers (env_push/pop_scope, parser temporaries)\n" +
            "// can opt in. Thread-safety: single-threaded runtime; no locks needed.\n" +
            "void* hexa_arena_alloc(size_t n) {\n" +
            "    _hx_mem_tick();\n" +
            "    // Round up to 8-byte alignment so we can safely return the pointer to\n" +
            "    // any caller that may store it where alignment matters.\n" +
            "    n = (n + 7u) & ~(size_t)7u;\n" +
            "    if (n == 0) n = 8;\n" +
            "    if (!__hexa_arena.head) {\n" +
            "        __hexa_arena.head = hexa_arena_new_block(n);\n" +
            "        __hexa_arena.cur = __hexa_arena.head;\n" +
            "        if (!__hexa_arena.head) return NULL;\n" +
            "    }\n" +
            "    HexaArenaBlock* b = __hexa_arena.cur;\n" +
            "    if (b->used + n > b->cap) {\n" +
            "        // Walk forward first: rewind may have left empty tail blocks we can reuse.\n" +
            "        HexaArenaBlock* nb = b->next;\n" +
            "        while (nb && nb->cap < n) nb = nb->next;\n" +
            "        if (!nb) {\n" +
            "            nb = hexa_arena_new_block(n);\n" +
            "            if (!nb) return NULL;\n" +
            "            // Append to end of chain (preserve any rewound-empty tail blocks).\n" +
            "            HexaArenaBlock* tail = __hexa_arena.cur;\n" +
            "            int64_t chain_len = 1;\n" +
            "            while (tail->next) { tail = tail->next; chain_len++; }\n" +
            "            tail->next = nb;\n" +
            "            chain_len++;  // include the just-appended block\n" +
            "            if (_hx_stats_on()) {\n" +
            "                if (chain_len > _hx_stats_arena_block_max_chain) {\n" +
            "                    _hx_stats_arena_block_max_chain = chain_len;\n" +
            "                }\n" +
            "            }\n" +
            "        } else {\n" +
            "            // Reused a previously rewound tail block (no malloc).\n" +
            "            if (_hx_stats_on()) _hx_stats_arena_block_reuse++;\n" +
            "        }\n" +
            "        nb->used = 0;\n" +
            "        __hexa_arena.cur = nb;\n" +
            "        b = nb;\n" +
            "    }\n" +
            "    void* p = (void*)(b->data + b->used);\n" +
            "    b->used += n;\n" +
            "    if (_hx_stats_on()) {\n" +
            "        _hx_stats_arena_alloc++;\n" +
            "        // H03: log2 size bucket histogram (B17 slab decision input).\n" +
            "        _hx_stats_size_hist[_hx_stats_size_bucket(n)]++;\n" +
            "    }\n" +
            "    return p;\n" +
            "}\n" +
            "\n" +
            "// Save current allocation frontier. Callers pair with hexa_arena_rewind.\n" +
            "HexaArenaMark hexa_arena_mark(void) {\n" +
            "    HexaArenaMark m;\n" +
            "    m.block = __hexa_arena.cur;\n" +
            "    m.used = __hexa_arena.cur ? __hexa_arena.cur->used : 0;\n" +
            "    return m;\n" +
            "}\n" +
            "\n" +
            "// Rewind arena to a previously captured mark. O(1). Blocks after `mark.block`\n" +
            "// retain their backing memory (for reuse on next alloc) but are logically\n" +
            "// empty.\n" +
            "void hexa_arena_rewind(HexaArenaMark m) {\n" +
            "    if (!m.block) {\n" +
            "        if (__hexa_arena.head) {\n" +
            "            __hexa_arena.head->used = 0;\n" +
            "            __hexa_arena.cur = __hexa_arena.head;\n" +
            "        }\n" +
            "        return;\n" +
            "    }\n" +
            "    m.block->used = m.used;\n" +
            "    // Mark all subsequent blocks as empty (they stay linked, reusable).\n" +
            "    for (HexaArenaBlock* b = m.block->next; b; b = b->next) b->used = 0;\n" +
            "    __hexa_arena.cur = m.block;\n" +
            "}\n" +
            "\n" +
            "// Rewind to beginning (keep blocks for reuse). Public for follow-up wiring.\n" +
            "void hexa_arena_reset(void) {\n" +
            "    if (!__hexa_arena.head) return;\n" +
            "    for (HexaArenaBlock* b = __hexa_arena.head; b; b = b->next) b->used = 0;\n" +
            "    __hexa_arena.cur = __hexa_arena.head;\n" +
            "}\n" +
            "\n" +
            "// ── rt 32-L: Val arena scope stack + heapify ─────────────\n" +
            "// Goal: bump-allocate short-lived `Val { ... }` struct literals (the dominant\n" +
            "// HexaMapTable churn in fib-style recursive interpreted programs) and free\n" +
            "// them in O(1) per scope pop. Reuses the existing block chain from rt 32-D\n" +
            "// (hexa_arena_alloc) so str-concat and val-pack share a single bump frontier.\n" +
            "//\n" +
            "// Lifetime model: a per-scope mark stack mirrors env_push_scope / env_pop_scope\n" +
            "// in hexa_full.hexa. On scope pop, any Val that survives the scope (the fn\n" +
            "// return value, env_set targets in the parent scope, closure captures) MUST\n" +
            "// be heapified BEFORE the rewind so its backing storage moves to malloc. We\n" +
            "// expose mark/pop/heapify via the `env(...)` builtin path with reserved\n" +
            "// `__HEXA_ARENA_*` keys — no transpiler edit needed.\n" +
            "//\n" +
            "// Gate: HEXA_VAL_ARENA env var. Default ON as of S7-B (2026-04-16) —\n" +
            "// Phase A wired codegen __hexa_fn_arena_enter/return on all fn\n" +
            "// boundaries; T33 corruption fixed; full regression suite verified.\n" +
            "// Opt-out: HEXA_VAL_ARENA=0.\n" +
            "//\n" +
            "// T33 audit (2026-04-14): minimum repro still failing is array-passthrough\n" +
            "// through two nested user fns — e.g.\n" +
            "//     fn wrap(){return [\"a\",\"b\",\"c\"]}  fn touch(x){return x}\n" +
            "//     fn inner(){let l=wrap(); let z=touch(l); println(type_of(l[0]))}\n" +
            "// prints \"map\" under ARENA=1 (expect \"str\"). Symptom: array_store slot gets\n" +
            "// reclaimed (array_store[K] = []) even though `l` and `z` still hold it —\n" +
            "// consistent with a missed env_pop_scope decref path that operates on a\n" +
            "// stale-tag HexaValStruct after arena rewind. Canary test: T33b-on in\n" +
            "// tests/regression.hexa. Fix is blocked on the interp rebuild\n" +
            "// regression (codegen FnDecl + forward-decl issue; see task tracker).\n" +
            "// Keep default OFF until both the canary flips PASS and the module_loader\n" +
            "// use-path smoke (see ml_resolve heapify discussion above) goes green.\n" +
            "\n" +
            "// Per-scope mark stack. Sized for deep recursion (fib(30) ≈ 30 frames; we\n" +
            "// budget 64K to cover ML stack depths). Overflow falls back to silently\n" +
            "// skipping the rewind for that scope (correctness preserved; arena just\n" +
            "// grows until the outer scope pops and rewinds).\n" +
            "#define HEXA_VAL_MARK_STACK_CAP 65536\n" +
            "\n" +
            "typedef struct {\n" +
            "    HexaArenaBlock* block;\n" +
            "    size_t used;\n" +
            "} HexaValMark;\n" +
            "\n" +
            "static HexaValMark __hexa_val_marks[HEXA_VAL_MARK_STACK_CAP];\n" +
            "int __hexa_val_mark_top = 0;            // count of pushed marks (extern-visible)\n" +
            "int __hexa_val_force_heap = 0;          // when set, valstruct_new_v uses heap (codegen refs this)\n" +
            "static int __hexa_val_arena_enabled = -1;  // -1 = lazy probe\n" +
            "// F6 option A — A3 (PLAN-stage3-footprint-F6-optA.md). When non-zero,\n" +
            "// __hexa_fn_arena_return routes its return through\n" +
            "// hexa_val_arena_heapify_to_parent (region-promote into the caller's\n" +
            "// arena frame) instead of hexa_val_heapify (escape to malloc). Default\n" +
            "// 0 — behaviour byte-identical to pre-A3. Toggled at the streaming-loop\n" +
            "// boundary via env(\"__HEXA_ARENA_RETURN_REGION_ON__\" / \"_OFF__\").\n" +
            "static int __hexa_val_region_returns_enabled = 0;\n" +
            "\n" +
            "static int hexa_val_arena_on(void) {\n" +
            "    if (__hexa_val_arena_enabled < 0) {\n" +
            "        const char* e = hxlcl_getenv(\"HEXA_VAL_ARENA\");\n" +
            "        // S7-B: default ON (2026-04-16). Phase A wired codegen\n" +
            "        // __hexa_fn_arena_enter/return; T33 corruption fixed; full 236-example\n" +
            "        // + 16-case dispatch regression suite passed 0-regression under ARENA=1.\n" +
            "        // Opt-out: HEXA_VAL_ARENA=0.\n" +
            "        if (!e || !e[0]) {\n" +
            "            __hexa_val_arena_enabled = 1;\n" +
            "        } else {\n" +
            "            __hexa_val_arena_enabled = (e[0] == '1' || e[0] == 'y' || e[0] == 'Y') ? 1 : 0;\n" +
            "        }\n" +
            "    }\n" +
            "    return __hexa_val_arena_enabled;\n" +
            "}\n" +
            "\n" +
            "// Zeroed allocation from the bump arena. Falls back to calloc on OOM so the\n" +
            "// caller never sees a NULL — keeps the hot path branch-free and correct.\n" +
            "static void* hexa_val_arena_calloc(size_t n) {\n" +
            "    void* p = hexa_arena_alloc(n);\n" +
            "    if (!p) return calloc(1, n);\n" +
            "    hxlcl_memset(p, 0, n);\n" +
            "    return p;\n" +
            "}\n" +
            "\n" +
            "// Forward decl — defined just below. Needed by scope_push for ω-interp-2 reset.\n" +
            "extern int __hexa_arena_slot_dirty;\n" +
            "\n" +
            "// ω-interp-2: per-frame arena watermark. The walks in hexa_val_heapify are\n" +
            "// only meaningful when an arena allocation has occurred inside the current\n" +
            "// frame — otherwise every Val reachable from a slot is heap-resident and the\n" +
            "// walk is wasted O(N) work. Snapshot at scope_push, compare at heapify.\n" +
            "// Saturating: a single int \"active block changed since push\" + saved used.\n" +
            "static HexaArenaBlock* __hexa_arena_frame_block = NULL;\n" +
            "static size_t          __hexa_arena_frame_used  = 0;\n" +
            "\n" +
            "// Push current arena frontier as a scope mark. Called on env_push_scope via\n" +
            "// the env(\"__HEXA_ARENA_PUSH__\") interception in hexa_env_var. Saturating: if\n" +
            "// the mark stack is full, we silently no-op rather than crashing.\n" +
            "static void hexa_val_arena_scope_push(void) {\n" +
            "    if (__hexa_val_mark_top >= HEXA_VAL_MARK_STACK_CAP) return;\n" +
            "    HexaValMark* m = &__hexa_val_marks[__hexa_val_mark_top++];\n" +
            "    m->block = __hexa_arena.cur;\n" +
            "    m->used = __hexa_arena.cur ? __hexa_arena.cur->used : 0;\n" +
            "    // ω-interp-2 RESET: each new frame starts clean — no slot writes have\n" +
            "    // occurred inside this frame yet. Subsequent hexa_array_set calls will\n" +
            "    // re-set the flag if any write happens. Safe because heapify always runs\n" +
            "    // BEFORE scope_pop (which is the consumer); a fresh push means we're\n" +
            "    // entering a new lifetime window.\n" +
            "    __hexa_arena_slot_dirty = 0;\n" +
            "    __hexa_arena_frame_block = __hexa_arena.cur;\n" +
            "    __hexa_arena_frame_used  = __hexa_arena.cur ? __hexa_arena.cur->used : 0;\n" +
            "}\n" +
            "\n" +
            "// ω-interp-2: precise check for \"no arena allocation occurred in current frame\".\n" +
            "// True when active block + used pointer match the scope_push snapshot. False\n" +
            "// when any arena_alloc has run (block advanced or used grew). When true, no\n" +
            "// Val written into any slot inside this frame can be arena-resident, so the\n" +
            "// heapify slot walks are bit-equivalent to no-ops and can be skipped.\n" +
            "static int hexa_arena_frame_clean(void) {\n" +
            "    return __hexa_arena.cur == __hexa_arena_frame_block\n" +
            "        && (__hexa_arena.cur ? __hexa_arena.cur->used : 0) == __hexa_arena_frame_used;\n" +
            "}\n" +
            "\n" +
            "// ω-interp-1 (2026-04-26): per-frame \"dirty\" flag — gates the expensive T33\n" +
            "// Fix 4 walk over array_store[idx] in hexa_val_heapify. Set whenever a push\n" +
            "// (or any other path that may store an arena-allocated child Val into a\n" +
            "// slot's items buffer) occurs inside an active arena frame. Cleared on\n" +
            "// scope_push so each frame starts clean.\n" +
            "//\n" +
            "// Without this, every fn-arena return for a TAG_ARRAY interpreter Val\n" +
            "// triggered the slot walk unconditionally, turning tight push loops\n" +
            "// (anima_audio.hexa vocal_hexa() — 4800 .push() calls per call) into O(N²).\n" +
            "// Repro: /tmp/test_push_n.hexa.\n" +
            "//\n" +
            "// ω-interp-2 (2026-04-26): WIRED.\n" +
            "//   SETTER  : hexa_array_set (line ~1187) — every host-array element write\n" +
            "//             marks dirty. Covers `array_store[idx] = items.push(item)` in\n" +
            "//             array_push_inplace plus map_store / struct_store assignments.\n" +
            "//   CHECKER : hexa_val_heapify TAG_VALSTRUCT path (line ~2515) — guards the\n" +
            "//             array_store / map_store / struct_store walks. When clean we\n" +
            "//             skip the walk entirely (the slot's contents have not been\n" +
            "//             reseated since the last heapify). Flag is cleared after the\n" +
            "//             walk so subsequent fn returns in the same frame stay cheap.\n" +
            "//   RESET   : hexa_val_arena_scope_push (line ~2272) — new frame starts\n" +
            "//             clean. Subsequent writes re-set as needed.\n" +
            "// Removed `static` so it's externally visible to the setter sitting above\n" +
            "// the original declaration in this TU; both references resolve to the same\n" +
            "// global.\n" +
            "int __hexa_arena_slot_dirty = 0;\n" +
            "\n" +
            "// Pop scope mark and rewind arena to it. Caller must have heapified any Val\n" +
            "// that escapes the popped scope BEFORE calling this. If the stack is empty\n" +
            "// (under-pop), no-op (defensive).\n" +
            "//\n" +
            "// rt 32-M: array arena currently fires only for slice_fast (lifetime-safe\n" +
            "// by construction — the slice is consumed by call_user_fn's args parameter\n" +
            "// and never stored persistently). Push-arena (first-push into arena) was\n" +
            "// prototyped + reverted; see hexa_array_push comment for the Hexa\n" +
            "// pass-by-value / snapshot-ABA blocker.\n" +
            "static void hexa_val_arena_scope_pop(void) {\n" +
            "    if (__hexa_val_mark_top <= 0) return;\n" +
            "    HexaValMark m = __hexa_val_marks[--__hexa_val_mark_top];\n" +
            "    if (!m.block) {\n" +
            "        // Mark predates any allocation — full reset.\n" +
            "        if (__hexa_arena.head) {\n" +
            "            for (HexaArenaBlock* b = __hexa_arena.head; b; b = b->next) b->used = 0;\n" +
            "            __hexa_arena.cur = __hexa_arena.head;\n" +
            "        }\n" +
            "        return;\n" +
            "    }\n" +
            "    m.block->used = m.used;\n" +
            "    for (HexaArenaBlock* b = m.block->next; b; b = b->next) b->used = 0;\n" +
            "    __hexa_arena.cur = m.block;\n" +
            "}\n" +
            "\n" +
            "// Forward decl — heapify itself is recursive over nested arena maps.\n" +
            "HexaVal hexa_val_heapify(HexaVal v);\n" +
            "\n" +
            "// ω-interp-2: per-slot high-water mark for incremental heapify of array_store.\n" +
            "// Tracks \"items[0..water[idx]] are known to be heap-resident\". Walks only\n" +
            "// process items[water..len), then update water := len. This breaks the per-push\n" +
            "// O(N) walk in tight push loops (`bytes.push(i)` × 4800) into amortized O(1).\n" +
            "//\n" +
            "// Storage: a parallel int array sized to the high-water-mark of any idx ever\n" +
            "// touched. Grows on demand via realloc. Reset to 0 on entries we don't yet\n" +
            "// have storage for (defensive — first walk reprocesses the full slot, which\n" +
            "// is correct).\n" +
            "static int*    __hexa_array_water     = NULL;\n" +
            "static int64_t __hexa_array_water_cap = 0;\n" +
            "\n" +
            "static int hexa_array_water_get(int64_t idx) {\n" +
            "    if (idx < 0 || idx >= __hexa_array_water_cap) return 0;\n" +
            "    return __hexa_array_water[idx];\n" +
            "}\n" +
            "\n" +
            "static void hexa_array_water_set(int64_t idx, int n) {\n" +
            "    if (idx < 0) return;\n" +
            "    if (idx >= __hexa_array_water_cap) {\n" +
            "        int64_t new_cap = __hexa_array_water_cap > 0 ? __hexa_array_water_cap : 64;\n" +
            "        while (new_cap <= idx) new_cap *= 2;\n" +
            "        int* p = (int*)realloc(__hexa_array_water, sizeof(int) * (size_t)new_cap);\n" +
            "        if (!p) return;  // OOM — defensive no-op (next walk will reprocess)\n" +
            "        // Zero-init new tail.\n" +
            "        for (int64_t k = __hexa_array_water_cap; k < new_cap; k++) p[k] = 0;\n" +
            "        __hexa_array_water = p;\n" +
            "        __hexa_array_water_cap = new_cap;\n" +
            "    }\n" +
            "    __hexa_array_water[idx] = n;\n" +
            "}\n" +
            "\n" +
            "// ω-interp-2: invalidate the water mark for a slot when it is overwritten by\n" +
            "// a non-append (truncate, COW, slice). Forces the next walk to reprocess\n" +
            "// items[0..len). For now we only call this from cow paths that explicitly\n" +
            "// reseat array_store[idx] — for the dominant push path the water grows\n" +
            "// monotonically with len.\n" +
            "//\n" +
            "// Note: the water mark for slot S is left stale when array_decref drops S\n" +
            "// to 0; M4-fix freelist disabled means S won't be reused, so the stale\n" +
            "// value is harmless.\n" +
            "\n" +
            "// T33 Fix 4: weak-link to the interpreter's array_store / map_store globals.\n" +
            "// These are emitted as `HexaVal array_store;` / `HexaVal map_store;` by the\n" +
            "// codegen for `pub let mut array_store = []` in interpreter.hexa. They are\n" +
            "// host-array TAG_ARRAY HexaVals that hold the *contents* of every interpreter\n" +
            "// array / map (the wrapped HexaValStruct only carries a slot index in\n" +
            "// vs->int_val). Because hexa_val_heapify previously stopped at the index-\n" +
            "// holding VALSTRUCT, arena-allocated child elements stored *inside*\n" +
            "// array_store[idx] / map_store[idx] were never deep-copied — when the arena\n" +
            "// rewound on scope-pop, those elements turned into dangling memory that\n" +
            "// later prints as \"index 5702266960 out of bounds\" or as the wrong tag.\n" +
            "//\n" +
            "// We weak-link so this object can also link into translation units that\n" +
            "// don't include hexa_full.hexa (e.g. the bootstrap_compiler.c stub or\n" +
            "// standalone test harnesses). At runtime we NULL-check before deref.\n" +
            "extern HexaVal array_store  __attribute__((weak_import, weak));\n" +
            "extern HexaVal map_store    __attribute__((weak_import, weak));\n" +
            "extern HexaVal struct_store __attribute__((weak_import, weak));\n" +
            "__attribute__((weak)) HexaVal array_store  __attribute__((common));\n" +
            "__attribute__((weak)) HexaVal map_store    __attribute__((common));\n" +
            "__attribute__((weak)) HexaVal struct_store __attribute__((common));\n" +
            "\n" +
            "// Interpreter-level Val.tag constants (see self/interpreter.hexa lines 20-30).\n" +
            "// Hardcoded here because the hexa-side `let TAG_ARRAY = 5` is emitted as a\n" +
            "// HexaVal, not a C #define. Mismatch with runtime.c's HexaTag enum is\n" +
            "// intentional — these are *interpreter Val tags* (vs->tag_i), not the\n" +
            "// outer HexaVal.tag.\n" +
            "#define HEXA_INTERP_TAG_ARRAY  5\n" +
            "#define HEXA_INTERP_TAG_STRUCT 7\n" +
            "#define HEXA_INTERP_TAG_MAP    10\n" +
            "\n" +
            "// Deep-copy an arena-allocated HexaMapTable to malloc'd storage. Recursive\n" +
            "// over nested values (TAG_MAP and TAG_ARRAY descend; scalars + already-heap\n" +
            "// strings are bit-copied; TAG_STR with arena-pointing s gets strdup'd).\n" +
            "static HexaMapTable* hmap_heapify(HexaMapTable* src) {\n" +
            "    if (!src) return NULL;\n" +
            "    HexaMapTable* dst = hmap_alloc_ex(src->ht_cap, 0);\n" +
            "    // Re-insert by walking the order arrays so insertion order survives the\n" +
            "    // copy. The destination is freshly empty; we use the same hash for direct\n" +
            "    // slot placement (no rehash necessary because ht_cap matches).\n" +
            "    uint32_t mask = (uint32_t)(dst->ht_cap - 1);\n" +
            "    if (dst->order_cap < src->order_cap) {\n" +
            "        // Grow order arrays to match source capacity (dst->order_cap was\n" +
            "        // sized off ht_cap; src may have grown beyond that via push paths).\n" +
            "        dst->order_keys = (char**)realloc(dst->order_keys, sizeof(char*) * src->order_cap);\n" +
            "        dst->order_vals = (HexaVal*)realloc(dst->order_vals, sizeof(HexaVal) * src->order_cap);\n" +
            "        dst->order_cap = src->order_cap;\n" +
            "    }\n" +
            "    for (int i = 0; i < src->len; i++) {\n" +
            "        const char* k = src->order_keys[i];\n" +
            "        if (!k) continue;\n" +
            "        uint32_t h = hexa_fnv1a_str(k);\n" +
            "        uint32_t idx = h & mask;\n" +
            "        while (dst->slots[idx].key) idx = (idx + 1) & mask;\n" +
            "        dst->slots[idx].key = hxlcl_strdup(k);\n" +
            "        dst->slots[idx].hash = h;\n" +
            "        dst->slots[idx].order_idx = dst->len;  // ROI-24\n" +
            "        HexaVal nv = hexa_val_heapify(src->order_vals[i]);\n" +
            "        dst->vals[idx] = nv;\n" +
            "        dst->order_keys[dst->len] = dst->slots[idx].key;\n" +
            "        dst->order_vals[dst->len] = nv;\n" +
            "        dst->len++;\n" +
            "    }\n" +
            "    return dst;\n" +
            "}\n" +
            "\n" +
            "// Public: heapify a HexaVal. Idempotent on already-heap values. Recursively\n" +
            "// processes nested TAG_MAP / TAG_ARRAY / TAG_STR payloads. Scalar tags\n" +
            "// (INT/FLOAT/BOOL/VOID) are returned as-is. TAG_FN / TAG_VALSTRUCT / TAG_CLOSURE\n" +
            "// retain their pointer identity (those allocators don't currently use the\n" +
            "// arena, so heapify is a no-op for them).\n" +
            "// Valid heap/arena pointers on macOS/Linux live well above the NULL page.\n" +
            "// Any pointer under 0x1000 is a sign of corrupted Val slot (small-int bleed\n" +
            "// through the union, uninitialized stack, or freed memory with zeroed bits).\n" +
            "// Treat as no-op rather than dereferencing garbage.\n" +
            "// 2026-04-17: codegen_c2_extended driver repro produced recursive heapify\n" +
            "// calls with v.arr_ptr / v.vs / v.map_ptr = 0x0E causing SIGSEGV at offset\n" +
            "// +504 of hexa_val_heapify. Root cause is upstream Val corruption but the\n" +
            "// fault mode (sub-page deref) is easy to guard here.\n" +
            "#define HX_PTR_OK(p) ((uintptr_t)(p) >= 0x1000)\n" +
            "\n" +
            "// Cycle 51: `__attribute__((no_builtin(\"memcpy\")))` attempted on this\n" +
            "// fn (and hexa_valstruct_set_by_key below) to defeat clang's 160-byte\n" +
            "// HexaValStruct aggregate-assign lowering into libc _memcpy — kept\n" +
            "// because the attribute IS valid and harmless, but the aggregate-copy\n" +
            "// pass fires below the attribute scope. Real closure needs source-\n" +
            "// level rewrite of `*dst = *src` to explicit byte-loop or\n" +
            "// `__builtin_memcpy_inline`. Defer to a cycle that touches the source\n" +
            "// pattern directly.\n" +
            "__attribute__((no_builtin(\"memcpy\")))\n" +
            "HexaVal hexa_val_heapify(HexaVal v) {\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_MAP:\n" +
            "            if (HX_MAP_TBL(v) && HX_MAP_TBL(v)->from_arena) {\n" +
            "                HexaMapTable* heap_tbl = hmap_heapify(HX_MAP_TBL(v));\n" +
            "                HX_SET_MAP_TBL(v, heap_tbl);\n" +
            "                HX_SET_MAP_LEN(v, heap_tbl ? heap_tbl->len : 0);\n" +
            "            } else if (HX_MAP_TBL(v)) {\n" +
            "                // perf-3B-A1: slots[].order_idx (ROI-24, line 931) is O(1)-maintained\n" +
            "                // by every map-set path, so the slot→order index is already known.\n" +
            "                // Original used hmap_find (FNV1a + strcmp probe) per entry — the\n" +
            "                // sample profile attributed ~32 % of stack-presence to +1108 (the\n" +
            "                // post-recursive store) and ~5 % to _platform_strcmp. Forward-walk\n" +
            "                // slots[] instead: one heapify per non-empty slot, fan-out to both\n" +
            "                // arrays from a single computed index. No hash, no probe, no strcmp.\n" +
            "                HexaMapTable* t = HX_MAP_TBL(v);\n" +
            "                for (int si = 0; si < t->ht_cap; si++) {\n" +
            "                    HexaMapSlot* s = &t->slots[si];\n" +
            "                    if (!s->key) continue;\n" +
            "                    int oi = s->order_idx;\n" +
            "                    HexaVal nv = hexa_val_heapify(t->order_vals[oi]);\n" +
            "                    t->order_vals[oi] = nv;\n" +
            "                    t->vals[si] = nv;\n" +
            "                }\n" +
            "            }\n" +
            "            return v;\n" +
            "        case TAG_ARRAY: {\n" +
            "            // rt 32-M: if cap<0, items buffer is arena-backed — deep-copy to\n" +
            "            // malloc before the rewind. Then heapify nested elements (rt 32-L\n" +
            "            // handles nested arena maps / valstructs / strings).\n" +
            "            if (HX_ARR_CAP(v) < 0 && HX_ARR_ITEMS(v)) {\n" +
            "                if (_hx_stats_on()) _hx_stats_array_arena_heapify++;\n" +
            "                int real_cap = -HX_ARR_CAP(v);\n" +
            "                HexaVal* heap = hexa_array_promote_to_heap(HX_ARR_ITEMS(v), HX_ARR_LEN(v), real_cap);\n" +
            "                if (heap) {\n" +
            "                    HX_SET_ARR_ITEMS(v, heap);\n" +
            "                    HX_SET_ARR_CAP(v, real_cap);  // positive → heap\n" +
            "                }\n" +
            "                // On OOM we leave the arena pointer; caller may see invalid\n" +
            "                // memory after rewind — best-effort semantics match Val arena.\n" +
            "            }\n" +
            "            for (int i = 0; i < HX_ARR_LEN(v); i++) {\n" +
            "                HX_ARR_ITEMS(v)[i] = hexa_val_heapify(HX_ARR_ITEMS(v)[i]);\n" +
            "            }\n" +
            "            return v;\n" +
            "        }\n" +
            "        case TAG_STR: {\n" +
            "            // Conservative: if the arena owns the string (i.e. between any\n" +
            "            // arena block start and frontier), strdup it. Detection via\n" +
            "            // pointer-range check across active blocks.\n" +
            "            if (!HX_STR(v)) return v;\n" +
            "            // perf: O(1) envelope reject — a pointer outside the union of\n" +
            "            // all arena blocks is provably heap-resident, so skip the\n" +
            "            // block-chain walk. Collapses the O(n²) re-heapify of\n" +
            "            // already-heapified strings documented in 02af1622. A heap\n" +
            "            // pointer that happens to fall in a gap between blocks still\n" +
            "            // walks (and is correctly found in no block) — sound, just\n" +
            "            // not accelerated for that rare case.\n" +
            "            {\n" +
            "                uintptr_t p = (uintptr_t)HX_STR(v);\n" +
            "                if (p < __hx_arena_lo || p >= __hx_arena_hi) return v;\n" +
            "            }\n" +
            "            for (HexaArenaBlock* b = __hexa_arena.head; b; b = b->next) {\n" +
            "                char* base = b->data;\n" +
            "                char* end = base + b->cap;\n" +
            "                if (HX_STR(v) >= base && HX_STR(v) < end) {\n" +
            "                    // perf-31: heapify into header-allocated buffer so the\n" +
            "                    // surviving HexaVal supports O(1) HX_STRLEN.\n" +
            "                    size_t arena_len = hxlcl_strlen(HX_STR(v));\n" +
            "                    HX_SET_STR(v, hexa_strbuf_dup_n(HX_STR(v), arena_len));\n" +
            "                    if (_hx_stats_on()) _hx_stats_str_arena_heapify++;\n" +
            "                    break;\n" +
            "                }\n" +
            "            }\n" +
            "            return v;\n" +
            "        }\n" +
            "        case TAG_CLOSURE: {\n" +
            "            // env_box itself is malloc'd in hexa_closure_new — never arena.\n" +
            "            // But the captured array stored inside it may transitively contain\n" +
            "            // arena maps (params/body/captures). Recurse into env_box's value.\n" +
            "            if (HX_CLO_ENV(v)) {\n" +
            "                *HX_CLO_ENV(v) = hexa_val_heapify(*HX_CLO_ENV(v));\n" +
            "            }\n" +
            "            return v;\n" +
            "        }\n" +
            "        case TAG_VALSTRUCT: {\n" +
            "            // rt 32-L: deep-copy arena-allocated HexaValStruct (the dominant\n" +
            "            // fib hot path) to malloc'd storage. Polymorphic field slots are\n" +
            "            // recursively heapified — closure bodies / param arrays / nested\n" +
            "            // structs all need the same treatment.\n" +
            "            if (!HX_PTR_OK(HX_VS(v))) return v;\n" +
            "            // ω-interp-2 fast path: when this frame has not allocated ANY\n" +
            "            // arena memory (cur block + used unchanged from scope_push),\n" +
            "            // the VS itself is guaranteed heap (from_arena=0) and all of\n" +
            "            // its sub-Vals must also be heap (no arena allocation could\n" +
            "            // have happened). Skip the entire shallow-copy + recursive\n" +
            "            // heapify chain AND the store walks below.\n" +
            "            //\n" +
            "            // Correctness: if a child Val could be arena, some arena_alloc\n" +
            "            // would have run since scope_push, advancing cur or used. We\n" +
            "            // ignore inner-frame allocations because their pop rewinds\n" +
            "            // cur+used back to the snapshot.\n" +
            "            //\n" +
            "            // This addresses the dominant cost in tight push loops where\n" +
            "            // the value being heapified is a TAG_ARRAY VS whose backing\n" +
            "            // slot holds heap-only items: previously each fn return ran\n" +
            "            // a shallow-copy of the wrapping VS (malloc + 8 recursive\n" +
            "            // heapify calls) plus the per-item walk over up to N items.\n" +
            "            // With the gate, all of it collapses to a single comparison\n" +
            "            // + return.\n" +
            "            if (!HX_VSF(v, from_arena) && hexa_arena_frame_clean()) {\n" +
            "                return v;\n" +
            "            }\n" +
            "            if (HX_VSF(v, from_arena)) {\n" +
            "                HexaValStruct* dst = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n" +
            "                if (!dst) return v;  // OOM — caller will see arena pointer (best-effort)\n" +
            "                dst->tag_i        = HX_VSF(v, tag_i);\n" +
            "                dst->int_val      = HX_VSF(v, int_val);\n" +
            "                dst->float_val    = HX_VSF(v, float_val);\n" +
            "                dst->bool_val     = HX_VSF(v, bool_val);\n" +
            "                dst->from_arena   = 0;\n" +
            "                dst->str_val      = hexa_val_heapify(HX_VSF(v, str_val));\n" +
            "                dst->char_val     = hexa_val_heapify(HX_VSF(v, char_val));\n" +
            "                dst->array_val    = hexa_val_heapify(HX_VSF(v, array_val));\n" +
            "                dst->fn_name      = hexa_val_heapify(HX_VSF(v, fn_name));\n" +
            "                dst->fn_params    = hexa_val_heapify(HX_VSF(v, fn_params));\n" +
            "                dst->fn_body      = hexa_val_heapify(HX_VSF(v, fn_body));\n" +
            "                dst->struct_name  = hexa_val_heapify(HX_VSF(v, struct_name));\n" +
            "                dst->struct_fields= hexa_val_heapify(HX_VSF(v, struct_fields));\n" +
            "                HX_SET_VS(v, dst);\n" +
            "            } else {\n" +
            "                // Heap valstruct may still hold arena children (e.g. an arena\n" +
            "                // string was assigned to .str_val). Recurse for safety.\n" +
            "                // 2026-04-17 COW: __VAL_INT_CACHE singletons are heap valstructs\n" +
            "                // shared across the program. In-place mutation corrupts the cache.\n" +
            "                // Shallow-copy before heapifying children.\n" +
            "                //\n" +
            "                // ω-interp-2: scalar-only fast path. The dominant value class\n" +
            "                // in numeric push loops is val_int / val_float / val_bool — all\n" +
            "                // 8 polymorphic fields are __E (TAG_VOID placeholders). Skip\n" +
            "                // the malloc + 8 recursive heapify calls when every field's\n" +
            "                // outer tag is a scalar. This avoids 4800-per-push mallocs\n" +
            "                // in the vocal_hexa() hot path, where the slot walk iterates\n" +
            "                // through cached val_int items.\n" +
            "                #define HX_SCALAR_TAG(t) ((t) == TAG_INT || (t) == TAG_FLOAT \\\n" +
            "                                          || (t) == TAG_BOOL || (t) == TAG_VOID)\n" +
            "                HexaValStruct* vs0 = HX_VS(v);\n" +
            "                if (HX_SCALAR_TAG(vs0->str_val.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->char_val.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->array_val.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->fn_name.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->fn_params.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->fn_body.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->struct_name.tag)\n" +
            "                    && HX_SCALAR_TAG(vs0->struct_fields.tag)) {\n" +
            "                    return v;\n" +
            "                }\n" +
            "                #undef HX_SCALAR_TAG\n" +
            "                HexaValStruct* hcow = (HexaValStruct*)malloc(sizeof(HexaValStruct));\n" +
            "                if (hcow) {\n" +
            "                    // cycle 73: aggregate `*dst = *src` reverse-libcalls\n" +
            "                    // to libc memcpy below the #define layer; route via the\n" +
            "                    // memcpy macro (-> hxlcl_memcpy) so no _memcpy extern.\n" +
            "                    memcpy(hcow, HX_VS(v), sizeof(HexaValStruct));\n" +
            "                    hcow->from_arena = 0;\n" +
            "                    hcow->str_val      = hexa_val_heapify(hcow->str_val);\n" +
            "                    hcow->char_val     = hexa_val_heapify(hcow->char_val);\n" +
            "                    hcow->array_val    = hexa_val_heapify(hcow->array_val);\n" +
            "                    hcow->fn_name      = hexa_val_heapify(hcow->fn_name);\n" +
            "                    hcow->fn_params    = hexa_val_heapify(hcow->fn_params);\n" +
            "                    hcow->fn_body      = hexa_val_heapify(hcow->fn_body);\n" +
            "                    hcow->struct_name  = hexa_val_heapify(hcow->struct_name);\n" +
            "                    hcow->struct_fields= hexa_val_heapify(hcow->struct_fields);\n" +
            "                    HX_SET_VS(v, hcow);\n" +
            "                }\n" +
            "            }\n" +
            "            // T33 Fix 4: when the interpreter Val is a TAG_ARRAY (5) or\n" +
            "            // TAG_MAP (10), its contents live in array_store / map_store\n" +
            "            // indexed by vs->int_val — NOT in the VALSTRUCT itself. Heapify\n" +
            "            // the host array slot so each element survives arena rewind.\n" +
            "            //\n" +
            "            // We only descend if the corresponding global symbol is linked\n" +
            "            // (weak_import: &foo == NULL when absent — e.g. bootstrap stub).\n" +
            "            // Bounds-check against the host array length to defend against\n" +
            "            // freed / reused slot indices observed during T33 repro.\n" +
            "            // ω-interp-2 CHECKER: dual gate on (dirty flag) AND (arena grew\n" +
            "            // in current frame). The dirty flag fires on any slot write, but\n" +
            "            // the slot's items are only at risk of being arena-resident when\n" +
            "            // an arena allocation has actually occurred in this frame —\n" +
            "            // pushing scalar/cached/heap Vals (the dominant `bytes.push(i)`\n" +
            "            // pattern) writes the slot but does NOT advance the arena\n" +
            "            // watermark, so the walk is provably unnecessary.\n" +
            "            //\n" +
            "            // The arena watermark (block ptr + used) is snapshotted at\n" +
            "            // scope_push and compared here; equal → no allocation occurred →\n" +
            "            // every Val transitively reachable from any modified slot in\n" +
            "            // this frame must already be heap (or cached) → skip.\n" +
            "            //\n" +
            "            // Without this dual gate the dirty-only check still walks once\n" +
            "            // per slot-touching frame (call_method's per-push frame in the\n" +
            "            // 4800-push hot path), preserving the O(N²) item-walk cost. With\n" +
            "            // the arena gate, only frames that genuinely allocated arena Vals\n" +
            "            // pay for the walk — for vocal_hexa() that's effectively zero.\n" +
            "            //\n" +
            "            // We do NOT clear the flag here (see ω-interp-2 design notes\n" +
            "            // above re: multi-VS heapify within one frame).\n" +
            "            if (__hexa_arena_slot_dirty && !hexa_arena_frame_clean()) {\n" +
            "                if (HX_VSF(v, tag_i) == HEXA_INTERP_TAG_ARRAY && &array_store != 0) {\n" +
            "                    if (HX_IS_ARRAY(array_store) && HX_ARR_ITEMS(array_store)) {\n" +
            "                        int64_t idx = HX_VSF(v, int_val);\n" +
            "                        if (idx >= 0 && idx < (int64_t)HX_ARR_LEN(array_store)) {\n" +
            "                            // ω-interp-2: incremental walk for push hot path.\n" +
            "                            // Calling hexa_val_heapify on the items_array\n" +
            "                            // would re-iterate ALL N items per walk → O(N²)\n" +
            "                            // for tight push loops. Instead, bypass the\n" +
            "                            // outer-array recurse and walk only items in\n" +
            "                            // [last_water .. current_len) directly. Earlier\n" +
            "                            // items were heapified on prior fn returns and\n" +
            "                            // are heap-resident already.\n" +
            "                            //\n" +
            "                            // The high-water mark lives alongside the items\n" +
            "                            // array as the lower 16 bits of a sidecar entry\n" +
            "                            // we maintain in __hexa_array_water (parallel to\n" +
            "                            // array_store). When absent (idx >= water_len),\n" +
            "                            // default 0 → first walk processes the full slot.\n" +
            "                            HexaVal items_v = HX_ARR_ITEMS(array_store)[idx];\n" +
            "                            if (HX_IS_ARRAY(items_v) && HX_ARR_ITEMS(items_v)) {\n" +
            "                                if (HX_ARR_CAP(items_v) < 0) {\n" +
            "                                    // Arena items buffer — must promote in full.\n" +
            "                                    HX_ARR_ITEMS(array_store)[idx] =\n" +
            "                                        hexa_val_heapify(items_v);\n" +
            "                                } else {\n" +
            "                                    int n = HX_ARR_LEN(items_v);\n" +
            "                                    int water = hexa_array_water_get(idx);\n" +
            "                                    if (water > n) water = n;\n" +
            "                                    for (int i = water; i < n; i++) {\n" +
            "                                        HX_ARR_ITEMS(items_v)[i] =\n" +
            "                                            hexa_val_heapify(HX_ARR_ITEMS(items_v)[i]);\n" +
            "                                    }\n" +
            "                                    hexa_array_water_set(idx, n);\n" +
            "                                }\n" +
            "                            } else {\n" +
            "                                // Defensive: not a heap items array — fall\n" +
            "                                // back to full heapify (rare path).\n" +
            "                                HX_ARR_ITEMS(array_store)[idx] =\n" +
            "                                    hexa_val_heapify(items_v);\n" +
            "                            }\n" +
            "                        }\n" +
            "                    }\n" +
            "                } else if (HX_VSF(v, tag_i) == HEXA_INTERP_TAG_MAP && &map_store != 0) {\n" +
            "                    if (HX_IS_ARRAY(map_store) && HX_ARR_ITEMS(map_store)) {\n" +
            "                        int64_t idx = HX_VSF(v, int_val);\n" +
            "                        if (idx >= 0 && idx < (int64_t)HX_ARR_LEN(map_store)) {\n" +
            "                            // map_store[idx] is a TAG_ARRAY of length 2:\n" +
            "                            // [keys_array, values_array]. Heapifying the outer\n" +
            "                            // array walks both keys and values transitively.\n" +
            "                            HX_ARR_ITEMS(map_store)[idx] =\n" +
            "                                hexa_val_heapify(HX_ARR_ITEMS(map_store)[idx]);\n" +
            "                        }\n" +
            "                    }\n" +
            "                } else if (HX_VSF(v, tag_i) == HEXA_INTERP_TAG_STRUCT && &struct_store != 0) {\n" +
            "                    // rt 36-D: struct_store[idx] is a TAG_MAP (field map).\n" +
            "                    // Heapify it so closure-captured structs survive scope pop.\n" +
            "                    if (HX_IS_ARRAY(struct_store) && HX_ARR_ITEMS(struct_store)) {\n" +
            "                        int64_t idx = HX_VSF(v, int_val);\n" +
            "                        if (idx >= 0 && idx < (int64_t)HX_ARR_LEN(struct_store)) {\n" +
            "                            HX_ARR_ITEMS(struct_store)[idx] =\n" +
            "                                hexa_val_heapify(HX_ARR_ITEMS(struct_store)[idx]);\n" +
            "                        }\n" +
            "                    }\n" +
            "                }\n" +
            "            }\n" +
            "            return v;\n" +
            "        }\n" +
            "        default:\n" +
            "            return v;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────\n" +
            "// hexa_val_free_tree — recursive free of a malloc'd HexaVal tree.\n" +
            "// ─────────────────────────────────────────────────────────────\n" +
            "//\n" +
            "// PLAN-stage3-footprint-F6.md option C (P0-then-C). Used by the\n" +
            "// streaming codegen loop to reclaim per-function MFunc/LFunc once their\n" +
            "// asm text has been emitted. Caller asserts the value is unshared at\n" +
            "// the drop point — for the streaming loop this holds via the P0a-P0e\n" +
            "// escape-edge audit (string leaves forced-copied at every cross-\n" +
            "// lifetime store; container arrays/structs built fresh per pass).\n" +
            "//\n" +
            "// Conservative discipline:\n" +
            "//   - VALSTRUCT / ARRAY / MAP heap containers: recurse + free.\n" +
            "//   - from_arena=1 (VALSTRUCT, MapTable) or cap<0 (Array): SKIPPED —\n" +
            "//     arena-resident, lifetime owned by the scope pop, not free()-able.\n" +
            "//   - TAG_STR: NOT freed. Static literals (`hexa_str(\"...\")` in\n" +
            "//     transpiled source) and runtime-allocated buffers are not\n" +
            "//     statically distinguishable, and per-string overhead is small\n" +
            "//     versus the IR struct shells we DO reclaim.\n" +
            "//   - TAG_INT / FLOAT / BOOL / VOID / CHAR / FN / CLOSURE: no-op.\n" +
            "//\n" +
            "// Returns hexa_void() so it composes as an expression.\n" +
            "HexaVal hexa_val_free_tree(HexaVal v) {\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_VALSTRUCT: {\n" +
            "            HexaValStruct* vs = HX_VS(v);\n" +
            "            if (!HX_PTR_OK(vs)) return hexa_void();\n" +
            "            if (vs->from_arena) return hexa_void();\n" +
            "            hexa_val_free_tree(vs->str_val);\n" +
            "            hexa_val_free_tree(vs->char_val);\n" +
            "            hexa_val_free_tree(vs->array_val);\n" +
            "            hexa_val_free_tree(vs->fn_name);\n" +
            "            hexa_val_free_tree(vs->fn_params);\n" +
            "            hexa_val_free_tree(vs->fn_body);\n" +
            "            hexa_val_free_tree(vs->struct_name);\n" +
            "            hexa_val_free_tree(vs->struct_fields);\n" +
            "            free(vs);\n" +
            "            break;\n" +
            "        }\n" +
            "        case TAG_ARRAY: {\n" +
            "            if (!HX_PTR_OK(v.arr_ptr)) return hexa_void();\n" +
            "            int cap = HX_ARR_CAP(v);\n" +
            "            if (cap < 0) return hexa_void();  // arena-backed\n" +
            "            int len = HX_ARR_LEN(v);\n" +
            "            HexaVal* items = HX_ARR_ITEMS(v);\n" +
            "            if (items) {\n" +
            "                for (int i = 0; i < len; i++) {\n" +
            "                    hexa_val_free_tree(items[i]);\n" +
            "                }\n" +
            "                free(items);\n" +
            "            }\n" +
            "            free(v.arr_ptr);\n" +
            "            break;\n" +
            "        }\n" +
            "        case TAG_MAP: {\n" +
            "            HexaMap* mp = v.map_ptr;\n" +
            "            if (!HX_PTR_OK(mp)) return hexa_void();\n" +
            "            HexaMapTable* t = mp->tbl;\n" +
            "            if (t && !t->from_arena) {\n" +
            "                // Slot keys are strdup'd (heap) regardless of from_arena,\n" +
            "                // per the HexaMapTable comment.\n" +
            "                if (t->slots) {\n" +
            "                    for (int i = 0; i < t->ht_cap; i++) {\n" +
            "                        if (t->slots[i].key) free(t->slots[i].key);\n" +
            "                    }\n" +
            "                    free(t->slots);\n" +
            "                }\n" +
            "                if (t->order_vals) {\n" +
            "                    for (int i = 0; i < t->len; i++) {\n" +
            "                        hexa_val_free_tree(t->order_vals[i]);\n" +
            "                    }\n" +
            "                    free(t->order_vals);\n" +
            "                }\n" +
            "                if (t->vals)       free(t->vals);\n" +
            "                if (t->order_keys) free(t->order_keys);\n" +
            "                free(t);\n" +
            "            }\n" +
            "            free(mp);\n" +
            "            break;\n" +
            "        }\n" +
            "        default: break;\n" +
            "    }\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────\n" +
            "// hexa_val_copy_into_arena — recursive copy: malloc tree → arena tree\n" +
            "// ─────────────────────────────────────────────────────────────\n" +
            "//\n" +
            "// PLAN-stage3-footprint-F6-optA.md A1. Foundational primitive for the\n" +
            "// region-promote-on-return path. Mirrors hexa_val_heapify *in reverse*:\n" +
            "// where heapify copies arena→malloc, copy_into_arena copies malloc→\n" +
            "// arena and stamps from_arena=1 on every new heap-resident struct it\n" +
            "// makes. Allocations come from hexa_val_arena_calloc (bump arena);\n" +
            "// caller is responsible for the surrounding scope discipline.\n" +
            "//\n" +
            "// Dormant infrastructure — wired by A2 (heapify_to_parent wrapper) and\n" +
            "// A3 (the opt-in fn-return variant). Nothing calls this yet.\n" +
            "//\n" +
            "// Discipline:\n" +
            "//   - VALSTRUCT: alloc fresh in arena (from_arena=1), recurse each field.\n" +
            "//   - ARRAY: alloc HexaArr + items[] in arena (cap encoded as -real_cap\n" +
            "//     per rt 32-M arena-array marker), recurse each item.\n" +
            "//   - STR: copy bytes into a fresh arena buffer.\n" +
            "//   - MAP / CLOSURE / FN: passthrough unchanged. The streaming-loop IR\n" +
            "//     (MFunc / LFunc trees of VALSTRUCT + ARRAY + STR leaves) does not\n" +
            "//     materialise these tags inside the per-iteration region; if a\n" +
            "//     future caller needs them, add the mirror of hmap_heapify here.\n" +
            "//   - Primitives: passthrough.\n" +
            "//\n" +
            "// OOM-safe: arena alloc returning NULL falls back to the source value\n" +
            "// (caller still sees a consistent tree; the caller is responsible for\n" +
            "// keeping the source alive in that case — see A2 for the temp-buffer\n" +
            "// approach that makes this fall-back trivially correct).\n" +
            "HexaVal hexa_val_copy_into_arena(HexaVal v) {\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_VALSTRUCT: {\n" +
            "            HexaValStruct* src = HX_VS(v);\n" +
            "            if (!HX_PTR_OK(src)) return v;\n" +
            "            HexaValStruct* dst =\n" +
            "                (HexaValStruct*)hexa_val_arena_calloc(sizeof(HexaValStruct));\n" +
            "            if (!dst) return v;  // arena OOM — pass source through\n" +
            "            dst->tag_i      = src->tag_i;\n" +
            "            dst->int_val    = src->int_val;\n" +
            "            dst->float_val  = src->float_val;\n" +
            "            dst->bool_val   = src->bool_val;\n" +
            "            dst->from_arena = 1;\n" +
            "            dst->str_val       = hexa_val_copy_into_arena(src->str_val);\n" +
            "            dst->char_val      = hexa_val_copy_into_arena(src->char_val);\n" +
            "            dst->array_val     = hexa_val_copy_into_arena(src->array_val);\n" +
            "            dst->fn_name       = hexa_val_copy_into_arena(src->fn_name);\n" +
            "            dst->fn_params     = hexa_val_copy_into_arena(src->fn_params);\n" +
            "            dst->fn_body       = hexa_val_copy_into_arena(src->fn_body);\n" +
            "            dst->struct_name   = hexa_val_copy_into_arena(src->struct_name);\n" +
            "            dst->struct_fields = hexa_val_copy_into_arena(src->struct_fields);\n" +
            "            HX_SET_VS(v, dst);\n" +
            "            return v;\n" +
            "        }\n" +
            "        case TAG_ARRAY: {\n" +
            "            HexaArr* src = v.arr_ptr;\n" +
            "            if (!HX_PTR_OK(src)) return v;\n" +
            "            int len = src->len;\n" +
            "            HexaArr* dst = (HexaArr*)hexa_val_arena_calloc(sizeof(HexaArr));\n" +
            "            if (!dst) return v;  // arena OOM\n" +
            "            HexaVal* items = NULL;\n" +
            "            if (len > 0) {\n" +
            "                items = (HexaVal*)hexa_val_arena_calloc((size_t)len * sizeof(HexaVal));\n" +
            "                if (!items) return v;  // arena OOM\n" +
            "                for (int i = 0; i < len; i++) {\n" +
            "                    items[i] = hexa_val_copy_into_arena(src->items[i]);\n" +
            "                }\n" +
            "            }\n" +
            "            dst->items = items;\n" +
            "            dst->len = len;\n" +
            "            // rt 32-M: cap<0 marks arena-backed items buffer. Use -len so\n" +
            "            // future array_push paths recognise this as non-heap storage.\n" +
            "            dst->cap = (len > 0) ? -len : 0;\n" +
            "            v.arr_ptr = dst;\n" +
            "            return v;\n" +
            "        }\n" +
            "        case TAG_STR: {\n" +
            "            if (!HX_STR(v)) return v;\n" +
            "            size_t slen = HX_STRLEN(v);\n" +
            "            char* buf = (char*)hexa_arena_alloc(slen + 1);\n" +
            "            if (!buf) return v;  // arena OOM\n" +
            "            if (slen > 0) hxlcl_memcpy(buf, HX_STR(v), slen);\n" +
            "            buf[slen] = '\\0';\n" +
            "            HX_SET_STR(v, buf);\n" +
            "            return v;\n" +
            "        }\n" +
            "        case TAG_MAP: {\n" +
            "            // A6 ROOT-CAUSE FIX (2026-05-16): in this value model a hexa\n" +
            "            // `struct` is lowered to a TAG_MAP (field access =\n" +
            "            // hexa_map_get). A1's earlier MAP passthrough made the\n" +
            "            // arena copy SHARE the source map with the A2 malloc temp;\n" +
            "            // the temp-buffer free_tree(temp) then freed it, and\n" +
            "            // _new_block's hexa_map_get on the dangling LowerCtx map\n" +
            "            // SIGSEGV'd. Deep-copy into a fresh map so the result is\n" +
            "            // fully owned and independent of the temp.\n" +
            "            HexaMap* mp = v.map_ptr;\n" +
            "            if (!HX_PTR_OK(mp) || !mp->tbl) return v;\n" +
            "            HexaMapTable* t = mp->tbl;\n" +
            "            HexaVal nm = hexa_map_new();\n" +
            "            for (int i = 0; i < t->len; i++) {\n" +
            "                const char* k = t->order_keys ? t->order_keys[i] : (const char*)0;\n" +
            "                if (!k) continue;\n" +
            "                HexaVal vc = hexa_val_copy_into_arena(t->order_vals[i]);\n" +
            "                nm = hexa_map_set(nm, k, vc);\n" +
            "            }\n" +
            "            return nm;\n" +
            "        }\n" +
            "        default:\n" +
            "            // CLOSURE / FN / primitives — passthrough. The streaming-loop\n" +
            "            // IR (LowerCtx/MFunc/LFunc trees) does not materialise\n" +
            "            // closures inside the per-iteration region; extend here if a\n" +
            "            // future caller needs them (same share-then-free hazard).\n" +
            "            return v;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────\n" +
            "// hexa_val_arena_heapify_to_parent — temp-buffered region promote\n" +
            "// ─────────────────────────────────────────────────────────────\n" +
            "//\n" +
            "// PLAN-stage3-footprint-F6-optA.md A2. Promotes a Val that lives in the\n" +
            "// CURRENT arena frame into the PARENT frame's arena. The naive\n" +
            "// \"scope_pop then copy\" overlaps source and destination (the parent's\n" +
            "// frontier grows into where the callee's data sits, overwriting source\n" +
            "// mid-copy — see the optA doc \"Bump-arena overlap problem\"). The safe\n" +
            "// sequence routes the copy via a malloc temp:\n" +
            "//\n" +
            "//   1. heapify(v)         arena → malloc deep-copy (no overlap).\n" +
            "//   2. scope_pop()        rewind callee region; frontier at parent's mark.\n" +
            "//   3. copy_into_arena()  malloc → parent arena.\n" +
            "//   4. free_tree(temp)    release the malloc temp.\n" +
            "//\n" +
            "// Cost: 2× memory briefly (the malloc temp and the arena copy coexist\n" +
            "// for one recursion). Benefit: provably overlap-free, and the malloc\n" +
            "// temp goes through hexa_val_heapify whose recursion is the same the\n" +
            "// runtime uses on every fn-return today — no new aliasing surface.\n" +
            "//\n" +
            "// Caller contract: the per-fn arena scope mark is currently the\n" +
            "// callee's; this function pops that mark internally. Calling without a\n" +
            "// matching push is a defensive no-op (forwards v unchanged).\n" +
            "//\n" +
            "// Dormant infrastructure — wired by A3 (the opt-in fn-return variant).\n" +
            "HexaVal hexa_val_arena_heapify_to_parent(HexaVal v) {\n" +
            "    if (__hexa_val_mark_top <= 0) return v;  // no callee scope — no-op\n" +
            "    HexaVal temp = hexa_val_heapify(v);          // (1) malloc deep-copy\n" +
            "    hexa_val_arena_scope_pop();                  // (2) rewind callee region\n" +
            "    HexaVal arena_copy = hexa_val_copy_into_arena(temp); // (3) into parent\n" +
            "    hexa_val_free_tree(temp);                    // (4) release temp\n" +
            "    return arena_copy;\n" +
            "}\n" +
            "\n" +
            "// Public C entry — exposed for the env(\"__HEXA_ARENA_HEAPIFY_RETURN__\") path.\n" +
            "// Heapifies the global return_val (a hexa_full.hexa pub let mut, emitted as a\n" +
            "// C global). Declared extern; the symbol is provided by the generated C from\n" +
            "// hexa_full.hexa. Guarded by a weak-link check at call time so this object can\n" +
            "// link standalone (e.g. test harnesses that don't include hexa_full.hexa).\n" +
            "// rt#32-N build-fix: on macOS arm64 clang drops the weak attribute through\n" +
            "// plain extern; add weak_import so unresolved → NULL at runtime. Also provide\n" +
            "// a weak fallback definition so programs without a global `return_val` (like\n" +
            "// hexa_cc.c's own build) still link. When hexa_full.hexa's generated C\n" +
            "// defines `HexaVal return_val;` later, the strong definition wins (weak\n" +
            "// resolves to the strong one). A duplicate-weak -Wignored-attributes warning\n" +
            "// is harmless.\n" +
            "extern HexaVal return_val __attribute__((weak_import, weak));\n" +
            "__attribute__((weak)) HexaVal return_val __attribute__((common));\n" +
            "static void hexa_val_arena_heapify_return(void) {\n" +
            "    if (&return_val) {\n" +
            "        return_val = hexa_val_heapify(return_val);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ── STRUCTURAL-7 Phase A: codegen fn-boundary arena enter/return ──\n" +
            "// Implementations for the forward declarations near line 579. When the arena\n" +
            "// is OFF (HEXA_VAL_ARENA=0), both are no-ops. When ON (default since S7-B),\n" +
            "// enter() pushes an arena scope mark and return() heapifies the return value\n" +
            "// (promoting any arena-allocated memory to the heap) then pops the scope.\n" +
            "void __hexa_fn_arena_enter(void) {\n" +
            "    if (!hexa_val_arena_on()) return;\n" +
            "    hexa_val_arena_scope_push();\n" +
            "}\n" +
            "\n" +
            "HexaVal __hexa_fn_arena_return(HexaVal ret) {\n" +
            "    if (!hexa_val_arena_on()) return ret;\n" +
            "    if (__hexa_val_mark_top <= 0) return ret;  // no matching push — defensive\n" +
            "    // perf-3B: primitive tags carry no arena-backed storage, so the\n" +
            "    // hexa_val_heapify call + its switch dispatch is pure overhead.\n" +
            "    // Pratt-descent parser fns return int/bool dozens of times per token,\n" +
            "    // and sample showed __hexa_fn_arena_return + hexa_val_heapify ≈ 23% of\n" +
            "    // hexat user-time on codegen.hexa. Short-circuit primitives here.\n" +
            "    int tag = HX_TAG(ret);\n" +
            "    if (tag == TAG_INT || tag == TAG_FLOAT || tag == TAG_BOOL || tag == TAG_VOID) {\n" +
            "        hexa_val_arena_scope_pop();\n" +
            "        return ret;\n" +
            "    }\n" +
            "    // F6 option A — A3: when region returns are enabled (default OFF;\n" +
            "    // streaming loop toggles via env hook), promote into the caller's\n" +
            "    // arena frame instead of escaping to malloc. hexa_val_arena_heapify_\n" +
            "    // to_parent does the scope_pop itself, so we return immediately.\n" +
            "    if (__hexa_val_region_returns_enabled) {\n" +
            "        return hexa_val_arena_heapify_to_parent(ret);\n" +
            "    }\n" +
            "    ret = hexa_val_heapify(ret);\n" +
            "    hexa_val_arena_scope_pop();\n" +
            "    return ret;\n" +
            "}\n" +
            "\n" +
            "// ── String operations ────────────────────────────────────\n" +
            "\n" +
            "// rt 32-D: optional arena path. Under HEXA_STR_ARENA=1, temporary concat\n" +
            "// results are bump-allocated from the scope arena instead of malloc'd\n" +
            "// individually. Safety: strings that escape the arena's lifetime (returns,\n" +
            "// map inserts, closure captures) must be copied into the persistent heap\n" +
            "// by the caller — for now we do NOT perform automatic escape analysis, so\n" +
            "// the gate defaults to OFF. With the gate OFF behavior is bit-identical to\n" +
            "// pre-rt-32-D (every concat still does its own malloc).\n" +
            "HexaVal hexa_str_concat(HexaVal a, HexaVal b) {\n" +
            "    if (_hx_stats_on()) _hx_stats_str_concat++;\n" +
            "    // A17: both operands string is the dominant case in self-hosting parser\n" +
            "    // (token + token, prefix + name). Hint truthy on HX_IS_STR.\n" +
            "    char* sa = HX_LIKELY(HX_IS_STR(a)) ? HX_STR(a) : \"\";\n" +
            "    char* sb = HX_LIKELY(HX_IS_STR(b)) ? HX_STR(b) : \"\";\n" +
            "    size_t la = hxlcl_strlen(sa);\n" +
            "    size_t lb = hxlcl_strlen(sb);\n" +
            "    // ROI-36: empty-string elision — skip alloc+memcpy when one side is \"\".\n" +
            "    // Empty-side is uncommon on the hot self-host path (parser keyword\n" +
            "    // accumulator), so hint the non-empty arms.\n" +
            "    if (HX_UNLIKELY(la == 0)) return HX_IS_STR(b) ? b : hexa_str(sb);\n" +
            "    if (HX_UNLIKELY(lb == 0)) return HX_IS_STR(a) ? a : hexa_str(sa);\n" +
            "    size_t total = la + lb + 1;\n" +
            "    char* result;\n" +
            "    if (HX_LIKELY(hexa_arena_on())) {\n" +
            "        result = (char*)hexa_arena_alloc(total);\n" +
            "        if (HX_UNLIKELY(!result)) {\n" +
            "            // Fallback: arena OOM → heap malloc so we stay correct.\n" +
            "            result = (char*)malloc(total);\n" +
            "        } else {\n" +
            "            if (_hx_stats_on()) _hx_stats_str_concat_arena++;\n" +
            "        }\n" +
            "    } else {\n" +
            "        result = (char*)malloc(total);\n" +
            "    }\n" +
            "    // memcpy avoids the strcpy+strcat double walk.\n" +
            "    hxlcl_memcpy(result, sa, la);\n" +
            "    hxlcl_memcpy(result + la, sb, lb);\n" +
            "    result[la + lb] = '\\0';\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "\n" +
            "// L4 ω-cycle (lossless) — byte-index scan ASCII fast-path.\n" +
            "//\n" +
            "// Original: 1 hexa_str(buf) intern call per byte → FNV1a hash + linear probe\n" +
            "// + (first-time) strdup. For an N-byte source the lexer's hot path\n" +
            "// (`chars = source.chars()`) does N intern lookups even when all 256 single-\n" +
            "// byte values are already cached. On 842KB ai_native_pass.hexa baseline that\n" +
            "// is ~840k FNV1a calls + ~840k array_push calls inside parse phase.\n" +
            "//\n" +
            "// New: lazy-init a 256-entry HexaVal cache for single-byte strings, and have\n" +
            "// hexa_str_chars do a direct table lookup per byte. Output is byte-equivalent\n" +
            "// (same interned pointer that hexa_str(buf) would have returned anyway, since\n" +
            "// 1-byte strings hash into the intern table the same way), so token stream is\n" +
            "// preserved bitwise.\n" +
            "//\n" +
            "// Lossless axes:\n" +
            "//   performance: hexa_str(buf) result identity is preserved (same intern\n" +
            "//                pointer → same hexa_eq behavior).\n" +
            "//   resource:    +256*sizeof(HexaVal) static = ~4KB BSS one-shot.\n" +
            "//   speed:       O(1) table lookup vs hash + probe.\n" +
            "static HexaVal _cached_byte_str[256];\n" +
            "static int     _cached_byte_str_ready = 0;\n" +
            "\n" +
            "static void _hexa_init_byte_str_cache(void) {\n" +
            "    if (_cached_byte_str_ready) return;\n" +
            "    char buf[2];\n" +
            "    buf[1] = '\\0';\n" +
            "    for (int i = 0; i < 256; i++) {\n" +
            "        buf[0] = (char)(unsigned char)i;\n" +
            "        // For NUL byte we still produce the canonical empty-string interned\n" +
            "        // value so hexa_eq matches whatever hexa_str(\"\") returns elsewhere.\n" +
            "        _cached_byte_str[i] = hexa_str(buf);\n" +
            "    }\n" +
            "    _cached_byte_str_ready = 1;\n" +
            "}\n" +
            "\n" +
            "// Forward decl — defined further down. Needed here because hexa_str_chars\n" +
            "// (immediately below) uses it to walk UTF-8 codepoints.\n" +
            "static int _hx_utf8_cp_len(unsigned char b);\n" +
            "\n" +
            "// Step-3 cycle 47 port — UTF-8 codepoint walker dispatches to\n" +
            "// rt_str_chars (ctype.hexa). The hexa body inlines the\n" +
            "// `_hx_utf8_cp_len` bit-pattern table as if/else-if checks; the\n" +
            "// returned array contains 1-codepoint strings (not bytes).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_chars(HexaVal s) {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (!HX_IS_STR(s)) return arr;\n" +
            "    // 2026-05-19 parity-gate t45b: walk UTF-8 codepoints so\n" +
            "    // `\"한글hi\".chars().len() == 4` (4 codepoints), not 8 (bytes).\n" +
            "    // ASCII behavior is unchanged (codepoint == byte for ASCII). For\n" +
            "    // raw byte iteration use the separate `.bytes()` / hexa_str_bytes\n" +
            "    // path. The old byte-level chars() was the buggy-oracle behavior\n" +
            "    // that interp doesn't have — deletion-gate alignment.\n" +
            "    const char* p = HX_STR(s);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t i = 0;\n" +
            "    while (i < n) {\n" +
            "        int cp = _hx_utf8_cp_len((unsigned char)p[i]);\n" +
            "        char buf[5] = {0};\n" +
            "        int j = 0;\n" +
            "        while (j < cp && i + j < n) { buf[j] = p[i + j]; j++; }\n" +
            "        buf[j] = 0;\n" +
            "        arr = hexa_array_push(arr, hexa_str(buf));\n" +
            "        i += cp;\n" +
            "    }\n" +
            "    return arr;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_chars(HexaVal s);\n" +
            "HexaVal hexa_str_chars(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_array_new();\n" +
            "    return rt_str_chars(s);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ── UAX-29 extended grapheme cluster segmentation (PROBE r15-D10) ──────\n" +
            "// `.graphemes()` / `.grapheme_count()`.  Prior to r15-D10 `.graphemes()`\n" +
            "// was a DEGRADED stub aliased to `.chars()` (codepoint walk) — wrong for\n" +
            "// combining marks, ZWJ emoji families, regional-indicator flags, and\n" +
            "// conjoining Hangul.  This implements the Unicode Text Segmentation\n" +
            "// (UAX-29) extended grapheme cluster boundary rules via a pure-C\n" +
            "// GraphemeBreak property classifier — no external dependency, matching\n" +
            "// hexa's no-LLVM / generated-table identity (RFC §5 option 5-A).\n" +
            "//\n" +
            "// Covered GB rules:  GB1/GB2 (sot/eot), GB3 (CR × LF), GB4/GB5\n" +
            "// (Control/CR/LF break), GB6/GB7/GB8 (Hangul L/V/T/LV/LVT), GB9\n" +
            "// (× Extend, × ZWJ), GB9a (× SpacingMark), GB11 (Extended_Pictographic\n" +
            "// Extend* ZWJ × Extended_Pictographic — emoji families), GB12/GB13\n" +
            "// (regional-indicator pairs), GB999 (otherwise break).\n" +
            "// Deferred (rare; not in the r15-D9 acceptance set):  GB9b (Prepend ×).\n" +
            "//\n" +
            "// The property tables are range-compressed and cover the classes that\n" +
            "// drive real boundaries (Extend / SpacingMark / ZWJ / Regional_Indicator\n" +
            "// / Extended_Pictographic / Hangul L·V·T·LV·LVT / Control / CR / LF).\n" +
            "// Unlisted codepoints classify as \"Other\" → boundary on both sides\n" +
            "// (GB999), which is the correct default for the vast majority of text.\n" +
            "\n" +
            "// GraphemeBreak property classes (internal enum).\n" +
            "#define HXGB_OTHER   0\n" +
            "#define HXGB_CR      1\n" +
            "#define HXGB_LF      2\n" +
            "#define HXGB_CONTROL 3\n" +
            "#define HXGB_EXTEND  4\n" +
            "#define HXGB_ZWJ     5\n" +
            "#define HXGB_RI      6   /* Regional_Indicator */\n" +
            "#define HXGB_PREPEND 7\n" +
            "#define HXGB_SPMARK  8   /* SpacingMark */\n" +
            "#define HXGB_L       9\n" +
            "#define HXGB_V       10\n" +
            "#define HXGB_T       11\n" +
            "#define HXGB_LV      12\n" +
            "#define HXGB_LVT     13\n" +
            "#define HXGB_EXTPICT 14  /* Extended_Pictographic */\n" +
            "\n" +
            "// Decode the UTF-8 codepoint starting at p[i] (n = total bytes). Writes\n" +
            "// the byte length of the sequence into *outlen. Invalid lead bytes decode\n" +
            "// as the raw byte with length 1 (never infinite-loop). Mirrors the\n" +
            "// _hx_utf8_cp_len length table used elsewhere in this file.\n" +
            "static int32_t _hx_utf8_decode(const char* p, int64_t n, int64_t i, int* outlen) {\n" +
            "    unsigned char b0 = (unsigned char)p[i];\n" +
            "    if (b0 < 0x80) { *outlen = 1; return b0; }\n" +
            "    if ((b0 & 0xE0) == 0xC0) {\n" +
            "        if (i + 1 < n) {\n" +
            "            *outlen = 2;\n" +
            "            return ((b0 & 0x1F) << 6) | ((unsigned char)p[i + 1] & 0x3F);\n" +
            "        }\n" +
            "        *outlen = 1; return b0;\n" +
            "    }\n" +
            "    if ((b0 & 0xF0) == 0xE0) {\n" +
            "        if (i + 2 < n) {\n" +
            "            *outlen = 3;\n" +
            "            return ((b0 & 0x0F) << 12) | (((unsigned char)p[i + 1] & 0x3F) << 6)\n" +
            "                 | ((unsigned char)p[i + 2] & 0x3F);\n" +
            "        }\n" +
            "        *outlen = 1; return b0;\n" +
            "    }\n" +
            "    if ((b0 & 0xF8) == 0xF0) {\n" +
            "        if (i + 3 < n) {\n" +
            "            *outlen = 4;\n" +
            "            return ((b0 & 0x07) << 18) | (((unsigned char)p[i + 1] & 0x3F) << 12)\n" +
            "                 | (((unsigned char)p[i + 2] & 0x3F) << 6)\n" +
            "                 | ((unsigned char)p[i + 3] & 0x3F);\n" +
            "        }\n" +
            "        *outlen = 1; return b0;\n" +
            "    }\n" +
            "    *outlen = 1; return b0;  // invalid lead byte\n" +
            "}\n" +
            "\n" +
            "// Classify a codepoint into its GraphemeBreak property. Range-compressed;\n" +
            "// reasonably-scoped coverage (full UCD not required — the unlisted\n" +
            "// majority is HXGB_OTHER, the correct default).\n" +
            "static int _hx_gb_class(int32_t c) {\n" +
            "    // CR / LF / Control (GB3/GB4/GB5)\n" +
            "    if (c == 0x0D) return HXGB_CR;\n" +
            "    if (c == 0x0A) return HXGB_LF;\n" +
            "    if (c == 0x200D) return HXGB_ZWJ;                       // ZERO WIDTH JOINER\n" +
            "    if (c < 0x20 || (c >= 0x7F && c <= 0x9F)) return HXGB_CONTROL;\n" +
            "    if (c == 0x00AD) return HXGB_CONTROL;                   // SOFT HYPHEN\n" +
            "    if (c == 0x200B || c == 0x200C) return HXGB_CONTROL;    // ZWSP / ZWNJ\n" +
            "    if (c >= 0x2028 && c <= 0x202E) return HXGB_CONTROL;    // line/para sep + bidi\n" +
            "    if (c == 0xFEFF) return HXGB_CONTROL;                   // BOM / ZWNBSP\n" +
            "\n" +
            "    // Regional_Indicator (GB12/GB13)\n" +
            "    if (c >= 0x1F1E6 && c <= 0x1F1FF) return HXGB_RI;\n" +
            "\n" +
            "    // Hangul conjoining jamo + precomposed syllables (GB6/GB7/GB8)\n" +
            "    if (c >= 0x1100 && c <= 0x115F) return HXGB_L;          // L (leading)\n" +
            "    if (c >= 0xA960 && c <= 0xA97C) return HXGB_L;          // L (extended-A)\n" +
            "    if (c >= 0x1160 && c <= 0x11A7) return HXGB_V;          // V (vowel)\n" +
            "    if (c >= 0xD7B0 && c <= 0xD7C6) return HXGB_V;          // V (extended-B)\n" +
            "    if (c >= 0x11A8 && c <= 0x11FF) return HXGB_T;          // T (trailing)\n" +
            "    if (c >= 0xD7CB && c <= 0xD7FB) return HXGB_T;          // T (extended-B)\n" +
            "    if (c >= 0xAC00 && c <= 0xD7A3) {                       // precomposed syllable\n" +
            "        return ((c - 0xAC00) % 28 == 0) ? HXGB_LV : HXGB_LVT;\n" +
            "    }\n" +
            "\n" +
            "    // Extend — combining marks / variation selectors (GB9). Range-compressed\n" +
            "    // major blocks; covers the common scripts plus emoji modifiers.\n" +
            "    if (c >= 0x0300 && c <= 0x036F) return HXGB_EXTEND;     // combining diacritical\n" +
            "    if (c >= 0x0483 && c <= 0x0489) return HXGB_EXTEND;     // Cyrillic combining\n" +
            "    if (c >= 0x0591 && c <= 0x05BD) return HXGB_EXTEND;     // Hebrew points\n" +
            "    if (c == 0x05BF || c == 0x05C1 || c == 0x05C2 || c == 0x05C4 || c == 0x05C5 || c == 0x05C7)\n" +
            "        return HXGB_EXTEND;                                 // Hebrew points\n" +
            "    if (c >= 0x0610 && c <= 0x061A) return HXGB_EXTEND;     // Arabic\n" +
            "    if (c >= 0x064B && c <= 0x065F) return HXGB_EXTEND;     // Arabic diacritics\n" +
            "    if (c == 0x0670) return HXGB_EXTEND;                    // Arabic superscript alef\n" +
            "    if (c >= 0x06D6 && c <= 0x06DC) return HXGB_EXTEND;     // Arabic small high\n" +
            "    if (c >= 0x06DF && c <= 0x06E4) return HXGB_EXTEND;\n" +
            "    if (c == 0x06E7 || c == 0x06E8) return HXGB_EXTEND;\n" +
            "    if (c >= 0x06EA && c <= 0x06ED) return HXGB_EXTEND;\n" +
            "    if (c >= 0x0900 && c <= 0x0903) return HXGB_EXTEND;     // Devanagari (approx)\n" +
            "    if (c >= 0x093A && c <= 0x094F) return HXGB_EXTEND;\n" +
            "    if (c >= 0x0951 && c <= 0x0957) return HXGB_EXTEND;\n" +
            "    if (c >= 0x0E31 && c <= 0x0E3A) return HXGB_EXTEND;     // Thai (approx)\n" +
            "    if (c >= 0x0E47 && c <= 0x0E4E) return HXGB_EXTEND;\n" +
            "    if (c >= 0x0F71 && c <= 0x0F84) return HXGB_EXTEND;     // Tibetan (approx)\n" +
            "    if (c >= 0x135D && c <= 0x135F) return HXGB_EXTEND;     // Ethiopic combining\n" +
            "    if (c >= 0x1AB0 && c <= 0x1AFF) return HXGB_EXTEND;     // combining diacritical ext\n" +
            "    if (c >= 0x1DC0 && c <= 0x1DFF) return HXGB_EXTEND;     // combining diacritical supp\n" +
            "    if (c >= 0x20D0 && c <= 0x20FF) return HXGB_EXTEND;     // combining for symbols\n" +
            "    if (c >= 0xFE00 && c <= 0xFE0F) return HXGB_EXTEND;     // variation selectors\n" +
            "    if (c >= 0xFE20 && c <= 0xFE2F) return HXGB_EXTEND;     // combining half marks\n" +
            "    if (c >= 0xE0100 && c <= 0xE01EF) return HXGB_EXTEND;   // variation selectors supp\n" +
            "    if (c >= 0x1F3FB && c <= 0x1F3FF) return HXGB_EXTEND;   // emoji skin-tone modifiers\n" +
            "\n" +
            "    // Extended_Pictographic (GB11) — emoji. Range-compressed broad blocks.\n" +
            "    if (c >= 0x1F000 && c <= 0x1FAFF) {\n" +
            "        if (c >= 0x1F1E6 && c <= 0x1F1FF) return HXGB_RI;   // (RI handled above; guard)\n" +
            "        return HXGB_EXTPICT;\n" +
            "    }\n" +
            "    if (c >= 0x2600 && c <= 0x26FF) return HXGB_EXTPICT;    // misc symbols\n" +
            "    if (c >= 0x2700 && c <= 0x27BF) return HXGB_EXTPICT;    // dingbats\n" +
            "    if (c == 0x2049 || c == 0x203C) return HXGB_EXTPICT;\n" +
            "    if (c >= 0x2194 && c <= 0x21AA) return HXGB_EXTPICT;\n" +
            "    if (c >= 0x231A && c <= 0x231B) return HXGB_EXTPICT;\n" +
            "    if (c == 0x2328 || c == 0x23CF) return HXGB_EXTPICT;\n" +
            "    if (c >= 0x23E9 && c <= 0x23FA) return HXGB_EXTPICT;\n" +
            "    if (c == 0x24C2) return HXGB_EXTPICT;\n" +
            "    if (c >= 0x25AA && c <= 0x25FE) return HXGB_EXTPICT;\n" +
            "    if (c == 0x2B50 || c == 0x2B55 || c == 0x2B1B || c == 0x2B1C) return HXGB_EXTPICT;\n" +
            "    if (c == 0x3030 || c == 0x303D || c == 0x3297 || c == 0x3299) return HXGB_EXTPICT;\n" +
            "\n" +
            "    return HXGB_OTHER;\n" +
            "}\n" +
            "\n" +
            "// Determine whether there is a grapheme cluster boundary BETWEEN the\n" +
            "// codepoint with class `prev` and the codepoint with class `cur`.\n" +
            "// `ri_odd` = number of consecutive Regional_Indicators so far before\n" +
            "// `cur` is odd (GB12/GB13 — break only between RI pairs, not within).\n" +
            "// `after_zwj_pict` = the previous codepoint was a ZWJ that was itself\n" +
            "// preceded by an Extended_Pictographic (Extend*) run (GB11).\n" +
            "// Returns 1 if a boundary exists (cluster break), 0 if no break (join).\n" +
            "static int _hx_gb_is_boundary(int prev, int cur, int ri_odd, int after_zwj_pict) {\n" +
            "    // GB3: CR × LF — no break inside a CRLF pair.\n" +
            "    if (prev == HXGB_CR && cur == HXGB_LF) return 0;\n" +
            "    // GB4: (Control | CR | LF) ÷  — break after.\n" +
            "    if (prev == HXGB_CONTROL || prev == HXGB_CR || prev == HXGB_LF) return 1;\n" +
            "    // GB5: ÷ (Control | CR | LF) — break before.\n" +
            "    if (cur == HXGB_CONTROL || cur == HXGB_CR || cur == HXGB_LF) return 1;\n" +
            "\n" +
            "    // GB6: L × (L | V | LV | LVT)\n" +
            "    if (prev == HXGB_L && (cur == HXGB_L || cur == HXGB_V || cur == HXGB_LV || cur == HXGB_LVT))\n" +
            "        return 0;\n" +
            "    // GB7: (LV | V) × (V | T)\n" +
            "    if ((prev == HXGB_LV || prev == HXGB_V) && (cur == HXGB_V || cur == HXGB_T))\n" +
            "        return 0;\n" +
            "    // GB8: (LVT | T) × T\n" +
            "    if ((prev == HXGB_LVT || prev == HXGB_T) && cur == HXGB_T)\n" +
            "        return 0;\n" +
            "\n" +
            "    // GB9: × (Extend | ZWJ) — never break before Extend or ZWJ.\n" +
            "    if (cur == HXGB_EXTEND || cur == HXGB_ZWJ) return 0;\n" +
            "    // GB9a: × SpacingMark\n" +
            "    if (cur == HXGB_SPMARK) return 0;\n" +
            "    // GB9b: Prepend ×  (no break after Prepend) — deferred/partial.\n" +
            "    if (prev == HXGB_PREPEND) return 0;\n" +
            "\n" +
            "    // GB11: Extended_Pictographic Extend* ZWJ × Extended_Pictographic\n" +
            "    if (after_zwj_pict && cur == HXGB_EXTPICT) return 0;\n" +
            "\n" +
            "    // GB12/GB13: RI × RI only between an even-then-odd RI (i.e. join the\n" +
            "    // first of a pair). `ri_odd` true means `cur` (an RI) is the 2nd of a\n" +
            "    // pair → no break; else break.\n" +
            "    if (prev == HXGB_RI && cur == HXGB_RI) {\n" +
            "        return ri_odd ? 0 : 1;\n" +
            "    }\n" +
            "\n" +
            "    // GB999: otherwise, break.\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "// Core walker: invokes a callback at each cluster boundary. Shared by\n" +
            "// hexa_str_graphemes (collect substrings) and hexa_str_grapheme_count.\n" +
            "// Counts clusters in [p, p+n). Returns the cluster count; if `out_arr` is\n" +
            "// non-NULL, pushes each cluster substring onto it.\n" +
            "static int64_t _hx_grapheme_walk(const char* p, int64_t n, HexaVal* out_arr) {\n" +
            "    int64_t count = 0;\n" +
            "    int64_t i = 0;\n" +
            "    int64_t cluster_start = 0;\n" +
            "    int prev_class = -1;\n" +
            "    int ri_count = 0;            // consecutive RI run length (for GB12/13 parity)\n" +
            "    int pict_pending = 0;        // saw Extended_Pictographic then only Extend* since\n" +
            "    int after_zwj_pict = 0;      // previous cp was ZWJ closing a pictographic run\n" +
            "    while (i < n) {\n" +
            "        int cplen = 0;\n" +
            "        int32_t cp = _hx_utf8_decode(p, n, i, &cplen);\n" +
            "        int cls = _hx_gb_class(cp);\n" +
            "        if (prev_class < 0) {\n" +
            "            // sot — first codepoint opens the first cluster (GB1).\n" +
            "            cluster_start = i;\n" +
            "        } else {\n" +
            "            int ri_odd = (ri_count % 2 == 1);\n" +
            "            if (_hx_gb_is_boundary(prev_class, cls, ri_odd, after_zwj_pict)) {\n" +
            "                // Emit the cluster [cluster_start, i).\n" +
            "                if (out_arr) {\n" +
            "                    int64_t clen = i - cluster_start;\n" +
            "                    char* cbuf = (char*)malloc((size_t)clen + 1);\n" +
            "                    if (cbuf) {\n" +
            "                        memcpy(cbuf, p + cluster_start, (size_t)clen);\n" +
            "                        cbuf[clen] = 0;\n" +
            "                        *out_arr = hexa_array_push(*out_arr, hexa_str(cbuf));\n" +
            "                        free(cbuf);\n" +
            "                    }\n" +
            "                }\n" +
            "                count++;\n" +
            "                cluster_start = i;\n" +
            "            }\n" +
            "        }\n" +
            "        // Update GB11 pictographic-ZWJ state.\n" +
            "        if (cls == HXGB_EXTPICT) {\n" +
            "            pict_pending = 1;\n" +
            "            after_zwj_pict = 0;\n" +
            "        } else if (cls == HXGB_EXTEND) {\n" +
            "            // Extend* keeps the pictographic run alive (GB11 allows Extend*).\n" +
            "            after_zwj_pict = 0;\n" +
            "        } else if (cls == HXGB_ZWJ) {\n" +
            "            after_zwj_pict = pict_pending;   // ZWJ closes a pictographic run iff one was pending\n" +
            "        } else {\n" +
            "            pict_pending = 0;\n" +
            "            after_zwj_pict = 0;\n" +
            "        }\n" +
            "        // Update RI parity run (GB12/13): consecutive RIs.\n" +
            "        if (cls == HXGB_RI) {\n" +
            "            ri_count++;\n" +
            "        } else {\n" +
            "            ri_count = 0;\n" +
            "        }\n" +
            "        prev_class = cls;\n" +
            "        i += cplen;\n" +
            "    }\n" +
            "    if (prev_class >= 0) {\n" +
            "        // Emit the final cluster (eot, GB2).\n" +
            "        if (out_arr) {\n" +
            "            int64_t clen = n - cluster_start;\n" +
            "            char* cbuf = (char*)malloc((size_t)clen + 1);\n" +
            "            if (cbuf) {\n" +
            "                memcpy(cbuf, p + cluster_start, (size_t)clen);\n" +
            "                cbuf[clen] = 0;\n" +
            "                *out_arr = hexa_array_push(*out_arr, hexa_str(cbuf));\n" +
            "                free(cbuf);\n" +
            "            }\n" +
            "        }\n" +
            "        count++;\n" +
            "    }\n" +
            "    return count;\n" +
            "}\n" +
            "\n" +
            "// `.graphemes()` — array of UAX-29 extended grapheme cluster substrings.\n" +
            "HexaVal hexa_str_graphemes(HexaVal s) {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (!HX_IS_STR(s)) return arr;\n" +
            "    const char* p = HX_STR(s);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    _hx_grapheme_walk(p, n, &arr);\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// `.grapheme_count()` — count-only fast-path (no array allocation).\n" +
            "HexaVal hexa_str_grapheme_count(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_int(0);\n" +
            "    const char* p = HX_STR(s);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    return hexa_int(_hx_grapheme_walk(p, n, NULL));\n" +
            "}\n" +
            "\n" +
            "// Step-3 cycle 57 port — int-return bridge through rt_str_contains_b.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int hexa_str_contains(HexaVal s, HexaVal sub) {\n" +
            "    return hxlcl_strstr(HX_STR(s), HX_STR(sub)) != NULL;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_contains_b(HexaVal s, HexaVal sub);\n" +
            "int hexa_str_contains(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return 0;\n" +
            "    return hexa_truthy(rt_str_contains_b(s, sub)) ? 1 : 0;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 57 port — int-return bridge through rt_str_eq_b. The\n" +
            "// pointer-equality fast-path for interned strings stays C-side (hexa\n" +
            "// source can't observe HX_STR identity).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int hexa_str_eq(HexaVal a, HexaVal b) {\n" +
            "    if (!HX_IS_STR(a) || !HX_IS_STR(b)) return 0;\n" +
            "    // Optimization #11: interned strings share pointers\n" +
            "    if (HX_STR(a) == HX_STR(b)) return 1;\n" +
            "    return hxlcl_strcmp(HX_STR(a), HX_STR(b)) == 0;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_eq_b(HexaVal a, HexaVal b);\n" +
            "int hexa_str_eq(HexaVal a, HexaVal b) {\n" +
            "    if (!HX_IS_STR(a) || !HX_IS_STR(b)) return 0;\n" +
            "    if (HX_STR(a) == HX_STR(b)) return 1;  // intern fast-path stays C\n" +
            "    return hexa_truthy(rt_str_eq_b(a, b)) ? 1 : 0;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// M1 full · str_ext Step 5 (hxa-20260423-003): rt_str_starts_with/ends_with —\n" +
            "// codegen emits rt_str_* directly; hexa_str_starts_with/ends_with shims retired.\n" +
            "// Step-3 cycle 56 port — int-return bridge through rt_str_*_b (hexa\n" +
            "// source returns bool; the `_b` suffix avoids name collision with the\n" +
            "// C int-return symbol that codegen wraps via `hexa_bool(...)`).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int rt_str_starts_with(HexaVal s, HexaVal prefix) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(prefix)) return 0;\n" +
            "    size_t plen = HX_STRLEN(prefix);\n" +
            "    return hxlcl_strncmp(HX_STR(s), HX_STR(prefix), plen) == 0;\n" +
            "}\n" +
            "\n" +
            "int rt_str_ends_with(HexaVal s, HexaVal suffix) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(suffix)) return 0;\n" +
            "    size_t slen = HX_STRLEN(s);\n" +
            "    size_t sfxlen = HX_STRLEN(suffix);\n" +
            "    if (sfxlen > slen) return 0;\n" +
            "    return hxlcl_strcmp(HX_STR(s) + slen - sfxlen, HX_STR(suffix)) == 0;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_starts_with_b(HexaVal s, HexaVal prefix);\n" +
            "extern HexaVal rt_str_ends_with_b(HexaVal s, HexaVal suffix);\n" +
            "int rt_str_starts_with(HexaVal s, HexaVal prefix) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(prefix)) return 0;\n" +
            "    return hexa_truthy(rt_str_starts_with_b(s, prefix)) ? 1 : 0;\n" +
            "}\n" +
            "int rt_str_ends_with(HexaVal s, HexaVal suffix) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(suffix)) return 0;\n" +
            "    return hexa_truthy(rt_str_ends_with_b(s, suffix)) ? 1 : 0;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "HexaVal hexa_str_substring(HexaVal s, HexaVal start, HexaVal end) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    int64_t slen = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t a = HX_INT(start), b = HX_INT(end);\n" +
            "    if (a < 0) a = 0;\n" +
            "    if (b > slen) b = slen;\n" +
            "    if (a >= b) return hexa_str(\"\");\n" +
            "    // perf-31: write straight into header-allocated buffer — eliminates the\n" +
            "    // hexa_str_own copy that would otherwise re-strlen + re-malloc + memcpy.\n" +
            "    char* buf = hexa_strbuf_alloc((size_t)(b - a));\n" +
            "    hxlcl_memcpy(buf, HX_STR(s) + a, (size_t)(b - a));\n" +
            "    return (HexaVal){.tag=TAG_STR, .s=buf};\n" +
            "}\n" +
            "\n" +
            "// Step-3 cycle 54 port — int64_t-returning fn bridged through hexa-source\n" +
            "// `rt_str_index_of` (returns int → HexaVal at C ABI). The C wrapper\n" +
            "// preserves the int64_t signature so codegen wrapping\n" +
            "// `hexa_int(hexa_str_index_of(...))` keeps working.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int64_t hexa_str_index_of(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n" +
            "    char* p = hxlcl_strstr(HX_STR(s), HX_STR(sub));\n" +
            "    if (!p) return -1;\n" +
            "    return (int64_t)(p - HX_STR(s));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_index_of(HexaVal s, HexaVal sub);\n" +
            "int64_t hexa_str_index_of(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n" +
            "    return HX_INT(rt_str_index_of(s, sub));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// `.index_of(sub, start)` — first occurrence at-or-after byte offset `start`.\n" +
            "// hxa-20260423-012: the 2-arg form was silently dropping `start`, forcing\n" +
            "// anima to emit fields in a hack order (rank BEFORE weights) to dodge the\n" +
            "// miscompare. Semantics: clamp start to [0,len]; empty needle → start.\n" +
            "// Step-3 cycle 55 port — int64_t-return bridge.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int64_t hexa_str_index_of_from(HexaVal s, HexaVal sub, HexaVal start) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n" +
            "    const char* hay = HX_STR(s);\n" +
            "    size_t hlen = hxlcl_strlen(hay);\n" +
            "    int64_t st = HX_INT(start);\n" +
            "    if (st < 0) st = 0;\n" +
            "    if ((size_t)st > hlen) return -1;\n" +
            "    const char* needle = HX_STR(sub);\n" +
            "    if (*needle == '\\0') return st;\n" +
            "    const char* p = hxlcl_strstr(hay + st, needle);\n" +
            "    if (!p) return -1;\n" +
            "    return (int64_t)(p - hay);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_index_of_from(HexaVal s, HexaVal sub, HexaVal start);\n" +
            "int64_t hexa_str_index_of_from(HexaVal s, HexaVal sub, HexaVal start) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n" +
            "    return HX_INT(rt_str_index_of_from(s, sub, start));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Returns byte offset of LAST occurrence of `sub` within `s`, or -1.\n" +
            "// Mirrors interpreter `.rfind`/`.last_index_of` at self/hexa_full.hexa:15741.\n" +
            "// Added 2026-04-23 (hxa-20260422-002 lang_gap prio=95, rfind blocker).\n" +
            "// Step-3 cycle 55 port — int64_t-return bridge.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int64_t hexa_str_last_index_of(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n" +
            "    const char* hay = HX_STR(s);\n" +
            "    const char* needle = HX_STR(sub);\n" +
            "    size_t nlen = hxlcl_strlen(needle);\n" +
            "    size_t hlen = hxlcl_strlen(hay);\n" +
            "    if (nlen == 0) return (int64_t)hlen;\n" +
            "    if (nlen > hlen) return -1;\n" +
            "    int64_t last = -1;\n" +
            "    const char* p = hay;\n" +
            "    while ((p = hxlcl_strstr(p, needle)) != NULL) {\n" +
            "        last = (int64_t)(p - hay);\n" +
            "        p += 1;  // overlap-safe\n" +
            "    }\n" +
            "    return last;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_last_index_of(HexaVal s, HexaVal sub);\n" +
            "int64_t hexa_str_last_index_of(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n" +
            "    return HX_INT(rt_str_last_index_of(s, sub));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Byte-indexed single-char extraction. `.char_at(i)` → 1-byte string at\n" +
            "// offset i, empty string if out-of-range. Matches the byte-orientation\n" +
            "// of every other hexa_str_* helper (runtime has no UTF-8 codepoint iter\n" +
            "// — strings are treated as uninterpreted byte sequences, with the\n" +
            "// exception of UTF-8-safe display in hexa_println).\n" +
            "// Step-3 cycle 52 — char_at dispatches to rt_str_char_at (uses\n" +
            "// substring builtin, no recursion trap).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_char_at(HexaVal s, HexaVal idx) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    int64_t i = HX_INT(idx);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t _orig = i;\n" +
            "    // Python-style negative index — align interp `s[-1]` 지원 (`c` 반환).\n" +
            "    if (i < 0) i += n;\n" +
            "    if (i < 0 || i >= n) {\n" +
            "        // PROBE r12 #16: align with array OOB (throws cleanly at\n" +
            "        // hexa_array_get L2003).  String previously returned silent \"\"\n" +
            "        // which inverts the silent-failure-enforcement discipline.\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"string[%lld] out of bounds (len %lld)\", (long long)_orig, (long long)n);\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_str(\"\");\n" +
            "    }\n" +
            "    char buf[2] = { HX_STR(s)[i], '\\0' };\n" +
            "    return hexa_str(buf);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_char_at(HexaVal s, HexaVal idx);\n" +
            "HexaVal hexa_str_char_at(HexaVal s, HexaVal idx) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    return rt_str_char_at(s, idx);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Byte value at offset i (0..255), or -1 if out-of-range. JS-analog\n" +
            "// `.char_code_at` expects UTF-16 code units; we expose raw byte\n" +
            "// values since hexa strings are byte-sequenced. A later UTF-8\n" +
            "// codepoint API (`.code_point_at`) can layer on if needed.\n" +
            "// Step-3 cycle 52 NOTE — hexa_str_char_code_at is intentionally NOT\n" +
            "// ported. The chain `s.byte_at(i)` → hexa_str_byte_at(s, idx) →\n" +
            "// hexa_str_char_code_at(s, idx) (see line 4327) means any hexa-source\n" +
            "// rt_str_char_code_at body would infinite-recurse through the byte_at\n" +
            "// builtin. Stays C-only; the 4-line body has no real porting value.\n" +
            "HexaVal hexa_str_char_code_at(HexaVal s, HexaVal idx) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_int(-1);\n" +
            "    int64_t i = HX_INT(idx);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    if (i < 0) i += n;  // 음수 wraparound — char_at 과 align\n" +
            "    if (i < 0 || i >= n) return hexa_int(-1);\n" +
            "    return hexa_int((int64_t)(unsigned char)HX_STR(s)[i]);\n" +
            "}\n" +
            "\n" +
            "// ── UTF-8 char-aware string methods (parity-gate t45b: 2026-05-19) ──\n" +
            "// hexa strings are byte-sequenced UTF-8. `.char_at(i)` / `.byte_at(i)` /\n" +
            "// `.char_code_at(i)` are byte-indexed; the methods below are codepoint-\n" +
            "// indexed for true UTF-8 char-aware iteration (한글, emoji, etc.). The\n" +
            "// runtime was missing these (interp does the codepoint walking via\n" +
            "// tree-walker); deletion-gate requires the compiled path to match.\n" +
            "static int _hx_utf8_cp_len(unsigned char b) {\n" +
            "    if (b < 0x80) return 1;\n" +
            "    if ((b & 0xE0) == 0xC0) return 2;\n" +
            "    if ((b & 0xF0) == 0xE0) return 3;\n" +
            "    if ((b & 0xF8) == 0xF0) return 4;\n" +
            "    return 1;  // invalid lead byte — advance by 1 (don't infinite-loop)\n" +
            "}\n" +
            "\n" +
            "// Count UTF-8 codepoints. `\"한글hi\".char_count() == 4` etc.\n" +
            "// Step-3 cycle 52 — dispatches to rt_str_char_count (reuses\n" +
            "// rt_utf8_cpcount helper from cycle 51).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_char_count(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_int(0);\n" +
            "    const char* p = HX_STR(s);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t count = 0;\n" +
            "    int64_t i = 0;\n" +
            "    while (i < n) {\n" +
            "        i += _hx_utf8_cp_len((unsigned char)p[i]);\n" +
            "        count++;\n" +
            "    }\n" +
            "    return hexa_int(count);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_char_count(HexaVal s);\n" +
            "HexaVal hexa_str_char_count(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_int(0);\n" +
            "    return rt_str_char_count(s);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Codepoint-indexed nth char as a 1-codepoint string (1..4 bytes).\n" +
            "// Returns \"\" for negative or out-of-range n.\n" +
            "// Step-3 cycle 53 — dispatches to rt_str_nth_char (UTF-8 walker).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_nth_char(HexaVal s, HexaVal nv) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    int64_t target = HX_INT(nv);\n" +
            "    if (target < 0) return hexa_str(\"\");\n" +
            "    const char* p = HX_STR(s);\n" +
            "    int64_t sn = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t i = 0, k = 0;\n" +
            "    while (i < sn) {\n" +
            "        int cp = _hx_utf8_cp_len((unsigned char)p[i]);\n" +
            "        if (k == target) {\n" +
            "            char buf[5] = {0};\n" +
            "            int j = 0;\n" +
            "            while (j < cp && i + j < sn) { buf[j] = p[i + j]; j++; }\n" +
            "            buf[j] = 0;\n" +
            "            return hexa_str(buf);\n" +
            "        }\n" +
            "        i += cp;\n" +
            "        k++;\n" +
            "    }\n" +
            "    return hexa_str(\"\");  // OOB\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_nth_char(HexaVal s, HexaVal target);\n" +
            "HexaVal hexa_str_nth_char(HexaVal s, HexaVal nv) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    return rt_str_nth_char(s, nv);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Codepoint-indexed substring [start..end). `\"한글hi\".char_substring(0, 2) == \"한글\"`.\n" +
            "// Step-3 cycle 53 — dispatches to rt_str_char_substring (UTF-8 walker\n" +
            "// finds byte boundaries that correspond to the codepoint indices).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_char_substring(HexaVal s, HexaVal startv, HexaVal endv) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    int64_t cs = HX_INT(startv);\n" +
            "    int64_t ce = HX_INT(endv);\n" +
            "    if (cs < 0) cs = 0;\n" +
            "    if (ce <= cs) return hexa_str(\"\");\n" +
            "    const char* p = HX_STR(s);\n" +
            "    int64_t sn = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t i = 0, k = 0;\n" +
            "    int64_t bs = -1, be = sn;\n" +
            "    while (i < sn) {\n" +
            "        if (k == cs && bs < 0) bs = i;\n" +
            "        if (k == ce) { be = i; break; }\n" +
            "        i += _hx_utf8_cp_len((unsigned char)p[i]);\n" +
            "        k++;\n" +
            "    }\n" +
            "    if (bs < 0) return hexa_str(\"\");\n" +
            "    if (be > sn) be = sn;\n" +
            "    if (be <= bs) return hexa_str(\"\");\n" +
            "    int64_t len = be - bs;\n" +
            "    char* buf = (char*)malloc(len + 1);\n" +
            "    if (!buf) return hexa_str(\"\");\n" +
            "    int64_t j = 0;\n" +
            "    while (j < len) { buf[j] = p[bs + j]; j++; }\n" +
            "    buf[len] = 0;\n" +
            "    return hexa_str_own(buf);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_char_substring(HexaVal s, HexaVal cs, HexaVal ce);\n" +
            "HexaVal hexa_str_char_substring(HexaVal s, HexaVal startv, HexaVal endv) {\n" +
            "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n" +
            "    return rt_str_char_substring(s, startv, endv);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Byte at offset i (0..255). Throws on out-of-range — distinct from\n" +
            "// char_code_at's -1 sentinel: `.byte_at` is the raw-byte access surface\n" +
            "// and PROBE r15-D13 aligns it with array OOB (#467 \"string OOB throws\").\n" +
            "// Negative indices wrap (align with char_at); a wrapped-negative still\n" +
            "// out of range throws too. Error message matches the array OOB style.\n" +
            "HexaVal hexa_str_byte_at(HexaVal s, HexaVal idx) {\n" +
            "    if (!HX_IS_STR(s)) {\n" +
            "        hexa_throw(hexa_str(\"byte_at(): receiver is not a string\"));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    int64_t _orig = HX_INT(idx);\n" +
            "    int64_t n = (int64_t)HX_STRLEN(s);\n" +
            "    int64_t i = _orig;\n" +
            "    if (i < 0) i += n;  // 음수 wraparound — char_at/char_code_at 과 align\n" +
            "    if (i < 0 || i >= n) {\n" +
            "        char _buf[96];\n" +
            "        snprintf(_buf, sizeof(_buf),\n" +
            "                 \"byte_at index %lld out of bounds (len %lld)\",\n" +
            "                 (long long)_orig, (long long)n);\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    return hexa_int((int64_t)(unsigned char)HX_STR(s)[i]);\n" +
            "}\n" +
            "\n" +
            "// ── Array operations ─────────────────────────────────\n" +
            "// Step-3 cycle 74 port — in-place pop/shift using arr.truncate() and\n" +
            "// arr[i]=v hexa-source builtins. Empty/non-array guard stays C-side and\n" +
            "// throws (PROBE r14-UUUU-B1): empty pop previously returned hexa_void(),\n" +
            "// a silent miscompile (`[].pop() + 1` -> \"void1\" garbage). Now matches the\n" +
            "// sibling array.last()/array.get() contract — throw on empty/non-array.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_array_pop(HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"array.pop(): container is not an array (tag=%d)\", (int)HX_TAG(arr));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    if (HX_ARR_LEN(arr) == 0) {\n" +
            "        hexa_throw(hexa_str(\"array.pop(): empty array\"));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    HexaVal last = HX_ARR_ITEMS(arr)[n - 1];\n" +
            "    HX_SET_ARR_LEN(arr, n - 1);\n" +
            "    return last;\n" +
            "}\n" +
            "HexaVal hexa_array_shift(HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"array.shift(): container is not an array (tag=%d)\", (int)HX_TAG(arr));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    if (HX_ARR_LEN(arr) == 0) {\n" +
            "        hexa_throw(hexa_str(\"array.shift(): empty array\"));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    HexaVal first = HX_ARR_ITEMS(arr)[0];\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    for (int i = 0; i < n - 1; i++) {\n" +
            "        HX_ARR_ITEMS(arr)[i] = HX_ARR_ITEMS(arr)[i + 1];\n" +
            "    }\n" +
            "    HX_SET_ARR_LEN(arr, n - 1);\n" +
            "    return first;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_array_pop(HexaVal arr);\n" +
            "extern HexaVal rt_array_shift(HexaVal arr);\n" +
            "HexaVal hexa_array_pop(HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"array.pop(): container is not an array (tag=%d)\", (int)HX_TAG(arr));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    if (HX_ARR_LEN(arr) == 0) {\n" +
            "        hexa_throw(hexa_str(\"array.pop(): empty array\"));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    return rt_array_pop(arr);\n" +
            "}\n" +
            "HexaVal hexa_array_shift(HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) {\n" +
            "        char _buf[128];\n" +
            "        snprintf(_buf, sizeof(_buf), \"array.shift(): container is not an array (tag=%d)\", (int)HX_TAG(arr));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    if (HX_ARR_LEN(arr) == 0) {\n" +
            "        hexa_throw(hexa_str(\"array.shift(): empty array\"));\n" +
            "        return hexa_void();\n" +
            "    }\n" +
            "    return rt_array_shift(arr);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 25 port (float array fast-path).\n" +
            "HexaVal hexa_array_reverse(HexaVal arr) {\n" +
            "    if (HX_IS_STR(arr)) {\n" +
            "        const char* s = HX_STR(arr);\n" +
            "        size_t n = hxlcl_strlen(s);\n" +
            "        char* buf = (char*)malloc(n + 1);\n" +
            "        for (size_t i = 0; i < n; i++) buf[i] = s[n - 1 - i];\n" +
            "        buf[n] = '\\0';\n" +
            "        return hexa_str_own(buf);\n" +
            "    }\n" +
            "    if (!HX_IS_ARRAY(arr)) return arr;\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "    extern HexaVal rt_array_reverse_float(HexaVal arr);\n" +
            "    // Inline _arr_all_float (helper lives in runtime.c — declared static there)\n" +
            "    int all_float = 1;\n" +
            "    int64_t arr_n = HX_ARR_LEN(arr);\n" +
            "    for (int64_t i = 0; i < arr_n; i++) {\n" +
            "        if (!HX_IS_FLOAT(HX_ARR_ITEMS(arr)[i])) { all_float = 0; break; }\n" +
            "    }\n" +
            "    if (all_float) return rt_array_reverse_float(arr);\n" +
            "#endif\n" +
            "    HexaVal result = hexa_array_new();\n" +
            "    for (int i = HX_ARR_LEN(arr) - 1; i >= 0; i--)\n" +
            "        result = hexa_array_push(result, HX_ARR_ITEMS(arr)[i]);\n" +
            "    return result;\n" +
            "}\n" +
            "\n" +
            "// Generic value comparator used by hexa_array_sort + hexa_array_sort_by.\n" +
            "// 2026-05-14: added string lexicographic compare — prior version returned\n" +
            "// 0 for any non-numeric pair, causing `[\"c\",\"a\",\"b\"].sort() == [\"c\",\"a\",\"b\"]`\n" +
            "// (silent identity-sort). Filed at incoming/patches/stdlib-sort.md.\n" +
            "// Returns 0 for incomparable / cross-type pairs (caller treats as \"tie\" —\n" +
            "// stable sorts preserve insertion order on ties).\n" +
            "//\n" +
            "// PROBE r14-J (2026-05-23): canonical NaN-last total ordering. IEEE 754\n" +
            "// NaN compares return false for <, >, ==, so plain `da < db ? -1 : ...`\n" +
            "// returns 0 for every (NaN, x) pair → qsort sees an indeterminate\n" +
            "// ordering → undefined behavior (NaN scattered through output, sometimes\n" +
            "// dropping non-NaN values past it). Canonical fixes:\n" +
            "//   - Rust f64::total_cmp: NaN goes after +inf (NaN-last for +NaN)\n" +
            "//   - Python numpy.sort: NaN-last by default\n" +
            "//   - Python builtin list.sort: would TypeError, but we don't have that\n" +
            "//     channel cheaply available here.\n" +
            "// We pick NaN-last (Rust / numpy default). Both NaN → tie (stable sorts\n" +
            "// preserve insertion order).\n" +
            "static int hexa_sort_cmp(const void* a, const void* b) {\n" +
            "    HexaVal va = *(const HexaVal*)a, vb = *(const HexaVal*)b;\n" +
            "    if (HX_IS_INT(va) && HX_IS_INT(vb)) return HX_INT(va) < HX_INT(vb) ? -1 : HX_INT(va) > HX_INT(vb) ? 1 : 0;\n" +
            "    if (HX_IS_FLOAT(va) && HX_IS_FLOAT(vb)) {\n" +
            "        double da = HX_FLOAT(va), db = HX_FLOAT(vb);\n" +
            "        int na = isnan(da), nb = isnan(db);\n" +
            "        if (na && nb) return 0;\n" +
            "        if (na) return 1;       // NaN sorts AFTER everything (NaN-last)\n" +
            "        if (nb) return -1;\n" +
            "        return da < db ? -1 : da > db ? 1 : 0;\n" +
            "    }\n" +
            "    if (HX_IS_STR(va) && HX_IS_STR(vb)) {\n" +
            "        int r = hxlcl_strcmp(HX_STR(va), HX_STR(vb));\n" +
            "        return r < 0 ? -1 : r > 0 ? 1 : 0;\n" +
            "    }\n" +
            "    // mixed-numeric (int vs float): promote to float for the compare\n" +
            "    if ((HX_IS_INT(va) || HX_IS_FLOAT(va)) && (HX_IS_INT(vb) || HX_IS_FLOAT(vb))) {\n" +
            "        double da = HX_IS_INT(va) ? (double)HX_INT(va) : HX_FLOAT(va);\n" +
            "        double db = HX_IS_INT(vb) ? (double)HX_INT(vb) : HX_FLOAT(vb);\n" +
            "        int na = isnan(da), nb = isnan(db);\n" +
            "        if (na && nb) return 0;\n" +
            "        if (na) return 1;       // NaN-last (consistent with float/float path)\n" +
            "        if (nb) return -1;\n" +
            "        return da < db ? -1 : da > db ? 1 : 0;\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "// Step-3 cycle 59 port — float fast-path dispatches to insertion-sort\n" +
            "// hexa source. Mixed-type arrays still need hexa_sort_cmp polymorphism\n" +
            "// and stay on the qsort path.\n" +
            "HexaVal hexa_array_sort(HexaVal arr) {\n" +
            "    // Previously `result = arr` copied the HexaVal struct — but both still\n" +
            "    // alias array_store[arr.int_val]. `HX_SET_ARR_ITEMS(result, malloc(...))`\n" +
            "    // therefore also replaced arr's items pointer → the following\n" +
            "    // `memcpy(HX_ARR_ITEMS(result), HX_ARR_ITEMS(arr), ...)` memcpy'd the\n" +
            "    // brand-new empty buf onto itself. qsort'd that garbage → caller saw\n" +
            "    // [0,0,0]. **Both** `r` and original `arr` came out zeroed.\n" +
            "    // Fix: build a fresh result via hexa_array_new + push (mirrors\n" +
            "    // hexa_array_reverse), then qsort the fresh buffer.\n" +
            "    if (!HX_IS_ARRAY(arr)) return arr;\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "    extern HexaVal rt_array_sort_float(HexaVal arr);\n" +
            "    int all_float = 1;\n" +
            "    int64_t arr_n = HX_ARR_LEN(arr);\n" +
            "    for (int64_t i = 0; i < arr_n; i++) {\n" +
            "        if (!HX_IS_FLOAT(HX_ARR_ITEMS(arr)[i])) { all_float = 0; break; }\n" +
            "    }\n" +
            "    if (all_float) return rt_array_sort_float(arr);\n" +
            "#endif\n" +
            "    HexaVal result = hexa_array_new();\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    for (int i = 0; i < n; i++) {\n" +
            "        result = hexa_array_push(result, HX_ARR_ITEMS(arr)[i]);\n" +
            "    }\n" +
            "    qsort(HX_ARR_ITEMS(result), HX_ARR_LEN(result), sizeof(HexaVal), hexa_sort_cmp);\n" +
            "    return result;\n" +
            "}\n" +
            "\n" +
            "// Stable sort by precomputed keys. Closure invoked once per element via\n" +
            "// hexa_call1 to derive the sort key; bottom-up iterative merge sort over a\n" +
            "// parallel (item, key) buffer. Stability matters for downstream callers\n" +
            "// (e.g. wilson event_bus priority ordering). Comparator is hexa_sort_cmp\n" +
            "// (which handles int/float/string after 2026-05-14; mixed types tie).\n" +
            "// Filed at incoming/patches/stdlib-sort.md.\n" +
            "HexaVal hexa_array_sort_by(HexaVal arr, HexaVal key_fn) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return hexa_array_new();\n" +
            "    int n = HX_ARR_LEN(arr);\n" +
            "    HexaVal result = hexa_array_new();\n" +
            "    for (int i = 0; i < n; i++) {\n" +
            "        result = hexa_array_push(result, HX_ARR_ITEMS(arr)[i]);\n" +
            "    }\n" +
            "    if (n < 2) return result;\n" +
            "\n" +
            "    HexaVal* items = HX_ARR_ITEMS(result);\n" +
            "    HexaVal* keys = (HexaVal*)malloc(sizeof(HexaVal) * n);\n" +
            "    for (int i = 0; i < n; i++) keys[i] = hexa_call1(key_fn, items[i]);\n" +
            "\n" +
            "    HexaVal* tmp_items = (HexaVal*)malloc(sizeof(HexaVal) * n);\n" +
            "    HexaVal* tmp_keys  = (HexaVal*)malloc(sizeof(HexaVal) * n);\n" +
            "\n" +
            "    for (int width = 1; width < n; width *= 2) {\n" +
            "        for (int start = 0; start < n; start += 2 * width) {\n" +
            "            int left  = start;\n" +
            "            int mid   = start + width;       if (mid   > n) mid   = n;\n" +
            "            int right = start + 2 * width;   if (right > n) right = n;\n" +
            "            int li = left, ri = mid, ki = left;\n" +
            "            while (li < mid && ri < right) {\n" +
            "                // stable: take right side only when strictly less; ties → left first\n" +
            "                if (hexa_sort_cmp(&keys[ri], &keys[li]) < 0) {\n" +
            "                    tmp_items[ki] = items[ri]; tmp_keys[ki] = keys[ri]; ri++;\n" +
            "                } else {\n" +
            "                    tmp_items[ki] = items[li]; tmp_keys[ki] = keys[li]; li++;\n" +
            "                }\n" +
            "                ki++;\n" +
            "            }\n" +
            "            while (li < mid)   { tmp_items[ki] = items[li]; tmp_keys[ki] = keys[li]; li++; ki++; }\n" +
            "            while (ri < right) { tmp_items[ki] = items[ri]; tmp_keys[ki] = keys[ri]; ri++; ki++; }\n" +
            "            for (int j = left; j < right; j++) {\n" +
            "                items[j] = tmp_items[j];\n" +
            "                keys[j]  = tmp_keys[j];\n" +
            "            }\n" +
            "        }\n" +
            "    }\n" +
            "\n" +
            "    free(tmp_items); free(tmp_keys); free(keys);\n" +
            "    return result;\n" +
            "}\n" +
            "\n" +
            "// ── Exec ────────────────────────────────────────────\n" +
            "// TL;DR #2 (2026-05-06): posix_spawnp fast path for shell-free exec().\n" +
            "// popen() forks a /bin/sh child which then exec's the actual command —\n" +
            "// 2 fork+exec hops, plus shell startup time (~5–15 ms on macOS), even when\n" +
            "// the command has no shell-meta chars. posix_spawnp() skips the shell hop\n" +
            "// entirely (single fork+exec via the kernel's spawn syscall on macOS, or\n" +
            "// vfork+execvp emulation on Linux glibc).\n" +
            "//\n" +
            "// Opt-in via env HEXA_EXEC_NO_SHELL=1. When set AND the command contains\n" +
            "// no shell-meta characters (|&;<>*?$()`\\\\\"' newline tab ~{}[]#=) we tokenize\n" +
            "// on whitespace and posix_spawnp the argv directly, returning a FILE* wired\n" +
            "// to the child's stdout via pipe2/dup2. When unset, or shell-meta present,\n" +
            "// we fall through to popen() — preserving every existing behavior.\n" +
            "//\n" +
            "// Returns the child PID on success (caller must waitpid to reap), 0 on\n" +
            "// fallback/skip. The fp out-param receives a FILE* the caller reads as if\n" +
            "// from popen, freed with fclose() (NOT pclose — the child is reaped via\n" +
            "// waitpid by the caller using the returned pid).\n" +
            "static int hexa_exec_no_shell_enabled(void) {\n" +
            "    static int cached = -1;\n" +
            "    if (cached < 0) {\n" +
            "        const char* v = hxlcl_getenv(\"HEXA_EXEC_NO_SHELL\");\n" +
            "        cached = (v && v[0] == '1' && v[1] == '\\0') ? 1 : 0;\n" +
            "    }\n" +
            "    return cached;\n" +
            "}\n" +
            "\n" +
            "// Returns 1 if cmd contains a shell-meta character that requires sh -c\n" +
            "// interpretation. Conservative: any of these forces popen fallback.\n" +
            "// Quote chars (' \" `) are included because we tokenize on whitespace only —\n" +
            "// a quoted arg with spaces would split incorrectly without shell parsing.\n" +
            "static int hexa_cmd_has_shell_meta(const char* s) {\n" +
            "    if (!s) return 1;\n" +
            "    for (const char* p = s; *p; p++) {\n" +
            "        switch (*p) {\n" +
            "            case '|': case '&': case ';': case '<': case '>':\n" +
            "            case '*': case '?': case '$': case '(': case ')':\n" +
            "            case '`': case '\\\\': case '\"': case '\\'':\n" +
            "            case '\\n': case '\\t': case '~': case '{': case '}':\n" +
            "            case '[': case ']': case '#': case '=':\n" +
            "                return 1;\n" +
            "        }\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "// Tokenize cmd on ASCII whitespace into a freshly malloc'd argv (NULL-\n" +
            "// terminated). Caller owns argv + argv[0]; argv[i] for i>0 are interior\n" +
            "// pointers into the malloc'd argv[0] buffer (we replace whitespace with\n" +
            "// '\\0' in-place). Free via: free(argv[0]); free(argv);\n" +
            "static char** hexa_tokenize_argv(const char* cmd, int* out_argc) {\n" +
            "    *out_argc = 0;\n" +
            "    if (!cmd) return NULL;\n" +
            "    size_t len = hxlcl_strlen(cmd);\n" +
            "    char* buf = (char*)malloc(len + 1);\n" +
            "    if (!buf) return NULL;\n" +
            "    hxlcl_memcpy(buf, cmd, len + 1);\n" +
            "    int argc = 0;\n" +
            "    int in_tok = 0;\n" +
            "    for (size_t i = 0; i < len; i++) {\n" +
            "        unsigned char c = (unsigned char)buf[i];\n" +
            "        int is_ws = (c == ' ' || c == '\\t');\n" +
            "        if (!is_ws && !in_tok) { argc++; in_tok = 1; }\n" +
            "        else if (is_ws) in_tok = 0;\n" +
            "    }\n" +
            "    if (argc == 0) { free(buf); return NULL; }\n" +
            "    char** argv = (char**)malloc(sizeof(char*) * (argc + 1));\n" +
            "    if (!argv) { free(buf); return NULL; }\n" +
            "    int idx = 0;\n" +
            "    in_tok = 0;\n" +
            "    for (size_t i = 0; i < len; i++) {\n" +
            "        unsigned char c = (unsigned char)buf[i];\n" +
            "        int is_ws = (c == ' ' || c == '\\t');\n" +
            "        if (!is_ws && !in_tok) { argv[idx++] = buf + i; in_tok = 1; }\n" +
            "        else if (is_ws && in_tok) { buf[i] = '\\0'; in_tok = 0; }\n" +
            "    }\n" +
            "    argv[argc] = NULL;\n" +
            "    *out_argc = argc;\n" +
            "    return argv;\n" +
            "}\n" +
            "\n" +
            "// Spawn child reading cmd's stdout into a returned FILE*. Returns 0 (no\n" +
            "// FILE* set) when the env flag is off, the cmd has shell-meta, or any\n" +
            "// spawn step fails — caller must fall back to popen() in those cases.\n" +
            "// On success returns child pid (>0) and *out_fp = fdopen(read_end, \"r\").\n" +
            "static pid_t hexa_spawn_no_shell(const char* cmd, FILE** out_fp) {\n" +
            "    *out_fp = NULL;\n" +
            "    if (!hexa_exec_no_shell_enabled()) return 0;\n" +
            "    if (!cmd || hexa_cmd_has_shell_meta(cmd)) return 0;\n" +
            "    int argc = 0;\n" +
            "    char** argv = hexa_tokenize_argv(cmd, &argc);\n" +
            "    if (!argv || argc == 0) { if (argv) { free(argv[0]); free(argv); } return 0; }\n" +
            "\n" +
            "    int pipefd[2];\n" +
            "    if (hxlcl_pipe(pipefd) != 0) { free(argv[0]); free(argv); return 0; }\n" +
            "\n" +
            "    // RUNTIME net/exec ⑦ (cycle 81): replace posix_spawnp + the 4\n" +
            "    // posix_spawn_file_actions_* libc orchestrators with the proven\n" +
            "    // fork+dup2+execvp primitives (all svc-trapped). Drops 5 libc externs;\n" +
            "    // the no-shell behavior is preserved (execvp does the 'p' PATH search,\n" +
            "    // matching posix_spawnp). Mirrors the hxlcl_popen child pattern.\n" +
            "    pid_t pid = hxlcl_fork();\n" +
            "    if (pid < 0) {\n" +
            "        hxlcl_close(pipefd[0]); hxlcl_close(pipefd[1]);\n" +
            "        free(argv[0]); free(argv); return 0;\n" +
            "    }\n" +
            "    if (pid == 0) {\n" +
            "        // child: wire pipe write-end to stdout, exec argv via PATH search\n" +
            "        hxlcl_dup2(pipefd[1], STDOUT_FILENO);\n" +
            "        hxlcl_close(pipefd[0]);\n" +
            "        hxlcl_close(pipefd[1]);\n" +
            "        hxlcl_execvp(argv[0], argv);\n" +
            "        _exit(127); // exec failed\n" +
            "    }\n" +
            "    // parent\n" +
            "    free(argv[0]); free(argv);\n" +
            "    hxlcl_close(pipefd[1]);\n" +
            "    FILE* fp = fdopen(pipefd[0], \"r\");\n" +
            "    if (!fp) { hxlcl_close(pipefd[0]); return 0; }\n" +
            "    *out_fp = fp;\n" +
            "    return pid;\n" +
            "}\n" +
            "\n" +
            "// Reap a posix_spawn'd child and translate to popen-style status int\n" +
            "// (matching pclose's encoding so existing WIFEXITED/WEXITSTATUS code works).\n" +
            "static int hexa_spawn_reap(pid_t pid) {\n" +
            "    if (pid <= 0) return -1;\n" +
            "    int status = 0;\n" +
            "    while (hxlcl_waitpid(pid, &status, 0) < 0) {\n" +
            "        if (errno == EINTR) continue;\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return status;\n" +
            "}\n" +
            "\n" +
            "// 2026-04-26 cross-repo upstream (hive→hexa-lang): switched the read primitive\n" +
            "// from fgets()+strlen(buf) to fread(). Old loop computed chunk length via\n" +
            "// strlen() on the buffer fgets() filled — when the child wrote an embedded\n" +
            "// NUL byte (e.g. `git log --format=...%x00` for record boundaries),\n" +
            "// strlen(buf) returned 0 for that chunk's tail and every byte from the NUL\n" +
            "// onward inside that 4 KiB read window was silently dropped. The new loop\n" +
            "// uses fread() which reports the actual byte count, so the captured buffer\n" +
            "// faithfully retains every byte including embedded NULs.\n" +
            "//\n" +
            "// Caveat (string ABI): HexaVal strings are stored as a bare `char*` (see the\n" +
            "// HX_STR macro) and most downstream consumers (hexa_len → strlen, the intern\n" +
            "// table, str_eq → strcmp) still treat them as C-NUL-terminated. Hexa-source\n" +
            "// code that calls len() / == on the captured string still sees the C-string\n" +
            "// view (i.e. truncation at the first NUL). Callers that need full byte-level\n" +
            "// access to popen output with embedded NULs should use a byte-array variant\n" +
            "// modeled after rt_read_file_bytes (planned: `exec_bytes`). This fix is the\n" +
            "// read-loop slice of the problem — the buffer itself is now correct end-to-\n" +
            "// end, removing the runtime-layer truncation cliff.\n" +
            "HexaVal hexa_exec(HexaVal cmd) {\n" +
            "    if (!HX_IS_STR(cmd)) return hexa_str(\"\");\n" +
            "    // 2026-05-06 — POSIX 정합: fork() 전 부모 buffer flush 강제. popen()는\n" +
            "    // fork+exec 호출 — 부모의 stdio buffer가 자식에게 inherit. 자식 sh가\n" +
            "    // read </dev/tty 같은 syscall 대기시 부모 stderr/stdout buffer가\n" +
            "    // flush 안 되면 사용자에게 prompt 안 보임. setup_2fa.hexa 대화형 prompt\n" +
            "    // 무반응 case 진단됨 (T4 probe).\n" +
            "    fflush(NULL);\n" +
            "    // TL;DR #2 fast path: posix_spawnp when env enabled + shell-meta-free.\n" +
            "    FILE* spawn_fp = NULL;\n" +
            "    pid_t spawn_pid = hexa_spawn_no_shell(HX_STR(cmd), &spawn_fp);\n" +
            "    FILE* fp;\n" +
            "    if (spawn_pid > 0) {\n" +
            "        fp = spawn_fp;\n" +
            "    } else {\n" +
            "        fp = hxlcl_popen(HX_STR(cmd), \"r\");\n" +
            "        if (!fp) return hexa_str(\"\");\n" +
            "    }\n" +
            "    hexa_pipe_buf_enlarge_kernel(fp);  // TL;DR #4: F_SETPIPE_SZ Linux only (fread bulk drain)\n" +
            "    char buf[4096]; size_t total = 0;\n" +
            "    size_t cap = 4096;\n" +
            "    char* result = (char*)malloc(cap); result[0] = '\\0';\n" +
            "    size_t n;\n" +
            "    while ((n = fread(buf, 1, sizeof(buf), fp)) > 0) {\n" +
            "        // +1 for the trailing NUL we always append so HX_STR() remains a\n" +
            "        // valid C-string for ABI consumers (see caveat above).\n" +
            "        while (total + n + 1 > cap) { cap *= 2; result = (char*)realloc(result, cap); }\n" +
            "        hxlcl_memcpy(result + total, buf, n);\n" +
            "        total += n;\n" +
            "    }\n" +
            "    result[total] = '\\0';\n" +
            "    if (spawn_pid > 0) { fclose(fp); hexa_spawn_reap(spawn_pid); }\n" +
            "    else               { hxlcl_pclose(fp); }\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "\n" +
            "// hexa_exec_stream — like hexa_exec, but invokes `on_line(line)` for each\n" +
            "// stdout line as it is read instead of buffering the entire output. Returns\n" +
            "// the child's exit code (same convention as hexa_exec_with_status[1]: 0..255\n" +
            "// for normal exit, 128+sig for signal, -1 for unknown).\n" +
            "//\n" +
            "// Rationale (2026-04-25): hexa_exec / hexa_exec_with_status both popen() the\n" +
            "// command and only return after pclose(). For long-running build/test\n" +
            "// commands that emit progress on stdout (npm test, cargo build, hexa-lang's\n" +
            "// own dispatch self-compile) the agent layer sees zero output until the child\n" +
            "// exits, which surfaces to the user as a multi-minute silent stall. Adding\n" +
            "// streaming lets the calling hexa code emit progress in real time without\n" +
            "// the runtime buffering multi-megabyte transcripts.\n" +
            "//\n" +
            "// Each line passed to the callback retains its trailing newline (as fgets\n" +
            "// returns it), except the final partial line if the child exited mid-line.\n" +
            "// Callback is invoked inline on the hexa runtime stack via hexa_call1 — the\n" +
            "// caller's hexa function executes synchronously between fgets() iterations.\n" +
            "HexaVal hexa_exec_stream_impl(HexaVal cmd, HexaVal on_line) {\n" +
            "    if (!HX_IS_STR(cmd)) return hexa_int(127);\n" +
            "    if (!HX_IS_FN(on_line) && !HX_IS_CLOSURE(on_line)) return hexa_int(127);\n" +
            "    // 2026-05-06 — POSIX fork buffer flush (mirror hexa_exec)\n" +
            "    fflush(NULL);\n" +
            "    // TL;DR #2 fast path: posix_spawnp when env enabled + shell-meta-free.\n" +
            "    FILE* spawn_fp = NULL;\n" +
            "    pid_t spawn_pid = hexa_spawn_no_shell(HX_STR(cmd), &spawn_fp);\n" +
            "    FILE* fp;\n" +
            "    if (spawn_pid > 0) {\n" +
            "        fp = spawn_fp;\n" +
            "    } else {\n" +
            "        fp = hxlcl_popen(HX_STR(cmd), \"r\");\n" +
            "        if (!fp) return hexa_int(127);\n" +
            "    }\n" +
            "    hexa_pipe_buf_enlarge_full(fp);  // TL;DR #4: F_SETPIPE_SZ Linux + setvbuf 256K (fgets streaming)\n" +
            "    char buf[4096];\n" +
            "    while (fgets(buf, sizeof(buf), fp)) {\n" +
            "        // Construct a fresh hexa string per line (the buffer is reused).\n" +
            "        // hexa_str() copies, so this is safe across iterations.\n" +
            "        hexa_call1(on_line, hexa_str(buf));\n" +
            "    }\n" +
            "    int rc;\n" +
            "    if (spawn_pid > 0) { fclose(fp); rc = hexa_spawn_reap(spawn_pid); }\n" +
            "    else               { rc = hxlcl_pclose(fp); }\n" +
            "    int exit_code;\n" +
            "    if (WIFEXITED(rc))      exit_code = WEXITSTATUS(rc);\n" +
            "    else if (WIFSIGNALED(rc)) exit_code = 128 + WTERMSIG(rc);\n" +
            "    else                     exit_code = -1;\n" +
            "    return hexa_int(exit_code);\n" +
            "}\n" +
            "\n" +
            "// Forward decl + auto-wrap macro shim. The current hexat codegen emits\n" +
            "// `hexa_exec_stream(cmd, ident)` where `ident` is a raw C function symbol\n" +
            "// (e.g. `on_line`) rather than a HexaVal. To bridge that without rebuilding\n" +
            "// hexat, we redirect the user-visible call through a wrapping macro that\n" +
            "// invokes hexa_exec_stream_impl with a freshly-constructed TAG_FN HexaVal.\n" +
            "// After a dispatch self-rebuild activates the codegen lowering with proper\n" +
            "// gen2_expr wrapping, this macro becomes a no-op (the second arg will\n" +
            "// already be a HexaVal — _Generic could choose impl directly, but the\n" +
            "// double-wrap path remains safe for HexaVal too via a passthrough).\n" +
            "//\n" +
            "// We keep both names: hexa_exec_stream (callable from hexa) and\n" +
            "// hexa_exec_stream_impl (the actual C function). The macro picks based on\n" +
            "// whether the second argument is a function pointer or a HexaVal.\n" +
            "extern HexaVal hexa_exec_stream_impl(HexaVal cmd, HexaVal on_line);\n" +
            "extern HexaVal hexa_fn_new(void* fp, int arity);\n" +
            "static inline HexaVal __hexa_exec_stream_wrap_fp(HexaVal cmd, HexaVal (*fp)(HexaVal)) {\n" +
            "    return hexa_exec_stream_impl(cmd, hexa_fn_new((void*)fp, 1));\n" +
            "}\n" +
            "static inline HexaVal __hexa_exec_stream_wrap_hv(HexaVal cmd, HexaVal cb) {\n" +
            "    return hexa_exec_stream_impl(cmd, cb);\n" +
            "}\n" +
            "// _Generic dispatch — selects the function-pointer wrapper for raw symbols\n" +
            "// or the HexaVal passthrough when the lowering path supplies a value.\n" +
            "#define hexa_exec_stream(cmd, cb) _Generic((cb), \\\n" +
            "    HexaVal: __hexa_exec_stream_wrap_hv, \\\n" +
            "    default: __hexa_exec_stream_wrap_fp)((cmd), (cb))\n" +
            "\n" +
            "// hexa_exec_with_status: like hexa_exec but returns [stdout_str, exit_code].\n" +
            "// 2026-04-17: needed because the interpreter's exec_with_status dispatch in\n" +
            "// hexa_full.hexa silently always returns exit=0 (popen output without\n" +
            "// pclose status), letting build scripts roll forward stale binaries through\n" +
            "// failed clang/cargo invocations. Codegen + dispatch wiring TBD — this\n" +
            "// function is the C-runtime backstop ready when the interpreter learns to\n" +
            "// call it via codegen lowering of `exec_with_status(cmd)`.\n" +
            "//\n" +
            "// 2026-05-23 (PROBE r8): the 2-tuple shape is canonically-deviant. Rust\n" +
            "// `Output{stdout, stderr, status}`, Go `Cmd.Output()` separate `.Stderr`,\n" +
            "// Python `CompletedProcess.{stdout, stderr, returncode}` — every comparable\n" +
            "// runtime exposes stderr as its own field. popen(\"r\") here merges stderr\n" +
            "// into stdout only when the caller appends `2>&1`, which loses the channel\n" +
            "// distinction. The CANONICAL 3-tuple path already exists in this repo as\n" +
            "// `hexa_exec_capture(cmd)` (runtime.c:9991, returns [stdout, stderr, exit_code]\n" +
            "// via pipe/fork/select — same multiplexed drain pattern as PR #423). New\n" +
            "// code should call `exec_capture()` directly; `exec_with_status()` is kept\n" +
            "// for backward compatibility with ~150 existing callers (caller migration =\n" +
            "// separate stacked PR, see inbox/patches/exec-with-status-3tuple-migration.md).\n" +
            "HexaVal hexa_exec_with_status(HexaVal cmd) {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (!HX_IS_STR(cmd)) {\n" +
            "        arr = hexa_array_push(arr, hexa_str(\"\"));\n" +
            "        arr = hexa_array_push(arr, hexa_int(127));\n" +
            "        return arr;\n" +
            "    }\n" +
            "    // 2026-05-06 — POSIX fork buffer flush (mirror hexa_exec / hexa_exec_stream_impl)\n" +
            "    fflush(NULL);\n" +
            "    // TL;DR #2 fast path: posix_spawnp when env enabled + shell-meta-free.\n" +
            "    FILE* spawn_fp = NULL;\n" +
            "    pid_t spawn_pid = hexa_spawn_no_shell(HX_STR(cmd), &spawn_fp);\n" +
            "    FILE* fp;\n" +
            "    if (spawn_pid > 0) {\n" +
            "        fp = spawn_fp;\n" +
            "    } else {\n" +
            "        fp = hxlcl_popen(HX_STR(cmd), \"r\");\n" +
            "        if (!fp) {\n" +
            "            arr = hexa_array_push(arr, hexa_str(\"\"));\n" +
            "            arr = hexa_array_push(arr, hexa_int(127));\n" +
            "            return arr;\n" +
            "        }\n" +
            "    }\n" +
            "    hexa_pipe_buf_enlarge_kernel(fp);  // TL;DR #4: F_SETPIPE_SZ Linux only (fread bulk drain)\n" +
            "    // 2026-04-26 cross-repo upstream: same fgets→fread switch as hexa_exec\n" +
            "    // above (see that function's comment for the embedded-NUL truncation\n" +
            "    // root cause and the residual string-ABI caveat).\n" +
            "    char buf[4096]; size_t total = 0;\n" +
            "    size_t cap = 4096;\n" +
            "    char* result = (char*)malloc(cap); result[0] = '\\0';\n" +
            "    size_t n;\n" +
            "    while ((n = fread(buf, 1, sizeof(buf), fp)) > 0) {\n" +
            "        while (total + n + 1 > cap) { cap *= 2; result = (char*)realloc(result, cap); }\n" +
            "        hxlcl_memcpy(result + total, buf, n);\n" +
            "        total += n;\n" +
            "    }\n" +
            "    result[total] = '\\0';\n" +
            "    int rc;\n" +
            "    if (spawn_pid > 0) { fclose(fp); rc = hexa_spawn_reap(spawn_pid); }\n" +
            "    else               { rc = hxlcl_pclose(fp); }\n" +
            "    int exit_code;\n" +
            "    if (WIFEXITED(rc))      exit_code = WEXITSTATUS(rc);\n" +
            "    else if (WIFSIGNALED(rc)) exit_code = 128 + WTERMSIG(rc);\n" +
            "    else                     exit_code = -1;\n" +
            "    arr = hexa_array_push(arr, hexa_str_own(result));\n" +
            "    arr = hexa_array_push(arr, hexa_int(exit_code));\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// exec_replace — replace current process via execvp(\"/bin/sh\", \"-c\", cmd).\n" +
            "// Does not return on success. Used by `hexa lsp` to hand stdin/stdout fully\n" +
            "// to the interp interpreter so bidirectional streaming (JSON-RPC) works\n" +
            "// without popen buffering or the __HEXA_RC sentinel interleaving into the\n" +
            "// response body. On failure, returns empty string and the caller falls\n" +
            "// back to regular hexa_exec().\n" +
            "HexaVal hexa_exec_replace(HexaVal cmd) {\n" +
            "    if (!HX_IS_STR(cmd)) return hexa_str(\"\");\n" +
            "    // fflush to avoid duplicated stdio buffers in the replacement.\n" +
            "    fflush(stdout); fflush(stderr);\n" +
            "    char* argv[4];\n" +
            "    argv[0] = (char*)\"/bin/sh\";\n" +
            "    argv[1] = (char*)\"-c\";\n" +
            "    argv[2] = HX_STR(cmd);\n" +
            "    argv[3] = NULL;\n" +
            "    hxlcl_execvp(argv[0], argv);\n" +
            "    // execvp returned → failure; surface errno and fall through.\n" +
            "    perror(\"exec_replace\");\n" +
            "    return hexa_str(\"\");\n" +
            "}\n" +
            "\n" +
            "// 2026-05-20 (blocker-4 print-precision): opt-in higher-precision float\n" +
            "// formatter for human-readable `print`/`println`/`eprint`/`eprintln`. Default\n" +
            "// stays at \"%g\" (6 significant digits) — round-trip-loss but matches existing\n" +
            "// snapshots / golden outputs. Set HEXA_FLOAT_REPR=g17 to switch to \"%.17g\"\n" +
            "// (IEEE-754 double round-trip-safe). Cached static so the getenv() call\n" +
            "// happens once per process.\n" +
            "static const char* __hexa_print_float_fmt(void) {\n" +
            "    static int cached = 0;\n" +
            "    static const char* fmt = \"%g\";\n" +
            "    if (!cached) {\n" +
            "        const char* env = hxlcl_getenv(\"HEXA_FLOAT_REPR\");\n" +
            "        if (env) {\n" +
            "            if (hxlcl_strcmp(env, \"g17\") == 0) fmt = \"%.17g\";\n" +
            "            else if (hxlcl_strcmp(env, \"g15\") == 0) fmt = \"%.15g\";\n" +
            "            // unknown values fall back to \"%g\" (silent) — strict mode could\n" +
            "            // surface a stderr warning here, but print-path is hot so keep\n" +
            "            // the fast default.\n" +
            "        }\n" +
            "        cached = 1;\n" +
            "    }\n" +
            "    return fmt;\n" +
            "}\n" +
            "\n" +
            "// PROBE r14-E (2026-05-23): canonical Rust-style casing for special floats.\n" +
            "// glibc/macOS libc render NaN/inf in lowercase via \"%g\" (\"nan\"/\"inf\"); align\n" +
            "// with the g1 canonical-first policy (Rust: \"NaN\", \"inf\", \"-inf\"). Returns\n" +
            "// a static string or NULL when `f` is finite. Used by both the print-path\n" +
            "// and to_string-path so println/to_string/eprintln stay consistent.\n" +
            "static const char* __hexa_float_special_repr(double f) {\n" +
            "    if (isnan(f)) return \"NaN\";\n" +
            "    if (isinf(f)) return f < 0.0 ? \"-inf\" : \"inf\";\n" +
            "    return NULL;\n" +
            "}\n" +
            "\n" +
            "// PROBE r14-L (2026-05-23): unify print_val / eprint_val / eprintln / eprint\n" +
            "// float-rendering with hexa_to_string so `println(0.0)` matches\n" +
            "// `to_string(0.0)` (\"0.0\", not \"0\") and NaN/inf carry the canonical Rust\n" +
            "// casing.  Policy mirrors _hexa_to_string_rec TAG_FLOAT (line ~5731):\n" +
            "//   1. NaN/inf            → __hexa_float_special_repr (\"NaN\"/\"inf\"/\"-inf\")\n" +
            "//   2. integer-valued finite float in [-1e15, 1e15] → \"%.1f\"  (0.0 → \"0.0\")\n" +
            "//   3. otherwise          → __hexa_print_float_fmt() (env-honoring %g)\n" +
            "// Writes a NUL-terminated repr into `buf` (caller owns at least 32 bytes).\n" +
            "static void __hexa_format_float_for_print(double f, char* buf, size_t cap) {\n" +
            "    const char* sp = __hexa_float_special_repr(f);\n" +
            "    if (sp) { snprintf(buf, cap, \"%s\", sp); return; }\n" +
            "    if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n" +
            "        snprintf(buf, cap, \"%.1f\", f);\n" +
            "    } else {\n" +
            "        snprintf(buf, cap, __hexa_print_float_fmt(), f);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ── Stderr ──────────────────────────────────────────\n" +
            "void hexa_eprint_val(HexaVal v) {\n" +
            "    // 2026-04-20 silent-fallback fix: prior body dropped TAG_VOID /\n" +
            "    // TAG_ARRAY / TAG_MAP / TAG_VALSTRUCT entirely (no output, not even\n" +
            "    // \"<value>\"). User-visible path is eprintln(arr) / eprintln(map) —\n" +
            "    // emitting nothing is strictly worse than the hexa_to_string repr.\n" +
            "    // One-hop TAG_VALSTRUCT unwrap mirrors hexa_print_val.\n" +
            "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n" +
            "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n" +
            "    char __fbuf[64];\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        HexaValStruct* vs = HX_VS(v);\n" +
            "        switch (vs->tag_i) {\n" +
            "            case TAG_INT:   fprintf(stderr, \"%lld\", (long long)vs->int_val); return;\n" +
            "            case TAG_FLOAT:\n" +
            "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n" +
            "                fprintf(stderr, \"%s\", __fbuf); return;\n" +
            "            case TAG_BOOL:  fprintf(stderr, \"%s\", vs->bool_val ? \"true\" : \"false\"); return;\n" +
            "            case TAG_STR: {\n" +
            "                const char* cs = HX_STR(vs->str_val);\n" +
            "                if (cs) { fprintf(stderr, \"%s\", cs); return; }\n" +
            "                break;\n" +
            "            }\n" +
            "            case TAG_VOID:  fprintf(stderr, \"void\"); return;\n" +
            "        }\n" +
            "        // fall through for compound inner tags\n" +
            "    }\n" +
            "    if (HX_IS_STR(v)) {\n" +
            "        if (HX_STR(v)) fprintf(stderr, \"%s\", HX_STR(v));\n" +
            "        else fprintf(stderr, \"<str null>\");\n" +
            "    }\n" +
            "    else if (HX_IS_INT(v)) fprintf(stderr, \"%lld\", (long long)HX_INT(v));\n" +
            "    else if (HX_IS_FLOAT(v)) {\n" +
            "        __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n" +
            "        fprintf(stderr, \"%s\", __fbuf);\n" +
            "    }\n" +
            "    else if (HX_IS_BOOL(v)) fprintf(stderr, HX_BOOL(v) ? \"true\" : \"false\");\n" +
            "    else if (HX_IS_VOID(v)) fprintf(stderr, \"void\");\n" +
            "    else if (HX_IS_ARRAY(v) || HX_IS_MAP(v)) {\n" +
            "        // Delegate to hexa_to_string for container repr (depth/element\n" +
            "        // caps are inherited). Guards against null arr/map pointers.\n" +
            "        HexaVal s = hexa_to_string(v);\n" +
            "        if (HX_IS_STR(s) && HX_STR(s)) fprintf(stderr, \"%s\", HX_STR(s));\n" +
            "        else fprintf(stderr, \"<value>\");\n" +
            "    }\n" +
            "    else fprintf(stderr, \"<value>\");\n" +
            "}\n" +
            "\n" +
            "// ── Try/catch (setjmp based) ────────────────────────\n" +
            "#include <setjmp.h>\n" +
            "#define HEXA_MAX_TRY 64\n" +
            "static jmp_buf* __hexa_try_stack[HEXA_MAX_TRY];\n" +
            "/* PHASE 1.2.B (2026-05-15): de-staticized. Try-stack depth marker read by\n" +
            " * hexat-emitted try/catch lowering in user.c. */\n" +
            "int __hexa_try_top = 0;\n" +
            "static HexaVal __hexa_error_val;\n" +
            "\n" +
            "void __hexa_try_push(jmp_buf* jb) { if (__hexa_try_top < HEXA_MAX_TRY) __hexa_try_stack[__hexa_try_top++] = jb; }\n" +
            "void __hexa_try_pop(void) { if (__hexa_try_top > 0) __hexa_try_top--; }\n" +
            "HexaVal __hexa_last_error(void) { return __hexa_error_val; }\n" +
            "\n" +
            "// __hexa_try_cleanup: GCC/Clang `cleanup` attribute helper used by codegen.\n" +
            "// Restores try-stack depth on scope exit, so an early return / break / longjmp\n" +
            "// inside a try block can't leak entries onto __hexa_try_stack.\n" +
            "void __hexa_try_cleanup(int* saved) { if (__hexa_try_top > *saved) __hexa_try_top = *saved; }\n" +
            "\n" +
            "void hexa_throw(HexaVal err) {\n" +
            "    __hexa_error_val = err;\n" +
            "    if (__hexa_try_top > 0) {\n" +
            "        __hexa_try_top--;\n" +
            "        // RUNTIME tail (cycle 86): native longjmp (drops libc _longjmp). The\n" +
            "        // matching save is the codegen's `bl _hxlcl_setjmp` into the same slot.\n" +
            "        hxlcl_longjmp((void *)*__hexa_try_stack[__hexa_try_top], 1);\n" +
            "    }\n" +
            "    // hxa-20260423-013: print the error value on uncaught throw so tests\n" +
            "    // (T34) and users can see what failed. Falls back to generic label\n" +
            "    // when the value can't be rendered as a short scalar.\n" +
            "    if (HX_IS_STR(err) && HX_STR(err)) {\n" +
            "        fprintf(stderr, \"%s\\n\", HX_STR(err));\n" +
            "    } else {\n" +
            "        fprintf(stderr, \"Unhandled throw\\n\");\n" +
            "    }\n" +
            "    exit(1);\n" +
            "}\n" +
            "\n" +
            "// ── Printing ─────────────────────────────────────────────\n" +
            "\n" +
            "// Cycle-102 (2026-05-22) — IO 4th-fn activation. The hexa_print_val\n" +
            "// symbol is what shipped self/native/hexat emits for `print(v)`.\n" +
            "// Under HEXA_HAS_HEXA_RT_STDLIB the entry dispatches to rt_print\n" +
            "// (stdlib/runtime/io.hexa) which coerces via to_string + raw write.\n" +
            "// For TAG_ARRAY this routes through _hexa_to_string_rec which produces\n" +
            "// the same `[e1, e2, ...]` repr (depth-cap 8, element-cap 64) the C\n" +
            "// path emitted via recursive printf — byte-eq for scalar smokes.\n" +
            "// The C body is retained under #else for the standalone runtime.c\n" +
            "// smoke link path (no stdlib import).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_print(HexaVal v);\n" +
            "void hexa_print_val(HexaVal v) {\n" +
            "    (void)rt_print(v);\n" +
            "}\n" +
            "#else\n" +
            "// anima P0 bug #6 (2026-04-18): TAG_VALSTRUCT unwrap guard.\n" +
            "// When interpreter routes print through hexa_println with an arg that\n" +
            "// got boxed as TAG_VALSTRUCT (rt 32-G flat struct), the prior `default:`\n" +
            "// branch rendered \"<value>\" — correct-ish but lossy for the common\n" +
            "// string path (if true { println(\"inside\") } inside a fn body).\n" +
            "// Unwrap the inner tag here so the user-visible output matches the\n" +
            "// intent even when Val-boxing sneaks through the interp boundary.\n" +
            "// See: handoff 2026-04-18 bug #6, feedback_val_corruption_class_2026_04_17.md\n" +
            "void hexa_print_val(HexaVal v) {\n" +
            "    // One-hop TAG_VALSTRUCT unwrap. Not recursive — a VS wrapping a VS is\n" +
            "    // already a corruption signal we surface via the fallback tail.\n" +
            "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n" +
            "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n" +
            "    char __fbuf[64];\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        HexaValStruct* vs = HX_VS(v);\n" +
            "        switch (vs->tag_i) {\n" +
            "            case TAG_INT:   printf(\"%lld\", (long long)vs->int_val); return;\n" +
            "            case TAG_FLOAT:\n" +
            "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n" +
            "                printf(\"%s\", __fbuf); return;\n" +
            "            case TAG_BOOL:  printf(\"%s\", vs->bool_val ? \"true\" : \"false\"); return;\n" +
            "            case TAG_STR: {\n" +
            "                const char* cs = HX_STR(vs->str_val);\n" +
            "                if (cs) { printf(\"%s\", cs); return; }\n" +
            "                break;\n" +
            "            }\n" +
            "            case TAG_VOID:  printf(\"void\"); return;\n" +
            "        }\n" +
            "        // Inner tag not one of the printable scalars — fall through to the\n" +
            "        // outer switch with the boxed tag so we emit \"<value>\" rather than\n" +
            "        // dereferencing a compound descriptor that may not survive arena\n" +
            "        // rewinding (T33 class).\n" +
            "    }\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_INT: printf(\"%lld\", (long long)HX_INT(v)); break;\n" +
            "        case TAG_FLOAT:\n" +
            "            __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n" +
            "            printf(\"%s\", __fbuf); break;\n" +
            "        case TAG_BOOL: printf(\"%s\", HX_BOOL(v) ? \"true\" : \"false\"); break;\n" +
            "        case TAG_STR:\n" +
            "            // Null-pointer guard: a corrupted TAG_STR (str_val=NULL) would\n" +
            "            // crash printf(\"%s\", NULL) on some libc builds. Surface it.\n" +
            "            if (HX_STR(v)) printf(\"%s\", HX_STR(v));\n" +
            "            else printf(\"<str null>\");\n" +
            "            break;\n" +
            "        case TAG_VOID: printf(\"void\"); break;\n" +
            "        case TAG_ARRAY:\n" +
            "            printf(\"[\");\n" +
            "            for (int i = 0; i < HX_ARR_LEN(v); i++) {\n" +
            "                if (i > 0) printf(\", \");\n" +
            "                hexa_print_val(HX_ARR_ITEMS(v)[i]);\n" +
            "            }\n" +
            "            printf(\"]\");\n" +
            "            break;\n" +
            "        case TAG_MAP: {\n" +
            "            // 2026-04-20 silent-fallback fix: TAG_MAP branch added.\n" +
            "            // Prior default emitted \"<value>\" — lossy for println(map).\n" +
            "            // Delegate to hexa_to_string so depth/element caps apply.\n" +
            "            HexaVal s = hexa_to_string(v);\n" +
            "            if (HX_IS_STR(s) && HX_STR(s)) printf(\"%s\", HX_STR(s));\n" +
            "            else printf(\"<value>\");\n" +
            "            break;\n" +
            "        }\n" +
            "        default: printf(\"<value>\"); break;\n" +
            "    }\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// RUNTIME.md step-3 잔여 #7 (2026-05-22 cycle-101 c25ef75e) — hexa_println\n" +
            "// / hexa_eprint / hexa_eprintln may route to hexa-source rt_print /\n" +
            "// rt_println / rt_eprint / rt_eprintln (stdlib/runtime/io.hexa) when\n" +
            "// HEXA_HAS_HEXA_RT_STDLIB is defined. The hexa bodies coerce via\n" +
            "// to_string(v) + emit raw bytes via __fd_write_bytes (runtime.c shim).\n" +
            "// C bodies retained for the smoke link path (standalone runtime.c, no\n" +
            "// stdlib import) and as fallback.\n" +
            "//\n" +
            "// Cycle-102 (2026-05-22, runtime|codegen|stdlib|restore) — restores the\n" +
            "// cycle-101 dispatch after the silent wipe in commit e8c2dc1c (wip:\n" +
            "// dfflibmap sky130 reset-flop variants + ...). Additionally activates\n" +
            "// the 4th IO fn (rt_print) by routing the existing `hexa_print_val`\n" +
            "// symbol — which is what shipped self/native/hexat emits for\n" +
            "// `print(v)` — through rt_print at the top of hexa_print_val. Internal\n" +
            "// recursion (TAG_ARRAY children) stays on the C path via the private\n" +
            "// helper _hexa_print_val_c_body to avoid double-routing.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_println(HexaVal v);\n" +
            "void hexa_println(HexaVal v) {\n" +
            "    (void)rt_println(v);\n" +
            "}\n" +
            "#else\n" +
            "void hexa_println(HexaVal v) {\n" +
            "    hexa_print_val(v); printf(\"\\n\");\n" +
            "    // 2026-05-06 — auto-fflush. setvbuf constructor가 일부 환경 (macOS Tahoe\n" +
            "    // Terminal, qrencode subprocess와 interactive prompt 혼재 등)에서 무력\n" +
            "    // 화 case 발견. 매 println 후 명시 fflush로 dead time 0 보장.\n" +
            "    // opt-out: HEXA_NO_AUTOFLUSH=1 (bulk-output benchmark용).\n" +
            "    if (!hxlcl_getenv(\"HEXA_NO_AUTOFLUSH\")) fflush(stdout);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Cycle-102 (2026-05-22) — 4th IO fn activation. `print(v)` codegen\n" +
            "// lowers to `hexa_print_val(v)` (the symbol used recursively for\n" +
            "// ARRAY children). The shipped hexat binary emits this name, so we\n" +
            "// dispatch at this entry point under HEXA_HAS_HEXA_RT_STDLIB to route\n" +
            "// the top-level call through rt_print (stdlib/runtime/io.hexa). The\n" +
            "// recursive case (hexa_print_val called from within hexa_print_val\n" +
            "// for TAG_ARRAY items above) flows through the SAME dispatched entry\n" +
            "// — `rt_print` calls `to_string(v)` which for arrays delegates to\n" +
            "// _hexa_to_string_rec (depth-capped at 8, element-capped at 64),\n" +
            "// producing the same `[e1, e2, ...]` repr that the C path emitted via\n" +
            "// recursive printf. Byte-eq for plain string args (the smoke test).\n" +
            "//\n" +
            "// Additionally introduces a new C symbol `hexa_print(v)` for the\n" +
            "// codegen rule (single-arg `print(v)` → `hexa_print(v)`) that ships\n" +
            "// with the next regen of self/native/hexat. Until regen lands the\n" +
            "// shipped binary continues to call hexa_print_val (which now\n" +
            "// dispatches), so activation is functional today and will remain\n" +
            "// correct after regen flips the call site.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_print(HexaVal v);\n" +
            "HexaVal hexa_print(HexaVal v) {\n" +
            "    return rt_print(v);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_print(HexaVal v) {\n" +
            "    hexa_print_val(v);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// P7-6 builtin (2026-04-18): stderr counterpart to hexa_println. Used\n" +
            "// by user code that needs to emit diagnostics without polluting stdout\n" +
            "// (e.g. CLI tools whose stdout is a result stream piped to another\n" +
            "// process). Returns void-equivalent HexaVal so it can slot into the\n" +
            "// uniform i64-ret IR shape that the native_build dispatcher emits.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_eprintln(HexaVal v);\n" +
            "HexaVal hexa_eprintln(HexaVal v) {\n" +
            "    return rt_eprintln(v);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_eprintln(HexaVal v) {\n" +
            "    // Route through the same hexa_print_val logic but redirect the\n" +
            "    // writes to stderr. We cannot reuse hexa_print_val directly because\n" +
            "    // it hard-codes printf() — mirror the body with fprintf(stderr).\n" +
            "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n" +
            "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n" +
            "    char __fbuf[64];\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        HexaValStruct* vs = HX_VS(v);\n" +
            "        switch (vs->tag_i) {\n" +
            "            case TAG_INT:   fprintf(stderr, \"%lld\\n\", (long long)vs->int_val); return hexa_void();\n" +
            "            case TAG_FLOAT:\n" +
            "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n" +
            "                fprintf(stderr, \"%s\\n\", __fbuf); return hexa_void();\n" +
            "            case TAG_BOOL:  fprintf(stderr, \"%s\\n\", vs->bool_val ? \"true\" : \"false\"); return hexa_void();\n" +
            "            case TAG_STR: {\n" +
            "                const char* cs = HX_STR(vs->str_val);\n" +
            "                if (cs) { fprintf(stderr, \"%s\\n\", cs); return hexa_void(); }\n" +
            "                break;\n" +
            "            }\n" +
            "            case TAG_VOID:  fprintf(stderr, \"void\\n\"); return hexa_void();\n" +
            "        }\n" +
            "        // fall through to outer switch for corrupted/compound inner tags\n" +
            "    }\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_INT: fprintf(stderr, \"%lld\\n\", (long long)HX_INT(v)); break;\n" +
            "        case TAG_FLOAT:\n" +
            "            __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n" +
            "            fprintf(stderr, \"%s\\n\", __fbuf); break;\n" +
            "        case TAG_BOOL: fprintf(stderr, \"%s\\n\", HX_BOOL(v) ? \"true\" : \"false\"); break;\n" +
            "        case TAG_STR:\n" +
            "            if (HX_STR(v)) fprintf(stderr, \"%s\\n\", HX_STR(v));\n" +
            "            else fprintf(stderr, \"<str null>\\n\");\n" +
            "            break;\n" +
            "        case TAG_VOID: fprintf(stderr, \"void\\n\"); break;\n" +
            "        case TAG_ARRAY:\n" +
            "        case TAG_MAP: {\n" +
            "            // 2026-04-20 silent-fallback fix: TAG_ARRAY/TAG_MAP branches\n" +
            "            // added. Prior default emitted \"<value>\\n\" — lossy for\n" +
            "            // eprintln(arr) / eprintln(map). Delegate to hexa_to_string.\n" +
            "            HexaVal s = hexa_to_string(v);\n" +
            "            if (HX_IS_STR(s) && HX_STR(s)) fprintf(stderr, \"%s\\n\", HX_STR(s));\n" +
            "            else fprintf(stderr, \"<value>\\n\");\n" +
            "            break;\n" +
            "        }\n" +
            "        default: fprintf(stderr, \"<value>\\n\"); break;\n" +
            "    }\n" +
            "    // 2026-05-06 — auto-fflush stderr (mirror hexa_println 정합).\n" +
            "    if (!hxlcl_getenv(\"HEXA_NO_AUTOFLUSH\")) fflush(stderr);\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// 2026-04-20 builtin: stderr + NO trailing newline (print/println symmetry).\n" +
            "// Mirrors hexa_eprintln byte-for-byte except the \"\\n\" suffix is dropped from\n" +
            "// every format branch. Motivating callers:\n" +
            "//   tool/pkg/packages/token-forge/proxy/server.hexa\n" +
            "//   self/ml/corpus_clean.hexa\n" +
            "// which pre-2026-04-20 fell through to hexa_call1(eprint,...) and produced a\n" +
            "// clang link error in AOT. Interp path also route-checks this name.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_eprint(HexaVal v);\n" +
            "HexaVal hexa_eprint(HexaVal v) {\n" +
            "    return rt_eprint(v);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_eprint(HexaVal v) {\n" +
            "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n" +
            "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n" +
            "    char __fbuf[64];\n" +
            "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n" +
            "        HexaValStruct* vs = HX_VS(v);\n" +
            "        switch (vs->tag_i) {\n" +
            "            case TAG_INT:   fprintf(stderr, \"%lld\", (long long)vs->int_val); return hexa_void();\n" +
            "            case TAG_FLOAT:\n" +
            "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n" +
            "                fprintf(stderr, \"%s\", __fbuf); return hexa_void();\n" +
            "            case TAG_BOOL:  fprintf(stderr, \"%s\", vs->bool_val ? \"true\" : \"false\"); return hexa_void();\n" +
            "            case TAG_STR: {\n" +
            "                const char* cs = HX_STR(vs->str_val);\n" +
            "                if (cs) { fprintf(stderr, \"%s\", cs); return hexa_void(); }\n" +
            "                break;\n" +
            "            }\n" +
            "            case TAG_VOID:  fprintf(stderr, \"void\"); return hexa_void();\n" +
            "        }\n" +
            "    }\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_INT: fprintf(stderr, \"%lld\", (long long)HX_INT(v)); break;\n" +
            "        case TAG_FLOAT:\n" +
            "            __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n" +
            "            fprintf(stderr, \"%s\", __fbuf); break;\n" +
            "        case TAG_BOOL: fprintf(stderr, \"%s\", HX_BOOL(v) ? \"true\" : \"false\"); break;\n" +
            "        case TAG_STR:\n" +
            "            if (HX_STR(v)) fprintf(stderr, \"%s\", HX_STR(v));\n" +
            "            else fprintf(stderr, \"<str null>\");\n" +
            "            break;\n" +
            "        case TAG_VOID: fprintf(stderr, \"void\"); break;\n" +
            "        case TAG_ARRAY:\n" +
            "        case TAG_MAP: {\n" +
            "            HexaVal s = hexa_to_string(v);\n" +
            "            if (HX_IS_STR(s) && HX_STR(s)) fprintf(stderr, \"%s\", HX_STR(s));\n" +
            "            else fprintf(stderr, \"<value>\");\n" +
            "            break;\n" +
            "        }\n" +
            "        default: fprintf(stderr, \"<value>\"); break;\n" +
            "    }\n" +
            "    return hexa_void();\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ── to_string ────────────────────────────────────────────\n" +
            "\n" +
            "// 2026-04-20 container-repr fix: TAG_ARRAY/TAG_MAP branches added so\n" +
            "// `str(arr)` / `str(map)` produce readable `[e1, e2]` / `{k: v, ...}`\n" +
            "// output instead of the \"<value>\" fallback. Mirrors hexa_print_val\n" +
            "// (runtime.c:2796) which already handled TAG_ARRAY — the asymmetry\n" +
            "// between hexa_print_val (direct print) and hexa_to_string (string\n" +
            "// concat via `+`) was surfacing as `\"arr=\" + str(arr) -> \"arr=<value>\"`.\n" +
            "// Guards: recursion depth cap (8) to prevent stack blow-up on cyclic\n" +
            "// references; element cap (64) so a 1M-element tensor-as-array does\n" +
            "// not allocate a multi-MB string; null pointer guards on arr_ptr /\n" +
            "// map_ptr / order_keys before deref (T33 arena-dangling defence).\n" +
            "static HexaVal _hexa_to_string_rec(HexaVal v, int depth);\n" +
            "\n" +
            "// Step-4 cycle 96 port — scalar branches (int [outside cache] / float\n" +
            "// [integer-valued in range] / bool / void / str) dispatch to hexa source.\n" +
            "// Small-int cache + non-integer float [%g] + array/map/valstruct stay C.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_to_string_scalar(HexaVal v);\n" +
            "HexaVal hexa_to_string(HexaVal v) {\n" +
            "    /* Array/Map/ValStruct: recursive C body. */\n" +
            "    if (HX_IS_VALSTRUCT(v) || HX_TAG(v) == TAG_ARRAY || HX_TAG(v) == TAG_MAP) {\n" +
            "        return _hexa_to_string_rec(v, 0);\n" +
            "    }\n" +
            "    /* Small-int cache fast path. */\n" +
            "    if (HX_IS_INT(v) &&\n" +
            "        HX_INT(v) >= SMALL_INT_CACHE_MIN &&\n" +
            "        HX_INT(v) <= SMALL_INT_CACHE_MAX) {\n" +
            "        if (!_cached_small_ints_ready) _hexa_init_small_int_cache();\n" +
            "        return _cached_small_ints[HX_INT(v) - SMALL_INT_CACHE_MIN];\n" +
            "    }\n" +
            "    /* Non-integer-valued float: env-honoring fmt (default %g, opt-in g15/g17\n" +
            "     * via HEXA_FLOAT_REPR — matches print_val path).  PROBE r11 B6.\n" +
            "     * PROBE r14-E: pre-empt NaN/inf with Rust canonical casing. */\n" +
            "    if (HX_IS_FLOAT(v)) {\n" +
            "        double f = HX_FLOAT(v);\n" +
            "        const char* sp = __hexa_float_special_repr(f);\n" +
            "        if (sp) return hexa_str(sp);\n" +
            "        if (!(isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15)) {\n" +
            "            char buf[64];\n" +
            "            snprintf(buf, 64, __hexa_print_float_fmt(), f);\n" +
            "            return hexa_str(buf);\n" +
            "        }\n" +
            "    }\n" +
            "    return rt_to_string_scalar(v);\n" +
            "}\n" +
            "#else\n" +
            "HexaVal hexa_to_string(HexaVal v) {\n" +
            "    return _hexa_to_string_rec(v, 0);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "static HexaVal _hexa_to_string_rec(HexaVal v, int depth) {\n" +
            "    if (!_cached_strs_ready) _hexa_init_cached_strs();\n" +
            "    char buf[64];\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_INT: {\n" +
            "            // ROI-33: small-int cache hit — skip snprintf+intern entirely\n" +
            "            if (HX_INT(v) >= SMALL_INT_CACHE_MIN && HX_INT(v) <= SMALL_INT_CACHE_MAX) {\n" +
            "                if (!_cached_small_ints_ready) _hexa_init_small_int_cache();\n" +
            "                return _cached_small_ints[HX_INT(v) - SMALL_INT_CACHE_MIN];\n" +
            "            }\n" +
            "            snprintf(buf, 64, \"%lld\", (long long)HX_INT(v));\n" +
            "            return hexa_str(buf);\n" +
            "        }\n" +
            "        case TAG_FLOAT: {\n" +
            "            // trk.27 fix 2026-05-06: preserve `.0` for whole-valued floats so\n" +
            "            // to_string(0.0) returns \"0.0\" not \"0\", matching python json.dumps\n" +
            "            // and existing test assertions (test_lang_core.hexa:141 +\n" +
            "            // test_type_coercion.hexa:35 — to_string(3.0) == \"3.0\"). Plain %g\n" +
            "            // strips trailing zeros — use %.1f when float is integer-valued +\n" +
            "            // finite + within int-representable range; env-honoring fmt\n" +
            "            // (default %g, opt-in g15/g17 via HEXA_FLOAT_REPR) otherwise.\n" +
            "            // PROBE r11 B6.\n" +
            "            // PROBE r14-E (2026-05-23): pre-empt NaN/inf with Rust canonical\n" +
            "            // casing (\"NaN\"/\"inf\"/\"-inf\") before falling through to %g/%.1f\n" +
            "            // (libc default is lowercase \"nan\"/\"inf\").\n" +
            "            double f = HX_FLOAT(v);\n" +
            "            const char* sp = __hexa_float_special_repr(f);\n" +
            "            if (sp) return hexa_str(sp);\n" +
            "            if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n" +
            "                snprintf(buf, 64, \"%.1f\", f);\n" +
            "            } else {\n" +
            "                snprintf(buf, 64, __hexa_print_float_fmt(), f);\n" +
            "            }\n" +
            "            return hexa_str(buf);\n" +
            "        }\n" +
            "        case TAG_BOOL: return HX_BOOL(v) ? _cached_str_true : _cached_str_false;\n" +
            "        case TAG_STR: return v;\n" +
            "        case TAG_VOID: return _cached_str_void;\n" +
            "        // rt 32-G: minimal fallback repr — interpreter has its own\n" +
            "        // val_to_string for the full form.\n" +
            "        // Step 4 cycle 97 — minimal-repr port (잔여 #8). C wrapper retains\n" +
            "        // the HX_VS NULL guard + `<Val null>` sentinel; hexa source emits\n" +
            "        // the `Val{tag=N,i=M}` body via existing .get() builtin which\n" +
            "        // routes through hexa_valstruct_get_by_key at runtime (no new\n" +
            "        // codegen builtin required).\n" +
            "        case TAG_VALSTRUCT: {\n" +
            "            if (!HX_VS(v)) return hexa_str(\"<Val null>\");\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            extern HexaVal rt_valstruct_repr(HexaVal v);\n" +
            "            return rt_valstruct_repr(v);\n" +
            "#else\n" +
            "            snprintf(buf, 64, \"Val{tag=%lld,i=%lld}\",\n" +
            "                (long long)HX_VSF(v, tag_i), (long long)HX_VSF(v, int_val));\n" +
            "            return hexa_str(buf);\n" +
            "#endif\n" +
            "        }\n" +
            "        case TAG_ARRAY: {\n" +
            "            if (depth >= 8) return hexa_str(\"[...]\");\n" +
            "            if (!v.arr_ptr) return hexa_str(\"[<null>]\");\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            // Step 5 #3 cycle C2-retry — array container render ports to\n" +
            "            // hexa source. NULL-ptr + depth guards stay C; rt_to_string_array\n" +
            "            // owns the element loop / cap / overflow-trailer; nested\n" +
            "            // arrays/maps recurse in hexa, scalars dispatch to hexa_to_string.\n" +
            "            extern HexaVal rt_to_string_array(HexaVal arr, HexaVal depth);\n" +
            "            return rt_to_string_array(v, hexa_int(depth));\n" +
            "#else\n" +
            "            int n = HX_ARR_LEN(v);\n" +
            "            int cap = 64;  // element-dump cap\n" +
            "            HexaVal out = hexa_str(\"[\");\n" +
            "            HexaVal sep = hexa_str(\", \");\n" +
            "            int shown = n < cap ? n : cap;\n" +
            "            for (int i = 0; i < shown; i++) {\n" +
            "                if (i > 0) out = hexa_str_concat(out, sep);\n" +
            "                out = hexa_str_concat(out, _hexa_to_string_rec(HX_ARR_ITEMS(v)[i], depth + 1));\n" +
            "            }\n" +
            "            if (n > cap) {\n" +
            "                snprintf(buf, 64, \", ... (%d more)\", n - cap);\n" +
            "                out = hexa_str_concat(out, hexa_str(buf));\n" +
            "            }\n" +
            "            out = hexa_str_concat(out, hexa_str(\"]\"));\n" +
            "            return out;\n" +
            "#endif\n" +
            "        }\n" +
            "        case TAG_ENUM: {\n" +
            "            // PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): route through\n" +
            "            // `_hexa_enum_display` so both the new descriptor form (emitted\n" +
            "            // by gen2_enum_decl after this PR) and the legacy bare-string\n" +
            "            // form (pre-PR `hexa_enum_str(display)`) render identically.\n" +
            "            return hexa_str(_hexa_enum_display(v));\n" +
            "        }\n" +
            "        case TAG_MAP: {\n" +
            "            if (depth >= 8) return hexa_str(\"{...}\");\n" +
            "            HexaMapTable* t = HX_MAP_TBL(v);\n" +
            "            if (!t) return hexa_str(\"{}\");\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            // Step 5 #3 cycle C2-retry — map container render ports to hexa\n" +
            "            // source. NULL-tbl + depth guards stay C; rt_to_string_map owns\n" +
            "            // the key/value loop.\n" +
            "            extern HexaVal rt_to_string_map(HexaVal m, HexaVal depth);\n" +
            "            return rt_to_string_map(v, hexa_int(depth));\n" +
            "#else\n" +
            "            int n = t->len;\n" +
            "            int cap = 64;\n" +
            "            HexaVal out = hexa_str(\"{\");\n" +
            "            HexaVal sep = hexa_str(\", \");\n" +
            "            HexaVal kv_sep = hexa_str(\": \");\n" +
            "            int shown = n < cap ? n : cap;\n" +
            "            for (int i = 0; i < shown; i++) {\n" +
            "                if (i > 0) out = hexa_str_concat(out, sep);\n" +
            "                const char* k = (t->order_keys && t->order_keys[i]) ? t->order_keys[i] : \"<null>\";\n" +
            "                out = hexa_str_concat(out, hexa_str(k));\n" +
            "                out = hexa_str_concat(out, kv_sep);\n" +
            "                out = hexa_str_concat(out, _hexa_to_string_rec(t->order_vals[i], depth + 1));\n" +
            "            }\n" +
            "            if (n > cap) {\n" +
            "                snprintf(buf, 64, \", ... (%d more)\", n - cap);\n" +
            "                out = hexa_str_concat(out, hexa_str(buf));\n" +
            "            }\n" +
            "            out = hexa_str_concat(out, hexa_str(\"}\"));\n" +
            "            return out;\n" +
            "#endif\n" +
            "        }\n" +
            "        default: return _cached_str_value;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ── Truthy check ─────────────────────────────────────────\n" +
            "\n" +
            "int hexa_truthy(HexaVal v) {\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_BOOL: return HX_BOOL(v);\n" +
            "        case TAG_INT: return HX_INT(v) != 0;\n" +
            "        // 2026-04-20 silent-fallback audit: TAG_FLOAT was falling through\n" +
            "        // to `default: return 1`, so `if 0.0 { ... }` evaluated truthy.\n" +
            "        // Match TAG_INT semantics — zero is falsy. NaN is truthy (non-zero).\n" +
            "        case TAG_FLOAT: return HX_FLOAT(v) != 0.0;\n" +
            "        case TAG_STR: return HX_STR(v) != NULL && HX_STR(v)[0] != 0;\n" +
            "        case TAG_VOID: return 0;\n" +
            "        // RFC r16 (PROBE r16): empty collection is FALSY, consistent with\n" +
            "        // `if 0` / `if 0.0` / `if \"\"`. Non-empty stays truthy. Closes the\n" +
            "        // last `default: return 1` fall-through gap (same class of bug as the\n" +
            "        // 2026-04-20 TAG_FLOAT 0.0 audit above).\n" +
            "        case TAG_ARRAY: return HX_ARR_LEN(v) > 0;\n" +
            "        // TAG_MAP: empty anonymous map `#{}` is falsy. A struct instance is a\n" +
            "        // TAG_MAP carrying a \"__type__\" carrier field (hexa_struct_pack_map),\n" +
            "        // so it always has len >= 1 and stays truthy — RFC §4/Q2: struct\n" +
            "        // existence != empty collection. The explicit __type__ guard keeps\n" +
            "        // structs truthy regardless of user field count.\n" +
            "        case TAG_MAP:\n" +
            "            if (HX_MAP_TBL(v) == NULL) return 0;\n" +
            "            if (hmap_find(HX_MAP_TBL(v), \"__type__\", hexa_fnv1a_str(\"__type__\")) >= 0) return 1;\n" +
            "            return HX_MAP_LEN(v) > 0;\n" +
            "        // rt 32-G: TAG_VALSTRUCT truthy iff .vs pointer non-null.\n" +
            "        case TAG_VALSTRUCT: return HX_VS(v) != NULL;\n" +
            "        default: return 1;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ── Type checking ────────────────────────────────────────\n" +
            "\n" +
            "HexaVal hexa_type_of(HexaVal v) {\n" +
            "    if (!_cached_strs_ready) _hexa_init_cached_strs();\n" +
            "    switch (HX_TAG(v)) {\n" +
            "        case TAG_INT: return _cached_str_int;\n" +
            "        case TAG_FLOAT: return _cached_str_float;\n" +
            "        case TAG_BOOL: return _cached_str_bool;\n" +
            "        case TAG_STR: return _cached_str_string;\n" +
            "        case TAG_VOID: return _cached_str_void;\n" +
            "        case TAG_ARRAY: return _cached_str_array;\n" +
            "        case TAG_MAP: return _cached_str_map;\n" +
            "        // 2026-04-20 silent-fallback audit: prior default dropped TAG_FN /\n" +
            "        // TAG_CHAR / TAG_CLOSURE into \"unknown\" — Hexa-side dispatch like\n" +
            "        // `type_of(x) != \"string\"` then misclassified callable values.\n" +
            "        // Surface them explicitly; any remaining unknown tag is a real bug.\n" +
            "        case TAG_FN: return _cached_str_fn;\n" +
            "        case TAG_CHAR: return _cached_str_char;\n" +
            "        case TAG_CLOSURE: return _cached_str_closure;\n" +
            "        // rt 32-G: Val is a struct at the Hexa level; surface \"struct\".\n" +
            "        case TAG_VALSTRUCT: return _cached_str_struct;\n" +
            "        // PR-2.0 (enum-to-string-codegen-emit RFC, 2026-05-24): surface\n" +
            "        // \"enum\" so user-level `type_of(Color::Red) == \"enum\"` works once\n" +
            "        // PR-2.1 migrates emit to TAG_ENUM. DEAD CODE under PR-2.0 (no\n" +
            "        // emitter produces TAG_ENUM yet — Color::Red is TAG_INT today).\n" +
            "        case TAG_ENUM: return _cached_str_enum;\n" +
            "        default: return _cached_str_unknown;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ── Polymorphic add (int + or string concat) ─────────────\n" +
            "\n" +
            "// ROI-37: rename impl to _slow so the macro below can inline the int+int\n" +
            "// fast path without function-call ABI overhead.\n" +
            "/* PHASE 1.2.B (2026-05-15): de-staticized. Slow-path fallback for the\n" +
            " * hexa_add macro emitted into runtime.h — user.c TUs link against this. */\n" +
            "// RUNTIME.md Step 4 .c-none arith core op 5: hexa_add_slow (the slow path behind\n" +
            "// the int+int hexa_add MACRO) delegates to hexa-source rt_add_slow under\n" +
            "// HEXA_HAS_HEXA_RT_STDLIB. The float branch uses the __raw_add_f escape (defined\n" +
            "// below) so the hexa code never re-enters hexa_add via `+`. #else C body kept\n" +
            "// bit-for-bit for the standalone link.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_add_slow(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_add_slow(HexaVal a, HexaVal b) { return rt_add_slow(a, b); }\n" +
            "#else\n" +
            "HexaVal hexa_add_slow(HexaVal a, HexaVal b) {\n" +
            "    // Bool → int coercion (Python canonical: True=1, False=0).  Without this,\n" +
            "    // `true + 1` fell through to `hexa_to_string + str_concat` → \"true1\".\n" +
            "    // Round-7 probe finding.\n" +
            "    if (HX_IS_BOOL(a)) a = hexa_int(HX_BOOL(a) ? 1 : 0);\n" +
            "    if (HX_IS_BOOL(b)) b = hexa_int(HX_BOOL(b) ? 1 : 0);\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b)) return hexa_int(HX_INT(a) + HX_INT(b));\n" +
            "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b)) {\n" +
            "        // T39: unwrap via __hx_to_double so TAG_VALSTRUCT wrappers don't\n" +
            "        // cast the vs pointer to double (same root as T32 to_float bug).\n" +
            "        double fa = __hx_to_double(a);\n" +
            "        double fb = __hx_to_double(b);\n" +
            "        return hexa_float(fa + fb);\n" +
            "    }\n" +
            "    // B13: array concat. Interpreter (hexa_full.hexa:6954) does this but\n" +
            "    // codegen emits bare hexa_add(l,r) — without this branch, two arrays\n" +
            "    // fall through to to_string+str_concat → TAG_STR, then later arr[i]\n" +
            "    // reads .arr.len from a TAG_STR union slot (stack residue → random OOB).\n" +
            "    if (HX_IS_ARRAY(a) && HX_IS_ARRAY(b)) {\n" +
            "        HexaVal out = hexa_array_new();\n" +
            "        for (int i = 0; i < HX_ARR_LEN(a); i++) out = hexa_array_push(out, HX_ARR_ITEMS(a)[i]);\n" +
            "        for (int i = 0; i < HX_ARR_LEN(b); i++) out = hexa_array_push(out, HX_ARR_ITEMS(b)[i]);\n" +
            "        return out;\n" +
            "    }\n" +
            "    HexaVal sa = hexa_to_string(a);\n" +
            "    HexaVal sb = hexa_to_string(b);\n" +
            "    return hexa_str_concat(sa, sb);\n" +
            "}\n" +
            "#endif\n" +
            "// float-add escape for rt_add_slow — mirrors hexa_add_slow's float branch\n" +
            "// exactly: bool→int coerce, then hexa_float(__hx_to_double(a) + __hx_to_double(b))\n" +
            "// (so a non-numeric operand coerces to 0.0, same quirk as C). NOT inlined by\n" +
            "// codegen (multi-statement) — emitted as a direct/fp call, resolved here. Same\n" +
            "// __raw_* class as __raw_idiv/imod/fmod.\n" +
            "static inline HexaVal __raw_add_f(HexaVal a, HexaVal b) {\n" +
            "    if (HX_IS_BOOL(a)) a = hexa_int(HX_BOOL(a) ? 1 : 0);\n" +
            "    if (HX_IS_BOOL(b)) b = hexa_int(HX_BOOL(b) ? 1 : 0);\n" +
            "    return hexa_float(__hx_to_double(a) + __hx_to_double(b));\n" +
            "}\n" +
            "\n" +
            "// ROI-37: inline macro — int+int hot path avoids 32-byte HexaVal call ABI.\n" +
            "// Evaluates each operand exactly once via temporaries.\n" +
            "#define hexa_add(A, B) \\\n" +
            "    ({ HexaVal __ha = (A), __hb = (B); \\\n" +
            "       (HX_IS_INT(__ha) && HX_IS_INT(__hb)) \\\n" +
            "           ? hexa_int(HX_INT(__ha) + HX_INT(__hb)) \\\n" +
            "           : hexa_add_slow(__ha, __hb); })\n" +
            "\n" +
            "// ── Variadic concat (N-way) — clang bracket-depth relief ─────\n" +
            "// codegen flattens long `+` chains (≥16 operands) into a single call:\n" +
            "//   hexa_concat_many(N, (HexaVal[]){e1, e2, ..., eN})\n" +
            "// instead of hexa_add(hexa_add(hexa_add(...))) which blows past clang's\n" +
            "// default 256-level bracket nesting limit on anima launcher files\n" +
            "// (launch_alm_14b_r9.hexa ~170 deep → fatal). Semantics = left-fold via\n" +
            "// hexa_add so mixed int/string/array inputs follow the same rules as the\n" +
            "// pairwise operator.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_concat_many(int n, HexaVal* parts) {\n" +
            "    if (n <= 0) return hexa_str(\"\");\n" +
            "    HexaVal acc = parts[0];\n" +
            "    for (int i = 1; i < n; i++) {\n" +
            "        acc = hexa_add(acc, parts[i]);\n" +
            "    }\n" +
            "    return acc;\n" +
            "}\n" +
            "#else\n" +
            "// Step-3 cycle 89 — hexa-source port via TAG_ARRAY bridge. The variadic\n" +
            "// `HexaVal*` C buffer can't be expressed in hexa source (잔여 #7), so\n" +
            "// we wrap it in a TAG_ARRAY HexaVal (one hexa_array_new + n pushes) and\n" +
            "// delegate to rt_concat_many_arr. Semantics are byte-identical to the C\n" +
            "// body (left-fold `acc = acc + parts[i]` lowers to `hexa_add(acc,\n" +
            "// parts[i])` since `acc` is `let mut` untyped). Owner of the loop:\n" +
            "// stdlib/runtime/numeric.hexa::rt_concat_many_arr.\n" +
            "extern HexaVal rt_concat_many_arr(HexaVal parts);\n" +
            "HexaVal hexa_concat_many(int n, HexaVal* parts) {\n" +
            "    if (n <= 0) return hexa_str(\"\");\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    for (int i = 0; i < n; i++) {\n" +
            "        arr = hexa_array_push(arr, parts[i]);\n" +
            "    }\n" +
            "    return rt_concat_many_arr(arr);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ── Polymorphic equality ─────────────────────────────────\n" +
            "\n" +
            "/* Step 3 cycle 100 — pointer-eq inline builtins for hexa_eq TAG_VALSTRUCT\n" +
            " * + TAG_MAP branches (RUNTIME.md 잔여 #4, 4 of 9 branches ported). The\n" +
            " * aprime_cc codegen inlines `__vs_ptr_eq(a,b)` / `__map_ptr_eq(a,b)` to\n" +
            " * `hexa_bool(HX_VS(a)==HX_VS(b))` etc. The hexat bootstrap transpiler\n" +
            " * is unaware of the inline lowering and emits\n" +
            " * `hexa_call2(__vs_ptr_eq, a, b)`; the static-inline defs below satisfy\n" +
            " * that indirect-call path via the `hexa_call2` _Generic dispatch on\n" +
            " * `HexaVal (*)(HexaVal, HexaVal)`. Either way the lowered compare is\n" +
            " * byte-identical to the legacy C body. Mirror lives in self/runtime.h\n" +
            " * for non-aprime build paths. */\n" +
            "#ifndef __vs_ptr_eq_DEFINED\n" +
            "#define __vs_ptr_eq_DEFINED\n" +
            "static inline HexaVal __vs_ptr_eq(HexaVal a, HexaVal b) {\n" +
            "    return hexa_bool((HX_VS(a)) == (HX_VS(b)));\n" +
            "}\n" +
            "#endif\n" +
            "#ifndef __map_ptr_eq_DEFINED\n" +
            "#define __map_ptr_eq_DEFINED\n" +
            "static inline HexaVal __map_ptr_eq(HexaVal a, HexaVal b) {\n" +
            "    return hexa_bool((HX_MAP_TBL(a)) == (HX_MAP_TBL(b)));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "HexaVal hexa_eq(HexaVal a, HexaVal b) {\n" +
            "    // Cross-type numeric equality (int ↔ float) — matches interp\n" +
            "    // eval_binop float-coerce path (hexa_full.hexa:7867). 이전엔\n" +
            "    // tag 불일치 즉시 false → `2 == 2.0` AOT=false / interp=true\n" +
            "    // divergence 를 유발.\n" +
            "    if (HX_IS_INT(a) && HX_IS_FLOAT(b)) return hexa_bool((double)HX_INT(a) == HX_FLOAT(b));\n" +
            "    if (HX_IS_FLOAT(a) && HX_IS_INT(b)) return hexa_bool(HX_FLOAT(a) == (double)HX_INT(b));\n" +
            "    if (HX_TAG(a) != HX_TAG(b)) return hexa_bool(0);\n" +
            "    switch (HX_TAG(a)) {\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "        /* Step-3 cycle 103 — same-tag scalar branches ported to hexa\n" +
            "           source (RUNTIME.md 잔여 #4 → 9/9 candidate branches). Both\n" +
            "           operands are guaranteed the same scalar tag here (cross-type\n" +
            "           numeric coercion + HX_TAG(a)==HX_TAG(b) guard already passed).\n" +
            "           rt_eq_int/float express equality via ordered comparisons\n" +
            "           (hexa_cmp_le/ge — NOT redirected, byte-exact incl. NaN);\n" +
            "           rt_eq_bool avoids comparison on HexaVals entirely. None lower\n" +
            "           to a hexa_eq call site, so no recursion (transpile-verified). */\n" +
            "        case TAG_INT: {\n" +
            "            extern HexaVal rt_eq_int(HexaVal a, HexaVal b);\n" +
            "            return hexa_bool(hexa_truthy(rt_eq_int(a, b)));\n" +
            "        }\n" +
            "        case TAG_FLOAT: {\n" +
            "            extern HexaVal rt_eq_float(HexaVal a, HexaVal b);\n" +
            "            return hexa_bool(hexa_truthy(rt_eq_float(a, b)));\n" +
            "        }\n" +
            "        case TAG_BOOL: {\n" +
            "            extern HexaVal rt_eq_bool(HexaVal a, HexaVal b);\n" +
            "            return hexa_bool(hexa_truthy(rt_eq_bool(a, b)));\n" +
            "        }\n" +
            "#else\n" +
            "        case TAG_INT: return hexa_bool(HX_INT(a) == HX_INT(b));\n" +
            "        case TAG_FLOAT: return hexa_bool(HX_FLOAT(a) == HX_FLOAT(b));\n" +
            "        case TAG_BOOL: return hexa_bool(HX_BOOL(a) == HX_BOOL(b));\n" +
            "#endif\n" +
            "        case TAG_STR: {\n" +
            "            /* Intern fast-path stays C (HX_STR pointer identity). */\n" +
            "            if (HX_STR(a) == HX_STR(b)) return hexa_bool(1);\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            /* Step-3 cycle 91 — strcmp fallback via cycle-57 rt_str_eq_b. */\n" +
            "            extern HexaVal rt_str_eq_b(HexaVal a, HexaVal b);\n" +
            "            return hexa_bool(hexa_truthy(rt_str_eq_b(a, b)));\n" +
            "#else\n" +
            "            return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) == 0);\n" +
            "#endif\n" +
            "        }\n" +
            "        case TAG_VOID: return hexa_bool(1);\n" +
            "        // rt 32-G: Val identity is pointer-equality of heap struct (matches\n" +
            "        // TAG_MAP semantics — two separately constructed maps never compare\n" +
            "        // equal by value).\n" +
            "        case TAG_VALSTRUCT: {\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            /* Step-3 cycle 100 — hexa-source port via __vs_ptr_eq inline\n" +
            "               builtin. The hexa body is a single `return __vs_ptr_eq(a, b)`,\n" +
            "               so the lowered C is a single `HX_VS(a) == HX_VS(b)` compare —\n" +
            "               byte-equivalent to the legacy path. RUNTIME.md 잔여 #4\n" +
            "               (3 of 9 branches now ported). */\n" +
            "            extern HexaVal rt_eq_valstruct(HexaVal a, HexaVal b);\n" +
            "            return hexa_bool(hexa_truthy(rt_eq_valstruct(a, b)));\n" +
            "#else\n" +
            "            return hexa_bool(HX_VS(a) == HX_VS(b));\n" +
            "#endif\n" +
            "        }\n" +
            "        // Array deep equality — interp eval_binop (hexa_full.hexa:7939) 가\n" +
            "        // 요소별 vals_equal 로 비교하므로 AOT 도 요소 재귀 비교로 정렬.\n" +
            "        // 이전 comment 는 interp 가 ref eq 이라고 기록했지만 실제 코드는\n" +
            "        // value eq. 같은 포인터 shortcut 으로 빠른 경로 유지.\n" +
            "        case TAG_ARRAY: {\n" +
            "            /* Same-ptr fast-path + length check stay C (cheap). */\n" +
            "            if (a.arr_ptr == b.arr_ptr) return hexa_bool(1);\n" +
            "            int __na = HX_ARR_LEN(a); int __nb = HX_ARR_LEN(b);\n" +
            "            if (__na != __nb) return hexa_bool(0);\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            /* Step-3 cycle 97 — element-by-element deep loop via\n" +
            "               rt_eq_array_deep (hexa source). Inside the ported fn,\n" +
            "               `a[i] != b[i]` re-enters hexa_eq for each pair; scalar\n" +
            "               cases stay C, nested arrays recurse back into this\n" +
            "               case → rt_eq_array_deep. Mutual recursion on a strictly\n" +
            "               smaller subtree, so well-formed input terminates. */\n" +
            "            extern HexaVal rt_eq_array_deep(HexaVal a, HexaVal b);\n" +
            "            return hexa_bool(hexa_truthy(rt_eq_array_deep(a, b)));\n" +
            "#else\n" +
            "            HexaVal* __xa = HX_ARR_ITEMS(a); HexaVal* __xb = HX_ARR_ITEMS(b);\n" +
            "            for (int __i = 0; __i < __na; __i++) {\n" +
            "                if (!hexa_truthy(hexa_eq(__xa[__i], __xb[__i]))) return hexa_bool(0);\n" +
            "            }\n" +
            "            return hexa_bool(1);\n" +
            "#endif\n" +
            "        }\n" +
            "        case TAG_MAP: {\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "            /* Step-3 cycle 100 — hexa-source pointer-eq fast-path via\n" +
            "               __map_ptr_eq inline builtin (RUNTIME.md 잔여 #4, 4 of 9\n" +
            "               branches now ported). Hexa body is `return __map_ptr_eq(a, b)`\n" +
            "               which lowers to the same `HX_MAP_TBL(a) == HX_MAP_TBL(b)`\n" +
            "               compare. The `__tag` enum-variant deep-compare below stays\n" +
            "               C-side (separate logic, future cycle). */\n" +
            "            extern HexaVal rt_eq_map_ptr(HexaVal a, HexaVal b);\n" +
            "            if (hexa_truthy(rt_eq_map_ptr(a, b))) return hexa_bool(1);\n" +
            "#else\n" +
            "            if (HX_MAP_TBL(a) == HX_MAP_TBL(b)) return hexa_bool(1);\n" +
            "#endif\n" +
            "            // #28 — enum value equality. The native (aprime_cc) lowering\n" +
            "            // represents an enum variant as a map { \"__tag\": hash, \"__pN\": … }\n" +
            "            // (compiler/lower/hir_to_mir.hexa enum_path → struct_lit). Two\n" +
            "            // separately constructed enum maps for the same variant must\n" +
            "            // compare equal, mirroring the match-arm `__tag` discriminant\n" +
            "            // test. Plain maps / structs (\"__type__\"-keyed, or no marker)\n" +
            "            // keep pointer-identity semantics — unchanged. Scoped strictly\n" +
            "            // to \"__tag\"-bearing maps so struct / dict `==` is untouched.\n" +
            "            if (hexa_map_contains_key(a, \"__tag\") && hexa_map_contains_key(b, \"__tag\")) {\n" +
            "                HexaVal ta = hexa_map_get(a, \"__tag\");\n" +
            "                HexaVal tb = hexa_map_get(b, \"__tag\");\n" +
            "                if (!hexa_truthy(hexa_eq(ta, tb))) return hexa_bool(0);\n" +
            "                // Same variant ⇒ same payload arity. Compare each \"__pN\"\n" +
            "                // payload structurally until the first absent slot.\n" +
            "                for (int __pi = 0; ; __pi++) {\n" +
            "                    char __pk[24];\n" +
            "                    snprintf(__pk, sizeof(__pk), \"__p%d\", __pi);\n" +
            "                    int ha = hexa_map_contains_key(a, __pk);\n" +
            "                    int hb = hexa_map_contains_key(b, __pk);\n" +
            "                    if (!ha && !hb) break;\n" +
            "                    if (ha != hb) return hexa_bool(0);\n" +
            "                    if (!hexa_truthy(hexa_eq(hexa_map_get(a, __pk),\n" +
            "                                             hexa_map_get(b, __pk))))\n" +
            "                        return hexa_bool(0);\n" +
            "                }\n" +
            "                return hexa_bool(1);\n" +
            "            }\n" +
            "            return hexa_bool(0);\n" +
            "        }\n" +
            "        // TAG_FN: compare underlying C function pointer (descriptor indirection\n" +
            "        // may differ for two separately-constructed wrappers of the same fn).\n" +
            "        case TAG_FN:\n" +
            "            return hexa_bool(\n" +
            "                (a.fn_ptr_d && b.fn_ptr_d)\n" +
            "                    ? (HX_FN_PTR(a) == HX_FN_PTR(b))\n" +
            "                    : (a.fn_ptr_d == b.fn_ptr_d));\n" +
            "        case TAG_CHAR: return hexa_bool(HX_INT(a) == HX_INT(b));\n" +
            "        case TAG_CLOSURE:\n" +
            "            return hexa_bool(\n" +
            "                (a.clo_ptr && b.clo_ptr)\n" +
            "                    ? (HX_CLO_PTR(a) == HX_CLO_PTR(b))\n" +
            "                    : (a.clo_ptr == b.clo_ptr));\n" +
            "        case TAG_ENUM: {\n" +
            "            // PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): pointer-eq\n" +
            "            // covers both descriptor and bare forms (each variant has a\n" +
            "            // single static instance per TU); strcmp on display string is the\n" +
            "            // cross-TU fallback so the new descriptor form and the legacy\n" +
            "            // bare form compare equal when they name the same variant.\n" +
            "            if (HX_STR(a) == HX_STR(b)) return hexa_bool(1);\n" +
            "            const char* da = _hexa_enum_display(a);\n" +
            "            const char* db = _hexa_enum_display(b);\n" +
            "            if (!da || !db) return hexa_bool(0);\n" +
            "            return hexa_bool(hxlcl_strcmp(da, db) == 0);\n" +
            "        }\n" +
            "        default: return hexa_bool(0);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// ── File I/O ─────────────────────────────────────────────\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────────────\n" +
            "// M1 full · file layer (hxa-20260423-003 Step 3)\n" +
            "// rt_file_* hand-port — authoritative implementations for file I/O.\n" +
            "// hexa_* wrappers below are shims forwarding to rt_* (preserves external\n" +
            "// ABI: self/bootstrap_compiler.c, build_c.hexa emit, codegen emit).\n" +
            "// ─────────────────────────────────────────────────────────────────────\n" +
            "\n" +
            "HexaVal rt_read_file(HexaVal path) {\n" +
            "    FILE* f = fopen(HX_STR(path), \"rb\");\n" +
            "    if (!f) return hexa_str(\"\");\n" +
            "    fseek(f, 0, SEEK_END);\n" +
            "    long len = ftell(f);\n" +
            "    fseek(f, 0, SEEK_SET);\n" +
            "    char* buf = malloc(len + 1);\n" +
            "    fread(buf, 1, len, f);\n" +
            "    buf[len] = 0;\n" +
            "    fclose(f);\n" +
            "    return hexa_str_own(buf);\n" +
            "}\n" +
            "\n" +
            "HexaVal rt_write_file(HexaVal path, HexaVal content) {\n" +
            "    FILE* f = fopen(HX_STR(path), \"wb\");\n" +
            "    if (!f) return hexa_bool(0);\n" +
            "    const char* s = HX_STR(content);\n" +
            "    size_t len = s ? hxlcl_strlen(s) : 0;\n" +
            "    fwrite(s, 1, len, f);\n" +
            "    fclose(f);\n" +
            "    return hexa_bool(1);\n" +
            "}\n" +
            "\n" +
            "// P7-6 builtin (2026-04-18): boolean existence probe. Used by native_build\n" +
            "// and other self-hosting scripts to gate optional inputs without a\n" +
            "// full read_file round-trip.\n" +
            "//\n" +
            "// ω-stdlib-2 (2026-04-26): refined to S_ISREG semantics, matching the\n" +
            "// portable_fs.hexa POSIX-wc contract that consumers were forced to alias\n" +
            "// around (pfs_file_exists). Previously used access(p, F_OK) which returns\n" +
            "// true for ANY path entry incl. directories / symlinks-to-dirs / sockets.\n" +
            "// Now: stat() + S_ISREG → true only for regular files. Null/missing/non-\n" +
            "// regular → false. No errno propagation.\n" +
            "HexaVal rt_file_exists(HexaVal path) {\n" +
            "    const char* p = HX_STR(path);\n" +
            "    if (!p) return hexa_bool(0);\n" +
            "    struct stat st;\n" +
            "    if (hxlcl_stat(p, &st) != 0) return hexa_bool(0);\n" +
            "    return hexa_bool(S_ISREG(st.st_mode) ? 1 : 0);\n" +
            "}\n" +
            "\n" +
            "// ── Binary file I/O — write_bytes / read_file_bytes ─────\n" +
            "// write_bytes: takes a path and a TAG_ARRAY of integers (0-255),\n" +
            "// writes raw bytes. Null bytes survive — true binary I/O.\n" +
            "HexaVal rt_write_bytes(HexaVal path, HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n" +
            "    int len = HX_ARR_LEN(arr);\n" +
            "    FILE* f = fopen(HX_STR(path), \"wb\");\n" +
            "    if (!f) return hexa_bool(0);\n" +
            "    if (len > 0) {\n" +
            "        unsigned char* buf = (unsigned char*)malloc(len);\n" +
            "        HexaVal* items = HX_ARR_ITEMS(arr);\n" +
            "        for (int i = 0; i < len; i++) {\n" +
            "            int64_t v = HX_IS_INT(items[i]) ? HX_INT(items[i]) : (int64_t)HX_FLOAT(items[i]);\n" +
            "            buf[i] = (unsigned char)(v & 0xFF);\n" +
            "        }\n" +
            "        fwrite(buf, 1, len, f);\n" +
            "        free(buf);\n" +
            "    }\n" +
            "    fclose(f);\n" +
            "    return hexa_bool(1);\n" +
            "}\n" +
            "\n" +
            "// rt_write_bytes_v: variant called from the interpreter dispatch where each\n" +
            "// array item is a TAG_VALSTRUCT (Val) rather than a raw HexaVal int. Reads\n" +
            "// the inner `int_val` field from each Val and writes the low byte. Without\n" +
            "// this, write_bytes from interpreted user code silently no-ops (HX_IS_INT\n" +
            "// fails on TAG_VALSTRUCT items) or — with the historical fputs path — UTF-8\n" +
            "// encodes each byte > 0x7F to two bytes. (2026-04-17)\n" +
            "HexaVal rt_write_bytes_v(HexaVal path, HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n" +
            "    int len = HX_ARR_LEN(arr);\n" +
            "    FILE* f = fopen(HX_STR(path), \"wb\");\n" +
            "    if (!f) return hexa_bool(0);\n" +
            "    if (len > 0) {\n" +
            "        unsigned char* buf = (unsigned char*)malloc(len);\n" +
            "        HexaVal* items = HX_ARR_ITEMS(arr);\n" +
            "        for (int i = 0; i < len; i++) {\n" +
            "            HexaVal item = items[i];\n" +
            "            int64_t v = 0;\n" +
            "            if (HX_IS_INT(item)) {\n" +
            "                v = HX_INT(item);\n" +
            "            } else if (HX_TAG(item) == TAG_FLOAT) {\n" +
            "                v = (int64_t)HX_FLOAT(item);\n" +
            "            } else if (HX_TAG(item) == TAG_VALSTRUCT) {\n" +
            "                HexaVal iv = hexa_valstruct_int(item);\n" +
            "                if (HX_IS_INT(iv)) {\n" +
            "                    v = HX_INT(iv);\n" +
            "                } else if (HX_TAG(iv) == TAG_FLOAT) {\n" +
            "                    v = (int64_t)HX_FLOAT(iv);\n" +
            "                }\n" +
            "            }\n" +
            "            buf[i] = (unsigned char)(v & 0xFF);\n" +
            "        }\n" +
            "        fwrite(buf, 1, len, f);\n" +
            "        free(buf);\n" +
            "    }\n" +
            "    fclose(f);\n" +
            "    return hexa_bool(1);\n" +
            "}\n" +
            "\n" +
            "// read_file_bytes: reads a file in binary mode and returns\n" +
            "// a TAG_ARRAY of integers (0-255), one per byte.\n" +
            "HexaVal rt_read_file_bytes(HexaVal path) {\n" +
            "    FILE* f = fopen(HX_STR(path), \"rb\");\n" +
            "    if (!f) return hexa_array_new();\n" +
            "    fseek(f, 0, SEEK_END);\n" +
            "    long len = ftell(f);\n" +
            "    fseek(f, 0, SEEK_SET);\n" +
            "    unsigned char* buf = (unsigned char*)malloc(len);\n" +
            "    fread(buf, 1, len, f);\n" +
            "    fclose(f);\n" +
            "    // Pre-allocate array with exact capacity\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (len > 0) {\n" +
            "        HX_SET_ARR_ITEMS(arr, (HexaVal*)malloc(sizeof(HexaVal) * len));\n" +
            "        HX_SET_ARR_CAP(arr, (int)len);\n" +
            "        HX_SET_ARR_LEN(arr, (int)len);\n" +
            "        HexaVal* items = HX_ARR_ITEMS(arr);\n" +
            "        for (long i = 0; i < len; i++) {\n" +
            "            items[i] = hexa_int((int64_t)buf[i]);\n" +
            "        }\n" +
            "    }\n" +
            "    free(buf);\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// ── P4 streaming builtins — read_bytes_at / write_bytes_append ─────\n" +
            "// Required for multi-GB safetensors→hexaw conversion on 14B Qwen2.5\n" +
            "// (8 shards × ~3.7GB each). Whole-file read_file_bytes cannot fit.\n" +
            "\n" +
            "// read_bytes_at(path, offset, nbytes): pread-style ranged read.\n" +
            "// Returns a TAG_ARRAY of at most `nbytes` ints (shorter if EOF reached\n" +
            "// or offset is past EOF). Empty array on fopen failure.\n" +
            "HexaVal rt_read_bytes_at(HexaVal path, HexaVal offset, HexaVal nbytes) {\n" +
            "    int64_t off = HX_IS_INT(offset) ? HX_INT(offset)\n" +
            "                : (HX_TAG(offset) == TAG_FLOAT ? (int64_t)HX_FLOAT(offset) : 0);\n" +
            "    int64_t req = HX_IS_INT(nbytes) ? HX_INT(nbytes)\n" +
            "                : (HX_TAG(nbytes) == TAG_FLOAT ? (int64_t)HX_FLOAT(nbytes) : 0);\n" +
            "    if (off < 0 || req <= 0) return hexa_array_new();\n" +
            "    FILE* f = fopen(HX_STR(path), \"rb\");\n" +
            "    if (!f) return hexa_array_new();\n" +
            "    // Use 64-bit seek where available; on macOS/Linux fseeko is standard.\n" +
            "#if defined(_WIN32)\n" +
            "    if (_fseeki64(f, (long long)off, SEEK_SET) != 0) { fclose(f); return hexa_array_new(); }\n" +
            "#else\n" +
            "    if (fseeko(f, (off_t)off, SEEK_SET) != 0) { fclose(f); return hexa_array_new(); }\n" +
            "#endif\n" +
            "    unsigned char* buf = (unsigned char*)malloc((size_t)req);\n" +
            "    size_t got = fread(buf, 1, (size_t)req, f);\n" +
            "    fclose(f);\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (got > 0) {\n" +
            "        HX_SET_ARR_ITEMS(arr, (HexaVal*)malloc(sizeof(HexaVal) * got));\n" +
            "        HX_SET_ARR_CAP(arr, (int)got);\n" +
            "        HX_SET_ARR_LEN(arr, (int)got);\n" +
            "        HexaVal* items = HX_ARR_ITEMS(arr);\n" +
            "        for (size_t i = 0; i < got; i++) {\n" +
            "            items[i] = hexa_int((int64_t)buf[i]);\n" +
            "        }\n" +
            "    }\n" +
            "    free(buf);\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// write_bytes_append(path, arr): append raw bytes from an int array\n" +
            "// to `path` (fopen \"ab\"), creating the file if needed. Returns bool.\n" +
            "// Mirrors rt_write_bytes (raw HexaVal int array path).\n" +
            "HexaVal rt_write_bytes_append(HexaVal path, HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n" +
            "    int len = HX_ARR_LEN(arr);\n" +
            "    FILE* f = fopen(HX_STR(path), \"ab\");\n" +
            "    if (!f) return hexa_bool(0);\n" +
            "    if (len > 0) {\n" +
            "        unsigned char* buf = (unsigned char*)malloc(len);\n" +
            "        HexaVal* items = HX_ARR_ITEMS(arr);\n" +
            "        for (int i = 0; i < len; i++) {\n" +
            "            int64_t v = HX_IS_INT(items[i]) ? HX_INT(items[i]) : (int64_t)HX_FLOAT(items[i]);\n" +
            "            buf[i] = (unsigned char)(v & 0xFF);\n" +
            "        }\n" +
            "        fwrite(buf, 1, len, f);\n" +
            "        free(buf);\n" +
            "    }\n" +
            "    fclose(f);\n" +
            "    return hexa_bool(1);\n" +
            "}\n" +
            "\n" +
            "// write_bytes_append_v(path, arr): variant for the interpreter dispatch\n" +
            "// where each array item is a TAG_VALSTRUCT (Val). Mirrors write_bytes_v.\n" +
            "HexaVal rt_write_bytes_append_v(HexaVal path, HexaVal arr) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n" +
            "    int len = HX_ARR_LEN(arr);\n" +
            "    FILE* f = fopen(HX_STR(path), \"ab\");\n" +
            "    if (!f) return hexa_bool(0);\n" +
            "    if (len > 0) {\n" +
            "        unsigned char* buf = (unsigned char*)malloc(len);\n" +
            "        HexaVal* items = HX_ARR_ITEMS(arr);\n" +
            "        for (int i = 0; i < len; i++) {\n" +
            "            HexaVal item = items[i];\n" +
            "            int64_t v = 0;\n" +
            "            if (HX_IS_INT(item)) {\n" +
            "                v = HX_INT(item);\n" +
            "            } else if (HX_TAG(item) == TAG_FLOAT) {\n" +
            "                v = (int64_t)HX_FLOAT(item);\n" +
            "            } else if (HX_TAG(item) == TAG_VALSTRUCT) {\n" +
            "                HexaVal iv = hexa_valstruct_int(item);\n" +
            "                if (HX_IS_INT(iv)) {\n" +
            "                    v = HX_INT(iv);\n" +
            "                } else if (HX_TAG(iv) == TAG_FLOAT) {\n" +
            "                    v = (int64_t)HX_FLOAT(iv);\n" +
            "                }\n" +
            "            }\n" +
            "            buf[i] = (unsigned char)(v & 0xFF);\n" +
            "        }\n" +
            "        fwrite(buf, 1, len, f);\n" +
            "        free(buf);\n" +
            "    }\n" +
            "    fclose(f);\n" +
            "    return hexa_bool(1);\n" +
            "}\n" +
            "\n" +
            "// file_size(path): native 64-bit file size without loading contents.\n" +
            "// Existing hexa_full dispatch read the whole file to count length — not\n" +
            "// viable for multi-GB safetensors shards.\n" +
            "//\n" +
            "// ω-stdlib-2 (2026-04-26): switched from fopen+fseeko/ftello to stat()\n" +
            "// for two reasons: (1) avoids opening the file at all — pure metadata\n" +
            "// query, no FD pressure, no platform-dependent fopen-on-directory\n" +
            "// behaviour; (2) aligns the missing-file convention with portable_fs.hexa\n" +
            "// (`pfs_file_size`, POSIX `wc -c`-based) which returns 0 for missing\n" +
            "// rather than -1. Consumers can now stop maintaining the pfs_* alias\n" +
            "// shadow layer. Directories / non-regular files also return 0 (size is\n" +
            "// only meaningful for regular files; callers needing dir-size must walk).\n" +
            "HexaVal rt_file_size(HexaVal path) {\n" +
            "    const char* p = HX_STR(path);\n" +
            "    if (!p) return hexa_int(0);\n" +
            "    struct stat st;\n" +
            "    if (hxlcl_stat(p, &st) != 0) return hexa_int(0);\n" +
            "    if (!S_ISREG(st.st_mode)) return hexa_int(0);\n" +
            "    return hexa_int((int64_t)st.st_size);\n" +
            "}\n" +
            "\n" +
            "// ── Command line arguments ───────────────────────────\n" +
            "\n" +
            "static int _hexa_argc = 0;\n" +
            "static char** _hexa_argv = NULL;\n" +
            "\n" +
            "void hexa_set_args(int argc, char** argv) {\n" +
            "    // S1-D2: init TAG_FN shim globals before user code touches them.\n" +
            "    _hexa_init_fn_shims();\n" +
            "    // RFC 062 (2026-05-19): argv stored verbatim — no argv[0] duplication.\n" +
            "    // The historical double-insert ([exec, exec, sub, ...]) existed only to\n" +
            "    // match the tree-walking interpreter's [\"hexa\", \"script\", args...] index\n" +
            "    // layout. R7 retired the interpreter, so args() is now the clean\n" +
            "    // [exec, user-args...] layout. See RFC 062 / ROADMAP self-host child 65.\n" +
            "    _hexa_argc = argc;\n" +
            "    _hexa_argv = (char**)malloc(sizeof(char*) * (argc > 0 ? argc : 1));\n" +
            "    for (int i = 0; i < argc; i++) {\n" +
            "        _hexa_argv[i] = argv[i];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_args() {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    for (int i = 0; i < _hexa_argc; i++) {\n" +
            "        arr = hexa_array_push(arr, hexa_str(_hexa_argv[i]));\n" +
            "    }\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// Canonical argv API (roadmap 65 / M3, anima hxa-20260423-003 §3 M3).\n" +
            "// RFC 062 (argv[0] dedup) flipped args() to the clean [exec, user...]\n" +
            "// layout, so these helpers index from 1 (exec at 0, user args at 1..).\n" +
            "// script_path() = the thing that was launched, real_args() = user\n" +
            "// arguments only, identical across AOT/stage0.\n" +
            "HexaVal hexa_script_path() {\n" +
            "    // RFC 062: post-dedup layout — argv[0] is the launched executable.\n" +
            "    if (_hexa_argc < 1 || _hexa_argv[0] == NULL) return hexa_str(\"\");\n" +
            "    return hexa_str(_hexa_argv[0]);\n" +
            "}\n" +
            "\n" +
            "HexaVal hexa_real_args() {\n" +
            "    // RFC 062: post-dedup layout [exec, user-args...] — user args start at\n" +
            "    // index 1 (was 2 under the doubled [exec, exec, ...] layout). The\n" +
            "    // returned list is unchanged across the dedup.\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    int start = (_hexa_argc >= 1) ? 1 : _hexa_argc;\n" +
            "    for (int i = start; i < _hexa_argc; i++) {\n" +
            "        arr = hexa_array_push(arr, hexa_str(_hexa_argv[i]));\n" +
            "    }\n" +
            "    return arr;\n" +
            "}\n" +
            "\n" +
            "// ── Float operations ─────────────────────────────────\n" +
            "\n" +
            "#include <math.h>\n" +
            "\n" +
            "// T39: math helpers route through __hx_to_double so TAG_VALSTRUCT\n" +
            "// wrappers (interpreter Vals) don't cast vs pointer bits to double.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_sqrt(HexaVal v) {\n" +
            "    return hexa_float(sqrt(__hx_to_double(v)));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_sqrt(HexaVal v);\n" +
            "HexaVal hexa_sqrt(HexaVal v) {\n" +
            "    return rt_sqrt(hexa_float(__hx_to_double(v)));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_pow(HexaVal base, HexaVal exp) {\n" +
            "    // Integer fast-path: int^int with non-negative exponent stays int\n" +
            "    if (HX_IS_INT(base) && HX_IS_INT(exp) && HX_INT(exp) >= 0) {\n" +
            "        int64_t b = HX_INT(base), e = HX_INT(exp), r = 1;\n" +
            "        while (e > 0) { if (e & 1) r *= b; b *= b; e >>= 1; }\n" +
            "        return hexa_int(r);\n" +
            "    }\n" +
            "    return hexa_float(pow(__hx_to_double(base), __hx_to_double(exp)));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_pow_int(HexaVal b, HexaVal e);\n" +
            "extern HexaVal rt_pow_float(HexaVal b, HexaVal e);\n" +
            "HexaVal hexa_pow(HexaVal base, HexaVal exp) {\n" +
            "    if (HX_IS_INT(base) && HX_IS_INT(exp) && HX_INT(exp) >= 0) {\n" +
            "        return rt_pow_int(base, exp);\n" +
            "    }\n" +
            "    return rt_pow_float(hexa_float(__hx_to_double(base)),\n" +
            "                        hexa_float(__hx_to_double(exp)));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step 3 cycle 2 — hexa_floor/ceil/u_floor delegate to hexa-source.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_floor(HexaVal v) {\n" +
            "    return hexa_int((int64_t)floor(__hx_to_double(v)));\n" +
            "}\n" +
            "HexaVal hexa_u_floor(HexaVal a, HexaVal b) {\n" +
            "    int64_t ai = HX_IS_INT(a) ? HX_INT(a) : (int64_t)__hx_to_double(a);\n" +
            "    int64_t bi = HX_IS_INT(b) ? HX_INT(b) : (int64_t)__hx_to_double(b);\n" +
            "    if (bi == 0) return hexa_int(0);\n" +
            "    int64_t q = ai / bi;\n" +
            "    int64_t r = ai % bi;\n" +
            "    if (r != 0 && ((ai < 0) != (bi < 0))) q -= 1;\n" +
            "    return hexa_int(q);\n" +
            "}\n" +
            "HexaVal hexa_ceil(HexaVal v) {\n" +
            "    return hexa_int((int64_t)ceil(__hx_to_double(v)));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_floor(HexaVal v);\n" +
            "extern HexaVal rt_ceil(HexaVal v);\n" +
            "extern HexaVal rt_u_floor(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_floor(HexaVal v) {\n" +
            "    return rt_floor(hexa_float(__hx_to_double(v)));\n" +
            "}\n" +
            "HexaVal hexa_ceil(HexaVal v) {\n" +
            "    return rt_ceil(hexa_float(__hx_to_double(v)));\n" +
            "}\n" +
            "HexaVal hexa_u_floor(HexaVal a, HexaVal b) {\n" +
            "    int64_t ai = HX_IS_INT(a) ? HX_INT(a) : (int64_t)__hx_to_double(a);\n" +
            "    int64_t bi = HX_IS_INT(b) ? HX_INT(b) : (int64_t)__hx_to_double(b);\n" +
            "    return rt_u_floor(hexa_int(ai), hexa_int(bi));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// RUNTIME.md step-3 cycle 1 POC — first HI-tier hexa-source delegation\n" +
            "// from runtime_core.c. Source of truth: stdlib/runtime/numeric.hexa\n" +
            "// (rt_abs_int + rt_abs_float). #ifndef guard mirrors step-2 pattern:\n" +
            "// standalone build keeps C body; ap_post.c gets HEXA_HAS_HEXA_RT_STDLIB\n" +
            "// → hexa-emitted bodies win as strong symbols.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_abs(HexaVal v) {\n" +
            "    if (HX_IS_INT(v)) return hexa_int(HX_INT(v) < 0 ? -HX_INT(v) : HX_INT(v));\n" +
            "    return hexa_float(fabs(HX_FLOAT(v)));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_abs_int(HexaVal v);\n" +
            "extern HexaVal rt_abs_float(HexaVal v);\n" +
            "HexaVal hexa_abs(HexaVal v) {\n" +
            "    if (HX_IS_INT(v)) return rt_abs_int(v);\n" +
            "    return rt_abs_float(v);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// P7-6 math coverage (2026-04-19): transcendentals + rounding + conversions\n" +
            "// used by training/inference codegen. All route through __hx_to_double to\n" +
            "// unwrap TAG_VALSTRUCT wrappers (same pattern as hexa_sqrt).\n" +
            "\n" +
            "HexaVal hexa_sin(HexaVal v)   { return hexa_float(hxlcl_sin(__hx_to_double(v))); }\n" +
            "HexaVal hexa_cos(HexaVal v)   { return hexa_float(hxlcl_cos(__hx_to_double(v))); }\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_tan(HexaVal v)   { return hexa_float(tan(__hx_to_double(v))); }\n" +
            "#else\n" +
            "extern HexaVal rt_tan(HexaVal x);\n" +
            "HexaVal hexa_tan(HexaVal v)   { return rt_tan(hexa_float(__hx_to_double(v))); }\n" +
            "#endif\n" +
            "HexaVal hexa_exp(HexaVal v)   { return hexa_float(hxlcl_exp(__hx_to_double(v))); }\n" +
            "HexaVal hexa_log(HexaVal v)   { return hexa_float(hxlcl_log(__hx_to_double(v))); }\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_log10(HexaVal v) { return hexa_float(log10(__hx_to_double(v))); }\n" +
            "#else\n" +
            "extern HexaVal rt_log10(HexaVal x);\n" +
            "HexaVal hexa_log10(HexaVal v) { return rt_log10(hexa_float(__hx_to_double(v))); }\n" +
            "#endif\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_round(HexaVal v) { return hexa_int((int64_t)llround(__hx_to_double(v))); }\n" +
            "#else\n" +
            "extern HexaVal rt_round(HexaVal v);\n" +
            "HexaVal hexa_round(HexaVal v) { return rt_round(hexa_float(__hx_to_double(v))); }\n" +
            "#endif\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_tanh(HexaVal v)  { return hexa_float(tanh(__hx_to_double(v))); }\n" +
            "#else\n" +
            "extern HexaVal rt_tanh(HexaVal x);\n" +
            "HexaVal hexa_tanh(HexaVal v)  { return rt_tanh(hexa_float(__hx_to_double(v))); }\n" +
            "#endif\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_log2(HexaVal v)  { return hexa_float(log2(__hx_to_double(v))); }\n" +
            "#else\n" +
            "extern HexaVal rt_log2(HexaVal x);\n" +
            "HexaVal hexa_log2(HexaVal v)  { return rt_log2(hexa_float(__hx_to_double(v))); }\n" +
            "#endif\n" +
            "\n" +
            "// to_float: coerce any scalar to float. Step-3 cycle 13 port.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_to_float(HexaVal v) {\n" +
            "    return hexa_float(__hx_to_double(v));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_to_float(HexaVal v);\n" +
            "HexaVal hexa_to_float(HexaVal v) {\n" +
            "    return rt_to_float(hexa_float(__hx_to_double(v)));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// to_int: coerce any scalar to int (truncate toward zero for floats)\n" +
            "// RUNTIME.md Step 4 .c-none: hexa_to_int delegates to hexa-source rt_to_int\n" +
            "// (numeric.hexa) under HEXA_HAS_HEXA_RT_STDLIB. __raw_d2i is the float→int truncate\n" +
            "// escape (the C `(int64_t)HX_FLOAT` cast can't be expressed in hexa source). #else C\n" +
            "// body kept bit-for-bit.\n" +
            "static inline HexaVal __raw_d2i(HexaVal v) { return hexa_int((int64_t)__hx_to_double(v)); }\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_to_int(HexaVal v);\n" +
            "HexaVal hexa_to_int(HexaVal v) { return rt_to_int(v); }\n" +
            "#else\n" +
            "HexaVal hexa_to_int(HexaVal v) {\n" +
            "    if (HX_IS_INT(v)) return v;\n" +
            "    if (HX_IS_FLOAT(v)) return hexa_int((int64_t)HX_FLOAT(v));\n" +
            "    // String → int fallback via existing parser\n" +
            "    if (HX_IS_STR(v)) return hexa_str_parse_int(v);\n" +
            "    return hexa_int((int64_t)__hx_to_double(v));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ── String format ────────────────────────────────────\n" +
            "\n" +
            "// Multi-arg format: hexa_format_n(fmt, args_array)\n" +
            "// Step-3 cycle 62 port — single-arg `{}` substitution dispatches to\n" +
            "// rt_format. The polymorphic `hexa_to_string(arg)` coercion stays\n" +
            "// C-side; the hexa fn receives both args as string.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_format(HexaVal fmt, HexaVal arg) {\n" +
            "    // Delegate to multi-arg path so brace-escape (`{{` → `{`,\n" +
            "    // `}}` → `}`) works uniformly in both single- and multi-arg\n" +
            "    // formats.  The prior strstr-based path silently emitted\n" +
            "    // `{{}}` literally instead of `{}`.\n" +
            "    if (!HX_IS_STR(fmt)) return fmt;\n" +
            "    HexaVal args = hexa_array_new();\n" +
            "    args = hexa_array_push(args, arg);\n" +
            "    return hexa_format_n(fmt, args);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_format(HexaVal fmt, HexaVal sarg);\n" +
            "HexaVal hexa_format(HexaVal fmt, HexaVal arg) {\n" +
            "    if (!HX_IS_STR(fmt)) return fmt;\n" +
            "    HexaVal sarg = hexa_to_string(arg);\n" +
            "    return rt_format(fmt, sarg);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "HexaVal hexa_format_n(HexaVal fmt, HexaVal args) {\n" +
            "    // Multi-arg: replace {} and {:.N} with successive args\n" +
            "    if (!HX_IS_STR(fmt) || !HX_IS_ARRAY(args)) return fmt;\n" +
            "    size_t cap = HX_STRLEN(fmt) * 4 + HX_ARR_LEN(args) * 64 + 256;\n" +
            "    char* result = malloc(cap);\n" +
            "    size_t total = 0;\n" +
            "    result[0] = 0;\n" +
            "    char* src = HX_STR(fmt);\n" +
            "    int ai = 0;\n" +
            "    while (*src) {\n" +
            "        // Brace escape — `{{` emits `{`, `}}` emits `}`.  Without this\n" +
            "        // a Rust-style format string `\"{{}}\"` produced `{{}}` literal\n" +
            "        // instead of `{}`.  Round-5 string-format probe finding.\n" +
            "        if (src[0] == '{' && src[1] == '{') {\n" +
            "            while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "            result[total++] = '{';\n" +
            "            result[total] = 0;\n" +
            "            src += 2;\n" +
            "            continue;\n" +
            "        }\n" +
            "        if (src[0] == '}' && src[1] == '}') {\n" +
            "            while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "            result[total++] = '}';\n" +
            "            result[total] = 0;\n" +
            "            src += 2;\n" +
            "            continue;\n" +
            "        }\n" +
            "        if (src[0] == '{' && ai < HX_ARR_LEN(args)) {\n" +
            "            // Find closing }\n" +
            "            char* close = hxlcl_strchr(src, '}');\n" +
            "            if (close) {\n" +
            "                int speclen = (int)(close - src - 1);\n" +
            "                char spec[32] = {0};\n" +
            "                if (speclen > 0 && speclen < 31) hxlcl_memcpy(spec, src+1, speclen);\n" +
            "                char buf[128];\n" +
            "                HexaVal arg = HX_ARR_ITEMS(args)[ai++];\n" +
            "                if (spec[0] == ':' && spec[1] == '.') {\n" +
            "                    // Precision format {:.N} or {:.Nf}\n" +
            "                    int prec = hxlcl_atoi(spec + 2);\n" +
            "                    double val = HX_IS_FLOAT(arg) ? HX_FLOAT(arg) : (double)HX_INT(arg);\n" +
            "                    snprintf(buf, sizeof(buf), \"%.*f\", prec, val);\n" +
            "                } else if (spec[0] == ':') {\n" +
            "                    // Width/pad/int-suffix format: {:N} {:<N} {:>N} {:0N} {:Nd}\n" +
            "                    // Strategy: render arg via hexa_to_string, then pad/truncate\n" +
            "                    // to a width parsed from the spec body.\n" +
            "                    const char* p = spec + 1;\n" +
            "                    char align = 'R';                           // numeric default\n" +
            "                    char fill  = ' ';\n" +
            "                    if (*p == '<') { align = 'L'; p++; }\n" +
            "                    else if (*p == '>') { align = 'R'; p++; }\n" +
            "                    else if (*p == '^') { align = 'C'; p++; }\n" +
            "                    if (*p == '0' && p[1] != 0) { fill = '0'; p++; }\n" +
            "                    int width = 0;\n" +
            "                    while (*p >= '0' && *p <= '9') { width = width * 10 + (*p - '0'); p++; }\n" +
            "                    // ignore trailing type char ('d'/'s'/'f')\n" +
            "                    HexaVal s = hexa_to_string(arg);\n" +
            "                    int slen = (int)HX_STRLEN(s);\n" +
            "                    int pad = width > slen ? width - slen : 0;\n" +
            "                    int bp = 0;\n" +
            "                    if (align == 'L') {\n" +
            "                        hxlcl_memcpy(buf + bp, HX_STR(s), slen); bp += slen;\n" +
            "                        for (int q = 0; q < pad && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n" +
            "                    } else if (align == 'C') {\n" +
            "                        int lp = pad / 2, rp = pad - lp;\n" +
            "                        for (int q = 0; q < lp && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n" +
            "                        hxlcl_memcpy(buf + bp, HX_STR(s), slen); bp += slen;\n" +
            "                        for (int q = 0; q < rp && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n" +
            "                    } else {\n" +
            "                        for (int q = 0; q < pad && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n" +
            "                        hxlcl_memcpy(buf + bp, HX_STR(s), slen); bp += slen;\n" +
            "                    }\n" +
            "                    if (bp >= (int)sizeof(buf)) bp = sizeof(buf) - 1;\n" +
            "                    buf[bp] = 0;\n" +
            "                } else if (spec[0] == 0) {\n" +
            "                    // Simple {}\n" +
            "                    HexaVal s = hexa_to_string(arg);\n" +
            "                    hxlcl_strncpy(buf, HX_STR(s), sizeof(buf)-1); buf[sizeof(buf)-1]=0;\n" +
            "                } else {\n" +
            "                    // Indexed {N} — best-effort; non-numeric falls through to to_string\n" +
            "                    HexaVal s = hexa_to_string(arg);\n" +
            "                    hxlcl_strncpy(buf, HX_STR(s), sizeof(buf)-1); buf[sizeof(buf)-1]=0;\n" +
            "                }\n" +
            "                size_t blen = hxlcl_strlen(buf);\n" +
            "                while (total + blen + 1 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "                hxlcl_memcpy(result + total, buf, blen);\n" +
            "                total += blen;\n" +
            "                result[total] = 0;\n" +
            "                src = close + 1;\n" +
            "            } else {\n" +
            "                while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "                result[total++] = *src;\n" +
            "                result[total] = 0;\n" +
            "                src++;\n" +
            "            }\n" +
            "        } else {\n" +
            "            while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "            result[total++] = *src;\n" +
            "            result[total] = 0;\n" +
            "            src++;\n" +
            "        }\n" +
            "    }\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "\n" +
            "// ── String split ─────────────────────────────────────\n" +
            "\n" +
            "// Step-3 cycle 45 port — string split dispatches to rt_str_split. The\n" +
            "// hexa path scans byte-by-byte (no strstr) and avoids the strdup/free\n" +
            "// pair the C body uses for the in-place NUL terminator trick.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_split(HexaVal s, HexaVal delim) {\n" +
            "    HexaVal arr = hexa_array_new();\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(delim)) return arr;\n" +
            "    char* src = hxlcl_strdup(HX_STR(s));\n" +
            "    char* d = HX_STR(delim);\n" +
            "    int dlen = hxlcl_strlen(d);\n" +
            "    char* pos = src;\n" +
            "    while (1) {\n" +
            "        char* found = hxlcl_strstr(pos, d);\n" +
            "        if (!found) { arr = hexa_array_push(arr, hexa_str(pos)); break; }\n" +
            "        *found = 0;\n" +
            "        arr = hexa_array_push(arr, hexa_str(pos));\n" +
            "        pos = found + dlen;\n" +
            "    }\n" +
            "    free(src);\n" +
            "    return arr;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_split(HexaVal s, HexaVal delim);\n" +
            "HexaVal hexa_str_split(HexaVal s, HexaVal delim) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(delim)) return hexa_array_new();\n" +
            "    return rt_str_split(s, delim);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────────────\n" +
            "// M1-lite (hxa-20260423-003 Step 4): rt_str_* layer — GENERATED from\n" +
            "// self/runtime_hi.hexa via tool/extract_runtime_hi.sh. Included below\n" +
            "// in the hexa_str_join region (where rt_str_* dependencies are ready).\n" +
            "// hexa_str_* shims forward to rt_str_* after the include.\n" +
            "// ─────────────────────────────────────────────────────────────────────\n" +
            "\n" +
            "// M1 full · str_ext Step 5 (hxa-20260423-003): rt_str_trim — codegen\n" +
            "// emits rt_str_* directly; hexa_str_trim shim retired.\n" +
            "// Step-3 cycle 49 — rt_str_trim moves to hexa source. C body stays\n" +
            "// for the no-stdlib path.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal rt_str_trim(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return s;\n" +
            "    char* str = HX_STR(s);\n" +
            "    while (*str == ' ' || *str == '\\t' || *str == '\\n' || *str == '\\r') str++;\n" +
            "    int len = hxlcl_strlen(str);\n" +
            "    while (len > 0 && (str[len-1] == ' ' || str[len-1] == '\\t' || str[len-1] == '\\n' || str[len-1] == '\\r')) len--;\n" +
            "    char* result = hxlcl_strndup(str, len);\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 44 port — string replace-all dispatches to rt_str_replace\n" +
            "// in stdlib/runtime/ctype.hexa. The hexa path is O(n*m) (no strstr;\n" +
            "// byte-by-byte match) and uses `+` concat (no preallocated buffer);\n" +
            "// acceptable trade-off for hexa-native landing, matches the cycle-\n" +
            "// 2/4 precision/perf budget.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_replace(HexaVal s, HexaVal old, HexaVal new_s) {\n" +
            "    if (!HX_IS_STR(s)) return s;\n" +
            "    size_t cap = HX_STRLEN(s) * 2 + 1;\n" +
            "    char* result = malloc(cap);\n" +
            "    size_t total = 0;\n" +
            "    result[0] = 0;\n" +
            "    char* pos = HX_STR(s);\n" +
            "    int oldlen = (int)HX_STRLEN(old);\n" +
            "    size_t newlen = HX_STRLEN(new_s);\n" +
            "    while (1) {\n" +
            "        char* found = hxlcl_strstr(pos, HX_STR(old));\n" +
            "        if (!found) {\n" +
            "            size_t rlen = hxlcl_strlen(pos);\n" +
            "            while (total + rlen + 1 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "            hxlcl_memcpy(result + total, pos, rlen);\n" +
            "            total += rlen;\n" +
            "            result[total] = 0;\n" +
            "            break;\n" +
            "        }\n" +
            "        size_t seg = (size_t)(found - pos);\n" +
            "        while (total + seg + newlen + 1 > cap) { cap *= 2; result = realloc(result, cap); }\n" +
            "        hxlcl_memcpy(result + total, pos, seg);\n" +
            "        total += seg;\n" +
            "        hxlcl_memcpy(result + total, HX_STR(new_s), newlen);\n" +
            "        total += newlen;\n" +
            "        result[total] = 0;\n" +
            "        pos = found + oldlen;\n" +
            "    }\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_replace(HexaVal s, HexaVal old, HexaVal new_s);\n" +
            "HexaVal hexa_str_replace(HexaVal s, HexaVal old, HexaVal new_s) {\n" +
            "    if (!HX_IS_STR(s)) return s;\n" +
            "    if (!HX_IS_STR(old) || !HX_IS_STR(new_s)) return s;\n" +
            "    return rt_str_replace(s, old, new_s);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// M1 full · str_ext Step 5 (hxa-20260423-003): rt_str_to_upper/lower —\n" +
            "// codegen emits rt_str_* directly; hexa_str_to_upper/lower shims retired.\n" +
            "// Step-3 cycle 50 — both move to hexa source. C bodies stay for the\n" +
            "// no-stdlib path.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal rt_str_to_upper(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return s;\n" +
            "    char* r = hxlcl_strdup(HX_STR(s));\n" +
            "    for (int i = 0; r[i]; i++) if (r[i] >= 'a' && r[i] <= 'z') r[i] -= 32;\n" +
            "    return hexa_str_own(r);\n" +
            "}\n" +
            "\n" +
            "HexaVal rt_str_to_lower(HexaVal s) {\n" +
            "    if (!HX_IS_STR(s)) return s;\n" +
            "    char* r = hxlcl_strdup(HX_STR(s));\n" +
            "    for (int i = 0; r[i]; i++) if (r[i] >= 'A' && r[i] <= 'Z') r[i] += 32;\n" +
            "    return hexa_str_own(r);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 43 port — float-style fast-path for all-string arrays\n" +
            "// dispatches to rt_str_join_str (ctype.hexa). Mixed-type arrays still\n" +
            "// need hexa_to_string() coercion per element — that path stays C-side.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_join(HexaVal arr, HexaVal sep) {\n" +
            "    if (!HX_IS_ARRAY(arr) || HX_ARR_LEN(arr) == 0) return hexa_str(\"\");\n" +
            "    size_t total_size = 0;\n" +
            "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n" +
            "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n" +
            "        total_size += HX_STRLEN(s);\n" +
            "    }\n" +
            "    size_t seplen = HX_STRLEN(sep);\n" +
            "    total_size += (HX_ARR_LEN(arr) - 1) * seplen;\n" +
            "    char* result = malloc(total_size + 1);\n" +
            "    size_t total = 0;\n" +
            "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n" +
            "        if (i > 0) {\n" +
            "            hxlcl_memcpy(result + total, HX_STR(sep), seplen);\n" +
            "            total += seplen;\n" +
            "        }\n" +
            "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n" +
            "        size_t slen = HX_STRLEN(s);\n" +
            "        hxlcl_memcpy(result + total, HX_STR(s), slen);\n" +
            "        total += slen;\n" +
            "    }\n" +
            "    result[total] = 0;\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_join_str(HexaVal arr, HexaVal sep);\n" +
            "static int _arr_all_str_join(HexaVal arr) {\n" +
            "    int64_t n = HX_ARR_LEN(arr);\n" +
            "    for (int64_t i = 0; i < n; i++) {\n" +
            "        if (!HX_IS_STR(HX_ARR_ITEMS(arr)[i])) return 0;\n" +
            "    }\n" +
            "    return 1;\n" +
            "}\n" +
            "HexaVal hexa_str_join(HexaVal arr, HexaVal sep) {\n" +
            "    if (!HX_IS_ARRAY(arr) || HX_ARR_LEN(arr) == 0) return hexa_str(\"\");\n" +
            "    if (HX_IS_STR(sep) && _arr_all_str_join(arr)) {\n" +
            "        return rt_str_join_str(arr, sep);\n" +
            "    }\n" +
            "    size_t total_size = 0;\n" +
            "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n" +
            "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n" +
            "        total_size += HX_STRLEN(s);\n" +
            "    }\n" +
            "    size_t seplen = HX_STRLEN(sep);\n" +
            "    total_size += (HX_ARR_LEN(arr) - 1) * seplen;\n" +
            "    char* result = malloc(total_size + 1);\n" +
            "    size_t total = 0;\n" +
            "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n" +
            "        if (i > 0) {\n" +
            "            hxlcl_memcpy(result + total, HX_STR(sep), seplen);\n" +
            "            total += seplen;\n" +
            "        }\n" +
            "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n" +
            "        size_t slen = HX_STRLEN(s);\n" +
            "        hxlcl_memcpy(result + total, HX_STR(s), slen);\n" +
            "        total += slen;\n" +
            "    }\n" +
            "    result[total] = 0;\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ─────────────────────────────────────────────────────────────────────\n" +
            "// M1-lite (hxa-20260423-003 Step 4): rt_str_* layer from runtime_hi.hexa\n" +
            "// SSOT. Must appear AFTER hexa_str_join (depended on by pad_left/pad_right/\n" +
            "// repeat/center) and AFTER hexa_str_substring (depended on by rt_str_split).\n" +
            "// Shims below forward the public hexa_str_* symbols to the generated\n" +
            "// rt_str_* implementations.\n" +
            "// ─────────────────────────────────────────────────────────────────────\n" +
            "#include \"runtime_hi_gen.c\"\n" +
            "// Step 5 (hxa-20260423-003): hexa_str_lines/repeat/pad_left/pad_right/center\n" +
            "// shims removed — codegen now dispatches directly to rt_str_* from\n" +
            "// runtime_hi_gen.c (SSOT: self/runtime_hi.hexa). See self/codegen.hexa\n" +
            "// cg_string_sym \"c\" branch (lines 250-272).\n" +
            "\n" +
            "static int utf8_cpcount(const char* s) {\n" +
            "    int n = 0;\n" +
            "    for (int i = 0; s[i]; i++) if ((s[i] & 0xC0) != 0x80) n++;\n" +
            "    return n;\n" +
            "}\n" +
            "// Step-3 cycle 51 port — pad_left dispatches to rt_pad_left. The\n" +
            "// hexa_to_string polymorphic coercion stays C-side (hexa-source\n" +
            "// param is string-typed); the actual padding work is hexa-source.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_pad_left(HexaVal s, HexaVal width) {\n" +
            "    HexaVal str = hexa_to_string(s);\n" +
            "    int w = HX_INT(width);\n" +
            "    int cplen = utf8_cpcount(HX_STR(str));\n" +
            "    int bytelen = (int)HX_STRLEN(str);\n" +
            "    if (cplen >= w) return str;\n" +
            "    int pad = w - cplen;\n" +
            "    char* result = malloc(bytelen + pad + 1);\n" +
            "    hxlcl_memset(result, ' ', pad);\n" +
            "    hxlcl_strcpy(result + pad, HX_STR(str));\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_pad_left(HexaVal s, HexaVal width);\n" +
            "HexaVal hexa_pad_left(HexaVal s, HexaVal width) {\n" +
            "    HexaVal str = hexa_to_string(s);\n" +
            "    return rt_pad_left(str, width);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "\n" +
            "// Bootstrap shim: hexa-level `join(arr, sep)` free-fn idiom in SSOT modules\n" +
            "// emits `hexa_call2(join, arr, sep)` via TAG_FN lookup. Once hexat is rebuilt\n" +
            "// from codegen.hexa's join-builtin dispatch, this becomes unused.\n" +
            "// (`split` was retired 2026-04-21 — codegen now emits hexa_str_split directly.)\n" +
            "static HexaVal join;\n" +
            "\n" +
            "// Step-3 cycle 51 port — pad_right symmetric to pad_left.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_pad_right(HexaVal s, HexaVal width) {\n" +
            "    HexaVal str = hexa_to_string(s);\n" +
            "    int w = HX_INT(width);\n" +
            "    int cplen = utf8_cpcount(HX_STR(str));\n" +
            "    int bytelen = (int)HX_STRLEN(str);\n" +
            "    if (cplen >= w) return str;\n" +
            "    int pad = w - cplen;\n" +
            "    char* result = malloc(bytelen + pad + 1);\n" +
            "    hxlcl_strcpy(result, HX_STR(str));\n" +
            "    hxlcl_memset(result + bytelen, ' ', pad);\n" +
            "    result[bytelen + pad] = 0;\n" +
            "    return hexa_str_own(result);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_pad_right(HexaVal s, HexaVal width);\n" +
            "HexaVal hexa_pad_right(HexaVal s, HexaVal width) {\n" +
            "    HexaVal str = hexa_to_string(s);\n" +
            "    return rt_pad_right(str, width);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// B-19: Polymorphic arithmetic — T39 routes through __hx_to_double.\n" +
            "// ROI-47: explicit float+float fast path avoids 2x __hx_to_double tag dispatch.\n" +
            "// Bool → int coercion shared across sub/mul/div/mod (Python canonical).\n" +
            "// Without this, `true * 5` fell to __hx_to_double which returned 0.0 (no bool\n" +
            "// branch) → silently 0.  Now bool first promotes to int before the int/int\n" +
            "// fast path, keeping the result type consistent with `hexa_add_slow`.\n" +
            "#define _HX_COERCE_BOOL(_a, _b) do { \\\n" +
            "    if (HX_IS_BOOL(_a)) _a = hexa_int(HX_BOOL(_a) ? 1 : 0); \\\n" +
            "    if (HX_IS_BOOL(_b)) _b = hexa_int(HX_BOOL(_b) ? 1 : 0); \\\n" +
            "} while (0)\n" +
            "// RUNTIME.md step-4 / .c-none — arithmetic core moved C → hexa (shape-2, full\n" +
            "// dispatch in hexa). Under HEXA_HAS_HEXA_RT_STDLIB hexa_sub delegates to hexa-\n" +
            "// source rt_sub (stdlib/runtime/numeric.hexa); the #else C body (bit-for-bit)\n" +
            "// stays for standalone/smoke. rt_sub returns via typed helpers (rt_sub_int/float)\n" +
            "// so no bare-native-scalar return (the attempt-1 crash, #1214). Emit-path →\n" +
            "// gen1≡gen2 fixpoint MUST hold (gated before merge). NOTE the throw message text\n" +
            "// differs (hexa uses type-name strings vs C's \"tag %d\") — prefix preserved.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_sub(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_sub(HexaVal a, HexaVal b) { return rt_sub(a, b); }\n" +
            "#else\n" +
            "HexaVal hexa_sub(HexaVal a, HexaVal b) {\n" +
            "    _HX_COERCE_BOOL(a, b);\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b)) return hexa_int(HX_INT(a) - HX_INT(b));\n" +
            "    if (HX_IS_FLOAT(a) && HX_IS_FLOAT(b)) return hexa_float(HX_FLOAT(a) - HX_FLOAT(b));\n" +
            "    // PROBE r16 (#807 sibling): a non-numeric operand (e.g. string) is a TYPE\n" +
            "    // ERROR, not a silent number. Before this guard `\"ab\" - 3` quietly returned\n" +
            "    // -3.0 because __hx_to_double() coerces a string to 0.0. Go/Rust canonical.\n" +
            "    // Mixed int/float still promotes through the __hx_to_double fallback below.\n" +
            "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n" +
            "        char _buf[96];\n" +
            "        snprintf(_buf, sizeof(_buf), \"cannot subtract non-numeric operand (tag %d - tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_float(0.0);\n" +
            "    }\n" +
            "    return hexa_float(__hx_to_double(a) - __hx_to_double(b));\n" +
            "}\n" +
            "#endif\n" +
            "// RUNTIME.md step-4 / .c-none — arith core op 2 moved C → hexa. Under\n" +
            "// HEXA_HAS_HEXA_RT_STDLIB hexa_mul delegates to hexa-source rt_mul (numeric.hexa,\n" +
            "// same shape as rt_sub #1217); #else C body kept. Emit-path → byte-identity gated.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_mul(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_mul(HexaVal a, HexaVal b) { return rt_mul(a, b); }\n" +
            "#else\n" +
            "HexaVal hexa_mul(HexaVal a, HexaVal b) {\n" +
            "    _HX_COERCE_BOOL(a, b);\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b)) return hexa_int(HX_INT(a) * HX_INT(b));\n" +
            "    if (HX_IS_FLOAT(a) && HX_IS_FLOAT(b)) return hexa_float(HX_FLOAT(a) * HX_FLOAT(b));\n" +
            "    // PROBE r16 (2026-05-25): a non-numeric operand (e.g. string) is a TYPE\n" +
            "    // ERROR, not a silent 0.0. Before this guard `\"ab\" * 3` quietly returned\n" +
            "    // 0.0 because __hx_to_double() coerces a string to 0.0. Go/Rust canonical —\n" +
            "    // `str * int` does not compile; Python's string-repeat is intentionally NOT\n" +
            "    // adopted (hexa has no operator-overload prelude for it). Mixed int/float\n" +
            "    // still promotes through the fallback below.\n" +
            "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n" +
            "        char _buf[96];\n" +
            "        snprintf(_buf, sizeof(_buf), \"cannot multiply non-numeric operand (tag %d * tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_float(0.0);\n" +
            "    }\n" +
            "    return hexa_float(__hx_to_double(a) * __hx_to_double(b));\n" +
            "}\n" +
            "#endif\n" +
            "// FMA: fused multiply-add — fma(a,b,c) = a*b + c\n" +
            "// For floats uses C99 fma() (single rounding, hardware FMA on modern CPUs).\n" +
            "// For pure ints falls back to a*b+c with int arithmetic.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_fma(HexaVal a, HexaVal b, HexaVal c) {\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b) && HX_IS_INT(c))\n" +
            "        return hexa_int(HX_INT(a) * HX_INT(b) + HX_INT(c));\n" +
            "    return hexa_float(fma(__hx_to_double(a), __hx_to_double(b), __hx_to_double(c)));\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_fma_int(HexaVal a, HexaVal b, HexaVal c);\n" +
            "extern HexaVal rt_fma_float(HexaVal a, HexaVal b, HexaVal c);\n" +
            "HexaVal hexa_fma(HexaVal a, HexaVal b, HexaVal c) {\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b) && HX_IS_INT(c))\n" +
            "        return rt_fma_int(a, b, c);\n" +
            "    return rt_fma_float(hexa_float(__hx_to_double(a)),\n" +
            "                        hexa_float(__hx_to_double(b)),\n" +
            "                        hexa_float(__hx_to_double(c)));\n" +
            "}\n" +
            "#endif\n" +
            "// Bootstrap bridge for the __raw_idiv/__raw_imod codegen primitives. The NEW\n" +
            "// codegen.hexa lowers these inline (hexa_int(HX_INT/HX_INT)), but a PRE-builtin\n" +
            "// bootstrap transpiler (self/native/hexat before regen) doesn't know them and\n" +
            "// emits the generic function-pointer form `hexa_call2(__raw_idiv, a, b)` — which\n" +
            "// resolves to __hexa_call2_fp2(fp, a, b) → fp(a, b) via the hexa_call2 _Generic.\n" +
            "// So these MUST be real C functions of signature HexaVal(HexaVal,HexaVal) (not\n" +
            "// macros — a macro would not expand on the bare identifier). Same class + form\n" +
            "// as the s4_flatc_post.py-injected static helpers (e.g. __arr_alloc_items_zero).\n" +
            "// Unreferenced (harmless) once the bootstrap regenerates and inlines them.\n" +
            "static inline HexaVal __raw_idiv(HexaVal a, HexaVal b) { return hexa_int(HX_INT(a) / HX_INT(b)); }\n" +
            "static inline HexaVal __raw_imod(HexaVal a, HexaVal b) { return hexa_int(HX_INT(a) % HX_INT(b)); }\n" +
            "// float modulo bridge → libm-free hxlcl_fmod (fwd-declared above the runtime_core.c\n" +
            "// include at self/runtime.c:983). rt_mod's float path uses this instead of the `%`\n" +
            "// operator so no `_fmod` libm extern is pulled. Mirrors hexa_mod's C body.\n" +
            "static inline HexaVal __raw_fmod(HexaVal a, HexaVal b) { return hexa_float(hxlcl_fmod(HX_FLOAT(a), HX_FLOAT(b))); }\n" +
            "\n" +
            "// RUNTIME.md Step 4 .c-none arith core op 3: under HEXA_HAS_HEXA_RT_STDLIB\n" +
            "// hexa_div delegates to hexa-source rt_div (stdlib/runtime/numeric.hexa). The\n" +
            "// int divide there uses the __raw_idiv codegen escape (native HX_INT/HX_INT)\n" +
            "// since the `/` operator on known-int routes back here (recursion). The #else\n" +
            "// C body is retained bit-for-bit for the standalone link (smoke path doesn't\n" +
            "// define the macro). Semantics byte-identical: pure int/int + pure float/float\n" +
            "// throw on zero; mixed int/float is IEEE (no throw).\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_div(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_div(HexaVal a, HexaVal b) { return rt_div(a, b); }\n" +
            "#else\n" +
            "HexaVal hexa_div(HexaVal a, HexaVal b) {\n" +
            "    _HX_COERCE_BOOL(a, b);\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b)) {\n" +
            "        // 이전엔 silent 0 반환 → 버그 은폐. interp 는 이미 throw + void.\n" +
            "        // hexa_throw 는 try-stack 이 있으면 longjmp, 없으면 stderr + exit.\n" +
            "        if (HX_INT(b) == 0) { hexa_throw(hexa_str(\"division by zero\")); return hexa_int(0); }\n" +
            "        return hexa_int(HX_INT(a) / HX_INT(b));\n" +
            "    }\n" +
            "    if (HX_IS_FLOAT(a) && HX_IS_FLOAT(b)) {\n" +
            "        if (HX_FLOAT(b) == 0.0) { hexa_throw(hexa_str(\"division by zero\")); return hexa_float(0.0); }\n" +
            "        return hexa_float(HX_FLOAT(a) / HX_FLOAT(b));\n" +
            "    }\n" +
            "    // PROBE r14-DD (T follow-up): mixed int/float divide promotes int to\n" +
            "    // double and routes to IEEE float divide.  `1 / 0.0` → +inf, `-1 / 0.0`\n" +
            "    // → -inf, `0 / 0.0` → NaN — same canonical as Python/JS/Rust runtime.\n" +
            "    // Pure int/int still throws (Python canonical) via the branch above.\n" +
            "    // PR #497 (r14-T) closes the codegen literal-fold side; this closes the\n" +
            "    // runtime-value side.\n" +
            "    if (HX_IS_INT(a) && HX_IS_FLOAT(b)) {\n" +
            "        return hexa_float((double)HX_INT(a) / HX_FLOAT(b));\n" +
            "    }\n" +
            "    if (HX_IS_FLOAT(a) && HX_IS_INT(b)) {\n" +
            "        return hexa_float(HX_FLOAT(a) / (double)HX_INT(b));\n" +
            "    }\n" +
            "    // PROBE r16 (#807 sibling): a non-numeric operand (e.g. string) is a TYPE\n" +
            "    // ERROR, not a silent 0.0. Before this guard `\"ab\" / 3` quietly returned 0.0\n" +
            "    // because __hx_to_double() coerces a string to 0.0. All four numeric pairings\n" +
            "    // (int/int, float/float, mixed) are handled above; only non-numeric reaches here.\n" +
            "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n" +
            "        char _buf[96];\n" +
            "        snprintf(_buf, sizeof(_buf), \"cannot divide non-numeric operand (tag %d / tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_float(0.0);\n" +
            "    }\n" +
            "    double fb = __hx_to_double(b);\n" +
            "    if (fb == 0.0) { hexa_throw(hexa_str(\"division by zero\")); return hexa_float(0.0); }\n" +
            "    return hexa_float(__hx_to_double(a) / fb);\n" +
            "}\n" +
            "#endif\n" +
            "// RUNTIME.md Step 4 .c-none arith core op 4: hexa_mod delegates to hexa-source\n" +
            "// rt_mod (numeric.hexa) under HEXA_HAS_HEXA_RT_STDLIB; int modulo via __raw_imod\n" +
            "// codegen escape (same `%`-operator recursion reason as rt_div). #else C body\n" +
            "// kept bit-for-bit. int/int + any-numeric throw on zero; fmod for the rest.\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_mod(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_mod(HexaVal a, HexaVal b) { return rt_mod(a, b); }\n" +
            "#else\n" +
            "HexaVal hexa_mod(HexaVal a, HexaVal b) {\n" +
            "    _HX_COERCE_BOOL(a, b);\n" +
            "    if (HX_IS_INT(a) && HX_IS_INT(b)) {\n" +
            "        if (HX_INT(b) == 0) { hexa_throw(hexa_str(\"modulo by zero\")); return hexa_int(0); }\n" +
            "        return hexa_int(HX_INT(a) % HX_INT(b));\n" +
            "    }\n" +
            "    // PROBE r16 (#807 sibling): a non-numeric operand (e.g. string) is a TYPE\n" +
            "    // ERROR, not a silent 0.0. Before this guard `\"ab\" % 3` quietly returned 0.0\n" +
            "    // because __hx_to_double() coerces a string to 0.0. Mixed int/float still\n" +
            "    // promotes to fmod below; only non-numeric operands reach this guard.\n" +
            "    if (!(HX_IS_INT(a) || HX_IS_FLOAT(a)) || !(HX_IS_INT(b) || HX_IS_FLOAT(b))) {\n" +
            "        char _buf[96];\n" +
            "        snprintf(_buf, sizeof(_buf), \"cannot compute modulo of non-numeric operand (tag %d %% tag %d)\", (int)HX_TAG(a), (int)HX_TAG(b));\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "        return hexa_float(0.0);\n" +
            "    }\n" +
            "    double fb = __hx_to_double(b);\n" +
            "    if (fb == 0.0) { hexa_throw(hexa_str(\"modulo by zero\")); return hexa_float(0.0); }\n" +
            "    return hexa_float(hxlcl_fmod(__hx_to_double(a), fb));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// ROI-44: comparison runtime helpers — replace inline GCC stmt-expr in codegen.\n" +
            "// Semantics: TAG_FLOAT promotes to double compare; TAG_INT uses int64 compare.\n" +
            "// 2026-04-17: TAG_VALSTRUCT (interpreter Val wrapper) routes through\n" +
            "// __hx_to_double so wrapped ints compare on the inner value rather than\n" +
            "// HX_INT(v) reading the .vs pointer as garbage. Symptom before fix:\n" +
            "// `let x = 5; let z = 1 + x` returned 0xA00000005 because val_int's cache\n" +
            "// range check `n < __VAL_INT_CACHE_LEN` mis-evaluated when one side was\n" +
            "// a wrapped Val from the cached singleton table.\n" +
            "// String comparisons via strcmp — 이전 경로는 __hx_to_double(\"abc\") = atof\n" +
            "// 으로 fallthrough 해서 대부분 0.0 으로 수렴 + intern pointer 비교로 떨어져\n" +
            "// 의미 없는 순서 (abc>abb=false 같은 오류).\n" +
            "// PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): cross-cutting helper used\n" +
            "// by lt/gt/le/ge. Returns 1 if both operands are TAG_ENUM with descriptors\n" +
            "// from the same enum type AND writes (a_idx, b_idx) into `*out_a` / `*out_b`.\n" +
            "// Returns 0 otherwise (caller falls through to non-enum dispatch). Same-enum\n" +
            "// gate uses type_name pointer-eq when both descriptors live in the same TU\n" +
            "// (codegen emits one __enum_type_name_<Name> static literal per enum), else\n" +
            "// strcmp on the type_name string. Two distinct enums comparing must NOT\n" +
            "// silently fold; we punt to the legacy `HX_INT < HX_INT` fallback (the .s\n" +
            "// pointer cast to int64 — gives DEFINED-BUT-MEANINGLESS ordering that won't\n" +
            "// crash but won't satisfy total order across enum types either, matching the\n" +
            "// status quo for any \"compare two values of unrelated types\" call).\n" +
            "static inline int _hexa_enum_pair_idx(HexaVal a, HexaVal b,\n" +
            "                                      int64_t* out_a, int64_t* out_b) {\n" +
            "    if (HX_TAG(a) != TAG_ENUM || HX_TAG(b) != TAG_ENUM) return 0;\n" +
            "    const char* ta = _hexa_enum_type_name(a);\n" +
            "    const char* tb = _hexa_enum_type_name(b);\n" +
            "    if (!ta || !tb) return 0; // one or both are legacy bare-string form\n" +
            "    if (ta != tb && hxlcl_strcmp(ta, tb) != 0) return 0; // different enum types\n" +
            "    *out_a = _hexa_enum_idx(a);\n" +
            "    *out_b = _hexa_enum_idx(b);\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "// RFC r16 (PROBE r16): once the enum / str-str / numeric branches are\n" +
            "// exhausted, the only operands that may legitimately read through the\n" +
            "// `HX_INT(a) < HX_INT(b)` fall-through are those whose value lives in the\n" +
            "// int slot — TAG_INT, TAG_BOOL, TAG_CHAR (and legacy cross-type TAG_ENUM,\n" +
            "// whose meaningless-but-defined fallback the r14-TTTT contract preserves).\n" +
            "// Any other tag (TAG_STR mismatched against a non-str, TAG_ARRAY, TAG_MAP,\n" +
            "// TAG_FN, TAG_CLOSURE, TAG_VOID) would have its heap pointer read as int64\n" +
            "// → silent meaningless ordering (`1 < \"a\"` TRUE, `\"a\" < 1` FALSE — not even\n" +
            "// antisymmetric; `[] < []` TRUE). Such incomparable pairs are a TYPE ERROR,\n" +
            "// mirroring the `-` `/` `%` non-numeric throw (#807 sibling) and Python3's\n" +
            "// cross-type-order TypeError. Same-type ordering, numeric int/float promotion,\n" +
            "// and `==`/`!=` are all unaffected (handled by the branches above this guard).\n" +
            "static inline int _hx_int_slot_ordered(HexaVal v) {\n" +
            "    int t = (int)HX_TAG(v);\n" +
            "    return t == TAG_INT || t == TAG_BOOL || t == TAG_CHAR || t == TAG_ENUM;\n" +
            "}\n" +
            "static inline void _hx_cmp_guard(HexaVal a, HexaVal b, const char* op) {\n" +
            "    if (!_hx_int_slot_ordered(a) || !_hx_int_slot_ordered(b)) {\n" +
            "        char _buf[96];\n" +
            "        snprintf(_buf, sizeof(_buf), \"cannot compare tag %d with tag %d (operator %s)\",\n" +
            "                 (int)HX_TAG(a), (int)HX_TAG(b), op);\n" +
            "        hexa_throw(hexa_str(_buf));\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "// RUNTIME.md Step 4 .c-none — comparison family (cmp_lt/gt/le/ge). Two bridges\n" +
            "// expose the irreducible leaf ops (enum-pair ordinal · hxlcl_strcmp · float-coerce\n" +
            "// compare needing tag introspection); the hexa rt_cmp_* (numeric.hexa) own only\n" +
            "// the per-operator selection + throw.\n" +
            "//\n" +
            "// __raw_cmp3 returns a NON-NEGATIVE ordering code: 0 a<b · 1 a==b · 2 a>b · 3\n" +
            "// unordered (float NaN → all comparisons false) · 4 incomparable (rt_cmp throws).\n" +
            "// Float/valstruct is folded in HERE (native double compare, NaN-aware via the `3`\n" +
            "// sentinel) — no per-op hexa float compare needed.\n" +
            "//\n" +
            "// CRITICAL — codes MUST be non-negative: a negative literal in the hexa rt_cmp\n" +
            "// (`-1`) lowers to `hexa_sub(hexa_int(0), hexa_int(1))` (runtime subtract) → rt_sub\n" +
            "// → `type_of==` (hexa_eq) → rt_eq → string-eq (`a<=b && a>=b`) → hexa_cmp_le →\n" +
            "// rt_cmp_le = INFINITE RECURSION (stack overflow observed). The arith ports work\n" +
            "// precisely because they only use non-negative kind codes (0/1/2). Likewise rt_cmp\n" +
            "// must test the code with __raw_code_is (C int-eq) not hexa `==` (→ rt_eq → cmp).\n" +
            "static inline HexaVal __raw_cmp3(HexaVal a, HexaVal b) {\n" +
            "    int64_t ia, ib;\n" +
            "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_int(ia < ib ? 0 : (ia > ib ? 2 : 1));\n" +
            "    if (HX_IS_STR(a) && HX_IS_STR(b)) {\n" +
            "        int _c = hxlcl_strcmp(HX_STR(a), HX_STR(b));\n" +
            "        return hexa_int(_c < 0 ? 0 : (_c > 0 ? 2 : 1));\n" +
            "    }\n" +
            "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b)) {\n" +
            "        double _x = __hx_to_double(a), _y = __hx_to_double(b);\n" +
            "        if (_x < _y) return hexa_int(0);\n" +
            "        if (_x > _y) return hexa_int(2);\n" +
            "        if (_x == _y) return hexa_int(1);\n" +
            "        return hexa_int(3); // NaN-unordered → every comparison false\n" +
            "    }\n" +
            "    if (!_hx_int_slot_ordered(a) || !_hx_int_slot_ordered(b)) return hexa_int(4);\n" +
            "    int64_t _xi = HX_INT(a), _yi = HX_INT(b);\n" +
            "    return hexa_int(_xi < _yi ? 0 : (_xi > _yi ? 2 : 1));\n" +
            "}\n" +
            "static inline HexaVal __raw_code_is(HexaVal v, HexaVal k) { return hexa_bool(HX_INT(v) == HX_INT(k)); }\n" +
            "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "extern HexaVal rt_cmp_lt(HexaVal a, HexaVal b);\n" +
            "extern HexaVal rt_cmp_gt(HexaVal a, HexaVal b);\n" +
            "extern HexaVal rt_cmp_le(HexaVal a, HexaVal b);\n" +
            "extern HexaVal rt_cmp_ge(HexaVal a, HexaVal b);\n" +
            "HexaVal hexa_cmp_lt(HexaVal a, HexaVal b) { return rt_cmp_lt(a, b); }\n" +
            "HexaVal hexa_cmp_gt(HexaVal a, HexaVal b) { return rt_cmp_gt(a, b); }\n" +
            "HexaVal hexa_cmp_le(HexaVal a, HexaVal b) { return rt_cmp_le(a, b); }\n" +
            "HexaVal hexa_cmp_ge(HexaVal a, HexaVal b) { return rt_cmp_ge(a, b); }\n" +
            "#else\n" +
            "HexaVal hexa_cmp_lt(HexaVal a, HexaVal b) {\n" +
            "    int64_t ia, ib;\n" +
            "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia < ib);\n" +
            "    if (HX_IS_STR(a) && HX_IS_STR(b))\n" +
            "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) < 0);\n" +
            "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n" +
            "        return hexa_bool(__hx_to_double(a) < __hx_to_double(b));\n" +
            "    _hx_cmp_guard(a, b, \"<\");\n" +
            "    return hexa_bool(HX_INT(a) < HX_INT(b));\n" +
            "}\n" +
            "HexaVal hexa_cmp_gt(HexaVal a, HexaVal b) {\n" +
            "    int64_t ia, ib;\n" +
            "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia > ib);\n" +
            "    if (HX_IS_STR(a) && HX_IS_STR(b))\n" +
            "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) > 0);\n" +
            "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n" +
            "        return hexa_bool(__hx_to_double(a) > __hx_to_double(b));\n" +
            "    _hx_cmp_guard(a, b, \">\");\n" +
            "    return hexa_bool(HX_INT(a) > HX_INT(b));\n" +
            "}\n" +
            "HexaVal hexa_cmp_le(HexaVal a, HexaVal b) {\n" +
            "    int64_t ia, ib;\n" +
            "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia <= ib);\n" +
            "    if (HX_IS_STR(a) && HX_IS_STR(b))\n" +
            "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) <= 0);\n" +
            "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n" +
            "        return hexa_bool(__hx_to_double(a) <= __hx_to_double(b));\n" +
            "    _hx_cmp_guard(a, b, \"<=\");\n" +
            "    return hexa_bool(HX_INT(a) <= HX_INT(b));\n" +
            "}\n" +
            "HexaVal hexa_cmp_ge(HexaVal a, HexaVal b) {\n" +
            "    int64_t ia, ib;\n" +
            "    if (_hexa_enum_pair_idx(a, b, &ia, &ib)) return hexa_bool(ia >= ib);\n" +
            "    if (HX_IS_STR(a) && HX_IS_STR(b))\n" +
            "        return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) >= 0);\n" +
            "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b) || HX_IS_VALSTRUCT(a) || HX_IS_VALSTRUCT(b))\n" +
            "        return hexa_bool(__hx_to_double(a) >= __hx_to_double(b));\n" +
            "    _hx_cmp_guard(a, b, \">=\");\n" +
            "    return hexa_bool(HX_INT(a) >= HX_INT(b));\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 58 port — float fast-path bridge. Mixed-type arrays\n" +
            "// stay on the polymorphic hexa_eq path. Int return preserved (codegen\n" +
            "// wraps in `hexa_bool(...)` like starts_with). _arr_all_float helper\n" +
            "// is inlined here (lives static in runtime.c — copy-pattern from\n" +
            "// hexa_array_reverse above).\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "int hexa_array_contains(HexaVal arr, HexaVal item) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return 0;\n" +
            "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n" +
            "        if (hexa_truthy(hexa_eq(HX_ARR_ITEMS(arr)[i], item))) return 1;\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_array_contains_float_b(HexaVal arr, HexaVal item);\n" +
            "int hexa_array_contains(HexaVal arr, HexaVal item) {\n" +
            "    if (!HX_IS_ARRAY(arr)) return 0;\n" +
            "    if (HX_IS_FLOAT(item)) {\n" +
            "        int all_float = 1;\n" +
            "        int64_t n = HX_ARR_LEN(arr);\n" +
            "        for (int64_t i = 0; i < n; i++) {\n" +
            "            if (!HX_IS_FLOAT(HX_ARR_ITEMS(arr)[i])) { all_float = 0; break; }\n" +
            "        }\n" +
            "        if (all_float) {\n" +
            "            return hexa_truthy(rt_array_contains_float_b(arr, item)) ? 1 : 0;\n" +
            "        }\n" +
            "    }\n" +
            "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n" +
            "        if (hexa_truthy(hexa_eq(HX_ARR_ITEMS(arr)[i], item))) return 1;\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// count_substr(s, substr): number of non-overlapping occurrences.\n" +
            "// Matches interpreter's greedy advance (hexa_full.hexa:14954-14973).\n" +
            "// Step-3 cycle 27 port.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_str_count_substr(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return hexa_int(0);\n" +
            "    const char* src = HX_STR(s);\n" +
            "    const char* pat = HX_STR(sub);\n" +
            "    int plen = (int)hxlcl_strlen(pat);\n" +
            "    if (plen == 0) return hexa_int(0);\n" +
            "    int64_t cnt = 0;\n" +
            "    const char* p = src;\n" +
            "    while ((p = hxlcl_strstr(p, pat)) != NULL) {\n" +
            "        cnt++;\n" +
            "        p += plen; // non-overlapping\n" +
            "    }\n" +
            "    return hexa_int(cnt);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_str_count_substr(HexaVal s, HexaVal sub);\n" +
            "HexaVal hexa_str_count_substr(HexaVal s, HexaVal sub) {\n" +
            "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return hexa_int(0);\n" +
            "    return rt_str_count_substr(s, sub);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 60 port — snprintf \"%.*f\" replaced by hexa-source\n" +
            "// rt_format_float_f. Caveats: works exactly for values within ±2^53\n" +
            "// and prec ≤ 18; beyond that the int64 round-trip is lossy. The C\n" +
            "// body remains as the no-stdlib fallback.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_format_float(HexaVal f, HexaVal prec) {\n" +
            "    double v = __hx_to_double(f);\n" +
            "    int p = HX_INT(prec);\n" +
            "    char buf[64];\n" +
            "    snprintf(buf, 64, \"%.*f\", p, v);\n" +
            "    return hexa_str(buf);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_format_float_f(HexaVal v, HexaVal prec);\n" +
            "HexaVal hexa_format_float(HexaVal f, HexaVal prec) {\n" +
            "    return rt_format_float_f(hexa_float(__hx_to_double(f)), prec);\n" +
            "}\n" +
            "#endif\n" +
            "\n" +
            "// Step-3 cycle 61 port — snprintf \"%.*e\" replaced by hexa-source.\n" +
            "// Uses rt_log10 for the exponent, rt_format_float_f for the mantissa.\n" +
            "// Caveats: same int64 round-trip limit as cycle 60; mantissa rounding\n" +
            "// boundary (9.99→10) is NOT renormalized.\n" +
            "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n" +
            "HexaVal hexa_format_float_sci(HexaVal f, HexaVal prec) {\n" +
            "    double v = __hx_to_double(f);\n" +
            "    int p = HX_INT(prec);\n" +
            "    char buf[64];\n" +
            "    snprintf(buf, 64, \"%.*e\", p, v);\n" +
            "    return hexa_str(buf);\n" +
            "}\n" +
            "#else\n" +
            "extern HexaVal rt_format_float_sci(HexaVal v, HexaVal prec);\n" +
            "HexaVal hexa_format_float_sci(HexaVal f, HexaVal prec) {\n" +
            "    return rt_format_float_sci(hexa_float(__hx_to_double(f)), prec);\n" +
            "}\n" +
            "#endif\n" +
            "\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "runtime_core.c" }
    let c_text = emit_runtime_core_c()
    let cmd = "cat > \"" + out_path + "\" <<'RUNTIME_CORE_EMIT_EOF'\n" +
              c_text + "RUNTIME_CORE_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[runtime_core_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[runtime_core_emit] wrote " + out_path)
    exit(0)
}
