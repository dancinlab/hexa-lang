    buf = buf + "// ─────────────────────────────────────────────────────────────────────\n"
    buf = buf + "#include \"runtime_hi_gen.c\"\n"
    buf = buf + "// Step 5 (hxa-20260423-003): hexa_str_lines/repeat/pad_left/pad_right/center\n"
    buf = buf + "// shims removed — codegen now dispatches directly to rt_str_* from\n"
    buf = buf + "// runtime_hi_gen.c (SSOT: self/runtime_hi.hexa). See self/codegen.hexa\n"
    buf = buf + "// cg_string_sym \"c\" branch (lines 250-272).\n"
    buf = buf + "\n"
    buf = buf + "static int utf8_cpcount(const char* s) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    int n = 0;\n"
    buf = buf + "    for (int i = 0; s[i]; i++) if ((s[i] & 0xC0) != 0x80) n++;\n"
    buf = buf + "    return n;\n"
    buf = buf + "}\n"
    buf = buf + "// Step-3 cycle 51 port — pad_left dispatches to rt_pad_left. The\n"
    buf = buf + "// hexa_to_string polymorphic coercion stays C-side (hexa-source\n"
    buf = buf + "// param is string-typed); the actual padding work is hexa-source.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_pad_left(HexaVal s, HexaVal width) {\n"
    buf = buf + "    HexaVal str = hexa_to_string(s);\n"
    buf = buf + "    int w = HX_INT(width);\n"
    buf = buf + "    int cplen = utf8_cpcount(HX_STR(str));\n"
    buf = buf + "    int bytelen = (int)HX_STRLEN(str);\n"
    buf = buf + "    if (cplen >= w) return str;\n"
    buf = buf + "    int pad = w - cplen;\n"
    buf = buf + "    char* result = malloc(bytelen + pad + 1);\n"
    buf = buf + "    hxlcl_memset(result, ' ', pad);\n"
    buf = buf + "    hxlcl_strcpy(result + pad, HX_STR(str));\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
