    buf = buf + "#endif\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "\n"
    buf = buf + "// `.index_of(sub, start)` — first occurrence at-or-after byte offset `start`.\n"
    buf = buf + "// hxa-20260423-012: the 2-arg form was silently dropping `start`, forcing\n"
