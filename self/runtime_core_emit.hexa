    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_index_of_from(HexaVal s, HexaVal sub, HexaVal start);\n"
    buf = buf + "int64_t hexa_str_index_of_from(HexaVal s, HexaVal sub, HexaVal start) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n"
    buf = buf + "    return HX_INT(rt_str_index_of_from(s, sub, start));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Returns byte offset of LAST occurrence of `sub` within `s`, or -1.\n"
    buf = buf + "// Mirrors interpreter `.rfind`/`.last_index_of` at self/hexa_full.hexa:15741.\n"
    buf = buf + "// Added 2026-04-23 (hxa-20260422-002 lang_gap prio=95, rfind blocker).\n"
    buf = buf + "// Step-3 cycle 55 port — int64_t-return bridge.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "int64_t hexa_str_last_index_of(HexaVal s, HexaVal sub) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(sub)) return -1;\n"
    buf = buf + "    const char* hay = HX_STR(s);\n"
    buf = buf + "    const char* needle = HX_STR(sub);\n"
    buf = buf + "    size_t nlen = hxlcl_strlen(needle);\n"
    buf = buf + "    size_t hlen = hxlcl_strlen(hay);\n"
    buf = buf + "    if (nlen == 0) return (int64_t)hlen;\n"
    buf = buf + "    if (nlen > hlen) return -1;\n"
    buf = buf + "    int64_t last = -1;\n"
