    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Byte-indexed single-char extraction. `.char_at(i)` → 1-byte string at\n"
    buf = buf + "// offset i, empty string if out-of-range. Matches the byte-orientation\n"
    buf = buf + "// of every other hexa_str_* helper (runtime has no UTF-8 codepoint iter\n"
