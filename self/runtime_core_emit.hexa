    buf = buf + "    // surfacing the ORIGINAL negative index in the message (_orig_idx_g).\n"
    buf = buf + "    if (idx < 0 || idx >= HX_ARR_LEN(arr)) {\n"
    buf = buf + "        char _buf[128];\n"
