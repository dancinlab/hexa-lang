    buf = buf + "        HexaVal* new_items = realloc(HX_ARR_ITEMS(arr), sizeof(HexaVal) * (size_t)n);\n"
    buf = buf + "        if (!new_items) { fprintf(stderr, \"OOM in array_reserve\\n\"); exit(1); }\n"
    buf = buf + "        HX_SET_ARR_ITEMS(arr, new_items);\n"
    buf = buf + "        HX_SET_ARR_CAP(arr, n);\n"
