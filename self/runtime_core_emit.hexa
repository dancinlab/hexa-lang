    buf = buf + "            if (__hexa_val_mark_top > 0 && hexa_array_arena_on()) {\n"
    buf = buf + "                next_items = hexa_array_arena_alloc_items(new_cap);\n"
    buf = buf + "            }\n"
    buf = buf + "            if (next_items) {\n"
