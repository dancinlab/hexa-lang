    buf = buf + "    }\n"
    buf = buf + "    if (HX_ARR_LEN(arr) == 0) {\n"
    buf = buf + "        hexa_throw(hexa_str(\"array.shift(): empty array\"));\n"
    buf = buf + "        return hexa_void();\n"
    buf = buf + "    }\n"
    buf = buf + "    return rt_array_shift(arr);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 25 port (float array fast-path).\n"
    buf = buf + "HexaVal hexa_array_reverse(HexaVal arr) {\n"
    buf = buf + "    if (HX_IS_STR(arr)) {\n"
    buf = buf + "        const char* s = HX_STR(arr);\n"
    buf = buf + "        size_t n = hxlcl_strlen(s);\n"
    buf = buf + "        char* buf = (char*)malloc(n + 1);\n"
    buf = buf + "        for (size_t i = 0; i < n; i++) buf[i] = s[n - 1 - i];\n"
    buf = buf + "        buf[n] = '\\0';\n"
    buf = buf + "        return hexa_str_own(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return arr;\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "    extern HexaVal rt_array_reverse_float(HexaVal arr);\n"
    buf = buf + "    // Inline _arr_all_float (helper lives in runtime.c — declared static there)\n"
    buf = buf + "    int all_float = 1;\n"
    buf = buf + "    int64_t arr_n = HX_ARR_LEN(arr);\n"
    buf = buf + "    for (int64_t i = 0; i < arr_n; i++) {\n"
    buf = buf + "        if (!HX_IS_FLOAT(HX_ARR_ITEMS(arr)[i])) { all_float = 0; break; }\n"
    buf = buf + "    }\n"
    buf = buf + "    if (all_float) return rt_array_reverse_float(arr);\n"
    buf = buf + "#endif\n"
    buf = buf + "    HexaVal result = hexa_array_new();\n"
    buf = buf + "    for (int i = HX_ARR_LEN(arr) - 1; i >= 0; i--)\n"
    buf = buf + "        result = hexa_array_push(result, HX_ARR_ITEMS(arr)[i]);\n"
    buf = buf + "    return result;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Generic value comparator used by hexa_array_sort + hexa_array_sort_by.\n"
    buf = buf + "// 2026-05-14: added string lexicographic compare — prior version returned\n"
    buf = buf + "// 0 for any non-numeric pair, causing `[\"c\",\"a\",\"b\"].sort() == [\"c\",\"a\",\"b\"]`\n"
    buf = buf + "// (silent identity-sort). Filed at incoming/patches/stdlib-sort.md.\n"
    buf = buf + "// Returns 0 for incomparable / cross-type pairs (caller treats as \"tie\" —\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// stable sorts preserve insertion order on ties).\n"
    buf = buf + "//\n"
    buf = buf + "// PROBE r14-J (2026-05-23): canonical NaN-last total ordering. IEEE 754\n"
    buf = buf + "// NaN compares return false for <, >, ==, so plain `da < db ? -1 : ...`\n"
    buf = buf + "// returns 0 for every (NaN, x) pair → qsort sees an indeterminate\n"
    buf = buf + "// ordering → undefined behavior (NaN scattered through output, sometimes\n"
    buf = buf + "// dropping non-NaN values past it). Canonical fixes:\n"
    buf = buf + "//   - Rust f64::total_cmp: NaN goes after +inf (NaN-last for +NaN)\n"
    buf = buf + "//   - Python numpy.sort: NaN-last by default\n"
    buf = buf + "//   - Python builtin list.sort: would TypeError, but we don't have that\n"
    buf = buf + "//     channel cheaply available here.\n"
    buf = buf + "// We pick NaN-last (Rust / numpy default). Both NaN → tie (stable sorts\n"
    buf = buf + "// preserve insertion order).\n"
    buf = buf + "static int hexa_sort_cmp(const void* a, const void* b) {\n"
    buf = buf + "    HexaVal va = *(const HexaVal*)a, vb = *(const HexaVal*)b;\n"
    buf = buf + "    if (HX_IS_INT(va) && HX_IS_INT(vb)) return HX_INT(va) < HX_INT(vb) ? -1 : HX_INT(va) > HX_INT(vb) ? 1 : 0;\n"
    buf = buf + "    if (HX_IS_FLOAT(va) && HX_IS_FLOAT(vb)) {\n"
    buf = buf + "        double da = HX_FLOAT(va), db = HX_FLOAT(vb);\n"
    buf = buf + "        int na = isnan(da), nb = isnan(db);\n"
    buf = buf + "        if (na && nb) return 0;\n"
    buf = buf + "        if (na) return 1;       // NaN sorts AFTER everything (NaN-last)\n"
    buf = buf + "        if (nb) return -1;\n"
    buf = buf + "        return da < db ? -1 : da > db ? 1 : 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_STR(va) && HX_IS_STR(vb)) {\n"
    buf = buf + "        int r = hxlcl_strcmp(HX_STR(va), HX_STR(vb));\n"
    buf = buf + "        return r < 0 ? -1 : r > 0 ? 1 : 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    // mixed-numeric (int vs float): promote to float for the compare\n"
    buf = buf + "    if ((HX_IS_INT(va) || HX_IS_FLOAT(va)) && (HX_IS_INT(vb) || HX_IS_FLOAT(vb))) {\n"
    buf = buf + "        double da = HX_IS_INT(va) ? (double)HX_INT(va) : HX_FLOAT(va);\n"
    buf = buf + "        double db = HX_IS_INT(vb) ? (double)HX_INT(vb) : HX_FLOAT(vb);\n"
    buf = buf + "        int na = isnan(da), nb = isnan(db);\n"
    buf = buf + "        if (na && nb) return 0;\n"
    buf = buf + "        if (na) return 1;       // NaN-last (consistent with float/float path)\n"
    buf = buf + "        if (nb) return -1;\n"
    buf = buf + "        return da < db ? -1 : da > db ? 1 : 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 59 port — float fast-path dispatches to insertion-sort\n"
    buf = buf + "// hexa source. Mixed-type arrays still need hexa_sort_cmp polymorphism\n"
    buf = buf + "// and stay on the qsort path.\n"
    buf = buf + "HexaVal hexa_array_sort(HexaVal arr) {\n"
    buf = buf + "    // Previously `result = arr` copied the HexaVal struct — but both still\n"
    buf = buf + "    // alias array_store[arr.int_val]. `HX_SET_ARR_ITEMS(result, malloc(...))`\n"
    buf = buf + "    // therefore also replaced arr's items pointer → the following\n"
    buf = buf + "    // `memcpy(HX_ARR_ITEMS(result), HX_ARR_ITEMS(arr), ...)` memcpy'd the\n"
    buf = buf + "    // brand-new empty buf onto itself. qsort'd that garbage → caller saw\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    // [0,0,0]. **Both** `r` and original `arr` came out zeroed.\n"
    buf = buf + "    // Fix: build a fresh result via hexa_array_new + push (mirrors\n"
    buf = buf + "    // hexa_array_reverse), then qsort the fresh buffer.\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return arr;\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "    extern HexaVal rt_array_sort_float(HexaVal arr);\n"
    buf = buf + "    int all_float = 1;\n"
    buf = buf + "    int64_t arr_n = HX_ARR_LEN(arr);\n"
    buf = buf + "    for (int64_t i = 0; i < arr_n; i++) {\n"
    buf = buf + "        if (!HX_IS_FLOAT(HX_ARR_ITEMS(arr)[i])) { all_float = 0; break; }\n"
    buf = buf + "    }\n"
    buf = buf + "    if (all_float) return rt_array_sort_float(arr);\n"
    buf = buf + "#endif\n"
    buf = buf + "    HexaVal result = hexa_array_new();\n"
    buf = buf + "    int n = HX_ARR_LEN(arr);\n"
    buf = buf + "    for (int i = 0; i < n; i++) {\n"
    buf = buf + "        result = hexa_array_push(result, HX_ARR_ITEMS(arr)[i]);\n"
    buf = buf + "    }\n"
    buf = buf + "    qsort(HX_ARR_ITEMS(result), HX_ARR_LEN(result), sizeof(HexaVal), hexa_sort_cmp);\n"
    buf = buf + "    return result;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Stable sort by precomputed keys. Closure invoked once per element via\n"
    buf = buf + "// hexa_call1 to derive the sort key; bottom-up iterative merge sort over a\n"
    buf = buf + "// parallel (item, key) buffer. Stability matters for downstream callers\n"
    buf = buf + "// (e.g. wilson event_bus priority ordering). Comparator is hexa_sort_cmp\n"
    buf = buf + "// (which handles int/float/string after 2026-05-14; mixed types tie).\n"
    buf = buf + "// Filed at incoming/patches/stdlib-sort.md.\n"
    buf = buf + "HexaVal hexa_array_sort_by(HexaVal arr, HexaVal key_fn) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return hexa_array_new();\n"
    buf = buf + "    int n = HX_ARR_LEN(arr);\n"
    buf = buf + "    HexaVal result = hexa_array_new();\n"
    buf = buf + "    for (int i = 0; i < n; i++) {\n"
    buf = buf + "        result = hexa_array_push(result, HX_ARR_ITEMS(arr)[i]);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (n < 2) return result;\n"
    buf = buf + "\n"
    buf = buf + "    HexaVal* items = HX_ARR_ITEMS(result);\n"
    buf = buf + "    HexaVal* keys = (HexaVal*)malloc(sizeof(HexaVal) * n);\n"
    buf = buf + "    for (int i = 0; i < n; i++) keys[i] = hexa_call1(key_fn, items[i]);\n"
    buf = buf + "\n"
    buf = buf + "    HexaVal* tmp_items = (HexaVal*)malloc(sizeof(HexaVal) * n);\n"
    buf = buf + "    HexaVal* tmp_keys  = (HexaVal*)malloc(sizeof(HexaVal) * n);\n"
    buf = buf + "\n"
    buf = buf + "    for (int width = 1; width < n; width *= 2) {\n"
    buf = buf + "        for (int start = 0; start < n; start += 2 * width) {\n"
    buf = buf + "            int left  = start;\n"
    buf = buf + "            int mid   = start + width;       if (mid   > n) mid   = n;\n"
    buf = buf + "            int right = start + 2 * width;   if (right > n) right = n;\n"
    buf = buf + "            int li = left, ri = mid, ki = left;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            while (li < mid && ri < right) {\n"
    buf = buf + "                // stable: take right side only when strictly less; ties → left first\n"
    buf = buf + "                if (hexa_sort_cmp(&keys[ri], &keys[li]) < 0) {\n"
    buf = buf + "                    tmp_items[ki] = items[ri]; tmp_keys[ki] = keys[ri]; ri++;\n"
    buf = buf + "                } else {\n"
    buf = buf + "                    tmp_items[ki] = items[li]; tmp_keys[ki] = keys[li]; li++;\n"
    buf = buf + "                }\n"
    buf = buf + "                ki++;\n"
    buf = buf + "            }\n"
    buf = buf + "            while (li < mid)   { tmp_items[ki] = items[li]; tmp_keys[ki] = keys[li]; li++; ki++; }\n"
    buf = buf + "            while (ri < right) { tmp_items[ki] = items[ri]; tmp_keys[ki] = keys[ri]; ri++; ki++; }\n"
    buf = buf + "            for (int j = left; j < right; j++) {\n"
    buf = buf + "                items[j] = tmp_items[j];\n"
    buf = buf + "                keys[j]  = tmp_keys[j];\n"
    buf = buf + "            }\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "\n"
    buf = buf + "    free(tmp_items); free(tmp_keys); free(keys);\n"
    buf = buf + "    return result;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Exec ────────────────────────────────────────────\n"
    buf = buf + "// TL;DR #2 (2026-05-06): posix_spawnp fast path for shell-free exec().\n"
    buf = buf + "// popen() forks a /bin/sh child which then exec's the actual command —\n"
    buf = buf + "// 2 fork+exec hops, plus shell startup time (~5–15 ms on macOS), even when\n"
    buf = buf + "// the command has no shell-meta chars. posix_spawnp() skips the shell hop\n"
    buf = buf + "// entirely (single fork+exec via the kernel's spawn syscall on macOS, or\n"
    buf = buf + "// vfork+execvp emulation on Linux glibc).\n"
    buf = buf + "//\n"
    buf = buf + "// Opt-in via env HEXA_EXEC_NO_SHELL=1. When set AND the command contains\n"
    buf = buf + "// no shell-meta characters (|&;<>*?$()`\\\\\"' newline tab ~{}[]#=) we tokenize\n"
    buf = buf + "// on whitespace and posix_spawnp the argv directly, returning a FILE* wired\n"
    buf = buf + "// to the child's stdout via pipe2/dup2. When unset, or shell-meta present,\n"
    buf = buf + "// we fall through to popen() — preserving every existing behavior.\n"
    buf = buf + "//\n"
    buf = buf + "// Returns the child PID on success (caller must waitpid to reap), 0 on\n"
    buf = buf + "// fallback/skip. The fp out-param receives a FILE* the caller reads as if\n"
    buf = buf + "// from popen, freed with fclose() (NOT pclose — the child is reaped via\n"
    buf = buf + "// waitpid by the caller using the returned pid).\n"
    buf = buf + "static int hexa_exec_no_shell_enabled(void) {\n"
    buf = buf + "    static int cached = -1;\n"
    buf = buf + "    if (cached < 0) {\n"
    buf = buf + "        const char* v = hxlcl_getenv(\"HEXA_EXEC_NO_SHELL\");\n"
    buf = buf + "        cached = (v && v[0] == '1' && v[1] == '\\0') ? 1 : 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    return cached;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Returns 1 if cmd contains a shell-meta character that requires sh -c\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// interpretation. Conservative: any of these forces popen fallback.\n"
    buf = buf + "// Quote chars (' \" `) are included because we tokenize on whitespace only —\n"
    buf = buf + "// a quoted arg with spaces would split incorrectly without shell parsing.\n"
    buf = buf + "static int hexa_cmd_has_shell_meta(const char* s) {\n"
    buf = buf + "    if (!s) return 1;\n"
    buf = buf + "    for (const char* p = s; *p; p++) {\n"
    buf = buf + "        switch (*p) {\n"
    buf = buf + "            case '|': case '&': case ';': case '<': case '>':\n"
    buf = buf + "            case '*': case '?': case '$': case '(': case ')':\n"
    buf = buf + "            case '`': case '\\\\': case '\"': case '\\'':\n"
    buf = buf + "            case '\\n': case '\\t': case '~': case '{': case '}':\n"
    buf = buf + "            case '[': case ']': case '#': case '=':\n"
    buf = buf + "                return 1;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return 0;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Tokenize cmd on ASCII whitespace into a freshly malloc'd argv (NULL-\n"
    buf = buf + "// terminated). Caller owns argv + argv[0]; argv[i] for i>0 are interior\n"
    buf = buf + "// pointers into the malloc'd argv[0] buffer (we replace whitespace with\n"
    buf = buf + "// '\\0' in-place). Free via: free(argv[0]); free(argv);\n"
    buf = buf + "static char** hexa_tokenize_argv(const char* cmd, int* out_argc) {\n"
    buf = buf + "    *out_argc = 0;\n"
    buf = buf + "    if (!cmd) return NULL;\n"
    buf = buf + "    size_t len = hxlcl_strlen(cmd);\n"
    buf = buf + "    char* buf = (char*)malloc(len + 1);\n"
    buf = buf + "    if (!buf) return NULL;\n"
    buf = buf + "    hxlcl_memcpy(buf, cmd, len + 1);\n"
    buf = buf + "    int argc = 0;\n"
    buf = buf + "    int in_tok = 0;\n"
    buf = buf + "    for (size_t i = 0; i < len; i++) {\n"
    buf = buf + "        unsigned char c = (unsigned char)buf[i];\n"
    buf = buf + "        int is_ws = (c == ' ' || c == '\\t');\n"
    buf = buf + "        if (!is_ws && !in_tok) { argc++; in_tok = 1; }\n"
    buf = buf + "        else if (is_ws) in_tok = 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (argc == 0) { free(buf); return NULL; }\n"
    buf = buf + "    char** argv = (char**)malloc(sizeof(char*) * (argc + 1));\n"
    buf = buf + "    if (!argv) { free(buf); return NULL; }\n"
    buf = buf + "    int idx = 0;\n"
    buf = buf + "    in_tok = 0;\n"
    buf = buf + "    for (size_t i = 0; i < len; i++) {\n"
    buf = buf + "        unsigned char c = (unsigned char)buf[i];\n"
    buf = buf + "        int is_ws = (c == ' ' || c == '\\t');\n"
    buf = buf + "        if (!is_ws && !in_tok) { argv[idx++] = buf + i; in_tok = 1; }\n"
    buf = buf + "        else if (is_ws && in_tok) { buf[i] = '\\0'; in_tok = 0; }\n"
    buf = buf + "    }\n"
    buf = buf + "    argv[argc] = NULL;\n"
    buf = buf + "    *out_argc = argc;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    return argv;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Spawn child reading cmd's stdout into a returned FILE*. Returns 0 (no\n"
    buf = buf + "// FILE* set) when the env flag is off, the cmd has shell-meta, or any\n"
    buf = buf + "// spawn step fails — caller must fall back to popen() in those cases.\n"
    buf = buf + "// On success returns child pid (>0) and *out_fp = fdopen(read_end, \"r\").\n"
    buf = buf + "static pid_t hexa_spawn_no_shell(const char* cmd, FILE** out_fp) {\n"
    buf = buf + "    *out_fp = NULL;\n"
    buf = buf + "    if (!hexa_exec_no_shell_enabled()) return 0;\n"
    buf = buf + "    if (!cmd || hexa_cmd_has_shell_meta(cmd)) return 0;\n"
    buf = buf + "    int argc = 0;\n"
    buf = buf + "    char** argv = hexa_tokenize_argv(cmd, &argc);\n"
    buf = buf + "    if (!argv || argc == 0) { if (argv) { free(argv[0]); free(argv); } return 0; }\n"
    buf = buf + "\n"
    buf = buf + "    int pipefd[2];\n"
    buf = buf + "    if (hxlcl_pipe(pipefd) != 0) { free(argv[0]); free(argv); return 0; }\n"
    buf = buf + "\n"
    buf = buf + "    // RUNTIME net/exec ⑦ (cycle 81): replace posix_spawnp + the 4\n"
    buf = buf + "    // posix_spawn_file_actions_* libc orchestrators with the proven\n"
    buf = buf + "    // fork+dup2+execvp primitives (all svc-trapped). Drops 5 libc externs;\n"
    buf = buf + "    // the no-shell behavior is preserved (execvp does the 'p' PATH search,\n"
    buf = buf + "    // matching posix_spawnp). Mirrors the hxlcl_popen child pattern.\n"
    buf = buf + "    pid_t pid = hxlcl_fork();\n"
    buf = buf + "    if (pid < 0) {\n"
    buf = buf + "        hxlcl_close(pipefd[0]); hxlcl_close(pipefd[1]);\n"
    buf = buf + "        free(argv[0]); free(argv); return 0;\n"
    buf = buf + "    }\n"
    buf = buf + "    if (pid == 0) {\n"
    buf = buf + "        // child: wire pipe write-end to stdout, exec argv via PATH search\n"
    buf = buf + "        hxlcl_dup2(pipefd[1], STDOUT_FILENO);\n"
    buf = buf + "        hxlcl_close(pipefd[0]);\n"
    buf = buf + "        hxlcl_close(pipefd[1]);\n"
    buf = buf + "        hxlcl_execvp(argv[0], argv);\n"
    buf = buf + "        _exit(127); // exec failed\n"
    buf = buf + "    }\n"
    buf = buf + "    // parent\n"
    buf = buf + "    free(argv[0]); free(argv);\n"
    buf = buf + "    hxlcl_close(pipefd[1]);\n"
    buf = buf + "    FILE* fp = fdopen(pipefd[0], \"r\");\n"
    buf = buf + "    if (!fp) { hxlcl_close(pipefd[0]); return 0; }\n"
    buf = buf + "    *out_fp = fp;\n"
    buf = buf + "    return pid;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Reap a posix_spawn'd child and translate to popen-style status int\n"
    buf = buf + "// (matching pclose's encoding so existing WIFEXITED/WEXITSTATUS code works).\n"
    buf = buf + "static int hexa_spawn_reap(pid_t pid) {\n"
    buf = buf + "    if (pid <= 0) return -1;\n"
    buf = buf + "    int status = 0;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    while (hxlcl_waitpid(pid, &status, 0) < 0) {\n"
    buf = buf + "        if (errno == EINTR) continue;\n"
    buf = buf + "        return -1;\n"
    buf = buf + "    }\n"
    buf = buf + "    return status;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// 2026-04-26 cross-repo upstream (hive→hexa-lang): switched the read primitive\n"
    buf = buf + "// from fgets()+strlen(buf) to fread(). Old loop computed chunk length via\n"
    buf = buf + "// strlen() on the buffer fgets() filled — when the child wrote an embedded\n"
    buf = buf + "// NUL byte (e.g. `git log --format=...%x00` for record boundaries),\n"
    buf = buf + "// strlen(buf) returned 0 for that chunk's tail and every byte from the NUL\n"
    buf = buf + "// onward inside that 4 KiB read window was silently dropped. The new loop\n"
    buf = buf + "// uses fread() which reports the actual byte count, so the captured buffer\n"
    buf = buf + "// faithfully retains every byte including embedded NULs.\n"
    buf = buf + "//\n"
    buf = buf + "// Caveat (string ABI): HexaVal strings are stored as a bare `char*` (see the\n"
    buf = buf + "// HX_STR macro) and most downstream consumers (hexa_len → strlen, the intern\n"
    buf = buf + "// table, str_eq → strcmp) still treat them as C-NUL-terminated. Hexa-source\n"
    buf = buf + "// code that calls len() / == on the captured string still sees the C-string\n"
    buf = buf + "// view (i.e. truncation at the first NUL). Callers that need full byte-level\n"
    buf = buf + "// access to popen output with embedded NULs should use a byte-array variant\n"
    buf = buf + "// modeled after rt_read_file_bytes (planned: `exec_bytes`). This fix is the\n"
    buf = buf + "// read-loop slice of the problem — the buffer itself is now correct end-to-\n"
    buf = buf + "// end, removing the runtime-layer truncation cliff.\n"
    buf = buf + "HexaVal hexa_exec(HexaVal cmd) {\n"
    buf = buf + "    if (!HX_IS_STR(cmd)) return hexa_str(\"\");\n"
    buf = buf + "    // 2026-05-06 — POSIX 정합: fork() 전 부모 buffer flush 강제. popen()는\n"
    buf = buf + "    // fork+exec 호출 — 부모의 stdio buffer가 자식에게 inherit. 자식 sh가\n"
    buf = buf + "    // read </dev/tty 같은 syscall 대기시 부모 stderr/stdout buffer가\n"
    buf = buf + "    // flush 안 되면 사용자에게 prompt 안 보임. setup_2fa.hexa 대화형 prompt\n"
    buf = buf + "    // 무반응 case 진단됨 (T4 probe).\n"
    buf = buf + "    fflush(NULL);\n"
    buf = buf + "    // TL;DR #2 fast path: posix_spawnp when env enabled + shell-meta-free.\n"
    buf = buf + "    FILE* spawn_fp = NULL;\n"
    buf = buf + "    pid_t spawn_pid = hexa_spawn_no_shell(HX_STR(cmd), &spawn_fp);\n"
    buf = buf + "    FILE* fp;\n"
    buf = buf + "    if (spawn_pid > 0) {\n"
    buf = buf + "        fp = spawn_fp;\n"
    buf = buf + "    } else {\n"
    buf = buf + "        fp = hxlcl_popen(HX_STR(cmd), \"r\");\n"
    buf = buf + "        if (!fp) return hexa_str(\"\");\n"
    buf = buf + "    }\n"
    buf = buf + "    hexa_pipe_buf_enlarge_kernel(fp);  // TL;DR #4: F_SETPIPE_SZ Linux only (fread bulk drain)\n"
    buf = buf + "    char buf[4096]; size_t total = 0;\n"
    buf = buf + "    size_t cap = 4096;\n"
    buf = buf + "    char* result = (char*)malloc(cap); result[0] = '\\0';\n"
    buf = buf + "    size_t n;\n"
    buf = buf + "    while ((n = fread(buf, 1, sizeof(buf), fp)) > 0) {\n"
    buf = buf + "        // +1 for the trailing NUL we always append so HX_STR() remains a\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        // valid C-string for ABI consumers (see caveat above).\n"
    buf = buf + "        while (total + n + 1 > cap) { cap *= 2; result = (char*)realloc(result, cap); }\n"
    buf = buf + "        hxlcl_memcpy(result + total, buf, n);\n"
    buf = buf + "        total += n;\n"
    buf = buf + "    }\n"
    buf = buf + "    result[total] = '\\0';\n"
    buf = buf + "    if (spawn_pid > 0) { fclose(fp); hexa_spawn_reap(spawn_pid); }\n"
    buf = buf + "    else               { hxlcl_pclose(fp); }\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// hexa_exec_stream — like hexa_exec, but invokes `on_line(line)` for each\n"
    buf = buf + "// stdout line as it is read instead of buffering the entire output. Returns\n"
    buf = buf + "// the child's exit code (same convention as hexa_exec_with_status[1]: 0..255\n"
    buf = buf + "// for normal exit, 128+sig for signal, -1 for unknown).\n"
    buf = buf + "//\n"
    buf = buf + "// Rationale (2026-04-25): hexa_exec / hexa_exec_with_status both popen() the\n"
    buf = buf + "// command and only return after pclose(). For long-running build/test\n"
    buf = buf + "// commands that emit progress on stdout (npm test, cargo build, hexa-lang's\n"
    buf = buf + "// own dispatch self-compile) the agent layer sees zero output until the child\n"
    buf = buf + "// exits, which surfaces to the user as a multi-minute silent stall. Adding\n"
    buf = buf + "// streaming lets the calling hexa code emit progress in real time without\n"
    buf = buf + "// the runtime buffering multi-megabyte transcripts.\n"
    buf = buf + "//\n"
    buf = buf + "// Each line passed to the callback retains its trailing newline (as fgets\n"
    buf = buf + "// returns it), except the final partial line if the child exited mid-line.\n"
    buf = buf + "// Callback is invoked inline on the hexa runtime stack via hexa_call1 — the\n"
    buf = buf + "// caller's hexa function executes synchronously between fgets() iterations.\n"
    buf = buf + "HexaVal hexa_exec_stream_impl(HexaVal cmd, HexaVal on_line) {\n"
    buf = buf + "    if (!HX_IS_STR(cmd)) return hexa_int(127);\n"
    buf = buf + "    if (!HX_IS_FN(on_line) && !HX_IS_CLOSURE(on_line)) return hexa_int(127);\n"
    buf = buf + "    // 2026-05-06 — POSIX fork buffer flush (mirror hexa_exec)\n"
    buf = buf + "    fflush(NULL);\n"
    buf = buf + "    // TL;DR #2 fast path: posix_spawnp when env enabled + shell-meta-free.\n"
    buf = buf + "    FILE* spawn_fp = NULL;\n"
    buf = buf + "    pid_t spawn_pid = hexa_spawn_no_shell(HX_STR(cmd), &spawn_fp);\n"
    buf = buf + "    FILE* fp;\n"
    buf = buf + "    if (spawn_pid > 0) {\n"
    buf = buf + "        fp = spawn_fp;\n"
    buf = buf + "    } else {\n"
    buf = buf + "        fp = hxlcl_popen(HX_STR(cmd), \"r\");\n"
    buf = buf + "        if (!fp) return hexa_int(127);\n"
    buf = buf + "    }\n"
    buf = buf + "    hexa_pipe_buf_enlarge_full(fp);  // TL;DR #4: F_SETPIPE_SZ Linux + setvbuf 256K (fgets streaming)\n"
    buf = buf + "    char buf[4096];\n"
    buf = buf + "    while (fgets(buf, sizeof(buf), fp)) {\n"
    buf = buf + "        // Construct a fresh hexa string per line (the buffer is reused).\n"
    buf = buf + "        // hexa_str() copies, so this is safe across iterations.\n"
    buf = buf + "        hexa_call1(on_line, hexa_str(buf));\n"
    buf = buf + "    }\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    int rc;\n"
    buf = buf + "    if (spawn_pid > 0) { fclose(fp); rc = hexa_spawn_reap(spawn_pid); }\n"
    buf = buf + "    else               { rc = hxlcl_pclose(fp); }\n"
    buf = buf + "    int exit_code;\n"
    buf = buf + "    if (WIFEXITED(rc))      exit_code = WEXITSTATUS(rc);\n"
    buf = buf + "    else if (WIFSIGNALED(rc)) exit_code = 128 + WTERMSIG(rc);\n"
    buf = buf + "    else                     exit_code = -1;\n"
    buf = buf + "    return hexa_int(exit_code);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Forward decl + auto-wrap macro shim. The current hexat codegen emits\n"
    buf = buf + "// `hexa_exec_stream(cmd, ident)` where `ident` is a raw C function symbol\n"
    buf = buf + "// (e.g. `on_line`) rather than a HexaVal. To bridge that without rebuilding\n"
    buf = buf + "// hexat, we redirect the user-visible call through a wrapping macro that\n"
    buf = buf + "// invokes hexa_exec_stream_impl with a freshly-constructed TAG_FN HexaVal.\n"
    buf = buf + "// After a dispatch self-rebuild activates the codegen lowering with proper\n"
    buf = buf + "// gen2_expr wrapping, this macro becomes a no-op (the second arg will\n"
    buf = buf + "// already be a HexaVal — _Generic could choose impl directly, but the\n"
    buf = buf + "// double-wrap path remains safe for HexaVal too via a passthrough).\n"
    buf = buf + "//\n"
    buf = buf + "// We keep both names: hexa_exec_stream (callable from hexa) and\n"
    buf = buf + "// hexa_exec_stream_impl (the actual C function). The macro picks based on\n"
    buf = buf + "// whether the second argument is a function pointer or a HexaVal.\n"
    buf = buf + "extern HexaVal hexa_exec_stream_impl(HexaVal cmd, HexaVal on_line);\n"
    buf = buf + "extern HexaVal hexa_fn_new(void* fp, int arity);\n"
    buf = buf + "static inline HexaVal __hexa_exec_stream_wrap_fp(HexaVal cmd, HexaVal (*fp)(HexaVal)) {\n"
    buf = buf + "    return hexa_exec_stream_impl(cmd, hexa_fn_new((void*)fp, 1));\n"
    buf = buf + "}\n"
    buf = buf + "static inline HexaVal __hexa_exec_stream_wrap_hv(HexaVal cmd, HexaVal cb) {\n"
    buf = buf + "    return hexa_exec_stream_impl(cmd, cb);\n"
    buf = buf + "}\n"
    buf = buf + "// _Generic dispatch — selects the function-pointer wrapper for raw symbols\n"
    buf = buf + "// or the HexaVal passthrough when the lowering path supplies a value.\n"
    buf = buf + "#define hexa_exec_stream(cmd, cb) _Generic((cb), \\\n"
    buf = buf + "    HexaVal: __hexa_exec_stream_wrap_hv, \\\n"
    buf = buf + "    default: __hexa_exec_stream_wrap_fp)((cmd), (cb))\n"
    buf = buf + "\n"
    buf = buf + "// hexa_exec_with_status: like hexa_exec but returns [stdout_str, exit_code].\n"
    buf = buf + "// 2026-04-17: needed because the interpreter's exec_with_status dispatch in\n"
    buf = buf + "// hexa_full.hexa silently always returns exit=0 (popen output without\n"
    buf = buf + "// pclose status), letting build scripts roll forward stale binaries through\n"
    buf = buf + "// failed clang/cargo invocations. Codegen + dispatch wiring TBD — this\n"
    buf = buf + "// function is the C-runtime backstop ready when the interpreter learns to\n"
    buf = buf + "// call it via codegen lowering of `exec_with_status(cmd)`.\n"
    buf = buf + "//\n"
    buf = buf + "// 2026-05-23 (PROBE r8): the 2-tuple shape is canonically-deviant. Rust\n"
    buf = buf + "// `Output{stdout, stderr, status}`, Go `Cmd.Output()` separate `.Stderr`,\n"
    buf = buf + "// Python `CompletedProcess.{stdout, stderr, returncode}` — every comparable\n"
    buf = buf + "// runtime exposes stderr as its own field. popen(\"r\") here merges stderr\n"
    buf = buf + "// into stdout only when the caller appends `2>&1`, which loses the channel\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// distinction. The CANONICAL 3-tuple path already exists in this repo as\n"
    buf = buf + "// `hexa_exec_capture(cmd)` (runtime.c:9991, returns [stdout, stderr, exit_code]\n"
    buf = buf + "// via pipe/fork/select — same multiplexed drain pattern as PR #423). New\n"
    buf = buf + "// code should call `exec_capture()` directly; `exec_with_status()` is kept\n"
    buf = buf + "// for backward compatibility with ~150 existing callers (caller migration =\n"
    buf = buf + "// separate stacked PR, see inbox/patches/exec-with-status-3tuple-migration.md).\n"
    buf = buf + "HexaVal hexa_exec_with_status(HexaVal cmd) {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (!HX_IS_STR(cmd)) {\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_str(\"\"));\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_int(127));\n"
    buf = buf + "        return arr;\n"
    buf = buf + "    }\n"
    buf = buf + "    // 2026-05-06 — POSIX fork buffer flush (mirror hexa_exec / hexa_exec_stream_impl)\n"
    buf = buf + "    fflush(NULL);\n"
    buf = buf + "    // TL;DR #2 fast path: posix_spawnp when env enabled + shell-meta-free.\n"
    buf = buf + "    FILE* spawn_fp = NULL;\n"
    buf = buf + "    pid_t spawn_pid = hexa_spawn_no_shell(HX_STR(cmd), &spawn_fp);\n"
    buf = buf + "    FILE* fp;\n"
    buf = buf + "    if (spawn_pid > 0) {\n"
    buf = buf + "        fp = spawn_fp;\n"
    buf = buf + "    } else {\n"
    buf = buf + "        fp = hxlcl_popen(HX_STR(cmd), \"r\");\n"
    buf = buf + "        if (!fp) {\n"
    buf = buf + "            arr = hexa_array_push(arr, hexa_str(\"\"));\n"
    buf = buf + "            arr = hexa_array_push(arr, hexa_int(127));\n"
    buf = buf + "            return arr;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    hexa_pipe_buf_enlarge_kernel(fp);  // TL;DR #4: F_SETPIPE_SZ Linux only (fread bulk drain)\n"
    buf = buf + "    // 2026-04-26 cross-repo upstream: same fgets→fread switch as hexa_exec\n"
    buf = buf + "    // above (see that function's comment for the embedded-NUL truncation\n"
    buf = buf + "    // root cause and the residual string-ABI caveat).\n"
    buf = buf + "    char buf[4096]; size_t total = 0;\n"
    buf = buf + "    size_t cap = 4096;\n"
    buf = buf + "    char* result = (char*)malloc(cap); result[0] = '\\0';\n"
    buf = buf + "    size_t n;\n"
    buf = buf + "    while ((n = fread(buf, 1, sizeof(buf), fp)) > 0) {\n"
    buf = buf + "        while (total + n + 1 > cap) { cap *= 2; result = (char*)realloc(result, cap); }\n"
    buf = buf + "        hxlcl_memcpy(result + total, buf, n);\n"
    buf = buf + "        total += n;\n"
    buf = buf + "    }\n"
    buf = buf + "    result[total] = '\\0';\n"
    buf = buf + "    int rc;\n"
    buf = buf + "    if (spawn_pid > 0) { fclose(fp); rc = hexa_spawn_reap(spawn_pid); }\n"
    buf = buf + "    else               { rc = hxlcl_pclose(fp); }\n"
    buf = buf + "    int exit_code;\n"
    buf = buf + "    if (WIFEXITED(rc))      exit_code = WEXITSTATUS(rc);\n"
    buf = buf + "    else if (WIFSIGNALED(rc)) exit_code = 128 + WTERMSIG(rc);\n"
    buf = buf + "    else                     exit_code = -1;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    arr = hexa_array_push(arr, hexa_str_own(result));\n"
    buf = buf + "    arr = hexa_array_push(arr, hexa_int(exit_code));\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// exec_replace — replace current process via execvp(\"/bin/sh\", \"-c\", cmd).\n"
    buf = buf + "// Does not return on success. Used by `hexa lsp` to hand stdin/stdout fully\n"
    buf = buf + "// to the interp interpreter so bidirectional streaming (JSON-RPC) works\n"
    buf = buf + "// without popen buffering or the __HEXA_RC sentinel interleaving into the\n"
    buf = buf + "// response body. On failure, returns empty string and the caller falls\n"
    buf = buf + "// back to regular hexa_exec().\n"
    buf = buf + "HexaVal hexa_exec_replace(HexaVal cmd) {\n"
    buf = buf + "    if (!HX_IS_STR(cmd)) return hexa_str(\"\");\n"
    buf = buf + "    // fflush to avoid duplicated stdio buffers in the replacement.\n"
    buf = buf + "    fflush(stdout); fflush(stderr);\n"
    buf = buf + "    char* argv[4];\n"
    buf = buf + "    argv[0] = (char*)\"/bin/sh\";\n"
    buf = buf + "    argv[1] = (char*)\"-c\";\n"
    buf = buf + "    argv[2] = HX_STR(cmd);\n"
    buf = buf + "    argv[3] = NULL;\n"
    buf = buf + "    hxlcl_execvp(argv[0], argv);\n"
    buf = buf + "    // execvp returned → failure; surface errno and fall through.\n"
    buf = buf + "    perror(\"exec_replace\");\n"
    buf = buf + "    return hexa_str(\"\");\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// 2026-05-20 (blocker-4 print-precision): opt-in higher-precision float\n"
    buf = buf + "// formatter for human-readable `print`/`println`/`eprint`/`eprintln`. Default\n"
    buf = buf + "// stays at \"%g\" (6 significant digits) — round-trip-loss but matches existing\n"
    buf = buf + "// snapshots / golden outputs. Set HEXA_FLOAT_REPR=g17 to switch to \"%.17g\"\n"
    buf = buf + "// (IEEE-754 double round-trip-safe). Cached static so the getenv() call\n"
    buf = buf + "// happens once per process.\n"
    buf = buf + "static const char* __hexa_print_float_fmt(void) {\n"
    buf = buf + "    static int cached = 0;\n"
    buf = buf + "    static const char* fmt = \"%g\";\n"
    buf = buf + "    if (!cached) {\n"
    buf = buf + "        const char* env = hxlcl_getenv(\"HEXA_FLOAT_REPR\");\n"
    buf = buf + "        if (env) {\n"
    buf = buf + "            if (hxlcl_strcmp(env, \"g17\") == 0) fmt = \"%.17g\";\n"
    buf = buf + "            else if (hxlcl_strcmp(env, \"g15\") == 0) fmt = \"%.15g\";\n"
    buf = buf + "            // unknown values fall back to \"%g\" (silent) — strict mode could\n"
    buf = buf + "            // surface a stderr warning here, but print-path is hot so keep\n"
    buf = buf + "            // the fast default.\n"
    buf = buf + "        }\n"
    buf = buf + "        cached = 1;\n"
    buf = buf + "    }\n"
    buf = buf + "    return fmt;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// PROBE r14-E (2026-05-23): canonical Rust-style casing for special floats.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// glibc/macOS libc render NaN/inf in lowercase via \"%g\" (\"nan\"/\"inf\"); align\n"
    buf = buf + "// with the g1 canonical-first policy (Rust: \"NaN\", \"inf\", \"-inf\"). Returns\n"
    buf = buf + "// a static string or NULL when `f` is finite. Used by both the print-path\n"
    buf = buf + "// and to_string-path so println/to_string/eprintln stay consistent.\n"
    buf = buf + "static const char* __hexa_float_special_repr(double f) {\n"
    buf = buf + "    if (isnan(f)) return \"NaN\";\n"
    buf = buf + "    if (isinf(f)) return f < 0.0 ? \"-inf\" : \"inf\";\n"
    buf = buf + "    return NULL;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// PROBE r14-L (2026-05-23): unify print_val / eprint_val / eprintln / eprint\n"
    buf = buf + "// float-rendering with hexa_to_string so `println(0.0)` matches\n"
    buf = buf + "// `to_string(0.0)` (\"0.0\", not \"0\") and NaN/inf carry the canonical Rust\n"
    buf = buf + "// casing.  Policy mirrors _hexa_to_string_rec TAG_FLOAT (line ~5731):\n"
    buf = buf + "//   1. NaN/inf            → __hexa_float_special_repr (\"NaN\"/\"inf\"/\"-inf\")\n"
    buf = buf + "//   2. integer-valued finite float in [-1e15, 1e15] → \"%.1f\"  (0.0 → \"0.0\")\n"
    buf = buf + "//   3. otherwise          → __hexa_print_float_fmt() (env-honoring %g)\n"
    buf = buf + "// Writes a NUL-terminated repr into `buf` (caller owns at least 32 bytes).\n"
    buf = buf + "static void __hexa_format_float_for_print(double f, char* buf, size_t cap) {\n"
    buf = buf + "    const char* sp = __hexa_float_special_repr(f);\n"
    buf = buf + "    if (sp) { snprintf(buf, cap, \"%s\", sp); return; }\n"
    buf = buf + "    if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n"
    buf = buf + "        snprintf(buf, cap, \"%.1f\", f);\n"
    buf = buf + "    } else {\n"
    buf = buf + "        snprintf(buf, cap, __hexa_print_float_fmt(), f);\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Stderr ──────────────────────────────────────────\n"
    buf = buf + "void hexa_eprint_val(HexaVal v) {\n"
    buf = buf + "    // 2026-04-20 silent-fallback fix: prior body dropped TAG_VOID /\n"
    buf = buf + "    // TAG_ARRAY / TAG_MAP / TAG_VALSTRUCT entirely (no output, not even\n"
    buf = buf + "    // \"<value>\"). User-visible path is eprintln(arr) / eprintln(map) —\n"
    buf = buf + "    // emitting nothing is strictly worse than the hexa_to_string repr.\n"
    buf = buf + "    // One-hop TAG_VALSTRUCT unwrap mirrors hexa_print_val.\n"
    buf = buf + "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n"
    buf = buf + "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n"
    buf = buf + "    char __fbuf[64];\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        HexaValStruct* vs = HX_VS(v);\n"
    buf = buf + "        switch (vs->tag_i) {\n"
    buf = buf + "            case TAG_INT:   fprintf(stderr, \"%lld\", (long long)vs->int_val); return;\n"
    buf = buf + "            case TAG_FLOAT:\n"
    buf = buf + "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n"
    buf = buf + "                fprintf(stderr, \"%s\", __fbuf); return;\n"
    buf = buf + "            case TAG_BOOL:  fprintf(stderr, \"%s\", vs->bool_val ? \"true\" : \"false\"); return;\n"
    buf = buf + "            case TAG_STR: {\n"
    buf = buf + "                const char* cs = HX_STR(vs->str_val);\n"
    buf = buf + "                if (cs) { fprintf(stderr, \"%s\", cs); return; }\n"
    buf = buf + "                break;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            }\n"
    buf = buf + "            case TAG_VOID:  fprintf(stderr, \"void\"); return;\n"
    buf = buf + "        }\n"
    buf = buf + "        // fall through for compound inner tags\n"
    buf = buf + "    }\n"
    buf = buf + "    if (HX_IS_STR(v)) {\n"
    buf = buf + "        if (HX_STR(v)) fprintf(stderr, \"%s\", HX_STR(v));\n"
    buf = buf + "        else fprintf(stderr, \"<str null>\");\n"
    buf = buf + "    }\n"
    buf = buf + "    else if (HX_IS_INT(v)) fprintf(stderr, \"%lld\", (long long)HX_INT(v));\n"
    buf = buf + "    else if (HX_IS_FLOAT(v)) {\n"
    buf = buf + "        __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n"
    buf = buf + "        fprintf(stderr, \"%s\", __fbuf);\n"
    buf = buf + "    }\n"
    buf = buf + "    else if (HX_IS_BOOL(v)) fprintf(stderr, HX_BOOL(v) ? \"true\" : \"false\");\n"
    buf = buf + "    else if (HX_IS_VOID(v)) fprintf(stderr, \"void\");\n"
    buf = buf + "    else if (HX_IS_ARRAY(v) || HX_IS_MAP(v)) {\n"
    buf = buf + "        // Delegate to hexa_to_string for container repr (depth/element\n"
    buf = buf + "        // caps are inherited). Guards against null arr/map pointers.\n"
    buf = buf + "        HexaVal s = hexa_to_string(v);\n"
    buf = buf + "        if (HX_IS_STR(s) && HX_STR(s)) fprintf(stderr, \"%s\", HX_STR(s));\n"
    buf = buf + "        else fprintf(stderr, \"<value>\");\n"
    buf = buf + "    }\n"
    buf = buf + "    else fprintf(stderr, \"<value>\");\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Try/catch (setjmp based) ────────────────────────\n"
    buf = buf + "#include <setjmp.h>\n"
    buf = buf + "#define HEXA_MAX_TRY 64\n"
    buf = buf + "static jmp_buf* __hexa_try_stack[HEXA_MAX_TRY];\n"
    buf = buf + "/* PHASE 1.2.B (2026-05-15): de-staticized. Try-stack depth marker read by\n"
    buf = buf + " * hexat-emitted try/catch lowering in user.c. */\n"
    buf = buf + "int __hexa_try_top = 0;\n"
    buf = buf + "static HexaVal __hexa_error_val;\n"
    buf = buf + "\n"
    buf = buf + "void __hexa_try_push(jmp_buf* jb) { if (__hexa_try_top < HEXA_MAX_TRY) __hexa_try_stack[__hexa_try_top++] = jb; }\n"
    buf = buf + "void __hexa_try_pop(void) { if (__hexa_try_top > 0) __hexa_try_top--; }\n"
    buf = buf + "HexaVal __hexa_last_error(void) { return __hexa_error_val; }\n"
    buf = buf + "\n"
    buf = buf + "// __hexa_try_cleanup: GCC/Clang `cleanup` attribute helper used by codegen.\n"
    buf = buf + "// Restores try-stack depth on scope exit, so an early return / break / longjmp\n"
    buf = buf + "// inside a try block can't leak entries onto __hexa_try_stack.\n"
    buf = buf + "void __hexa_try_cleanup(int* saved) { if (__hexa_try_top > *saved) __hexa_try_top = *saved; }\n"
    buf = buf + "\n"
    buf = buf + "void hexa_throw(HexaVal err) {\n"
    buf = buf + "    __hexa_error_val = err;\n"
    buf = buf + "    if (__hexa_try_top > 0) {\n"
    buf = buf + "        __hexa_try_top--;\n"
    buf = buf + "        // RUNTIME tail (cycle 86): native longjmp (drops libc _longjmp). The\n"
    buf = buf + "        // matching save is the codegen's `bl _hxlcl_setjmp` into the same slot.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        hxlcl_longjmp((void *)*__hexa_try_stack[__hexa_try_top], 1);\n"
    buf = buf + "    }\n"
    buf = buf + "    // hxa-20260423-013: print the error value on uncaught throw so tests\n"
    buf = buf + "    // (T34) and users can see what failed. Falls back to generic label\n"
    buf = buf + "    // when the value can't be rendered as a short scalar.\n"
    buf = buf + "    if (HX_IS_STR(err) && HX_STR(err)) {\n"
    buf = buf + "        fprintf(stderr, \"%s\\n\", HX_STR(err));\n"
    buf = buf + "    } else {\n"
    buf = buf + "        fprintf(stderr, \"Unhandled throw\\n\");\n"
    buf = buf + "    }\n"
    buf = buf + "    exit(1);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Printing ─────────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// Cycle-102 (2026-05-22) — IO 4th-fn activation. The hexa_print_val\n"
    buf = buf + "// symbol is what shipped self/native/hexat emits for `print(v)`.\n"
    buf = buf + "// Under HEXA_HAS_HEXA_RT_STDLIB the entry dispatches to rt_print\n"
    buf = buf + "// (stdlib/runtime/io.hexa) which coerces via to_string + raw write.\n"
    buf = buf + "// For TAG_ARRAY this routes through _hexa_to_string_rec which produces\n"
    buf = buf + "// the same `[e1, e2, ...]` repr (depth-cap 8, element-cap 64) the C\n"
    buf = buf + "// path emitted via recursive printf — byte-eq for scalar smokes.\n"
    buf = buf + "// The C body is retained under #else for the standalone runtime.c\n"
    buf = buf + "// smoke link path (no stdlib import).\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_print(HexaVal v);\n"
    buf = buf + "void hexa_print_val(HexaVal v) {\n"
    buf = buf + "    (void)rt_print(v);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "// anima P0 bug #6 (2026-04-18): TAG_VALSTRUCT unwrap guard.\n"
    buf = buf + "// When interpreter routes print through hexa_println with an arg that\n"
    buf = buf + "// got boxed as TAG_VALSTRUCT (rt 32-G flat struct), the prior `default:`\n"
    buf = buf + "// branch rendered \"<value>\" — correct-ish but lossy for the common\n"
    buf = buf + "// string path (if true { println(\"inside\") } inside a fn body).\n"
    buf = buf + "// Unwrap the inner tag here so the user-visible output matches the\n"
    buf = buf + "// intent even when Val-boxing sneaks through the interp boundary.\n"
    buf = buf + "// See: handoff 2026-04-18 bug #6, feedback_val_corruption_class_2026_04_17.md\n"
    buf = buf + "void hexa_print_val(HexaVal v) {\n"
    buf = buf + "    // One-hop TAG_VALSTRUCT unwrap. Not recursive — a VS wrapping a VS is\n"
    buf = buf + "    // already a corruption signal we surface via the fallback tail.\n"
    buf = buf + "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n"
    buf = buf + "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n"
    buf = buf + "    char __fbuf[64];\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        HexaValStruct* vs = HX_VS(v);\n"
    buf = buf + "        switch (vs->tag_i) {\n"
    buf = buf + "            case TAG_INT:   printf(\"%lld\", (long long)vs->int_val); return;\n"
    buf = buf + "            case TAG_FLOAT:\n"
    buf = buf + "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                printf(\"%s\", __fbuf); return;\n"
    buf = buf + "            case TAG_BOOL:  printf(\"%s\", vs->bool_val ? \"true\" : \"false\"); return;\n"
    buf = buf + "            case TAG_STR: {\n"
    buf = buf + "                const char* cs = HX_STR(vs->str_val);\n"
    buf = buf + "                if (cs) { printf(\"%s\", cs); return; }\n"
    buf = buf + "                break;\n"
    buf = buf + "            }\n"
    buf = buf + "            case TAG_VOID:  printf(\"void\"); return;\n"
    buf = buf + "        }\n"
    buf = buf + "        // Inner tag not one of the printable scalars — fall through to the\n"
    buf = buf + "        // outer switch with the boxed tag so we emit \"<value>\" rather than\n"
    buf = buf + "        // dereferencing a compound descriptor that may not survive arena\n"
    buf = buf + "        // rewinding (T33 class).\n"
    buf = buf + "    }\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_INT: printf(\"%lld\", (long long)HX_INT(v)); break;\n"
    buf = buf + "        case TAG_FLOAT:\n"
    buf = buf + "            __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n"
    buf = buf + "            printf(\"%s\", __fbuf); break;\n"
    buf = buf + "        case TAG_BOOL: printf(\"%s\", HX_BOOL(v) ? \"true\" : \"false\"); break;\n"
    buf = buf + "        case TAG_STR:\n"
    buf = buf + "            // Null-pointer guard: a corrupted TAG_STR (str_val=NULL) would\n"
    buf = buf + "            // crash printf(\"%s\", NULL) on some libc builds. Surface it.\n"
    buf = buf + "            if (HX_STR(v)) printf(\"%s\", HX_STR(v));\n"
    buf = buf + "            else printf(\"<str null>\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        case TAG_VOID: printf(\"void\"); break;\n"
    buf = buf + "        case TAG_ARRAY:\n"
    buf = buf + "            printf(\"[\");\n"
    buf = buf + "            for (int i = 0; i < HX_ARR_LEN(v); i++) {\n"
    buf = buf + "                if (i > 0) printf(\", \");\n"
    buf = buf + "                hexa_print_val(HX_ARR_ITEMS(v)[i]);\n"
    buf = buf + "            }\n"
    buf = buf + "            printf(\"]\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "            // 2026-04-20 silent-fallback fix: TAG_MAP branch added.\n"
    buf = buf + "            // Prior default emitted \"<value>\" — lossy for println(map).\n"
    buf = buf + "            // Delegate to hexa_to_string so depth/element caps apply.\n"
    buf = buf + "            HexaVal s = hexa_to_string(v);\n"
    buf = buf + "            if (HX_IS_STR(s) && HX_STR(s)) printf(\"%s\", HX_STR(s));\n"
    buf = buf + "            else printf(\"<value>\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        default: printf(\"<value>\"); break;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// RUNTIME.md step-3 잔여 #7 (2026-05-22 cycle-101 c25ef75e) — hexa_println\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// / hexa_eprint / hexa_eprintln may route to hexa-source rt_print /\n"
    buf = buf + "// rt_println / rt_eprint / rt_eprintln (stdlib/runtime/io.hexa) when\n"
    buf = buf + "// HEXA_HAS_HEXA_RT_STDLIB is defined. The hexa bodies coerce via\n"
    buf = buf + "// to_string(v) + emit raw bytes via __fd_write_bytes (runtime.c shim).\n"
    buf = buf + "// C bodies retained for the smoke link path (standalone runtime.c, no\n"
    buf = buf + "// stdlib import) and as fallback.\n"
    buf = buf + "//\n"
    buf = buf + "// Cycle-102 (2026-05-22, runtime|codegen|stdlib|restore) — restores the\n"
    buf = buf + "// cycle-101 dispatch after the silent wipe in commit e8c2dc1c (wip:\n"
    buf = buf + "// dfflibmap sky130 reset-flop variants + ...). Additionally activates\n"
    buf = buf + "// the 4th IO fn (rt_print) by routing the existing `hexa_print_val`\n"
    buf = buf + "// symbol — which is what shipped self/native/hexat emits for\n"
    buf = buf + "// `print(v)` — through rt_print at the top of hexa_print_val. Internal\n"
    buf = buf + "// recursion (TAG_ARRAY children) stays on the C path via the private\n"
    buf = buf + "// helper _hexa_print_val_c_body to avoid double-routing.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_println(HexaVal v);\n"
    buf = buf + "void hexa_println(HexaVal v) {\n"
    buf = buf + "    (void)rt_println(v);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "void hexa_println(HexaVal v) {\n"
    buf = buf + "    hexa_print_val(v); printf(\"\\n\");\n"
    buf = buf + "    // 2026-05-06 — auto-fflush. setvbuf constructor가 일부 환경 (macOS Tahoe\n"
    buf = buf + "    // Terminal, qrencode subprocess와 interactive prompt 혼재 등)에서 무력\n"
    buf = buf + "    // 화 case 발견. 매 println 후 명시 fflush로 dead time 0 보장.\n"
    buf = buf + "    // opt-out: HEXA_NO_AUTOFLUSH=1 (bulk-output benchmark용).\n"
    buf = buf + "    if (!hxlcl_getenv(\"HEXA_NO_AUTOFLUSH\")) fflush(stdout);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Cycle-102 (2026-05-22) — 4th IO fn activation. `print(v)` codegen\n"
    buf = buf + "// lowers to `hexa_print_val(v)` (the symbol used recursively for\n"
    buf = buf + "// ARRAY children). The shipped hexat binary emits this name, so we\n"
    buf = buf + "// dispatch at this entry point under HEXA_HAS_HEXA_RT_STDLIB to route\n"
    buf = buf + "// the top-level call through rt_print (stdlib/runtime/io.hexa). The\n"
    buf = buf + "// recursive case (hexa_print_val called from within hexa_print_val\n"
    buf = buf + "// for TAG_ARRAY items above) flows through the SAME dispatched entry\n"
    buf = buf + "// — `rt_print` calls `to_string(v)` which for arrays delegates to\n"
    buf = buf + "// _hexa_to_string_rec (depth-capped at 8, element-capped at 64),\n"
    buf = buf + "// producing the same `[e1, e2, ...]` repr that the C path emitted via\n"
    buf = buf + "// recursive printf. Byte-eq for plain string args (the smoke test).\n"
    buf = buf + "//\n"
    buf = buf + "// Additionally introduces a new C symbol `hexa_print(v)` for the\n"
    buf = buf + "// codegen rule (single-arg `print(v)` → `hexa_print(v)`) that ships\n"
    buf = buf + "// with the next regen of self/native/hexat. Until regen lands the\n"
    buf = buf + "// shipped binary continues to call hexa_print_val (which now\n"
    buf = buf + "// dispatches), so activation is functional today and will remain\n"
    buf = buf + "// correct after regen flips the call site.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "extern HexaVal rt_print(HexaVal v);\n"
    buf = buf + "HexaVal hexa_print(HexaVal v) {\n"
    buf = buf + "    return rt_print(v);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_print(HexaVal v) {\n"
    buf = buf + "    hexa_print_val(v);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// P7-6 builtin (2026-04-18): stderr counterpart to hexa_println. Used\n"
    buf = buf + "// by user code that needs to emit diagnostics without polluting stdout\n"
    buf = buf + "// (e.g. CLI tools whose stdout is a result stream piped to another\n"
    buf = buf + "// process). Returns void-equivalent HexaVal so it can slot into the\n"
    buf = buf + "// uniform i64-ret IR shape that the native_build dispatcher emits.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_eprintln(HexaVal v);\n"
    buf = buf + "HexaVal hexa_eprintln(HexaVal v) {\n"
    buf = buf + "    return rt_eprintln(v);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_eprintln(HexaVal v) {\n"
    buf = buf + "    // Route through the same hexa_print_val logic but redirect the\n"
    buf = buf + "    // writes to stderr. We cannot reuse hexa_print_val directly because\n"
    buf = buf + "    // it hard-codes printf() — mirror the body with fprintf(stderr).\n"
    buf = buf + "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n"
    buf = buf + "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n"
    buf = buf + "    char __fbuf[64];\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        HexaValStruct* vs = HX_VS(v);\n"
    buf = buf + "        switch (vs->tag_i) {\n"
    buf = buf + "            case TAG_INT:   fprintf(stderr, \"%lld\\n\", (long long)vs->int_val); return hexa_void();\n"
    buf = buf + "            case TAG_FLOAT:\n"
    buf = buf + "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n"
    buf = buf + "                fprintf(stderr, \"%s\\n\", __fbuf); return hexa_void();\n"
    buf = buf + "            case TAG_BOOL:  fprintf(stderr, \"%s\\n\", vs->bool_val ? \"true\" : \"false\"); return hexa_void();\n"
    buf = buf + "            case TAG_STR: {\n"
    buf = buf + "                const char* cs = HX_STR(vs->str_val);\n"
    buf = buf + "                if (cs) { fprintf(stderr, \"%s\\n\", cs); return hexa_void(); }\n"
    buf = buf + "                break;\n"
    buf = buf + "            }\n"
    buf = buf + "            case TAG_VOID:  fprintf(stderr, \"void\\n\"); return hexa_void();\n"
    buf = buf + "        }\n"
    buf = buf + "        // fall through to outer switch for corrupted/compound inner tags\n"
    buf = buf + "    }\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_INT: fprintf(stderr, \"%lld\\n\", (long long)HX_INT(v)); break;\n"
    buf = buf + "        case TAG_FLOAT:\n"
    buf = buf + "            __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            fprintf(stderr, \"%s\\n\", __fbuf); break;\n"
    buf = buf + "        case TAG_BOOL: fprintf(stderr, \"%s\\n\", HX_BOOL(v) ? \"true\" : \"false\"); break;\n"
    buf = buf + "        case TAG_STR:\n"
    buf = buf + "            if (HX_STR(v)) fprintf(stderr, \"%s\\n\", HX_STR(v));\n"
    buf = buf + "            else fprintf(stderr, \"<str null>\\n\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        case TAG_VOID: fprintf(stderr, \"void\\n\"); break;\n"
    buf = buf + "        case TAG_ARRAY:\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "            // 2026-04-20 silent-fallback fix: TAG_ARRAY/TAG_MAP branches\n"
    buf = buf + "            // added. Prior default emitted \"<value>\\n\" — lossy for\n"
    buf = buf + "            // eprintln(arr) / eprintln(map). Delegate to hexa_to_string.\n"
    buf = buf + "            HexaVal s = hexa_to_string(v);\n"
    buf = buf + "            if (HX_IS_STR(s) && HX_STR(s)) fprintf(stderr, \"%s\\n\", HX_STR(s));\n"
    buf = buf + "            else fprintf(stderr, \"<value>\\n\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        default: fprintf(stderr, \"<value>\\n\"); break;\n"
    buf = buf + "    }\n"
    buf = buf + "    // 2026-05-06 — auto-fflush stderr (mirror hexa_println 정합).\n"
    buf = buf + "    if (!hxlcl_getenv(\"HEXA_NO_AUTOFLUSH\")) fflush(stderr);\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// 2026-04-20 builtin: stderr + NO trailing newline (print/println symmetry).\n"
    buf = buf + "// Mirrors hexa_eprintln byte-for-byte except the \"\\n\" suffix is dropped from\n"
    buf = buf + "// every format branch. Motivating callers:\n"
    buf = buf + "//   tool/pkg/packages/token-forge/proxy/server.hexa\n"
    buf = buf + "//   self/ml/corpus_clean.hexa\n"
    buf = buf + "// which pre-2026-04-20 fell through to hexa_call1(eprint,...) and produced a\n"
    buf = buf + "// clang link error in AOT. Interp path also route-checks this name.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_eprint(HexaVal v);\n"
    buf = buf + "HexaVal hexa_eprint(HexaVal v) {\n"
    buf = buf + "    return rt_eprint(v);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_eprint(HexaVal v) {\n"
    buf = buf + "    // PROBE r14-L: float branches route through __hexa_format_float_for_print\n"
    buf = buf + "    // for to_string parity (NaN/inf canonical casing + 0.0 → \"0.0\").\n"
    buf = buf + "    char __fbuf[64];\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) && HX_VS(v)) {\n"
    buf = buf + "        HexaValStruct* vs = HX_VS(v);\n"
    buf = buf + "        switch (vs->tag_i) {\n"
    buf = buf + "            case TAG_INT:   fprintf(stderr, \"%lld\", (long long)vs->int_val); return hexa_void();\n"
    buf = buf + "            case TAG_FLOAT:\n"
    buf = buf + "                __hexa_format_float_for_print(vs->float_val, __fbuf, sizeof(__fbuf));\n"
    buf = buf + "                fprintf(stderr, \"%s\", __fbuf); return hexa_void();\n"
    buf = buf + "            case TAG_BOOL:  fprintf(stderr, \"%s\", vs->bool_val ? \"true\" : \"false\"); return hexa_void();\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            case TAG_STR: {\n"
    buf = buf + "                const char* cs = HX_STR(vs->str_val);\n"
    buf = buf + "                if (cs) { fprintf(stderr, \"%s\", cs); return hexa_void(); }\n"
    buf = buf + "                break;\n"
    buf = buf + "            }\n"
    buf = buf + "            case TAG_VOID:  fprintf(stderr, \"void\"); return hexa_void();\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_INT: fprintf(stderr, \"%lld\", (long long)HX_INT(v)); break;\n"
    buf = buf + "        case TAG_FLOAT:\n"
    buf = buf + "            __hexa_format_float_for_print(HX_FLOAT(v), __fbuf, sizeof(__fbuf));\n"
    buf = buf + "            fprintf(stderr, \"%s\", __fbuf); break;\n"
    buf = buf + "        case TAG_BOOL: fprintf(stderr, \"%s\", HX_BOOL(v) ? \"true\" : \"false\"); break;\n"
    buf = buf + "        case TAG_STR:\n"
    buf = buf + "            if (HX_STR(v)) fprintf(stderr, \"%s\", HX_STR(v));\n"
    buf = buf + "            else fprintf(stderr, \"<str null>\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        case TAG_VOID: fprintf(stderr, \"void\"); break;\n"
    buf = buf + "        case TAG_ARRAY:\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "            HexaVal s = hexa_to_string(v);\n"
    buf = buf + "            if (HX_IS_STR(s) && HX_STR(s)) fprintf(stderr, \"%s\", HX_STR(s));\n"
    buf = buf + "            else fprintf(stderr, \"<value>\");\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        default: fprintf(stderr, \"<value>\"); break;\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_void();\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ── to_string ────────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// 2026-04-20 container-repr fix: TAG_ARRAY/TAG_MAP branches added so\n"
    buf = buf + "// `str(arr)` / `str(map)` produce readable `[e1, e2]` / `{k: v, ...}`\n"
    buf = buf + "// output instead of the \"<value>\" fallback. Mirrors hexa_print_val\n"
    buf = buf + "// (runtime.c:2796) which already handled TAG_ARRAY — the asymmetry\n"
    buf = buf + "// between hexa_print_val (direct print) and hexa_to_string (string\n"
    buf = buf + "// concat via `+`) was surfacing as `\"arr=\" + str(arr) -> \"arr=<value>\"`.\n"
    buf = buf + "// Guards: recursion depth cap (8) to prevent stack blow-up on cyclic\n"
    buf = buf + "// references; element cap (64) so a 1M-element tensor-as-array does\n"
    buf = buf + "// not allocate a multi-MB string; null pointer guards on arr_ptr /\n"
    buf = buf + "// map_ptr / order_keys before deref (T33 arena-dangling defence).\n"
    buf = buf + "static HexaVal _hexa_to_string_rec(HexaVal v, int depth);\n"
    buf = buf + "\n"
    buf = buf + "// Step-4 cycle 96 port — scalar branches (int [outside cache] / float\n"
    buf = buf + "// [integer-valued in range] / bool / void / str) dispatch to hexa source.\n"
    buf = buf + "// Small-int cache + non-integer float [%g] + array/map/valstruct stay C.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "extern HexaVal rt_to_string_scalar(HexaVal v);\n"
    buf = buf + "HexaVal hexa_to_string(HexaVal v) {\n"
    buf = buf + "    /* Array/Map/ValStruct: recursive C body. */\n"
    buf = buf + "    if (HX_IS_VALSTRUCT(v) || HX_TAG(v) == TAG_ARRAY || HX_TAG(v) == TAG_MAP) {\n"
    buf = buf + "        return _hexa_to_string_rec(v, 0);\n"
    buf = buf + "    }\n"
    buf = buf + "    /* Small-int cache fast path. */\n"
    buf = buf + "    if (HX_IS_INT(v) &&\n"
    buf = buf + "        HX_INT(v) >= SMALL_INT_CACHE_MIN &&\n"
    buf = buf + "        HX_INT(v) <= SMALL_INT_CACHE_MAX) {\n"
    buf = buf + "        if (!_cached_small_ints_ready) _hexa_init_small_int_cache();\n"
    buf = buf + "        return _cached_small_ints[HX_INT(v) - SMALL_INT_CACHE_MIN];\n"
    buf = buf + "    }\n"
    buf = buf + "    /* Non-integer-valued float: env-honoring fmt (default %g, opt-in g15/g17\n"
    buf = buf + "     * via HEXA_FLOAT_REPR — matches print_val path).  PROBE r11 B6.\n"
    buf = buf + "     * PROBE r14-E: pre-empt NaN/inf with Rust canonical casing. */\n"
    buf = buf + "    if (HX_IS_FLOAT(v)) {\n"
    buf = buf + "        double f = HX_FLOAT(v);\n"
    buf = buf + "        const char* sp = __hexa_float_special_repr(f);\n"
    buf = buf + "        if (sp) return hexa_str(sp);\n"
    buf = buf + "        if (!(isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15)) {\n"
    buf = buf + "            char buf[64];\n"
    buf = buf + "            snprintf(buf, 64, __hexa_print_float_fmt(), f);\n"
    buf = buf + "            return hexa_str(buf);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return rt_to_string_scalar(v);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_to_string(HexaVal v) {\n"
    buf = buf + "    return _hexa_to_string_rec(v, 0);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "static HexaVal _hexa_to_string_rec(HexaVal v, int depth) {\n"
    buf = buf + "    if (!_cached_strs_ready) _hexa_init_cached_strs();\n"
    buf = buf + "    char buf[64];\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_INT: {\n"
    buf = buf + "            // ROI-33: small-int cache hit — skip snprintf+intern entirely\n"
    buf = buf + "            if (HX_INT(v) >= SMALL_INT_CACHE_MIN && HX_INT(v) <= SMALL_INT_CACHE_MAX) {\n"
    buf = buf + "                if (!_cached_small_ints_ready) _hexa_init_small_int_cache();\n"
    buf = buf + "                return _cached_small_ints[HX_INT(v) - SMALL_INT_CACHE_MIN];\n"
    buf = buf + "            }\n"
    buf = buf + "            snprintf(buf, 64, \"%lld\", (long long)HX_INT(v));\n"
    buf = buf + "            return hexa_str(buf);\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_FLOAT: {\n"
    buf = buf + "            // trk.27 fix 2026-05-06: preserve `.0` for whole-valued floats so\n"
    buf = buf + "            // to_string(0.0) returns \"0.0\" not \"0\", matching python json.dumps\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            // and existing test assertions (test_lang_core.hexa:141 +\n"
    buf = buf + "            // test_type_coercion.hexa:35 — to_string(3.0) == \"3.0\"). Plain %g\n"
    buf = buf + "            // strips trailing zeros — use %.1f when float is integer-valued +\n"
    buf = buf + "            // finite + within int-representable range; env-honoring fmt\n"
    buf = buf + "            // (default %g, opt-in g15/g17 via HEXA_FLOAT_REPR) otherwise.\n"
    buf = buf + "            // PROBE r11 B6.\n"
    buf = buf + "            // PROBE r14-E (2026-05-23): pre-empt NaN/inf with Rust canonical\n"
    buf = buf + "            // casing (\"NaN\"/\"inf\"/\"-inf\") before falling through to %g/%.1f\n"
    buf = buf + "            // (libc default is lowercase \"nan\"/\"inf\").\n"
    buf = buf + "            double f = HX_FLOAT(v);\n"
    buf = buf + "            const char* sp = __hexa_float_special_repr(f);\n"
    buf = buf + "            if (sp) return hexa_str(sp);\n"
    buf = buf + "            if (isfinite(f) && f == floor(f) && f >= -1e15 && f <= 1e15) {\n"
    buf = buf + "                snprintf(buf, 64, \"%.1f\", f);\n"
    buf = buf + "            } else {\n"
    buf = buf + "                snprintf(buf, 64, __hexa_print_float_fmt(), f);\n"
    buf = buf + "            }\n"
    buf = buf + "            return hexa_str(buf);\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_BOOL: return HX_BOOL(v) ? _cached_str_true : _cached_str_false;\n"
    buf = buf + "        case TAG_STR: return v;\n"
    buf = buf + "        case TAG_VOID: return _cached_str_void;\n"
    buf = buf + "        // rt 32-G: minimal fallback repr — interpreter has its own\n"
    buf = buf + "        // val_to_string for the full form.\n"
    buf = buf + "        // Step 4 cycle 97 — minimal-repr port (잔여 #8). C wrapper retains\n"
    buf = buf + "        // the HX_VS NULL guard + `<Val null>` sentinel; hexa source emits\n"
    buf = buf + "        // the `Val{tag=N,i=M}` body via existing .get() builtin which\n"
    buf = buf + "        // routes through hexa_valstruct_get_by_key at runtime (no new\n"
    buf = buf + "        // codegen builtin required).\n"
    buf = buf + "        case TAG_VALSTRUCT: {\n"
    buf = buf + "            if (!HX_VS(v)) return hexa_str(\"<Val null>\");\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            extern HexaVal rt_valstruct_repr(HexaVal v);\n"
    buf = buf + "            return rt_valstruct_repr(v);\n"
    buf = buf + "#else\n"
    buf = buf + "            snprintf(buf, 64, \"Val{tag=%lld,i=%lld}\",\n"
    buf = buf + "                (long long)HX_VSF(v, tag_i), (long long)HX_VSF(v, int_val));\n"
    buf = buf + "            return hexa_str(buf);\n"
    buf = buf + "#endif\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_ARRAY: {\n"
    buf = buf + "            if (depth >= 8) return hexa_str(\"[...]\");\n"
    buf = buf + "            if (!v.arr_ptr) return hexa_str(\"[<null>]\");\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            // Step 5 #3 cycle C2-retry — array container render ports to\n"
    buf = buf + "            // hexa source. NULL-ptr + depth guards stay C; rt_to_string_array\n"
    buf = buf + "            // owns the element loop / cap / overflow-trailer; nested\n"
    buf = buf + "            // arrays/maps recurse in hexa, scalars dispatch to hexa_to_string.\n"
    buf = buf + "            extern HexaVal rt_to_string_array(HexaVal arr, HexaVal depth);\n"
    buf = buf + "            return rt_to_string_array(v, hexa_int(depth));\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#else\n"
    buf = buf + "            int n = HX_ARR_LEN(v);\n"
    buf = buf + "            int cap = 64;  // element-dump cap\n"
    buf = buf + "            HexaVal out = hexa_str(\"[\");\n"
    buf = buf + "            HexaVal sep = hexa_str(\", \");\n"
    buf = buf + "            int shown = n < cap ? n : cap;\n"
    buf = buf + "            for (int i = 0; i < shown; i++) {\n"
    buf = buf + "                if (i > 0) out = hexa_str_concat(out, sep);\n"
    buf = buf + "                out = hexa_str_concat(out, _hexa_to_string_rec(HX_ARR_ITEMS(v)[i], depth + 1));\n"
    buf = buf + "            }\n"
    buf = buf + "            if (n > cap) {\n"
    buf = buf + "                snprintf(buf, 64, \", ... (%d more)\", n - cap);\n"
    buf = buf + "                out = hexa_str_concat(out, hexa_str(buf));\n"
    buf = buf + "            }\n"
    buf = buf + "            out = hexa_str_concat(out, hexa_str(\"]\"));\n"
    buf = buf + "            return out;\n"
    buf = buf + "#endif\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_ENUM: {\n"
    buf = buf + "            // PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): route through\n"
    buf = buf + "            // `_hexa_enum_display` so both the new descriptor form (emitted\n"
    buf = buf + "            // by gen2_enum_decl after this PR) and the legacy bare-string\n"
    buf = buf + "            // form (pre-PR `hexa_enum_str(display)`) render identically.\n"
    buf = buf + "            return hexa_str(_hexa_enum_display(v));\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "            if (depth >= 8) return hexa_str(\"{...}\");\n"
    buf = buf + "            HexaMapTable* t = HX_MAP_TBL(v);\n"
    buf = buf + "            if (!t) return hexa_str(\"{}\");\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            // Step 5 #3 cycle C2-retry — map container render ports to hexa\n"
    buf = buf + "            // source. NULL-tbl + depth guards stay C; rt_to_string_map owns\n"
    buf = buf + "            // the key/value loop.\n"
    buf = buf + "            extern HexaVal rt_to_string_map(HexaVal m, HexaVal depth);\n"
    buf = buf + "            return rt_to_string_map(v, hexa_int(depth));\n"
    buf = buf + "#else\n"
    buf = buf + "            int n = t->len;\n"
    buf = buf + "            int cap = 64;\n"
    buf = buf + "            HexaVal out = hexa_str(\"{\");\n"
    buf = buf + "            HexaVal sep = hexa_str(\", \");\n"
    buf = buf + "            HexaVal kv_sep = hexa_str(\": \");\n"
    buf = buf + "            int shown = n < cap ? n : cap;\n"
    buf = buf + "            for (int i = 0; i < shown; i++) {\n"
    buf = buf + "                if (i > 0) out = hexa_str_concat(out, sep);\n"
    buf = buf + "                const char* k = (t->order_keys && t->order_keys[i]) ? t->order_keys[i] : \"<null>\";\n"
    buf = buf + "                out = hexa_str_concat(out, hexa_str(k));\n"
    buf = buf + "                out = hexa_str_concat(out, kv_sep);\n"
    buf = buf + "                out = hexa_str_concat(out, _hexa_to_string_rec(t->order_vals[i], depth + 1));\n"
    buf = buf + "            }\n"
    buf = buf + "            if (n > cap) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                snprintf(buf, 64, \", ... (%d more)\", n - cap);\n"
    buf = buf + "                out = hexa_str_concat(out, hexa_str(buf));\n"
    buf = buf + "            }\n"
    buf = buf + "            out = hexa_str_concat(out, hexa_str(\"}\"));\n"
    buf = buf + "            return out;\n"
    buf = buf + "#endif\n"
    buf = buf + "        }\n"
    buf = buf + "        default: return _cached_str_value;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Truthy check ─────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "int hexa_truthy(HexaVal v) {\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_BOOL: return HX_BOOL(v);\n"
    buf = buf + "        case TAG_INT: return HX_INT(v) != 0;\n"
    buf = buf + "        // 2026-04-20 silent-fallback audit: TAG_FLOAT was falling through\n"
    buf = buf + "        // to `default: return 1`, so `if 0.0 { ... }` evaluated truthy.\n"
    buf = buf + "        // Match TAG_INT semantics — zero is falsy. NaN is truthy (non-zero).\n"
    buf = buf + "        case TAG_FLOAT: return HX_FLOAT(v) != 0.0;\n"
    buf = buf + "        case TAG_STR: return HX_STR(v) != NULL && HX_STR(v)[0] != 0;\n"
    buf = buf + "        case TAG_VOID: return 0;\n"
    buf = buf + "        // RFC r16 (PROBE r16): empty collection is FALSY, consistent with\n"
    buf = buf + "        // `if 0` / `if 0.0` / `if \"\"`. Non-empty stays truthy. Closes the\n"
    buf = buf + "        // last `default: return 1` fall-through gap (same class of bug as the\n"
    buf = buf + "        // 2026-04-20 TAG_FLOAT 0.0 audit above).\n"
    buf = buf + "        case TAG_ARRAY: return HX_ARR_LEN(v) > 0;\n"
    buf = buf + "        // TAG_MAP: empty anonymous map `#{}` is falsy. A struct instance is a\n"
    buf = buf + "        // TAG_MAP carrying a \"__type__\" carrier field (hexa_struct_pack_map),\n"
    buf = buf + "        // so it always has len >= 1 and stays truthy — RFC §4/Q2: struct\n"
    buf = buf + "        // existence != empty collection. The explicit __type__ guard keeps\n"
    buf = buf + "        // structs truthy regardless of user field count.\n"
    buf = buf + "        case TAG_MAP:\n"
    buf = buf + "            if (HX_MAP_TBL(v) == NULL) return 0;\n"
    buf = buf + "            if (hmap_find(HX_MAP_TBL(v), \"__type__\", hexa_fnv1a_str(\"__type__\")) >= 0) return 1;\n"
    buf = buf + "            return HX_MAP_LEN(v) > 0;\n"
    buf = buf + "        // rt 32-G: TAG_VALSTRUCT truthy iff .vs pointer non-null.\n"
    buf = buf + "        case TAG_VALSTRUCT: return HX_VS(v) != NULL;\n"
    buf = buf + "        default: return 1;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Type checking ────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_type_of(HexaVal v) {\n"
    buf = buf + "    if (!_cached_strs_ready) _hexa_init_cached_strs();\n"
    buf = buf + "    switch (HX_TAG(v)) {\n"
    buf = buf + "        case TAG_INT: return _cached_str_int;\n"
    buf = buf + "        case TAG_FLOAT: return _cached_str_float;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        case TAG_BOOL: return _cached_str_bool;\n"
    buf = buf + "        case TAG_STR: return _cached_str_string;\n"
    buf = buf + "        case TAG_VOID: return _cached_str_void;\n"
    buf = buf + "        case TAG_ARRAY: return _cached_str_array;\n"
    buf = buf + "        case TAG_MAP: return _cached_str_map;\n"
    buf = buf + "        // 2026-04-20 silent-fallback audit: prior default dropped TAG_FN /\n"
    buf = buf + "        // TAG_CHAR / TAG_CLOSURE into \"unknown\" — Hexa-side dispatch like\n"
    buf = buf + "        // `type_of(x) != \"string\"` then misclassified callable values.\n"
    buf = buf + "        // Surface them explicitly; any remaining unknown tag is a real bug.\n"
    buf = buf + "        case TAG_FN: return _cached_str_fn;\n"
    buf = buf + "        case TAG_CHAR: return _cached_str_char;\n"
    buf = buf + "        case TAG_CLOSURE: return _cached_str_closure;\n"
    buf = buf + "        // rt 32-G: Val is a struct at the Hexa level; surface \"struct\".\n"
    buf = buf + "        case TAG_VALSTRUCT: return _cached_str_struct;\n"
    buf = buf + "        // PR-2.0 (enum-to-string-codegen-emit RFC, 2026-05-24): surface\n"
    buf = buf + "        // \"enum\" so user-level `type_of(Color::Red) == \"enum\"` works once\n"
    buf = buf + "        // PR-2.1 migrates emit to TAG_ENUM. DEAD CODE under PR-2.0 (no\n"
    buf = buf + "        // emitter produces TAG_ENUM yet — Color::Red is TAG_INT today).\n"
    buf = buf + "        case TAG_ENUM: return _cached_str_enum;\n"
    buf = buf + "        default: return _cached_str_unknown;\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Polymorphic add (int + or string concat) ─────────────\n"
    buf = buf + "\n"
    buf = buf + "// ROI-37: rename impl to _slow so the macro below can inline the int+int\n"
    buf = buf + "// fast path without function-call ABI overhead.\n"
    buf = buf + "/* PHASE 1.2.B (2026-05-15): de-staticized. Slow-path fallback for the\n"
    buf = buf + " * hexa_add macro emitted into runtime.h — user.c TUs link against this. */\n"
    buf = buf + "// RUNTIME.md Step 4 .c-none arith core op 5: hexa_add_slow (the slow path behind\n"
    buf = buf + "// the int+int hexa_add MACRO) delegates to hexa-source rt_add_slow under\n"
    buf = buf + "// HEXA_HAS_HEXA_RT_STDLIB. The float branch uses the __raw_add_f escape (defined\n"
    buf = buf + "// below) so the hexa code never re-enters hexa_add via `+`. #else C body kept\n"
    buf = buf + "// bit-for-bit for the standalone link.\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_add_slow(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_add_slow(HexaVal a, HexaVal b) { return rt_add_slow(a, b); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_add_slow(HexaVal a, HexaVal b) {\n"
    buf = buf + "    // Bool → int coercion (Python canonical: True=1, False=0).  Without this,\n"
    buf = buf + "    // `true + 1` fell through to `hexa_to_string + str_concat` → \"true1\".\n"
    buf = buf + "    // Round-7 probe finding.\n"
    buf = buf + "    if (HX_IS_BOOL(a)) a = hexa_int(HX_BOOL(a) ? 1 : 0);\n"
    buf = buf + "    if (HX_IS_BOOL(b)) b = hexa_int(HX_BOOL(b) ? 1 : 0);\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_INT(b)) return hexa_int(HX_INT(a) + HX_INT(b));\n"
    buf = buf + "    if (HX_IS_FLOAT(a) || HX_IS_FLOAT(b)) {\n"
    buf = buf + "        // T39: unwrap via __hx_to_double so TAG_VALSTRUCT wrappers don't\n"
    buf = buf + "        // cast the vs pointer to double (same root as T32 to_float bug).\n"
    buf = buf + "        double fa = __hx_to_double(a);\n"
    buf = buf + "        double fb = __hx_to_double(b);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "        return hexa_float(fa + fb);\n"
    buf = buf + "    }\n"
    buf = buf + "    // B13: array concat. Interpreter (hexa_full.hexa:6954) does this but\n"
    buf = buf + "    // codegen emits bare hexa_add(l,r) — without this branch, two arrays\n"
    buf = buf + "    // fall through to to_string+str_concat → TAG_STR, then later arr[i]\n"
    buf = buf + "    // reads .arr.len from a TAG_STR union slot (stack residue → random OOB).\n"
    buf = buf + "    if (HX_IS_ARRAY(a) && HX_IS_ARRAY(b)) {\n"
    buf = buf + "        HexaVal out = hexa_array_new();\n"
    buf = buf + "        for (int i = 0; i < HX_ARR_LEN(a); i++) out = hexa_array_push(out, HX_ARR_ITEMS(a)[i]);\n"
    buf = buf + "        for (int i = 0; i < HX_ARR_LEN(b); i++) out = hexa_array_push(out, HX_ARR_ITEMS(b)[i]);\n"
    buf = buf + "        return out;\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal sa = hexa_to_string(a);\n"
    buf = buf + "    HexaVal sb = hexa_to_string(b);\n"
    buf = buf + "    return hexa_str_concat(sa, sb);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "// float-add escape for rt_add_slow — mirrors hexa_add_slow's float branch\n"
    buf = buf + "// exactly: bool→int coerce, then hexa_float(__hx_to_double(a) + __hx_to_double(b))\n"
    buf = buf + "// (so a non-numeric operand coerces to 0.0, same quirk as C). NOT inlined by\n"
    buf = buf + "// codegen (multi-statement) — emitted as a direct/fp call, resolved here. Same\n"
    buf = buf + "// __raw_* class as __raw_idiv/imod/fmod.\n"
    buf = buf + "static inline HexaVal __raw_add_f(HexaVal a, HexaVal b) {\n"
    buf = buf + "    if (HX_IS_BOOL(a)) a = hexa_int(HX_BOOL(a) ? 1 : 0);\n"
    buf = buf + "    if (HX_IS_BOOL(b)) b = hexa_int(HX_BOOL(b) ? 1 : 0);\n"
    buf = buf + "    return hexa_float(__hx_to_double(a) + __hx_to_double(b));\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ROI-37: inline macro — int+int hot path avoids 32-byte HexaVal call ABI.\n"
    buf = buf + "// Evaluates each operand exactly once via temporaries.\n"
    buf = buf + "#define hexa_add(A, B) \\\n"
    buf = buf + "    ({ HexaVal __ha = (A), __hb = (B); \\\n"
    buf = buf + "       (HX_IS_INT(__ha) && HX_IS_INT(__hb)) \\\n"
    buf = buf + "           ? hexa_int(HX_INT(__ha) + HX_INT(__hb)) \\\n"
    buf = buf + "           : hexa_add_slow(__ha, __hb); })\n"
    buf = buf + "\n"
    buf = buf + "// ── Variadic concat (N-way) — clang bracket-depth relief ─────\n"
    buf = buf + "// codegen flattens long `+` chains (≥16 operands) into a single call:\n"
    buf = buf + "//   hexa_concat_many(N, (HexaVal[]){e1, e2, ..., eN})\n"
    buf = buf + "// instead of hexa_add(hexa_add(hexa_add(...))) which blows past clang's\n"
    buf = buf + "// default 256-level bracket nesting limit on anima launcher files\n"
    buf = buf + "// (launch_alm_14b_r9.hexa ~170 deep → fatal). Semantics = left-fold via\n"
    buf = buf + "// hexa_add so mixed int/string/array inputs follow the same rules as the\n"
    buf = buf + "// pairwise operator.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_concat_many(int n, HexaVal* parts) {\n"
    buf = buf + "    if (n <= 0) return hexa_str(\"\");\n"
    buf = buf + "    HexaVal acc = parts[0];\n"
    buf = buf + "    for (int i = 1; i < n; i++) {\n"
    buf = buf + "        acc = hexa_add(acc, parts[i]);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    }\n"
    buf = buf + "    return acc;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "// Step-3 cycle 89 — hexa-source port via TAG_ARRAY bridge. The variadic\n"
    buf = buf + "// `HexaVal*` C buffer can't be expressed in hexa source (잔여 #7), so\n"
    buf = buf + "// we wrap it in a TAG_ARRAY HexaVal (one hexa_array_new + n pushes) and\n"
    buf = buf + "// delegate to rt_concat_many_arr. Semantics are byte-identical to the C\n"
    buf = buf + "// body (left-fold `acc = acc + parts[i]` lowers to `hexa_add(acc,\n"
    buf = buf + "// parts[i])` since `acc` is `let mut` untyped). Owner of the loop:\n"
    buf = buf + "// stdlib/runtime/numeric.hexa::rt_concat_many_arr.\n"
    buf = buf + "extern HexaVal rt_concat_many_arr(HexaVal parts);\n"
    buf = buf + "HexaVal hexa_concat_many(int n, HexaVal* parts) {\n"
    buf = buf + "    if (n <= 0) return hexa_str(\"\");\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    for (int i = 0; i < n; i++) {\n"
    buf = buf + "        arr = hexa_array_push(arr, parts[i]);\n"
    buf = buf + "    }\n"
    buf = buf + "    return rt_concat_many_arr(arr);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ── Polymorphic equality ─────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "/* Step 3 cycle 100 — pointer-eq inline builtins for hexa_eq TAG_VALSTRUCT\n"
    buf = buf + " * + TAG_MAP branches (RUNTIME.md 잔여 #4, 4 of 9 branches ported). The\n"
    buf = buf + " * aprime_cc codegen inlines `__vs_ptr_eq(a,b)` / `__map_ptr_eq(a,b)` to\n"
    buf = buf + " * `hexa_bool(HX_VS(a)==HX_VS(b))` etc. The hexat bootstrap transpiler\n"
    buf = buf + " * is unaware of the inline lowering and emits\n"
    buf = buf + " * `hexa_call2(__vs_ptr_eq, a, b)`; the static-inline defs below satisfy\n"
    buf = buf + " * that indirect-call path via the `hexa_call2` _Generic dispatch on\n"
    buf = buf + " * `HexaVal (*)(HexaVal, HexaVal)`. Either way the lowered compare is\n"
    buf = buf + " * byte-identical to the legacy C body. Mirror lives in self/runtime.h\n"
    buf = buf + " * for non-aprime build paths. */\n"
    buf = buf + "#ifndef __vs_ptr_eq_DEFINED\n"
    buf = buf + "#define __vs_ptr_eq_DEFINED\n"
    buf = buf + "static inline HexaVal __vs_ptr_eq(HexaVal a, HexaVal b) {\n"
    buf = buf + "    return hexa_bool((HX_VS(a)) == (HX_VS(b)));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifndef __map_ptr_eq_DEFINED\n"
    buf = buf + "#define __map_ptr_eq_DEFINED\n"
    buf = buf + "static inline HexaVal __map_ptr_eq(HexaVal a, HexaVal b) {\n"
    buf = buf + "    return hexa_bool((HX_MAP_TBL(a)) == (HX_MAP_TBL(b)));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_eq(HexaVal a, HexaVal b) {\n"
    buf = buf + "    // Cross-type numeric equality (int ↔ float) — matches interp\n"
    buf = buf + "    // eval_binop float-coerce path (hexa_full.hexa:7867). 이전엔\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    // tag 불일치 즉시 false → `2 == 2.0` AOT=false / interp=true\n"
    buf = buf + "    // divergence 를 유발.\n"
    buf = buf + "    if (HX_IS_INT(a) && HX_IS_FLOAT(b)) return hexa_bool((double)HX_INT(a) == HX_FLOAT(b));\n"
    buf = buf + "    if (HX_IS_FLOAT(a) && HX_IS_INT(b)) return hexa_bool(HX_FLOAT(a) == (double)HX_INT(b));\n"
    buf = buf + "    if (HX_TAG(a) != HX_TAG(b)) return hexa_bool(0);\n"
    buf = buf + "    switch (HX_TAG(a)) {\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "        /* Step-3 cycle 103 — same-tag scalar branches ported to hexa\n"
    buf = buf + "           source (RUNTIME.md 잔여 #4 → 9/9 candidate branches). Both\n"
    buf = buf + "           operands are guaranteed the same scalar tag here (cross-type\n"
    buf = buf + "           numeric coercion + HX_TAG(a)==HX_TAG(b) guard already passed).\n"
    buf = buf + "           rt_eq_int/float express equality via ordered comparisons\n"
    buf = buf + "           (hexa_cmp_le/ge — NOT redirected, byte-exact incl. NaN);\n"
    buf = buf + "           rt_eq_bool avoids comparison on HexaVals entirely. None lower\n"
    buf = buf + "           to a hexa_eq call site, so no recursion (transpile-verified). */\n"
    buf = buf + "        case TAG_INT: {\n"
    buf = buf + "            extern HexaVal rt_eq_int(HexaVal a, HexaVal b);\n"
    buf = buf + "            return hexa_bool(hexa_truthy(rt_eq_int(a, b)));\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_FLOAT: {\n"
    buf = buf + "            extern HexaVal rt_eq_float(HexaVal a, HexaVal b);\n"
    buf = buf + "            return hexa_bool(hexa_truthy(rt_eq_float(a, b)));\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_BOOL: {\n"
    buf = buf + "            extern HexaVal rt_eq_bool(HexaVal a, HexaVal b);\n"
    buf = buf + "            return hexa_bool(hexa_truthy(rt_eq_bool(a, b)));\n"
    buf = buf + "        }\n"
    buf = buf + "#else\n"
    buf = buf + "        case TAG_INT: return hexa_bool(HX_INT(a) == HX_INT(b));\n"
    buf = buf + "        case TAG_FLOAT: return hexa_bool(HX_FLOAT(a) == HX_FLOAT(b));\n"
    buf = buf + "        case TAG_BOOL: return hexa_bool(HX_BOOL(a) == HX_BOOL(b));\n"
    buf = buf + "#endif\n"
    buf = buf + "        case TAG_STR: {\n"
    buf = buf + "            /* Intern fast-path stays C (HX_STR pointer identity). */\n"
    buf = buf + "            if (HX_STR(a) == HX_STR(b)) return hexa_bool(1);\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            /* Step-3 cycle 91 — strcmp fallback via cycle-57 rt_str_eq_b. */\n"
    buf = buf + "            extern HexaVal rt_str_eq_b(HexaVal a, HexaVal b);\n"
    buf = buf + "            return hexa_bool(hexa_truthy(rt_str_eq_b(a, b)));\n"
    buf = buf + "#else\n"
    buf = buf + "            return hexa_bool(hxlcl_strcmp(HX_STR(a), HX_STR(b)) == 0);\n"
    buf = buf + "#endif\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_VOID: return hexa_bool(1);\n"
    buf = buf + "        // rt 32-G: Val identity is pointer-equality of heap struct (matches\n"
    buf = buf + "        // TAG_MAP semantics — two separately constructed maps never compare\n"
    buf = buf + "        // equal by value).\n"
    buf = buf + "        case TAG_VALSTRUCT: {\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            /* Step-3 cycle 100 — hexa-source port via __vs_ptr_eq inline\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "               builtin. The hexa body is a single `return __vs_ptr_eq(a, b)`,\n"
    buf = buf + "               so the lowered C is a single `HX_VS(a) == HX_VS(b)` compare —\n"
    buf = buf + "               byte-equivalent to the legacy path. RUNTIME.md 잔여 #4\n"
    buf = buf + "               (3 of 9 branches now ported). */\n"
    buf = buf + "            extern HexaVal rt_eq_valstruct(HexaVal a, HexaVal b);\n"
    buf = buf + "            return hexa_bool(hexa_truthy(rt_eq_valstruct(a, b)));\n"
    buf = buf + "#else\n"
    buf = buf + "            return hexa_bool(HX_VS(a) == HX_VS(b));\n"
    buf = buf + "#endif\n"
    buf = buf + "        }\n"
    buf = buf + "        // Array deep equality — interp eval_binop (hexa_full.hexa:7939) 가\n"
    buf = buf + "        // 요소별 vals_equal 로 비교하므로 AOT 도 요소 재귀 비교로 정렬.\n"
    buf = buf + "        // 이전 comment 는 interp 가 ref eq 이라고 기록했지만 실제 코드는\n"
    buf = buf + "        // value eq. 같은 포인터 shortcut 으로 빠른 경로 유지.\n"
    buf = buf + "        case TAG_ARRAY: {\n"
    buf = buf + "            /* Same-ptr fast-path + length check stay C (cheap). */\n"
    buf = buf + "            if (a.arr_ptr == b.arr_ptr) return hexa_bool(1);\n"
    buf = buf + "            int __na = HX_ARR_LEN(a); int __nb = HX_ARR_LEN(b);\n"
    buf = buf + "            if (__na != __nb) return hexa_bool(0);\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            /* Step-3 cycle 97 — element-by-element deep loop via\n"
    buf = buf + "               rt_eq_array_deep (hexa source). Inside the ported fn,\n"
    buf = buf + "               `a[i] != b[i]` re-enters hexa_eq for each pair; scalar\n"
    buf = buf + "               cases stay C, nested arrays recurse back into this\n"
    buf = buf + "               case → rt_eq_array_deep. Mutual recursion on a strictly\n"
    buf = buf + "               smaller subtree, so well-formed input terminates. */\n"
    buf = buf + "            extern HexaVal rt_eq_array_deep(HexaVal a, HexaVal b);\n"
    buf = buf + "            return hexa_bool(hexa_truthy(rt_eq_array_deep(a, b)));\n"
    buf = buf + "#else\n"
    buf = buf + "            HexaVal* __xa = HX_ARR_ITEMS(a); HexaVal* __xb = HX_ARR_ITEMS(b);\n"
    buf = buf + "            for (int __i = 0; __i < __na; __i++) {\n"
    buf = buf + "                if (!hexa_truthy(hexa_eq(__xa[__i], __xb[__i]))) return hexa_bool(0);\n"
    buf = buf + "            }\n"
    buf = buf + "            return hexa_bool(1);\n"
    buf = buf + "#endif\n"
    buf = buf + "        }\n"
    buf = buf + "        case TAG_MAP: {\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "            /* Step-3 cycle 100 — hexa-source pointer-eq fast-path via\n"
    buf = buf + "               __map_ptr_eq inline builtin (RUNTIME.md 잔여 #4, 4 of 9\n"
    buf = buf + "               branches now ported). Hexa body is `return __map_ptr_eq(a, b)`\n"
    buf = buf + "               which lowers to the same `HX_MAP_TBL(a) == HX_MAP_TBL(b)`\n"
    buf = buf + "               compare. The `__tag` enum-variant deep-compare below stays\n"
    buf = buf + "               C-side (separate logic, future cycle). */\n"
    buf = buf + "            extern HexaVal rt_eq_map_ptr(HexaVal a, HexaVal b);\n"
    buf = buf + "            if (hexa_truthy(rt_eq_map_ptr(a, b))) return hexa_bool(1);\n"
    buf = buf + "#else\n"
    buf = buf + "            if (HX_MAP_TBL(a) == HX_MAP_TBL(b)) return hexa_bool(1);\n"
    buf = buf + "#endif\n"
    buf = buf + "            // #28 — enum value equality. The native (aprime_cc) lowering\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            // represents an enum variant as a map { \"__tag\": hash, \"__pN\": … }\n"
    buf = buf + "            // (compiler/lower/hir_to_mir.hexa enum_path → struct_lit). Two\n"
    buf = buf + "            // separately constructed enum maps for the same variant must\n"
    buf = buf + "            // compare equal, mirroring the match-arm `__tag` discriminant\n"
    buf = buf + "            // test. Plain maps / structs (\"__type__\"-keyed, or no marker)\n"
    buf = buf + "            // keep pointer-identity semantics — unchanged. Scoped strictly\n"
    buf = buf + "            // to \"__tag\"-bearing maps so struct / dict `==` is untouched.\n"
    buf = buf + "            if (hexa_map_contains_key(a, \"__tag\") && hexa_map_contains_key(b, \"__tag\")) {\n"
    buf = buf + "                HexaVal ta = hexa_map_get(a, \"__tag\");\n"
    buf = buf + "                HexaVal tb = hexa_map_get(b, \"__tag\");\n"
    buf = buf + "                if (!hexa_truthy(hexa_eq(ta, tb))) return hexa_bool(0);\n"
    buf = buf + "                // Same variant ⇒ same payload arity. Compare each \"__pN\"\n"
    buf = buf + "                // payload structurally until the first absent slot.\n"
    buf = buf + "                for (int __pi = 0; ; __pi++) {\n"
    buf = buf + "                    char __pk[24];\n"
    buf = buf + "                    snprintf(__pk, sizeof(__pk), \"__p%d\", __pi);\n"
    buf = buf + "                    int ha = hexa_map_contains_key(a, __pk);\n"
    buf = buf + "                    int hb = hexa_map_contains_key(b, __pk);\n"
    buf = buf + "                    if (!ha && !hb) break;\n"
    buf = buf + "                    if (ha != hb) return hexa_bool(0);\n"
    buf = buf + "                    if (!hexa_truthy(hexa_eq(hexa_map_get(a, __pk),\n"
    buf = buf + "                                             hexa_map_get(b, __pk))))\n"
    buf = buf + "                        return hexa_bool(0);\n"
    buf = buf + "                }\n"
    buf = buf + "                return hexa_bool(1);\n"
    buf = buf + "            }\n"
    buf = buf + "            return hexa_bool(0);\n"
    buf = buf + "        }\n"
    buf = buf + "        // TAG_FN: compare underlying C function pointer (descriptor indirection\n"
    buf = buf + "        // may differ for two separately-constructed wrappers of the same fn).\n"
    buf = buf + "        case TAG_FN:\n"
    buf = buf + "            return hexa_bool(\n"
    buf = buf + "                (a.fn_ptr_d && b.fn_ptr_d)\n"
    buf = buf + "                    ? (HX_FN_PTR(a) == HX_FN_PTR(b))\n"
    buf = buf + "                    : (a.fn_ptr_d == b.fn_ptr_d));\n"
    buf = buf + "        case TAG_CHAR: return hexa_bool(HX_INT(a) == HX_INT(b));\n"
    buf = buf + "        case TAG_CLOSURE:\n"
    buf = buf + "            return hexa_bool(\n"
    buf = buf + "                (a.clo_ptr && b.clo_ptr)\n"
    buf = buf + "                    ? (HX_CLO_PTR(a) == HX_CLO_PTR(b))\n"
    buf = buf + "                    : (a.clo_ptr == b.clo_ptr));\n"
    buf = buf + "        case TAG_ENUM: {\n"
    buf = buf + "            // PROBE r14-TTTT (enum-ordering RFC, 2026-05-24): pointer-eq\n"
    buf = buf + "            // covers both descriptor and bare forms (each variant has a\n"
    buf = buf + "            // single static instance per TU); strcmp on display string is the\n"
    buf = buf + "            // cross-TU fallback so the new descriptor form and the legacy\n"
    buf = buf + "            // bare form compare equal when they name the same variant.\n"
    buf = buf + "            if (HX_STR(a) == HX_STR(b)) return hexa_bool(1);\n"
    buf = buf + "            const char* da = _hexa_enum_display(a);\n"
    buf = buf + "            const char* db = _hexa_enum_display(b);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            if (!da || !db) return hexa_bool(0);\n"
    buf = buf + "            return hexa_bool(hxlcl_strcmp(da, db) == 0);\n"
    buf = buf + "        }\n"
    buf = buf + "        default: return hexa_bool(0);\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── File I/O ─────────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────────────\n"
    buf = buf + "// M1 full · file layer (hxa-20260423-003 Step 3)\n"
    buf = buf + "// rt_file_* hand-port — authoritative implementations for file I/O.\n"
    buf = buf + "// hexa_* wrappers below are shims forwarding to rt_* (preserves external\n"
    buf = buf + "// ABI: self/bootstrap_compiler.c, build_c.hexa emit, codegen emit).\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_read_file(HexaVal path) {\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"rb\");\n"
    buf = buf + "    if (!f) return hexa_str(\"\");\n"
    buf = buf + "    fseek(f, 0, SEEK_END);\n"
    buf = buf + "    long len = ftell(f);\n"
    buf = buf + "    fseek(f, 0, SEEK_SET);\n"
    buf = buf + "    char* buf = malloc(len + 1);\n"
    buf = buf + "    fread(buf, 1, len, f);\n"
    buf = buf + "    buf[len] = 0;\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    return hexa_str_own(buf);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_write_file(HexaVal path, HexaVal content) {\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"wb\");\n"
    buf = buf + "    if (!f) return hexa_bool(0);\n"
    buf = buf + "    const char* s = HX_STR(content);\n"
    buf = buf + "    size_t len = s ? hxlcl_strlen(s) : 0;\n"
    buf = buf + "    fwrite(s, 1, len, f);\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    return hexa_bool(1);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// P7-6 builtin (2026-04-18): boolean existence probe. Used by native_build\n"
    buf = buf + "// and other self-hosting scripts to gate optional inputs without a\n"
    buf = buf + "// full read_file round-trip.\n"
    buf = buf + "//\n"
    buf = buf + "// ω-stdlib-2 (2026-04-26): refined to S_ISREG semantics, matching the\n"
    buf = buf + "// portable_fs.hexa POSIX-wc contract that consumers were forced to alias\n"
    buf = buf + "// around (pfs_file_exists). Previously used access(p, F_OK) which returns\n"
    buf = buf + "// true for ANY path entry incl. directories / symlinks-to-dirs / sockets.\n"
    buf = buf + "// Now: stat() + S_ISREG → true only for regular files. Null/missing/non-\n"
    buf = buf + "// regular → false. No errno propagation.\n"
    buf = buf + "HexaVal rt_file_exists(HexaVal path) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    const char* p = HX_STR(path);\n"
    buf = buf + "    if (!p) return hexa_bool(0);\n"
    buf = buf + "    struct stat st;\n"
    buf = buf + "    if (hxlcl_stat(p, &st) != 0) return hexa_bool(0);\n"
    buf = buf + "    return hexa_bool(S_ISREG(st.st_mode) ? 1 : 0);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// path_exists: stat-based existence probe — true for ANY path that\n"
    buf = buf + "// exists (regular file OR directory OR other). Mirrors Rust\n"
    buf = buf + "// Path::exists() / Go os.Stat + !IsNotExist. (file_exists is\n"
    buf = buf + "// regular-file-only via S_ISREG; dir_exists is S_ISDIR.)\n"
    buf = buf + "HexaVal rt_path_exists(HexaVal path) {\n"
    buf = buf + "    const char* p = HX_STR(path);\n"
    buf = buf + "    if (!p) return hexa_bool(0);\n"
    buf = buf + "    struct stat st;\n"
    buf = buf + "    return hexa_bool(hxlcl_stat(p, &st) == 0 ? 1 : 0);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Binary file I/O — write_bytes / read_file_bytes ─────\n"
    buf = buf + "// write_bytes: takes a path and a TAG_ARRAY of integers (0-255),\n"
    buf = buf + "// writes raw bytes. Null bytes survive — true binary I/O.\n"
    buf = buf + "HexaVal rt_write_bytes(HexaVal path, HexaVal arr) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n"
    buf = buf + "    int len = HX_ARR_LEN(arr);\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"wb\");\n"
    buf = buf + "    if (!f) return hexa_bool(0);\n"
    buf = buf + "    if (len > 0) {\n"
    buf = buf + "        unsigned char* buf = (unsigned char*)malloc(len);\n"
    buf = buf + "        HexaVal* items = HX_ARR_ITEMS(arr);\n"
    buf = buf + "        for (int i = 0; i < len; i++) {\n"
    buf = buf + "            int64_t v = HX_IS_INT(items[i]) ? HX_INT(items[i]) : (int64_t)HX_FLOAT(items[i]);\n"
    buf = buf + "            buf[i] = (unsigned char)(v & 0xFF);\n"
    buf = buf + "        }\n"
    buf = buf + "        fwrite(buf, 1, len, f);\n"
    buf = buf + "        free(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    return hexa_bool(1);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// rt_write_bytes_v: variant called from the interpreter dispatch where each\n"
    buf = buf + "// array item is a TAG_VALSTRUCT (Val) rather than a raw HexaVal int. Reads\n"
    buf = buf + "// the inner `int_val` field from each Val and writes the low byte. Without\n"
    buf = buf + "// this, write_bytes from interpreted user code silently no-ops (HX_IS_INT\n"
    buf = buf + "// fails on TAG_VALSTRUCT items) or — with the historical fputs path — UTF-8\n"
    buf = buf + "// encodes each byte > 0x7F to two bytes. (2026-04-17)\n"
    buf = buf + "HexaVal rt_write_bytes_v(HexaVal path, HexaVal arr) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n"
    buf = buf + "    int len = HX_ARR_LEN(arr);\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"wb\");\n"
    buf = buf + "    if (!f) return hexa_bool(0);\n"
    buf = buf + "    if (len > 0) {\n"
    buf = buf + "        unsigned char* buf = (unsigned char*)malloc(len);\n"
    buf = buf + "        HexaVal* items = HX_ARR_ITEMS(arr);\n"
    buf = buf + "        for (int i = 0; i < len; i++) {\n"
    buf = buf + "            HexaVal item = items[i];\n"
    buf = buf + "            int64_t v = 0;\n"
    buf = buf + "            if (HX_IS_INT(item)) {\n"
    buf = buf + "                v = HX_INT(item);\n"
    buf = buf + "            } else if (HX_TAG(item) == TAG_FLOAT) {\n"
    buf = buf + "                v = (int64_t)HX_FLOAT(item);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "            } else if (HX_TAG(item) == TAG_VALSTRUCT) {\n"
    buf = buf + "                HexaVal iv = hexa_valstruct_int(item);\n"
    buf = buf + "                if (HX_IS_INT(iv)) {\n"
    buf = buf + "                    v = HX_INT(iv);\n"
    buf = buf + "                } else if (HX_TAG(iv) == TAG_FLOAT) {\n"
    buf = buf + "                    v = (int64_t)HX_FLOAT(iv);\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            buf[i] = (unsigned char)(v & 0xFF);\n"
    buf = buf + "        }\n"
    buf = buf + "        fwrite(buf, 1, len, f);\n"
    buf = buf + "        free(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    return hexa_bool(1);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// read_file_bytes: reads a file in binary mode and returns\n"
    buf = buf + "// a TAG_ARRAY of integers (0-255), one per byte.\n"
    buf = buf + "HexaVal rt_read_file_bytes(HexaVal path) {\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"rb\");\n"
    buf = buf + "    if (!f) return hexa_array_new();\n"
    buf = buf + "    fseek(f, 0, SEEK_END);\n"
    buf = buf + "    long len = ftell(f);\n"
    buf = buf + "    fseek(f, 0, SEEK_SET);\n"
    buf = buf + "    unsigned char* buf = (unsigned char*)malloc(len);\n"
    buf = buf + "    fread(buf, 1, len, f);\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    // Pre-allocate array with exact capacity\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (len > 0) {\n"
    buf = buf + "        HX_SET_ARR_ITEMS(arr, (HexaVal*)malloc(sizeof(HexaVal) * len));\n"
    buf = buf + "        HX_SET_ARR_CAP(arr, (int)len);\n"
    buf = buf + "        HX_SET_ARR_LEN(arr, (int)len);\n"
    buf = buf + "        HexaVal* items = HX_ARR_ITEMS(arr);\n"
    buf = buf + "        for (long i = 0; i < len; i++) {\n"
    buf = buf + "            items[i] = hexa_int((int64_t)buf[i]);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    free(buf);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── P4 streaming builtins — read_bytes_at / write_bytes_append ─────\n"
    buf = buf + "// Required for multi-GB safetensors→hexaw conversion on 14B Qwen2.5\n"
    buf = buf + "// (8 shards × ~3.7GB each). Whole-file read_file_bytes cannot fit.\n"
    buf = buf + "\n"
    buf = buf + "// read_bytes_at(path, offset, nbytes): pread-style ranged read.\n"
    buf = buf + "// Returns a TAG_ARRAY of at most `nbytes` ints (shorter if EOF reached\n"
    buf = buf + "// or offset is past EOF). Empty array on fopen failure.\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "HexaVal rt_read_bytes_at(HexaVal path, HexaVal offset, HexaVal nbytes) {\n"
    buf = buf + "    int64_t off = HX_IS_INT(offset) ? HX_INT(offset)\n"
    buf = buf + "                : (HX_TAG(offset) == TAG_FLOAT ? (int64_t)HX_FLOAT(offset) : 0);\n"
    buf = buf + "    int64_t req = HX_IS_INT(nbytes) ? HX_INT(nbytes)\n"
    buf = buf + "                : (HX_TAG(nbytes) == TAG_FLOAT ? (int64_t)HX_FLOAT(nbytes) : 0);\n"
    buf = buf + "    if (off < 0 || req <= 0) return hexa_array_new();\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"rb\");\n"
    buf = buf + "    if (!f) return hexa_array_new();\n"
    buf = buf + "    // Use 64-bit seek where available; on macOS/Linux fseeko is standard.\n"
    buf = buf + "#if defined(_WIN32)\n"
    buf = buf + "    if (_fseeki64(f, (long long)off, SEEK_SET) != 0) { fclose(f); return hexa_array_new(); }\n"
    buf = buf + "#else\n"
    buf = buf + "    if (fseeko(f, (off_t)off, SEEK_SET) != 0) { fclose(f); return hexa_array_new(); }\n"
    buf = buf + "#endif\n"
    buf = buf + "    unsigned char* buf = (unsigned char*)malloc((size_t)req);\n"
    buf = buf + "    size_t got = fread(buf, 1, (size_t)req, f);\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (got > 0) {\n"
    buf = buf + "        HX_SET_ARR_ITEMS(arr, (HexaVal*)malloc(sizeof(HexaVal) * got));\n"
    buf = buf + "        HX_SET_ARR_CAP(arr, (int)got);\n"
    buf = buf + "        HX_SET_ARR_LEN(arr, (int)got);\n"
    buf = buf + "        HexaVal* items = HX_ARR_ITEMS(arr);\n"
    buf = buf + "        for (size_t i = 0; i < got; i++) {\n"
    buf = buf + "            items[i] = hexa_int((int64_t)buf[i]);\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    free(buf);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// write_bytes_append(path, arr): append raw bytes from an int array\n"
    buf = buf + "// to `path` (fopen \"ab\"), creating the file if needed. Returns bool.\n"
    buf = buf + "// Mirrors rt_write_bytes (raw HexaVal int array path).\n"
    buf = buf + "HexaVal rt_write_bytes_append(HexaVal path, HexaVal arr) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n"
    buf = buf + "    int len = HX_ARR_LEN(arr);\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"ab\");\n"
    buf = buf + "    if (!f) return hexa_bool(0);\n"
    buf = buf + "    if (len > 0) {\n"
    buf = buf + "        unsigned char* buf = (unsigned char*)malloc(len);\n"
    buf = buf + "        HexaVal* items = HX_ARR_ITEMS(arr);\n"
    buf = buf + "        for (int i = 0; i < len; i++) {\n"
    buf = buf + "            int64_t v = HX_IS_INT(items[i]) ? HX_INT(items[i]) : (int64_t)HX_FLOAT(items[i]);\n"
    buf = buf + "            buf[i] = (unsigned char)(v & 0xFF);\n"
    buf = buf + "        }\n"
    buf = buf + "        fwrite(buf, 1, len, f);\n"
    buf = buf + "        free(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    fclose(f);\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    return hexa_bool(1);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// write_bytes_append_v(path, arr): variant for the interpreter dispatch\n"
    buf = buf + "// where each array item is a TAG_VALSTRUCT (Val). Mirrors write_bytes_v.\n"
    buf = buf + "HexaVal rt_write_bytes_append_v(HexaVal path, HexaVal arr) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr)) return hexa_bool(0);\n"
    buf = buf + "    int len = HX_ARR_LEN(arr);\n"
    buf = buf + "    FILE* f = fopen(HX_STR(path), \"ab\");\n"
    buf = buf + "    if (!f) return hexa_bool(0);\n"
    buf = buf + "    if (len > 0) {\n"
    buf = buf + "        unsigned char* buf = (unsigned char*)malloc(len);\n"
    buf = buf + "        HexaVal* items = HX_ARR_ITEMS(arr);\n"
    buf = buf + "        for (int i = 0; i < len; i++) {\n"
    buf = buf + "            HexaVal item = items[i];\n"
    buf = buf + "            int64_t v = 0;\n"
    buf = buf + "            if (HX_IS_INT(item)) {\n"
    buf = buf + "                v = HX_INT(item);\n"
    buf = buf + "            } else if (HX_TAG(item) == TAG_FLOAT) {\n"
    buf = buf + "                v = (int64_t)HX_FLOAT(item);\n"
    buf = buf + "            } else if (HX_TAG(item) == TAG_VALSTRUCT) {\n"
    buf = buf + "                HexaVal iv = hexa_valstruct_int(item);\n"
    buf = buf + "                if (HX_IS_INT(iv)) {\n"
    buf = buf + "                    v = HX_INT(iv);\n"
    buf = buf + "                } else if (HX_TAG(iv) == TAG_FLOAT) {\n"
    buf = buf + "                    v = (int64_t)HX_FLOAT(iv);\n"
    buf = buf + "                }\n"
    buf = buf + "            }\n"
    buf = buf + "            buf[i] = (unsigned char)(v & 0xFF);\n"
    buf = buf + "        }\n"
    buf = buf + "        fwrite(buf, 1, len, f);\n"
    buf = buf + "        free(buf);\n"
    buf = buf + "    }\n"
    buf = buf + "    fclose(f);\n"
    buf = buf + "    return hexa_bool(1);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// file_size(path): native 64-bit file size without loading contents.\n"
    buf = buf + "// Existing hexa_full dispatch read the whole file to count length — not\n"
    buf = buf + "// viable for multi-GB safetensors shards.\n"
    buf = buf + "//\n"
    buf = buf + "// ω-stdlib-2 (2026-04-26): switched from fopen+fseeko/ftello to stat()\n"
    buf = buf + "// for two reasons: (1) avoids opening the file at all — pure metadata\n"
    buf = buf + "// query, no FD pressure, no platform-dependent fopen-on-directory\n"
    buf = buf + "// behaviour; (2) aligns the missing-file convention with portable_fs.hexa\n"
    buf = buf + "// (`pfs_file_size`, POSIX `wc -c`-based) which returns 0 for missing\n"
    buf = buf + "// rather than -1. Consumers can now stop maintaining the pfs_* alias\n"
    buf = buf + "// shadow layer. Directories / non-regular files also return 0 (size is\n"
    buf = buf + "// only meaningful for regular files; callers needing dir-size must walk).\n"
    buf = buf + "HexaVal rt_file_size(HexaVal path) {\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    const char* p = HX_STR(path);\n"
    buf = buf + "    if (!p) return hexa_int(0);\n"
    buf = buf + "    struct stat st;\n"
    buf = buf + "    if (hxlcl_stat(p, &st) != 0) return hexa_int(0);\n"
    buf = buf + "    if (!S_ISREG(st.st_mode)) return hexa_int(0);\n"
    buf = buf + "    return hexa_int((int64_t)st.st_size);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Command line arguments ───────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "static int _hexa_argc = 0;\n"
    buf = buf + "static char** _hexa_argv = NULL;\n"
    buf = buf + "\n"
    buf = buf + "void hexa_set_args(int argc, char** argv) {\n"
    buf = buf + "    // S1-D2: init TAG_FN shim globals before user code touches them.\n"
    buf = buf + "    _hexa_init_fn_shims();\n"
    buf = buf + "    // RFC 062 (2026-05-19): argv stored verbatim — no argv[0] duplication.\n"
    buf = buf + "    // The historical double-insert ([exec, exec, sub, ...]) existed only to\n"
    buf = buf + "    // match the tree-walking interpreter's [\"hexa\", \"script\", args...] index\n"
    buf = buf + "    // layout. R7 retired the interpreter, so args() is now the clean\n"
    buf = buf + "    // [exec, user-args...] layout. See RFC 062 / ROADMAP self-host child 65.\n"
    buf = buf + "    _hexa_argc = argc;\n"
    buf = buf + "    _hexa_argv = (char**)malloc(sizeof(char*) * (argc > 0 ? argc : 1));\n"
    buf = buf + "    for (int i = 0; i < argc; i++) {\n"
    buf = buf + "        _hexa_argv[i] = argv[i];\n"
    buf = buf + "    }\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_args() {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    for (int i = 0; i < _hexa_argc; i++) {\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_str(_hexa_argv[i]));\n"
    buf = buf + "    }\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// Canonical argv API (roadmap 65 / M3, anima hxa-20260423-003 §3 M3).\n"
    buf = buf + "// RFC 062 (argv[0] dedup) flipped args() to the clean [exec, user...]\n"
    buf = buf + "// layout, so these helpers index from 1 (exec at 0, user args at 1..).\n"
    buf = buf + "// script_path() = the thing that was launched, real_args() = user\n"
    buf = buf + "// arguments only, identical across AOT/stage0.\n"
    buf = buf + "HexaVal hexa_script_path() {\n"
    buf = buf + "    // RFC 062: post-dedup layout — argv[0] is the launched executable.\n"
    buf = buf + "    if (_hexa_argc < 1 || _hexa_argv[0] == NULL) return hexa_str(\"\");\n"
    buf = buf + "    return hexa_str(_hexa_argv[0]);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_real_args() {\n"
    buf = buf + "    // RFC 062: post-dedup layout [exec, user-args...] — user args start at\n"
    buf = buf + "    // index 1 (was 2 under the doubled [exec, exec, ...] layout). The\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    // returned list is unchanged across the dedup.\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    int start = (_hexa_argc >= 1) ? 1 : _hexa_argc;\n"
    buf = buf + "    for (int i = start; i < _hexa_argc; i++) {\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_str(_hexa_argv[i]));\n"
    buf = buf + "    }\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "// ── Float operations ─────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "#include <math.h>\n"
    buf = buf + "\n"
    buf = buf + "// T39: math helpers route through __hx_to_double so TAG_VALSTRUCT\n"
    buf = buf + "// wrappers (interpreter Vals) don't cast vs pointer bits to double.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_sqrt(HexaVal v) {\n"
    buf = buf + "    return hexa_float(sqrt(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_sqrt(HexaVal v);\n"
    buf = buf + "HexaVal hexa_sqrt(HexaVal v) {\n"
    buf = buf + "    return rt_sqrt(hexa_float(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_pow(HexaVal base, HexaVal exp) {\n"
    buf = buf + "    // Integer fast-path: int^int with non-negative exponent stays int\n"
    buf = buf + "    if (HX_IS_INT(base) && HX_IS_INT(exp) && HX_INT(exp) >= 0) {\n"
    buf = buf + "        int64_t b = HX_INT(base), e = HX_INT(exp), r = 1;\n"
    buf = buf + "        while (e > 0) { if (e & 1) r *= b; b *= b; e >>= 1; }\n"
    buf = buf + "        return hexa_int(r);\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_float(pow(__hx_to_double(base), __hx_to_double(exp)));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_pow_int(HexaVal b, HexaVal e);\n"
    buf = buf + "extern HexaVal rt_pow_float(HexaVal b, HexaVal e);\n"
    buf = buf + "HexaVal hexa_pow(HexaVal base, HexaVal exp) {\n"
    buf = buf + "    if (HX_IS_INT(base) && HX_IS_INT(exp) && HX_INT(exp) >= 0) {\n"
    buf = buf + "        return rt_pow_int(base, exp);\n"
    buf = buf + "    }\n"
    buf = buf + "    return rt_pow_float(hexa_float(__hx_to_double(base)),\n"
    buf = buf + "                        hexa_float(__hx_to_double(exp)));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step 3 cycle 2 — hexa_floor/ceil/u_floor delegate to hexa-source.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "HexaVal hexa_floor(HexaVal v) {\n"
    buf = buf + "    return hexa_int((int64_t)floor(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_u_floor(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ai = HX_IS_INT(a) ? HX_INT(a) : (int64_t)__hx_to_double(a);\n"
    buf = buf + "    int64_t bi = HX_IS_INT(b) ? HX_INT(b) : (int64_t)__hx_to_double(b);\n"
    buf = buf + "    if (bi == 0) return hexa_int(0);\n"
    buf = buf + "    int64_t q = ai / bi;\n"
    buf = buf + "    int64_t r = ai % bi;\n"
    buf = buf + "    if (r != 0 && ((ai < 0) != (bi < 0))) q -= 1;\n"
    buf = buf + "    return hexa_int(q);\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_ceil(HexaVal v) {\n"
    buf = buf + "    return hexa_int((int64_t)ceil(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_floor(HexaVal v);\n"
    buf = buf + "extern HexaVal rt_ceil(HexaVal v);\n"
    buf = buf + "extern HexaVal rt_u_floor(HexaVal a, HexaVal b);\n"
    buf = buf + "HexaVal hexa_floor(HexaVal v) {\n"
    buf = buf + "    return rt_floor(hexa_float(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_ceil(HexaVal v) {\n"
    buf = buf + "    return rt_ceil(hexa_float(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    buf = buf + "HexaVal hexa_u_floor(HexaVal a, HexaVal b) {\n"
    buf = buf + "    int64_t ai = HX_IS_INT(a) ? HX_INT(a) : (int64_t)__hx_to_double(a);\n"
    buf = buf + "    int64_t bi = HX_IS_INT(b) ? HX_INT(b) : (int64_t)__hx_to_double(b);\n"
    buf = buf + "    return rt_u_floor(hexa_int(ai), hexa_int(bi));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// RUNTIME.md step-3 cycle 1 POC — first HI-tier hexa-source delegation\n"
    buf = buf + "// from runtime_core.c. Source of truth: stdlib/runtime/numeric.hexa\n"
    buf = buf + "// (rt_abs_int + rt_abs_float). #ifndef guard mirrors step-2 pattern:\n"
    buf = buf + "// standalone build keeps C body; ap_post.c gets HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "// → hexa-emitted bodies win as strong symbols.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_abs(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_INT(v)) return hexa_int(HX_INT(v) < 0 ? -HX_INT(v) : HX_INT(v));\n"
    buf = buf + "    return hexa_float(fabs(HX_FLOAT(v)));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_abs_int(HexaVal v);\n"
    buf = buf + "extern HexaVal rt_abs_float(HexaVal v);\n"
    buf = buf + "HexaVal hexa_abs(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_INT(v)) return rt_abs_int(v);\n"
    buf = buf + "    return rt_abs_float(v);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "\n"
    buf = buf + "// P7-6 math coverage (2026-04-19): transcendentals + rounding + conversions\n"
    buf = buf + "// used by training/inference codegen. All route through __hx_to_double to\n"
    buf = buf + "// unwrap TAG_VALSTRUCT wrappers (same pattern as hexa_sqrt).\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_sin(HexaVal v)   { return hexa_float(hxlcl_sin(__hx_to_double(v))); }\n"
    buf = buf + "HexaVal hexa_cos(HexaVal v)   { return hexa_float(hxlcl_cos(__hx_to_double(v))); }\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_tan(HexaVal v)   { return hexa_float(tan(__hx_to_double(v))); }\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_tan(HexaVal x);\n"
    buf = buf + "HexaVal hexa_tan(HexaVal v)   { return rt_tan(hexa_float(__hx_to_double(v))); }\n"
    buf = buf + "#endif\n"
    buf = buf + "HexaVal hexa_exp(HexaVal v)   { return hexa_float(hxlcl_exp(__hx_to_double(v))); }\n"
    buf = buf + "HexaVal hexa_log(HexaVal v)   { return hexa_float(hxlcl_log(__hx_to_double(v))); }\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_log10(HexaVal v) { return hexa_float(log10(__hx_to_double(v))); }\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_log10(HexaVal x);\n"
    buf = buf + "HexaVal hexa_log10(HexaVal v) { return rt_log10(hexa_float(__hx_to_double(v))); }\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_round(HexaVal v) { return hexa_int((int64_t)llround(__hx_to_double(v))); }\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_round(HexaVal v);\n"
    buf = buf + "HexaVal hexa_round(HexaVal v) { return rt_round(hexa_float(__hx_to_double(v))); }\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_tanh(HexaVal v)  { return hexa_float(tanh(__hx_to_double(v))); }\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_tanh(HexaVal x);\n"
    buf = buf + "HexaVal hexa_tanh(HexaVal v)  { return rt_tanh(hexa_float(__hx_to_double(v))); }\n"
    buf = buf + "#endif\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_log2(HexaVal v)  { return hexa_float(log2(__hx_to_double(v))); }\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_log2(HexaVal x);\n"
    buf = buf + "HexaVal hexa_log2(HexaVal v)  { return rt_log2(hexa_float(__hx_to_double(v))); }\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// to_float: coerce any scalar to float. Step-3 cycle 13 port.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_to_float(HexaVal v) {\n"
    buf = buf + "    return hexa_float(__hx_to_double(v));\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_to_float(HexaVal v);\n"
    buf = buf + "HexaVal hexa_to_float(HexaVal v) {\n"
    buf = buf + "    return rt_to_float(hexa_float(__hx_to_double(v)));\n"
    buf = buf + "}\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// to_int: coerce any scalar to int (truncate toward zero for floats)\n"
    buf = buf + "// RUNTIME.md Step 4 .c-none: hexa_to_int delegates to hexa-source rt_to_int\n"
    buf = buf + "// (numeric.hexa) under HEXA_HAS_HEXA_RT_STDLIB. __raw_d2i is the float→int truncate\n"
    buf = buf + "// escape (the C `(int64_t)HX_FLOAT` cast can't be expressed in hexa source). #else C\n"
    buf = buf + "// body kept bit-for-bit.\n"
    buf = buf + "static inline HexaVal __raw_d2i(HexaVal v) { return hexa_int((int64_t)__hx_to_double(v)); }\n"
    buf = buf + "#ifdef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "extern HexaVal rt_to_int(HexaVal v);\n"
    buf = buf + "HexaVal hexa_to_int(HexaVal v) { return rt_to_int(v); }\n"
    buf = buf + "#else\n"
    buf = buf + "HexaVal hexa_to_int(HexaVal v) {\n"
    buf = buf + "    if (HX_IS_INT(v)) return v;\n"
    buf = buf + "    if (HX_IS_FLOAT(v)) return hexa_int((int64_t)HX_FLOAT(v));\n"
    buf = buf + "    // String → int fallback via existing parser\n"
    buf = buf + "    if (HX_IS_STR(v)) return hexa_str_parse_int(v);\n"
    buf = buf + "    return hexa_int((int64_t)__hx_to_double(v));\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ── String format ────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// Multi-arg format: hexa_format_n(fmt, args_array)\n"
    buf = buf + "// Step-3 cycle 62 port — single-arg `{}` substitution dispatches to\n"
    buf = buf + "// rt_format. The polymorphic `hexa_to_string(arg)` coercion stays\n"
    buf = buf + "// C-side; the hexa fn receives both args as string.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_format(HexaVal fmt, HexaVal arg) {\n"
    buf = buf + "    // Delegate to multi-arg path so brace-escape (`{{` → `{`,\n"
    buf = buf + "    // `}}` → `}`) works uniformly in both single- and multi-arg\n"
    buf = buf + "    // formats.  The prior strstr-based path silently emitted\n"
    buf = buf + "    // `{{}}` literally instead of `{}`.\n"
    buf = buf + "    if (!HX_IS_STR(fmt)) return fmt;\n"
    buf = buf + "    HexaVal args = hexa_array_new();\n"
    buf = buf + "    args = hexa_array_push(args, arg);\n"
    buf = buf + "    return hexa_format_n(fmt, args);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_format(HexaVal fmt, HexaVal sarg);\n"
    buf = buf + "HexaVal hexa_format(HexaVal fmt, HexaVal arg) {\n"
    buf = buf + "    if (!HX_IS_STR(fmt)) return fmt;\n"
    buf = buf + "    HexaVal sarg = hexa_to_string(arg);\n"
    buf = buf + "    return rt_format(fmt, sarg);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "HexaVal hexa_format_n(HexaVal fmt, HexaVal args) {\n"
    buf = buf + "    // Multi-arg: replace {} and {:.N} with successive args\n"
    buf = buf + "    if (!HX_IS_STR(fmt) || !HX_IS_ARRAY(args)) return fmt;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    size_t cap = HX_STRLEN(fmt) * 4 + HX_ARR_LEN(args) * 64 + 256;\n"
    buf = buf + "    char* result = malloc(cap);\n"
    buf = buf + "    size_t total = 0;\n"
    buf = buf + "    result[0] = 0;\n"
    buf = buf + "    char* src = HX_STR(fmt);\n"
    buf = buf + "    int ai = 0;\n"
    buf = buf + "    while (*src) {\n"
    buf = buf + "        // Brace escape — `{{` emits `{`, `}}` emits `}`.  Without this\n"
    buf = buf + "        // a Rust-style format string `\"{{}}\"` produced `{{}}` literal\n"
    buf = buf + "        // instead of `{}`.  Round-5 string-format probe finding.\n"
    buf = buf + "        if (src[0] == '{' && src[1] == '{') {\n"
    buf = buf + "            while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "            result[total++] = '{';\n"
    buf = buf + "            result[total] = 0;\n"
    buf = buf + "            src += 2;\n"
    buf = buf + "            continue;\n"
    buf = buf + "        }\n"
    buf = buf + "        if (src[0] == '}' && src[1] == '}') {\n"
    buf = buf + "            while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "            result[total++] = '}';\n"
    buf = buf + "            result[total] = 0;\n"
    buf = buf + "            src += 2;\n"
    buf = buf + "            continue;\n"
    buf = buf + "        }\n"
    buf = buf + "        if (src[0] == '{' && ai < HX_ARR_LEN(args)) {\n"
    buf = buf + "            // Find closing }\n"
    buf = buf + "            char* close = hxlcl_strchr(src, '}');\n"
    buf = buf + "            if (close) {\n"
    buf = buf + "                int speclen = (int)(close - src - 1);\n"
    buf = buf + "                char spec[32] = {0};\n"
    buf = buf + "                if (speclen > 0 && speclen < 31) hxlcl_memcpy(spec, src+1, speclen);\n"
    buf = buf + "                char buf[128];\n"
    buf = buf + "                HexaVal arg = HX_ARR_ITEMS(args)[ai++];\n"
    buf = buf + "                if (spec[0] == ':' && spec[1] == '.') {\n"
    buf = buf + "                    // Precision format {:.N} or {:.Nf}\n"
    buf = buf + "                    int prec = hxlcl_atoi(spec + 2);\n"
    buf = buf + "                    double val = HX_IS_FLOAT(arg) ? HX_FLOAT(arg) : (double)HX_INT(arg);\n"
    buf = buf + "                    snprintf(buf, sizeof(buf), \"%.*f\", prec, val);\n"
    buf = buf + "                } else if (spec[0] == ':') {\n"
    buf = buf + "                    // Width/pad/int-suffix format: {:N} {:<N} {:>N} {:0N} {:Nd}\n"
    buf = buf + "                    // Strategy: render arg via hexa_to_string, then pad/truncate\n"
    buf = buf + "                    // to a width parsed from the spec body.\n"
    buf = buf + "                    const char* p = spec + 1;\n"
    buf = buf + "                    char align = 'R';                           // numeric default\n"
    buf = buf + "                    char fill  = ' ';\n"
    buf = buf + "                    if (*p == '<') { align = 'L'; p++; }\n"
    buf = buf + "                    else if (*p == '>') { align = 'R'; p++; }\n"
    buf = buf + "                    else if (*p == '^') { align = 'C'; p++; }\n"
    buf = buf + "                    if (*p == '0' && p[1] != 0) { fill = '0'; p++; }\n"
    buf = buf + "                    int width = 0;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "                    while (*p >= '0' && *p <= '9') { width = width * 10 + (*p - '0'); p++; }\n"
    buf = buf + "                    // ignore trailing type char ('d'/'s'/'f')\n"
    buf = buf + "                    HexaVal s = hexa_to_string(arg);\n"
    buf = buf + "                    int slen = (int)HX_STRLEN(s);\n"
    buf = buf + "                    int pad = width > slen ? width - slen : 0;\n"
    buf = buf + "                    int bp = 0;\n"
    buf = buf + "                    if (align == 'L') {\n"
    buf = buf + "                        hxlcl_memcpy(buf + bp, HX_STR(s), slen); bp += slen;\n"
    buf = buf + "                        for (int q = 0; q < pad && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n"
    buf = buf + "                    } else if (align == 'C') {\n"
    buf = buf + "                        int lp = pad / 2, rp = pad - lp;\n"
    buf = buf + "                        for (int q = 0; q < lp && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n"
    buf = buf + "                        hxlcl_memcpy(buf + bp, HX_STR(s), slen); bp += slen;\n"
    buf = buf + "                        for (int q = 0; q < rp && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n"
    buf = buf + "                    } else {\n"
    buf = buf + "                        for (int q = 0; q < pad && bp < (int)sizeof(buf) - 1; q++) buf[bp++] = fill;\n"
    buf = buf + "                        hxlcl_memcpy(buf + bp, HX_STR(s), slen); bp += slen;\n"
    buf = buf + "                    }\n"
    buf = buf + "                    if (bp >= (int)sizeof(buf)) bp = sizeof(buf) - 1;\n"
    buf = buf + "                    buf[bp] = 0;\n"
    buf = buf + "                } else if (spec[0] == 0) {\n"
    buf = buf + "                    // Simple {}\n"
    buf = buf + "                    HexaVal s = hexa_to_string(arg);\n"
    buf = buf + "                    hxlcl_strncpy(buf, HX_STR(s), sizeof(buf)-1); buf[sizeof(buf)-1]=0;\n"
    buf = buf + "                } else {\n"
    buf = buf + "                    // Indexed {N} — best-effort; non-numeric falls through to to_string\n"
    buf = buf + "                    HexaVal s = hexa_to_string(arg);\n"
    buf = buf + "                    hxlcl_strncpy(buf, HX_STR(s), sizeof(buf)-1); buf[sizeof(buf)-1]=0;\n"
    buf = buf + "                }\n"
    buf = buf + "                size_t blen = hxlcl_strlen(buf);\n"
    buf = buf + "                while (total + blen + 1 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "                hxlcl_memcpy(result + total, buf, blen);\n"
    buf = buf + "                total += blen;\n"
    buf = buf + "                result[total] = 0;\n"
    buf = buf + "                src = close + 1;\n"
    buf = buf + "            } else {\n"
    buf = buf + "                while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "                result[total++] = *src;\n"
    buf = buf + "                result[total] = 0;\n"
    buf = buf + "                src++;\n"
    buf = buf + "            }\n"
    buf = buf + "        } else {\n"
    buf = buf + "            while (total + 2 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "            result[total++] = *src;\n"
    buf = buf + "            result[total] = 0;\n"
    buf = buf + "            src++;\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "\n"
    buf = buf + "// ── String split ─────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 45 port — string split dispatches to rt_str_split. The\n"
    buf = buf + "// hexa path scans byte-by-byte (no strstr) and avoids the strdup/free\n"
    buf = buf + "// pair the C body uses for the in-place NUL terminator trick.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_split(HexaVal s, HexaVal delim) {\n"
    buf = buf + "    HexaVal arr = hexa_array_new();\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(delim)) return arr;\n"
    buf = buf + "    char* src = hxlcl_strdup(HX_STR(s));\n"
    buf = buf + "    char* d = HX_STR(delim);\n"
    buf = buf + "    int dlen = hxlcl_strlen(d);\n"
    buf = buf + "    char* pos = src;\n"
    buf = buf + "    while (1) {\n"
    buf = buf + "        char* found = hxlcl_strstr(pos, d);\n"
    buf = buf + "        if (!found) { arr = hexa_array_push(arr, hexa_str(pos)); break; }\n"
    buf = buf + "        *found = 0;\n"
    buf = buf + "        arr = hexa_array_push(arr, hexa_str(pos));\n"
    buf = buf + "        pos = found + dlen;\n"
    buf = buf + "    }\n"
    buf = buf + "    free(src);\n"
    buf = buf + "    return arr;\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_split(HexaVal s, HexaVal delim);\n"
    buf = buf + "HexaVal hexa_str_split(HexaVal s, HexaVal delim) {\n"
    buf = buf + "    if (!HX_IS_STR(s) || !HX_IS_STR(delim)) return hexa_array_new();\n"
    buf = buf + "    return rt_str_split(s, delim);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────────────\n"
    buf = buf + "// M1-lite (hxa-20260423-003 Step 4): rt_str_* layer — GENERATED from\n"
    buf = buf + "// self/runtime_hi.hexa via tool/extract_runtime_hi.sh. Included below\n"
    buf = buf + "// in the hexa_str_join region (where rt_str_* dependencies are ready).\n"
    buf = buf + "// hexa_str_* shims forward to rt_str_* after the include.\n"
    buf = buf + "// ─────────────────────────────────────────────────────────────────────\n"
    buf = buf + "\n"
    buf = buf + "// M1 full · str_ext Step 5 (hxa-20260423-003): rt_str_trim — codegen\n"
    buf = buf + "// emits rt_str_* directly; hexa_str_trim shim retired.\n"
    buf = buf + "// Step-3 cycle 49 — rt_str_trim moves to hexa source. C body stays\n"
    buf = buf + "// for the no-stdlib path.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal rt_str_trim(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return s;\n"
    buf = buf + "    char* str = HX_STR(s);\n"
    buf = buf + "    while (*str == ' ' || *str == '\\t' || *str == '\\n' || *str == '\\r') str++;\n"
    buf = buf + "    int len = hxlcl_strlen(str);\n"
    buf = buf + "    while (len > 0 && (str[len-1] == ' ' || str[len-1] == '\\t' || str[len-1] == '\\n' || str[len-1] == '\\r')) len--;\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "    char* result = hxlcl_strndup(str, len);\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 44 port — string replace-all dispatches to rt_str_replace\n"
    buf = buf + "// in stdlib/runtime/ctype.hexa. The hexa path is O(n*m) (no strstr;\n"
    buf = buf + "// byte-by-byte match) and uses `+` concat (no preallocated buffer);\n"
    buf = buf + "// acceptable trade-off for hexa-native landing, matches the cycle-\n"
    buf = buf + "// 2/4 precision/perf budget.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_replace(HexaVal s, HexaVal old, HexaVal new_s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return s;\n"
    buf = buf + "    size_t cap = HX_STRLEN(s) * 2 + 1;\n"
    buf = buf + "    char* result = malloc(cap);\n"
    buf = buf + "    size_t total = 0;\n"
    buf = buf + "    result[0] = 0;\n"
    buf = buf + "    char* pos = HX_STR(s);\n"
    buf = buf + "    int oldlen = (int)HX_STRLEN(old);\n"
    buf = buf + "    size_t newlen = HX_STRLEN(new_s);\n"
    buf = buf + "    while (1) {\n"
    buf = buf + "        char* found = hxlcl_strstr(pos, HX_STR(old));\n"
    buf = buf + "        if (!found) {\n"
    buf = buf + "            size_t rlen = hxlcl_strlen(pos);\n"
    buf = buf + "            while (total + rlen + 1 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "            hxlcl_memcpy(result + total, pos, rlen);\n"
    buf = buf + "            total += rlen;\n"
    buf = buf + "            result[total] = 0;\n"
    buf = buf + "            break;\n"
    buf = buf + "        }\n"
    buf = buf + "        size_t seg = (size_t)(found - pos);\n"
    buf = buf + "        while (total + seg + newlen + 1 > cap) { cap *= 2; result = realloc(result, cap); }\n"
    buf = buf + "        hxlcl_memcpy(result + total, pos, seg);\n"
    buf = buf + "        total += seg;\n"
    buf = buf + "        hxlcl_memcpy(result + total, HX_STR(new_s), newlen);\n"
    buf = buf + "        total += newlen;\n"
    buf = buf + "        result[total] = 0;\n"
    buf = buf + "        pos = found + oldlen;\n"
    buf = buf + "    }\n"
    buf = buf + "    return hexa_str_own(result);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_replace(HexaVal s, HexaVal old, HexaVal new_s);\n"
    buf = buf + "HexaVal hexa_str_replace(HexaVal s, HexaVal old, HexaVal new_s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return s;\n"
    buf = buf + "    if (!HX_IS_STR(old) || !HX_IS_STR(new_s)) return s;\n"
    buf = buf + "    return rt_str_replace(s, old, new_s);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    if buf.len() > 65536 { _flush_runtime_core(out_path, buf); buf = "" }
    buf = buf + "// M1 full · str_ext Step 5 (hxa-20260423-003): rt_str_to_upper/lower —\n"
    buf = buf + "// codegen emits rt_str_* directly; hexa_str_to_upper/lower shims retired.\n"
    buf = buf + "// Step-3 cycle 50 — both move to hexa source. C bodies stay for the\n"
    buf = buf + "// no-stdlib path.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal rt_str_to_upper(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return s;\n"
    buf = buf + "    char* r = hxlcl_strdup(HX_STR(s));\n"
    buf = buf + "    for (int i = 0; r[i]; i++) if (r[i] >= 'a' && r[i] <= 'z') r[i] -= 32;\n"
    buf = buf + "    return hexa_str_own(r);\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_to_lower(HexaVal s) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return s;\n"
    buf = buf + "    char* r = hxlcl_strdup(HX_STR(s));\n"
    buf = buf + "    for (int i = 0; r[i]; i++) if (r[i] >= 'A' && r[i] <= 'Z') r[i] += 32;\n"
    buf = buf + "    return hexa_str_own(r);\n"
    buf = buf + "}\n"
    buf = buf + "#endif\n"
    buf = buf + "\n"
    buf = buf + "// Step-3 cycle 43 port — float-style fast-path for all-string arrays\n"
    buf = buf + "// dispatches to rt_str_join_str (ctype.hexa). Mixed-type arrays still\n"
    buf = buf + "// need hexa_to_string() coercion per element — that path stays C-side.\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_join(HexaVal arr, HexaVal sep) {\n"
    buf = buf + "    if (!HX_IS_ARRAY(arr) || HX_ARR_LEN(arr) == 0) return hexa_str(\"\");\n"
    buf = buf + "    size_t total_size = 0;\n"
    buf = buf + "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n"
    buf = buf + "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n"
    buf = buf + "        total_size += HX_STRLEN(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    size_t seplen = HX_STRLEN(sep);\n"
    buf = buf + "    total_size += (HX_ARR_LEN(arr) - 1) * seplen;\n"
    buf = buf + "    char* result = malloc(total_size + 1);\n"
    buf = buf + "    size_t total = 0;\n"
    buf = buf + "    for (int i = 0; i < HX_ARR_LEN(arr); i++) {\n"
    buf = buf + "        if (i > 0) {\n"
    buf = buf + "            hxlcl_memcpy(result + total, HX_STR(sep), seplen);\n"
    buf = buf + "            total += seplen;\n"
    buf = buf + "        }\n"
    buf = buf + "        HexaVal s = hexa_to_string(HX_ARR_ITEMS(arr)[i]);\n"
    buf = buf + "        size_t slen = HX_STRLEN(s);\n"
    buf = buf + "        hxlcl_memcpy(result + total, HX_STR(s), slen);\n"
    buf = buf + "        total += slen;\n"
