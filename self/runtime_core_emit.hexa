    buf = buf + "        snprintf(_buf, sizeof(_buf), \"index %lld out of bounds (len %d)\", (long long)_orig_idx_g, HX_ARR_LEN(arr));\n"
    buf = buf + "        if (hxlcl_getenv(\"HEXA_OOB_TRACE\")) {\n"
    buf = buf + "            // RUNTIME.md Tier-A.4: hexa-native frame-walker stubs (defined\n"
    buf = buf + "            // in runtime.c before this TU is #include'd) — drops the libc\n"
    buf = buf + "            // _backtrace / _backtrace_symbols_fd externs from aprime_cc.\n"
    buf = buf + "            void* _bt[32]; int _n = hxlcl_backtrace(_bt, 32);\n"
