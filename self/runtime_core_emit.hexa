    buf = buf + "// Step-3 cycle 52 — char_at dispatches to rt_str_char_at (uses\n"
    buf = buf + "// substring builtin, no recursion trap).\n"
    buf = buf + "#ifndef HEXA_HAS_HEXA_RT_STDLIB\n"
    buf = buf + "HexaVal hexa_str_char_at(HexaVal s, HexaVal idx) {\n"
    buf = buf + "    if (!HX_IS_STR(s)) return hexa_str(\"\");\n"
    buf = buf + "    int64_t i = HX_INT(idx);\n"
    buf = buf + "    int64_t n = (int64_t)HX_STRLEN(s);\n"
    buf = buf + "    int64_t _orig = i;\n"
    buf = buf + "    // Python-style negative index — align interp `s[-1]` 지원 (`c` 반환).\n"
    buf = buf + "    if (i < 0) i += n;\n"
    buf = buf + "    if (i < 0 || i >= n) {\n"
    buf = buf + "        // PROBE r12 #16: align with array OOB (throws cleanly at\n"
    buf = buf + "        // hexa_array_get L2003).  String previously returned silent \"\"\n"
    buf = buf + "        // which inverts the silent-failure-enforcement discipline.\n"
    buf = buf + "        char _buf[128];\n"
    buf = buf + "        snprintf(_buf, sizeof(_buf), \"string[%lld] out of bounds (len %lld)\", (long long)_orig, (long long)n);\n"
    buf = buf + "        hexa_throw(hexa_str(_buf));\n"
    buf = buf + "        return hexa_str(\"\");\n"
    buf = buf + "    }\n"
    buf = buf + "    char buf[2] = { HX_STR(s)[i], '\\0' };\n"
    buf = buf + "    return hexa_str(buf);\n"
    buf = buf + "}\n"
    buf = buf + "#else\n"
    buf = buf + "extern HexaVal rt_str_char_at(HexaVal s, HexaVal idx);\n"
