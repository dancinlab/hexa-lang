#!hexa strict
// self/runtime_hi_gen_emit.hexa
//   B9.C (.c-text · #1866 / #1871 pattern) — runtime_hi_gen.c source emitter.
//
// self/runtime_core.c `#include "runtime_hi_gen.c"` (RFC 061 amalgamation,
// runtime.c → runtime_core.c → this fragment). runtime_hi_gen.c is the
// high-layer rt_str_* stdlib (split / lines / pad_left / pad_right / repeat /
// center), itself generated from the hexa SSOT self/runtime_hi.hexa via
// tool/extract_runtime_hi.sh (hexat transpile + awk slice + sed rename +
// __attribute__((constructor)) footer).
//
// This emitter is the .c-text SSOT for the .c FILE: it prints the exact bytes
// of self/runtime_hi_gen.c VERBATIM, so the build can regenerate the .c before
// runtime.c compiles and the .c becomes a gitignored build artifact. (The
// upstream extract_runtime_hi.sh remains the SSOT for the *content* — regen it
// when runtime_hi.hexa changes, then refresh this verbatim emitter.)
//
// Byte-identity: the emitted .c is byte-for-byte the in-tree self/runtime_hi_gen.c
// (verified via self/runtime_hi_gen_byte_diff.hexa, gate-1 source-SHA), so the
// runtime.c TU (and the linked hexa binary) is identical — PERF UNCHANGED.
//
// runtime_hi_gen.c is NOT a standalone TU (it references runtime.c-internal
// symbols HexaVal / hexa_str / hexa_array_* / hexa_str_join / HX_BOOL / …) and
// CANNOT be compiled in isolation; gate-1 source-SHA is the only per-file gate,
// by design — the .o-equivalence is proven END-TO-END by the full hexa_cc build.
//
// Invocation:  hexa-run self/runtime_hi_gen_emit.hexa <output-path>
// Default output path (if argv missing): "runtime_hi_gen.c" in cwd.

let MODULE_NAME = "runtime_hi_gen_emit"

fn emit_runtime_hi_gen_c() -> str {
    // Verbatim content of self/runtime_hi_gen.c (extract_runtime_hi.sh output).
    let s =
            "// GENERATED FROM self/runtime_hi.hexa — do not edit manually.\n" +
            "// Source of truth: self/runtime_hi.hexa (M1-lite hi-layer SSOT).\n" +
            "// Reproduce: tool/extract_runtime_hi.sh (runs self/native/hexat then\n" +
            "// strips main/selftest, renames __hexa_sl_* -> __hexa_rt_sl_*).\n" +
            "// Included from self/runtime.c AFTER hexa_str_join is defined.\n" +
            "// (hxa-20260423-003 Step 4 — extraction replaces hand-port rt_str_*)\n" +
            "//\n" +
            "// PHASE 1.3.B follow-up (2026-05-15): rt_str_* are NON-static now so they're\n" +
            "// reachable from user.c when codegen emits `#include \"runtime.h\"` (the new\n" +
            "// default — see codegen_c2.hexa:679). Header forward decls live in\n" +
            "// runtime.h's \"rt_* high-layer stdlib (runtime_hi_gen.c)\" block. Internal\n" +
            "// `__hexa_rt_sl_*` constants stay file-scoped static — they're only used\n" +
            "// by the bodies in this file.\n" +
            "\n" +
            "static HexaVal __hexa_rt_sl_0;\n" +
            "static HexaVal __hexa_rt_sl_1;\n" +
            "static HexaVal __hexa_rt_sl_2;\n" +
            "static HexaVal __hexa_rt_sl_3;\n" +
            "static HexaVal __hexa_rt_sl_4;\n" +
            "static HexaVal __hexa_rt_sl_5;\n" +
            "static HexaVal __hexa_rt_sl_6;\n" +
            "static HexaVal __hexa_rt_sl_7;\n" +
            "static HexaVal __hexa_rt_sl_8;\n" +
            "static HexaVal __hexa_rt_sl_9;\n" +
            "static HexaVal __hexa_rt_sl_10;\n" +
            "static HexaVal __hexa_rt_sl_11;\n" +
            "static HexaVal __hexa_rt_sl_12;\n" +
            "static HexaVal __hexa_rt_sl_13;\n" +
            "static void __hexa_rt_strlit_init(void) {\n" +
            "    __hexa_rt_sl_0 = hexa_str(\"\\n\");\n" +
            "    __hexa_rt_sl_1 = hexa_str(\"\");\n" +
            "    __hexa_rt_sl_2 = hexa_str(\"7\");\n" +
            "    __hexa_rt_sl_3 = hexa_str(\"0\");\n" +
            "    __hexa_rt_sl_4 = hexa_str(\"ab\");\n" +
            "    __hexa_rt_sl_5 = hexa_str(\"hi\");\n" +
            "    __hexa_rt_sl_6 = hexa_str(\"-\");\n" +
            "    __hexa_rt_sl_7 = hexa_str(\"a\\nb\\nc\");\n" +
            "    __hexa_rt_sl_8 = hexa_str(\"007\");\n" +
            "    __hexa_rt_sl_9 = hexa_str(\"700\");\n" +
            "    __hexa_rt_sl_10 = hexa_str(\"ababab\");\n" +
            "    __hexa_rt_sl_11 = hexa_str(\"--hi--\");\n" +
            "    __hexa_rt_sl_12 = hexa_str(\"runtime_hi: selftest OK\");\n" +
            "    __hexa_rt_sl_13 = hexa_str(\"runtime_hi: selftest FAIL\");\n" +
            "}\n" +
            "\n" +
            "HexaVal rt_str_split(HexaVal s, HexaVal delim) {\n" +
            "    __hexa_fn_arena_enter();\n" +
            "    HexaVal out = hexa_array_new();\n" +
            "    if (hexa_truthy(hexa_eq(hexa_int(hexa_len(delim)), hexa_int(0)))) {\n" +
            "        hexa_array_push(out, s);\n" +
            "        return __hexa_fn_arena_return(out);\n" +
            "    }\n" +
            "    HexaVal dlen = hexa_int(hexa_len(delim));\n" +
            "    HexaVal start = hexa_int(0);\n" +
            "    HexaVal i = hexa_int(0);\n" +
            "    while (HX_BOOL(hexa_cmp_le(i, hexa_sub(hexa_int(hexa_len(s)), dlen)))) {\n" +
            "        if (hexa_truthy(hexa_eq(hexa_str_substring(s, i, hexa_add(i, dlen)), delim))) {\n" +
            "            hexa_array_push(out, hexa_str_substring(s, start, i));\n" +
            "            start = hexa_add(i, dlen);\n" +
            "            i = start;\n" +
            "        } else {\n" +
            "            i = hexa_add(i, hexa_int(1));\n" +
            "        }\n" +
            "    }\n" +
            "    hexa_array_push(out, hexa_str_substring(s, start, hexa_int(hexa_len(s))));\n" +
            "    return __hexa_fn_arena_return(out);\n" +
            "    return __hexa_fn_arena_return(hexa_void());\n" +
            "}\n" +
            "\n" +
            "\n" +
            "HexaVal rt_str_lines(HexaVal s) {\n" +
            "    __hexa_fn_arena_enter();\n" +
            "    return __hexa_fn_arena_return(rt_str_split(s, __hexa_rt_sl_0));\n" +
            "    return __hexa_fn_arena_return(hexa_void());\n" +
            "}\n" +
            "\n" +
            "\n" +
            "HexaVal rt_str_pad_left(HexaVal s, HexaVal width, HexaVal pad) {\n" +
            "    __hexa_fn_arena_enter();\n" +
            "    HexaVal slen = hexa_int(hexa_len(s));\n" +
            "    HexaVal plen = hexa_int(hexa_len(pad));\n" +
            "    if (hexa_truthy(hexa_cmp_ge(slen, width))) {\n" +
            "        return __hexa_fn_arena_return(s);\n" +
            "    }\n" +
            "    if (hexa_truthy(hexa_eq(plen, hexa_int(0)))) {\n" +
            "        return __hexa_fn_arena_return(s);\n" +
            "    }\n" +
            "    HexaVal pad_total = hexa_sub(width, slen);\n" +
            "    HexaVal iters = hexa_div(pad_total, plen);\n" +
            "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(iters, plen), pad_total))) {\n" +
            "        iters = hexa_add(iters, hexa_int(1));\n" +
            "    }\n" +
            "    HexaVal parts = hexa_array_new();\n" +
            "    HexaVal i = hexa_int(0);\n" +
            "    while (HX_BOOL(hexa_cmp_lt(i, iters))) {\n" +
            "        hexa_array_push(parts, pad);\n" +
            "        i = hexa_add(i, hexa_int(1));\n" +
            "    }\n" +
            "    hexa_array_push(parts, s);\n" +
            "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n" +
            "    return __hexa_fn_arena_return(hexa_void());\n" +
            "}\n" +
            "\n" +
            "\n" +
            "HexaVal rt_str_pad_right(HexaVal s, HexaVal width, HexaVal pad) {\n" +
            "    __hexa_fn_arena_enter();\n" +
            "    HexaVal slen = hexa_int(hexa_len(s));\n" +
            "    HexaVal plen = hexa_int(hexa_len(pad));\n" +
            "    if (hexa_truthy(hexa_cmp_ge(slen, width))) {\n" +
            "        return __hexa_fn_arena_return(s);\n" +
            "    }\n" +
            "    if (hexa_truthy(hexa_eq(plen, hexa_int(0)))) {\n" +
            "        return __hexa_fn_arena_return(s);\n" +
            "    }\n" +
            "    HexaVal pad_total = hexa_sub(width, slen);\n" +
            "    HexaVal iters = hexa_div(pad_total, plen);\n" +
            "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(iters, plen), pad_total))) {\n" +
            "        iters = hexa_add(iters, hexa_int(1));\n" +
            "    }\n" +
            "    HexaVal parts = hexa_array_new();\n" +
            "    hexa_array_push(parts, s);\n" +
            "    HexaVal i = hexa_int(0);\n" +
            "    while (HX_BOOL(hexa_cmp_lt(i, iters))) {\n" +
            "        hexa_array_push(parts, pad);\n" +
            "        i = hexa_add(i, hexa_int(1));\n" +
            "    }\n" +
            "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n" +
            "    return __hexa_fn_arena_return(hexa_void());\n" +
            "}\n" +
            "\n" +
            "\n" +
            "HexaVal rt_str_repeat(HexaVal s, HexaVal count) {\n" +
            "    __hexa_fn_arena_enter();\n" +
            "    if (hexa_truthy(hexa_cmp_le(count, hexa_int(0)))) {\n" +
            "        return __hexa_fn_arena_return(__hexa_rt_sl_1);\n" +
            "    }\n" +
            "    HexaVal parts = hexa_array_new();\n" +
            "    HexaVal i = hexa_int(0);\n" +
            "    while (HX_BOOL(hexa_cmp_lt(i, count))) {\n" +
            "        hexa_array_push(parts, s);\n" +
            "        i = hexa_add(i, hexa_int(1));\n" +
            "    }\n" +
            "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n" +
            "    return __hexa_fn_arena_return(hexa_void());\n" +
            "}\n" +
            "\n" +
            "\n" +
            "HexaVal rt_str_center(HexaVal s, HexaVal width, HexaVal pad) {\n" +
            "    __hexa_fn_arena_enter();\n" +
            "    HexaVal slen = hexa_int(hexa_len(s));\n" +
            "    HexaVal plen = hexa_int(hexa_len(pad));\n" +
            "    if (hexa_truthy(hexa_cmp_ge(slen, width))) {\n" +
            "        return __hexa_fn_arena_return(s);\n" +
            "    }\n" +
            "    if (hexa_truthy(hexa_eq(plen, hexa_int(0)))) {\n" +
            "        return __hexa_fn_arena_return(s);\n" +
            "    }\n" +
            "    HexaVal total_pad = hexa_sub(width, slen);\n" +
            "    HexaVal left_pad = hexa_div(total_pad, hexa_int(2));\n" +
            "    HexaVal right_pad = hexa_sub(total_pad, left_pad);\n" +
            "    HexaVal li = hexa_div(left_pad, plen);\n" +
            "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(li, plen), left_pad))) {\n" +
            "        li = hexa_add(li, hexa_int(1));\n" +
            "    }\n" +
            "    HexaVal ri = hexa_div(right_pad, plen);\n" +
            "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(ri, plen), right_pad))) {\n" +
            "        ri = hexa_add(ri, hexa_int(1));\n" +
            "    }\n" +
            "    HexaVal parts = hexa_array_new();\n" +
            "    HexaVal i = hexa_int(0);\n" +
            "    while (HX_BOOL(hexa_cmp_lt(i, li))) {\n" +
            "        hexa_array_push(parts, pad);\n" +
            "        i = hexa_add(i, hexa_int(1));\n" +
            "    }\n" +
            "    hexa_array_push(parts, s);\n" +
            "    HexaVal j = hexa_int(0);\n" +
            "    while (HX_BOOL(hexa_cmp_lt(j, ri))) {\n" +
            "        hexa_array_push(parts, pad);\n" +
            "        j = hexa_add(j, hexa_int(1));\n" +
            "    }\n" +
            "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n" +
            "    return __hexa_fn_arena_return(hexa_void());\n" +
            "}\n" +
            "\n" +
            "\n" +
            "\n" +
            "__attribute__((constructor))\n" +
            "static void __hexa_rt_strlit_init_ctor(void) { __hexa_rt_strlit_init(); }\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "runtime_hi_gen.c" }
    let c_text = emit_runtime_hi_gen_c()
    let cmd = "cat > \"" + out_path + "\" <<'RUNTIME_HI_GEN_EMIT_EOF'\n" +
              c_text + "RUNTIME_HI_GEN_EMIT_EOF"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[runtime_hi_gen_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[runtime_hi_gen_emit] wrote " + out_path)
    exit(0)
}
