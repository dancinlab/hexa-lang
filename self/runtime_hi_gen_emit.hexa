#!hexa strict
// runtime_hi_gen_emit.hexa
//   B9.C (.c-text · #1850 pattern) — runtime_hi_gen.c source emitter.
//
// RFC 061 amalgamation HI-tier rt_str_* stdlib (split/lines/pad/repeat/center). content SSOT=self/runtime_hi.hexa via tool/extract_runtime_hi.sh. Written via buffered-flush.
//
// Emits runtime_hi_gen.c VERBATIM. The hexa build regenerates the .c from
// this emitter before compiling, so the emitter becomes the SSOT and the
// .c becomes a build artifact. Byte-identity (gate-1 source-SHA, proven by
// runtime_hi_gen_byte_diff.hexa) ⇒ identical .o/.so ⇒ PERF UNCHANGED.
//
// GENERATED by tool/gen_c_text_emitter.hexa — do not hand-edit; re-run the
// generator against the hand-written .c if it ever changes.
//
// Invocation:  hexa-run runtime_hi_gen_emit.hexa <output-path>
// Default output path (if argv missing): "runtime_hi_gen.c" in cwd.

let MODULE_NAME = "runtime_hi_gen_emit"

fn _flush_runtime_hi_gen(out_path: str, buf: str) {
    let _ = exec("cat >> \"" + out_path + "\" <<'GEN_runtime_hi_gen_EOF'\n" + buf + "GEN_runtime_hi_gen_EOF")
}

fn emit_runtime_hi_gen_to(out_path: str) {
    // Verbatim content of hand-written self/native/runtime_hi_gen.c, streamed in
    // size-bounded chunks (see generator note on the per-command exec limit).
    let _ = exec("printf '' > \"" + out_path + "\"")
    let mut buf = ""
    buf = buf + "// GENERATED FROM self/runtime_hi.hexa — do not edit manually.\n"
    buf = buf + "// Source of truth: self/runtime_hi.hexa (M1-lite hi-layer SSOT).\n"
    buf = buf + "// Reproduce: tool/extract_runtime_hi.sh (runs self/native/hexat then\n"
    buf = buf + "// strips main/selftest, renames __hexa_sl_* -> __hexa_rt_sl_*).\n"
    buf = buf + "// Included from self/runtime.c AFTER hexa_str_join is defined.\n"
    buf = buf + "// (hxa-20260423-003 Step 4 — extraction replaces hand-port rt_str_*)\n"
    buf = buf + "//\n"
    buf = buf + "// PHASE 1.3.B follow-up (2026-05-15): rt_str_* are NON-static now so they're\n"
    buf = buf + "// reachable from user.c when codegen emits `#include \"runtime.h\"` (the new\n"
    buf = buf + "// default — see codegen_c2.hexa:679). Header forward decls live in\n"
    buf = buf + "// runtime.h's \"rt_* high-layer stdlib (runtime_hi_gen.c)\" block. Internal\n"
    buf = buf + "// `__hexa_rt_sl_*` constants stay file-scoped static — they're only used\n"
    buf = buf + "// by the bodies in this file.\n"
    buf = buf + "\n"
    buf = buf + "static HexaVal __hexa_rt_sl_0;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_1;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_2;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_3;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_4;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_5;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_6;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_7;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_8;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_9;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_10;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_11;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_12;\n"
    buf = buf + "static HexaVal __hexa_rt_sl_13;\n"
    buf = buf + "static void __hexa_rt_strlit_init(void) {\n"
    buf = buf + "    __hexa_rt_sl_0 = hexa_str(\"\\n\");\n"
    buf = buf + "    __hexa_rt_sl_1 = hexa_str(\"\");\n"
    buf = buf + "    __hexa_rt_sl_2 = hexa_str(\"7\");\n"
    buf = buf + "    __hexa_rt_sl_3 = hexa_str(\"0\");\n"
    buf = buf + "    __hexa_rt_sl_4 = hexa_str(\"ab\");\n"
    buf = buf + "    __hexa_rt_sl_5 = hexa_str(\"hi\");\n"
    buf = buf + "    __hexa_rt_sl_6 = hexa_str(\"-\");\n"
    buf = buf + "    __hexa_rt_sl_7 = hexa_str(\"a\\nb\\nc\");\n"
    buf = buf + "    __hexa_rt_sl_8 = hexa_str(\"007\");\n"
    buf = buf + "    __hexa_rt_sl_9 = hexa_str(\"700\");\n"
    buf = buf + "    __hexa_rt_sl_10 = hexa_str(\"ababab\");\n"
    buf = buf + "    __hexa_rt_sl_11 = hexa_str(\"--hi--\");\n"
    buf = buf + "    __hexa_rt_sl_12 = hexa_str(\"runtime_hi: selftest OK\");\n"
    buf = buf + "    __hexa_rt_sl_13 = hexa_str(\"runtime_hi: selftest FAIL\");\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_split(HexaVal s, HexaVal delim) {\n"
    buf = buf + "    __hexa_fn_arena_enter();\n"
    buf = buf + "    HexaVal out = hexa_array_new();\n"
    buf = buf + "    if (hexa_truthy(hexa_eq(hexa_int(hexa_len(delim)), hexa_int(0)))) {\n"
    buf = buf + "        hexa_array_push(out, s);\n"
    if buf.len() > 65536 { _flush_runtime_hi_gen(out_path, buf); buf = "" }
    buf = buf + "        return __hexa_fn_arena_return(out);\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal dlen = hexa_int(hexa_len(delim));\n"
    buf = buf + "    HexaVal start = hexa_int(0);\n"
    buf = buf + "    HexaVal i = hexa_int(0);\n"
    buf = buf + "    while (HX_BOOL(hexa_cmp_le(i, hexa_sub(hexa_int(hexa_len(s)), dlen)))) {\n"
    buf = buf + "        if (hexa_truthy(hexa_eq(hexa_str_substring(s, i, hexa_add(i, dlen)), delim))) {\n"
    buf = buf + "            hexa_array_push(out, hexa_str_substring(s, start, i));\n"
    buf = buf + "            start = hexa_add(i, dlen);\n"
    buf = buf + "            i = start;\n"
    buf = buf + "        } else {\n"
    buf = buf + "            i = hexa_add(i, hexa_int(1));\n"
    buf = buf + "        }\n"
    buf = buf + "    }\n"
    buf = buf + "    hexa_array_push(out, hexa_str_substring(s, start, hexa_int(hexa_len(s))));\n"
    buf = buf + "    return __hexa_fn_arena_return(out);\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_void());\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_lines(HexaVal s) {\n"
    buf = buf + "    __hexa_fn_arena_enter();\n"
    buf = buf + "    return __hexa_fn_arena_return(rt_str_split(s, __hexa_rt_sl_0));\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_void());\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_pad_left(HexaVal s, HexaVal width, HexaVal pad) {\n"
    buf = buf + "    __hexa_fn_arena_enter();\n"
    buf = buf + "    HexaVal slen = hexa_int(hexa_len(s));\n"
    buf = buf + "    HexaVal plen = hexa_int(hexa_len(pad));\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_ge(slen, width))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (hexa_truthy(hexa_eq(plen, hexa_int(0)))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal pad_total = hexa_sub(width, slen);\n"
    buf = buf + "    HexaVal iters = hexa_div(pad_total, plen);\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(iters, plen), pad_total))) {\n"
    buf = buf + "        iters = hexa_add(iters, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal parts = hexa_array_new();\n"
    buf = buf + "    HexaVal i = hexa_int(0);\n"
    buf = buf + "    while (HX_BOOL(hexa_cmp_lt(i, iters))) {\n"
    buf = buf + "        hexa_array_push(parts, pad);\n"
    buf = buf + "        i = hexa_add(i, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    hexa_array_push(parts, s);\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n"
    if buf.len() > 65536 { _flush_runtime_hi_gen(out_path, buf); buf = "" }
    buf = buf + "    return __hexa_fn_arena_return(hexa_void());\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_pad_right(HexaVal s, HexaVal width, HexaVal pad) {\n"
    buf = buf + "    __hexa_fn_arena_enter();\n"
    buf = buf + "    HexaVal slen = hexa_int(hexa_len(s));\n"
    buf = buf + "    HexaVal plen = hexa_int(hexa_len(pad));\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_ge(slen, width))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (hexa_truthy(hexa_eq(plen, hexa_int(0)))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal pad_total = hexa_sub(width, slen);\n"
    buf = buf + "    HexaVal iters = hexa_div(pad_total, plen);\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(iters, plen), pad_total))) {\n"
    buf = buf + "        iters = hexa_add(iters, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal parts = hexa_array_new();\n"
    buf = buf + "    hexa_array_push(parts, s);\n"
    buf = buf + "    HexaVal i = hexa_int(0);\n"
    buf = buf + "    while (HX_BOOL(hexa_cmp_lt(i, iters))) {\n"
    buf = buf + "        hexa_array_push(parts, pad);\n"
    buf = buf + "        i = hexa_add(i, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_void());\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_repeat(HexaVal s, HexaVal count) {\n"
    buf = buf + "    __hexa_fn_arena_enter();\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_le(count, hexa_int(0)))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(__hexa_rt_sl_1);\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal parts = hexa_array_new();\n"
    buf = buf + "    HexaVal i = hexa_int(0);\n"
    buf = buf + "    while (HX_BOOL(hexa_cmp_lt(i, count))) {\n"
    buf = buf + "        hexa_array_push(parts, s);\n"
    buf = buf + "        i = hexa_add(i, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_void());\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "HexaVal rt_str_center(HexaVal s, HexaVal width, HexaVal pad) {\n"
    buf = buf + "    __hexa_fn_arena_enter();\n"
    buf = buf + "    HexaVal slen = hexa_int(hexa_len(s));\n"
    if buf.len() > 65536 { _flush_runtime_hi_gen(out_path, buf); buf = "" }
    buf = buf + "    HexaVal plen = hexa_int(hexa_len(pad));\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_ge(slen, width))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    if (hexa_truthy(hexa_eq(plen, hexa_int(0)))) {\n"
    buf = buf + "        return __hexa_fn_arena_return(s);\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal total_pad = hexa_sub(width, slen);\n"
    buf = buf + "    HexaVal left_pad = hexa_div(total_pad, hexa_int(2));\n"
    buf = buf + "    HexaVal right_pad = hexa_sub(total_pad, left_pad);\n"
    buf = buf + "    HexaVal li = hexa_div(left_pad, plen);\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(li, plen), left_pad))) {\n"
    buf = buf + "        li = hexa_add(li, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal ri = hexa_div(right_pad, plen);\n"
    buf = buf + "    if (hexa_truthy(hexa_cmp_lt(hexa_mul(ri, plen), right_pad))) {\n"
    buf = buf + "        ri = hexa_add(ri, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    HexaVal parts = hexa_array_new();\n"
    buf = buf + "    HexaVal i = hexa_int(0);\n"
    buf = buf + "    while (HX_BOOL(hexa_cmp_lt(i, li))) {\n"
    buf = buf + "        hexa_array_push(parts, pad);\n"
    buf = buf + "        i = hexa_add(i, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    hexa_array_push(parts, s);\n"
    buf = buf + "    HexaVal j = hexa_int(0);\n"
    buf = buf + "    while (HX_BOOL(hexa_cmp_lt(j, ri))) {\n"
    buf = buf + "        hexa_array_push(parts, pad);\n"
    buf = buf + "        j = hexa_add(j, hexa_int(1));\n"
    buf = buf + "    }\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_str_join(parts, __hexa_rt_sl_1));\n"
    buf = buf + "    return __hexa_fn_arena_return(hexa_void());\n"
    buf = buf + "}\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "\n"
    buf = buf + "__attribute__((constructor))\n"
    buf = buf + "static void __hexa_rt_strlit_init_ctor(void) { __hexa_rt_strlit_init(); }\n"
    if buf.len() > 0 { _flush_runtime_hi_gen(out_path, buf) }
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "runtime_hi_gen.c" }
    emit_runtime_hi_gen_to(out_path)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[runtime_hi_gen_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[runtime_hi_gen_emit] wrote " + out_path)
    exit(0)
}
