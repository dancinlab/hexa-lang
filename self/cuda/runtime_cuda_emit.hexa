#!hexa strict
// self/cuda/runtime_cuda_emit.hexa
//   B9.C-5 (.c-leg batch · #1850 pattern) — runtime_cuda.c source emitter.
//
// Mirrors lib/hxpyembed/hxpyembed_emit.hexa one-to-one. Emits the
// anima RFC 040 Phase A real-cuBLAS impl (`runtime_cuda.c`) verbatim.
// This TU hosts the FP64 substrate (`_CudaFarrSlot` device mirror,
// cuBLAS Dgemm dispatch, all `_hx_cuda_*` entry points). The dispatch
// scripts (tool/dispatch_phase4d{6,9}_*, dispatch_phase4d_5_{3,4}.sh,
// flame_phase4d{7,9}_*.sh) upload the regenerated `.c` to a GPU pod
// for nvcc compile — there is no local CMake target (no `nvcc` on the
// Mac host).
//
// Invocation (from a build wrapper or dispatch-script regen step):
//   hexa-run self/cuda/runtime_cuda_emit.hexa <output-path>
//
// Default output path (if argv missing): "runtime_cuda.c" in cwd.
//
// Phase: B9.C-5 batch (runtime_bf16 + runtime_cuda).


let MODULE_NAME = "runtime_cuda_emit"

fn emit_runtime_cuda_c() -> str {
    let s = "/* runtime_cuda.c — anima RFC 040 Phase A real-cuBLAS impl.\n" +
            " *\n" +
            " * Provides the `_hx_cuda_*` TU forward-decl'd by hexa-lang self/runtime.c\n" +
            " * under `#ifdef HEXA_CUDA`. When the host has a CUDA toolkit, this TU\n" +
            " * compiles + links with `-lcudart -lcublas`, giving farr_matmul_gpu a\n" +
            " * real cuBLAS Dgemm body. On a no-CUDA host this file is simply not\n" +
            " * compiled (the no-CUDA build is byte-identical to today).\n" +
            " *\n" +
            " * Math contract — same as RFC 032 farr_matmul:\n" +
            " *   A row-major M×K, B row-major K×N, C row-major M×N.\n" +
            " *   Reproducible bit-identity is NOT claimed (cuBLAS reduces in a\n" +
            " *   different order than the CPU ikj scalar loop, fp non-associativity).\n" +
            " *   Tolerance: |Δ| < ~1e-9 for Dgemm — matches RFC 040 §\"Honest caveats\"\n" +
            " *   TOL_MATMUL guess; this fire measures and reports the actual max |Δ|.\n" +
            " *\n" +
            " * cuBLAS is column-major. Our farr is row-major. We map row-major\n" +
            " * C = A·B to cuBLAS column-major by computing:\n" +
            " *   C^T_col = B^T_col · A^T_col\n" +
            " * which in cuBLAS column-major terms (treating row-major A as col-major\n" +
            " * A^T) is: `cublasDgemm(handle, N, N, N=cols_out, M=rows_out, K, alpha,\n" +
            " * B_dev, ldb=N, A_dev, lda=K, beta, C_dev, ldc=N)`.\n" +
            " *\n" +
            " * Device-farr coordination: we own a tiny device-side mirror table keyed\n" +
            " * by farr_id. Operands are uploaded H2D on demand (when not already\n" +
            " * resident) and outputs allocated device-side. The runtime.c side keeps\n" +
            " * `dirty_host=1` / `loc=FARR_DEVICE` to track residence; this TU does\n" +
            " * the actual cudaMalloc / cudaMemcpy calls.\n" +
            " *\n" +
            " * Honest reporting: every error path returns -1 + a one-line stderr\n" +
            " * message naming the failure. No silent fallbacks; no fake CUDA results.\n" +
            " */\n" +
            "\n" +
            "#include <stdio.h>\n" +
            "#include <stdint.h>\n" +
            "#include <stdlib.h>\n" +
            "#include <string.h>\n" +
            "\n" +
            "#include <cuda_runtime.h>\n" +
            "#include <cublas_v2.h>\n" +
            "\n" +
            "/* C linkage for the public surface so that C harnesses (or runtime.c on\n" +
            " * the host build) can call these symbols without C++ name mangling.\n" +
            " * `-x cu` always parses as C++; without `extern \"C\"`, the harness\n" +
            " * `extern \"C\" { int _hx_cuda_*(...); }` will fail to resolve. */\n" +
            "#ifdef __cplusplus\n" +
            "extern \"C\" {\n" +
            "#endif\n" +
            "\n" +
            "/* Tiny device-side mirror table. Keyed by farr_id (same int handle the\n" +
            " * runtime.c HexaFarrEntry table uses). Sparse: grows on demand. */\n" +
            "typedef struct {\n" +
            "    double*  d_buf;       /* cudaMalloc'd device pointer, or NULL */\n" +
            "    int64_t  len;         /* element count (must match host len when valid) */\n" +
            "    /* RFC 056 §6.2: -1 = this slot owns its d_buf (cudaMalloc'd here, may\n" +
            "     * be cudaFree'd). >=0 = this slot is a NON-OWNING device sub-view of\n" +
            "     * base farr `view_base` (d_buf = g_slots[view_base].d_buf + offset);\n" +
            "     * device_free / free must NOT cudaFree it (would corrupt the base).\n" +
            "     * A view is invalidated when its base is freed/migrated (guarded). */\n" +
            "    int64_t  view_base;\n" +
            "} _CudaFarrSlot;\n" +
            "\n" +
            "static _CudaFarrSlot* g_slots     = NULL;\n" +
            "static int64_t        g_slot_cap  = 0;\n" +
            "\n" +
            "static int _ensure_slot_cap(int64_t id) {\n" +
            "    if (id < 0) return -1;\n" +
            "    if (id < g_slot_cap) return 0;\n" +
            "    int64_t new_cap = g_slot_cap < 16 ? 16 : g_slot_cap;\n" +
            "    while (new_cap <= id) new_cap *= 2;\n" +
            "    _CudaFarrSlot* ns = (_CudaFarrSlot*)realloc(g_slots,\n" +
            "                            (size_t)new_cap * sizeof(_CudaFarrSlot));\n" +
            "    if (!ns) { fprintf(stderr, \"[cuda] OOM slot table\\n\"); return -1; }\n" +
            "    /* zero-init the new tail. view_base = -1 (owns / not a view). */\n" +
            "    for (int64_t i = g_slot_cap; i < new_cap; i++) {\n" +
            "        ns[i].d_buf     = NULL;\n" +
            "        ns[i].len       = 0;\n" +
            "        ns[i].view_base = -1;\n" +
            "    }\n" +
            "    g_slots = ns;\n" +
            "    g_slot_cap = new_cap;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* Forward decls — these live in self/runtime.c. We access the host\n" +
            " * HexaFarrEntry table to read host buf + len for H2D + D2H. */\n" +
            "typedef struct {\n" +
            "    double*  buf;\n" +
            "    int64_t  len;\n" +
            "    void*    d_buf;       /* runtime.c side device-ptr slot (we mirror) */\n" +
            "    int      loc;\n" +
            "    int      pinned;\n" +
            "    int      dirty_host;\n" +
            "    int      dirty_dev;\n" +
            "} HexaFarrEntry;\n" +
            "extern HexaFarrEntry* _hx_farr_table;\n" +
            "extern int64_t        _hx_farr_count;\n" +
            "\n" +
            "enum { FARR_HOST = 0, FARR_DEVICE = 1, FARR_MIRRORED = 2 };\n" +
            "\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * RFC 056 — device residence contract + sub-view API (Phase 1).\n" +
            " *\n" +
            " * §6.4 output-disposition register. The forge `_gpu` wrappers do not\n" +
            " * change ABI (the Phase 4-D-5-3 byte-eq oracle harnesses declare them\n" +
            " * `extern \"C\"` and re-running that oracle unchanged is falsifier\n" +
            " * F-RFC056-BYTEEQ-PRESERVE — a signature break would fail the gate by\n" +
            " * construction). Instead RFC 056 §6.4's \"per-call out_disposition arg\"\n" +
            " * is realised as a process-wide register set by the caller IMMEDIATELY\n" +
            " * before the `_gpu` call (functionally per-call; single-threaded forge\n" +
            " * dispatch). Default = FORGE_OUT_HOST_NOW → any caller not updated gets\n" +
            " * byte-identical current behaviour (the backward-safety invariant; spec\n" +
            " * §6.4 / §8.3).\n" +
            " *\n" +
            " *   FORGE_OUT_HOST_NOW   = 0  D2H the output now (== pre-RFC-056)\n" +
            " *   FORGE_OUT_DEVICE_KEEP = 1 defer D2H, output stays loc=FARR_DEVICE,\n" +
            " *                             dirty_dev=1 (consumed by next GPU op)\n" +
            " *\n" +
            " * H2D-skip (§6.1): _h2d on an input that is loc∈{DEVICE,MIRRORED} with\n" +
            " * !dirty_host and a live device slot of matching len SKIPs the\n" +
            " * cudaMemcpy HostToDevice — the device bytes were written by the\n" +
            " * authoritative path and host has not mutated them since, so the copy\n" +
            " * is provably a no-op. Zero output bytes change (the byte-eq invariant\n" +
            " * of §6.1 \"Byte-eq invariant\").\n" +
            " *\n" +
            " * NB: every threshold/behaviour here traces to RFC 056 §6.1-6.4 + the\n" +
            " * fire #5-#9 measured campaign; no lattice numerology (f1/f2).\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "enum { FORGE_OUT_HOST_NOW = 0, FORGE_OUT_DEVICE_KEEP = 1 };\n" +
            "\n" +
            "/* Process-wide output-disposition register. Default HOST_NOW =\n" +
            " * byte-identical to the verified pre-RFC-056 substrate. */\n" +
            "static int g_forge_out_disposition = FORGE_OUT_HOST_NOW;\n" +
            "\n" +
            "/* Called by the host runtime.c shim immediately before a `_gpu` op to\n" +
            " * express §6.4's consumed-by-next-GPU-op hint. Returns the previous\n" +
            " * value (so callers can save/restore). */\n" +
            "int _hx_cuda_set_out_disposition(int d) {\n" +
            "    int prev = g_forge_out_disposition;\n" +
            "    g_forge_out_disposition = (d == FORGE_OUT_DEVICE_KEEP)\n" +
            "                              ? FORGE_OUT_DEVICE_KEEP : FORGE_OUT_HOST_NOW;\n" +
            "    return prev;\n" +
            "}\n" +
            "\n" +
            "/* cuBLAS handle — lazy init. */\n" +
            "static cublasHandle_t g_cublas = NULL;\n" +
            "\n" +
            "static int _ensure_cublas(void) {\n" +
            "    if (g_cublas) return 0;\n" +
            "    cublasStatus_t st = cublasCreate(&g_cublas);\n" +
            "    if (st != CUBLAS_STATUS_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] cublasCreate failed: %d\\n\", (int)st);\n" +
            "        g_cublas = NULL;\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Default math mode is fp64-strict for Dgemm; do NOT set\n" +
            "     * CUBLAS_TENSOR_OP_MATH (we want bit-reproducible Dgemm). */\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* Upload host buf → device. Allocate if needed. Returns 0 ok / -1 err. */\n" +
            "static int _h2d(int64_t id) {\n" +
            "    if (id < 0 || id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] h2d: bad id %lld\\n\", (long long)id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_ensure_slot_cap(id) != 0) return -1;\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[id];\n" +
            "    _CudaFarrSlot* s = &g_slots[id];\n" +
            "    /* RFC 056 §6.2: a non-owning device sub-view is, by definition,\n" +
            "     * already device-resident (it aliases the base's live buffer).\n" +
            "     * Never upload, never realloc — that would corrupt the base.\n" +
            "     * Just mirror the device pointer back for visibility. */\n" +
            "    if (s->view_base >= 0 && s->d_buf) {\n" +
            "        e->d_buf = (void*)s->d_buf;\n" +
            "        e->dirty_dev = 0;\n" +
            "        return 0;\n" +
            "    }\n" +
            "    if (!e->buf || e->len <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] h2d: empty host farr id=%lld\\n\", (long long)id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* RFC 056 §6.1 H2D-skip. If the farr is device-resident\n" +
            "     * (loc∈{DEVICE,MIRRORED}) AND host is not dirty AND the device slot\n" +
            "     * is live with a matching length, the device bytes ALREADY equal\n" +
            "     * what the cudaMemcpy H2D would write (they were produced by the\n" +
            "     * authoritative path; host unchanged since). Skipping the copy is\n" +
            "     * therefore provably byte-eq — falsifier F-RFC056-BYTEEQ-PRESERVE\n" +
            "     * requires max|Δ|=0.0 with this path active. We still mirror the\n" +
            "     * device pointer back to the entry for visibility. */\n" +
            "    if ((e->loc == FARR_DEVICE || e->loc == FARR_MIRRORED) &&\n" +
            "        !e->dirty_host && s->d_buf && s->len == e->len) {\n" +
            "        e->d_buf = (void*)s->d_buf;\n" +
            "        e->dirty_dev = 0;\n" +
            "        return 0; /* SKIP cudaMemcpy HostToDevice */\n" +
            "    }\n" +
            "    if (!s->d_buf || s->len != e->len) {\n" +
            "        if (s->d_buf) cudaFree(s->d_buf);\n" +
            "        cudaError_t er = cudaMalloc((void**)&s->d_buf,\n" +
            "                                    (size_t)e->len * sizeof(double));\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] cudaMalloc(%lld doubles) failed: %s\\n\",\n" +
            "                    (long long)e->len, cudaGetErrorString(er));\n" +
            "            s->d_buf = NULL; s->len = 0;\n" +
            "            return -1;\n" +
            "        }\n" +
            "        s->len = e->len;\n" +
            "    }\n" +
            "    cudaError_t er = cudaMemcpy(s->d_buf, e->buf,\n" +
            "                                (size_t)e->len * sizeof(double),\n" +
            "                                cudaMemcpyHostToDevice);\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] cudaMemcpy H2D failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Mirror device pointer back to runtime.c entry for visibility. */\n" +
            "    e->d_buf = (void*)s->d_buf;\n" +
            "    if (e->loc == FARR_HOST) e->loc = FARR_MIRRORED;\n" +
            "    e->dirty_dev = 0;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* Copy device → host. Returns 0 ok / -1 err. */\n" +
            "static int _d2h(int64_t id) {\n" +
            "    if (id < 0 || id >= _hx_farr_count) return -1;\n" +
            "    if (id >= g_slot_cap)               return -1;\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[id];\n" +
            "    _CudaFarrSlot* s = &g_slots[id];\n" +
            "    if (!e->buf || !s->d_buf || s->len != e->len) {\n" +
            "        fprintf(stderr, \"[cuda] d2h: state mismatch id=%lld\\n\", (long long)id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    cudaError_t er = cudaMemcpy(e->buf, s->d_buf,\n" +
            "                                (size_t)e->len * sizeof(double),\n" +
            "                                cudaMemcpyDeviceToHost);\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] cudaMemcpy D2H failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    e->dirty_host = 0;\n" +
            "    if (e->loc == FARR_DEVICE) e->loc = FARR_MIRRORED;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* ── Public surface (forward-decl'd in self/runtime.c HEXA_CUDA block) ── */\n" +
            "\n" +
            "int _hx_cuda_runtime_available(void) {\n" +
            "    int n = 0;\n" +
            "    cudaError_t er = cudaGetDeviceCount(&n);\n" +
            "    if (er != cudaSuccess) return 0;\n" +
            "    return (n > 0) ? 1 : 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_device_count_impl(void) {\n" +
            "    int n = 0;\n" +
            "    cudaError_t er = cudaGetDeviceCount(&n);\n" +
            "    if (er != cudaSuccess) return 0;\n" +
            "    return (n > 0) ? n : 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_to_device(int64_t farr_id) {\n" +
            "    if (_h2d(farr_id) != 0) return -1;\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_to_host(int64_t farr_id) {\n" +
            "    if (_d2h(farr_id) != 0) return -1;\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_device_free(int64_t farr_id) {\n" +
            "    if (farr_id < 0 || farr_id >= g_slot_cap) return 1; /* nothing to free */\n" +
            "    _CudaFarrSlot* s = &g_slots[farr_id];\n" +
            "    if (s->view_base >= 0) {\n" +
            "        /* RFC 056 §6.2: this slot is a NON-OWNING device sub-view —\n" +
            "         * d_buf aliases the base's buffer. Never cudaFree it (that\n" +
            "         * would corrupt the base). Just drop the view. */\n" +
            "        s->d_buf     = NULL;\n" +
            "        s->len       = 0;\n" +
            "        s->view_base = -1;\n" +
            "    } else if (s->d_buf) {\n" +
            "        /* RFC 056 §6.2: freeing a base invalidates every view that\n" +
            "         * aliased it (use-after-free guard — F-RFC056-VIEW-SAFETY).\n" +
            "         * Scan the slot table and drop dependent views BEFORE the\n" +
            "         * cudaFree so a later op on a view sees d_buf=NULL, not a\n" +
            "         * dangling device pointer. */\n" +
            "        for (int64_t v = 0; v < g_slot_cap; v++) {\n" +
            "            if (g_slots[v].view_base == farr_id) {\n" +
            "                g_slots[v].d_buf     = NULL;\n" +
            "                g_slots[v].len       = 0;\n" +
            "                g_slots[v].view_base = -1;\n" +
            "                if (v < _hx_farr_count) {\n" +
            "                    HexaFarrEntry* ve = &_hx_farr_table[v];\n" +
            "                    ve->d_buf = NULL;\n" +
            "                    ve->loc = FARR_HOST;\n" +
            "                    ve->dirty_host = 0;\n" +
            "                    ve->dirty_dev = 0;\n" +
            "                }\n" +
            "            }\n" +
            "        }\n" +
            "        cudaFree(s->d_buf);\n" +
            "        s->d_buf = NULL;\n" +
            "        s->len = 0;\n" +
            "    }\n" +
            "    if (farr_id < _hx_farr_count) {\n" +
            "        HexaFarrEntry* e = &_hx_farr_table[farr_id];\n" +
            "        e->d_buf = NULL;\n" +
            "        e->loc = FARR_HOST;\n" +
            "        e->dirty_host = 0;\n" +
            "        e->dirty_dev = 0;\n" +
            "    }\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "#ifdef HEXA_CUDA\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * RFC 055 055-P1 — hexa_cuda_launch_kernel\n" +
            " *\n" +
            " *   Thin Driver-API wrapper that loads a cubin from an in-memory blob,\n" +
            " *   resolves a kernel by name, marshals the farr-base argument list,\n" +
            " *   and launches with the caller's grid/block configuration. This is\n" +
            " *   the `gpu_launch` host-ABI termination point (gpu/SPEC.md §7,\n" +
            " *   RFC 055 §6.5): the hexa surface lowers to this call exactly the\n" +
            " *   way `hexa_cuda_alloc / copy / free / sync` lower to the Runtime\n" +
            " *   API helpers above.\n" +
            " *\n" +
            " *   Inputs:\n" +
            " *     - cubin_blob / cubin_len  — the @gpu_kernel's compiled cubin\n" +
            " *                                 (RFC 055 emits PTX text; ptxas turns\n" +
            " *                                 it into a cubin which the build\n" +
            " *                                 system embeds as a .rodata LSection).\n" +
            " *     - kernel_name             — the PTX `.visible .entry` symbol.\n" +
            " *     - gx/gy/gz/bx/by/bz       — CUDA grid + block dimensions.\n" +
            " *     - farr_ids  / n_args      — argument list: each int64_t is a\n" +
            " *                                 farr slot id; the wrapper resolves\n" +
            " *                                 the slot's d_buf and marshals a\n" +
            " *                                 (CUdeviceptr) pointer into the\n" +
            " *                                 cuLaunchKernel argv. n is appended\n" +
            " *                                 as a trailing i64 in extra_i64_args.\n" +
            " *\n" +
            " *   Returns 1 on success, 0 on failure (with stderr diagnostic).\n" +
            " *\n" +
            " *   F-RFC055-LAUNCH-ABI gates this entry point round-trip via the\n" +
            " *   tool/dispatch_r055_p1_vec_add.sh harness (host→kernel→host). The\n" +
            " *   wrapper compiles only under `#ifdef HEXA_CUDA`; on a host without\n" +
            " *   the CUDA toolkit the symbol is defined as a no-op returning 0 so\n" +
            " *   the f-style fallback (F-RFC055-FALLBACK) stays byte-identical to\n" +
            " *   the no-NVPTX build.\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "#include <cuda.h>   /* CUmodule / CUfunction / cuLaunchKernel — Driver API. */\n" +
            "\n" +
            "int _hx_cuda_launch_kernel(const void*   cubin_blob,\n" +
            "                           size_t        cubin_len,\n" +
            "                           const char*   kernel_name,\n" +
            "                           int           gx, int gy, int gz,\n" +
            "                           int           bx, int by, int bz,\n" +
            "                           const int64_t* farr_ids,\n" +
            "                           int            n_farr,\n" +
            "                           const int64_t* extra_i64_args,\n" +
            "                           int            n_extra) {\n" +
            "    if (!cubin_blob || cubin_len == 0 || !kernel_name) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: bad cubin/name\\n\");\n" +
            "        return 0;\n" +
            "    }\n" +
            "    /* Lazy Driver-API init — Runtime API above auto-inits cuCtx, but a\n" +
            "     * Driver-API cuModuleLoadData call without an explicit Init/Context\n" +
            "     * fails on some toolkit/driver pairings. Calling cuInit(0) is\n" +
            "     * idempotent and cheap. */\n" +
            "    CUresult cr = cuInit(0);\n" +
            "    if (cr != CUDA_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: cuInit failed (%d)\\n\", (int)cr);\n" +
            "        return 0;\n" +
            "    }\n" +
            "    CUmodule mod = NULL;\n" +
            "    cr = cuModuleLoadData(&mod, cubin_blob);\n" +
            "    if (cr != CUDA_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: cuModuleLoadData failed (%d)\\n\", (int)cr);\n" +
            "        return 0;\n" +
            "    }\n" +
            "    CUfunction kfn = NULL;\n" +
            "    cr = cuModuleGetFunction(&kfn, mod, kernel_name);\n" +
            "    if (cr != CUDA_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: cuModuleGetFunction(`%s`) failed (%d)\\n\",\n" +
            "                kernel_name, (int)cr);\n" +
            "        cuModuleUnload(mod);\n" +
            "        return 0;\n" +
            "    }\n" +
            "\n" +
            "    /* Marshal the argument list. cuLaunchKernel expects an array of\n" +
            "     * `void*` pointing at each argument's storage; we hold the farr\n" +
            "     * d_buf pointers + the i64 extras in caller-allocated arrays so a\n" +
            "     * VLA-free build (MSVC, older compilers) still works — cap at 16\n" +
            "     * total args which is the documented gpu_launch surface for 055-P1\n" +
            "     * (gpu/SPEC.md §7 — kernel signatures fit comfortably). */\n" +
            "    enum { _HX_GPU_LAUNCH_MAX_ARGS = 16 };\n" +
            "    CUdeviceptr arg_dptrs[_HX_GPU_LAUNCH_MAX_ARGS];\n" +
            "    int64_t     arg_i64s [_HX_GPU_LAUNCH_MAX_ARGS];\n" +
            "    void*       arg_ptrs [_HX_GPU_LAUNCH_MAX_ARGS];\n" +
            "\n" +
            "    int total = n_farr + n_extra;\n" +
            "    if (total > _HX_GPU_LAUNCH_MAX_ARGS) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: too many args (%d > %d)\\n\",\n" +
            "                total, _HX_GPU_LAUNCH_MAX_ARGS);\n" +
            "        cuModuleUnload(mod);\n" +
            "        return 0;\n" +
            "    }\n" +
            "    int idx = 0;\n" +
            "    for (int i = 0; i < n_farr; i++) {\n" +
            "        int64_t farr_id = farr_ids[i];\n" +
            "        if (farr_id < 0 || farr_id >= g_slot_cap) {\n" +
            "            fprintf(stderr, \"[cuda] launch_kernel: bad farr id %lld\\n\",\n" +
            "                    (long long)farr_id);\n" +
            "            cuModuleUnload(mod);\n" +
            "            return 0;\n" +
            "        }\n" +
            "        /* The kernel reads .global memory — ensure the slot is\n" +
            "         * device-resident before launch. */\n" +
            "        if (_h2d(farr_id) != 0) {\n" +
            "            fprintf(stderr, \"[cuda] launch_kernel: h2d for farr %lld failed\\n\",\n" +
            "                    (long long)farr_id);\n" +
            "            cuModuleUnload(mod);\n" +
            "            return 0;\n" +
            "        }\n" +
            "        arg_dptrs[idx] = (CUdeviceptr)(uintptr_t)g_slots[farr_id].d_buf;\n" +
            "        arg_ptrs [idx] = &arg_dptrs[idx];\n" +
            "        idx++;\n" +
            "    }\n" +
            "    for (int i = 0; i < n_extra; i++) {\n" +
            "        arg_i64s[idx] = extra_i64_args[i];\n" +
            "        arg_ptrs[idx] = &arg_i64s[idx];\n" +
            "        idx++;\n" +
            "    }\n" +
            "\n" +
            "    /* Launch — shared memory bytes = 0, stream = 0 (default). Extra\n" +
            "     * config (dynamic .shared, async stream) is 055-P2. */\n" +
            "    cr = cuLaunchKernel(kfn,\n" +
            "                       (unsigned)gx, (unsigned)gy, (unsigned)gz,\n" +
            "                       (unsigned)bx, (unsigned)by, (unsigned)bz,\n" +
            "                       0u, NULL,\n" +
            "                       arg_ptrs, NULL);\n" +
            "    if (cr != CUDA_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: cuLaunchKernel(`%s`) failed (%d)\\n\",\n" +
            "                kernel_name, (int)cr);\n" +
            "        cuModuleUnload(mod);\n" +
            "        return 0;\n" +
            "    }\n" +
            "    /* Synchronize so a follow-up _d2h sees the kernel's writes — the\n" +
            "     * Runtime API path above is cudaDeviceSynchronize but cuCtxSync is\n" +
            "     * the Driver-API equivalent. */\n" +
            "    cr = cuCtxSynchronize();\n" +
            "    if (cr != CUDA_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] launch_kernel: cuCtxSynchronize failed (%d)\\n\",\n" +
            "                (int)cr);\n" +
            "        cuModuleUnload(mod);\n" +
            "        return 0;\n" +
            "    }\n" +
            "    /* Mark any farr arg as dev-dirty so a follow-up host read triggers\n" +
            "     * a D2H — the kernel just wrote to the .global buffers. */\n" +
            "    for (int i = 0; i < n_farr; i++) {\n" +
            "        int64_t farr_id = farr_ids[i];\n" +
            "        if (farr_id >= 0 && farr_id < _hx_farr_count) {\n" +
            "            HexaFarrEntry* e = &_hx_farr_table[farr_id];\n" +
            "            e->dirty_dev = 1;\n" +
            "            e->loc = FARR_MIRRORED;\n" +
            "        }\n" +
            "    }\n" +
            "    cuModuleUnload(mod);\n" +
            "    return 1;\n" +
            "}\n" +
            "#else\n" +
            "/* No-CUDA fallback (F-RFC055-FALLBACK) — the runtime_cuda.c TU still\n" +
            " * compiles `-fsyntax-only` on a host without the CUDA toolkit; the\n" +
            " * launch wrapper degrades to a no-op stub returning 0 (\"no GPU\"). */\n" +
            "int _hx_cuda_launch_kernel(const void*   cubin_blob,\n" +
            "                           size_t        cubin_len,\n" +
            "                           const char*   kernel_name,\n" +
            "                           int           gx, int gy, int gz,\n" +
            "                           int           bx, int by, int bz,\n" +
            "                           const int64_t* farr_ids,\n" +
            "                           int            n_farr,\n" +
            "                           const int64_t* extra_i64_args,\n" +
            "                           int            n_extra) {\n" +
            "    (void)cubin_blob; (void)cubin_len; (void)kernel_name;\n" +
            "    (void)gx; (void)gy; (void)gz; (void)bx; (void)by; (void)bz;\n" +
            "    (void)farr_ids; (void)n_farr; (void)extra_i64_args; (void)n_extra;\n" +
            "    return 0;\n" +
            "}\n" +
            "#endif /* HEXA_CUDA — gpu_launch wrapper guard */\n" +
            "\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * RFC 056 §6.2 — device sub-view API.  hexa_farr_dev_view(base, off,\n" +
            " * len) binds an already-host-allocated farr handle `view_id` so that\n" +
            " * its CUDA slot aliases base.d_buf + off*sizeof(double) for `len`\n" +
            " * doubles. NON-OWNING: device_free/free on the view drops the alias\n" +
            " * without cudaFree. The base must be device-resident (caller pins it\n" +
            " * first, §6.3). Out-of-range (off,len) → -1, no UB. Returns 0 ok.\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "int _hx_cuda_farr_dev_view(int64_t base_id, int64_t offset, int64_t len,\n" +
            "                           int64_t view_id) {\n" +
            "    if (base_id < 0 || base_id >= _hx_farr_count ||\n" +
            "        view_id < 0 || view_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] dev_view: bad ids base=%lld view=%lld\\n\",\n" +
            "                (long long)base_id, (long long)view_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (offset < 0 || len <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] dev_view: bad offset=%lld len=%lld\\n\",\n" +
            "                (long long)offset, (long long)len);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_ensure_slot_cap(base_id) != 0) return -1;\n" +
            "    if (_ensure_slot_cap(view_id) != 0) return -1;\n" +
            "    _CudaFarrSlot* bs = &g_slots[base_id];\n" +
            "    if (!bs->d_buf || bs->len <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] dev_view: base %lld not device-resident\\n\",\n" +
            "                (long long)base_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (offset + len > bs->len) {\n" +
            "        fprintf(stderr, \"[cuda] dev_view: range [%lld,%lld) exceeds \"\n" +
            "                \"base len %lld\\n\", (long long)offset,\n" +
            "                (long long)(offset + len), (long long)bs->len);\n" +
            "        return -1; /* out-of-range — no UB, F-RFC056-VIEW-SAFETY */\n" +
            "    }\n" +
            "    _CudaFarrSlot* vs = &g_slots[view_id];\n" +
            "    /* If the view slot previously OWNED a device buffer, free it (we\n" +
            "     * are repurposing the handle as a non-owning view). */\n" +
            "    if (vs->view_base < 0 && vs->d_buf) {\n" +
            "        cudaFree(vs->d_buf);\n" +
            "    }\n" +
            "    vs->d_buf     = bs->d_buf + offset;     /* double* arithmetic */\n" +
            "    vs->len       = len;\n" +
            "    vs->view_base = base_id;\n" +
            "    /* Mirror into the host entry so forge `_gpu` ops + H2D-skip see the\n" +
            "     * view as device-resident (it shares the base's residence). */\n" +
            "    HexaFarrEntry* ve = &_hx_farr_table[view_id];\n" +
            "    ve->d_buf      = (void*)vs->d_buf;\n" +
            "    ve->loc        = FARR_DEVICE;\n" +
            "    ve->dirty_host = 1;   /* host buf of the view handle is not the data */\n" +
            "    ve->dirty_dev  = 0;   /* device bytes are the authoritative base data */\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* RFC 056 §6.3 — residence anchor. pin: force the farr device-resident\n" +
            " * (H2D once) and mark it non-evictable (HexaFarrEntry.pinned, RFC 040).\n" +
            " * unpin: clear the pin; if the device copy is dirty, D2H it back. */\n" +
            "int _hx_cuda_farr_pin_device(int64_t farr_id) {\n" +
            "    if (farr_id < 0 || farr_id >= _hx_farr_count) return -1;\n" +
            "    if (_h2d(farr_id) != 0) return -1;          /* ensure resident */\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[farr_id];\n" +
            "    e->pinned = 1;\n" +
            "    if (e->loc == FARR_HOST) e->loc = FARR_MIRRORED;\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_unpin_device(int64_t farr_id) {\n" +
            "    if (farr_id < 0 || farr_id >= _hx_farr_count) return -1;\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[farr_id];\n" +
            "    e->pinned = 0;\n" +
            "    if (e->dirty_dev) { (void)_d2h(farr_id); }  /* materialize if stale */\n" +
            "    return 1;\n" +
            "}\n" +
            "\n" +
            "/* _hx_cuda_farr_matmul_gpu(A, M, K, B, N, C) — Dgemm row-major C = A · B.\n" +
            " *   A is M×K, B is K×N, C is M×N.\n" +
            " *   - Caller (runtime.c) has already allocated C farr_id with len = M·N\n" +
            " *     via hexa_farr_zeros.\n" +
            " *   - We upload A,B to device (idempotent — skips if already resident),\n" +
            " *     compute Dgemm on device, copy result back to host C buf,\n" +
            " *     mark C dirty_host=0 (host current), loc=MIRRORED.\n" +
            " *   - Returns 0 ok / -1 err.\n" +
            " *\n" +
            " *   Row-major → column-major mapping:\n" +
            " *     C_row[M,N] = A_row[M,K] · B_row[K,N]\n" +
            " *   View row-major A as column-major A^T (K×M); same for B,C. Then\n" +
            " *     C^T_col[N,M] = B^T_col[N,K] · A^T_col[K,M]\n" +
            " *   cuBLAS Dgemm with (op=N, op=N, m=N, n=M, k=K, A=B_dev, lda=N,\n" +
            " *                      B=A_dev, ldb=K, C=C_dev, ldc=N).\n" +
            " */\n" +
            "int _hx_cuda_farr_matmul_gpu(int64_t a_id, int64_t M, int64_t K,\n" +
            "                             int64_t b_id, int64_t N,\n" +
            "                             int64_t c_id) {\n" +
            "    if (_ensure_cublas() != 0) return -1;\n" +
            "    if (a_id < 0 || b_id < 0 || c_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] matmul: bad ids %lld %lld %lld\\n\",\n" +
            "                (long long)a_id, (long long)b_id, (long long)c_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (M <= 0 || K <= 0 || N <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] matmul: bad shape M=%lld K=%lld N=%lld\\n\",\n" +
            "                (long long)M, (long long)K, (long long)N);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Upload A,B (H2D). */\n" +
            "    if (_h2d(a_id) != 0) return -1;\n" +
            "    if (_h2d(b_id) != 0) return -1;\n" +
            "    /* Ensure C device buffer exists with size M·N. We re-use _ensure_slot_cap\n" +
            "     * + a fresh cudaMalloc to make a clean device-resident output. */\n" +
            "    if (_ensure_slot_cap(c_id) != 0) return -1;\n" +
            "    HexaFarrEntry* ce = &_hx_farr_table[c_id];\n" +
            "    _CudaFarrSlot*  cs = &g_slots[c_id];\n" +
            "    if (!ce->buf || ce->len < M * N) {\n" +
            "        fprintf(stderr, \"[cuda] matmul: C host len %lld < M*N %lld\\n\",\n" +
            "                (long long)ce->len, (long long)(M*N));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (!cs->d_buf || cs->len != ce->len) {\n" +
            "        if (cs->d_buf) cudaFree(cs->d_buf);\n" +
            "        cudaError_t er = cudaMalloc((void**)&cs->d_buf,\n" +
            "                                    (size_t)ce->len * sizeof(double));\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] cudaMalloc C(%lld) failed: %s\\n\",\n" +
            "                    (long long)ce->len, cudaGetErrorString(er));\n" +
            "            cs->d_buf = NULL; cs->len = 0;\n" +
            "            return -1;\n" +
            "        }\n" +
            "        cs->len = ce->len;\n" +
            "    }\n" +
            "    double* A_dev = g_slots[a_id].d_buf;\n" +
            "    double* B_dev = g_slots[b_id].d_buf;\n" +
            "    double* C_dev = cs->d_buf;\n" +
            "    const double alpha = 1.0;\n" +
            "    const double beta  = 0.0;\n" +
            "    /* Row-major C = A · B → column-major C^T = B^T · A^T trick:\n" +
            "     *   cuBLAS sees B's row-major buffer as column-major (N×K)\n" +
            "     *   cuBLAS sees A's row-major buffer as column-major (K×M)\n" +
            "     * Dgemm(N,N, m=N, n=M, k=K, alpha, B_dev, ldb=N, A_dev, lda=K,\n" +
            "     *       beta, C_dev, ldc=N) — produces column-major (N×M), which\n" +
            "     * IS the row-major C (M×N). */\n" +
            "    cublasStatus_t st = cublasDgemm(g_cublas,\n" +
            "                                    CUBLAS_OP_N, CUBLAS_OP_N,\n" +
            "                                    (int)N, (int)M, (int)K,\n" +
            "                                    &alpha,\n" +
            "                                    B_dev, (int)N,\n" +
            "                                    A_dev, (int)K,\n" +
            "                                    &beta,\n" +
            "                                    C_dev, (int)N);\n" +
            "    if (st != CUBLAS_STATUS_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] cublasDgemm failed: %d\\n\", (int)st);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Copy C device → host so the host-side caller sees the result. */\n" +
            "    cudaError_t er = cudaMemcpy(ce->buf, C_dev,\n" +
            "                                (size_t)(M * N) * sizeof(double),\n" +
            "                                cudaMemcpyDeviceToHost);\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] cudaMemcpy C D2H failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    ce->d_buf      = (void*)C_dev;\n" +
            "    ce->loc        = FARR_MIRRORED;\n" +
            "    ce->dirty_host = 0;\n" +
            "    ce->dirty_dev  = 0;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * RFC 041 Phase 4-D-5-2 — Phase B reduction + Phase B2 real CUDA kernels\n" +
            " * ────────────────────────────────────────────────────────────────────\n" +
            " * 6 ops landed this cycle (reduction + matmul-variants split; the\n" +
            " * elementwise split — mul/add/scale/silu/silu_grad — is the parallel\n" +
            " * Agent's deliverable):\n" +
            " *\n" +
            " *   reduction (block-per-row, warp-shuffle, no atomics):\n" +
            " *     - _hx_cuda_farr_softmax_rows_gpu     (Phase B)\n" +
            " *     - _hx_cuda_farr_rmsnorm_rows_gpu     (Phase B)\n" +
            " *     - _hx_cuda_farr_rmsnorm_bwd_rows_gpu (Phase B2; two row reductions)\n" +
            " *\n" +
            " *   matmul-variants (cuBLAS Dgemm reshape per RFC 041 §1):\n" +
            " *     - _hx_cuda_farr_matmul_t_gpu  (Mᵀ·u   = cublasDgemm u[1×R]·M[R×C]→[1×C])\n" +
            " *     - _hx_cuda_farr_outer_gpu     (u⊗v    = cublasDgemm u[R×1]·v[1×C]→[R×C])\n" +
            " *\n" +
            " *   1-D fused in-place update (no cross-element reduction):\n" +
            " *     - _hx_cuda_farr_adamw_step_gpu (decoupled-wd AdamW, mirrors dt2_adamw_step)\n" +
            " *\n" +
            " * Wiring contract (matches existing Phase A `_hx_cuda_farr_matmul_gpu`):\n" +
            " *   - Caller (self/runtime.c) has already allocated `out_id` via\n" +
            " *     hexa_farr_zeros with the correct length.\n" +
            " *   - We H2D-upload inputs (idempotent), cudaMalloc the output device\n" +
            " *     buffer (if not resident), launch the kernel / cuBLAS, then D2H\n" +
            " *     the result back to the caller's host buffer.\n" +
            " *   - Returns 0 ok / -1 err. Every error path prints `[cuda] <op>: ...`\n" +
            " *     to stderr; no silent fallback, no fake PASS.\n" +
            " *\n" +
            " * Determinism (F-RFC041-DETERMINISM):\n" +
            " *   - Reductions use FIXED block size + warp-shuffle/shared-mem tree\n" +
            " *     (no `atomicAdd`). Run-to-run byte-identical at fixed shape.\n" +
            " *   - cuBLAS Dgemm: same handle, no Tensor-Op math mode flip → bit-eq\n" +
            " *     across invocations on the same shape (per Phase D evidence).\n" +
            " *\n" +
            " * Tolerance choices (CALIBRATED — not asserted by hope):\n" +
            " *   - matmul_t   : TOL_MATMUL ≈ 2e-9 relative (carries RFC 040 §2.2 H100\n" +
            " *                  cuBLAS Dgemm measurement; same kernel, same caveat)\n" +
            " *   - outer      : |Δ| = 0 BIT-EXACT (single product term per cell,\n" +
            " *                  zero reduction → no fp non-associativity; RFC 041\n" +
            " *                  F-RFC041-OUTER-EXACT demands exactness)\n" +
            " *   - softmax_rows / rmsnorm_rows / rmsnorm_bwd_rows : TOL_ELEM ≈ 1e-12\n" +
            " *                  (one row-length reduction, C ≤ ~4096; warp-shuffle\n" +
            " *                  tree reorders pairwise sums relative to CPU sequential\n" +
            " *                  loop — the fp non-associativity bound for sum of N\n" +
            " *                  doubles is ~N·ε ≈ 4096·2.22e-16 ≈ 1e-12. Conservative.)\n" +
            " *   - adamw_step : TOL_ELEM ≈ 1e-12 (no cross-element reduction; only the\n" +
            " *                  per-element sqrt/division ULP — essentially bit-eq\n" +
            " *                  modulo the libm sqrt platform ulp delta. The CPU side\n" +
            " *                  also uses libm sqrt; bit-eq expected on modern x86/A64\n" +
            " *                  but a 1e-15 cushion guards against IEEE-754 corner\n" +
            " *                  cases on the GPU sqrt.)\n" +
            " *\n" +
            " * Build:\n" +
            " *   - Real kernels are compiled by `nvcc -x cu -c runtime_cuda.c` only\n" +
            " *     (the gcc-on-no-GPU path in PHASE_D_H100_EVIDENCE remains valid\n" +
            " *     for Phase A — it never enters the `__CUDACC__`-guarded bodies and\n" +
            " *     would link-fail at runtime if the new symbols are called without\n" +
            " *     nvcc; that link-fail is the correct, honest behaviour).\n" +
            " *   - On Mac dev (clang -DHEXA_CUDA -I /usr/local/cuda/include) the\n" +
            " *     `__CUDACC__` macro is undefined, so the wrappers below compile as\n" +
            " *     `return -1` stubs — syntactic check passes, no fake PASS.\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "\n" +
            "/* ── Output-allocation helper (no H2D upload — output starts fresh). ── */\n" +
            "static int _ensure_dev_alloc_out(int64_t out_id, int64_t need_len) {\n" +
            "    if (out_id < 0 || out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] out: bad id %lld\\n\", (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_ensure_slot_cap(out_id) != 0) return -1;\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[out_id];\n" +
            "    _CudaFarrSlot* s = &g_slots[out_id];\n" +
            "    /* RFC 056 §6.2: a non-owning view must never be used as a kernel\n" +
            "     * OUTPUT through this allocator (it would realloc/own the alias and\n" +
            "     * corrupt the base). Views are read-only slices in the A2 design;\n" +
            "     * reject defensively rather than risk the verified base buffer. */\n" +
            "    if (s->view_base >= 0) {\n" +
            "        fprintf(stderr, \"[cuda] out: id %lld is a non-owning device view \"\n" +
            "                \"(cannot be a kernel output)\\n\", (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (!e->buf || e->len < need_len) {\n" +
            "        fprintf(stderr, \"[cuda] out: host len %lld < need %lld\\n\",\n" +
            "                (long long)e->len, (long long)need_len);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (!s->d_buf || s->len != e->len) {\n" +
            "        if (s->d_buf) cudaFree(s->d_buf);\n" +
            "        cudaError_t er = cudaMalloc((void**)&s->d_buf,\n" +
            "                                    (size_t)e->len * sizeof(double));\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] cudaMalloc out(%lld) failed: %s\\n\",\n" +
            "                    (long long)e->len, cudaGetErrorString(er));\n" +
            "            s->d_buf = NULL; s->len = 0;\n" +
            "            return -1;\n" +
            "        }\n" +
            "        s->len = e->len;\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* ── D2H of an output buffer with explicit length (post-kernel copy). ──\n" +
            " *\n" +
            " * RFC 056 §6.1/§6.4 D2H-defer. When the caller set the disposition\n" +
            " * register to FORGE_OUT_DEVICE_KEEP (output is consumed by the next GPU\n" +
            " * op, no host reader in between), the cudaMemcpy DeviceToHost is\n" +
            " * DEFERRED: the output stays loc=FARR_DEVICE, dirty_dev=1 with a live\n" +
            " * device slot. The very next forge op's _h2d sees DEVICE && !dirty_host\n" +
            " * and SKIPs the redundant H2D — the value never round-trips. A later\n" +
            " * host reader (or an explicit hexa_farr_to_host) does the lazy D2H.\n" +
            " *\n" +
            " * The DEFAULT (FORGE_OUT_HOST_NOW) is byte-identical to the verified\n" +
            " * pre-RFC-056 substrate: same cudaMemcpy, same loc=FARR_MIRRORED,\n" +
            " * dirty flags cleared. F-RFC056-BYTEEQ-PRESERVE re-runs the 12-kernel\n" +
            " * oracle harnesses (which never set the register → always HOST_NOW)\n" +
            " * and requires max|Δ|=0.0. */\n" +
            "static int _d2h_out(int64_t out_id, int64_t copy_len) {\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[out_id];\n" +
            "    _CudaFarrSlot* s = &g_slots[out_id];\n" +
            "    if (g_forge_out_disposition == FORGE_OUT_DEVICE_KEEP) {\n" +
            "        /* Defer D2H — device authoritative, host stale. No bytes\n" +
            "         * copied; the next op reads s->d_buf directly via H2D-skip. */\n" +
            "        e->d_buf      = (void*)s->d_buf;\n" +
            "        e->loc        = FARR_DEVICE;\n" +
            "        e->dirty_host = 1;   /* host buf no longer current */\n" +
            "        e->dirty_dev  = 1;   /* device holds the freshest value */\n" +
            "        (void)copy_len;\n" +
            "        return 0;\n" +
            "    }\n" +
            "    cudaError_t er = cudaMemcpy(e->buf, s->d_buf,\n" +
            "                                (size_t)copy_len * sizeof(double),\n" +
            "                                cudaMemcpyDeviceToHost);\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] D2H out failed: %s\\n\", cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    e->d_buf      = (void*)s->d_buf;\n" +
            "    e->loc        = FARR_MIRRORED;\n" +
            "    e->dirty_host = 0;\n" +
            "    e->dirty_dev  = 0;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "#ifdef __CUDACC__\n" +
            "\n" +
            "/* ── Warp + block sum-reduction primitives (deterministic tree). ── */\n" +
            "/* Block size for row-reduction kernels. 256 threads = 8 warps, fits\n" +
            " * even long rows (C up to ~4096 with grid-stride within the block). */\n" +
            "#define HX_RR_BLOCK 256\n" +
            "\n" +
            "__device__ __forceinline__ double _hx_warp_sum(double v) {\n" +
            "    /* unsigned mask = 0xFFFFFFFF — all 32 threads of the warp. */\n" +
            "    for (int offset = 16; offset > 0; offset >>= 1) {\n" +
            "        v += __shfl_down_sync(0xFFFFFFFFu, v, offset);\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "__device__ __forceinline__ double _hx_warp_max(double v) {\n" +
            "    for (int offset = 16; offset > 0; offset >>= 1) {\n" +
            "        double o = __shfl_down_sync(0xFFFFFFFFu, v, offset);\n" +
            "        if (o > v) v = o;\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "/* Block-wide sum: warp-reduce → shared-mem (one slot per warp) → first\n" +
            " * warp re-reduces. HX_RR_BLOCK=256 → 8 warps → 8 shared slots. Returns\n" +
            " * the total on thread 0; other threads see garbage. */\n" +
            "__device__ __forceinline__ double _hx_block_sum(double v, double* smem) {\n" +
            "    int lane = threadIdx.x & 31;\n" +
            "    int wid  = threadIdx.x >> 5;\n" +
            "    v = _hx_warp_sum(v);\n" +
            "    if (lane == 0) smem[wid] = v;\n" +
            "    __syncthreads();\n" +
            "    /* First warp reads up-to-(HX_RR_BLOCK/32) warp sums + reduces. */\n" +
            "    int n_warps = (blockDim.x + 31) >> 5;\n" +
            "    if (wid == 0) {\n" +
            "        double w = (lane < n_warps) ? smem[lane] : 0.0;\n" +
            "        w = _hx_warp_sum(w);\n" +
            "        if (lane == 0) smem[0] = w;\n" +
            "    }\n" +
            "    __syncthreads();\n" +
            "    return smem[0];\n" +
            "}\n" +
            "\n" +
            "__device__ __forceinline__ double _hx_block_max(double v, double* smem) {\n" +
            "    int lane = threadIdx.x & 31;\n" +
            "    int wid  = threadIdx.x >> 5;\n" +
            "    v = _hx_warp_max(v);\n" +
            "    if (lane == 0) smem[wid] = v;\n" +
            "    __syncthreads();\n" +
            "    int n_warps = (blockDim.x + 31) >> 5;\n" +
            "    if (wid == 0) {\n" +
            "        /* -inf-equivalent for unused slots; rows always have ≥1 valid val. */\n" +
            "        double w = (lane < n_warps) ? smem[lane] : -1.0e308;\n" +
            "        w = _hx_warp_max(w);\n" +
            "        if (lane == 0) smem[0] = w;\n" +
            "    }\n" +
            "    __syncthreads();\n" +
            "    return smem[0];\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel 1 — softmax_rows: numerically-stable row-wise softmax.\n" +
            " *   Y[r,j] = exp(X[r,j] - max_j X[r,j]) / Σ_j exp(...)\n" +
            " * Layout: one block per row (gridDim.x = R), HX_RR_BLOCK threads per\n" +
            " * block. Each thread strides across the row.\n" +
            " * Two reductions per row (max, then sum). Fixed tree → deterministic.\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_softmax_rows(const double* __restrict__ X,\n" +
            "                                   double* __restrict__ Y,\n" +
            "                                   int64_t R, int64_t C) {\n" +
            "    int64_t r = blockIdx.x;\n" +
            "    if (r >= R) return;\n" +
            "    const double* xr = X + r * C;\n" +
            "    double*       yr = Y + r * C;\n" +
            "\n" +
            "    __shared__ double smem[HX_RR_BLOCK / 32];\n" +
            "\n" +
            "    /* Pass 1: row max. */\n" +
            "    double vmax = -1.0e308;\n" +
            "    for (int64_t j = threadIdx.x; j < C; j += blockDim.x) {\n" +
            "        double v = xr[j];\n" +
            "        if (v > vmax) vmax = v;\n" +
            "    }\n" +
            "    double zmax = _hx_block_max(vmax, smem);\n" +
            "\n" +
            "    /* Pass 2: write exp(x - max) into Y, accumulate sum. */\n" +
            "    double vsum = 0.0;\n" +
            "    for (int64_t j = threadIdx.x; j < C; j += blockDim.x) {\n" +
            "        double e = exp(xr[j] - zmax);\n" +
            "        yr[j] = e;\n" +
            "        vsum += e;\n" +
            "    }\n" +
            "    double s = _hx_block_sum(vsum, smem);\n" +
            "    double inv = (s > 0.0) ? (1.0 / s) : 0.0;\n" +
            "\n" +
            "    /* Pass 3: normalize. */\n" +
            "    for (int64_t j = threadIdx.x; j < C; j += blockDim.x) {\n" +
            "        yr[j] *= inv;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel 1c (RFC gpu-resident-large-vocab-lmhead-loss, ADDITIVE) —\n" +
            " * ce_seed: GPU-resident large-vocab lm-head cross-entropy loss + seed\n" +
            " * gradient, ONE kernel, logits never leave the device.\n" +
            " *\n" +
            " *   row r ∈ [0,R), logits L[r,*] over a vocab of size V:\n" +
            " *     m       = max_v L[r,v]                          (block-reduce)\n" +
            " *     s       = Σ_v exp(L[r,v] - m)                    (block-reduce)\n" +
            " *     lse     = m + log(s)                             (log-sum-exp)\n" +
            " *     loss[r] = lse - L[r, target[r]]                 = -log softmax(target)\n" +
            " *     dlogits[r,v] = softmax(L[r,v]) - onehot(v == target[r])\n" +
            " *\n" +
            " * Layout matches _hx_k_softmax_rows: one block per row (gridDim.x = R),\n" +
            " * HX_RR_BLOCK threads striding the row; the two reductions use the same\n" +
            " * deterministic _hx_block_max / _hx_block_sum tree. Per-row loss is\n" +
            " * written to OUT_LOSS[r] (length R; the caller sums the R values on host\n" +
            " * — R is small, e.g. 512). The seed grad fills OUT_DL[r*V + v] in place.\n" +
            " *\n" +
            " * HONEST SCOPE — bit-identity NOT claimed (online/parallel reduce order\n" +
            " * differs from the host FP64 sequential loop); follows the forge `_gpu`\n" +
            " * convention (rel-err tolerance, not max|Δ|=0). The targets arrive as a\n" +
            " * double-encoded farr (token ids stored as doubles); each is rounded to\n" +
            " * the nearest int64 vocab index.\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_ce_seed(const double* __restrict__ L,\n" +
            "                              const double* __restrict__ TGT,\n" +
            "                              double* __restrict__ OUT_LOSS,\n" +
            "                              double* __restrict__ OUT_DL,\n" +
            "                              int64_t R, int64_t V) {\n" +
            "    int64_t r = blockIdx.x;\n" +
            "    if (r >= R) return;\n" +
            "    const double* lr = L + r * V;\n" +
            "    double*       dr = OUT_DL + r * V;\n" +
            "\n" +
            "    __shared__ double smem[HX_RR_BLOCK / 32];\n" +
            "\n" +
            "    /* target index for this row (double-encoded → rounded int64). */\n" +
            "    int64_t tgt = (int64_t)(TGT[r] + (TGT[r] >= 0.0 ? 0.5 : -0.5));\n" +
            "\n" +
            "    /* Pass 1: row max. */\n" +
            "    double vmax = -1.0e308;\n" +
            "    for (int64_t j = threadIdx.x; j < V; j += blockDim.x) {\n" +
            "        double v = lr[j];\n" +
            "        if (v > vmax) vmax = v;\n" +
            "    }\n" +
            "    double m = _hx_block_max(vmax, smem);\n" +
            "\n" +
            "    /* Pass 2: write exp(x - m) into dlogits, accumulate sum-exp. */\n" +
            "    double vsum = 0.0;\n" +
            "    for (int64_t j = threadIdx.x; j < V; j += blockDim.x) {\n" +
            "        double e = exp(lr[j] - m);\n" +
            "        dr[j] = e;\n" +
            "        vsum += e;\n" +
            "    }\n" +
            "    double s   = _hx_block_sum(vsum, smem);\n" +
            "    double inv = (s > 0.0) ? (1.0 / s) : 0.0;\n" +
            "\n" +
            "    /* CE loss for this row = lse - L[target] = (m + log s) - L[target].\n" +
            "     * One thread (lane 0 of block) writes OUT_LOSS[r]; guard tgt range. */\n" +
            "    if (threadIdx.x == 0) {\n" +
            "        double lse = m + log(s);\n" +
            "        double lt  = (tgt >= 0 && tgt < V) ? lr[tgt] : 0.0;\n" +
            "        OUT_LOSS[r] = lse - lt;\n" +
            "    }\n" +
            "\n" +
            "    /* Pass 3: normalize → softmax, then subtract onehot(target). */\n" +
            "    for (int64_t j = threadIdx.x; j < V; j += blockDim.x) {\n" +
            "        double p = dr[j] * inv;\n" +
            "        if (j == tgt) p -= 1.0;\n" +
            "        dr[j] = p;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel 1b (flame Phase 4-D-9, ADDITIVE — RFC 058 12→13→14 precedent)\n" +
            " * ────────────────────────────────────────────────────────────────────\n" +
            " * causal_softmax_rows: per-row causal-prefix softmax for the attention\n" +
            " * block (tool/flame_phase4d7_block_fwd_primitive.c L767-789). For row i,\n" +
            " * with the causal prefix length L = i+1:\n" +
            " *\n" +
            " *     m_max  = max_{j∈[0,L)}  X[i*T+j]\n" +
            " *     e_j    = _hx_dt_exp_dev(X[i*T+j] - m_max)              j∈[0,L)\n" +
            " *     tot    = Σ_{j∈[0,L)} e_j\n" +
            " *     Y[i*T+j] = e_j / tot                                   j∈[0,L)\n" +
            " *     Y[i*T+j] = 0.0                                         j∈[L,T)\n" +
            " *\n" +
            " * BYTE-EQ CONTRACT — the CPU reference uses `flame_g7_dt_exp`, a\n" +
            " * deterministic 12-term-Taylor / range-halving polynomial, NOT libm\n" +
            " * `exp()`. _hx_dt_exp_dev below is that algorithm ported VERBATIM\n" +
            " * (same constants, same loop bounds 1..11 / 0..r-1, same order) so the\n" +
            " * only numerical gap vs the CPU reference is the row-reduction reorder\n" +
            " * (deterministic tree, ~1e-12 band), never an exp-algorithm error.\n" +
            " *\n" +
            " * The existing _hx_k_softmax_rows (Kernel 1 above) softmaxes the FULL\n" +
            " * row with libm exp() and is UNTOUCHED — this is a separate, additive\n" +
            " * kernel for the causal-masked attention path.\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "\n" +
            "/* __device__ port of flame_g7_dt_exp (tool/flame_phase4d7_block_fwd_\n" +
            " * primitive.c:78-85). Byte-for-byte the same algorithm: range-reduce by\n" +
            " * halving while |xr| > 0.25 (counting r halvings), 12-term Taylor\n" +
            " * (k = 1..11, term *= xr/k, acc += term), then square the result r\n" +
            " * times. Same operations, same order ⇒ bit-identical to the CPU\n" +
            " * reference modulo NONE (pure fp64 ops, identical sequence). */\n" +
            "__device__ __forceinline__ double _hx_dt_exp_dev(double x) {\n" +
            "    int r = 0; double xr = x;\n" +
            "    while ((xr > 0.0 ? xr : -xr) > 0.25) { xr = xr / 2.0; r = r + 1; }\n" +
            "    double term = 1.0, acc = 1.0;\n" +
            "    for (int k = 1; k < 12; k++) { term = term * xr / (double)k; acc = acc + term; }\n" +
            "    for (int s = 0; s < r; s++) acc = acc * acc;\n" +
            "    return acc;\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_causal_softmax_rows(const double* __restrict__ X,\n" +
            "                                                  double* __restrict__ Y,\n" +
            "                                                  int64_t R, int64_t T) {\n" +
            "    int64_t i = blockIdx.x;                 /* one block per row i */\n" +
            "    if (i >= R) return;\n" +
            "    const double* xr = X + i * T;\n" +
            "    double*       yr = Y + i * T;\n" +
            "    int64_t L = i + 1;                      /* causal prefix length */\n" +
            "\n" +
            "    __shared__ double smem[HX_RR_BLOCK / 32];\n" +
            "\n" +
            "    /* Pass 1: max over the causal prefix [0, L). Threads outside the\n" +
            "     * prefix contribute the -inf-equivalent identity (matches the CPU\n" +
            "     * reference which seeds m_max = sc[i*T+0] and scans j∈[1,L)). */\n" +
            "    double vmax = -1.0e308;\n" +
            "    for (int64_t j = threadIdx.x; j < L; j += blockDim.x) {\n" +
            "        double v = xr[j];\n" +
            "        if (v > vmax) vmax = v;\n" +
            "    }\n" +
            "    double zmax = _hx_block_max(vmax, smem);\n" +
            "\n" +
            "    /* Pass 2: e_j = dt_exp(x - max) into Y[0,L); accumulate the prefix\n" +
            "     * sum. j∈[L,T) is written exactly 0.0 (the CPU code only writes /\n" +
            "     * normalizes [0,L) and leaves the rest of the Bc slab as its prior\n" +
            "     * zeros — here Y is the dedicated output so we zero it explicitly). */\n" +
            "    double vsum = 0.0;\n" +
            "    for (int64_t j = threadIdx.x; j < T; j += blockDim.x) {\n" +
            "        if (j < L) {\n" +
            "            double e = _hx_dt_exp_dev(xr[j] - zmax);\n" +
            "            yr[j] = e;\n" +
            "            vsum += e;\n" +
            "        } else {\n" +
            "            yr[j] = 0.0;\n" +
            "        }\n" +
            "    }\n" +
            "    double tot = _hx_block_sum(vsum, smem);\n" +
            "\n" +
            "    /* Pass 3: normalize the causal prefix. The CPU reference divides\n" +
            "     * (`Bc[oP+...] /= tot`) — use the SAME divide here (NOT a\n" +
            "     * multiply-by-reciprocal) so the only residual numerical gap vs the\n" +
            "     * CPU reference is the deterministic-tree reorder of m_max and tot.\n" +
            "     * The CPU `tot` is always > 0 (≥ exp(0)=1 from the j=i diagonal),\n" +
            "     * so no /0 guard is needed to mirror it; guard defensively anyway. */\n" +
            "    for (int64_t j = threadIdx.x; j < L; j += blockDim.x) {\n" +
            "        if (tot != 0.0) yr[j] = yr[j] / tot;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel 2 — rmsnorm_rows: Y[r,j] = X[r,j] / sqrt(mean_j(X²) + eps)\n" +
            " *   One block per row; one reduction (sum of squares).\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_rmsnorm_rows(const double* __restrict__ X,\n" +
            "                                   double* __restrict__ Y,\n" +
            "                                   int64_t R, int64_t C, double eps) {\n" +
            "    int64_t r = blockIdx.x;\n" +
            "    if (r >= R) return;\n" +
            "    const double* xr = X + r * C;\n" +
            "    double*       yr = Y + r * C;\n" +
            "\n" +
            "    __shared__ double smem[HX_RR_BLOCK / 32];\n" +
            "\n" +
            "    double v = 0.0;\n" +
            "    for (int64_t j = threadIdx.x; j < C; j += blockDim.x) {\n" +
            "        double x = xr[j];\n" +
            "        v += x * x;\n" +
            "    }\n" +
            "    double ss = _hx_block_sum(v, smem);\n" +
            "    double ms = ss / (double)C;\n" +
            "    double inv = 1.0 / sqrt(ms + eps);\n" +
            "\n" +
            "    for (int64_t j = threadIdx.x; j < C; j += blockDim.x) {\n" +
            "        yr[j] = xr[j] * inv;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel 3 — rmsnorm_bwd_rows: exact dx-branch of RMSNorm vjp.\n" +
            " *   inv  = (mean_j(x²)+ε)^(−1/2)\n" +
            " *   dot  = Σ_k dxn_k · x_k\n" +
            " *   dx_i = inv·dxn_i − (inv³·x_i / C)·dot\n" +
            " *   ε = 1e-6 (mirrors CPU c3_rmsnorm_bwd contract).\n" +
            " * Two reductions per row (ms = Σx², dot = Σdxn·x).\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_rmsnorm_bwd_rows(const double* __restrict__ X,\n" +
            "                                       const double* __restrict__ DXN,\n" +
            "                                       double* __restrict__ O,\n" +
            "                                       int64_t R, int64_t C) {\n" +
            "    int64_t r = blockIdx.x;\n" +
            "    if (r >= R) return;\n" +
            "    const double* xr  = X   + r * C;\n" +
            "    const double* dxr = DXN + r * C;\n" +
            "    double*       orr = O   + r * C;\n" +
            "\n" +
            "    __shared__ double smem[HX_RR_BLOCK / 32];\n" +
            "\n" +
            "    /* Reduction 1: sum of squares. */\n" +
            "    double ssq = 0.0;\n" +
            "    for (int64_t j = threadIdx.x; j < C; j += blockDim.x) {\n" +
            "        double x = xr[j];\n" +
            "        ssq += x * x;\n" +
            "    }\n" +
            "    double ms_total = _hx_block_sum(ssq, smem);\n" +
            "    double ms       = ms_total / (double)C;\n" +
            "    double inv      = 1.0 / sqrt(ms + 1e-6);\n" +
            "\n" +
            "    /* Reduction 2: dot(dxn, x). */\n" +
            "    double dotp = 0.0;\n" +
            "    for (int64_t k = threadIdx.x; k < C; k += blockDim.x) {\n" +
            "        dotp += dxr[k] * xr[k];\n" +
            "    }\n" +
            "    double dot  = _hx_block_sum(dotp, smem);\n" +
            "    double coef = (inv * inv * inv) / (double)C;\n" +
            "\n" +
            "    /* Write dx. */\n" +
            "    for (int64_t i = threadIdx.x; i < C; i += blockDim.x) {\n" +
            "        orr[i] = inv * dxr[i] - coef * xr[i] * dot;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel 4 — adamw_step: decoupled-wd AdamW in-place.\n" +
            " *   m_i  ← β1·m_i + (1-β1)·g_i\n" +
            " *   v_i  ← β2·v_i + (1-β2)·g_i²\n" +
            " *   mhat = m_i / (1-β1^t)\n" +
            " *   vhat = v_i / (1-β2^t)\n" +
            " *   W_i  ← W_i - lr·wd·W_i - lr·mhat/(sqrt(vhat)+eps)   (out → O[i])\n" +
            " *   m, v updated in-place on their device buffers.\n" +
            " * 1-D grid-stride; no cross-element reduction → bit-eq per element\n" +
            " * (modulo sqrt ULP).\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_adamw_step(double* __restrict__ W,\n" +
            "                                 double* __restrict__ Mm,\n" +
            "                                 double* __restrict__ Vv,\n" +
            "                                 const double* __restrict__ G,\n" +
            "                                 double* __restrict__ O,\n" +
            "                                 int64_t n,\n" +
            "                                 double lr, double b1, double b2,\n" +
            "                                 double eps, double wd,\n" +
            "                                 double c1, double c2) {\n" +
            "    int64_t stride = (int64_t)blockDim.x * (int64_t)gridDim.x;\n" +
            "    for (int64_t i = (int64_t)blockIdx.x * blockDim.x + threadIdx.x;\n" +
            "         i < n;\n" +
            "         i += stride) {\n" +
            "        double g    = G[i];\n" +
            "        double mi   = b1 * Mm[i] + (1.0 - b1) * g;\n" +
            "        double vi   = b2 * Vv[i] + (1.0 - b2) * g * g;\n" +
            "        double mhat = mi / c1;\n" +
            "        double vhat = vi / c2;\n" +
            "        double denom = sqrt(vhat) + eps;\n" +
            "        double wi   = W[i] - lr * wd * W[i] - lr * mhat / denom;\n" +
            "        Mm[i] = mi;     /* in-place optimizer state */\n" +
            "        Vv[i] = vi;\n" +
            "        O[i]  = wi;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* In-place AdamW kernel — IDENTICAL arithmetic to _hx_k_adamw_step,\n" +
            " * but W is both the read source AND the write destination (no separate\n" +
            " * O). No `__restrict__` aliasing hazard (a single W pointer). Each\n" +
            " * thread reads W[i] then writes W[i] within its own iteration → safe. */\n" +
            "__global__ void _hx_k_adamw_step_inplace(double* __restrict__ W,\n" +
            "                                 double* __restrict__ Mm,\n" +
            "                                 double* __restrict__ Vv,\n" +
            "                                 const double* __restrict__ G,\n" +
            "                                 int64_t n,\n" +
            "                                 double lr, double b1, double b2,\n" +
            "                                 double eps, double wd,\n" +
            "                                 double c1, double c2) {\n" +
            "    int64_t stride = (int64_t)blockDim.x * (int64_t)gridDim.x;\n" +
            "    for (int64_t i = (int64_t)blockIdx.x * blockDim.x + threadIdx.x;\n" +
            "         i < n;\n" +
            "         i += stride) {\n" +
            "        double g    = G[i];\n" +
            "        double mi   = b1 * Mm[i] + (1.0 - b1) * g;\n" +
            "        double vi   = b2 * Vv[i] + (1.0 - b2) * g * g;\n" +
            "        double mhat = mi / c1;\n" +
            "        double vhat = vi / c2;\n" +
            "        double denom = sqrt(vhat) + eps;\n" +
            "        double wi   = W[i] - lr * wd * W[i] - lr * mhat / denom;\n" +
            "        Mm[i] = mi;     /* in-place optimizer state */\n" +
            "        Vv[i] = vi;\n" +
            "        W[i]  = wi;     /* W updated IN PLACE — no out buffer */\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * Kernel — packed_gemv_offset (small-dim fallback for cuBLAS Dgemv).\n" +
            " *   out[i] = Σ_j P[off + i·cols + j] · U[j],  i in [0,rows).\n" +
            " * Layout matches _hx_k_softmax_rows: one block per output row\n" +
            " * (gridDim.x = rows), HX_RR_BLOCK threads stride across `cols`, then a\n" +
            " * single block-sum reduction. Reduction order is the SAME fixed tree as\n" +
            " * the softmax/ce kernels (warp-shfl → shared → re-reduce), NOT the\n" +
            " * cuBLAS-tiled order — so this path carries the matmul tolerance caveat\n" +
            " * (not bit-eq vs cuBLAS), same as the existing block-reduction kernels.\n" +
            " * Used only when `cols` is small (see HEXA_GEMV_CUBLAS_MIN_DIM gate in\n" +
            " * the host wrapper); at small dims the cuBLAS library dispatch cost\n" +
            " * dominates the FLOPs, so a plain on-device kernel is cheaper.\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_packed_gemv_offset(const double* __restrict__ P,\n" +
            "                                 int64_t off,\n" +
            "                                 const double* __restrict__ U,\n" +
            "                                 double* __restrict__ O,\n" +
            "                                 int64_t rows, int64_t cols) {\n" +
            "    __shared__ double smem[HX_RR_BLOCK / 32];\n" +
            "    int64_t r = (int64_t)blockIdx.x;\n" +
            "    if (r >= rows) return;\n" +
            "    const double* row = P + off + r * cols;\n" +
            "    double acc = 0.0;\n" +
            "    for (int64_t j = (int64_t)threadIdx.x; j < cols; j += blockDim.x) {\n" +
            "        acc += row[j] * U[j];\n" +
            "    }\n" +
            "    double total = _hx_block_sum(acc, smem);\n" +
            "    if (threadIdx.x == 0) O[r] = total;\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * HEXA-TRAIN-FLOOR M6 — fp32 dtype slice for packed_gemv_offset.\n" +
            " *   out[i] = Σ_j P[off + i·cols + j] · U[j],  computed in fp32.\n" +
            " *\n" +
            " * SAME layout / reduction shape as _hx_k_packed_gemv_offset (one block\n" +
            " * per output row, HX_RR_BLOCK threads stride `cols`, single block-sum),\n" +
            " * but the per-thread products + accumulator are `float` (fp32) instead\n" +
            " * of `double`. The device storage stays fp64 (_CudaFarrSlot.d_buf is\n" +
            " * `double*`); each operand is narrowed fp64→fp32 AT THE LOAD and the\n" +
            " * row dot-product reduces in fp32. The result is widened fp32→fp64 at\n" +
            " * the store so the host ABI (packed-double farr) is unchanged.\n" +
            " *\n" +
            " * Why this is the M4-identified lever (HEXA-TRAIN-FLOOR.md §M4): the\n" +
            " * trainer is fp64 COMPUTE-bound; the gemv contraction is the hot path.\n" +
            " * fp32 multiply-accumulate runs at the device's fp32 throughput\n" +
            " * (A100/5070: 32–64× the fp64 rate) — this kernel is the first slice\n" +
            " * that exercises that rate without touching the fp64 storage layout.\n" +
            " *\n" +
            " * ACCURACY CAVEAT (opt-in only): fp32 has a 24-bit mantissa vs fp64's\n" +
            " * 53-bit; the accumulator carries ~7 significant decimal digits. For a\n" +
            " * length-`cols` dot product the relative error grows ~cols·2^-24. This\n" +
            " * is mixed-precision training territory — it DOES perturb convergence\n" +
            " * and is therefore OFF BY DEFAULT (HEXA_TRAIN_DTYPE unset/`fp64` keeps\n" +
            " * the exact fp64 path). No bit-eq vs the fp64 reference is claimed; the\n" +
            " * caller opts in only when the fp32 throughput win outweighs the loss\n" +
            " * of mantissa bits (the M6→M7 measurement gate decides that per model).\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__device__ __forceinline__ float _hx_warp_sum_f(float v) {\n" +
            "    for (int offset = 16; offset > 0; offset >>= 1) {\n" +
            "        v += __shfl_down_sync(0xFFFFFFFFu, v, offset);\n" +
            "    }\n" +
            "    return v;\n" +
            "}\n" +
            "\n" +
            "__device__ __forceinline__ float _hx_block_sum_f(float v, float* smem) {\n" +
            "    int lane = threadIdx.x & 31;\n" +
            "    int wid  = threadIdx.x >> 5;\n" +
            "    v = _hx_warp_sum_f(v);\n" +
            "    if (lane == 0) smem[wid] = v;\n" +
            "    __syncthreads();\n" +
            "    int n_warps = (blockDim.x + 31) >> 5;\n" +
            "    if (wid == 0) {\n" +
            "        float w = (lane < n_warps) ? smem[lane] : 0.0f;\n" +
            "        w = _hx_warp_sum_f(w);\n" +
            "        if (lane == 0) smem[0] = w;\n" +
            "    }\n" +
            "    __syncthreads();\n" +
            "    return smem[0];\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_k_packed_gemv_offset_f32(const double* __restrict__ P,\n" +
            "                                 int64_t off,\n" +
            "                                 const double* __restrict__ U,\n" +
            "                                 double* __restrict__ O,\n" +
            "                                 int64_t rows, int64_t cols) {\n" +
            "    __shared__ float smem[HX_RR_BLOCK / 32];\n" +
            "    int64_t r = (int64_t)blockIdx.x;\n" +
            "    if (r >= rows) return;\n" +
            "    const double* row = P + off + r * cols;\n" +
            "    float acc = 0.0f;\n" +
            "    for (int64_t j = (int64_t)threadIdx.x; j < cols; j += blockDim.x) {\n" +
            "        /* narrow fp64→fp32 at load; multiply-accumulate in fp32. */\n" +
            "        acc += (float)row[j] * (float)U[j];\n" +
            "    }\n" +
            "    float total = _hx_block_sum_f(acc, smem);\n" +
            "    if (threadIdx.x == 0) O[r] = (double)total;  /* widen fp32→fp64 store */\n" +
            "}\n" +
            "\n" +
            "#endif /* __CUDACC__ — kernel bodies (compiled by nvcc only) */\n" +
            "\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * Host wrappers — match the extern decls in self/runtime.c §10941-10954\n" +
            " * (Phase B) and §11181-11200 (Phase B2). Signature: caller owns the\n" +
            " * pre-allocated out_id farr; we return 0 ok / -1 err.\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "\n" +
            "int _hx_cuda_farr_softmax_rows_gpu(int64_t x_id, int64_t R, int64_t C,\n" +
            "                                   int64_t out_id) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (R <= 0 || C <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] softmax_rows: bad shape R=%lld C=%lld\\n\",\n" +
            "                (long long)R, (long long)C);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, R * C) != 0) return -1;\n" +
            "    const double* X = g_slots[x_id].d_buf;\n" +
            "    double*       Y = g_slots[out_id].d_buf;\n" +
            "    dim3 grid((unsigned)R), block(HX_RR_BLOCK);\n" +
            "    _hx_k_softmax_rows<<<grid, block>>>(X, Y, R, C);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] softmax_rows launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, R * C);\n" +
            "#else\n" +
            "    (void)x_id; (void)R; (void)C; (void)out_id;\n" +
            "    fprintf(stderr, \"[cuda] softmax_rows: built without __CUDACC__ \"\n" +
            "                    \"(use nvcc -x cu)\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* ── ce_seed host wrapper (RFC gpu-resident-large-vocab-lmhead-loss).\n" +
            " * GPU-resident large-vocab lm-head CE loss + seed grad in ONE kernel.\n" +
            " * Mirrors _hx_cuda_farr_softmax_rows_gpu's contract: validate → H2D the\n" +
            " * two inputs (logits[R*V], targets[R]) → _ensure_dev_alloc_out for the\n" +
            " * two caller-allocated outputs (out_loss[R], out_dlogits[R*V]) → launch\n" +
            " * one block-per-row kernel → cudaDeviceSynchronize → D2H both outputs.\n" +
            " * The logits farr is the lm-head matmul output that STAYS device-\n" +
            " * resident (the RFC's whole point — no 78M H2D round-trip); _h2d() sees\n" +
            " * it DEVICE && !dirty_host and SKIPs the redundant copy (RFC 056 §6.1).\n" +
            " * loss is per-row (caller sums R values on host). Returns 0 ok / -1. */\n" +
            "int _hx_cuda_farr_ce_seed_gpu(int64_t logits_id, int64_t target_ids_id,\n" +
            "                              int64_t R, int64_t V,\n" +
            "                              int64_t out_loss_id, int64_t out_dlogits_id) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (R <= 0 || V <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] ce_seed: bad shape R=%lld V=%lld\\n\",\n" +
            "                (long long)R, (long long)V);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(logits_id) != 0)     return -1;\n" +
            "    if (_h2d(target_ids_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_loss_id, R) != 0)         return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_dlogits_id, R * V) != 0)  return -1;\n" +
            "    const double* L   = g_slots[logits_id].d_buf;\n" +
            "    const double* TGT = g_slots[target_ids_id].d_buf;\n" +
            "    double* OUT_LOSS  = g_slots[out_loss_id].d_buf;\n" +
            "    double* OUT_DL    = g_slots[out_dlogits_id].d_buf;\n" +
            "    dim3 grid((unsigned)R), block(HX_RR_BLOCK);\n" +
            "    _hx_k_ce_seed<<<grid, block>>>(L, TGT, OUT_LOSS, OUT_DL, R, V);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] ce_seed launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_loss_id, R) != 0)        return -1;\n" +
            "    return _d2h_out(out_dlogits_id, R * V);\n" +
            "#else\n" +
            "    (void)logits_id; (void)target_ids_id; (void)R; (void)V;\n" +
            "    (void)out_loss_id; (void)out_dlogits_id;\n" +
            "    fprintf(stderr, \"[cuda] ce_seed: built without __CUDACC__ \"\n" +
            "                    \"(use nvcc -x cu)\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* ────────────────────────────────────────────────────────────────────\n" +
            " * BC-ANIMA M3 (2026-05-28): seed-only CE gradient kernel (5-arg).\n" +
            " *\n" +
            " *   row r ∈ [0,R), softmax S[r,*] over columns C:\n" +
            " *     dlogits[r,c] = S[r,c] - onehot(c == target[r])\n" +
            " *\n" +
            " * Lighter sibling of _hx_k_ce_seed (which fuses loss + seed + softmax).\n" +
            " * Used when softmax is already computed via M2 farr_softmax_rows. Single\n" +
            " * pass — no reductions. One block per row; HX_RR_BLOCK threads stride C.\n" +
            " * ──────────────────────────────────────────────────────────────────── */\n" +
            "__global__ void _hx_k_ce_seed_only(const double* __restrict__ S,\n" +
            "                                   const double* __restrict__ TGT,\n" +
            "                                   double* __restrict__ DL,\n" +
            "                                   int64_t R, int64_t C) {\n" +
            "    int64_t r = blockIdx.x;\n" +
            "    if (r >= R) return;\n" +
            "    const double* sr = S + r * C;\n" +
            "    double*       dr = DL + r * C;\n" +
            "    int64_t tgt = (int64_t)(TGT[r] + (TGT[r] >= 0.0 ? 0.5 : -0.5));\n" +
            "    for (int64_t c = threadIdx.x; c < C; c += blockDim.x) {\n" +
            "        double p = sr[c];\n" +
            "        if (c == tgt) p -= 1.0;\n" +
            "        dr[c] = p;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ── BC-ANIMA M3 (2026-05-28): farr_ce_seed host wrapper.\n" +
            " * 5-arg seed-only CE gradient — softmax precomputed (anima M2). H2D\n" +
            " * the two inputs (softmax[R*C], targets[R]) → _ensure_dev_alloc_out\n" +
            " * for caller-allocated dlogits[R*C] → launch slim block-per-row kernel\n" +
            " * → cudaDeviceSynchronize → D2H dlogits. Returns 0 ok / -1. */\n" +
            "int _hx_cuda_farr_ce_seed(int64_t softmax_id, int64_t target_ids_id,\n" +
            "                          int64_t dlogits_id,\n" +
            "                          int64_t R, int64_t C) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (R <= 0 || C <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] ce_seed_only: bad shape R=%lld C=%lld\\n\",\n" +
            "                (long long)R, (long long)C);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(softmax_id) != 0)    return -1;\n" +
            "    if (_h2d(target_ids_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(dlogits_id, R * C) != 0) return -1;\n" +
            "    const double* S   = g_slots[softmax_id].d_buf;\n" +
            "    const double* TGT = g_slots[target_ids_id].d_buf;\n" +
            "    double*       DL  = g_slots[dlogits_id].d_buf;\n" +
            "    dim3 grid((unsigned)R), block(HX_RR_BLOCK);\n" +
            "    _hx_k_ce_seed_only<<<grid, block>>>(S, TGT, DL, R, C);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] ce_seed_only launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(dlogits_id, R * C);\n" +
            "#else\n" +
            "    (void)softmax_id; (void)target_ids_id; (void)dlogits_id;\n" +
            "    (void)R; (void)C;\n" +
            "    fprintf(stderr, \"[cuda] ce_seed_only: built without __CUDACC__ \"\n" +
            "                    \"(use nvcc -x cu)\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* ── causal_softmax_rows host wrapper (flame Phase 4-D-9, the 14th\n" +
            " * kernel — ADDITIVE; the 12 verified kernels + RFC 058 13th + all\n" +
            " * existing wrappers are UNTOUCHED). Mirrors _hx_cuda_farr_softmax_rows_\n" +
            " * gpu EXACTLY: validate → _h2d(x) → _ensure_dev_alloc_out(R*T) → launch\n" +
            " * → cudaDeviceSynchronize/cudaGetLastError → _d2h_out(R*T) → mark. The\n" +
            " * X buffer is R×T causal scores; Y[i*T+j] = softmax over [0,i+1) (the\n" +
            " * causal prefix), 0.0 for j ≥ i+1. Per-row reduction is the same\n" +
            " * deterministic _hx_block_max/_hx_block_sum tree as Kernel 1. */\n" +
            "int _hx_cuda_farr_causal_softmax_rows_gpu(int64_t x_id, int64_t R,\n" +
            "                                          int64_t T, int64_t out_id) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (R <= 0 || T <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] causal_softmax_rows: bad shape \"\n" +
            "                \"R=%lld T=%lld\\n\", (long long)R, (long long)T);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, R * T) != 0) return -1;\n" +
            "    const double* X = g_slots[x_id].d_buf;\n" +
            "    double*       Y = g_slots[out_id].d_buf;\n" +
            "    dim3 grid((unsigned)R), block(HX_RR_BLOCK);\n" +
            "    _hx_cuda_kern_causal_softmax_rows<<<grid, block>>>(X, Y, R, T);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] causal_softmax_rows launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, R * T);\n" +
            "#else\n" +
            "    (void)x_id; (void)R; (void)T; (void)out_id;\n" +
            "    fprintf(stderr, \"[cuda] causal_softmax_rows: built without __CUDACC__ \"\n" +
            "                    \"(use nvcc -x cu)\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_rmsnorm_rows_gpu(int64_t x_id, int64_t R, int64_t C,\n" +
            "                                   double eps, int64_t out_id) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (R <= 0 || C <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_rows: bad shape R=%lld C=%lld\\n\",\n" +
            "                (long long)R, (long long)C);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (!(eps >= 0.0)) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_rows: bad eps %g\\n\", eps);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, R * C) != 0) return -1;\n" +
            "    const double* X = g_slots[x_id].d_buf;\n" +
            "    double*       Y = g_slots[out_id].d_buf;\n" +
            "    dim3 grid((unsigned)R), block(HX_RR_BLOCK);\n" +
            "    _hx_k_rmsnorm_rows<<<grid, block>>>(X, Y, R, C, eps);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_rows launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, R * C);\n" +
            "#else\n" +
            "    (void)x_id; (void)R; (void)C; (void)eps; (void)out_id;\n" +
            "    fprintf(stderr, \"[cuda] rmsnorm_rows: built without __CUDACC__\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_rmsnorm_bwd_rows_gpu(int64_t x_id, int64_t dxn_id,\n" +
            "                                       int64_t R, int64_t C,\n" +
            "                                       int64_t out_id) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (R <= 0 || C <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_bwd: bad shape R=%lld C=%lld\\n\",\n" +
            "                (long long)R, (long long)C);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_h2d(dxn_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, R * C) != 0) return -1;\n" +
            "    const double* X   = g_slots[x_id].d_buf;\n" +
            "    const double* DXN = g_slots[dxn_id].d_buf;\n" +
            "    double*       O   = g_slots[out_id].d_buf;\n" +
            "    dim3 grid((unsigned)R), block(HX_RR_BLOCK);\n" +
            "    _hx_k_rmsnorm_bwd_rows<<<grid, block>>>(X, DXN, O, R, C);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_bwd launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, R * C);\n" +
            "#else\n" +
            "    (void)x_id; (void)dxn_id; (void)R; (void)C; (void)out_id;\n" +
            "    fprintf(stderr, \"[cuda] rmsnorm_bwd: built without __CUDACC__\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_adamw_step_gpu(int64_t w_id, int64_t m_id,\n" +
            "                                  int64_t v_id, int64_t g_id,\n" +
            "                                  int64_t n, double lr, double b1,\n" +
            "                                  double b2, double eps, double wd,\n" +
            "                                  int64_t step_t, int64_t out_id) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (n <= 0 || step_t < 1) {\n" +
            "        fprintf(stderr, \"[cuda] adamw_step: bad n=%lld step_t=%lld\\n\",\n" +
            "                (long long)n, (long long)step_t);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* H2D for ALL four operands. W/m/v get updated (in-place on device);\n" +
            "     * we then D2H W back to the CALLER's out buf and ALSO D2H m,v back\n" +
            "     * to their host bufs so the optimizer-state contract holds\n" +
            "     * (CPU oracle updates m,v in place on the host buffers). */\n" +
            "    if (_h2d(w_id) != 0) return -1;\n" +
            "    if (_h2d(m_id) != 0) return -1;\n" +
            "    if (_h2d(v_id) != 0) return -1;\n" +
            "    if (_h2d(g_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, n) != 0) return -1;\n" +
            "\n" +
            "    /* Compute c1 = 1 - β1^t, c2 = 1 - β2^t on host (deterministic,\n" +
            "     * matches CPU oracle's per-step repeated mul: see runtime.c\n" +
            "     * §11419-11422). */\n" +
            "    double b1t = 1.0, b2t = 1.0;\n" +
            "    for (int64_t e = 0; e < step_t; e++) { b1t *= b1; b2t *= b2; }\n" +
            "    double c1 = 1.0 - b1t;\n" +
            "    double c2 = 1.0 - b2t;\n" +
            "\n" +
            "    double* W  = g_slots[w_id].d_buf;\n" +
            "    double* Mm = g_slots[m_id].d_buf;\n" +
            "    double* Vv = g_slots[v_id].d_buf;\n" +
            "    const double* G = g_slots[g_id].d_buf;\n" +
            "    double* O  = g_slots[out_id].d_buf;\n" +
            "\n" +
            "    /* 1-D grid-stride: ~256 threads/block, blocks = min(1024, ceil(n/256)).\n" +
            "     * Cap at 1024 blocks to keep stride pattern compact + deterministic. */\n" +
            "    int block_sz = 256;\n" +
            "    int64_t want_blocks = (n + block_sz - 1) / block_sz;\n" +
            "    int grid_sz = (want_blocks > 1024) ? 1024 : (int)want_blocks;\n" +
            "    if (grid_sz < 1) grid_sz = 1;\n" +
            "\n" +
            "    _hx_k_adamw_step<<<grid_sz, block_sz>>>(W, Mm, Vv, G, O, n,\n" +
            "                                            lr, b1, b2, eps, wd, c1, c2);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] adamw_step launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Write back W (out_id) AND in-place-updated m, v (their own ids). */\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    if (_d2h(m_id) != 0)          return -1;\n" +
            "    if (_d2h(v_id) != 0)          return -1;\n" +
            "    return 0;\n" +
            "#else\n" +
            "    (void)w_id; (void)m_id; (void)v_id; (void)g_id;\n" +
            "    (void)n; (void)lr; (void)b1; (void)b2; (void)eps; (void)wd;\n" +
            "    (void)step_t; (void)out_id;\n" +
            "    fprintf(stderr, \"[cuda] adamw_step: built without __CUDACC__\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* In-place AdamW host wrapper — no fresh device output buffer; W is\n" +
            " * updated in place on its own device slot (out == W). H2D W/m/v/g,\n" +
            " * launch _hx_k_adamw_step_inplace, then D2H W AND m,v back to host\n" +
            " * (optimizer-state contract). Byte-eq to _hx_cuda_farr_adamw_step_gpu\n" +
            " * with out_id == w_id (same arithmetic, O ≡ W). Returns 0 ok / -1. */\n" +
            "int _hx_cuda_farr_adamw_step_inplace_gpu(int64_t w_id, int64_t m_id,\n" +
            "                                  int64_t v_id, int64_t g_id,\n" +
            "                                  int64_t n, double lr, double b1,\n" +
            "                                  double b2, double eps, double wd,\n" +
            "                                  int64_t step_t) {\n" +
            "#ifdef __CUDACC__\n" +
            "    if (n <= 0 || step_t < 1) {\n" +
            "        fprintf(stderr, \"[cuda] adamw_step_inplace: bad n=%lld step_t=%lld\\n\",\n" +
            "                (long long)n, (long long)step_t);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(w_id) != 0) return -1;\n" +
            "    if (_h2d(m_id) != 0) return -1;\n" +
            "    if (_h2d(v_id) != 0) return -1;\n" +
            "    if (_h2d(g_id) != 0) return -1;\n" +
            "\n" +
            "    double b1t = 1.0, b2t = 1.0;\n" +
            "    for (int64_t e = 0; e < step_t; e++) { b1t *= b1; b2t *= b2; }\n" +
            "    double c1 = 1.0 - b1t;\n" +
            "    double c2 = 1.0 - b2t;\n" +
            "\n" +
            "    double* W  = g_slots[w_id].d_buf;\n" +
            "    double* Mm = g_slots[m_id].d_buf;\n" +
            "    double* Vv = g_slots[v_id].d_buf;\n" +
            "    const double* G = g_slots[g_id].d_buf;\n" +
            "\n" +
            "    int block_sz = 256;\n" +
            "    int64_t want_blocks = (n + block_sz - 1) / block_sz;\n" +
            "    int grid_sz = (want_blocks > 1024) ? 1024 : (int)want_blocks;\n" +
            "    if (grid_sz < 1) grid_sz = 1;\n" +
            "\n" +
            "    _hx_k_adamw_step_inplace<<<grid_sz, block_sz>>>(W, Mm, Vv, G, n,\n" +
            "                                            lr, b1, b2, eps, wd, c1, c2);\n" +
            "    cudaError_t er = cudaDeviceSynchronize();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] adamw_step_inplace launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Write back the in-place-updated W, m, v to their host buffers. */\n" +
            "    if (_d2h(w_id) != 0) return -1;\n" +
            "    if (_d2h(m_id) != 0) return -1;\n" +
            "    if (_d2h(v_id) != 0) return -1;\n" +
            "    return 0;\n" +
            "#else\n" +
            "    (void)w_id; (void)m_id; (void)v_id; (void)g_id;\n" +
            "    (void)n; (void)lr; (void)b1; (void)b2; (void)eps; (void)wd;\n" +
            "    (void)step_t;\n" +
            "    fprintf(stderr, \"[cuda] adamw_step_inplace: built without __CUDACC__\\n\");\n" +
            "    return -1;\n" +
            "#endif\n" +
            "}\n" +
            "\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * matmul_t and outer — cuBLAS Dgemm reshape (RFC 041 §1, proven exact\n" +
            " * on real hardware for the outer case; same Dgemm path as Phase A\n" +
            " * for matmul_t — TOL_MATMUL ≈ 2e-9 inherited).\n" +
            " *\n" +
            " * Row-major→column-major trick recap (same as _hx_cuda_farr_matmul_gpu):\n" +
            " *   to compute row-major C[M,N] = A[M,K]·B[K,N] via column-major Dgemm,\n" +
            " *   call cublasDgemm(N,N, m=N, n=M, k=K, alpha, B_dev, ldb=N,\n" +
            " *                    A_dev, lda=K, beta, C_dev, ldc=N).\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "\n" +
            "/* matmul_t: Mᵀ·u = [C].  M row-major [R,C], u [R], out [C].\n" +
            " *\n" +
            " * View as the matmul of u-as-row-vector with M:  out[1,C] = u[1,R] · M[R,C].\n" +
            " * Plug into the row-major→col trick with M_outer=1, K=R, N=C:\n" +
            " *   cublasDgemm(N, N, m=C, n=1, k=R, alpha, M_dev, ldb=C, U_dev, lda=R,\n" +
            " *               beta, O_dev, ldc=C).\n" +
            " * Reduction order: cuBLAS-tiled (NOT the CPU c3_matvec_t r-outer/k-inner\n" +
            " * order) → reduction-tolerance applies. TOL_MATMUL ≈ 2e-9 (RFC 040 §2.2).\n" +
            " */\n" +
            "int _hx_cuda_farr_matmul_t_gpu(int64_t m_id, int64_t R, int64_t C,\n" +
            "                               int64_t u_id, int64_t out_id) {\n" +
            "    if (_ensure_cublas() != 0) return -1;\n" +
            "    if (R <= 0 || C <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] matmul_t: bad shape R=%lld C=%lld\\n\",\n" +
            "                (long long)R, (long long)C);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(m_id) != 0) return -1;\n" +
            "    if (_h2d(u_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, C) != 0) return -1;\n" +
            "\n" +
            "    double* M_dev = g_slots[m_id].d_buf;\n" +
            "    double* U_dev = g_slots[u_id].d_buf;\n" +
            "    double* O_dev = g_slots[out_id].d_buf;\n" +
            "    const double alpha = 1.0, beta = 0.0;\n" +
            "    /* row-major: out[1·C] = u[1·R] · M[R·C]\n" +
            "     * → cuBLAS Dgemm(N,N, m=C, n=1, k=R, alpha, M_dev, ldb=C, U_dev, lda=R,\n" +
            "     *                beta, O_dev, ldc=C) */\n" +
            "    cublasStatus_t st = cublasDgemm(g_cublas,\n" +
            "                                    CUBLAS_OP_N, CUBLAS_OP_N,\n" +
            "                                    (int)C, 1, (int)R,\n" +
            "                                    &alpha,\n" +
            "                                    M_dev, (int)C,\n" +
            "                                    U_dev, (int)R,\n" +
            "                                    &beta,\n" +
            "                                    O_dev, (int)C);\n" +
            "    if (st != CUBLAS_STATUS_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] cublasDgemm(matmul_t) failed: %d\\n\", (int)st);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, C);\n" +
            "}\n" +
            "\n" +
            "/* packed_gemv_offset: out[i] = Σ_j P[off + i·cols + j]·U[j], out[rows].\n" +
            " * P is a packed-double buffer; the [rows×cols] row-major sub-block\n" +
            " * starts at element `off`. anima mm_packed_gemv 1:1.\n" +
            " *\n" +
            " * cuBLAS sees the (row-major) sub-block P[off..] as a column-major\n" +
            " * [cols×rows] matrix A with lda=cols. Then A^T (= [rows×cols], our\n" +
            " * row-major block) times U[cols] gives out[rows]:\n" +
            " *   cublasDgemv(handle, CUBLAS_OP_T, m=cols, n=rows, alpha,\n" +
            " *               A=P_dev+off, lda=cols, U_dev, incx=1, beta,\n" +
            " *               O_dev, incy=1).\n" +
            " * Single dot-product per output row, cuBLAS-tiled reduction →\n" +
            " * TOL_MATMUL ≈ 2e-9 (same caveat as matmul_t). H2D P once (whole\n" +
            " * buffer), base+offset device pointer, D2H out. */\n" +
            "/* HEXA-TRAIN-FLOOR M6 — training compute dtype selector.\n" +
            " *   Returns 1 when HEXA_TRAIN_DTYPE selects an fp32 compute path, 0\n" +
            " *   otherwise (default = fp64, the exact-precision substrate). The env\n" +
            " *   var is read once per call (cheap; the value is process-stable in\n" +
            " *   practice). Accepted fp32 spellings: `fp32`, `f32`, `float`. Any\n" +
            " *   other value (incl. `fp64`/`f64`/`double`/unset) keeps fp64 — so an\n" +
            " *   unrecognized value NEVER silently downgrades precision (fail-safe\n" +
            " *   to the exact path). bf16/TensorCore lives in the runtime_bf16.c\n" +
            " *   sibling storage class (RFC 049) — this selector only gates the\n" +
            " *   in-place fp32 kernel slice; `bf16` here falls through to fp64. */\n" +
            "static int _hx_train_dtype_is_fp32(void) {\n" +
            "    const char* d = getenv(\"HEXA_TRAIN_DTYPE\");\n" +
            "    if (!d || !*d) return 0;\n" +
            "    if (strcmp(d, \"fp32\") == 0) return 1;\n" +
            "    if (strcmp(d, \"f32\")  == 0) return 1;\n" +
            "    if (strcmp(d, \"float\") == 0) return 1;\n" +
            "    return 0;  /* fp64 (default) / bf16 (sibling TU) / unknown → exact */\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_packed_gemv_offset_gpu(int64_t p_id, int64_t off,\n" +
            "                               int64_t rows, int64_t cols,\n" +
            "                               int64_t u_id, int64_t out_id) {\n" +
            "    if (rows <= 0 || cols <= 0 || off < 0) {\n" +
            "        fprintf(stderr, \"[cuda] packed_gemv_offset: bad off=%lld rows=%lld cols=%lld\\n\",\n" +
            "                (long long)off, (long long)rows, (long long)cols);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(p_id) != 0) return -1;\n" +
            "    if (_h2d(u_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, rows) != 0) return -1;\n" +
            "\n" +
            "    double* P_dev = g_slots[p_id].d_buf + off;\n" +
            "    double* U_dev = g_slots[u_id].d_buf;\n" +
            "    double* O_dev = g_slots[out_id].d_buf;\n" +
            "#ifdef __CUDACC__\n" +
            "    /* HEXA-TRAIN-FLOOR M6 — fp32 dtype slice (opt-in). When\n" +
            "     * HEXA_TRAIN_DTYPE selects fp32, run the fp32-accumulating on-device\n" +
            "     * gemv kernel: it narrows the fp64 device operands to fp32 at load\n" +
            "     * and reduces in fp32, exercising the device's fp32 throughput (the\n" +
            "     * M4-identified fp64-compute-bound lever). Independent of the cuBLAS\n" +
            "     * min-dim sync gate below — fp32 is a COMPUTE-precision choice, not a\n" +
            "     * dispatch-cost one. NOT bit-eq vs fp64 (mantissa loss); default\n" +
            "     * (unset/fp64) keeps the exact fp64 path unchanged. */\n" +
            "    if (_hx_train_dtype_is_fp32()) {\n" +
            "        dim3 grid_f((unsigned)rows), block_f(HX_RR_BLOCK);\n" +
            "        _hx_k_packed_gemv_offset_f32<<<grid_f, block_f>>>(\n" +
            "            g_slots[p_id].d_buf, off, U_dev, O_dev, rows, cols);\n" +
            "        cudaError_t fer = cudaDeviceSynchronize();\n" +
            "        if (fer != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] packed_gemv_offset fp32 kernel failed: %s\\n\",\n" +
            "                    cudaGetErrorString(fer));\n" +
            "            return -1;\n" +
            "        }\n" +
            "        return _d2h_out(out_id, rows);\n" +
            "    }\n" +
            "    /* d-threshold gate (hexa-lang #1354): at small contraction dim `cols`\n" +
            "     * the cuBLAS Dgemv library-dispatch cost dominates the FLOPs and the\n" +
            "     * H2D/D2H sync round-trip outweighs the saved compute (~3x slowdown\n" +
            "     * at d=64). Below threshold, use the plain on-device block-reduction\n" +
            "     * kernel; large `cols` keeps cuBLAS (regression-free). Override via\n" +
            "     * HEXA_GEMV_CUBLAS_MIN_DIM (default 128, conservative). */\n" +
            "    long min_dim = 128;\n" +
            "    const char* _md = getenv(\"HEXA_GEMV_CUBLAS_MIN_DIM\");\n" +
            "    if (_md && *_md) { long v = atol(_md); if (v > 0) min_dim = v; }\n" +
            "    if (cols < min_dim) {\n" +
            "        dim3 grid((unsigned)rows), block(HX_RR_BLOCK);\n" +
            "        _hx_k_packed_gemv_offset<<<grid, block>>>(g_slots[p_id].d_buf, off,\n" +
            "                                                  U_dev, O_dev, rows, cols);\n" +
            "        cudaError_t ker = cudaDeviceSynchronize();\n" +
            "        if (ker != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] packed_gemv_offset kernel failed: %s\\n\",\n" +
            "                    cudaGetErrorString(ker));\n" +
            "            return -1;\n" +
            "        }\n" +
            "        return _d2h_out(out_id, rows);\n" +
            "    }\n" +
            "#endif\n" +
            "    if (_ensure_cublas() != 0) return -1;\n" +
            "    const double alpha = 1.0, beta = 0.0;\n" +
            "    cublasStatus_t st = cublasDgemv(g_cublas, CUBLAS_OP_T,\n" +
            "                                    (int)cols, (int)rows,\n" +
            "                                    &alpha,\n" +
            "                                    P_dev, (int)cols,\n" +
            "                                    U_dev, 1,\n" +
            "                                    &beta,\n" +
            "                                    O_dev, 1);\n" +
            "    if (st != CUBLAS_STATUS_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] cublasDgemv(packed_gemv_offset) failed: %d\\n\", (int)st);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, rows);\n" +
            "}\n" +
            "\n" +
            "/* outer: u⊗v = [R·C].  u [R], v [C], out row-major [R,C].\n" +
            " *\n" +
            " * out[R,C] = u[R,1] · v[1,C]. Plug into the trick with M_outer=R, K=1, N=C:\n" +
            " *   cublasDgemm(N, N, m=C, n=R, k=1, alpha, V_dev, ldb=C, U_dev, lda=1,\n" +
            " *               beta, O_dev, ldc=C).\n" +
            " * K=1 → SINGLE product term per output cell → ZERO reduction →\n" +
            " * BIT-EXACT vs CPU c3_outer (F-RFC041-OUTER-EXACT demands |Δ| = 0).\n" +
            " */\n" +
            "int _hx_cuda_farr_outer_gpu(int64_t u_id, int64_t v_id,\n" +
            "                            int64_t R, int64_t C, int64_t out_id) {\n" +
            "    if (_ensure_cublas() != 0) return -1;\n" +
            "    if (R <= 0 || C <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] outer: bad shape R=%lld C=%lld\\n\",\n" +
            "                (long long)R, (long long)C);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(u_id) != 0) return -1;\n" +
            "    if (_h2d(v_id) != 0) return -1;\n" +
            "    if (_ensure_dev_alloc_out(out_id, R * C) != 0) return -1;\n" +
            "\n" +
            "    double* U_dev = g_slots[u_id].d_buf;\n" +
            "    double* V_dev = g_slots[v_id].d_buf;\n" +
            "    double* O_dev = g_slots[out_id].d_buf;\n" +
            "    const double alpha = 1.0, beta = 0.0;\n" +
            "    cublasStatus_t st = cublasDgemm(g_cublas,\n" +
            "                                    CUBLAS_OP_N, CUBLAS_OP_N,\n" +
            "                                    (int)C, (int)R, 1,\n" +
            "                                    &alpha,\n" +
            "                                    V_dev, (int)C,\n" +
            "                                    U_dev, 1,\n" +
            "                                    &beta,\n" +
            "                                    O_dev, (int)C);\n" +
            "    if (st != CUBLAS_STATUS_SUCCESS) {\n" +
            "        fprintf(stderr, \"[cuda] cublasDgemm(outer) failed: %d\\n\", (int)st);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    return _d2h_out(out_id, R * C);\n" +
            "}\n" +
            "\n" +
            "/* ══════════════════════════════════════════════════════════════════\n" +
            " * RFC 041 Phase B — elementwise CUDA kernels (5 ops)\n" +
            " *\n" +
            " *   _hx_cuda_farr_add_gpu        C[i] = A[i] + B[i]\n" +
            " *   _hx_cuda_farr_scale_gpu      Y[i] = α · X[i]\n" +
            " *   _hx_cuda_farr_mul_gpu        C[i] = A[i] · B[i]   (Hadamard)\n" +
            " *   _hx_cuda_farr_silu_gpu       Y[i] = X[i] · σ(X[i])\n" +
            " *   _hx_cuda_farr_silu_grad_gpu  Y[i] = σ(X[i]) · (1 + X[i] · (1 − σ(X[i])))\n" +
            " *\n" +
            " * Math contract — bit-identical to the CPU oracles\n" +
            " * (`self/runtime.c` `_hx_farr_{add,scale,mul,silu,silu_grad}_cpu`):\n" +
            " *   - add / scale / mul: no cross-thread reduction → falsifier demands\n" +
            " *     `|Δ| = 0` exact vs the CPU loop (F-RFC041-ADD-EXACT,\n" +
            " *     -SCALE-EXACT, -MUL-EXACT).\n" +
            " *   - silu / silu_grad: per-element transcendental (`exp` in fp64);\n" +
            " *     tolerance is the f64 `exp` ULP — `TOL_ELEM` per RFC 041\n" +
            " *     §\"Falsifier battery\" (F-RFC041-SILU-EQ, -SILU-GRAD-EQ).\n" +
            " *\n" +
            " * ABI — each host wrapper matches the existing `extern int _hx_cuda_*`\n" +
            " * forward-decl in `self/runtime.c` (lines 10950-10953, 11188-11192).\n" +
            " * Output farr_id is caller-allocated (host-side `hexa_farr_zeros`); this\n" +
            " * TU H2D's inputs, ensures the device output slot is sized, launches the\n" +
            " * kernel on the default stream, D2H's the result back, and marks the\n" +
            " * output entry MIRRORED/clean — mirrors the Phase A `_hx_cuda_farr_matmul_gpu`\n" +
            " * residence protocol.\n" +
            " *\n" +
            " * Determinism — 1-D grid-stride elementwise; no atomics, no cross-thread\n" +
            " * reduction; the output for thread `i` is a pure function of input[i]\n" +
            " * (and α for scale). Hence run-to-run byte-identical\n" +
            " * (F-RFC041-DETERMINISM extends trivially here).\n" +
            " *\n" +
            " * Honest caveats:\n" +
            " *   - `exp()` device-side resolves to the CUDA math device library\n" +
            " *     fp64 `exp` (matches host libm fp64 `exp` to within 1 ULP per the\n" +
            " *     CUDA math API contract; the silu falsifier framing accounts for\n" +
            " *     this — `TOL_ELEM`, not bit-exact).\n" +
            " *   - No tensor-core / mixed-precision path here; this is the strict\n" +
            " *     fp64 elementwise reference. A bf16 / fp16 variant is RFC 044+/049.\n" +
            " *   - Host wrappers compile only under `#ifdef HEXA_CUDA` (Mac no-CUDA\n" +
            " *     build is unchanged — the wrapper symbols are simply absent;\n" +
            " *     `self/runtime.c`'s `hexa_farr_*_gpu` dispatcher already returns\n" +
            " *     -1 from the CUDA branch when the symbol isn't wired by the\n" +
            " *     caller path, preserving the F-RFC041-NO-CUDA-FALLBACK contract).\n" +
            " *\n" +
            " * Kernel launch geometry — block=256, grid=min((n+255)/256, 65535).\n" +
            " * Grid-stride loop covers any n (no upper bound from grid cap).\n" +
            " *\n" +
            " * The `__global__` kernels and `cudaLaunchKernel`-style `<<<...>>>`\n" +
            " * launch syntax require the TU to be compiled with nvcc (CUDA C++) or\n" +
            " * with clang's `-x cuda --cuda-path=...` mode. The build-system rename\n" +
            " * `runtime_cuda.c` → `runtime_cuda.cu` (or nvcc `-x cu`) is the\n" +
            " * concern of Phase 4-D-5-3 (CUDA-host link verify). This TU stays\n" +
            " * `*.c` for the no-CUDA path — every existing build remains\n" +
            " * byte-identical when HEXA_CUDA is undefined (the entire Phase B\n" +
            " * elementwise block below is inside `#ifdef HEXA_CUDA`).\n" +
            " * ══════════════════════════════════════════════════════════════════ */\n" +
            "\n" +
            "#ifdef HEXA_CUDA\n" +
            "\n" +
            "/* Default 1-D launch geometry. 256 threads/block balances occupancy on\n" +
            " * SM 7.0+ (V100/A100/H100) without wasting SM resources on the simple\n" +
            " * elementwise body; grid is capped at 65535 blocks (well under any\n" +
            " * device's gridDim.x max — 2^31-1 on SM 3.0+, but 65535 fits the\n" +
            " * grid-stride loop naturally and avoids over-subscription for small n).\n" +
            " */\n" +
            "#define _HX_CUDA_ELEM_BLOCK 256\n" +
            "#define _HX_CUDA_ELEM_MAX_GRID 65535\n" +
            "\n" +
            "static int _hx_cuda_elem_grid(int64_t n) {\n" +
            "    int64_t blocks = (n + (_HX_CUDA_ELEM_BLOCK - 1)) / _HX_CUDA_ELEM_BLOCK;\n" +
            "    if (blocks < 1) blocks = 1;\n" +
            "    if (blocks > _HX_CUDA_ELEM_MAX_GRID) blocks = _HX_CUDA_ELEM_MAX_GRID;\n" +
            "    return (int)blocks;\n" +
            "}\n" +
            "\n" +
            "/* Ensure the device-side slot for `id` has an allocated buffer of `len`\n" +
            " * doubles. Re-allocs if size changed. Returns 0 ok / -1 err. */\n" +
            "static int _ensure_dev_buf(int64_t id, int64_t len) {\n" +
            "    if (id < 0 || len <= 0) return -1;\n" +
            "    if (_ensure_slot_cap(id) != 0) return -1;\n" +
            "    _CudaFarrSlot* s = &g_slots[id];\n" +
            "    if (!s->d_buf || s->len != len) {\n" +
            "        if (s->d_buf) cudaFree(s->d_buf);\n" +
            "        cudaError_t er = cudaMalloc((void**)&s->d_buf,\n" +
            "                                    (size_t)len * sizeof(double));\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] cudaMalloc(%lld doubles) failed: %s\\n\",\n" +
            "                    (long long)len, cudaGetErrorString(er));\n" +
            "            s->d_buf = NULL; s->len = 0;\n" +
            "            return -1;\n" +
            "        }\n" +
            "        s->len = len;\n" +
            "    }\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* D2H copy `len` doubles from device slot `id` to its host buf, then\n" +
            " * mark MIRRORED/clean. Returns 0 ok / -1 err.\n" +
            " * (Agent #25 Phase B elementwise variant with bounds checks; the Phase B\n" +
            " *  reduction code uses the simpler `_d2h_out` at line 403. Renamed here\n" +
            " *  to avoid redefinition.) */\n" +
            "static int _d2h_out_elem(int64_t id, int64_t len) {\n" +
            "    if (id < 0 || id >= _hx_farr_count) return -1;\n" +
            "    if (id >= g_slot_cap)               return -1;\n" +
            "    HexaFarrEntry* e = &_hx_farr_table[id];\n" +
            "    _CudaFarrSlot* s = &g_slots[id];\n" +
            "    if (!e->buf || !s->d_buf || e->len < len || s->len < len) return -1;\n" +
            "    /* RFC 056 §6.1/§6.4 D2H-defer — same contract as _d2h_out. Default\n" +
            "     * FORGE_OUT_HOST_NOW = byte-identical to the verified substrate. */\n" +
            "    if (g_forge_out_disposition == FORGE_OUT_DEVICE_KEEP) {\n" +
            "        e->d_buf      = (void*)s->d_buf;\n" +
            "        e->loc        = FARR_DEVICE;\n" +
            "        e->dirty_host = 1;\n" +
            "        e->dirty_dev  = 1;\n" +
            "        return 0;\n" +
            "    }\n" +
            "    cudaError_t er = cudaMemcpy(e->buf, s->d_buf,\n" +
            "                                (size_t)len * sizeof(double),\n" +
            "                                cudaMemcpyDeviceToHost);\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] cudaMemcpy elem D2H failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    e->d_buf      = (void*)s->d_buf;\n" +
            "    e->loc        = FARR_MIRRORED;\n" +
            "    e->dirty_host = 0;\n" +
            "    e->dirty_dev  = 0;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* ── __global__ kernels (1-D grid-stride, fp64) ────────────────────── */\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_add(const double* __restrict__ A,\n" +
            "                                  const double* __restrict__ B,\n" +
            "                                  double* __restrict__ C,\n" +
            "                                  int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        C[i] = A[i] + B[i];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_scale(const double* __restrict__ X,\n" +
            "                                    double alpha,\n" +
            "                                    double* __restrict__ Y,\n" +
            "                                    int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        Y[i] = alpha * X[i];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_mul(const double* __restrict__ A,\n" +
            "                                  const double* __restrict__ B,\n" +
            "                                  double* __restrict__ C,\n" +
            "                                  int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        C[i] = A[i] * B[i];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* σ(x) = 1 / (1 + exp(-x)), fp64 device math. Matches the CPU\n" +
            " * `_hx_sigmoid_d` (host libm `exp`) to within the CUDA fp64 `exp` ULP. */\n" +
            "__device__ __forceinline__ double _hx_cuda_sigmoid_d(double x) {\n" +
            "    return 1.0 / (1.0 + exp(-x));\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_silu(const double* __restrict__ X,\n" +
            "                                   double* __restrict__ Y,\n" +
            "                                   int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        double xi = X[i];\n" +
            "        Y[i] = xi * _hx_cuda_sigmoid_d(xi);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* silu'(x) = σ(x) · (1 + x · (1 − σ(x))). Mirrors CPU `_hx_farr_silu_grad_cpu`\n" +
            " * (`self/runtime.c` §11314-11332) — same algebraic form, same single\n" +
            " * `exp` call per element. */\n" +
            "__global__ void _hx_cuda_kern_silu_grad(const double* __restrict__ X,\n" +
            "                                        double* __restrict__ Y,\n" +
            "                                        int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        double xi = X[i];\n" +
            "        double s  = _hx_cuda_sigmoid_d(xi);\n" +
            "        Y[i] = s * (1.0 + xi * (1.0 - s));\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ── RoPE kernels (RFC 041 Phase B completion, 2026-05-17) ──────────\n" +
            " *\n" +
            " * Rotary position embedding. The flame decoder block (RFC 043,\n" +
            " * stdlib/flame/decoder_block_lib.hexa §3 fwd / §3rev bwd; CPU reference\n" +
            " * tool/flame_phase4d6_block_{fwd,bwd}_primitive.c) consumes PRECOMPUTED\n" +
            " * cos/sin tables — the kernel does NOT recompute angles.\n" +
            " *\n" +
            " * Layout — tensor T_buf is row-major [T · nheads · hd]; the row for\n" +
            " * position t, head hh starts at (t·nheads + hh)·hd. cos/sin are\n" +
            " * row-major [T · hd], indexed bse + c with bse = t·hd. `half = hd/2`.\n" +
            " *\n" +
            " * Forward (mirrors fwd_primitive.c lines 162-167):\n" +
            " *   rh_c   = (c < half) ? -x[row+half+c] : x[row+c-half]\n" +
            " *   out[c] = x[row+c]·cos[bse+c] + rh_c·sin[bse+c]\n" +
            " *\n" +
            " * Backward — inverse rotation (mirrors bwd_primitive.c lines 322-327):\n" +
            " *   gs   = (c < half) ?  dx[row+half+c]·sin[bse+half+c]\n" +
            " *                     : -dx[row+c-half]·sin[bse+c-half]\n" +
            " *   out[c] = dx[row+c]·cos[bse+c] + gs\n" +
            " *\n" +
            " * Each output element is a pure function of TWO input-row elements\n" +
            " * (index c and c±half) plus cos/sin — NO cross-element reduction. A\n" +
            " * thread-per-element kernel reading from a SEPARATE input buffer is\n" +
            " * therefore BIT-EXACT vs the CPU scratch-buffer loop: same two\n" +
            " * fp64 products + one add, no reordering (F-RFC041-ROPE-EXACT,\n" +
            " * F-RFC041-ROPE-BWD-EXACT demand |Δ| = 0).\n" +
            " *\n" +
            " * 1-D grid-stride over the flat index e ∈ [0, T·nheads·hd). For each e\n" +
            " * we recover t = e/(nheads·hd), c = e mod hd, and the row base.\n" +
            " */\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_rope_fwd(const double* __restrict__ X,\n" +
            "                                       const double* __restrict__ COS,\n" +
            "                                       const double* __restrict__ SIN,\n" +
            "                                       double* __restrict__ Y,\n" +
            "                                       int64_t T, int64_t nheads,\n" +
            "                                       int64_t hd) {\n" +
            "    int64_t total  = T * nheads * hd;\n" +
            "    int64_t half   = hd / 2;\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < total; i += stride) {\n" +
            "        int64_t c   = i % hd;\n" +
            "        int64_t row = i - c;             /* (t·nheads+hh)·hd */\n" +
            "        int64_t t   = i / (nheads * hd);\n" +
            "        int64_t bse = t * hd;\n" +
            "        double rh_c = (c < half)\n" +
            "            ? (0.0 - X[row + half + c])\n" +
            "            : X[row + c - half];\n" +
            "        /* __dmul_rn/__dadd_rn: explicit round-to-nearest, no FMA\n" +
            "         * contraction. nvcc device default (--fmad=true) would fuse\n" +
            "         * a*b+c*d into one fma() (1 rounding); the verified flame\n" +
            "         * reference nn_rope_apply_fwd (and the CPU fallback, pinned\n" +
            "         * by #pragma STDC FP_CONTRACT OFF, commit c0789e05) does 2\n" +
            "         * roundings. The RoPE GPU byte-eq oracle measured the fused\n" +
            "         * form diverging max|Δ|=4.441e-16 — this conforms the kernel\n" +
            "         * to the reference's rounding (F-RFC041-ROPE-EXACT |Δ|=0). */\n" +
            "        Y[i] = __dadd_rn(__dmul_rn(X[row + c], COS[bse + c]),\n" +
            "                         __dmul_rn(rh_c, SIN[bse + c]));\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_rope_bwd(const double* __restrict__ DX,\n" +
            "                                       const double* __restrict__ COS,\n" +
            "                                       const double* __restrict__ SIN,\n" +
            "                                       double* __restrict__ Y,\n" +
            "                                       int64_t T, int64_t nheads,\n" +
            "                                       int64_t hd) {\n" +
            "    int64_t total  = T * nheads * hd;\n" +
            "    int64_t half   = hd / 2;\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < total; i += stride) {\n" +
            "        int64_t c   = i % hd;\n" +
            "        int64_t row = i - c;\n" +
            "        int64_t t   = i / (nheads * hd);\n" +
            "        int64_t bse = t * hd;\n" +
            "        /* __dmul_rn/__dadd_rn — no FMA contraction; conform to the\n" +
            "         * non-contracted reference (see fwd kernel note + c0789e05). */\n" +
            "        double gs = (c < half)\n" +
            "            ? __dmul_rn(DX[row + half + c], SIN[bse + half + c])\n" +
            "            : (0.0 - __dmul_rn(DX[row + c - half], SIN[bse + c - half]));\n" +
            "        Y[i] = __dadd_rn(__dmul_rn(DX[row + c], COS[bse + c]), gs);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ── Transpose-scatter kernel (RFC 058 §5.1, 13th forge kernel) ──────\n" +
            " *\n" +
            " * Pure index permutation: src (rows×cols, row-major) → dst transposed\n" +
            " * (cols×rows, row-major) at byte-offset dst_off:\n" +
            " *\n" +
            " *   dst[dst_off + c*rows + r] = src[r*cols + c]\n" +
            " *\n" +
            " * ZERO floating-point operations — a `double` is copied bit-for-bit\n" +
            " * from one slot to another, no add / mul / fma / rounding. The output\n" +
            " * is a reindexing of the input bits, so byte-equality vs the CPU host\n" +
            " * transpose loop `Y[Y_off + t*d_out + r] = C[r*T + t]` is mathematically\n" +
            " * trivial (no accumulation order, no fp ULP — F-RFC058-KERNEL-BYTEEQ\n" +
            " * |Δ|=0 by construction; the d768 GPU fire confirms it empirically).\n" +
            " *\n" +
            " * The flat thread index e ∈ [0, rows*cols) decomposes as r = e/cols,\n" +
            " * c = e%cols — the SAME (r,c) the CPU loop visits (CPU iterates r outer,\n" +
            " * c inner over the *transposed* read C[r*T+t]; here src has rows=d_out,\n" +
            " * cols=T so r∈[0,d_out), c∈[0,T) and dst[dst_off+c*rows+r] is exactly\n" +
            " * Y[Y_off + t*d_out + r] with t=c). No cross-element dependency, so a\n" +
            " * thread-per-element grid-stride kernel is order-independent and exact.\n" +
            " *\n" +
            " * dst is NOT a fresh buffer — it is Bc, populated slab-by-slab across\n" +
            " * projections. Only the [dst_off, dst_off+rows*cols) range is written;\n" +
            " * the host wrapper H2D-uploads dst's current contents first so untouched\n" +
            " * regions are preserved. The 12 verified kernels above are UNTOUCHED —\n" +
            " * this is purely additive (RFC 058 §1, g_forge_verify_oracle 12→13). */\n" +
            "__global__ void _hx_cuda_kern_transpose_scatter(const double* __restrict__ src,\n" +
            "                                                double* __restrict__ dst,\n" +
            "                                                int64_t rows, int64_t cols,\n" +
            "                                                int64_t dst_off) {\n" +
            "    int64_t total  = rows * cols;\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < total; i += stride) {\n" +
            "        int64_t r = i / cols;\n" +
            "        int64_t c = i % cols;\n" +
            "        dst[dst_off + c * rows + r] = src[r * cols + c];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* ── Host wrappers (extern surface — match runtime.c forward-decls) ──\n" +
            " * Each: validate → H2D inputs → ensure output device buf sized → launch\n" +
            " * → cudaGetLastError → D2H output → mark MIRRORED/clean. Returns 0 ok /\n" +
            " * -1 err with a one-line stderr message (no silent fallback). */\n" +
            "\n" +
            "int _hx_cuda_farr_add_gpu(int64_t a_id, int64_t b_id,\n" +
            "                          int64_t n, int64_t out_id) {\n" +
            "    if (a_id < 0 || b_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] add: bad ids %lld %lld %lld\\n\",\n" +
            "                (long long)a_id, (long long)b_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] add: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (a_id >= _hx_farr_count || b_id >= _hx_farr_count ||\n" +
            "        out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] add: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[a_id].len < n || _hx_farr_table[b_id].len < n ||\n" +
            "        _hx_farr_table[out_id].len < n) {\n" +
            "        fprintf(stderr, \"[cuda] add: host len < n\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(a_id) != 0) return -1;\n" +
            "    if (_h2d(b_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, n) != 0) return -1;\n" +
            "    double* A = g_slots[a_id].d_buf;\n" +
            "    double* B = g_slots[b_id].d_buf;\n" +
            "    double* C = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(n);\n" +
            "    _hx_cuda_kern_add<<<grid, _HX_CUDA_ELEM_BLOCK>>>(A, B, C, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] add launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_scale_gpu(int64_t x_id, double alpha,\n" +
            "                            int64_t n, int64_t out_id) {\n" +
            "    if (x_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] scale: bad ids %lld %lld\\n\",\n" +
            "                (long long)x_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] scale: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (x_id >= _hx_farr_count || out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] scale: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[x_id].len < n || _hx_farr_table[out_id].len < n) {\n" +
            "        fprintf(stderr, \"[cuda] scale: host len < n\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, n) != 0) return -1;\n" +
            "    double* X = g_slots[x_id].d_buf;\n" +
            "    double* Y = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(n);\n" +
            "    _hx_cuda_kern_scale<<<grid, _HX_CUDA_ELEM_BLOCK>>>(X, alpha, Y, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] scale launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_mul_gpu(int64_t a_id, int64_t b_id,\n" +
            "                          int64_t n, int64_t out_id) {\n" +
            "    if (a_id < 0 || b_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] mul: bad ids %lld %lld %lld\\n\",\n" +
            "                (long long)a_id, (long long)b_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] mul: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (a_id >= _hx_farr_count || b_id >= _hx_farr_count ||\n" +
            "        out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] mul: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[a_id].len < n || _hx_farr_table[b_id].len < n ||\n" +
            "        _hx_farr_table[out_id].len < n) {\n" +
            "        fprintf(stderr, \"[cuda] mul: host len < n\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(a_id) != 0) return -1;\n" +
            "    if (_h2d(b_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, n) != 0) return -1;\n" +
            "    double* A = g_slots[a_id].d_buf;\n" +
            "    double* B = g_slots[b_id].d_buf;\n" +
            "    double* C = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(n);\n" +
            "    _hx_cuda_kern_mul<<<grid, _HX_CUDA_ELEM_BLOCK>>>(A, B, C, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] mul launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_silu_gpu(int64_t x_id, int64_t n, int64_t out_id) {\n" +
            "    if (x_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] silu: bad ids %lld %lld\\n\",\n" +
            "                (long long)x_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] silu: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (x_id >= _hx_farr_count || out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] silu: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[x_id].len < n || _hx_farr_table[out_id].len < n) {\n" +
            "        fprintf(stderr, \"[cuda] silu: host len < n\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, n) != 0) return -1;\n" +
            "    double* X = g_slots[x_id].d_buf;\n" +
            "    double* Y = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(n);\n" +
            "    _hx_cuda_kern_silu<<<grid, _HX_CUDA_ELEM_BLOCK>>>(X, Y, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] silu launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_silu_grad_gpu(int64_t x_id, int64_t n, int64_t out_id) {\n" +
            "    if (x_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] silu_grad: bad ids %lld %lld\\n\",\n" +
            "                (long long)x_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] silu_grad: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (x_id >= _hx_farr_count || out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] silu_grad: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[x_id].len < n || _hx_farr_table[out_id].len < n) {\n" +
            "        fprintf(stderr, \"[cuda] silu_grad: host len < n\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, n) != 0) return -1;\n" +
            "    double* X = g_slots[x_id].d_buf;\n" +
            "    double* Y = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(n);\n" +
            "    _hx_cuda_kern_silu_grad<<<grid, _HX_CUDA_ELEM_BLOCK>>>(X, Y, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] silu_grad launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* ── RoPE host wrappers (RFC 041 Phase B completion) ────────────────\n" +
            " * Signature: (t_id, cos_id, sin_id, T, nheads, hd, out_id). Caller\n" +
            " * (self/runtime.c) has pre-allocated out_id via hexa_farr_zeros with\n" +
            " * len = T·nheads·hd. Validate → H2D the 3 inputs → ensure output\n" +
            " * device buffer → launch the per-element kernel → D2H → MIRRORED.\n" +
            " * `out` is a fresh buffer (separate from the input) so the rotation\n" +
            " * reads originals — the byte-exact contract holds. */\n" +
            "\n" +
            "static int _hx_cuda_rope_common(int64_t t_id, int64_t cos_id,\n" +
            "                                int64_t sin_id, int64_t T,\n" +
            "                                int64_t nheads, int64_t hd,\n" +
            "                                int64_t out_id, int is_bwd) {\n" +
            "    const char* tag = is_bwd ? \"rope_bwd\" : \"rope\";\n" +
            "    if (T <= 0 || nheads <= 0 || hd <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] %s: bad shape T=%lld nheads=%lld hd=%lld\\n\",\n" +
            "                tag, (long long)T, (long long)nheads, (long long)hd);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if ((hd & 1) != 0) {\n" +
            "        fprintf(stderr, \"[cuda] %s: hd=%lld must be even\\n\",\n" +
            "                tag, (long long)hd);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (t_id < 0 || cos_id < 0 || sin_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] %s: bad ids %lld %lld %lld %lld\\n\",\n" +
            "                tag, (long long)t_id, (long long)cos_id,\n" +
            "                (long long)sin_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (t_id >= _hx_farr_count || cos_id >= _hx_farr_count ||\n" +
            "        sin_id >= _hx_farr_count || out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] %s: id out of range\\n\", tag);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int64_t total = T * nheads * hd;\n" +
            "    if (_hx_farr_table[t_id].len < total ||\n" +
            "        _hx_farr_table[out_id].len < total) {\n" +
            "        fprintf(stderr, \"[cuda] %s: tensor host len < T*nheads*hd %lld\\n\",\n" +
            "                tag, (long long)total);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[cos_id].len < T * hd ||\n" +
            "        _hx_farr_table[sin_id].len < T * hd) {\n" +
            "        fprintf(stderr, \"[cuda] %s: cos/sin host len < T*hd %lld\\n\",\n" +
            "                tag, (long long)(T * hd));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(t_id) != 0)   return -1;\n" +
            "    if (_h2d(cos_id) != 0) return -1;\n" +
            "    if (_h2d(sin_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, total) != 0) return -1;\n" +
            "    const double* X   = g_slots[t_id].d_buf;\n" +
            "    const double* COS = g_slots[cos_id].d_buf;\n" +
            "    const double* SIN = g_slots[sin_id].d_buf;\n" +
            "    double*       Y   = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(total);\n" +
            "    if (is_bwd) {\n" +
            "        _hx_cuda_kern_rope_bwd<<<grid, _HX_CUDA_ELEM_BLOCK>>>(\n" +
            "            X, COS, SIN, Y, T, nheads, hd);\n" +
            "    } else {\n" +
            "        _hx_cuda_kern_rope_fwd<<<grid, _HX_CUDA_ELEM_BLOCK>>>(\n" +
            "            X, COS, SIN, Y, T, nheads, hd);\n" +
            "    }\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] %s launch failed: %s\\n\",\n" +
            "                tag, cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, total) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_rope_gpu(int64_t t_id, int64_t cos_id, int64_t sin_id,\n" +
            "                           int64_t T, int64_t nheads, int64_t hd,\n" +
            "                           int64_t out_id) {\n" +
            "    return _hx_cuda_rope_common(t_id, cos_id, sin_id, T, nheads, hd,\n" +
            "                                out_id, 0);\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_rope_bwd_gpu(int64_t t_id, int64_t cos_id, int64_t sin_id,\n" +
            "                               int64_t T, int64_t nheads, int64_t hd,\n" +
            "                               int64_t out_id) {\n" +
            "    return _hx_cuda_rope_common(t_id, cos_id, sin_id, T, nheads, hd,\n" +
            "                                out_id, 1);\n" +
            "}\n" +
            "\n" +
            "/* ── Transpose-scatter host wrapper (RFC 058 §5.2) ──────────────────\n" +
            " *\n" +
            " * Fills a slab of dst with the transpose of src on-device:\n" +
            " *   dst[dst_off + c*rows + r] = src[r*cols + c]   (rows×cols → cols×rows)\n" +
            " *\n" +
            " * src is the cuBLAS projection output C — left FARR_DEVICE/dirty_dev by\n" +
            " * RFC 057 §6.1, so _h2d(src_id) SKIPs the redundant H2D (H2D-skip\n" +
            " * predicate, line ~190). dst is Bc — populated slab-by-slab. The kernel\n" +
            " * writes ONLY the [dst_off, dst_off+rows*cols) range, so dst's current\n" +
            " * device contents must be correct outside that range; _h2d(dst_id)\n" +
            " * uploads dst's host bytes first (and SKIPs once dst is already\n" +
            " * device-authoritative — exactly the residency win RFC 058 unlocks).\n" +
            " *\n" +
            " * On return dst (Bc) is MIRRORED — the kernel result is copied D2H back\n" +
            " * to the host buffer so host Bc == device Bc byte-identically.\n" +
            " *\n" +
            " * RFC 058 byte-eq fix (fire #13 regression): the original wrapper marked\n" +
            " * dst loc=FARR_DEVICE/dirty_host=1 and SKIPPED the D2H (\"device freshest,\n" +
            " * a host reader triggers a lazy D2H\"). But the downstream A2-block ops\n" +
            " * (RMSNorm/RoPE/attention/SwiGLU slabs in flame_phase4d7_block_*_\n" +
            " * primitive.c) read Bc via the RAW host pointer `_hx_farr_table[Bc].buf`\n" +
            " * — NOT through a farr API — so the lazy-D2H trigger never fires. They\n" +
            " * read STALE host Bc bytes → wrong numerics (d768 init gn2 3.98438 vs\n" +
            " * the correct 3.99026 of fires #8–#12).\n" +
            " *\n" +
            " * Device residency is all-or-nothing: marking Bc device-authoritative\n" +
            " * while consumers still host-read it breaks byte-eq. Until every Bc\n" +
            " * reader is converted to hexa_farr_dev_view (RFC 057 §6.2 consume wiring,\n" +
            " * flame Phase 4-D-9 — element-loop kernels for RMSNorm/RoPE/attention/\n" +
            " * SwiGLU not yet landed), the wrapper MUST D2H so the host buffer is\n" +
            " * correct. The full-buffer _d2h is valid here: _h2d(dst_id) above\n" +
            " * uploaded dst's whole host buffer, the kernel wrote only the slab, so\n" +
            " * the device buffer holds the entire correct Bc; _d2h copies it all\n" +
            " * back, sets dirty_host=0, loc=FARR_MIRRORED. The device copy stays live\n" +
            " * (MIRRORED) so a later GPU op's _h2d still SKIPs — no wall regression\n" +
            " * beyond the D2H round-trip itself.\n" +
            " *\n" +
            " * NOTE the d=32 path NEVER reaches this wrapper — the consumer keeps the\n" +
            " * host transpose loop below the dim-gate (RFC 058 §5.4) so d=32 stays\n" +
            " * byte-identical. This is purely the d768 GPU-resident path. */\n" +
            "int _hx_cuda_farr_transpose_scatter_gpu(int64_t src_id, int64_t dst_id,\n" +
            "                                        int64_t rows, int64_t cols,\n" +
            "                                        int64_t dst_off) {\n" +
            "    if (src_id < 0 || dst_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter: bad ids %lld %lld\\n\",\n" +
            "                (long long)src_id, (long long)dst_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (rows <= 0 || cols <= 0 || dst_off < 0) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter: bad shape \"\n" +
            "                \"rows=%lld cols=%lld dst_off=%lld\\n\",\n" +
            "                (long long)rows, (long long)cols, (long long)dst_off);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (src_id >= _hx_farr_count || dst_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int64_t total = rows * cols;\n" +
            "    if (_hx_farr_table[src_id].len < total) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter: src host len %lld \"\n" +
            "                \"< rows*cols %lld\\n\",\n" +
            "                (long long)_hx_farr_table[src_id].len, (long long)total);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[dst_id].len < dst_off + total) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter: dst host len %lld \"\n" +
            "                \"< dst_off+rows*cols %lld\\n\",\n" +
            "                (long long)_hx_farr_table[dst_id].len,\n" +
            "                (long long)(dst_off + total));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* src device-resident → _h2d SKIPs (RFC 057 §6.1). dst current host\n" +
            "     * bytes uploaded so the kernel preserves regions outside the slab;\n" +
            "     * SKIPs once dst is already device-authoritative. */\n" +
            "    if (_h2d(src_id) != 0) return -1;\n" +
            "    if (_h2d(dst_id) != 0) return -1;\n" +
            "    const double* SRC = g_slots[src_id].d_buf;\n" +
            "    double*       DST = g_slots[dst_id].d_buf;\n" +
            "    if (!SRC || !DST) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter: null device buf\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int grid = _hx_cuda_elem_grid(total);\n" +
            "    _hx_cuda_kern_transpose_scatter<<<grid, _HX_CUDA_ELEM_BLOCK>>>(\n" +
            "        SRC, DST, rows, cols, dst_off);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_scatter launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* RFC 058 byte-eq fix — D2H the kernel result back to the host buffer.\n" +
            "     * Downstream A2-block consumers (RMSNorm/RoPE/attention/SwiGLU slabs)\n" +
            "     * read Bc via the RAW host pointer, NOT a farr API, so the lazy-D2H\n" +
            "     * trigger never fires; the host buffer MUST therefore be made fresh\n" +
            "     * here. _d2h copies the whole device buffer back (it holds the entire\n" +
            "     * correct Bc — see header), sets dirty_host=0, loc=FARR_MIRRORED. The\n" +
            "     * device pointer stays live so a later GPU op's _h2d still SKIPs. The\n" +
            "     * resident-residency win (dropping this D2H) lands once all Bc readers\n" +
            "     * are converted to hexa_farr_dev_view — flame Phase 4-D-9. */\n" +
            "    if (_d2h(dst_id) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "\n" +
            "\n" +
            "\n" +
            "/* ── mk2 dt_* faithful device transcendentals restored from e030fa31 ─\n" +
            " * _hx_cuda_dt_exp_d / _hx_cuda_dt_sqrt_d: non-contracted (__dmul_rn/\n" +
            " * __dadd_rn/__ddiv_rn) device mirrors of the CPU _hx_dt_*_d, byte-eq\n" +
            " * under FP_CONTRACT OFF (commit b73269ea discipline). Called by the\n" +
            " * mk2-C5 device kernels below — must precede them. */\n" +
            "__device__ __forceinline__ double _hx_cuda_dt_exp_d(double x) {\n" +
            "    int r = 0;\n" +
            "    double xr = x;\n" +
            "    while ((xr > 0.0 ? xr : 0.0 - xr) > 0.25) { xr = xr / 2.0; r = r + 1; }\n" +
            "    double term = 1.0;\n" +
            "    double acc  = 1.0;\n" +
            "    int k = 1;\n" +
            "    while (k < 12) {\n" +
            "        term = __ddiv_rn(__dmul_rn(term, xr), (double)k);\n" +
            "        acc  = __dadd_rn(acc, term);\n" +
            "        k = k + 1;\n" +
            "    }\n" +
            "    int s = 0;\n" +
            "    while (s < r) { acc = __dmul_rn(acc, acc); s = s + 1; }\n" +
            "    return acc;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C2 (2026-05-19): dt_sqrt byte-exact device mirror of hexa\n" +
            " * flame_math `dt_sqrt` (24-iter Newton from g0 = max(x,1)). The\n" +
            " * decoder-block rmsnorm reference uses dt_sqrt, NOT libm sqrt —\n" +
            " * same FMA / transcendental hazard as dt_exp. __dmul_rn / __ddiv_rn /\n" +
            " * __dadd_rn = contraction-immune, byte-eq to host _hx_dt_sqrt_d\n" +
            " * under FP_CONTRACT OFF (same discipline as the silu-gate dt_exp\n" +
            " * mirror, commit e5faa8b0). */\n" +
            "__device__ __forceinline__ double _hx_cuda_dt_sqrt_d(double x) {\n" +
            "    if (x <= 0.0) return 0.0;\n" +
            "    double g = x > 1.0 ? x : 1.0;\n" +
            "    int i = 0;\n" +
            "    while (i < 24) {\n" +
            "        g = __dmul_rn(0.5, __dadd_rn(g, __ddiv_rn(x, g)));\n" +
            "        i = i + 1;\n" +
            "    }\n" +
            "    return g;\n" +
            "}\n" +
            "\n" +
            "/* ── mk2-C5 __global__ device kernels restored from e030fa31 ───────\n" +
            " * Launched by the host wrappers immediately below; the A/B/C merge\n" +
            " * dropped both halves. Pure double* math kernels, FP_CONTRACT-safe\n" +
            " * (compiled by nvcc -x cu). Must precede the host launchers. */\n" +
            "__global__ void _hx_cuda_kern_rmsnorm_mh(const double* __restrict__ X,\n" +
            "                                         const double* __restrict__ G,\n" +
            "                                         double* __restrict__ Y,\n" +
            "                                         double* __restrict__ XN,\n" +
            "                                         double* __restrict__ I,\n" +
            "                                         int64_t T, int64_t d) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    const double eps = 0.000001;\n" +
            "    for (; i < T; i += stride) {\n" +
            "        double ms = 0.0;\n" +
            "        for (int64_t c = 0; c < d; c++) {\n" +
            "            double xv = X[i*d + c];\n" +
            "            ms = __dadd_rn(ms, __dmul_rn(xv, xv));\n" +
            "        }\n" +
            "        ms = __ddiv_rn(ms, (double)d);\n" +
            "        double iv = __ddiv_rn(1.0, _hx_cuda_dt_sqrt_d(__dadd_rn(ms, eps)));\n" +
            "        I[i] = iv;\n" +
            "        for (int64_t c = 0; c < d; c++) {\n" +
            "            double xni = __dmul_rn(X[i*d + c], iv);\n" +
            "            XN[i*d + c] = xni;\n" +
            "            Y[i*d + c]  = __dmul_rn(G[c], xni);\n" +
            "        }\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* mk2-C5 (2026-05-19): farr_copy_slice + farr_transpose_2d device\n" +
            " * kernels — bandwidth-bound memcpy / memory rearrangement. No FP\n" +
            " * arithmetic → trivially byte-eq with the host scalar t_get/t_set\n" +
            " * loop. Eliminates the ~412M scalar HexaVal-box prelude that\n" +
            " * dominated the d768·12L generic ag_tape step (mk2-FINAL #1 fire\n" +
            " * 2026-05-19 timeout at 901s with 14min GPU idle). */\n" +
            "__global__ void _hx_cuda_kern_copy_slice(const double* __restrict__ src,\n" +
            "                                         double* __restrict__ dst,\n" +
            "                                         int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        dst[i] = src[i];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* transpose: dst[c·d_out + r] = src[soff + r·d_in + c], one thread per\n" +
            " * (r, c) cell. byte-identical to the agt_wT_slice / agt_wT_off host\n" +
            " * loop (no FP — pure memory rearrangement). */\n" +
            "__global__ void _hx_cuda_kern_transpose_2d(const double* __restrict__ src,\n" +
            "                                           int64_t soff,\n" +
            "                                           double* __restrict__ dst,\n" +
            "                                           int64_t doff,\n" +
            "                                           int64_t d_out, int64_t d_in) {\n" +
            "    int64_t flat   = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t total  = d_out * d_in;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; flat < total; flat += stride) {\n" +
            "        int64_t r = flat / d_in;\n" +
            "        int64_t c = flat - r * d_in;\n" +
            "        dst[doff + c * d_out + r] = src[soff + r * d_in + c];\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* mk2-C4 (2026-05-19): GQA attention-dt forge-route. One thread per\n" +
            " * (head, query) pair = nh·T threads (strict per-pair sequential for\n" +
            " * byte-eq with the host loop's nested hh→i→j order). Memory contract:\n" +
            " *   in:  Q[T·nh·hd], K[T·nkv·hd], V[T·nkv·hd]\n" +
            " *   out: P[nh·T·T]   — causal probs, j ∈ [0,i+1); j ∈ [i+1,T) is 0.\n" +
            " *        CTX[T·nh·hd]\n" +
            " * Uses dt_sqrt mirror (scale=1/√hd) + dt_exp mirror (stable softmax).\n" +
            " * P doubles as scratch: step 1 writes raw scores; steps 3-4 transform\n" +
            " * in place to probs. Op order byte-identical to ag_tape.hexa\n" +
            " * _ag_attn_dt_fwd (causal mask + per-row stable softmax + GQA kvh =\n" +
            " * hh/n_rep). */\n" +
            "__global__ void _hx_cuda_kern_attn_dt_fwd(const double* __restrict__ Q,\n" +
            "                                          const double* __restrict__ K,\n" +
            "                                          const double* __restrict__ V,\n" +
            "                                          double* __restrict__ P,\n" +
            "                                          double* __restrict__ CTX,\n" +
            "                                          int64_t T, int64_t nh,\n" +
            "                                          int64_t nkv, int64_t hd) {\n" +
            "    int64_t flat   = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t total  = nh * T;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    int64_t n_rep  = nh / nkv;\n" +
            "    int64_t d      = nh * hd;\n" +
            "    /* scale = 1 / dt_sqrt(hd). dt_sqrt-faithful (NOT libm sqrt) —\n" +
            "     * same hazard as rmsnorm. */\n" +
            "    double scale = __ddiv_rn(1.0, _hx_cuda_dt_sqrt_d((double)hd));\n" +
            "    for (; flat < total; flat += stride) {\n" +
            "        int64_t hh  = flat / T;\n" +
            "        int64_t i   = flat % T;\n" +
            "        int64_t kvh = hh / n_rep;\n" +
            "        int64_t L   = i + 1;\n" +
            "        /* Step 1: P[hh,i,j] = dot(Q[i,hh,·], K[j,kvh,·]) * scale */\n" +
            "        for (int64_t j = 0; j < L; j++) {\n" +
            "            double dot = 0.0;\n" +
            "            for (int64_t c = 0; c < hd; c++) {\n" +
            "                dot = __dadd_rn(dot,\n" +
            "                                __dmul_rn(Q[(i*nh + hh)*hd + c],\n" +
            "                                          K[(j*nkv + kvh)*hd + c]));\n" +
            "            }\n" +
            "            P[(hh*T + i)*T + j] = __dmul_rn(dot, scale);\n" +
            "        }\n" +
            "        /* Step 2: max */\n" +
            "        double mx = P[(hh*T + i)*T + 0];\n" +
            "        for (int64_t j = 1; j < L; j++) {\n" +
            "            double v = P[(hh*T + i)*T + j];\n" +
            "            if (v > mx) mx = v;\n" +
            "        }\n" +
            "        /* Step 3: e = dt_exp(P − mx); P := e; tot += e. */\n" +
            "        double tot = 0.0;\n" +
            "        for (int64_t j = 0; j < L; j++) {\n" +
            "            double e = _hx_cuda_dt_exp_d(P[(hh*T + i)*T + j] - mx);\n" +
            "            P[(hh*T + i)*T + j] = e;\n" +
            "            tot = __dadd_rn(tot, e);\n" +
            "        }\n" +
            "        /* Step 4: normalize */\n" +
            "        for (int64_t j = 0; j < L; j++) {\n" +
            "            P[(hh*T + i)*T + j] = __ddiv_rn(P[(hh*T + i)*T + j], tot);\n" +
            "        }\n" +
            "        /* Step 5: ctx[i,hh,c2] = Σ P[hh,i,j] · V[j,kvh,c2] */\n" +
            "        for (int64_t c2 = 0; c2 < hd; c2++) {\n" +
            "            double acc = 0.0;\n" +
            "            for (int64_t j = 0; j < L; j++) {\n" +
            "                acc = __dadd_rn(acc,\n" +
            "                                __dmul_rn(P[(hh*T + i)*T + j],\n" +
            "                                          V[(j*nkv + kvh)*hd + c2]));\n" +
            "            }\n" +
            "            CTX[i*d + hh*hd + c2] = acc;\n" +
            "        }\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* mk2-C4-bwd (2026-05-19): GQA attention-dt bwd. Three kernels with\n" +
            " * a shared scratch buffer (dP_row[nh·T·T], allocated by the host\n" +
            " * wrapper).\n" +
            " *   Step 1 (dProw kernel) — per (hh,i,j): dP_row[hh,i,j] = Σ_c\n" +
            " *     dctx[i,hh,c]·V[j,kvh,c], j < L only.\n" +
            " *   Step 2 (dS+dQ kernel) — per (hh,i): sdot=Σ_j P·dP_row; then for\n" +
            " *     j<L overwrite dP_row[hh,i,j] := P·(dP_row[hh,i,j]-sdot)·scale\n" +
            " *     (this IS dS); then dQ[i,hh,c2] = Σ_j dS·K[j,kvh,c2]. Each\n" +
            " *     thread owns its dQ[(i*nh+hh)*hd + c2] cell — no race.\n" +
            " *   Step 3a (dV kernel) — per (j,kvh,c): dV[j,kvh,c] = Σ_{hh in\n" +
            " *     group, i ≥ j} P[hh,i,j]·dctx[i,hh,c]. Output-centric strict\n" +
            " *     sequential = byte-eq with CPU canonical (hh,i) order.\n" +
            " *   Step 3b (dK kernel) — per (j,kvh,c): dK[j,kvh,c] = Σ_{hh in\n" +
            " *     group, i ≥ j} dS[hh,i,j]·Q[i,hh,c]. (dS lives in dP_row\n" +
            " *     scratch after step 2.)\n" +
            " * dQ/dK/dV are assumed FRESH t_zeros at the call site (the tape\n" +
            " * replay site allocates them inline). */\n" +
            "__global__ void _hx_cuda_kern_attn_dt_bwd_dProw(\n" +
            "    const double* __restrict__ V,\n" +
            "    const double* __restrict__ dctx,\n" +
            "    double* __restrict__ dProw,\n" +
            "    int64_t T, int64_t nh, int64_t nkv, int64_t hd) {\n" +
            "    int64_t flat   = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t total  = nh * T * T;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    int64_t n_rep  = nh / nkv;\n" +
            "    int64_t d      = nh * hd;\n" +
            "    for (; flat < total; flat += stride) {\n" +
            "        int64_t hh = flat / (T * T);\n" +
            "        int64_t r  = flat - hh * T * T;\n" +
            "        int64_t i  = r / T;\n" +
            "        int64_t j  = r - i * T;\n" +
            "        if (j > i) { dProw[flat] = 0.0; continue; }\n" +
            "        int64_t kvh = hh / n_rep;\n" +
            "        double acc = 0.0;\n" +
            "        for (int64_t c = 0; c < hd; c++) {\n" +
            "            acc = __dadd_rn(acc,\n" +
            "                            __dmul_rn(dctx[i*d + hh*hd + c],\n" +
            "                                      V[(j*nkv + kvh)*hd + c]));\n" +
            "        }\n" +
            "        dProw[flat] = acc;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_attn_dt_bwd_dS_dQ(\n" +
            "    const double* __restrict__ Q,\n" +
            "    const double* __restrict__ K,\n" +
            "    const double* __restrict__ P,\n" +
            "    double* __restrict__ dProw,    /* in: dP_row, out: dS (same buffer) */\n" +
            "    double* __restrict__ dQ,\n" +
            "    int64_t T, int64_t nh, int64_t nkv, int64_t hd) {\n" +
            "    int64_t flat   = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t total  = nh * T;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    int64_t n_rep  = nh / nkv;\n" +
            "    /* Compute scale device-side (no cross-TU call to host static\n" +
            "     * `_hx_dt_sqrt_d`). 25 Newton iters × per-thread ≈ 300K ops total\n" +
            "     * at d768·12L — negligible. */\n" +
            "    double scale = __ddiv_rn(1.0, _hx_cuda_dt_sqrt_d((double)hd));\n" +
            "    for (; flat < total; flat += stride) {\n" +
            "        int64_t hh = flat / T;\n" +
            "        int64_t i  = flat - hh * T;\n" +
            "        int64_t kvh = hh / n_rep;\n" +
            "        int64_t L = i + 1;\n" +
            "        /* sdot = Σ_j P[hh,i,j] · dP_row[hh,i,j], j∈[0,L) */\n" +
            "        double sdot = 0.0;\n" +
            "        for (int64_t j = 0; j < L; j++) {\n" +
            "            sdot = __dadd_rn(sdot,\n" +
            "                             __dmul_rn(P[(hh*T + i)*T + j],\n" +
            "                                       dProw[(hh*T + i)*T + j]));\n" +
            "        }\n" +
            "        /* in-place: dProw[hh,i,j] := P · (dProw - sdot) · scale = dS */\n" +
            "        for (int64_t j = 0; j < L; j++) {\n" +
            "            double v = dProw[(hh*T + i)*T + j] - sdot;\n" +
            "            dProw[(hh*T + i)*T + j] = __dmul_rn(\n" +
            "                __dmul_rn(P[(hh*T + i)*T + j], v), scale);\n" +
            "        }\n" +
            "        /* dQ[i,hh,c2] = Σ_j dS[hh,i,j] · K[j,kvh,c2]\n" +
            "         * CPU canonical: outer j, inner c2 — accumulator per c2.\n" +
            "         * Reproduce: keep separate dQ acc per c2 (registers), j outer. */\n" +
            "        /* For each c2 ∈ [0..hd), the strict j-ascending fold matches\n" +
            "         * CPU exactly. (kvh constant for this thread.) */\n" +
            "        for (int64_t c2 = 0; c2 < hd; c2++) {\n" +
            "            double acc = 0.0;\n" +
            "            for (int64_t j = 0; j < L; j++) {\n" +
            "                acc = __dadd_rn(acc,\n" +
            "                                __dmul_rn(dProw[(hh*T + i)*T + j],\n" +
            "                                          K[(j*nkv + kvh)*hd + c2]));\n" +
            "            }\n" +
            "            dQ[(i*nh + hh)*hd + c2] = acc;\n" +
            "        }\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_attn_dt_bwd_dV(\n" +
            "    const double* __restrict__ P,\n" +
            "    const double* __restrict__ dctx,\n" +
            "    double* __restrict__ dV,\n" +
            "    int64_t T, int64_t nh, int64_t nkv, int64_t hd) {\n" +
            "    int64_t flat   = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t total  = T * nkv * hd;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    int64_t n_rep  = nh / nkv;\n" +
            "    int64_t d      = nh * hd;\n" +
            "    for (; flat < total; flat += stride) {\n" +
            "        int64_t j   = flat / (nkv * hd);\n" +
            "        int64_t r   = flat - j * (nkv * hd);\n" +
            "        int64_t kvh = r / hd;\n" +
            "        int64_t c   = r - kvh * hd;\n" +
            "        int64_t hh0 = kvh * n_rep;\n" +
            "        double acc = 0.0;\n" +
            "        /* CPU canonical order: hh ascending, then i ascending (i ≥ j) */\n" +
            "        for (int64_t hh = hh0; hh < hh0 + n_rep; hh++) {\n" +
            "            for (int64_t i = j; i < T; i++) {\n" +
            "                acc = __dadd_rn(acc,\n" +
            "                                __dmul_rn(P[(hh*T + i)*T + j],\n" +
            "                                          dctx[i*d + hh*hd + c]));\n" +
            "            }\n" +
            "        }\n" +
            "        dV[(j*nkv + kvh)*hd + c] = acc;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "__global__ void _hx_cuda_kern_attn_dt_bwd_dK(\n" +
            "    const double* __restrict__ Q,\n" +
            "    const double* __restrict__ dS,    /* same buffer as dProw after step 2 */\n" +
            "    double* __restrict__ dK,\n" +
            "    int64_t T, int64_t nh, int64_t nkv, int64_t hd) {\n" +
            "    int64_t flat   = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t total  = T * nkv * hd;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    int64_t n_rep  = nh / nkv;\n" +
            "    for (; flat < total; flat += stride) {\n" +
            "        int64_t j   = flat / (nkv * hd);\n" +
            "        int64_t r   = flat - j * (nkv * hd);\n" +
            "        int64_t kvh = r / hd;\n" +
            "        int64_t c   = r - kvh * hd;\n" +
            "        int64_t hh0 = kvh * n_rep;\n" +
            "        double acc = 0.0;\n" +
            "        for (int64_t hh = hh0; hh < hh0 + n_rep; hh++) {\n" +
            "            for (int64_t i = j; i < T; i++) {\n" +
            "                acc = __dadd_rn(acc,\n" +
            "                                __dmul_rn(dS[(hh*T + i)*T + j],\n" +
            "                                          Q[(i*nh + hh)*hd + c]));\n" +
            "            }\n" +
            "        }\n" +
            "        dK[(j*nkv + kvh)*hd + c] = acc;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* silu-gate: O[i] = (A[i]·σ(A[i]))·B[i], σ=1/(1+dt_exp(-x)).\n" +
            " * dt_exp-faithful (NOT _hx_cuda_sigmoid_d's libm exp). Op order\n" +
            " * byte-identical to CPU _hx_farr_silu_gate_cpu / ag_tape\n" +
            " * _ag_silu(a)*b. */\n" +
            "__global__ void _hx_cuda_kern_silu_gate(const double* __restrict__ A,\n" +
            "                                        const double* __restrict__ B,\n" +
            "                                        double* __restrict__ O,\n" +
            "                                        int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        double ai  = A[i];\n" +
            "        double sig = 1.0 / (1.0 + _hx_cuda_dt_exp_d(0.0 - ai));\n" +
            "        O[i] = __dmul_rn(__dmul_rn(ai, sig), B[i]);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "\n" +
            "/* ── mk2-C5 GPU kernels restored from e030fa31 (rfc043-flame-camp) ──\n" +
            " * The A/B/C three-way merge dropped Cycle A's runtime_cuda.c additions;\n" +
            " * these 9 device kernels are the GPU side of the HEXA_CUDA seam in\n" +
            " * self/runtime.c (silu_gate/rmsnorm_mh/attn_dt_fwd+bwd/copy_slice/\n" +
            " * fill_dt_lcg/add_inplace/zero_slice/transpose_2d). byte-eq oracle-\n" +
            " * gated vs the _hx_farr_*_cpu mirrors. */\n" +
            "/* mk2-C1b: silu-gate O = (A·σ(A))·B (dt_exp-faithful). Two host\n" +
            " * inputs H2D'd; byte-eq oracle-gated vs CPU _hx_farr_silu_gate_cpu. */\n" +
            "int _hx_cuda_farr_silu_gate_gpu(int64_t a_id, int64_t b_id,\n" +
            "                                int64_t n, int64_t out_id) {\n" +
            "    if (a_id < 0 || b_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] silu_gate: bad ids %lld %lld %lld\\n\",\n" +
            "                (long long)a_id, (long long)b_id, (long long)out_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] silu_gate: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (a_id >= _hx_farr_count || b_id >= _hx_farr_count ||\n" +
            "        out_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] silu_gate: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_hx_farr_table[a_id].len < n || _hx_farr_table[b_id].len < n ||\n" +
            "        _hx_farr_table[out_id].len < n) {\n" +
            "        fprintf(stderr, \"[cuda] silu_gate: host len < n\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(a_id) != 0) return -1;\n" +
            "    if (_h2d(b_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(out_id, n) != 0) return -1;\n" +
            "    double* A = g_slots[a_id].d_buf;\n" +
            "    double* B = g_slots[b_id].d_buf;\n" +
            "    double* O = g_slots[out_id].d_buf;\n" +
            "    int grid = _hx_cuda_elem_grid(n);\n" +
            "    _hx_cuda_kern_silu_gate<<<grid, _HX_CUDA_ELEM_BLOCK>>>(A, B, O, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] silu_gate launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, n) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C2 (2026-05-19): rmsnorm-mh fwd forge-route. fwd kernel above\n" +
            " * computes y[T·d], xn[T·d], inv[T] in one launch (one thread per row,\n" +
            " * sequential reduction for byte-eq). All three outputs go through\n" +
            " * _d2h_out → DEVICE_KEEP register honoured (mk2-C3) so the next forge\n" +
            " * op's _h2d sees them via the §6.1 skip path. Replaces the host-scalar\n" +
            " * t_get/t_set loop in ag_tape.hexa::ag_rmsnorm_mh, byte-eq oracle-\n" +
            " * gated vs CPU _hx_farr_rmsnorm_mh_cpu (FP_CONTRACT OFF, dt_sqrt-\n" +
            " * faithful). */\n" +
            "int _hx_cuda_farr_rmsnorm_mh_gpu(int64_t x_id, int64_t g_id,\n" +
            "                                 int64_t y_id, int64_t xn_id,\n" +
            "                                 int64_t inv_id, int64_t T, int64_t d) {\n" +
            "    if (x_id < 0 || g_id < 0 || y_id < 0 || xn_id < 0 || inv_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_mh: bad ids\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (T <= 0 || d <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_mh: bad T=%lld d=%lld\\n\",\n" +
            "                (long long)T, (long long)d);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (x_id >= _hx_farr_count || g_id >= _hx_farr_count ||\n" +
            "        y_id >= _hx_farr_count || xn_id >= _hx_farr_count ||\n" +
            "        inv_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_mh: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int64_t n_xy = T * d;\n" +
            "    if (_hx_farr_table[x_id].len  < n_xy || _hx_farr_table[g_id].len  < d ||\n" +
            "        _hx_farr_table[y_id].len  < n_xy || _hx_farr_table[xn_id].len < n_xy ||\n" +
            "        _hx_farr_table[inv_id].len < T) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_mh: host len mismatch\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(x_id) != 0) return -1;\n" +
            "    if (_h2d(g_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(y_id,   n_xy) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(xn_id,  n_xy) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(inv_id, T)    != 0) return -1;\n" +
            "    double* X = g_slots[x_id].d_buf;\n" +
            "    double* G = g_slots[g_id].d_buf;\n" +
            "    double* Y = g_slots[y_id].d_buf;\n" +
            "    double* XN= g_slots[xn_id].d_buf;\n" +
            "    double* I = g_slots[inv_id].d_buf;\n" +
            "    /* one thread per row; T parallel. Cap grid at 65535 (legacy CUDA\n" +
            "     * 1-D grid ceiling we already use elsewhere). */\n" +
            "    int block = 256;\n" +
            "    int64_t need = (T + block - 1) / block;\n" +
            "    int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "    _hx_cuda_kern_rmsnorm_mh<<<grid, block>>>(X, G, Y, XN, I, T, d);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] rmsnorm_mh launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(y_id,   n_xy) != 0) return -1;\n" +
            "    if (_d2h_out(xn_id,  n_xy) != 0) return -1;\n" +
            "    if (_d2h_out(inv_id, T)    != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C4 (2026-05-19): GQA attention-dt fwd forge-route. One kernel\n" +
            " * launch computes P[nh·T·T] (causal probs, j<L only) and CTX[T·nh·hd]\n" +
            " * from Q/K/V. dt_sqrt + dt_exp mirrors guarantee byte-eq with the host\n" +
            " * loop. Outputs honour DEVICE_KEEP via _d2h_out. */\n" +
            "int _hx_cuda_farr_attn_dt_fwd_gpu(int64_t q_id, int64_t k_id, int64_t v_id,\n" +
            "                                  int64_t p_id, int64_t ctx_id,\n" +
            "                                  int64_t T, int64_t nh, int64_t nkv,\n" +
            "                                  int64_t hd) {\n" +
            "    if (q_id < 0 || k_id < 0 || v_id < 0 || p_id < 0 || ctx_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd: bad ids\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (T <= 0 || nh <= 0 || nkv <= 0 || hd <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd: bad dims T=%lld nh=%lld nkv=%lld hd=%lld\\n\",\n" +
            "                (long long)T, (long long)nh, (long long)nkv, (long long)hd);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (nh % nkv != 0) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd: nh=%lld not divisible by nkv=%lld\\n\",\n" +
            "                (long long)nh, (long long)nkv);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (q_id >= _hx_farr_count || k_id >= _hx_farr_count ||\n" +
            "        v_id >= _hx_farr_count || p_id >= _hx_farr_count ||\n" +
            "        ctx_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int64_t nq = T * nh  * hd;\n" +
            "    int64_t nk = T * nkv * hd;\n" +
            "    int64_t np = nh * T * T;\n" +
            "    if (_hx_farr_table[q_id].len   < nq ||\n" +
            "        _hx_farr_table[k_id].len   < nk ||\n" +
            "        _hx_farr_table[v_id].len   < nk ||\n" +
            "        _hx_farr_table[p_id].len   < np ||\n" +
            "        _hx_farr_table[ctx_id].len < nq) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd: host len mismatch\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(q_id) != 0) return -1;\n" +
            "    if (_h2d(k_id) != 0) return -1;\n" +
            "    if (_h2d(v_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(p_id,   np) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(ctx_id, nq) != 0) return -1;\n" +
            "    /* Zero P first — only j < L positions are written, the upper\n" +
            "     * triangle (j ≥ L per row) must stay 0 to match the t_zeros init\n" +
            "     * on the host side. cudaMemset is fine (P is doubles; 0x00·8 == 0.0). */\n" +
            "    cudaError_t ze = cudaMemset(g_slots[p_id].d_buf, 0,\n" +
            "                                (size_t)np * sizeof(double));\n" +
            "    if (ze != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd: cudaMemset P failed: %s\\n\",\n" +
            "                cudaGetErrorString(ze));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    double* Q = g_slots[q_id].d_buf;\n" +
            "    double* K = g_slots[k_id].d_buf;\n" +
            "    double* V = g_slots[v_id].d_buf;\n" +
            "    double* P = g_slots[p_id].d_buf;\n" +
            "    double* C = g_slots[ctx_id].d_buf;\n" +
            "    /* one thread per (hh, i) — nh·T threads. */\n" +
            "    int64_t total = nh * T;\n" +
            "    int block = 64;\n" +
            "    int64_t need = (total + block - 1) / block;\n" +
            "    int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "    _hx_cuda_kern_attn_dt_fwd<<<grid, block>>>(Q, K, V, P, C, T, nh, nkv, hd);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_fwd launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(p_id,   np) != 0) return -1;\n" +
            "    if (_d2h_out(ctx_id, nq) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C4-bwd (2026-05-19): GQA attention-dt bwd forge-route. 3-kernel\n" +
            " * pipeline using a temporary dP_row[nh·T·T] scratch (reused as dS\n" +
            " * after step 2). dQ/dK/dV must be FRESH t_zeros at the call site —\n" +
            " * the tape replay in ag_tape.hexa allocates them with t_zeros and the\n" +
            " * kernel writes acc directly (no read-modify-write). All outputs go\n" +
            " * through _d2h_out → DEVICE_KEEP honoured. */\n" +
            "int _hx_cuda_farr_attn_dt_bwd_gpu(int64_t q_id, int64_t k_id, int64_t v_id,\n" +
            "                                  int64_t p_id, int64_t dctx_id,\n" +
            "                                  int64_t dq_id, int64_t dk_id, int64_t dv_id,\n" +
            "                                  int64_t T, int64_t nh, int64_t nkv,\n" +
            "                                  int64_t hd) {\n" +
            "    if (q_id < 0 || k_id < 0 || v_id < 0 || p_id < 0 || dctx_id < 0 ||\n" +
            "        dq_id < 0 || dk_id < 0 || dv_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_bwd: bad ids\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (T <= 0 || nh <= 0 || nkv <= 0 || hd <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_bwd: bad dims T=%lld nh=%lld nkv=%lld hd=%lld\\n\",\n" +
            "                (long long)T, (long long)nh, (long long)nkv, (long long)hd);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (nh % nkv != 0) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_bwd: nh not multiple of nkv\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (q_id >= _hx_farr_count || k_id >= _hx_farr_count ||\n" +
            "        v_id >= _hx_farr_count || p_id >= _hx_farr_count ||\n" +
            "        dctx_id >= _hx_farr_count || dq_id >= _hx_farr_count ||\n" +
            "        dk_id >= _hx_farr_count || dv_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_bwd: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int64_t nq = T * nh  * hd;\n" +
            "    int64_t nk = T * nkv * hd;\n" +
            "    int64_t np = nh * T * T;\n" +
            "    if (_hx_farr_table[q_id].len    < nq ||\n" +
            "        _hx_farr_table[k_id].len    < nk ||\n" +
            "        _hx_farr_table[v_id].len    < nk ||\n" +
            "        _hx_farr_table[p_id].len    < np ||\n" +
            "        _hx_farr_table[dctx_id].len < nq ||\n" +
            "        _hx_farr_table[dq_id].len   < nq ||\n" +
            "        _hx_farr_table[dk_id].len   < nk ||\n" +
            "        _hx_farr_table[dv_id].len   < nk) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_bwd: host len mismatch\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(q_id) != 0) return -1;\n" +
            "    if (_h2d(k_id) != 0) return -1;\n" +
            "    if (_h2d(v_id) != 0) return -1;\n" +
            "    if (_h2d(p_id) != 0) return -1;\n" +
            "    if (_h2d(dctx_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(dq_id, nq) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(dk_id, nk) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(dv_id, nk) != 0) return -1;\n" +
            "    /* dP_row scratch (reused as dS after step 2) */\n" +
            "    double* dProw = NULL;\n" +
            "    cudaError_t er = cudaMalloc(&dProw, (size_t)np * sizeof(double));\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] attn_dt_bwd: dProw malloc failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    double* Q = g_slots[q_id].d_buf;\n" +
            "    double* K = g_slots[k_id].d_buf;\n" +
            "    double* V = g_slots[v_id].d_buf;\n" +
            "    double* P = g_slots[p_id].d_buf;\n" +
            "    double* dctx = g_slots[dctx_id].d_buf;\n" +
            "    double* dQ = g_slots[dq_id].d_buf;\n" +
            "    double* dK = g_slots[dk_id].d_buf;\n" +
            "    double* dV = g_slots[dv_id].d_buf;\n" +
            "    /* Step 1: dProw per (hh, i, j). nh·T·T threads. */\n" +
            "    {\n" +
            "        int64_t total = nh * T * T;\n" +
            "        int block = 64;\n" +
            "        int64_t need = (total + block - 1) / block;\n" +
            "        int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "        _hx_cuda_kern_attn_dt_bwd_dProw<<<grid, block>>>(V, dctx, dProw,\n" +
            "                                                         T, nh, nkv, hd);\n" +
            "        er = cudaGetLastError();\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] attn_dt_bwd dProw kernel failed: %s\\n\",\n" +
            "                    cudaGetErrorString(er));\n" +
            "            cudaFree(dProw);\n" +
            "            return -1;\n" +
            "        }\n" +
            "    }\n" +
            "    /* Step 2: dS in-place (overwrite dProw) + dQ. nh·T threads. */\n" +
            "    {\n" +
            "        int64_t total = nh * T;\n" +
            "        int block = 64;\n" +
            "        int64_t need = (total + block - 1) / block;\n" +
            "        int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "        _hx_cuda_kern_attn_dt_bwd_dS_dQ<<<grid, block>>>(Q, K, P, dProw, dQ,\n" +
            "                                                         T, nh, nkv, hd);\n" +
            "        er = cudaGetLastError();\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] attn_dt_bwd dS+dQ kernel failed: %s\\n\",\n" +
            "                    cudaGetErrorString(er));\n" +
            "            cudaFree(dProw);\n" +
            "            return -1;\n" +
            "        }\n" +
            "    }\n" +
            "    /* Step 3a: dV per (j, kvh, c). T·nkv·hd threads. */\n" +
            "    {\n" +
            "        int64_t total = T * nkv * hd;\n" +
            "        int block = 64;\n" +
            "        int64_t need = (total + block - 1) / block;\n" +
            "        int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "        _hx_cuda_kern_attn_dt_bwd_dV<<<grid, block>>>(P, dctx, dV,\n" +
            "                                                      T, nh, nkv, hd);\n" +
            "        er = cudaGetLastError();\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] attn_dt_bwd dV kernel failed: %s\\n\",\n" +
            "                    cudaGetErrorString(er));\n" +
            "            cudaFree(dProw);\n" +
            "            return -1;\n" +
            "        }\n" +
            "    }\n" +
            "    /* Step 3b: dK per (j, kvh, c). Same shape. */\n" +
            "    {\n" +
            "        int64_t total = T * nkv * hd;\n" +
            "        int block = 64;\n" +
            "        int64_t need = (total + block - 1) / block;\n" +
            "        int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "        _hx_cuda_kern_attn_dt_bwd_dK<<<grid, block>>>(Q, dProw, dK,\n" +
            "                                                      T, nh, nkv, hd);\n" +
            "        er = cudaGetLastError();\n" +
            "        if (er != cudaSuccess) {\n" +
            "            fprintf(stderr, \"[cuda] attn_dt_bwd dK kernel failed: %s\\n\",\n" +
            "                    cudaGetErrorString(er));\n" +
            "            cudaFree(dProw);\n" +
            "            return -1;\n" +
            "        }\n" +
            "    }\n" +
            "    cudaFree(dProw);\n" +
            "    if (_d2h_out(dq_id, nq) != 0) return -1;\n" +
            "    if (_d2h_out(dk_id, nk) != 0) return -1;\n" +
            "    if (_d2h_out(dv_id, nk) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C5: device-resident slice copy. Reads src[soff..soff+n) and\n" +
            " * writes dst[doff..doff+n). DEVICE_KEEP honoured via _d2h_out. */\n" +
            "int _hx_cuda_farr_copy_slice_gpu(int64_t src_id, int64_t soff,\n" +
            "                                 int64_t dst_id, int64_t doff,\n" +
            "                                 int64_t n) {\n" +
            "    if (src_id < 0 || dst_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] copy_slice: bad ids %lld %lld\\n\",\n" +
            "                (long long)src_id, (long long)dst_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0 || soff < 0 || doff < 0) {\n" +
            "        fprintf(stderr, \"[cuda] copy_slice: bad n=%lld soff=%lld doff=%lld\\n\",\n" +
            "                (long long)n, (long long)soff, (long long)doff);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (src_id >= _hx_farr_count || dst_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] copy_slice: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    HexaFarrEntry* se = &_hx_farr_table[src_id];\n" +
            "    HexaFarrEntry* de = &_hx_farr_table[dst_id];\n" +
            "    if (se->len < soff + n || de->len < doff + n) {\n" +
            "        fprintf(stderr, \"[cuda] copy_slice: range out of bounds\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(src_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(dst_id, de->len) != 0) return -1;\n" +
            "    const double* S = g_slots[src_id].d_buf;\n" +
            "    double* D = g_slots[dst_id].d_buf;\n" +
            "    /* Device-to-device cudaMemcpy is the canonical (and fastest) form\n" +
            "     * for a contiguous slice — saturates HBM bandwidth, no kernel\n" +
            "     * launch overhead per element. */\n" +
            "    cudaError_t er = cudaMemcpy(D + doff, S + soff,\n" +
            "                                (size_t)n * sizeof(double),\n" +
            "                                cudaMemcpyDeviceToDevice);\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] copy_slice cudaMemcpy failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Mark dst as device-current; lazy-D2H handles host readback. */\n" +
            "    if (_d2h_out(dst_id, de->len) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C5: device-side dt_lcg fill (single thread sequential to match\n" +
            " * the hexa nn_decoder_init / _train_fill_dt_lcg byte-eq exactly —\n" +
            " * each value depends on the previous LCG state). int64_t modular\n" +
            " * arithmetic is byte-identical to the hexa `(s * 1103515245 + 12345)\n" +
            " * % 2^31`. ~100M elements/init × 25ns = ~2.5s on A100, vs ~10min on\n" +
            " * host via HexaVal-box farr_set. The init runs once at startup,\n" +
            " * before any forge ops fire — eliminating it is what lets the d768\n" +
            " * trainer actually reach step 1. */\n" +
            "__global__ void _hx_cuda_kern_fill_dt_lcg(double* __restrict__ dst,\n" +
            "                                          int64_t off, int64_t n,\n" +
            "                                          int64_t seed, double scale) {\n" +
            "    if (blockIdx.x == 0 && threadIdx.x == 0) {\n" +
            "        int64_t s = seed;\n" +
            "        for (int64_t i = 0; i < n; i++) {\n" +
            "            s = (s * (int64_t)1103515245 + (int64_t)12345) % (int64_t)2147483648;\n" +
            "            double rv = (double)(s % 1000) / 1000.0 - 0.5;\n" +
            "            dst[off + i] = rv * scale;\n" +
            "        }\n" +
            "    }\n" +
            "}\n" +
            "int _hx_cuda_farr_fill_dt_lcg_gpu(int64_t dst_id, int64_t doff, int64_t n,\n" +
            "                                  int64_t seed, double scale) {\n" +
            "    /* IMPORTANT (mk2-FINAL #2 measured): the LCG state evolves\n" +
            "     * sequentially (s_{i+1} = f(s_i)), so the kernel is necessarily\n" +
            "     * single-thread. A GPU thread runs ~100ns/iter — 20× slower than\n" +
            "     * a host C loop (~5ns/iter). For ~100M elements per nn_decoder_\n" +
            "     * init, that's 10s/call on GPU vs 0.5s/call on CPU; 121 calls\n" +
            "     * blew the 901s budget on the v6 fire (GPU 100% util, never\n" +
            "     * reached step 1). Switch to host-side fill: the next forge op\n" +
            "     * (`farr_copy_slice_gpu(M, oTE, tokE, …)` in _agt_decoder_step)\n" +
            "     * triggers _h2d on M as a side-effect of the host-write path\n" +
            "     * marking dirty_host=1, so the data lands on device exactly once\n" +
            "     * per farr, lazily, when it's actually needed. */\n" +
            "    if (dst_id < 0 || dst_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] fill_dt_lcg: bad id\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0 || doff < 0) {\n" +
            "        fprintf(stderr, \"[cuda] fill_dt_lcg: bad n=%lld doff=%lld\\n\",\n" +
            "                (long long)n, (long long)doff);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    HexaFarrEntry* de = &_hx_farr_table[dst_id];\n" +
            "    if (!de->buf || de->len < doff + n) {\n" +
            "        fprintf(stderr, \"[cuda] fill_dt_lcg: range out of bounds\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    /* Pure C host loop — int64_t modular arithmetic byte-identical\n" +
            "     * to the hexa source (`(s * 1103515245 + 12345) % 2^31`). */\n" +
            "    int64_t s = seed;\n" +
            "    double* H = de->buf + doff;\n" +
            "    for (int64_t i = 0; i < n; i++) {\n" +
            "        s = (s * (int64_t)1103515245 + (int64_t)12345) % (int64_t)2147483648;\n" +
            "        double rv = (double)(s % 1000) / 1000.0 - 0.5;\n" +
            "        H[i] = rv * scale;\n" +
            "    }\n" +
            "    /* Mark host-fresh; the next _h2d uploads the new bytes. Do NOT\n" +
            "     * call _d2h_out here — we want the host buffer to be the source\n" +
            "     * of truth, not the device. */\n" +
            "    de->loc        = FARR_HOST;\n" +
            "    de->dirty_host = 1;\n" +
            "    de->dirty_dev  = 0;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C5: device in-place elementwise add dst[i] += src[i] for i ∈\n" +
            " * [0..n). Used by the gradient accumulator (Mg_acc += Mg across the\n" +
            " * micro-batch samples). No FMA-contraction concern — a single\n" +
            " * __dadd_rn per element, byte-eq with host `dst + src` under\n" +
            " * FP_CONTRACT OFF. */\n" +
            "__global__ void _hx_cuda_kern_add_inplace(double* __restrict__ dst,\n" +
            "                                          const double* __restrict__ src,\n" +
            "                                          int64_t n) {\n" +
            "    int64_t i      = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    int64_t stride = (int64_t)gridDim.x  * (int64_t)blockDim.x;\n" +
            "    for (; i < n; i += stride) {\n" +
            "        dst[i] = __dadd_rn(dst[i], src[i]);\n" +
            "    }\n" +
            "}\n" +
            "int _hx_cuda_farr_add_inplace_gpu(int64_t dst_id, int64_t src_id, int64_t n) {\n" +
            "    if (dst_id < 0 || src_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] add_inplace: bad ids\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] add_inplace: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (dst_id >= _hx_farr_count || src_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] add_inplace: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    HexaFarrEntry* de = &_hx_farr_table[dst_id];\n" +
            "    HexaFarrEntry* se = &_hx_farr_table[src_id];\n" +
            "    if (de->len < n || se->len < n) {\n" +
            "        fprintf(stderr, \"[cuda] add_inplace: range out of bounds\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(dst_id) != 0) return -1;\n" +
            "    if (_h2d(src_id) != 0) return -1;\n" +
            "    double* D = g_slots[dst_id].d_buf;\n" +
            "    const double* S = g_slots[src_id].d_buf;\n" +
            "    int block = 256;\n" +
            "    int64_t need = (n + block - 1) / block;\n" +
            "    int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "    _hx_cuda_kern_add_inplace<<<grid, block>>>(D, S, n);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] add_inplace launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(dst_id, de->len) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C5: device zero-fill of dst[doff..doff+n). Used to clear MgOut\n" +
            " * at the top of each grad-gather postlude (~100M-double memset). */\n" +
            "int _hx_cuda_farr_zero_slice_gpu(int64_t dst_id, int64_t doff, int64_t n) {\n" +
            "    if (dst_id < 0 || dst_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] zero_slice: bad id %lld\\n\", (long long)dst_id);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0 || doff < 0) {\n" +
            "        fprintf(stderr, \"[cuda] zero_slice: bad n=%lld doff=%lld\\n\",\n" +
            "                (long long)n, (long long)doff);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    HexaFarrEntry* de = &_hx_farr_table[dst_id];\n" +
            "    if (de->len < doff + n) {\n" +
            "        fprintf(stderr, \"[cuda] zero_slice: range out of bounds\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_ensure_dev_buf(dst_id, de->len) != 0) return -1;\n" +
            "    double* D = g_slots[dst_id].d_buf;\n" +
            "    cudaError_t er = cudaMemset(D + doff, 0, (size_t)n * sizeof(double));\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] zero_slice cudaMemset failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(dst_id, de->len) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* mk2-C5: device-resident 2-D transpose (dst[c·d_out + r] = src[soff +\n" +
            " * r·d_in + c]), byte-eq with agt_wT_slice / agt_wT_off host loop. */\n" +
            "int _hx_cuda_farr_transpose_2d_gpu(int64_t src_id, int64_t soff,\n" +
            "                                   int64_t dst_id, int64_t doff,\n" +
            "                                   int64_t d_out, int64_t d_in) {\n" +
            "    if (src_id < 0 || dst_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_2d: bad ids\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (d_out <= 0 || d_in <= 0 || soff < 0 || doff < 0) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_2d: bad dims\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (src_id >= _hx_farr_count || dst_id >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_2d: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    HexaFarrEntry* se = &_hx_farr_table[src_id];\n" +
            "    HexaFarrEntry* de = &_hx_farr_table[dst_id];\n" +
            "    int64_t total = d_out * d_in;\n" +
            "    if (se->len < soff + total || de->len < doff + total) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_2d: range out of bounds\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(src_id) != 0) return -1;\n" +
            "    if (_ensure_dev_buf(dst_id, de->len) != 0) return -1;\n" +
            "    const double* S = g_slots[src_id].d_buf;\n" +
            "    double* D = g_slots[dst_id].d_buf;\n" +
            "    int block = 256;\n" +
            "    int64_t need = (total + block - 1) / block;\n" +
            "    int grid = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "    _hx_cuda_kern_transpose_2d<<<grid, block>>>(S, soff, D, doff, d_out, d_in);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] transpose_2d launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(dst_id, de->len) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "/* ── flame spiking STDP pair-based GPU kernel ───────────────────────\n" +
            " * inbox/patches/flame-stdp-pair-gpu-kernel.md (anima LEGO arc §141).\n" +
            " * One thread per (i, j) weight cell on an N×N grid. Output bytes\n" +
            " * match the CPU oracle spiking_lib.hexa::flame_stdp_pair exactly —\n" +
            " * single-precision-free scalar fp64 arithmetic, no fma/__dmul_rn\n" +
            " * substitution, same (ltp - ltd) subtraction order, same diagonal\n" +
            " * passthrough + clip. F-STDP-GPU-1 / -2 / -3 are enforced by\n" +
            " * construction. F-STDP-GPU-4 (scale speedup) is a fire-time measure-\n" +
            " * ment gate, not a construction-time invariant. */\n" +
            "__global__ void _hx_cuda_kern_stdp_pair(const double* __restrict__ W,\n" +
            "                                        const double* __restrict__ tr_pre,\n" +
            "                                        const double* __restrict__ tr_post,\n" +
            "                                        const double* __restrict__ spike,\n" +
            "                                        double* __restrict__ out,\n" +
            "                                        int64_t n,\n" +
            "                                        double A_plus, double A_minus,\n" +
            "                                        double w_max) {\n" +
            "    int64_t i = (int64_t)blockIdx.y * (int64_t)blockDim.y + (int64_t)threadIdx.y;\n" +
            "    int64_t j = (int64_t)blockIdx.x * (int64_t)blockDim.x + (int64_t)threadIdx.x;\n" +
            "    if (i >= n || j >= n) return;\n" +
            "    int64_t idx = i * n + j;\n" +
            "    double  w_ij = W[idx];\n" +
            "    double  wd;\n" +
            "    if (i == j) {\n" +
            "        wd = w_ij;\n" +
            "    } else {\n" +
            "        /* IMPORTANT — fma-free byte-equality with the CPU oracle.\n" +
            "         * nvcc auto-fuses `a*b + c` into __fma_rn by default; this would\n" +
            "         * silently diverge from the CPU loop (single-precision-free fp64\n" +
            "         * mul-then-add). Use __dmul_rn / __dadd_rn / __dsub_rn so each\n" +
            "         * scalar op rounds at IEEE-754 round-to-nearest in isolation,\n" +
            "         * matching the host scalar order in spiking_lib.hexa\n" +
            "         * flame_stdp_pair exactly. See feedback memory\n" +
            "         * flame_transcendental_byteeq_hazard.md mechanism (3). */\n" +
            "        double s_i      = spike[i];\n" +
            "        double trpost_i = tr_post[i];\n" +
            "        double tmp1     = __dmul_rn(A_plus,  s_i);\n" +
            "        double ltp      = __dmul_rn(tmp1,    tr_pre[j]);\n" +
            "        double tmp2     = __dmul_rn(A_minus, trpost_i);\n" +
            "        double ltd      = __dmul_rn(tmp2,    spike[j]);\n" +
            "        double dlt      = __dsub_rn(ltp, ltd);\n" +
            "        wd              = __dadd_rn(w_ij, dlt);\n" +
            "    }\n" +
            "    double neg_w_max = 0.0 - w_max;\n" +
            "    if (wd > w_max)     wd = w_max;\n" +
            "    if (wd < neg_w_max) wd = neg_w_max;\n" +
            "    out[idx] = wd;\n" +
            "}\n" +
            "\n" +
            "int _hx_cuda_farr_stdp_pair_gpu(int64_t W_id, int64_t tr_pre_id,\n" +
            "                                int64_t tr_post_id, int64_t spike_id,\n" +
            "                                int64_t out_id, int64_t n,\n" +
            "                                double A_plus, double A_minus,\n" +
            "                                double w_max) {\n" +
            "    if (W_id < 0 || tr_pre_id < 0 || tr_post_id < 0 ||\n" +
            "        spike_id < 0 || out_id < 0) {\n" +
            "        fprintf(stderr, \"[cuda] stdp_pair: bad ids\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (n <= 0) {\n" +
            "        fprintf(stderr, \"[cuda] stdp_pair: bad n=%lld\\n\", (long long)n);\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (W_id      >= _hx_farr_count || tr_pre_id >= _hx_farr_count ||\n" +
            "        tr_post_id>= _hx_farr_count || spike_id  >= _hx_farr_count ||\n" +
            "        out_id    >= _hx_farr_count) {\n" +
            "        fprintf(stderr, \"[cuda] stdp_pair: id out of range\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    int64_t nn = n * n;\n" +
            "    if (_hx_farr_table[W_id].len      < nn ||\n" +
            "        _hx_farr_table[tr_pre_id].len < n  ||\n" +
            "        _hx_farr_table[tr_post_id].len< n  ||\n" +
            "        _hx_farr_table[spike_id].len  < n  ||\n" +
            "        _hx_farr_table[out_id].len    < nn) {\n" +
            "        fprintf(stderr, \"[cuda] stdp_pair: host len mismatch\\n\");\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_h2d(W_id) != 0)       return -1;\n" +
            "    if (_h2d(tr_pre_id) != 0)  return -1;\n" +
            "    if (_h2d(tr_post_id) != 0) return -1;\n" +
            "    if (_h2d(spike_id) != 0)   return -1;\n" +
            "    if (_ensure_dev_buf(out_id, nn) != 0) return -1;\n" +
            "    const double* W      = g_slots[W_id].d_buf;\n" +
            "    const double* tr_pre = g_slots[tr_pre_id].d_buf;\n" +
            "    const double* tr_post= g_slots[tr_post_id].d_buf;\n" +
            "    const double* spike  = g_slots[spike_id].d_buf;\n" +
            "    double*       out    = g_slots[out_id].d_buf;\n" +
            "    /* 2D grid, 16×16 block — one thread per (i,j) cell. Cap each grid\n" +
            "     * dim at 65535 (legacy CUDA 1-D grid ceiling we use elsewhere); at\n" +
            "     * block=16 that covers N up to 16·65535 = 1,048,560 per dim, well\n" +
            "     * past the LEGO arc target (N≤16k). */\n" +
            "    int block_dim = 16;\n" +
            "    int64_t need = (n + block_dim - 1) / block_dim;\n" +
            "    int grid_dim = (int)(need < 1 ? 1 : (need > 65535 ? 65535 : need));\n" +
            "    dim3 block(block_dim, block_dim, 1);\n" +
            "    dim3 grid(grid_dim, grid_dim, 1);\n" +
            "    _hx_cuda_kern_stdp_pair<<<grid, block>>>(W, tr_pre, tr_post, spike,\n" +
            "                                             out, n, A_plus, A_minus, w_max);\n" +
            "    cudaError_t er = cudaGetLastError();\n" +
            "    if (er != cudaSuccess) {\n" +
            "        fprintf(stderr, \"[cuda] stdp_pair launch failed: %s\\n\",\n" +
            "                cudaGetErrorString(er));\n" +
            "        return -1;\n" +
            "    }\n" +
            "    if (_d2h_out(out_id, nn) != 0) return -1;\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "\n" +
            "#endif /* HEXA_CUDA — Agent #25 Phase B elementwise block (opened at line 944) */\n" +
            "\n" +
            "#ifdef __cplusplus\n" +
            "}  /* extern \"C\" */\n" +
            "#endif\n" +
            "\n" +
            "/* ════════════════════════════════════════════════════════════════════\n" +
            " * forge RFC 049 Stage 2 — BF16 mixed-precision substrate.\n" +
            " *\n" +
            " * The `farr_bf16` storage class + `*_bf16_gpu` kernel entry points live\n" +
            " * in the sibling TU runtime_bf16.c. It is `#include`d here (not compiled\n" +
            " * separately) so the BF16 tier shares this file's single `nvcc -x cu`\n" +
            " * build — the same way the FP64 substrate above is one TU. runtime_bf16.c\n" +
            " * carries its own `extern \"C\"` + `#include` guards and gates every\n" +
            " * CUDA-only line behind `#ifdef HEXA_CUDA`, so on a no-CUDA host it\n" +
            " * `cc -fsyntax-only`s clean as plain C.\n" +
            " *\n" +
            " * Stage 2 status: storage-class + kernel-entry SCAFFOLD. The Stage 1\n" +
            " * BF16 fused FFN kernel is already MEASURED PASS (9.67x FP64 cuBLAS,\n" +
            " * self/cuda/experiments/r049_bf16_fused_ffn.cu); the production kernel\n" +
            " * fire-validation is a follow-up cost-bearing cycle.\n" +
            " * ════════════════════════════════════════════════════════════════════ */\n" +
            "#include \"runtime_bf16.c\"\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "runtime_cuda.c" }
    let c_text = emit_runtime_cuda_c()
    let cmd = "cat > \"" + out_path + "\" <<'__HEXA_EMIT_EOF__'\n" +
              c_text + "__HEXA_EMIT_EOF__"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[runtime_cuda_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[runtime_cuda_emit] wrote " + out_path)
    exit(0)
}
