// ═══════════════════════════════════════════════════════════
//  self/stdlib/proc/mountinfo.hexa -- /proc/self/mountinfo parser
//
//  Pure-hexa parser for the Linux /proc/self/mountinfo file format
//  (proc(5), `man 5 proc`). One MountEntry per line. Returns empty
//  list on hosts without /proc (macOS).
//
//  Format (10 fields, space-separated, ` - ` separator between
//  optional-fields and fs-type):
//
//    36 35 98:0 /mnt1 /mnt rw,noatime [optional...] - ext3 /dev/root rw,errors=continue
//    ^  ^  ^    ^     ^    ^         ^              ^ ^    ^         ^
//    |  |  |    |     |    mnt_opts  optional       | type source    super_opts
//    |  |  major:minor
//    |  parent
//    mount_id
//
//  Common consumer: "is <path> mounted?" / "what's its fs type?".
//  pool_mount uses /proc/self/mountinfo for idempotency checks.

use "self/stdlib/fs"

pub struct MountEntry {
    mount_id: int,
    parent_id: int,
    major: int,
    minor: int,
    root: string,
    mount_point: string,
    mount_options: string,
    fs_type: string,
    source: string,
    super_options: string
}

fn _split_ws(s: string) -> [string] {
    let mut out: [string] = []
    let n = len(s)
    let mut i = 0
    while i < n {
        // skip leading whitespace
        while i < n {
            let c = s.substring(i, i + 1)
            if c != " " && c != "\t" { break }
            i = i + 1
        }
        if i >= n { break }
        let start = i
        while i < n {
            let c = s.substring(i, i + 1)
            if c == " " || c == "\t" { break }
            i = i + 1
        }
        out.push(s.substring(start, i))
    }
    return out
}

fn _parse_majmin(s: string) -> [int] {
    // "8:1" -> [8, 1]; malformed -> [0, 0]
    let parts = s.split(":")
    if len(parts) != 2 { return [0, 0] }
    return [to_int(str(parts[0])), to_int(str(parts[1]))]
}

// Parse one mountinfo line. Returns void on malformed input.
pub fn mountinfo_parse_line(line: string) -> any {
    let toks = _split_ws(line.trim())
    if len(toks) < 7 { return void }
    // Find the " - " separator: it's the token equal to exactly "-".
    let mut dash_idx = -1
    let mut i = 5
    while i < len(toks) {
        if str(toks[i]) == "-" { dash_idx = i ; break }
        i = i + 1
    }
    if dash_idx < 0 { return void }
    // After-dash: at least 3 tokens (fs_type, source, super_options).
    if dash_idx + 3 > len(toks) { return void }
    let mm = _parse_majmin(str(toks[2]))
    return MountEntry {
        mount_id:      to_int(str(toks[0])),
        parent_id:     to_int(str(toks[1])),
        major:         mm[0],
        minor:         mm[1],
        root:          str(toks[3]),
        mount_point:   str(toks[4]),
        mount_options: str(toks[5]),
        // optional-fields between idx 6 and dash_idx are skipped here
        // (rarely useful; if a consumer needs them, parse_line v2 can
        // surface them as an [string] list).
        fs_type:       str(toks[dash_idx + 1]),
        source:        str(toks[dash_idx + 2]),
        super_options: str(toks[dash_idx + 3])
    }
}

// Parse the whole mountinfo string -> list of MountEntry. Skips
// malformed lines silently.
pub fn mountinfo_parse(src: string) -> [MountEntry] {
    let mut out: [MountEntry] = []
    let lines = src.split("\n")
    let mut i = 0
    while i < len(lines) {
        let l = str(lines[i])
        if l != "" {
            let e = mountinfo_parse_line(l)
            if type_of(e) != "void" { out.push(e) }
        }
        i = i + 1
    }
    return out
}

// Convenience: read /proc/self/mountinfo (or alt path for tests).
// macOS / any host without /proc returns []. Safe to call anywhere.
pub fn mountinfo_read(path: string) -> [MountEntry] {
    let src = read_file_safe(path)
    if len(src) == 0 { return [] }
    return mountinfo_parse(src)
}

// One-shot: is <mount_point> currently mounted? Returns the
// MountEntry on hit, or void.
pub fn mountinfo_find(entries: [MountEntry], mount_point: string) -> any {
    let mut i = 0
    while i < len(entries) {
        if entries[i].mount_point == mount_point { return entries[i] }
        i = i + 1
    }
    return void
}
