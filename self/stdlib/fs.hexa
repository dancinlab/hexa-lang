// self/stdlib/fs.hexa — Native filesystem stdlib for hexa.
//
// Resolves hive blocker `goal_hexa_native_fs_stdlib`: provides
// fs primitives required by `scripts/install-extensions.mjs` (407 LoC),
// `packages/coding-agent/scripts/gen-embedded-assets.mjs` and the rest
// of the hive `.mjs → .hexa` axis-B port. Without this module, every
// fs op had to be open-coded as `exec("test/ln/readlink/...")` shell
// boilerplate (~700 LoC verbose per script).
//
// Design:
//   - pure hexa (hexa-only) — zero external libs.
//   - delegates to runtime builtins where present (file_exists,
//     read_file, write_file, mkdir, list_dir, dir_exists,
//     delete_file, append_file).
//   - wraps `exec("/bin/...")` for ops the runtime does not expose
//     (lstat-flags, readlink, symlink, unlink-symlink).
//   - never panics on missing files: file_exists==false on missing,
//     read_file_safe→"" on missing, etc. — Node fs/sync semantics.
//
// C3 (no_silent_errors):
//   shell wrappers redirect stderr to /dev/null but ALWAYS verify
//   the post-condition (file present / absent / link points where
//   expected) before returning success. A failed verification
//   returns false / "" so callers can fail-loud upstream.
//
// no-hardcode9 (hexa-lang-upstream-proposal-mandate):
//   This module is the upstream-of-truth for hive's fs ops. hive ports
//   `use "self/stdlib/fs"` and never re-implements these.
//
// --selftest mode:
//   hexa run self/stdlib/fs.hexa --selftest
//     → emits __FS_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
//
// Naming note:
//   The runtime already exposes a `file_exists` builtin (regular files
//   only). We export `fs_exists` for the BROADER existsSync-equivalent
//   (also matches dirs and live symlinks). Use `lstat_exists` if you
//   also want broken/dangling symlinks.
//
// Exports:
//   fs_exists(path) -> bool         // -e (covers files+dirs+live links)
//   lstat_exists(path) -> bool      // -e or -L (also broken symlinks)
//   lstat_is_dir(path) -> bool
//   lstat_is_file(path) -> bool
//   lstat_is_link(path) -> bool
//   lstat_size(path) -> int         // bytes; -1 on missing
//   read_file_safe(path) -> string  // "" on missing
//   write_file_safe(path, content) -> bool
//   read_dir(path) -> [string]      // [] on missing dir
//   fs_readlink(path) -> string     // "" on non-link / missing
//   fs_symlink(target, link_path) -> bool
//   fs_unlink(path) -> bool         // file or symlink; idempotent
//   mkdir_p(path) -> bool           // recursive parents (shell wrap)
//   fs_append_atomic(path, data) -> int    // G5 A2: POSIX O_APPEND, bytes or -errno
//   fs_stat(path) -> [size, mtime_ns, is_dir, mode] | void  // G5 B: POSIX stat(2)
//   fs_stat_size(path) -> int               // G5 B: convenience -1 on missing
//   fs_stat_mtime_ns(path) -> int           // G5 B: convenience -1 on missing
//   fs_rotate_if_over(p, max, suf) -> int   // G5 B: 1=rotated, 0=no, -errno
//   fs_mkdir_p_native(path) -> int          // G5 B: fork-free, 0|-errno

use "self/stdlib/shell_escape"

// ── file_exists ─────────────────────────────────────────────
// Idempotent existence probe. Mirrors Node fs.existsSync.
// Returns false on any error (missing, permission denied,
// dangling symlink). For the DOES-IT-EXIST-INCLUDING-LINKS
// query, use lstat_exists().
fn fs_exists(path) {
    let p = shell_escape(to_string(path))
    let r = to_string(exec("test -e " + p + " && echo 1 || echo 0")).trim()
    return r == "1"
}

// ── lstat_exists ────────────────────────────────────────────
// True if path exists as a regular entry OR a symlink (even if
// the symlink target is missing). Mirrors POSIX `test -e -o -L`.
fn lstat_exists(path) {
    let p = shell_escape(to_string(path))
    let r = to_string(exec("test -e " + p + " -o -L " + p + " && echo 1 || echo 0")).trim()
    return r == "1"
}

// ── lstat_is_dir ────────────────────────────────────────────
// True if path is a directory (follows symlinks — POSIX `test -d`).
fn lstat_is_dir(path) {
    let p = shell_escape(to_string(path))
    let r = to_string(exec("test -d " + p + " && echo 1 || echo 0")).trim()
    return r == "1"
}

// ── lstat_is_file ───────────────────────────────────────────
// True if path is a regular file (follows symlinks).
fn lstat_is_file(path) {
    let p = shell_escape(to_string(path))
    let r = to_string(exec("test -f " + p + " && echo 1 || echo 0")).trim()
    return r == "1"
}

// ── lstat_is_link ───────────────────────────────────────────
// True if path is a symlink itself (does NOT follow). POSIX `test -L`.
fn lstat_is_link(path) {
    let p = shell_escape(to_string(path))
    let r = to_string(exec("test -L " + p + " && echo 1 || echo 0")).trim()
    return r == "1"
}

// ── lstat_size ──────────────────────────────────────────────
// Byte size. -1 on missing. macOS uses `stat -f %z`, Linux uses
// `stat -c %s`; we try both so the same module works on both.
fn lstat_size(path) {
    if !lstat_exists(path) {
        return -1
    }
    let p = shell_escape(to_string(path))
    let s = to_string(exec("stat -f %z " + p + " 2>/dev/null || stat -c %s " + p + " 2>/dev/null || echo 0")).trim()
    return to_int(s)
}

// ── read_file_safe ──────────────────────────────────────────
// Mirrors Node readFileSync(p, 'utf8') but returns "" on missing
// instead of throwing. Use file_exists() first if the empty-vs-
// missing distinction matters.
fn read_file_safe(path) {
    if !fs_exists(path) {
        return ""
    }
    return read_file(to_string(path))
}

// ── write_file_safe ─────────────────────────────────────────
// Writes content to path. Returns true on success. Caller should
// pre-create parent dir via mkdir_p() if needed. C3: verifies
// post-condition (file exists after write).
fn write_file_safe(path, content) {
    write_file(to_string(path), to_string(content))
    return fs_exists(path)
}

// ── read_dir ────────────────────────────────────────────────
// Mirrors Node readdirSync(p). Returns [] on missing dir. Output
// is sorted ascending (POSIX `ls -1A` semantics). Hidden files
// (.dotfiles) ARE included to match Node behavior.
fn read_dir(path) {
    if !lstat_is_dir(path) {
        return []
    }
    let p = shell_escape(to_string(path))
    let raw = to_string(exec("ls -1A " + p + " 2>/dev/null")).trim()
    if raw == "" {
        return []
    }
    return raw.split("\n")
}

// ── fs_readlink ─────────────────────────────────────────────
// Returns the symlink target string, or "" if path is not a
// symlink (or does not exist). Does NOT resolve recursively —
// use path.resolve() for that. Prefix `fs_` avoids collision
// with POSIX C readlink(2) at codegen time.
fn fs_readlink(path) {
    if !lstat_is_link(path) {
        return ""
    }
    let p = shell_escape(to_string(path))
    return to_string(exec("readlink " + p + " 2>/dev/null")).trim()
}

// ── fs_symlink ──────────────────────────────────────────────
// Creates a symlink at link_path pointing to target. Returns
// true on success. If link_path already exists, returns false
// (no clobber). To replace, fs_unlink() first.
fn fs_symlink(target, link_path) {
    if lstat_exists(link_path) {
        return false
    }
    let t = shell_escape(to_string(target))
    let lp = shell_escape(to_string(link_path))
    let _ = exec("ln -s " + t + " " + lp + " 2>/dev/null")
    let actual = fs_readlink(link_path)
    return actual == to_string(target)
}

// ── fs_unlink ───────────────────────────────────────────────
// Removes a file or symlink (NOT a directory — use a separate
// rm-rf wrapper for dirs). Returns true on success or if path
// was already missing (idempotent — idempotency). For broken
// symlinks, `rm -f` works where the `delete_file` builtin
// sometimes does not.
fn fs_unlink(path) {
    if !lstat_exists(path) {
        return true
    }
    let p = shell_escape(to_string(path))
    let _ = exec("rm -f " + p + " 2>/dev/null")
    let still = to_string(exec("test -e " + p + " -o -L " + p + " && echo 1 || echo 0")).trim()
    return still == "0"
}

// ── mkdir_p ─────────────────────────────────────────────────
// Recursive mkdir (Node mkdirSync(p, {recursive:true})).
// Idempotent. Returns true if dir exists after the call.
// Legacy shell-wrap path (`mkdir -p`). For fork-free hot paths
// prefer fs_mkdir_p_native() — the rt_fs_mkdir_p primitive walks
// the path with mkdir(2) directly.
fn mkdir_p(path) {
    let p = shell_escape(to_string(path))
    let _ = exec("mkdir -p " + p + " 2>/dev/null")
    return lstat_is_dir(path)
}

// ── fs_append_atomic ────────────────────────────────────────
// G5 (wilson-pi-port-6-gap S-FS-ATOMIC-APPEND, A2 cycle) primitive.
//
// Concurrent-writer-safe append via POSIX O_APPEND + single write(2).
// The single write() under O_APPEND is atomic with respect to other
// O_APPEND writers iff the byte count is <= PIPE_BUF (4096 B Linux,
// 512 B macOS — POSIX.1-2008 minimum). The caller is responsible for
// chunking; this primitive does NOT split or buffer.
//
// Returns: bytes_written (>= 0) on success, or -errno (< 0) on
// open/write failure. EINTR on write() is retried automatically.
//
// `fs_append_atomic` is wired as a runtime builtin (codegen →
// rt_fs_append_atomic). This wrapper exists for self-documentation
// and so to_string() coercion is centralized.
fn fs_append_atomic_wrap(path, data) {
    return fs_append_atomic(to_string(path), to_string(data))
}

// ── fs_stat ─────────────────────────────────────────────────
// G5 (wilson-pi-port-6-gap, B cycle) — POSIX stat(2) parity.
//
// Returns a 4-element array [size_i64, mtime_ns_i64, is_dir(0/1),
// mode_i64] on success, or hexa_void (none) on stat(2) failure.
// Mode is masked to 0777 perm bits. mtime_ns is high-resolution
// (st_mtim on Linux, st_mtimespec on macOS).
//
// Convenience helpers below: fs_stat_size / fs_stat_mtime_ns
// flatten to -1 on missing for callers that don't care about the
// exists/error distinction.
fn fs_stat_size(path) {
    let st = fs_stat(to_string(path))
    if st == nil { return -1 }
    return st[0]
}

fn fs_stat_mtime_ns(path) {
    let st = fs_stat(to_string(path))
    if st == nil { return -1 }
    return st[1]
}

// ── fs_rotate_if_over ───────────────────────────────────────
// G5 (wilson-pi-port-6-gap, B cycle) — log-rotation primitive.
//
// If fs_stat(path).size > max_bytes, rename(path, path+suffix).
// Returns 1 if rotated, 0 if not (size <= max_bytes or path missing),
// -errno on rename(2) failure.
//
// Single-process atomic: rename(2) is POSIX-atomic. Subsequent
// fs_append_atomic on `path` re-creates the file via O_CREAT.
// NOT safe across rotator processes without external coordination
// (two rotators racing the same file could clobber the suffix
// target). Typical use: log writer rotates from inside its own
// `if size > N { rotate; }` check after each append.
fn fs_rotate_if_over_wrap(path, max_bytes, suffix) {
    return fs_rotate_if_over(to_string(path), max_bytes, to_string(suffix))
}

// ── fs_mkdir_p_native ───────────────────────────────────────
// G5 (wilson-pi-port-6-gap, B cycle) — fork-free recursive mkdir.
//
// POSIX mkdir(2) loop, no shell fork. EEXIST is tolerated iff
// the existing entry is a directory (else -ENOTDIR). Mode 0755
// on creation. Idempotent.
//
// Returns: 0 on success, -errno on failure. Use when shell
// fork-exec cost matters (hot paths, restricted environments).
// The legacy mkdir_p() above remains available for callers that
// want the bool-returning Node-compat signature.
fn fs_mkdir_p_native(path) {
    return fs_mkdir_p(to_string(path))
}

// ── --selftest ──────────────────────────────────────────────
// Fixture-based PASS/FAIL run. Exercises every export with a tmp
// scratch dir. Cleans up after.
fn _fs_selftest() {
    let pid = to_string(exec("echo $$")).trim()
    let scratch = "/tmp/_hexa_fs_selftest_" + pid
    let _ = exec("rm -rf " + shell_escape(scratch))
    let mut fail = 0
    let mut n = 0

    // 1. mkdir_p creates nested dir
    n = n + 1
    if !mkdir_p(scratch + "/a/b/c") {
        eprintln("FAIL 1 mkdir_p")
        fail = fail + 1
    }

    // 2. fs_exists positive (dir — broader than builtin file_exists)
    n = n + 1
    if !fs_exists(scratch + "/a/b/c") {
        eprintln("FAIL 2 fs_exists(dir)")
        fail = fail + 1
    }

    // 3. fs_exists negative
    n = n + 1
    if fs_exists(scratch + "/does_not_exist_xyz") {
        eprintln("FAIL 3 fs_exists(missing) should be false")
        fail = fail + 1
    }

    // 4. write_file_safe + read_file_safe
    n = n + 1
    let file_path = scratch + "/a/hello.txt"
    if !write_file_safe(file_path, "world") {
        eprintln("FAIL 4 write_file_safe")
        fail = fail + 1
    }
    n = n + 1
    let content = read_file_safe(file_path)
    if content != "world" {
        eprintln("FAIL 5 read_file_safe got: " + content)
        fail = fail + 1
    }

    // 5. read_file_safe on missing -> ""
    n = n + 1
    let empty = read_file_safe(scratch + "/missing.txt")
    if empty != "" {
        eprintln("FAIL 6 read_file_safe(missing) should be empty")
        fail = fail + 1
    }

    // 6. lstat regular file
    n = n + 1
    if !lstat_is_file(file_path) || lstat_is_dir(file_path) || lstat_is_link(file_path) {
        eprintln("FAIL 7 lstat(file) wrong flags")
        fail = fail + 1
    }

    // 7. lstat directory
    n = n + 1
    if !lstat_is_dir(scratch + "/a/b/c") || lstat_is_file(scratch + "/a/b/c") {
        eprintln("FAIL 8 lstat(dir) wrong flags")
        fail = fail + 1
    }

    // 8. lstat missing
    n = n + 1
    if lstat_exists(scratch + "/missing") {
        eprintln("FAIL 9 lstat(missing) should be false")
        fail = fail + 1
    }

    // 9. symlink + readlink + lstat(link)
    n = n + 1
    let link_path = scratch + "/link.txt"
    if !fs_symlink(file_path, link_path) {
        eprintln("FAIL 10 symlink create")
        fail = fail + 1
    }
    n = n + 1
    let target_resolved = fs_readlink(link_path)
    if target_resolved != file_path {
        eprintln("FAIL 11 readlink got: " + target_resolved)
        fail = fail + 1
    }
    n = n + 1
    if !lstat_is_link(link_path) {
        eprintln("FAIL 12 lstat_is_link(link) should be true")
        fail = fail + 1
    }

    // 10. readlink on non-link -> ""
    n = n + 1
    let nolink = fs_readlink(file_path)
    if nolink != "" {
        eprintln("FAIL 13 readlink(non-link) should be empty")
        fail = fail + 1
    }

    // 11. read_dir
    n = n + 1
    let entries = read_dir(scratch + "/a")
    let mut has_b = false
    let mut has_hello = false
    let mut i = 0
    while i < len(entries) {
        if entries[i] == "b" { has_b = true }
        if entries[i] == "hello.txt" { has_hello = true }
        i = i + 1
    }
    if !has_b || !has_hello {
        eprintln("FAIL 14 read_dir missing entries")
        fail = fail + 1
    }

    // 12. read_dir on missing -> []
    n = n + 1
    let nodir = read_dir(scratch + "/no_such_dir")
    if len(nodir) != 0 {
        eprintln("FAIL 15 read_dir(missing) should be []")
        fail = fail + 1
    }

    // 13. lstat_size positive
    n = n + 1
    let sz = lstat_size(file_path)
    if sz != 5 {
        eprintln("FAIL 16 lstat_size('world') should be 5 got " + to_string(sz))
        fail = fail + 1
    }

    // 14. unlink file
    n = n + 1
    if !fs_unlink(file_path) {
        eprintln("FAIL 17 fs_unlink(file)")
        fail = fail + 1
    }
    n = n + 1
    if fs_exists(file_path) {
        eprintln("FAIL 18 file still exists after fs_unlink")
        fail = fail + 1
    }

    // 15. fs_unlink symlink (now a dangling link — make sure fs_unlink
    // still removes it correctly)
    n = n + 1
    if !fs_unlink(link_path) {
        eprintln("FAIL 19 fs_unlink(symlink)")
        fail = fail + 1
    }

    // 16. fs_unlink missing -> idempotent true (idempotency)
    n = n + 1
    if !fs_unlink(scratch + "/never_existed") {
        eprintln("FAIL 20 unlink(missing) should be idempotent true")
        fail = fail + 1
    }

    // 17. fs_append_atomic — single-write O_APPEND primitive (G5 A2).
    // Round-trip: write "hello\n" + "world\n" sequentially, expect
    // 6+6 bytes returned, file content "hello\nworld\n", lstat_size==12.
    n = n + 1
    let log_path = scratch + "/atomic.log"
    let w1 = fs_append_atomic(log_path, "hello\n")
    if w1 != 6 {
        eprintln("FAIL 21 fs_append_atomic write1 expected 6 got " + to_string(w1))
        fail = fail + 1
    }
    n = n + 1
    let w2 = fs_append_atomic(log_path, "world\n")
    if w2 != 6 {
        eprintln("FAIL 22 fs_append_atomic write2 expected 6 got " + to_string(w2))
        fail = fail + 1
    }
    n = n + 1
    let log_content = read_file_safe(log_path)
    if log_content != "hello\nworld\n" {
        eprintln("FAIL 23 fs_append_atomic content mismatch: " + log_content)
        fail = fail + 1
    }
    n = n + 1
    if lstat_size(log_path) != 12 {
        eprintln("FAIL 24 fs_append_atomic size expected 12 got " + to_string(lstat_size(log_path)))
        fail = fail + 1
    }

    // 18. fs_append_atomic — open-failure path returns negative errno.
    // Writing into a non-existent parent dir → -ENOENT (Linux: -2, macOS: -2).
    n = n + 1
    let err_rc = fs_append_atomic(scratch + "/no_such_subdir/x.log", "x")
    if err_rc >= 0 {
        eprintln("FAIL 25 fs_append_atomic(missing-parent) expected negative errno got " + to_string(err_rc))
        fail = fail + 1
    }

    // 19. fs_stat — round-trip on the atomic.log file (12 bytes,
    //     not a dir, mode bits set). G5 B.
    n = n + 1
    let st = fs_stat(log_path)
    if st == nil {
        eprintln("FAIL 26 fs_stat(atomic.log) returned nil")
        fail = fail + 1
    } else {
        n = n + 1
        if st[0] != 12 {
            eprintln("FAIL 27 fs_stat size expected 12 got " + to_string(st[0]))
            fail = fail + 1
        }
        n = n + 1
        if st[1] <= 0 {
            eprintln("FAIL 28 fs_stat mtime_ns should be > 0 got " + to_string(st[1]))
            fail = fail + 1
        }
        n = n + 1
        if st[2] != 0 {
            eprintln("FAIL 29 fs_stat is_dir on file expected 0 got " + to_string(st[2]))
            fail = fail + 1
        }
        n = n + 1
        if st[3] <= 0 {
            eprintln("FAIL 30 fs_stat mode should be > 0 got " + to_string(st[3]))
            fail = fail + 1
        }
    }

    // 20. fs_stat — directory case (is_dir == 1).
    n = n + 1
    let dst = fs_stat(scratch + "/a/b/c")
    if dst == nil {
        eprintln("FAIL 31 fs_stat(dir) returned nil")
        fail = fail + 1
    } else {
        n = n + 1
        if dst[2] != 1 {
            eprintln("FAIL 32 fs_stat is_dir on dir expected 1 got " + to_string(dst[2]))
            fail = fail + 1
        }
    }

    // 21. fs_stat — missing path returns void (nil).
    n = n + 1
    let mst = fs_stat(scratch + "/no_such_path_xyz")
    if mst != nil {
        eprintln("FAIL 33 fs_stat(missing) expected nil")
        fail = fail + 1
    }

    // 22. fs_stat_size / fs_stat_mtime_ns helpers — -1 on missing.
    n = n + 1
    if fs_stat_size(scratch + "/no_such_path_xyz") != -1 {
        eprintln("FAIL 34 fs_stat_size(missing) expected -1")
        fail = fail + 1
    }
    n = n + 1
    if fs_stat_mtime_ns(scratch + "/no_such_path_xyz") != -1 {
        eprintln("FAIL 35 fs_stat_mtime_ns(missing) expected -1")
        fail = fail + 1
    }
    n = n + 1
    if fs_stat_size(log_path) != 12 {
        eprintln("FAIL 36 fs_stat_size(log_path) expected 12 got " + to_string(fs_stat_size(log_path)))
        fail = fail + 1
    }

    // 23. fs_rotate_if_over — size=12 bytes, max=100 → no rotation (rc=0).
    n = n + 1
    let r_no = fs_rotate_if_over(log_path, 100, ".1")
    if r_no != 0 {
        eprintln("FAIL 37 fs_rotate(size<=max) expected 0 got " + to_string(r_no))
        fail = fail + 1
    }
    n = n + 1
    if !fs_exists(log_path) {
        eprintln("FAIL 38 fs_rotate(no-op) should leave file alone")
        fail = fail + 1
    }

    // 24. fs_rotate_if_over — size=12 bytes, max=5 → rotate (rc=1).
    //     log_path should be missing; log_path+".1" should hold the content.
    n = n + 1
    let r_yes = fs_rotate_if_over(log_path, 5, ".1")
    if r_yes != 1 {
        eprintln("FAIL 39 fs_rotate(size>max) expected 1 got " + to_string(r_yes))
        fail = fail + 1
    }
    n = n + 1
    if fs_exists(log_path) {
        eprintln("FAIL 40 fs_rotate should have moved log_path away")
        fail = fail + 1
    }
    n = n + 1
    if !fs_exists(log_path + ".1") {
        eprintln("FAIL 41 fs_rotate should have created log_path+.1")
        fail = fail + 1
    }
    n = n + 1
    if read_file_safe(log_path + ".1") != "hello\nworld\n" {
        eprintln("FAIL 42 rotated content mismatch")
        fail = fail + 1
    }

    // 25. fs_rotate_if_over — missing source → rc=0 (no-op, not error).
    n = n + 1
    let r_mis = fs_rotate_if_over(scratch + "/no_such_log", 100, ".1")
    if r_mis != 0 {
        eprintln("FAIL 43 fs_rotate(missing) expected 0 got " + to_string(r_mis))
        fail = fail + 1
    }

    // 26. fs_mkdir_p (rt builtin) — fresh nested dir, rc=0, dir exists.
    n = n + 1
    let nest = scratch + "/n1/n2/n3"
    if fs_mkdir_p(nest) != 0 {
        eprintln("FAIL 44 fs_mkdir_p(nest) expected 0")
        fail = fail + 1
    }
    n = n + 1
    if !lstat_is_dir(nest) {
        eprintln("FAIL 45 fs_mkdir_p target should be a dir")
        fail = fail + 1
    }

    // 27. fs_mkdir_p — idempotent: second call on existing dir = rc=0.
    n = n + 1
    if fs_mkdir_p(nest) != 0 {
        eprintln("FAIL 46 fs_mkdir_p(idempotent) expected 0")
        fail = fail + 1
    }

    // 28. fs_mkdir_p — over a regular file → -ENOTDIR (negative).
    n = n + 1
    let regf = scratch + "/n1/regular_file"
    write_file_safe(regf, "")
    let bad_rc = fs_mkdir_p(regf + "/subdir")
    if bad_rc >= 0 {
        eprintln("FAIL 47 fs_mkdir_p(over-file) expected -errno got " + to_string(bad_rc))
        fail = fail + 1
    }

    let _ = exec("rm -rf " + shell_escape(scratch))

    if fail == 0 {
        println("__FS_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__FS_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _fs_argv = args()
let mut _fs_selftest_flag = false
let mut _fs_ai = 0
while _fs_ai < len(_fs_argv) {
    if _fs_argv[_fs_ai] == "--selftest-fs" { _fs_selftest_flag = true }
    if _fs_argv[_fs_ai] == "--selftest" { _fs_selftest_flag = true }
    _fs_ai = _fs_ai + 1
}
if _fs_selftest_flag {
    _fs_selftest()
}
