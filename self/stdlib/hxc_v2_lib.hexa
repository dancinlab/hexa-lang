#!hexa strict

use "self/stdlib/hxc_composite_chain_v2"

// hxc_v2_lib — DOWNSTREAM-CALLABLE HXC v2 library surface
// ════════════════════════════════════════════════════════════════════
//
// PURPOSE
//   Resolves archive/patches/hxc-v2-no-downstream-library-api.md by
//   exposing a minimum stable, library-callable surface for the HXC v2
//   composite codec (`cc2_encode`/`cc2_decode` lifted from CLI-only
//   `fn` to `pub fn`, plus a records-pair built on top of the same
//   chain). The patch source — downstream `wisp` Decision 8 option A —
//   asked for a swappable encode/decode pair so machine-readable
//   surfaces (audit ledgers, witness rows, dispatch envelopes) can
//   honor `@D g_hxc` without shelling out to the interpreter
//   (`@D g_interp_deprecated` would forbid that anyway).
//
// PRIVACY / NON-DUPLICATION
//   This file does NOT re-implement codec logic. It is a thin
//   re-export wrapper around the existing
//   `self/stdlib/hxc_composite_chain_v2.hexa` primitives
//   (`cc2_encode` / `cc2_decode`). Those in turn compose
//   `hxc_a29_deflate.hexa` (LZ + canonical Huffman) and
//   `hxc_a30_bwt_mtf.hexa` (BWT + MTF + RLE + range coder) with the
//   `magic-number2 D2` shortest-of-{composite, A29, A30, identity}
//   try-revert. Any codec maintenance lands upstream of this file.
//
// PUBLIC API (stable surface — downstream consumers may rely on these
// signatures across hexa-lang revisions; the underlying chain is
// allowed to evolve as long as round-trip semantics hold):
//
//   pub fn hxc_v2_encode(s: string) -> string
//   pub fn hxc_v2_decode(z: string) -> string
//   pub fn hxc_v2_encode_records(rows: array) -> string
//   pub fn hxc_v2_decode_records(blob: string) -> array
//
// SEMANTICS (idempotency + 68 + 137 inherited from cc2_encode):
//   * `hxc_v2_decode(hxc_v2_encode(s)) == s` for every `s`.
//   * `hxc_v2_encode(hxc_v2_encode(s)) == hxc_v2_encode(s)` (header
//     short-circuit; the v2 chain refuses to re-wrap its own output).
//   * Input below `CC2_MIN_BYTES` (64) passes through unchanged (D2
//     try-revert always prefers identity when it is shortest).
//   * Non-v2 input to `hxc_v2_decode` falls back to A29/A30/identity
//     passthrough (the chain's documented behaviour).
//
// RECORDS WIRE FORMAT (mirrors `compiler/atlas/hxc_loader.hexa`
// pipe-escape convention):
//   row    := cell ( "|" cell )*
//   blob   := row ( "\n" row )*       // trailing newline allowed
//   cell   := raw text with `\` → `\\` and `|` → `\|` escapes
//   The text blob is then passed through `cc2_encode` / `cc2_decode`.
//   Decoder splits the trailing `\n` if present.
//
// COMPLIANCE NOTES
//   * `@D g5` hexa-native-only — pure hexa, no LLVM/C-transpile-only
//     primitive. The chain compiles via the canonical
//     `.hexa → hexa_v2 → C → clang` pipeline.
//   * `@D g6` citation-enforced — this wrapper carries NO formula
//     lines, only re-exports. The cited theorems live in
//     `hxc_composite_chain_v2.hexa` (A29 RFC 1951 / A30 BWT chain).
//   * `@D g_interp_deprecated` — wrapper has no `fn main()`; it is a
//     pure library, callable from `hexa build`-produced binaries
//     without the interpreter.
//   * `@D g_hxc` — this file is the downstream-callable bridge that
//     makes the recommendation reachable for non-atlas consumers.
//   * `@X x_hxc_spec` — wire format is the canonical HXC v2 composite
//     envelope (header `# cc:s2 v=composite-byte-v1 chain=C1 …`).
//
// THREAD-SAFETY / DETERMINISM
//   The chain is byte-deterministic (no FP, no RNG, no neural mixer).
//   The wrapper adds no state. Re-entry-safe within a single
//   interpreter-free compiled binary.

// ───────────────── plain-string surface ─────────────────

pub fn hxc_v2_encode(s: string) -> string {
    return cc2_encode(s)
}

pub fn hxc_v2_decode(z: string) -> string {
    return cc2_decode(z)
}

// ───────────────── records surface (pipe-escape rows) ─────────────────

fn _hxc_v2_lib_escape_cell(c: string) -> string {
    // `\` → `\\`, `|` → `\|`. Order matters — backslash first so we do
    // not double-escape an escape we just produced.
    if !c.contains("\\") {
        if !c.contains("|") { return c }
        return c.replace("|", "\\|")
    }
    let with_bs = c.replace("\\", "\\\\")
    if !with_bs.contains("|") { return with_bs }
    return with_bs.replace("|", "\\|")
}

fn _hxc_v2_lib_unescape_cell(c: string) -> string {
    // Sentinel-swap mirror of compiler/atlas/hxc_loader.hexa::_unesc_pipe.
    if !c.contains("\\") { return c }
    let SENTINEL = ""
    let s1 = c.replace("\\\\", SENTINEL)
    let s2 = s1.replace("\\|", "|")
    return s2.replace(SENTINEL, "\\")
}

fn _hxc_v2_lib_ends_with_odd_backslash(s: string) -> bool {
    let n: i64 = len(s)
    let mut k: i64 = 0
    let mut j: i64 = n - 1
    while j >= 0 {
        if s.substring(j, j + 1) == "\\" {
            k = k + 1
            j = j - 1
        } else {
            break
        }
    }
    return (k - (k / 2) * 2) == 1
}

fn _hxc_v2_lib_split_pipes(row: string) -> array {
    // Mirrors hxc_loader._split_pipes — split on `|` then re-merge any
    // false split where the preceding cell ends in an odd number of
    // trailing backslashes (i.e. the `|` was originally `\|`).
    let parts = row.split("|")
    let mut out = []
    let mut i: i64 = 0
    while i < len(parts) {
        let mut cur = parts[i]
        while _hxc_v2_lib_ends_with_odd_backslash(cur) && i + 1 < len(parts) {
            cur = cur + "|" + parts[i + 1]
            i = i + 1
        }
        out.push(cur)
        i = i + 1
    }
    return out
}

pub fn hxc_v2_encode_records(rows: array) -> string {
    // Serialize rows → pipe-escape blob → cc2_encode. Empty input is a
    // zero-byte blob, which cc2_encode short-circuits to identity.
    let n_rows: i64 = len(rows)
    let mut out_rows = []
    let mut i: i64 = 0
    while i < n_rows {
        let row = rows[i]
        let mut cells = []
        let mut j: i64 = 0
        let n_cells: i64 = len(row)
        while j < n_cells {
            cells.push(_hxc_v2_lib_escape_cell(row[j]))
            j = j + 1
        }
        out_rows.push(cells.join("|"))
        i = i + 1
    }
    let blob = out_rows.join("\n")
    return cc2_encode(blob)
}

pub fn hxc_v2_decode_records(blob: string) -> array {
    // cc2_decode → split on `\n` → pipe-aware unescape each cell.
    // Tolerates a trailing newline (drops empty final row).
    let raw = cc2_decode(blob)
    if len(raw) == 0 { return [] }
    let rows_raw = raw.split("\n")
    let n_rows: i64 = len(rows_raw)
    let mut out = []
    let mut i: i64 = 0
    while i < n_rows {
        let row_str = rows_raw[i]
        // Drop a single trailing empty row (artifact of trailing `\n`).
        if i == n_rows - 1 && len(row_str) == 0 { break }
        let cells_esc = _hxc_v2_lib_split_pipes(row_str)
        let mut cells = []
        let mut j: i64 = 0
        let n_cells: i64 = len(cells_esc)
        while j < n_cells {
            cells.push(_hxc_v2_lib_unescape_cell(cells_esc[j]))
            j = j + 1
        }
        out.push(cells)
        i = i + 1
    }
    return out
}
