#!hexa lax
// self/lexer.hexa — HEXA lexer written in HEXA (Stage 1 of self-hosting)
// Tokenizes HEXA source code into the same token sequence as the Rust lexer.

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

// Check if a word is one of the 56 HEXA keywords (sigma*tau+sopfr+3) + import alias
fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "match" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "loop" { return true }
    if word == "type" { return true }
    if word == "struct" { return true }
    if word == "enum" { return true }
    if word == "trait" { return true }
    if word == "impl" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "yield" { return true }
    if word == "async" { return true }
    if word == "await" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "static" { return true }
    if word == "mod" { return true }
    if word == "use" { return true }
    if word == "import" { return true }
    if word == "pub" { return true }
    if word == "crate" { return true }
    if word == "own" { return true }
    if word == "borrow" { return true }
    if word == "move" { return true }
    if word == "drop" { return true }
    if word == "spawn" { return true }
    if word == "atomic" { return true }
    if word == "handle" { return true }
    if word == "resume" { return true }
    if word == "pure" { return true }
    if word == "proof" { return true }
    if word == "assert" { return true }
    if word == "invariant" { return true }
    if word == "theorem" { return true }
    if word == "macro" { return true }
    if word == "where" { return true }
    if word == "comptime" { return true }
    if word == "try" { return true }
    if word == "catch" { return true }
    if word == "throw" { return true }
    if word == "panic" { return true }
    if word == "recover" { return true }
    if word == "extern" { return true }
    if word == "break" { return true }
    if word == "continue" { return true }
    if word == "dyn" { return true }
    if word == "in" { return true }
    if word == "do" { return true }
    if word == "defer" { return true }
    if word == "typeof" { return true }
    if word == "with" { return true }
    if word == "as" { return true }
    // Termination policy modifiers were reserved 2026-05-06 but pulled
    // 2026-05-07 — `partial fn` / `total fn` bare-keyword syntax has zero
    // in-tree users and the reservation broke 30+ files using `let total =`
    // and `let mut total = 0` as ordinary identifiers (RFC-010 self-
    // bootstrap collision). Use `@partial` / `@total` attribute annotations
    // (parser-level) instead.
    return false
}

// Get the keyword kind for a word (returns "Ident" if not a keyword)
fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if word == "import" { return "Use" }
    if is_keyword(word) {
        // Capitalize first letter for kind name
        let first = to_string(word.chars()[0]).to_upper()
        let mut rest_parts = []
        let chars = word.chars()
        let mut i = 1
        while i < len(chars) {
            rest_parts.push(to_string(chars[i]))
            i = i + 1
        }
        return first + join(rest_parts, "")
    }
    return "Ident"
}

// Unicode identifiers (Go/Rust canonical — round-10 r10-4). The lexer is
// byte-oriented (source.chars() yields single-byte strings over UTF-8), so
// any byte with the high bit set (>= 0x80) is part of a UTF-8 multibyte
// sequence — i.e. a non-ASCII letter. We pragmatically treat every such byte
// as an identifier byte (both start and continue), which accepts `café`,
// `λ`, `日本語` etc. without a full Unicode XID table. ASCII rules unchanged.
// Go: identifier = letter { letter | unicode_digit }, letter = unicode_letter | "_".
@pure
fn is_unicode_byte(ch) {
    return char_code(ch, 0) >= 128
}

// Check if character is valid identifier start (alpha, _, or unicode byte)
@pure
fn is_ident_start(ch) {
    if is_alpha(ch) { return true }
    if ch == '_' { return true }
    if is_unicode_byte(ch) { return true }
    return false
}

// Check if character is valid identifier continuation (alphanumeric, _, or unicode byte)
@pure
fn is_ident_char(ch) {
    if is_alphanumeric(ch) { return true }
    if ch == '_' { return true }
    if is_unicode_byte(ch) { return true }
    return false
}

// Check if character is a hex digit (0-9, a-f, A-F)
fn is_hex_digit(ch) {
    if is_digit(ch) { return true }
    if ch == 'a' || ch == 'b' || ch == 'c' || ch == 'd' || ch == 'e' || ch == 'f' { return true }
    if ch == 'A' || ch == 'B' || ch == 'C' || ch == 'D' || ch == 'E' || ch == 'F' { return true }
    return false
}

// Main tokenizer function
@compile_trace
pub fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let len_chars = len(chars)
    let mut paren_depth = 0

    // POSIX shebang: if source begins with `#!`, skip the entire first line
    // so `#!/usr/bin/env python3` does not leak `usr`, `bin`, etc. as idents.
    if len_chars >= 2 && chars[0] == '#' && chars[1] == '!' {
        while pos < len_chars && chars[pos] != '\n' {
            pos = pos + 1
            col = col + 1
        }
    }

    while pos < len_chars {
        let ch = chars[pos]

        // Skip whitespace (not newlines)
        if ch == ' ' || ch == '\t' || ch == '\r' {
            pos = pos + 1
            col = col + 1
            // Continue to next iteration
        } else if ch == '\n' {
            // Newline token — suppressed inside () and []
            if paren_depth == 0 {
                tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
            }
            pos = pos + 1
            line = line + 1
            col = 1
        } else if ch == '/' && pos + 1 < len_chars && chars[pos + 1] == '/' {
            // Line comment — skip until newline
            pos = pos + 2
            col = col + 2
            while pos < len_chars && chars[pos] != '\n' {
                pos = pos + 1
                col = col + 1
            }
        } else if ch == '/' && pos + 1 < len_chars && chars[pos + 1] == '*' {
            // Block comment (supports nesting)
            pos = pos + 2
            col = col + 2
            let mut depth = 1
            while depth > 0 && pos < len_chars {
                if pos + 1 < len_chars && chars[pos] == '/' && chars[pos + 1] == '*' {
                    depth = depth + 1
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos] == '*' && chars[pos + 1] == '/' {
                    depth = depth - 1
                    pos = pos + 2
                    col = col + 2
                } else if chars[pos] == '\n' {
                    pos = pos + 1
                    line = line + 1
                    col = 1
                } else {
                    pos = pos + 1
                    col = col + 1
                }
            }
        } else if is_ident_start(ch) {
            // Identifier or keyword
            let start_col = col
            let mut word_parts = []
            while pos < len_chars && is_ident_char(chars[pos]) {
                word_parts.push(to_string(chars[pos]))
                pos = pos + 1
                col = col + 1
            }
            let word = join(word_parts, "")
            let kind = keyword_kind(word)
            tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
        } else if is_digit(ch) {
            // Number literal — integer, float, or hex (0x)
            // Underscore separators: 1_000_000 -> 1000000, 0xFF_FF -> 0xFFFF
            // Rules: _ only between digits, no leading/trailing _, no consecutive __
            let start_col = col
            let mut num_parts = []
            let mut is_float = false
            let mut is_hex = false

            // Reject octal (`0o…`) / binary (`0b…`) prefixes loudly.  hexa
            // does not yet implement them, and the prior silence let `0o17`
            // / `0b1010` lex as `0` + identifier `o17` / `b1010`, leaking
            // through to clang as `undeclared identifier 'o17'`.  Fail
            // loud at lex time with a clear hint instead.
            if ch == '0' && pos + 1 < len_chars && (chars[pos + 1] == 'o' || chars[pos + 1] == 'O' || chars[pos + 1] == 'b' || chars[pos + 1] == 'B') && pos + 2 < len_chars && is_digit(chars[pos + 2]) {
                let _prefix = "0" + to_string(chars[pos + 1])
                println("error: literal prefix `" + _prefix + "` (octal/binary) not supported at line " + to_string(line) + ":" + to_string(start_col) + " — use decimal or `0x` hex")
                exit(1)
            }
            // Check for hex prefix 0x / 0X
            if ch == '0' && pos + 1 < len_chars && (chars[pos + 1] == 'x' || chars[pos + 1] == 'X') {
                is_hex = true
                num_parts.push("0x")
                pos = pos + 2
                col = col + 2
                // Collect hex digits; accept _ only between hex digits (lookahead)
                while pos < len_chars && is_hex_digit(chars[pos]) {
                    num_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                    // After a hex digit, consume a single _ if followed by another hex digit
                    if pos < len_chars && chars[pos] == '_' {
                        if pos + 1 < len_chars && is_hex_digit(chars[pos + 1]) {
                            // Valid separator — skip _ and let loop consume next digit
                            pos = pos + 1
                            col = col + 1
                        }
                        // else: trailing _ or __ — stop; _ left for next token
                    }
                }
                // PROBE r14-B: IEEE 754 hex-float literal `0x1.8p+1`.
                // After hex significand digits, if we see `.<hexdigit>` or
                // `p`/`P`, switch to float mode. C99 hex-float syntax:
                //   hex-prefix  hex-digits [ . hex-digits ]  p|P [+-]? decimal-digits
                // Significand+exponent form (`0x1p+0`) and dotted form (`0x1.8p+1`)
                // both supported. The exponent suffix is REQUIRED in C99 — without
                // `p` the literal would be ambiguous (hex digits vs hex range `..`).
                // We pass the literal text through as the FloatLit value; both
                // downstream paths handle it: C codegen emits `hexa_float(0x1.8p+1)`
                // which is a valid C99 hex-float literal, and the comptime folder
                // calls strtod() which natively accepts C hex-floats.
                let mut is_hex_float = false
                // Optional fractional part: `.<hexdigit>`
                if pos + 1 < len_chars && chars[pos] == '.' && is_hex_digit(chars[pos + 1]) {
                    is_hex_float = true
                    num_parts.push(".")
                    pos = pos + 1
                    col = col + 1
                    while pos < len_chars && is_hex_digit(chars[pos]) {
                        num_parts.push(to_string(chars[pos]))
                        pos = pos + 1
                        col = col + 1
                        if pos < len_chars && chars[pos] == '_' {
                            if pos + 1 < len_chars && is_hex_digit(chars[pos + 1]) {
                                pos = pos + 1
                                col = col + 1
                            }
                        }
                    }
                }
                // Binary exponent `p`/`P` [+-]? decimal-digits.
                // If a `.<hexdigit>` was consumed, the exponent is required (C99);
                // otherwise the bare `p` triggers the hex-float transition.
                if pos < len_chars && (chars[pos] == 'p' || chars[pos] == 'P') {
                    let mut ep = pos + 1
                    if ep < len_chars && (chars[ep] == '+' || chars[ep] == '-') { ep = ep + 1 }
                    if ep < len_chars && is_digit(chars[ep]) {
                        is_hex_float = true
                        num_parts.push(to_string(chars[pos]))
                        pos = pos + 1
                        col = col + 1
                        if pos < len_chars && (chars[pos] == '+' || chars[pos] == '-') {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                        while pos < len_chars && is_digit(chars[pos]) {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                    } else if is_hex_float {
                        // Already saw `.<hex>` so exponent is required.
                        println("error: hex-float literal requires binary exponent `p±N` at line " + to_string(line) + ":" + to_string(start_col) + " — e.g. `0x1.8p+1`")
                        exit(1)
                    }
                }
                if is_hex_float {
                    is_float = true
                    is_hex = false
                }
            } else {
                // Decimal integer part: collect digits; accept _ only between digits
                while pos < len_chars && is_digit(chars[pos]) {
                    num_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                    // After a digit, consume a single _ if followed by another digit
                    if pos < len_chars && chars[pos] == '_' {
                        if pos + 1 < len_chars && is_digit(chars[pos + 1]) {
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
                // Check for decimal point (not range ..)
                if pos < len_chars && chars[pos] == '.' {
                    if pos + 1 < len_chars && is_digit(chars[pos + 1]) {
                        // It's a float: consume . and fractional digits
                        is_float = true
                        num_parts.push(".")
                        pos = pos + 1
                        col = col + 1
                        while pos < len_chars && is_digit(chars[pos]) {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                            // After a digit, consume a single _ if followed by another digit
                            if pos < len_chars && chars[pos] == '_' {
                                if pos + 1 < len_chars && is_digit(chars[pos + 1]) {
                                    pos = pos + 1
                                    col = col + 1
                                }
                            }
                        }
                    }
                }
                // Scientific notation: e/E [+-]? digits (1e10, 1e-5, 1.5e+3)
                // Lookahead: only consume `e` if followed by optional sign + digit,
                // otherwise leave `e` for identifier lexer (e.g. `1err` — unlikely but safe).
                if pos < len_chars && (chars[pos] == 'e' || chars[pos] == 'E') {
                    let mut ep = pos + 1
                    if ep < len_chars && (chars[ep] == '+' || chars[ep] == '-') { ep = ep + 1 }
                    if ep < len_chars && is_digit(chars[ep]) {
                        is_float = true
                        num_parts.push(to_string(chars[pos]))
                        pos = pos + 1
                        col = col + 1
                        if pos < len_chars && (chars[pos] == '+' || chars[pos] == '-') {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                        while pos < len_chars && is_digit(chars[pos]) {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
            }
            let num_str = join(num_parts, "")
            // Reject literal suffix adjacency loudly.  `5i32` / `5_i32`
            // / `1.0f32` (Rust-style typed-suffix) — and `1e5` scientific
            // (not yet supported) — were silently lexed as a numeric
            // token followed by a bare identifier (`i32` / `_i32` / `f32`
            // / `e5`), which then leaked through to clang as
            // `undeclared identifier`.  Fail loud at the lex site.
            // Underscore separator `1_000_000` is unaffected: the existing
            // decimal loop consumes `_` only when followed by a digit, so
            // it never reaches this check.
            if pos < len_chars && is_ident_start(chars[pos]) {
                println("error: literal suffix `" + num_str + to_string(chars[pos]) + "…` not supported at line " + to_string(line) + ":" + to_string(start_col) + " — typed-suffix (`5i32`, `1.0f32`, scientific `1e5`) is not yet implemented")
                exit(1)
            }
            if is_float {
                tokens.push(Token { kind: "FloatLit", value: num_str, line: line, col: start_col })
            } else {
                tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
            }
        } else if ch == '"' {
            // String literal — check for triple-quote """
            let start_col = col
            if pos + 2 < len_chars && chars[pos + 1] == '"' && chars[pos + 2] == '"' {
                // Triple-quoted multiline string
                pos = pos + 3
                col = col + 3
                // Skip optional leading newline after opening """
                if pos < len_chars && chars[pos] == '\n' {
                    pos = pos + 1
                    line = line + 1
                    col = 1
                } else if pos < len_chars && chars[pos] == '\r' && pos + 1 < len_chars && chars[pos + 1] == '\n' {
                    pos = pos + 2
                    line = line + 1
                    col = 1
                }
                let mut ts_parts = []
                let mut ts_done = false
                let mut ts_jstmpl_warned = false
                while pos < len_chars && !ts_done {
                    if pos + 2 < len_chars && chars[pos] == '"' && chars[pos + 1] == '"' && chars[pos + 2] == '"' {
                        ts_done = true
                        pos = pos + 3
                        col = col + 3
                    } else {
                        let tc = chars[pos]
                        // PROBE r14: detect JS-style `${...}` template syntax and warn once
                        // (hexa is function-form — use `format("...{}", x)` instead).
                        // Escape with `\${` to silence (canonical pass-through of `$` literal).
                        if !ts_jstmpl_warned && tc == '$' && pos + 1 < len_chars && chars[pos + 1] == '{' {
                            println("warning: '${...}' JS template syntax not supported at line " + to_string(line) + ":" + to_string(col) + " — use format(\"...{}\", x) instead (escape with \\${ to silence)")
                            ts_jstmpl_warned = true
                        }
                        ts_parts.push(to_string(tc))
                        pos = pos + 1
                        if tc == '\n' {
                            line = line + 1
                            col = 1
                        } else {
                            col = col + 1
                        }
                    }
                }
                let ts = join(ts_parts, "")
                tokens.push(Token { kind: "StringLit", value: ts, line: line, col: start_col })
            } else {
                // Regular string literal
                pos = pos + 1
                col = col + 1
                let mut s_parts = []
                let mut done = false
                let mut s_jstmpl_warned = false
                while pos < len_chars && !done {
                    let c = chars[pos]
                    if c == '"' {
                        done = true
                        pos = pos + 1
                        col = col + 1
                    } else if c == '\\' {
                        pos = pos + 1
                        col = col + 1
                        if pos < len_chars {
                            let esc = chars[pos]
                            if esc == 'n' { s_parts.push("\n") }
                            else if esc == 't' { s_parts.push("\t") }
                            else if esc == 'r' { s_parts.push("\r") }
                            else if esc == '\\' { s_parts.push("\\") }
                            else if esc == '"' { s_parts.push("\"") }
                            else if esc == '0' { s_parts.push("\0") }
                            else { s_parts.push(to_string(esc)) }
                            pos = pos + 1
                            col = col + 1
                        }
                    } else {
                        // PROBE r14: detect JS-style `${...}` template syntax and warn once
                        // (hexa is function-form — use `format("...{}", x)` instead).
                        // Escape with `\${` to silence (canonical pass-through of `$` literal).
                        if !s_jstmpl_warned && c == '$' && pos + 1 < len_chars && chars[pos + 1] == '{' {
                            println("warning: '${...}' JS template syntax not supported at line " + to_string(line) + ":" + to_string(col) + " — use format(\"...{}\", x) instead (escape with \\${ to silence)")
                            s_jstmpl_warned = true
                        }
                        s_parts.push(to_string(c))
                        pos = pos + 1
                        if c == '\n' {
                            line = line + 1
                            col = 1
                        } else {
                            col = col + 1
                        }
                    }
                }
                let s = join(s_parts, "")
                tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
            }
        } else if ch == '\'' {
            let start_col = col
            // Check for label: 'ident where ident is >=2 chars or followed by ':'
            // Labels: 'outer  (used with labeled break/continue)
            // Char literals: 'x' or '\n'
            let mut is_label = false
            if pos + 1 < len_chars && is_ident_start(chars[pos + 1]) {
                // Peek ahead to see if this is a multi-char ident (label) or char lit
                let mut peek_pos = pos + 1
                while peek_pos < len_chars && is_ident_char(chars[peek_pos]) {
                    peek_pos = peek_pos + 1
                }
                let ident_len = peek_pos - pos - 1
                if ident_len > 1 {
                    // Multi-char ident after ' → label (e.g. 'outer)
                    is_label = true
                } else if peek_pos < len_chars && chars[peek_pos] != '\'' {
                    // Single-char ident NOT followed by closing ' → label
                    is_label = true
                }
            }
            if is_label {
                // Label token: 'identifier
                pos = pos + 1  // skip '
                col = col + 1
                let mut label_parts = []
                while pos < len_chars && is_ident_char(chars[pos]) {
                    label_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                }
                let label_name = join(label_parts, "")
                tokens.push(Token { kind: "Label", value: label_name, line: line, col: start_col })
            } else {
                // Char literal
                pos = pos + 1
                col = col + 1
                let mut ch_val = ""
                if pos < len_chars && chars[pos] == '\\' {
                    pos = pos + 1
                    col = col + 1
                    if pos < len_chars {
                        let esc = chars[pos]
                        if esc == 'n' { ch_val = "\n" }
                        else if esc == 't' { ch_val = "\t" }
                        else if esc == 'r' { ch_val = "\r" }
                        else if esc == '\\' { ch_val = "\\" }
                        else if esc == '\'' { ch_val = "'" }
                        else if esc == '0' { ch_val = "\0" }
                        else { ch_val = to_string(esc) }
                        pos = pos + 1
                        col = col + 1
                    }
                } else if pos < len_chars {
                    ch_val = to_string(chars[pos])
                    pos = pos + 1
                    col = col + 1
                }
                // Consume closing quote
                if pos < len_chars && chars[pos] == '\'' {
                    pos = pos + 1
                    col = col + 1
                }
                tokens.push(Token { kind: "CharLit", value: ch_val, line: line, col: start_col })
            }
        } else {
            // Operators and delimiters
            let start_col = col
            if ch == '+' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "PlusEq", value: "+=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '-' {
                if pos + 1 < len_chars && chars[pos + 1] == '>' {
                    tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "MinusEq", value: "-=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '*' {
                if pos + 1 < len_chars && chars[pos + 1] == '*' {
                    tokens.push(Token { kind: "Power", value: "**", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "StarEq", value: "*=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '/' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "SlashEq", value: "/=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '%' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "PercentEq", value: "%=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Percent", value: "%", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '=' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == '>' {
                    tokens.push(Token { kind: "FatArrow", value: "=>", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '!' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '<' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == '<' {
                    tokens.push(Token { kind: "Shl", value: "<<", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '>' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == '>' {
                    tokens.push(Token { kind: "Shr", value: ">>", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '&' {
                if pos + 1 < len_chars && chars[pos + 1] == '&' {
                    if pos + 2 < len_chars && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "AndAssign", value: "&&=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "And", value: "&&", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "BitAnd", value: "&", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '|' {
                if pos + 1 < len_chars && chars[pos + 1] == '|' {
                    if pos + 2 < len_chars && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "OrAssign", value: "||=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "Or", value: "||", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "BitOr", value: "|", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '^' {
                if pos + 1 < len_chars && chars[pos + 1] == '^' {
                    tokens.push(Token { kind: "Xor", value: "^^", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "BitXor", value: "^", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '~' {
                tokens.push(Token { kind: "BitNot", value: "~", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                if pos + 1 < len_chars && chars[pos + 1] == '?' {
                    // Greedy `??=` match — mirrors hexa_full.hexa:733 fix.
                    if pos + 2 < len_chars && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "NullCoalescingAssign", value: "??=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "NullCoal", value: "??", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else if pos + 1 < len_chars && chars[pos + 1] == '.' {
                    // Optional chaining: `?.` — PROBE r14-BB.  Must lex
                    // here (before the bare-`?` fallthrough) so the parser
                    // sees `QuestionDot` instead of a `Question` followed
                    // by `Dot`.  The later `else if ch == '?'` arm below
                    // is dead code (this earlier arm wins).
                    tokens.push(Token { kind: "QuestionDot", value: "?.", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                // AI-native attribute marker (M0)
                tokens.push(Token { kind: "At", value: "@", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ':' {
                if pos + 1 < len_chars && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "ColonEq", value: ":=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == ':' {
                    tokens.push(Token { kind: "ColonColon", value: "::", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '.' {
                if pos + 2 < len_chars && chars[pos + 1] == '.' && chars[pos + 2] == '.' {
                    // G8: spread operator `...` — must check 3 dots before 2-dot range
                    tokens.push(Token { kind: "DotDotDot", value: "...", line: line, col: start_col })
                    pos = pos + 3
                    col = col + 3
                } else if pos + 1 < len_chars && chars[pos + 1] == '.' {
                    if pos + 2 < len_chars && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "DotDotEq", value: "..=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '(' {
                tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                paren_depth = paren_depth + 1
                pos = pos + 1
                col = col + 1
            } else if ch == ')' {
                tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                if paren_depth > 0 { paren_depth = paren_depth - 1 }
                pos = pos + 1
                col = col + 1
            } else if ch == '{' {
                tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '}' {
                tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '[' {
                tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                paren_depth = paren_depth + 1
                pos = pos + 1
                col = col + 1
            } else if ch == ']' {
                tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                if paren_depth > 0 { paren_depth = paren_depth - 1 }
                pos = pos + 1
                col = col + 1
            } else if ch == ',' {
                tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ';' {
                tokens.push(Token { kind: "Semicolon", value: ";", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                // Optional chaining: ?.
                if pos + 1 < len_chars && chars[pos + 1] == '.' {
                    tokens.push(Token { kind: "QuestionDot", value: "?.", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                // Attribute token: @name
                pos = pos + 1
                col = col + 1
                let mut attr_parts = []
                while pos < len_chars && is_ident_char(chars[pos]) {
                    attr_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                }
                let attr_name = join(attr_parts, "")
                tokens.push(Token { kind: "Attribute", value: attr_name, line: line, col: start_col })
            } else if ch == '?' {
                if pos + 1 < len_chars && chars[pos + 1] == '?' {
                    if pos + 2 < len_chars && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "NullCoalescingAssign", value: "??=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "NullCoalescing", value: "??", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '#' {
                // Map literal: #{...}
                if pos + 1 < len_chars && chars[pos + 1] == '{' {
                    tokens.push(Token { kind: "HashLBrace", value: "#{", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < len_chars && chars[pos + 1] == '!' {
                    // 2026-04-26 silent-failure-enforcement Class 3:
                    // mid-file `#!hexa …` shebang. The first-line shebang
                    // is consumed by the pre-loop POSIX skip (line 138).
                    // Reaching this branch means the file has a shebang on
                    // line >1 — typical cause: bad `sed` insert OR a user
                    // hand-pasting from another file. Without this hard-fail
                    // the previous behavior was: `#` skipped silently → `!`
                    // tokenized → `hexa` ident → cryptic parse error far
                    // from the real cause ("unexpected token at L:C").
                    println("error: shebang `#!` must be on line 1 of the file; found at line " + to_string(line) + ":" + to_string(start_col))
                    println("hint: remove the shebang OR move it to the very first line")
                    println("ref: silent-failure-enforcement Class 3 (doc/audit/silent_failure_enforcement_audit.md)")
                    exit(1)
                } else {
                    // Standalone # — skip
                    pos = pos + 1
                    col = col + 1
                }
            } else {
                // Unknown character — skip
                pos = pos + 1
                col = col + 1
            }
        }
    }

    // Add EOF token
    tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// Count tokens by kind
fn count_kind(tokens, kind) {
    let mut count = 0
    for t in tokens {
        if t.kind == kind {
            count = count + 1
        }
    }
    return count
}
