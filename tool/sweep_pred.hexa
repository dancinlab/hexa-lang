// tool/sweep_pred.hexa
// F-GPU-SWEEP-SHARED-REDUCE-NUMERIC — terminal falsifier for PR-C @shared landing.
//
// Closes the parent discovery `.discoveries/gpu-kernel-usability-sweep-extension.tape`
// (matrix_7 row · finding_3 — the single-launch CUDA tree-reduce shape that
// the prior sweep marked "NOT probed"). PR #1313 piece 2+3 (parse → HIR/MIR
// annotation thread) + PR #1318 piece 4+5 (.shared directive + ld.shared/
// st.shared routing) = full source-to-silicon close on the @shared seam.
//
// Shape (matches the existing 2048-byte default the NVPTX emitter falls back
// to when HIR/MIR doesn't thread fixed-array sizes yet — `sm: [f64; 256]` =
// 256 × 8 = 2048 B exact, no threading-bug exposure):
//
//   N=256, blockDim=256, gridDim=1, a[i] = i + 1.0 → sum = N(N+1)/2 = 32896.0
//
// All compute lives inside ONE block; per-thread cooperative load → barrier →
// halving-stride tree-reduce → lane-0 publish. Expected partial[0] == 32896.0
// EXACT (integer-valued FP64, all partial sums representable, max|Δ| = 0).

@gpu_kernel
fn sweep_pred(a: [f64], partial: [f64], n: i64) {
    @shared let sm: [f64; 256] = []
    let mut tid: i64 = to_i64(gpu_thread_id_x())
    // cooperative load into shared
    if tid < n {
        sm[to_i64(tid)] = a[to_i64(tid)]
    } else {
        sm[to_i64(tid)] = 0.0
    }
    gpu_barrier()
    // halving-stride tree-reduce — stride = 128, 64, 32, ..., 1
    let mut stride: i64 = 128
    while stride > 0 {
        if tid < stride {
            sm[to_i64(tid)] = sm[to_i64(tid)] + sm[to_i64(tid + stride)]
        }
        gpu_barrier()
        stride = stride / 2
    }
    // single-block result
    if tid == 0 {
        partial[to_i64(0)] = sm[to_i64(0)]
    }
}
