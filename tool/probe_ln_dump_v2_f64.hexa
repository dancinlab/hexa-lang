// §5a LN self-dump v2 — to_i64()-wrapped, 3-param, NO GEMM (Round 9d)
//
// Isolates to_i64() effect on the SELF-DUMP variant (diag was bare-tid → NaN).
// IDENTICAL to probe_ln_dump_f64 but every sm[...] index to_i64()-wrapped.
//   PASS → bare-tid index was the dump culprit; v2 LN+GEMM NaN = W-param/GEMM-phase
//   NaN  → Phase-1c sm write-then-read itself miscompiles (independent of to_i64)

@gpu_kernel
fn probe_ln_dump_v2_f64(x: [f64], y: [f64], N: i64) {
    @shared let sm: [f64; 256] = []
    let mut tid: i64 = to_i64(gpu_thread_id_x())

    if tid < N { sm[to_i64(tid)] = x[to_i64(tid)] } else { sm[to_i64(tid)] = 0.0 }
    gpu_barrier()
    let mut stride: i64 = 128
    while stride > 0 {
        if tid < stride { sm[to_i64(tid)] = sm[to_i64(tid)] + sm[to_i64(tid) + stride] }
        gpu_barrier()
        stride = stride / 2
    }
    let mean: f64 = sm[0] / to_f64(N)
    gpu_barrier()

    let xi: f64 = x[to_i64(tid)]
    let diff0: f64 = xi - mean
    if tid < N { sm[to_i64(tid)] = diff0 * diff0 } else { sm[to_i64(tid)] = 0.0 }
    gpu_barrier()
    stride = 128
    while stride > 0 {
        if tid < stride { sm[to_i64(tid)] = sm[to_i64(tid)] + sm[to_i64(tid) + stride] }
        gpu_barrier()
        stride = stride / 2
    }
    let var: f64 = sm[0] / to_f64(N)
    let inv: f64 = rsqrt(var + 0.00001)
    gpu_barrier()

    if tid < N { sm[to_i64(tid)] = (x[to_i64(tid)] - mean) * inv } else { sm[to_i64(tid)] = 0.0 }
    gpu_barrier()

    if tid < N { y[to_i64(tid)] = sm[to_i64(tid)] }
}
