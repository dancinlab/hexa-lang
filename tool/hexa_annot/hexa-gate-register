#!/usr/bin/env bash
# hexa-gate-register — extract @gate(rule="...") annotations (AST-backed)
# MVP: dry-run only.
#
# Usage:
#   hexa-gate-register <file.hexa>...
#   hexa-gate-register --dir <dir>
#   hexa-gate-register --apply <file.hexa>...   # warns + exit 1 (unsupported)
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-gate-register <file.hexa> [<file2.hexa> ...]
       hexa-gate-register --dir <dir>
       hexa-gate-register --apply <file.hexa>...
EOF
    exit 0
}

case "${1:-}" in
    -h|--help) usage ;;
    "") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

apply=0
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --apply) apply=1; shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if [ "$apply" -eq 1 ]; then
    echo "error: --apply not supported in MVP (read-only)" >&2
    exit 1
fi

if ! resolve_files "${ARGS[@]}"; then exit 2; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","gates":[],"summary":{"total":0,"applied":0,"dry_run":true}}\n'
    exit 0
fi

TMP_TSV=$(mktemp -t hexa_gate.XXXXXX)
trap 'rm -f "$TMP_TSV"' EXIT
run_ast_extract > "$TMP_TSV"

awk '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function kv_extract(raw, key,    s, pat, pos, rest, val, n, i, c, nc) {
    s = raw
    pat = "(^|[ \\t,(])" key "[ \\t]*[=:][ \\t]*"
    pos = match(s, pat)
    if (pos == 0) return ""
    rest = substr(s, pos + RLENGTH)
    sub(/^[ \t]+/, "", rest)
    if (substr(rest, 1, 1) == "\"") {
        val = ""; i = 2; n = length(rest)
        while (i <= n) {
            c = substr(rest, i, 1)
            if (c == "\"") break
            val = val c; i++
        }
        return val
    }
    if (match(rest, /[,)[:space:]]/)) return substr(rest, 1, RSTART - 1)
    return rest
}
BEGIN { FS = "\t"; total = 0; body = "" }
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; fn = $3; file = $4; line = $5; raw = decode_esc($6)
    if (kind != "gate") next
    # Distinguish gate-register (with rule=) from harness gate (with rule_id=H-*)
    rule_v = kv_extract(raw, "rule")
    if (rule_v == "") next
    total++
    if (body != "") body = body ","
    body = body "{\"rule\":\"" jesc(rule_v) "\",\"file\":\"" jesc(file) "\",\"line\":" line ",\"target_fn\":\"" jesc(fn) "\",\"applied\":false}"
}
END {
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"gates\":[%s],\"summary\":{\"total\":%d,\"applied\":0,\"dry_run\":true}}\n", body, total)
}' "$TMP_TSV"
