#!/usr/bin/env bash
# hexa-memo-check — extract @memo(ttl=N) annotations + fn params for cache
# key schema metadata (AST-backed).
#
# Usage:
#   hexa-memo-check <file.hexa>... | --dir <dir>
#
# Output (JSON):
#   { "version":"0.2","source":"ast",
#     "memos":[{fn, ttl_seconds, file, line, args[{name,type}], cache_key_template}],
#     "summary":{total_memos, min_ttl, max_ttl} }
set -eu

usage() {
    cat >&2 <<EOF
hexa-memo-check — @memo(ttl=N) cache key schema dumper (advisory)

Usage:
  hexa-memo-check <file.hexa>...
  hexa-memo-check --dir <dir>
EOF
    exit 2
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

if ! resolve_files "$@"; then exit 1; fi

if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","memos":[],"summary":{"total_memos":0,"min_ttl":0,"max_ttl":0}}\n'
    exit 0
fi

# After AST TSV, we re-grep each fn's signature line from the source file
# to pull the param list (since the extractor's TSV doesn't carry params).
# This is still strictly more accurate than the grep MVP because the
# annotation matching itself is now token-aware.
TSV=$(run_ast_extract | awk -F'\t' '$1=="memo" && $2=="fn"')

# JSON emit
awk -v tsv="$TSV" '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function trim(s) { sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function kv_extract(raw, key,    s, pat, pos, rest, val, n, i, c, nc) {
    s = raw
    pat = "(^|[ \\t,(])" key "[ \\t]*[=:][ \\t]*"
    pos = match(s, pat)
    if (pos == 0) return ""
    rest = substr(s, pos + RLENGTH)
    sub(/^[ \t]+/, "", rest)
    if (substr(rest, 1, 1) == "\"") {
        val = ""; i = 2; n = length(rest)
        while (i <= n) {
            c = substr(rest, i, 1)
            if (c == "\"") break
            val = val c; i++
        }
        return val
    }
    if (match(rest, /[,)[:space:]]/)) return substr(rest, 1, RSTART - 1)
    return rest
}
# parse params from a fn header line — between first "(" and matching ")"
function parse_params(file, fn,    cmd, line, depth, i, c, in_args, accum, params_str, n) {
    cmd = "grep -nE \"^[ \\t]*(pub[ \\t]+)?fn[ \\t]+" fn "[ \\t]*\\(\" \"" file "\" 2>/dev/null | head -1"
    cmd | getline line
    close(cmd)
    # line format: <lineno>:<rest>
    if (line == "") return ""
    # strip leading "N:"
    sub(/^[0-9]+:/, "", line)
    i = index(line, "(")
    if (i == 0) return ""
    accum = substr(line, i + 1)
    # accum may end with ")" or continue onto next lines (advisory: best-effort)
    n = length(accum)
    depth = 1
    params_str = ""
    for (j = 1; j <= n && depth > 0; j++) {
        c = substr(accum, j, 1)
        if (c == "(") depth++
        else if (c == ")") { depth--; if (depth == 0) break }
        params_str = params_str c
    }
    return params_str
}
function emit_args(params_str,    parts_n, k, p, depth2, len2, c, piece, start, colon, nm, ty, eq, out, afirst) {
    out = ""
    if (params_str == "") return out
    # split by top-level commas
    parts_n = 0
    depth2 = 0; start = 1
    len2 = length(params_str)
    for (k = 1; k <= len2; k++) {
        c = substr(params_str, k, 1)
        if (c == "(" || c == "[" || c == "<") depth2++
        else if (c == ")" || c == "]" || c == ">") depth2--
        else if (c == "," && depth2 == 0) {
            piece = trim(substr(params_str, start, k - start))
            if (piece != "") { parts_n++; parts[parts_n] = piece }
            start = k + 1
        }
    }
    piece = trim(substr(params_str, start))
    if (piece != "") { parts_n++; parts[parts_n] = piece }
    afirst = 1
    for (k = 1; k <= parts_n; k++) {
        p = parts[k]
        colon = index(p, ":")
        if (colon > 0) {
            nm = trim(substr(p, 1, colon - 1))
            ty = trim(substr(p, colon + 1))
            eq = index(ty, "=")
            if (eq > 0) ty = trim(substr(ty, 1, eq - 1))
        } else {
            nm = p; ty = ""
        }
        if (nm == "self" || nm == "&self" || nm == "&mut self" || nm == "") continue
        if (afirst == 1) { afirst = 0 } else out = out ","
        out = out "{\"name\":\"" jesc(nm) "\",\"type\":\"" jesc(ty) "\"}"
    }
    return out
}
BEGIN {
    FS = "\t"
    n_rows = split(tsv, lines, "\n")
    total = 0; min_ttl = 0; max_ttl = 0; have_any = 0
    body = ""
    for (i = 1; i <= n_rows; i++) {
        if (lines[i] == "") continue
        split(lines[i], cols, "\t")
        fn = cols[3]; file = cols[4]; line = cols[5]; raw = decode_esc(cols[6])
        ttl_str = kv_extract(raw, "ttl")
        if (ttl_str == "") continue
        if (ttl_str !~ /^-?[0-9]+$/) continue
        ttl = ttl_str + 0
        total++
        if (!have_any) { min_ttl = ttl; max_ttl = ttl; have_any = 1 }
        else { if (ttl < min_ttl) min_ttl = ttl; if (ttl > max_ttl) max_ttl = ttl }
        params_str = parse_params(file, fn)
        args_json = emit_args(params_str)
        # cache_key_template
        ckt = fn
        if (args_json != "") {
            # rebuild key from emitted args (parse names back out is messy — just re-derive)
            # naive: split args_json on `{` boundaries
            n2 = split(args_json, ents, "},{")
            for (k = 1; k <= n2; k++) {
                # extract name field
                if (match(ents[k], /"name":"[^"]*"/)) {
                    mm = substr(ents[k], RSTART, RLENGTH)
                    if (match(mm, /:"[^"]*"/)) {
                        nm = substr(mm, RSTART + 2, RLENGTH - 3)
                        ckt = ckt ":{" nm "}"
                    }
                }
            }
        }
        if (body != "") body = body ","
        body = body "{\"fn\":\"" jesc(fn) "\",\"ttl_seconds\":" ttl ",\"file\":\"" jesc(file) "\",\"line\":" line ",\"args\":[" args_json "],\"cache_key_template\":\"" jesc(ckt) "\"}"
    }
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"memos\":[%s],\"summary\":{\"total_memos\":%d,\"min_ttl\":%d,\"max_ttl\":%d}}\n", body, total, min_ttl, max_ttl)
}
'
