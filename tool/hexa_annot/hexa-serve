#!/usr/bin/env bash
# hexa-serve — agent-serving annotation extractor (AST-backed)
# Recognizes: @ctx_compress, @tool_cache, @session_migrate, @route_agent
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-serve [--kind ctx_compress|tool_cache|session_migrate|route_agent] <file.hexa> [file2.hexa ...]
       hexa-serve [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                ctx_compress|tool_cache|session_migrate|route_agent) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"ctx_compress":0,"tool_cache":0,"session_migrate":0,"route_agent":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "ctx_compress,tool_cache,session_migrate,route_agent" "$filter_kind"
