#!/usr/bin/env bash
# hexa-struct-layout — @repr/@align/@pack + struct fields → layout JSON
# (AST-backed; preserves the v0.1 grep MVP shape modulo schema version).
#
# Usage:
#   hexa-struct-layout <file.hexa> [<file2>...]
#   hexa-struct-layout --dir <dir>
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-struct-layout <file.hexa> [<file2>...]
       hexa-struct-layout --dir <dir>
EOF
    exit 2
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

if ! resolve_files "$@"; then exit 2; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","structs":[],"summary":{"total":0,"with_repr_c":0,"aligned":0,"packed":0}}\n'
    exit 0
fi

# Stash AST TSV into a temp file (awk -v can't carry newlines safely).
TMP_TSV=$(mktemp -t hexa_struct_layout.XXXXXX)
trap 'rm -f "$TMP_TSV"' EXIT
run_ast_extract > "$TMP_TSV"

awk '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function trim(s) { sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function parse_repr_arg(raw,   v) {
    v = trim(raw)
    if (length(v) >= 2 && substr(v, 1, 1) == "\"" && substr(v, length(v), 1) == "\"") return substr(v, 2, length(v) - 2)
    return v
}
function fetch_fields(file, name,    cmd, ln, fields, found, c, fn_, ft, f) {
    cmd = "awk -v want=\"" name "\" \047/^[ \\t]*struct[ \\t]+[A-Za-z_]/ { hdr=$0; sub(/^[ \\t]*struct[ \\t]+/, \"\", hdr); sub(/[ \\t{].*$/, \"\", hdr); if (hdr == want) { found=1; next } } found && /^[ \\t]*\\}/ { exit } found { print }\047 \"" file "\""
    fields = ""
    while ((cmd | getline ln) > 0) {
        f = trim(ln)
        sub(/\/\/.*$/, "", f)
        sub(/,$/, "", f)
        f = trim(f)
        if (f == "") continue
        c = index(f, ":")
        if (c > 0) {
            fn_ = trim(substr(f, 1, c - 1))
            ft = trim(substr(f, c + 1))
            if (fields != "") fields = fields ","
            fields = fields "{\"name\":\"" jesc(fn_) "\",\"type\":\"" jesc(ft) "\"}"
        }
    }
    close(cmd)
    return fields
}
BEGIN { FS = "\t"; n_structs = 0 }
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; name = $3; file = $4; line = $5; raw = decode_esc($6)
    if (tgtk != "struct") next
    if (kind != "repr" && kind != "align" && kind != "pack") next
    key = file "\t" name
    if (!(key in seen)) {
        seen[key] = 1
        n_structs++
        struct_name[n_structs] = name
        struct_file[n_structs] = file
        struct_line[n_structs] = line
        struct_repr[n_structs] = ""
        struct_align[n_structs] = ""
        struct_packed[n_structs] = 0
        struct_idx[key] = n_structs
    }
    k = struct_idx[key]
    if (kind == "repr") struct_repr[k] = parse_repr_arg(raw)
    else if (kind == "align") struct_align[k] = parse_repr_arg(raw)
    else if (kind == "pack")  struct_packed[k] = 1
}
END {
    total = n_structs
    with_repr_c = 0; aligned = 0; packed_n = 0
    for (i = 1; i <= n_structs; i++) {
        if (struct_repr[i] == "c") with_repr_c++
        if (struct_align[i] != "") aligned++
        if (struct_packed[i] == 1) packed_n++
    }
    body = ""
    for (i = 1; i <= n_structs; i++) {
        if (i > 1) body = body ","
        repr_v = (struct_repr[i] != "") ? ("\"" jesc(struct_repr[i]) "\"") : "null"
        align_v = (struct_align[i] != "") ? struct_align[i] : "null"
        if (align_v != "null" && align_v !~ /^-?[0-9]+$/) align_v = "\"" jesc(struct_align[i]) "\""
        packed_v = (struct_packed[i] == 1) ? "true" : "false"
        fields_json = fetch_fields(struct_file[i], struct_name[i])
        body = body "{"
        body = body "\"name\":\"" jesc(struct_name[i]) "\""
        body = body ",\"repr\":" repr_v
        body = body ",\"align\":" align_v
        body = body ",\"packed\":" packed_v
        body = body ",\"file\":\"" jesc(struct_file[i]) "\""
        body = body ",\"line\":" struct_line[i]
        body = body ",\"fields\":[" fields_json "]"
        body = body "}"
    }
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"structs\":[%s],\"summary\":{\"total\":%d,\"with_repr_c\":%d,\"aligned\":%d,\"packed\":%d}}\n", body, total, with_repr_c, aligned, packed_n)
}' "$TMP_TSV"
