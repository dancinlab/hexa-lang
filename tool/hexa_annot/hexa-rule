#!/usr/bin/env bash
# hexa-rule — @rule(kind=...) annotation collector (AST-backed)
#
# Modes:
#   default      collect @rule kinds, emit JSON
#   migrate      dry-run alias migration plan (no rewrites — same as MVP)
#                use --apply to surface "unsupported in MVP" warning
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-rule <file.hexa> [file2.hexa ...]
       hexa-rule --dir <directory>
       hexa-rule [--kind name|alias|deprecate|scope|stack|schema|conflict|migrate|lint|audit|enforce] <files...>
       hexa-rule --mode migrate [--apply] <file...>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

mode="collect"
apply=0
filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --mode)
            shift; [ $# -ge 1 ] || usage
            mode="$1"; shift ;;
        --apply) apply=1; shift ;;
        --kind)
            shift; [ $# -ge 1 ] || usage
            filter_kind="$1"; shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi

if [ "$mode" = "migrate" ]; then
    if [ ${#FILES[@]} -eq 0 ]; then
        printf '{"version":"0.2","source":"ast","apply":%s,"migrations":[],"summary":{"matched":0,"applied":0}}\n' "$([ "$apply" -eq 1 ] && echo true || echo false)"
        exit 0
    fi
    TMP_TSV=$(mktemp -t hexa_rule_mig.XXXXXX)
    trap 'rm -f "$TMP_TSV"' EXIT
    run_ast_extract > "$TMP_TSV"
    awk -v apply="$apply" '
    function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
    function decode_esc(s,   out, i, n, c, nc) {
        out = ""; n = length(s); i = 1
        while (i <= n) {
            c = substr(s, i, 1)
            if (c == "\\" && i < n) {
                nc = substr(s, i + 1, 1)
                if (nc == "n")  { out = out "\n"; i += 2; continue }
                if (nc == "r")  { out = out "\r"; i += 2; continue }
                if (nc == "t")  { out = out "\t"; i += 2; continue }
                if (nc == "\\") { out = out "\\"; i += 2; continue }
            }
            out = out c; i++
        }
        return out
    }
    function kv_extract(raw, key,    s, pat, pos, rest, val, n, i, c, nc) {
        s = raw
        pat = "(^|[ \\t,(])" key "[ \\t]*[=:][ \\t]*"
        pos = match(s, pat)
        if (pos == 0) return ""
        rest = substr(s, pos + RLENGTH)
        sub(/^[ \t]+/, "", rest)
        if (substr(rest, 1, 1) == "\"") {
            val = ""; i = 2; n = length(rest)
            while (i <= n) {
                c = substr(rest, i, 1)
                if (c == "\"") break
                val = val c; i++
            }
            return val
        }
        if (match(rest, /[,)[:space:]]/)) return substr(rest, 1, RSTART - 1)
        return rest
    }
    BEGIN { FS = "\t"; matched = 0; body = "" }
    /^# error\t/ { next }
    {
        kind = $1; tgtk = $2; file = $4; line = $5; raw = decode_esc($6)
        if (kind != "rule") next
        rk = kv_extract(raw, "kind")
        if (rk != "alias") next
        from = kv_extract(raw, "from")
        to   = kv_extract(raw, "to")
        disc = kv_extract(raw, "discriminator")
        matched++
        if (body != "") body = body ","
        body = body "{\"file\":\"" jesc(file) "\",\"line\":" line ",\"from\":\"" jesc(from) "\",\"to\":\"" jesc(to) "\",\"discriminator\":\"" jesc(disc) "\",\"applied\":false}"
    }
    END {
        printf("{\"version\":\"0.2\",\"source\":\"ast\",\"apply\":%s,\"migrations\":[%s],\"summary\":{\"matched\":%d,\"applied\":0}}\n", (apply == 1 ? "true" : "false"), body, matched)
    }' "$TMP_TSV"
    exit 0
fi

# default collect mode
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","rules":[],"summary":{"name":0,"alias":0,"deprecate":0,"scope":0,"stack":0,"schema":0,"conflict":0,"migrate":0,"lint":0,"audit":0,"enforce":0,"total":0}}\n'
    exit 0
fi

TMP_TSV=$(mktemp -t hexa_rule_collect.XXXXXX)
trap 'rm -f "$TMP_TSV"' EXIT
run_ast_extract > "$TMP_TSV"

awk -v filter="$filter_kind" '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function kv_extract(raw, key,    s, pat, pos, rest, val, n, i, c, nc) {
    s = raw
    pat = "(^|[ \\t,(])" key "[ \\t]*[=:][ \\t]*"
    pos = match(s, pat)
    if (pos == 0) return ""
    rest = substr(s, pos + RLENGTH)
    sub(/^[ \t]+/, "", rest)
    if (substr(rest, 1, 1) == "\"") {
        val = ""; i = 2; n = length(rest)
        while (i <= n) {
            c = substr(rest, i, 1)
            if (c == "\"") break
            val = val c; i++
        }
        return val
    }
    if (match(rest, /[,)[:space:]]/)) return substr(rest, 1, RSTART - 1)
    return rest
}
function kv_to_json_skip_kind(raw,    s, n, i, c, key, val, depth, n_out, is_str, nc, out, sep) {
    s = raw; sub(/^[ \t]+/, "", s); n = length(s); i = 1; n_out = 0; out = ""
    while (i <= n) {
        while (i <= n && (substr(s, i, 1) == " " || substr(s, i, 1) == "\t" || substr(s, i, 1) == ",")) i++
        if (i > n) break
        key = ""
        while (i <= n) {
            c = substr(s, i, 1)
            if ((c >= "A" && c <= "Z") || (c >= "a" && c <= "z") || (c >= "0" && c <= "9") || c == "_") { key = key c; i++ } else break
        }
        if (key == "") {
            val = ""; depth = 0
            while (i <= n) {
                c = substr(s, i, 1)
                if (c == "(" || c == "[" || c == "{") depth++
                else if (c == ")" || c == "]" || c == "}") depth--
                else if (c == "," && depth == 0) break
                val = val c; i++
            }
            continue
        }
        while (i <= n && (substr(s, i, 1) == " " || substr(s, i, 1) == "\t")) i++
        sep = substr(s, i, 1)
        if (sep != "=" && sep != ":") continue
        i++
        while (i <= n && (substr(s, i, 1) == " " || substr(s, i, 1) == "\t")) i++
        val = ""; is_str = 0
        if (substr(s, i, 1) == "\"") {
            is_str = 1; i++
            while (i <= n) {
                c = substr(s, i, 1)
                if (c == "\"") { i++; break }
                val = val c; i++
            }
        } else {
            depth = 0
            while (i <= n) {
                c = substr(s, i, 1)
                if (c == "(" || c == "[" || c == "{") depth++
                else if (c == ")" || c == "]" || c == "}") depth--
                else if (c == "," && depth == 0) break
                val = val c; i++
            }
            gsub(/^[ \t]+|[ \t]+$/, "", val)
        }
        if (key == "kind") continue
        n_out++; if (n_out > 1) out = out ","
        if (is_str) out = out "\"" jesc(key) "\":\"" jesc(val) "\""
        else if (val == "true" || val == "false" || val == "null") out = out "\"" jesc(key) "\":" val
        else if (val ~ /^-?[0-9]+$/ || val ~ /^-?[0-9]+\.[0-9]+$/) out = out "\"" jesc(key) "\":" val
        else out = out "\"" jesc(key) "\":\"" jesc(val) "\""
    }
    return out
}
BEGIN {
    FS = "\t"
    n_kinds = split("name,alias,deprecate,scope,stack,schema,conflict,migrate,lint,audit,enforce", kinds_arr, ",")
    for (i = 1; i <= n_kinds; i++) { kinds_idx[kinds_arr[i]] = i; counts[kinds_arr[i]] = 0 }
    body = ""; total = 0
}
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; fn = $3; file = $4; line = $5; raw = decode_esc($6)
    if (kind != "rule") next
    rk = kv_extract(raw, "kind")
    if (rk == "" || !(rk in kinds_idx)) next
    if (filter != "" && rk != filter) next
    counts[rk]++
    if (total > 0) body = body ","
    total++
    body = body "{\"kind\":\"" jesc(rk) "\",\"fn\":\"" jesc(fn) "\",\"file\":\"" jesc(file) "\",\"line\":" line ",\"meta\":{" kv_to_json_skip_kind(raw) "}}"
}
END {
    sum = ""
    for (i = 1; i <= n_kinds; i++) {
        if (i > 1) sum = sum ","
        sum = sum "\"" kinds_arr[i] "\":" counts[kinds_arr[i]]
    }
    sum = sum ",\"total\":" total
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"rules\":[%s],\"summary\":{%s}}\n", body, sum)
}' "$TMP_TSV"
