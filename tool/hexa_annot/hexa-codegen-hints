#!/usr/bin/env bash
# hexa-codegen-hints — codegen-hint annotation extractor (AST-backed)
#
# Input:
#   hexa-codegen-hints <file.hexa> [<file2.hexa> ...]
#   hexa-codegen-hints --dir <directory>
#
# Output (stdout JSON, schema v0.2 / source "ast"):
#   { "version":"0.2","source":"ast",
#     "hints":[ {kind, fn, file, line, args} ],
#     "summary":{ inline, no_inline, cold, deprecated, total } }
#
# Recognized annotations (immediately preceding fn decl, stacking allowed):
#   @inline
#   @no_inline
#   @cold
#   @deprecated(since="1.0", reason="use new_api")
#
# Phase 5 (2026-05-13): grep MVP → AST. Token-stream walk via
# tool/hexa_annot/_ast_extract.hexa correctly skips @-tokens inside
# comments and string literals.
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-codegen-hints <file.hexa> [file2.hexa ...]
       hexa-codegen-hints --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

if ! resolve_files "$@"; then
    exit 1
fi

if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","hints":[],"summary":{"inline":0,"no_inline":0,"cold":0,"deprecated":0,"total":0}}\n'
    exit 0
fi

# Codegen-hint kinds we report on (others ignored).
# Filter the AST TSV stream and emit JSON.
run_ast_extract | awk '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function decode_esc(s,   out, i, n, c, nc) {
    out = ""
    n = length(s)
    i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c
        i++
    }
    return out
}
BEGIN {
    FS = "\t"
    n_inline = 0
    n_no_inline = 0
    n_cold = 0
    n_deprecated = 0
    total = 0
    body = ""
}
/^# error\t/ { next }
{
    kind   = $1
    tgtk   = $2
    fn     = $3
    file   = $4
    line   = $5
    raw    = decode_esc($6)
    if (tgtk != "fn") next
    if (kind != "inline" && kind != "no_inline" && kind != "cold" && kind != "deprecated") next
    if (total > 0) body = body ","
    total++
    if      (kind == "inline")     n_inline++
    else if (kind == "no_inline")  n_no_inline++
    else if (kind == "cold")       n_cold++
    else if (kind == "deprecated") n_deprecated++
    body = body "{"
    body = body "\"kind\":\""  json_escape(kind) "\""
    body = body ",\"fn\":\""   json_escape(fn) "\""
    body = body ",\"file\":\"" json_escape(file) "\""
    body = body ",\"line\":"   line
    body = body ",\"args\":\"" json_escape(raw) "\""
    body = body "}"
}
END {
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"hints\":[%s],\"summary\":{\"inline\":%d,\"no_inline\":%d,\"cold\":%d,\"deprecated\":%d,\"total\":%d}}\n", body, n_inline, n_no_inline, n_cold, n_deprecated, total)
}
'
