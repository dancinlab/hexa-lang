#!/usr/bin/env bash
# hexa-eval-run — evaluation annotation extractor (AST-backed)
# Recognizes: @eval, @cat_adaptive, @judge_calibrate, @contamination_check
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-eval-run [--kind eval|cat_adaptive|judge_calibrate|contamination_check] <file.hexa> [file2.hexa ...]
       hexa-eval-run [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                eval|cat_adaptive|judge_calibrate|contamination_check) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"eval":0,"cat_adaptive":0,"judge_calibrate":0,"contamination_check":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "eval,cat_adaptive,judge_calibrate,contamination_check" "$filter_kind"
