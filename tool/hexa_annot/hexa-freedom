#!/usr/bin/env bash
# hexa-freedom — agency/freedom annotation extractor (AST-backed)
# Recognizes: @free_will, @autonomy, @agency, @choice, @spontaneity,
#             @volition, @initiative, @self_determined,
#             @degrees_of_freedom, @indeterminate, @causal_power
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-freedom [--kind <name>] <file.hexa> [file2.hexa ...]
       hexa-freedom [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                free_will|autonomy|agency|choice|spontaneity|volition|initiative|self_determined|degrees_of_freedom|indeterminate|causal_power) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"free_will":0,"autonomy":0,"agency":0,"choice":0,"spontaneity":0,"volition":0,"initiative":0,"self_determined":0,"degrees_of_freedom":0,"causal_power":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "free_will,autonomy,agency,choice,spontaneity,volition,initiative,self_determined,degrees_of_freedom,indeterminate,causal_power" "$filter_kind"
