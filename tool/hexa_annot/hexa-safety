#!/usr/bin/env bash
# hexa-safety — AI Safety annotation extractor (AST-backed)
# Recognizes: @interpret, @align, @adversarial_robust, @deploy_safe,
#             @multimodal_safe, @model_welfare
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-safety [--kind interpret|align|adversarial_robust|deploy_safe|multimodal_safe|model_welfare] <file.hexa> [file2.hexa ...]
       hexa-safety [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                interpret|align|adversarial_robust|deploy_safe|multimodal_safe|model_welfare) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"interpret":0,"align":0,"adversarial_robust":0,"deploy_safe":0,"multimodal_safe":0,"model_welfare":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "interpret,align,adversarial_robust,deploy_safe,multimodal_safe,model_welfare" "$filter_kind"
