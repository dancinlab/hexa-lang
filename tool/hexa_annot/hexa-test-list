#!/usr/bin/env bash
# hexa-test-list — @test / @bench annotation discovery (AST-backed)
#
# Usage:
#   hexa-test-list <file.hexa> [<file2.hexa> ...]
#   hexa-test-list --dir <directory>
#   hexa-test-list --kind test|bench [files...]
#
# Output (JSON):
#   { "version":"0.2","source":"ast",
#     "tests":[{kind, fn, file, line, args[]}],
#     "summary":{tests, benches} }
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-test-list <file.hexa> [file2.hexa ...]
       hexa-test-list --dir <directory>
       hexa-test-list --kind test|bench [<files or --dir>]
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

kind_filter=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                test|bench) kind_filter="$1" ;;
                *) echo "ERROR: --kind must be 'test' or 'bench'" >&2; exit 1 ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","tests":[],"summary":{"tests":0,"benches":0}}\n'
    exit 0
fi

TMP_TSV=$(mktemp -t hexa_test_list.XXXXXX)
trap 'rm -f "$TMP_TSV"' EXIT
run_ast_extract > "$TMP_TSV"

awk -v filter="$kind_filter" '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function trim(s) { sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function fetch_args(file, fn,    cmd, ln, params_str, accum, depth, i, c, params, ki, n, piece, start, ke, nm, ty, eq, arg_names, n_args) {
    cmd = "grep -nE \"^[ \\t]*(pub[ \\t]+)?fn[ \\t]+" fn "[ \\t]*\\(\" \"" file "\" 2>/dev/null | head -1"
    cmd | getline ln
    close(cmd)
    if (ln == "") return ""
    sub(/^[0-9]+:/, "", ln)
    i = index(ln, "(")
    if (i == 0) return ""
    accum = substr(ln, i + 1)
    depth = 1
    params_str = ""
    n = length(accum)
    for (j = 1; j <= n && depth > 0; j++) {
        c = substr(accum, j, 1)
        if (c == "(") depth++
        else if (c == ")") { depth--; if (depth == 0) break }
        params_str = params_str c
    }
    # split by top-level comma
    arg_names = ""
    n_args = 0
    depth = 0; start = 1
    n = length(params_str)
    for (j = 1; j <= n; j++) {
        c = substr(params_str, j, 1)
        if (c == "(" || c == "[" || c == "<") depth++
        else if (c == ")" || c == "]" || c == ">") depth--
        else if (c == "," && depth == 0) {
            piece = trim(substr(params_str, start, j - start))
            if (piece != "") {
                ke = index(piece, ":")
                if (ke > 0) nm = trim(substr(piece, 1, ke - 1))
                else nm = piece
                if (nm != "" && nm != "self") {
                    if (n_args > 0) arg_names = arg_names ","
                    arg_names = arg_names "\"" jesc(nm) "\""
                    n_args++
                }
            }
            start = j + 1
        }
    }
    piece = trim(substr(params_str, start))
    if (piece != "") {
        ke = index(piece, ":")
        if (ke > 0) nm = trim(substr(piece, 1, ke - 1))
        else nm = piece
        if (nm != "" && nm != "self") {
            if (n_args > 0) arg_names = arg_names ","
            arg_names = arg_names "\"" jesc(nm) "\""
            n_args++
        }
    }
    return arg_names
}
BEGIN { FS = "\t"; n_tests = 0; n_benches = 0; body = "" }
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; fn = $3; file = $4; line = $5; raw = decode_esc($6)
    if (kind != "test" && kind != "bench") next
    if (tgtk != "fn") next
    if (filter != "" && kind != filter) next
    if (kind == "test") n_tests++; else n_benches++
    args_json = fetch_args(file, fn)
    if (body != "") body = body ","
    body = body "{"
    body = body "\"kind\":\""  jesc(kind) "\""
    body = body ",\"fn\":\""   jesc(fn) "\""
    body = body ",\"file\":\"" jesc(file) "\""
    body = body ",\"line\":"   line
    body = body ",\"args\":["  args_json "]"
    body = body "}"
}
END {
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"tests\":[%s],\"summary\":{\"tests\":%d,\"benches\":%d}}\n", body, n_tests, n_benches)
}' "$TMP_TSV"
