#!/usr/bin/env bash
# hexa-intent-map — @intent(description: "...") fn intent collector (AST-backed)
#
# Usage:
#   hexa-intent-map <file.hexa> [<file2.hexa> ...]
#   hexa-intent-map --dir <directory>
#   hexa-intent-map --project <name>
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-intent-map <file.hexa> [file2.hexa ...]
       hexa-intent-map --dir <directory>
       hexa-intent-map --project <name>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

if [ "${1:-}" = "--project" ]; then
    [ $# -ge 2 ] || usage
    name="$2"
    cand=""
    if [ -d "$HOME/core/$name" ]; then cand="$HOME/core/$name"
    elif [ -d "$HOME/Dev/$name" ]; then cand="$HOME/Dev/$name"
    else echo "ERROR: project not found: $name" >&2; exit 1; fi
    set -- --dir "$cand"
fi

if ! resolve_files "$@"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","intents":[],"summary":{"total":0,"files":0,"fallback_count":0}}\n'
    exit 0
fi

TMP_TSV=$(mktemp -t hexa_intent_map.XXXXXX)
trap 'rm -f "$TMP_TSV"' EXIT
run_ast_extract > "$TMP_TSV"

n_files=${#FILES[@]}

awk -v nfiles="$n_files" '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function kv_extract(raw, key,    s, pat, pos, rest, val, n, i, c, nc) {
    s = raw
    pat = "(^|[ \\t,(])" key "[ \\t]*[=:][ \\t]*"
    pos = match(s, pat)
    if (pos == 0) return ""
    rest = substr(s, pos + RLENGTH)
    sub(/^[ \t]+/, "", rest)
    if (substr(rest, 1, 1) == "\"") {
        val = ""; i = 2; n = length(rest)
        while (i <= n) {
            c = substr(rest, i, 1)
            if (c == "\"") break
            val = val c; i++
        }
        return val
    }
    if (match(rest, /[,)[:space:]]/)) return substr(rest, 1, RSTART - 1)
    return rest
}
BEGIN { FS = "\t"; total = 0; fallback_n = 0; body = "" }
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; fn = $3; file = $4; line = $5; raw = decode_esc($6)
    if (kind != "intent") next
    if (tgtk != "fn") next
    desc = kv_extract(raw, "description")
    if (body != "") body = body ","
    body = body "{"
    body = body "\"fn\":\""          jesc(fn) "\""
    body = body ",\"description\":\"" jesc(desc) "\""
    body = body ",\"file\":\""        jesc(file) "\""
    body = body ",\"line\":"          line
    body = body ",\"fallback\":false"
    body = body "}"
    total++
}
END {
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"intents\":[%s],\"summary\":{\"total\":%d,\"files\":%d,\"fallback_count\":%d}}\n", body, total, nfiles, fallback_n)
}' "$TMP_TSV"
