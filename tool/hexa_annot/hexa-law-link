#!/usr/bin/env bash
# hexa-law-link — @law(ref="...") cross-reference checker (AST-backed)
#
# Usage:
#   hexa-law-link <file.hexa> [<file2.hexa> ...]
#   hexa-law-link --dir <directory>
#   hexa-law-link --rules <path/to/rules.json> <files...>
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-law-link [--rules <rules.json>] <file.hexa> [file2.hexa ...]
       hexa-law-link [--rules <rules.json>] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

# Default rules: <script_dir>/../../config/annot_rules.json
DEFAULT_RULES="${SCRIPT_DIR}/../../config/annot_rules.json"
RULES="$DEFAULT_RULES"
if [ ! -f "$RULES" ] && [ -n "${NEXUS:-}" ] && [ -f "${NEXUS}/shared/rules/anima.json" ]; then
    RULES="${NEXUS}/shared/rules/anima.json"
fi

ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --rules)
            shift; [ $# -ge 1 ] || usage
            RULES="$1"; shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","links":[],"summary":{"total":0,"valid_refs":0,"missing_refs":0,"missing_list":[]}}\n'
    exit 0
fi

if [ ! -f "$RULES" ]; then
    echo "ERROR: rules file not found: $RULES" >&2
    exit 1
fi

TMP_TSV=$(mktemp -t hexa_law_link.XXXXXX)
trap 'rm -f "$TMP_TSV"' EXIT
run_ast_extract > "$TMP_TSV"

awk -v rules="$RULES" '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
function kv_extract(raw, key,    s, pat, pos, rest, val, n, i, c, nc) {
    s = raw
    pat = "(^|[ \\t,(])" key "[ \\t]*[=:][ \\t]*"
    pos = match(s, pat)
    if (pos == 0) return ""
    rest = substr(s, pos + RLENGTH)
    sub(/^[ \t]+/, "", rest)
    if (substr(rest, 1, 1) == "\"") {
        val = ""; i = 2; n = length(rest)
        while (i <= n) {
            c = substr(rest, i, 1)
            if (c == "\"") break
            val = val c; i++
        }
        return val
    }
    if (match(rest, /[,)[:space:]]/)) return substr(rest, 1, RSTART - 1)
    return rest
}
BEGIN {
    FS = "\t"
    # Load rules: naive parse for "id":"..." and "level":"..."
    rule_count = 0
    while ((getline ln < rules) > 0) all = all "\n" ln
    close(rules)
    # find blocks
    n_split = split(all, blocks, /}[ \t,\n]*{/)
    for (b = 1; b <= n_split; b++) {
        s = blocks[b]
        if (match(s, /"id"[ \t]*:[ \t]*"[^"]*"/)) {
            m = substr(s, RSTART, RLENGTH); if (match(m, /:"[^"]*"/)) id = substr(m, RSTART + 2, RLENGTH - 3); else continue
        } else continue
        if (match(s, /"level"[ \t]*:[ \t]*"[^"]*"/)) {
            m = substr(s, RSTART, RLENGTH); if (match(m, /:"[^"]*"/)) lv = substr(m, RSTART + 2, RLENGTH - 3); else lv = ""
        } else lv = ""
        rule_level[id] = lv
        rule_exists[id] = 1
        rule_count++
    }
    total = 0; valid = 0; missing = 0
    body = ""; missing_body = ""
}
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; fn = $3; file = $4; line = $5; raw = decode_esc($6)
    if (kind != "law") next
    if (tgtk != "fn") next
    ref = kv_extract(raw, "ref")
    exists = (ref in rule_exists) ? "true" : "false"
    lvl = (ref in rule_level) ? rule_level[ref] : ""
    if (body != "") body = body ","
    body = body "{\"fn\":\"" jesc(fn) "\",\"ref\":\"" jesc(ref) "\",\"rule_exists\":" exists ",\"rule_level\":\"" jesc(lvl) "\",\"file\":\"" jesc(file) "\",\"line\":" line "}"
    total++
    if (exists == "true") valid++
    else {
        missing++
        if (missing_body != "") missing_body = missing_body ","
        missing_body = missing_body "\"" jesc(ref) "\""
    }
}
END {
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"links\":[%s],\"summary\":{\"total\":%d,\"valid_refs\":%d,\"missing_refs\":%d,\"missing_list\":[%s]}}\n", body, total, valid, missing, missing_body)
}' "$TMP_TSV"
