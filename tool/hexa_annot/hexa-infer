#!/usr/bin/env bash
# hexa-infer — inference-optimization annotation extractor (AST-backed)
# Recognizes: @infer, @quantize, @cache_kv, @speculate, @batch_continuous
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-infer [--kind infer|quantize|cache_kv|speculate|batch_continuous] <file.hexa> [file2.hexa ...]
       hexa-infer [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                infer|quantize|cache_kv|speculate|batch_continuous) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"infer":0,"quantize":0,"cache_kv":0,"speculate":0,"batch_continuous":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "infer,quantize,cache_kv,speculate,batch_continuous" "$filter_kind"
