#!/usr/bin/env bash
# hexa-self-aware — compiler self-awareness annotation extractor (AST-backed)
# Recognizes: @compile_trace, @ast_visible, @codegen_mark,
#             @optimizer_hint, @type_debug, @self_check
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-self-aware [--kind compile_trace|ast_visible|codegen_mark|optimizer_hint|type_debug|self_check] <file.hexa> [file2.hexa ...]
       hexa-self-aware [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                compile_trace|ast_visible|codegen_mark|optimizer_hint|type_debug|self_check) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"compile_trace":0,"ast_visible":0,"codegen_mark":0,"optimizer_hint":0,"type_debug":0,"self_check":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "compile_trace,ast_visible,codegen_mark,optimizer_hint,type_debug,self_check" "$filter_kind"
