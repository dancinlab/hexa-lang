#!/usr/bin/env bash
# hexa-antivirus — AI security/antivirus annotation extractor (AST-backed)
# Recognizes: @antivirus, @quarantine, @heal, @integrity, @sandbox,
#             @cve, @rce_guard, @audit, @canary, @patch
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-antivirus [--kind antivirus|quarantine|heal|integrity|sandbox|cve|rce_guard|audit|canary|patch] <file.hexa> [file2.hexa ...]
       hexa-antivirus [--kind ...] --dir <directory>
EOF
    exit 1
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

filter_kind=""
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift; [ $# -ge 1 ] || usage
            case "$1" in
                antivirus|quarantine|heal|integrity|sandbox|cve|rce_guard|audit|canary|patch) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift ;;
        -h|--help) usage ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi
if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","annotations":[],"summary":{"antivirus":0,"quarantine":0,"heal":0,"integrity":0,"sandbox":0,"cve":0,"rce_guard":0,"audit":0,"canary":0,"patch":0,"total":0}}\n'
    exit 0
fi
run_ast_extract | ast_emit_kindmap_json "antivirus,quarantine,heal,integrity,sandbox,cve,rce_guard,audit,canary,patch" "$filter_kind"
