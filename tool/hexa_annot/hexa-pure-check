#!/usr/bin/env bash
# hexa-pure-check — detect @pure annotation body violations (AST-backed).
#
# Usage:
#   hexa-pure-check [--strict] <file.hexa>...
#   hexa-pure-check [--strict] --dir <dir>
#
# Flags:
#   --strict   also flag "let mut" as a violation
#
# Output: JSON on stdout (schema v0.2, source "ast").
set -eu

usage() {
    cat >&2 <<EOF
hexa-pure-check — @pure purity violation detector (advisory)

Usage:
  hexa-pure-check [--strict] <file.hexa>...
  hexa-pure-check [--strict] --dir <dir>

Flags:
  --strict   also flag "let mut " as a violation

Output: JSON on stdout (schema v0.2).
EOF
    exit 2
}

case "${1:-}" in
    -h|--help|"") usage ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_ast_extract.sh"

STRICT=0
ARGS=()
for a in "$@"; do
    case "$a" in
        --strict) STRICT=1 ;;
        -h|--help) usage ;;
        *) ARGS+=("$a") ;;
    esac
done

if ! resolve_files "${ARGS[@]}"; then exit 1; fi

if [ ${#FILES[@]} -eq 0 ]; then
    printf '{"version":"0.2","source":"ast","pure_fns":[],"summary":{"total":0,"clean":0,"violations":0}}\n'
    exit 0
fi

run_ast_extract | awk -v strict="$STRICT" '
function jesc(s,   r) { r = s; gsub(/\\/, "\\\\", r); gsub(/"/, "\\\"", r); return r }
function decode_esc(s,   out, i, n, c, nc) {
    out = ""; n = length(s); i = 1
    while (i <= n) {
        c = substr(s, i, 1)
        if (c == "\\" && i < n) {
            nc = substr(s, i + 1, 1)
            if (nc == "n")  { out = out "\n"; i += 2; continue }
            if (nc == "r")  { out = out "\r"; i += 2; continue }
            if (nc == "t")  { out = out "\t"; i += 2; continue }
            if (nc == "\\") { out = out "\\"; i += 2; continue }
        }
        out = out c; i++
    }
    return out
}
BEGIN { FS = "\t"; total = 0; clean = 0; viol = 0; body = "" }
/^# error\t/ { next }
{
    kind = $1; tgtk = $2; fn = $3; file = $4; line = $5; body_text = decode_esc($7)
    if (kind != "pure") next
    if (tgtk != "fn") next
    total++
    vlist = ""
    n_v = 0
    # Walk the body_text looking for forbidden call idents. The AST extractor
    # already stripped comments and re-quoted StringLits, so substring index
    # is correct on the token-joined body.
    if (index(body_text, " exec ( ") > 0 || index(body_text, "exec ( ") == 1)      { if (n_v > 0) vlist = vlist "|"; vlist = vlist "exec("; n_v++ }
    if (index(body_text, " print ( ") > 0 || index(body_text, "print ( ") == 1)    { if (n_v > 0) vlist = vlist "|"; vlist = vlist "print("; n_v++ }
    if (index(body_text, " println ( ") > 0 || index(body_text, "println ( ") == 1){ if (n_v > 0) vlist = vlist "|"; vlist = vlist "println("; n_v++ }
    if (index(body_text, " eprintln ( ") > 0 || index(body_text, "eprintln ( ") == 1){ if (n_v > 0) vlist = vlist "|"; vlist = vlist "eprintln("; n_v++ }
    if (index(body_text, " env ( ") > 0 || index(body_text, "env ( ") == 1)        { if (n_v > 0) vlist = vlist "|"; vlist = vlist "env("; n_v++ }
    if (strict == 1 && (index(body_text, " let mut ") > 0 || index(body_text, "let mut ") == 1)) {
        if (n_v > 0) vlist = vlist "|"; vlist = vlist "let mut"; n_v++
    }
    if (n_v == 0) clean++
    else viol++
    # build violations JSON array
    vjson = ""
    if (n_v > 0) {
        n_split = split(vlist, parts, "|")
        for (i = 1; i <= n_split; i++) {
            if (i > 1) vjson = vjson ","
            vjson = vjson "\"" jesc(parts[i]) "\""
        }
    }
    if (body != "") body = body ","
    body = body "{\"fn\":\"" jesc(fn) "\",\"file\":\"" jesc(file) "\",\"line\":" line ",\"violations\":[" vjson "]}"
}
END {
    printf("{\"version\":\"0.2\",\"source\":\"ast\",\"pure_fns\":[%s],\"summary\":{\"total\":%d,\"clean\":%d,\"violations\":%d}}\n", body, total, clean, viol)
}'
