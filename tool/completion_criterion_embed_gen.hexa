// tool/completion_criterion_embed_gen.hexa — Wave 1 absorption driver (D6)
//
// @version 0.1.0
// @capabilities [fs_read, fs_write, exec]
//
// Reads ~/core/nexus/config/projects.json, extracts
// _meta.universal_completion_criterion, emits
// compiler/completion_criterion/embedded.gen.hexa.
//
// HASH semantics: we hash the FULL projects.json bytes (the SSOT input
// file) so drift in either the criterion or the surrounding _meta
// triggers a regen signal. Source_count is fixed at 1 (single record).

use "compiler/completion_criterion/embed"

let DEFAULT_SRC: string = "config/projects.json"
let DEFAULT_OUT: string = "/Users/ghost/core/hexa-lang/compiler/completion_criterion/embedded.gen.hexa"
let MODULE_NAME: string = "COMPLETION_CRITERION"

fn _esc_char(c: string) -> string {
    if c == "\\" { return "\\\\" }
    if c == "\"" { return "\\\"" }
    if c == "\n" { return "\\n" }
    if c == "\r" { return "\\r" }
    if c == "\t" { return "\\t" }
    return c
}

fn _esc(s: string) -> string {
    let n = len(s)
    let chunks = []
    let mut i = 0
    while i < n {
        chunks.push(_esc_char(s.substring(i, i + 1)))
        i = i + 1
    }
    return chunks.join("")
}

fn _iso_utc_now() -> string {
    return exec("LC_ALL=C date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _sha256(path: string) -> string {
    let out = exec("LC_ALL=C shasum -a 256 " + path).trim()
    if len(out) < 64 { return "" }
    return out.substring(0, 64)
}

fn _gstr(m, key: string) -> string {
    if !has_key(m, key) { return "" }
    let v = m[key]
    if type_of(v) == "void" { return "" }
    return to_string(v)
}

fn _gint(m, key: string) -> i64 {
    if !has_key(m, key) { return 0 }
    let v = m[key]
    let t = type_of(v)
    if t == "int" { return v }
    if t == "float" { return to_int(v) }
    return 0
}

fn _garr(m, key: string) -> array {
    let out = []
    if !has_key(m, key) { return out }
    let v = m[key]
    if type_of(v) != "array" { return out }
    let n = len(v)
    let mut i = 0
    while i < n {
        out.push(to_string(v[i]))
        i = i + 1
    }
    return out
}

fn _emit_str_array(parts: array, arr: array) {
    parts.push("[")
    let n = len(arr)
    let mut i = 0
    while i < n {
        parts.push("\"")
        parts.push(_esc(to_string(arr[i])))
        parts.push("\"")
        if i + 1 < n { parts.push(", ") }
        i = i + 1
    }
    parts.push("]")
}

fn main() {
    let av = argv()
    let mut src = ""
    if len(av) >= 3 { src = to_string(av[2]) }
    if len(src) == 0 { src = env("HOME") + "/core/nexus/" + DEFAULT_SRC }
    let out_path = DEFAULT_OUT

    println("wave1 completion_criterion embed codegen")
    println("  src:  " + src)
    println("  out:  " + out_path)

    let hash = _sha256(src)
    let gen_at = _iso_utc_now()
    let text = read_file(src)
    let root = json_parse(text)

    // Extract _meta.universal_completion_criterion.
    let crit = json_parse("{}")
    let mut have = false
    if type_of(root) == "map" && has_key(root, "_meta") {
        let meta = root["_meta"]
        if type_of(meta) == "map" && has_key(meta, "universal_completion_criterion") {
            let c = meta["universal_completion_criterion"]
            if type_of(c) == "map" {
                let ks = map_keys(c)
                let nk = len(ks)
                let mut i = 0
                while i < nk {
                    let k = to_string(ks[i])
                    crit[k] = c[k]
                    i = i + 1
                }
                have = true
            }
        }
    }
    if !have {
        println("FATAL: _meta.universal_completion_criterion not found in " + src)
        exit(1)
    }

    let parts = []
    parts.push("// AUTO-GENERATED — do not edit. Regenerate via tool/completion_criterion_embed_gen.hexa\n")
    parts.push("//\n")
    parts.push("// Wave 1 absorption: universal completion criterion static embed (D6).\n")
    parts.push("// Source: config/projects.json -> _meta.universal_completion_criterion\n")
    parts.push("\n")
    parts.push("use \"compiler/completion_criterion/embed\"\n")
    parts.push("\n")
    parts.push("@phase(\"parse_only\")\n")
    parts.push("pub let " + MODULE_NAME + "_HASH: string = \"" + _esc(hash) + "\"\n")
    parts.push("@phase(\"parse_only\")\n")
    parts.push("pub let " + MODULE_NAME + "_GENERATED_AT: string = \"" + _esc(gen_at) + "\"\n")
    parts.push("@phase(\"parse_only\")\n")
    parts.push("pub let " + MODULE_NAME + "_SOURCE_COUNT: i64 = 1\n")
    parts.push("\n")
    parts.push("@phase(\"parse_only\")\n")
    parts.push("pub let " + MODULE_NAME + ": CompletionCriterion = CompletionCriterion {\n")
    parts.push("    name: \"")
    parts.push(_esc(_gstr(crit, "name")))
    parts.push("\",\n")
    parts.push("    breakthrough_threshold: ")
    parts.push(to_string(_gint(crit, "breakthrough_threshold")))
    parts.push(",\n")
    parts.push("    breakthrough_label: \"")
    parts.push(_esc(_gstr(crit, "breakthrough_label")))
    parts.push("\",\n")
    parts.push("    breakthrough_definition: \"")
    parts.push(_esc(_gstr(crit, "breakthrough_definition")))
    parts.push("\",\n")
    parts.push("    principle: \"")
    parts.push(_esc(_gstr(crit, "principle")))
    parts.push("\",\n")
    parts.push("    description: \"")
    parts.push(_esc(_gstr(crit, "description")))
    parts.push("\",\n")
    parts.push("    forbidden: ")
    _emit_str_array(parts, _garr(crit, "forbidden"))
    parts.push(",\n")
    parts.push("    allowed: ")
    _emit_str_array(parts, _garr(crit, "allowed"))
    parts.push(",\n")
    parts.push("    verify_type: \"")
    parts.push(_esc(_gstr(crit, "verify_type")))
    parts.push("\",\n")
    parts.push("    verify_artifact: \"")
    parts.push(_esc(_gstr(crit, "verify_artifact")))
    parts.push("\",\n")
    parts.push("    violation: \"")
    parts.push(_esc(_gstr(crit, "violation")))
    parts.push("\"\n")
    parts.push("}\n")

    write_file(out_path, parts.join(""))

    let sz = file_size(out_path)
    println("")
    println("emit:")
    println("  entries: 1")
    println("  size:    " + to_string(sz) + " bytes")
    println("  sha256:  " + hash)
    println("  gen_at:  " + gen_at)
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = to_string(_av[1])
    if s.ends_with("/completion_criterion_embed_gen.hexa") { return true }
    if s == "completion_criterion_embed_gen.hexa" { return true }
    return false
}
if _is_main() { main() }
