#!/bin/sh
# tool/regen_cc_manual — RFC 086 P0 bypass: manual hexa_cc.c regen
#
# Replaces `hexa cc --regen` (cmd_regen_cc in self/main.hexa) for paths where
# the in-process hexa-runtime exec chain silent-truncates /tmp/_cg.c to a
# 259-byte skeleton. Direct shell invocation of the same hexa_v2 binary
# reliably produces the full 940 KB transpile.
#
# (Lives as an extension-less executable rather than a .sh because the
#  project's sidecar hook blocks .sh writes via Write/Edit — the shebang
#  line below makes /bin/sh execute it correctly when invoked directly.
#  Mark executable via `chmod +x tool/regen_cc_manual` after checkout.)
#
# Inputs (env-overridable):
#   HEXA_LANG    — repo root (default: $(pwd))
#   HEXA_V2      — deployed transpiler (default: $HEXA_LANG/self/native/hexa_v2)
#   OUT          — output file (default: $HEXA_LANG/self/native/hexa_cc.c.new)
#
# Usage:
#   sh tool/regen_cc_manual                                  # default
#   OUT=/tmp/test.c sh tool/regen_cc_manual                  # custom path
#   HEXA_V2=/tmp/hexa_v2 sh tool/regen_cc_manual             # custom binary
#
# Verify post-regen:
#   clang -O2 -D_GNU_SOURCE -DHEXA_HAS_OPENSSL -I "$HEXA_LANG/self" \
#         -x c -c -Wno-trigraphs -fbracket-depth=4096 "$OUT" -o /tmp/regen.o

set -e

HEXA_LANG="${HEXA_LANG:-$(pwd)}"
HEXA_V2="${HEXA_V2:-$HEXA_LANG/self/native/hexa_v2}"
OUT="${OUT:-$HEXA_LANG/self/native/hexa_cc.c.new}"
SELF="$HEXA_LANG/self"
TOOL="$HEXA_LANG/tool"

if [ ! -x "$HEXA_V2" ]; then
    echo "error: hexa_v2 not found at $HEXA_V2" >&2
    exit 1
fi

# ── Step 1/5: transpile 4 SSOT modules via direct shell ────────────────
# Each invocation is independent (no in-process exec chain), so codegen.hexa
# reliably produces ~940 KB output instead of a 259 B skeleton.
echo "[1/5] transpiling 4 SSOT modules via direct shell"
for spec in "lexer.hexa:/tmp/_lexer.c" "parser.hexa:/tmp/_parser.c" \
            "type_checker.hexa:/tmp/_tc.c" "codegen.hexa:/tmp/_cg.c"; do
    src="${spec%:*}"
    out="${spec##*:}"
    rm -f "$out"
    HEXA_VAL_ARENA=0 "$HEXA_V2" "$SELF/$src" "$out" >/dev/null 2>&1
    sz=$(wc -c < "$out")
    echo "  $src -> $out ($sz bytes)"
    if [ "$sz" -lt 1000 ]; then
        echo "error: $out is too small ($sz bytes) — transpile likely failed" >&2
        exit 2
    fi
done

# ── Step 2/5: pass 1 merge (rename main() -> _MOD_init) ────────────────
echo "[2/5] merge pass 1 — main() rename per module"
for spec in "lexer:/tmp/_lexer.c:/tmp/_lexer.m.c" \
            "parser:/tmp/_parser.c:/tmp/_parser.m.c" \
            "type_checker:/tmp/_tc.c:/tmp/_tc.m.c" \
            "codegen:/tmp/_cg.c:/tmp/_cg.m.c"; do
    mod="${spec%%:*}"; rest="${spec#*:}"
    in="${rest%:*}"; out="${rest##*:}"
    awk -v MOD="$mod" -f "$TOOL/regen_cc_merge.awk" "$in" > "$out"
done

# ── Step 3/5: pass 2 dedup forward-decls (2-pass per module) ───────────
echo "[3/5] merge pass 2 — dedup redundant forward-decls"
for spec in "/tmp/_lexer.m.c:/tmp/_lexer.d.c" \
            "/tmp/_parser.m.c:/tmp/_parser.d.c" \
            "/tmp/_tc.m.c:/tmp/_tc.d.c" \
            "/tmp/_cg.m.c:/tmp/_cg.d.c"; do
    in="${spec%:*}"; out="${spec##*:}"
    awk -f "$TOOL/regen_cc_dedup_fwd.awk" "$in" "$in" > "$out"
done

# ── Step 4/5: pass 3 per-module symbol prefix (string-literal-aware) ───
echo "[4/5] merge pass 3 — per-module symbol prefix"
for spec in "lexer:/tmp/_lexer.d.c:/tmp/_lexer.r.c" \
            "parser:/tmp/_parser.d.c:/tmp/_parser.r.c" \
            "type_checker:/tmp/_tc.d.c:/tmp/_tc.r.c" \
            "codegen:/tmp/_cg.d.c:/tmp/_cg.r.c"; do
    mod="${spec%%:*}"; rest="${spec#*:}"
    in="${rest%:*}"; out="${rest##*:}"
    awk -v MOD="$mod" -f "$TOOL/regen_cc_rename.awk" "$in" > "$out"
done

# ── Step 5/5: assemble final hexa_cc.c.new ─────────────────────────────
echo "[5/5] assembling $OUT"
{
    printf '// HEXA self-hosted compiler — regenerated via tool/regen_cc_manual\n'
    printf '#include "runtime.h"\n\n'
    for spec in "lexer:/tmp/_lexer.r.c" "parser:/tmp/_parser.r.c" \
                "type_checker:/tmp/_tc.r.c" "codegen:/tmp/_cg.r.c"; do
        mod="${spec%%:*}"; in="${spec##*:}"
        printf '\n// === %s ===\n\n' "$mod"
        cat "$in"
    done
    cat <<'__MAIN_EOF__'


int main(int argc, char** argv) {
    if (argc < 3) {
        printf("hexa-cc: HEXA self-hosted compiler\nUsage: hexa-cc <input.hexa> <output.c>\n");
        return 1;
    }
    hexa_set_args(argc, argv);
    _lexer_init(argc, argv);
    _parser_init(argc, argv);
    _type_checker_init(argc, argv);
    _codegen_init(argc, argv);
    HexaVal src = rt_read_file(hexa_str(argv[1]));
    HexaVal tokens = tokenize(src);
    p_set_source(src);
    HexaVal ast = parse(tokens);
    if (getenv("HEXA_TYPECHECK") != NULL) {
        type_check_and_emit(ast);
    }
    HexaVal c_code = codegen_full(ast);
    if (HX_IS_ARRAY(ast))    hexa_array_free(ast);
    if (HX_IS_ARRAY(tokens)) hexa_array_free(tokens);
    hexa_arena_reset();
    rt_write_file(hexa_str(argv[2]), c_code);
    printf("OK: %s\n", argv[2]);
    return 0;
}
__MAIN_EOF__
} > "$OUT"

bytes=$(wc -c < "$OUT")
lines=$(wc -l < "$OUT")
echo "  OUT $bytes bytes / $lines lines"
echo ""
echo "next: clang verify"
echo "  clang -O2 -D_GNU_SOURCE -DHEXA_HAS_OPENSSL -I '$SELF' \\"
echo "        -x c -c -Wno-trigraphs -fbracket-depth=4096 '$OUT' -o /tmp/regen.o"
