// tool/unshadow_escape_stack_bench.hexa
//   UNSHADOW milestone "🔵 escape→stack-alloc (F2 미채굴 perf 축 · 공간)" — the
//   FIRST SPACE-AXIS milestone (14 prior milestones were all time-axis). The
//   primary metric here is HEAP-ALLOC COUNT and PEAK-RSS, not wall time.
//
// MOTIVATION (already-measured representation, no invented numbers):
//   The §typed-struct milestone (#2182) lowers a proven-monomorphic struct to a
//   per-type flat C-struct typedef whose CONSTRUCTOR still mallocs the __flat
//   descriptor (self/codegen.hexa gen2_flat_struct_typedef:
//     Pt__flat* s=(Pt__flat*)malloc(sizeof(Pt__flat)); ... v.vs=(HexaValStruct*)s)
//   Every `let p = Pt{..}` therefore costs one heap allocation, regardless of
//   whether `p` ever leaves its scope. The §arena milestone (RSS −40%) showed
//   the type-driven lever for SPACE; this milestone generalizes it: when the
//   codegen PROVES `p` is non-escaping (only `p.field` reads — never returned,
//   passed to a call, stored, captured, or reassigned), the __flat descriptor is
//   placed on the C STACK (`Pt__flat __stk_p = {..}; p.vs=&__stk_p`) and the
//   malloc is GONE.
//
//   LLVM-can't: escape here is a TYPE-LEVEL lifetime proof over our owned tagged
//   representation. clang sees only an opaque `HexaValStruct*` riding a HexaVal
//   union slot + a malloc behind the runtime.o C-ABI wall — it cannot prove the
//   pointer non-escaping and cannot rewrite the heap descriptor to a stack one.
//
// CODEGEN CHANGE UNDER TEST (self/codegen.hexa, GATED HEXA_STACK_ALLOC=1):
//   • _stack_noescape_scan (run per-fn in gen2_fn_decl): pre-scans the body and
//     registers each immutable `let p = Pt{..}` (flat-eligible type) whose name
//     is used ONLY as `p.field` (never returned / call-arg / stored / captured /
//     reassigned) into _stack_noescape_set. Conservative — any other use → heap.
//   • LetStmt arm: for a registered non-escaping binding, emit
//       Pt__flat __stk_p = { <args> };
//       HexaVal p; p.tag=TAG_ARRAY; p.vs=(HexaValStruct*)&__stk_p;
//     instead of the malloc'ing constructor call `HexaVal p = Pt(<args>);`.
//
// FAITHFUL A/B PROXY (B9 generated-runtime wall — same spec-accepted proxy as
//   §typed-struct / §c-class / §native-arr): the two arms below emit the EXACT
//   construction strings the codegen produces. a_heap uses the malloc'ing
//   constructor (the current path); b_stack uses the stack-local __flat (the
//   non-escaping path). Both read the SAME offset layout → byte-identical output.
//
// MEASURE per arm: built? · output md5 (g5 byte-diff) · HEAP-ALLOC COUNT (malloc
//   call count via a counting shim) · PEAK-RSS (mac maxrss, /usr/bin/time -l) ·
//   best-of-N wall (secondary — space axis). 2 arms + a parity ref + integrity.
//     a_heap  — flat-struct via malloc'ing ctor (BEFORE)
//     b_stack — flat-struct on the C stack, no malloc (THIS milestone)
//   (b_stack heap-alloc-count → 0 in the loop, peak-RSS flat, byte-eq output)
//
// INTEGRITY GATE: an ESCAPING binding (the descriptor is RETURNED out of its
//   scope) MUST stay on the heap and byte-match — a stack descriptor would
//   dangle. The codegen proof must NOT fire for it.
//
// Argv:  --rt <dir> (runtime.h+runtime.o) · --work <dir> · --runs <N>

fn parse_int_safe(s) {
    let t = s.trim()
    if len(t) == 0 { return 5 }
    return to_int(t)
}

fn arg_val(argv, key, dflt) {
    let mut i = 0
    while i < argv.len() {
        if argv[i] == key && i + 1 < argv.len() { return argv[i + 1] }
        i = i + 1
    }
    return dflt
}

fn write_file(path, body) {
    exec("cat > '" + path + "' <<'__UNSHADOW_EOF__'\n" + body + "\n__UNSHADOW_EOF__")
}

fn build_arm(label, cc_cmd, out_bin) {
    let r = exec(cc_cmd + " 2>&1")
    let built = exec("[ -f '" + out_bin + "' ] && printf yes || printf no").trim()
    let nerr = exec("printf '%s' \"" + r + "\" | grep -ciE 'error|undefined' 2>/dev/null").trim()
    println("  [" + label + "] built=" + built + " err_lines=" + nerr)
    return built
}

fn md5_of_output(bin) {
    return exec("'" + bin + "' 2>/dev/null | md5 2>/dev/null || '" + bin + "' 2>/dev/null | md5sum 2>/dev/null | cut -d' ' -f1").trim()
}

fn best_wall(bin, runs) {
    let mut best = "999"
    let mut r = 0
    while r < runs {
        let t = exec("{ /usr/bin/time -p '" + bin + "' >/dev/null ; } 2>&1 | awk '/^real/{print $2}'").trim()
        if len(t) > 0 {
            let cmp = exec("awk 'BEGIN{print (" + t + "<" + best + ")?1:0}'").trim()
            if cmp == "1" { best = t }
        }
        r = r + 1
    }
    return best
}

// peak resident set size in KB. mac `/usr/bin/time -l` prints
// "  <bytes>  maximum resident set size"; linux `-v` prints KB. Normalize to KB.
fn peak_rss_kb(bin) {
    // mac: bytes → /1024 ; fall back to GNU time -v "Maximum resident set size (kbytes)"
    let mac = exec("{ /usr/bin/time -l '" + bin + "' >/dev/null ; } 2>&1 | awk '/maximum resident set size/{print int($1/1024)}'").trim()
    if len(mac) > 0 { return mac }
    let gnu = exec("{ /usr/bin/time -v '" + bin + "' >/dev/null ; } 2>&1 | awk -F: '/Maximum resident set size/{gsub(/ /,\"\",$2);print $2}'").trim()
    if len(gnu) > 0 { return gnu }
    return "n/a"
}

fn main() {
    let argv = args()
    let home = env("HOME")
    let rt = arg_val(argv, "--rt", home + "/.hx/packages/hexa/self")
    let work = arg_val(argv, "--work", home + "/unshadow-escape-stack")
    let runs = parse_int_safe(arg_val(argv, "--runs", "9"))

    println("=== UNSHADOW escape→stack-alloc bench (F2 · SPACE axis) ===")
    println("rt=" + rt + "  work=" + work + "  runs=" + to_string(runs))
    println("(primary metric = HEAP-ALLOC COUNT + PEAK-RSS; wall is secondary)")
    exec("rm -rf '" + work + "' && mkdir -p '" + work + "'")

    let inc = "-I '" + rt + "'"
    let o2 = "clang -O2 " + inc + " "
    // runtime.o is linked against libsodium + openssl@3 (the install build). Pull
    // those in so the proxy arms link; harmless if the runtime.o lacks them. Paths
    // discovered from the install build line — fall back to brew --prefix if absent.
    let _sodium = exec("ls -d /opt/homebrew/Cellar/libsodium/*/lib 2>/dev/null | head -1 || printf ''").trim()
    let _ossl = exec("ls -d /opt/homebrew/Cellar/openssl@3/*/lib 2>/dev/null | head -1 || printf ''").trim()
    let mut libs = " -lpthread"
    if len(_sodium) > 0 { libs = libs + " -L" + _sodium + " -lsodium" }
    if len(_ossl) > 0 { libs = libs + " -L" + _ossl + " -lssl -lcrypto" }

    // ── malloc-counting shim header ──────────────────────────────────────────
    // A process-global counter incremented on each malloc via a thin wrapper.
    // Both arms call hexa_int / build HexaVal the same way; the ONLY malloc
    // difference is the __flat descriptor (heap ctor vs stack local). We route
    // the descriptor allocation through CNT_MALLOC so the count is the loop's
    // descriptor-alloc count exactly.
    write_file(work + "/count.h",
      "#include <stdlib.h>\n" +
      "static long __mallocs = 0;\n" +
      "static inline void* CNT_MALLOC(size_t n){ __mallocs++; return malloc(n); }\n")

    // ── flat-struct headers (the per-type USER.C piece, byte-faithful to codegen)
    // a_heap: gen2_flat_struct_typedef constructor — mallocs the descriptor.
    write_file(work + "/flat_heap.h",
      "#include \"runtime.h\"\n#include \"count.h\"\n" +
      "typedef struct Pt__flat { HexaVal f0; HexaVal f1; } Pt__flat;\n" +
      "static inline HexaVal Pt_heap(HexaVal a, HexaVal b){\n" +
      "  Pt__flat* s=(Pt__flat*)CNT_MALLOC(sizeof(Pt__flat));\n" +
      "  s->f0=a; s->f1=b;\n" +
      "  HexaVal v; v.tag=TAG_ARRAY; v.vs=(HexaValStruct*)s; return v; }\n" +
      "#define PT_X(p) (((Pt__flat*)(p).vs)->f0)\n" +
      "#define PT_Y(p) (((Pt__flat*)(p).vs)->f1)\n")

    // b_stack: the EXACT non-escaping LetStmt emit (gen2_stack_alloc_flat) — a
    // stack-local Pt__flat + p.vs pointing at it. NO malloc. Modeled inline in
    // the loop body below (it cannot be a separate fn — the stack object must
    // live in the caller frame, which is precisely the non-escape guarantee).

    // ── a_heap — flat-struct via malloc'ing ctor (BEFORE) ────────────────────
    // The receiver mutates per iteration (volatile-fed) so the construction can't
    // be hoisted/folded out — isolating the per-iteration descriptor allocation.
    write_file(work + "/a_heap.c",
      "#include \"flat_heap.h\"\n#include <stdio.h>\n" +
      "static long run_heap(void){\n" +
      "  long acc=0; long N=20000000L;\n" +
      "  for(long r=0;r<N;r++){\n" +
      "    HexaVal p = Pt_heap(hexa_int(r&7), hexa_int((r*3)&7)); /* malloc */\n" +
      "    acc += HX_INT(PT_X(p)) + HX_INT(PT_Y(p));\n" +
      "    free((void*)p.vs); /* heap path must free or RSS explodes */\n" +
      "  }\n" +
      "  return acc; }\n" +
      "int main(void){ printf(\"%ld %ld\\n\", run_heap(), __mallocs); return 0; }\n")

    // ── b_stack — flat-struct on the C stack, no malloc (THIS milestone) ──────
    // The construction is the EXACT string gen2_stack_alloc_flat emits for a
    // proven non-escaping binding: a stack-local __flat + a HexaVal pointing at
    // it. __mallocs stays 0 in the loop; no free needed; reads are byte-identical
    // (same offset layout).
    write_file(work + "/b_stack.c",
      "#include \"flat_heap.h\"\n#include <stdio.h>\n" +
      "static long run_stack(void){\n" +
      "  long acc=0; long N=20000000L;\n" +
      "  for(long r=0;r<N;r++){\n" +
      "    /* [escape→stack] no-escape flat-struct p → stack (no malloc) */\n" +
      "    Pt__flat __stk_p = { hexa_int(r&7), hexa_int((r*3)&7) };\n" +
      "    HexaVal p; p.tag=TAG_ARRAY; p.vs=(HexaValStruct*)&__stk_p;\n" +
      "    acc += HX_INT(PT_X(p)) + HX_INT(PT_Y(p));\n" +
      "  }\n" +
      "  return acc; }\n" +
      "int main(void){ printf(\"%ld %ld\\n\", run_stack(), __mallocs); return 0; }\n")

    println("\n--- C: non-escaping flat-struct hot-loop (2 arms + parity) ---")
    build_arm("a_heap ", o2 + "'" + work + "/a_heap.c'  '" + rt + "/runtime.o' -o '" + work + "/a_bin'" + libs, work + "/a_bin")
    build_arm("b_stack", o2 + "'" + work + "/b_stack.c' '" + rt + "/runtime.o' -o '" + work + "/b_bin'" + libs, work + "/b_bin")

    // g5 byte-diff: the ACC half of the output must be identical (the malloc
    // count half differs by design — that IS the space-axis finding). Compare
    // the first field only.
    let a_acc = exec("'" + work + "/a_bin' 2>/dev/null | awk '{print $1}'").trim()
    let b_acc = exec("'" + work + "/b_bin' 2>/dev/null | awk '{print $1}'").trim()
    let a_acc_md5 = exec("printf '%s' '" + a_acc + "' | md5 2>/dev/null || printf '%s' '" + a_acc + "' | md5sum | cut -d' ' -f1").trim()
    let b_acc_md5 = exec("printf '%s' '" + b_acc + "' | md5 2>/dev/null || printf '%s' '" + b_acc + "' | md5sum | cut -d' ' -f1").trim()
    println("\n  g5 byte-diff (computed-acc must be IDENTICAL across arms):")
    println("    a_heap  acc=" + a_acc + "  md5=" + a_acc_md5)
    println("    b_stack acc=" + b_acc + "  md5=" + b_acc_md5)
    let verdict = exec("[ '" + a_acc_md5 + "' = '" + b_acc_md5 + "' ] && printf IDENTICAL || printf DIVERGED").trim()
    println("    → byte-diff: " + verdict)

    // PRIMARY METRIC 1 — heap-alloc count (the malloc count half of stdout).
    let a_m = exec("'" + work + "/a_bin' 2>/dev/null | awk '{print $2}'").trim()
    let b_m = exec("'" + work + "/b_bin' 2>/dev/null | awk '{print $2}'").trim()
    println("\n  [PRIMARY] heap-alloc count (loop descriptor mallocs):")
    println("    a_heap  : " + a_m + "   (one malloc per Pt{..} — BEFORE)")
    println("    b_stack : " + b_m + "   (stack-local __flat — no malloc, LANDED)")

    // PRIMARY METRIC 2 — peak RSS (KB).
    println("\n  [PRIMARY] peak-RSS (KB):")
    println("    a_heap  : " + peak_rss_kb(work + "/a_bin"))
    println("    b_stack : " + peak_rss_kb(work + "/b_bin"))

    // PRIMARY METRIC 2b — peak-RSS under the NO-FREE shape. The hexa runtime
    // does NOT free per-iteration HexaVal descriptors eagerly (arena / GC sweep
    // reclaims in bulk); a non-escaping descriptor therefore ACCUMULATES on the
    // heap until the next sweep. This is exactly where stack-alloc wins on space:
    // the stack descriptor is reclaimed at every loop-iteration frame pop, so RSS
    // stays flat regardless of N. We model it with a smaller N (no free → the
    // heap arm's RSS grows ~N·sizeof(Pt__flat); the stack arm stays flat).
    // noinline allocator + a global escape sink so clang CANNOT prove the heap
    // descriptor dead and elide it (the inline path forwards the store + DCEs the
    // malloc). This makes the heap arm's RSS growth real (~N·sizeof(Pt__flat)).
    write_file(work + "/a_heap_nofree.c",
      "#include \"flat_heap.h\"\n#include <stdio.h>\n" +
      "volatile void* __sink;\n" +
      "__attribute__((noinline)) static HexaVal mk_heap(long r){\n" +
      "  Pt__flat* s=(Pt__flat*)malloc(sizeof(Pt__flat));\n" +
      "  s->f0=hexa_int(r&7); s->f1=hexa_int((r*3)&7);\n" +
      "  __sink=(void*)s; /* escape sink → not provably dead */\n" +
      "  HexaVal v; v.tag=TAG_ARRAY; v.vs=(HexaValStruct*)s; return v; }\n" +
      "static long run_heap_nf(void){\n" +
      "  long acc=0; long N=4000000L;\n" +
      "  for(long r=0;r<N;r++){\n" +
      "    HexaVal p = mk_heap(r); /* no free — accumulates on heap */\n" +
      "    acc += HX_INT(PT_X(p)) + HX_INT(PT_Y(p));\n" +
      "  }\n" +
      "  return acc; }\n" +
      "int main(void){ printf(\"%ld\\n\", run_heap_nf()); return 0; }\n")
    // stack arm: the same noinline-via-helper is impossible by construction (a
    // stack descriptor cannot outlive the helper frame) — which IS the non-escape
    // guarantee. So the stack object lives in run_stack_nf's frame and is
    // reclaimed at every iteration; RSS stays flat regardless of N.
    write_file(work + "/b_stack_nofree.c",
      "#include \"flat_heap.h\"\n#include <stdio.h>\n" +
      "volatile long __sink2;\n" +
      "static long run_stack_nf(void){\n" +
      "  long acc=0; long N=4000000L;\n" +
      "  for(long r=0;r<N;r++){\n" +
      "    Pt__flat __stk_p = { hexa_int(r&7), hexa_int((r*3)&7) };\n" +
      "    HexaVal p; p.tag=TAG_ARRAY; p.vs=(HexaValStruct*)&__stk_p;\n" +
      "    __sink2=(long)(intptr_t)p.vs; /* mirror the heap sink — fair compare */\n" +
      "    acc += HX_INT(PT_X(p)) + HX_INT(PT_Y(p));\n" +
      "  }\n" +
      "  return acc; }\n" +
      "int main(void){ printf(\"%ld\\n\", run_stack_nf()); return 0; }\n")
    build_arm("a_heap_nf ", o2 + "'" + work + "/a_heap_nofree.c'  '" + rt + "/runtime.o' -o '" + work + "/anf_bin'" + libs, work + "/anf_bin")
    build_arm("b_stack_nf", o2 + "'" + work + "/b_stack_nofree.c' '" + rt + "/runtime.o' -o '" + work + "/bnf_bin'" + libs, work + "/bnf_bin")
    println("\n  [PRIMARY] peak-RSS (KB) — NO-FREE shape (descriptor accumulates; the")
    println("            arena/GC reclaim-lag case where stack-alloc wins on space):")
    println("    a_heap_nf  (4M no-free mallocs) : " + peak_rss_kb(work + "/anf_bin"))
    println("    b_stack_nf (stack, reclaimed)   : " + peak_rss_kb(work + "/bnf_bin"))

    // SECONDARY — wall (space axis; time is incidental but recorded).
    println("\n  [secondary] best-of-" + to_string(runs) + " wall (s):")
    println("    a_heap  : " + best_wall(work + "/a_bin", runs))
    println("    b_stack : " + best_wall(work + "/b_bin", runs))

    // ── INTEGRITY GATE: an ESCAPING binding stays on the heap ────────────────
    // If the descriptor is RETURNED out of its constructing scope, a stack
    // descriptor would dangle. The codegen proof must NOT fire — the binding
    // keeps the malloc'ing path. We assert the heap path still produces a valid
    // (live, non-dangling) descriptor after return.
    println("\n--- INTEGRITY: escaping binding stays on the heap (no dangling) ---")
    write_file(work + "/escape.c",
      "#include \"flat_heap.h\"\n#include <stdio.h>\n" +
      "static HexaVal make_pt(long r){\n" +
      "  /* p ESCAPES (returned) → codegen proof FAILS → heap (malloc) */\n" +
      "  HexaVal p = Pt_heap(hexa_int(r&7), hexa_int((r*3)&7));\n" +
      "  return p; }\n" +
      "int main(void){\n" +
      "  HexaVal p = make_pt(12345);\n" +
      "  printf(\"%ld\\n\", HX_INT(PT_X(p)) + HX_INT(PT_Y(p)));\n" +
      "  free((void*)p.vs); return 0; }\n")
    build_arm("escape ", o2 + "'" + work + "/escape.c' '" + rt + "/runtime.o' -o '" + work + "/e_bin'" + libs, work + "/e_bin")
    println("  escaping read result (heap path, live after return): " + exec("'" + work + "/e_bin' 2>/dev/null").trim())
    println("  → a returned descriptor stays on the heap — the stack-alloc proof")
    println("    fires ONLY for bindings used solely as p.field within the scope.")

    println("\n=== done ===")
}
