// tool/build_hexa_lsp.hexa — build the standalone `hexa lsp` sub-binary.
//
// Hexa-native build orchestrator (project.tape requires .hexa over .sh —
// porting tool/build_hexa_lsp.sh in the same cycle as the keyword-SSOT
// rewire). Pipeline:
//   1. (one-time) build compiled module_loader from self/module_loader.hexa
//      — needed because self/lsp.hexa now `use`s self/lexer to share the
//      keyword_list() SSOT; without a compiled loader the use-closure
//      flattens to extern-only stubs and clang link fails on _keyword_list
//      (see [[reference_hexa_module_loader_env_2026_05_20]]). Pattern
//      mirrors .github/workflows/bootstrap.yml stage-1.
//   2. `hexa build self/lsp.hexa -o bin/hexa-lsp` with HEXA_MODULE_LOADER
//      pointed at the freshly-built loader.
//   3. Smoke: feed a minimal LSP `initialize` request, expect a JSON-RPC
//      response naming `jsonrpc` / `capabilities` / `result`, then exit.
//
// Output: bin/hexa-lsp (override via $HEXA_LSP_OUT). Dispatcher at
// self/main.hexa::dispatch_absorbed sub == "lsp" || "--lsp" exec_replace()s
// into this binary when present.
//
// Usage:
//   hexa run tool/build_hexa_lsp.hexa

// ── Resolve repo root ──
let mut repo = env("HEXA_LANG")
if len(repo) == 0 {
    repo = exec("pwd").trim()
}
if !file_exists(repo + "/self/lsp.hexa") {
    println("build_hexa_lsp: no self/lsp.hexa under " + repo)
    exit(1)
}

let src = repo + "/self/lsp.hexa"
let env_out = env("HEXA_LSP_OUT")
let mut out = repo + "/bin/hexa-lsp"
if len(env_out) > 0 {
    out = env_out
}

// ── Stage 1 — ensure compiled module_loader exists ──
let ml_out = repo + "/build/hexa_module_loader"
if exec("test -x '" + ml_out + "' && printf yes || printf no") != "yes" {
    println("[build_hexa_lsp] building module_loader (one-time) -> " + ml_out)
    let _mk1 = exec("mkdir -p '" + repo + "/build/stage1' 2>/dev/null")
    let v2 = repo + "/self/native/hexat"
    if exec("test -x '" + v2 + "' && printf yes || printf no") != "yes" {
        println("build_hexa_lsp: hexat missing/not-executable: " + v2)
        exit(1)
    }
    let ml_c = repo + "/build/stage1/module_loader.c"
    let _t = exec("'" + v2 + "' '" + repo + "/self/module_loader.hexa' '" + ml_c + "' 2>&1 | tail -3")
    if len(_t) > 0 { println("    " + _t) }
    if exec("test -s '" + ml_c + "' && printf yes || printf no") != "yes" {
        println("build_hexa_lsp: hexat produced empty " + ml_c)
        exit(1)
    }
    let cl_ml = "clang -O2 -I '" + repo + "/self' '" + ml_c + "' '" + repo + "/self/runtime.c' -o '" + ml_out + "' -lpthread 2>&1"
    let _cl = exec(cl_ml)
    if exec("test -x '" + ml_out + "' && printf yes || printf no") != "yes" {
        println("build_hexa_lsp: module_loader link failed:")
        if len(_cl) > 0 { println(_cl) }
        exit(1)
    }
}

// ── Stage 2 — hexa build lsp.hexa -> bin/hexa-lsp ──
let _mk2 = exec("mkdir -p '" + exec("dirname '" + out + "'").trim() + "' 2>/dev/null")
println("[build_hexa_lsp] src=" + src)
println("[build_hexa_lsp] out=" + out)
println("[build_hexa_lsp] HEXA_MODULE_LOADER=" + ml_out)
let build_cmd = "HEXA_MAC_BUILD_OK=1 HEXA_MODULE_LOADER='" + ml_out + "' hexa build '" + src + "' -o '" + out + "' 2>&1"
let build_log = exec(build_cmd)
if exec("test -x '" + out + "' && printf yes || printf no") != "yes" {
    println("build_hexa_lsp: hexa build failed:")
    if len(build_log) > 0 { println(build_log) }
    exit(1)
}

// ── Stage 3 — initialize-handshake smoke test ──
// Pipe a minimal LSP `initialize` request and confirm a JSON-RPC reply.
println("[build_hexa_lsp] smoke: initialize handshake")
let req_path = exec("mktemp -t hexa_lsp_init.XXXXXX").trim()
let req_body = "Content-Length: 58\r\n\r\n{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}"
write_file(req_path, req_body)
let smoke_out = exec("'" + out + "' < '" + req_path + "' 2>&1 | head -c 400")
let _rm = exec("rm -f '" + req_path + "' 2>/dev/null")
let ok = false
let mut ok2 = ok
if smoke_out.contains("jsonrpc") { ok2 = true }
if smoke_out.contains("capabilities") { ok2 = true }
if smoke_out.contains("result") { ok2 = true }
if !ok2 {
    println("build_hexa_lsp: lsp initialize smoke FAIL — no JSON-RPC response")
    println(smoke_out)
    exit(2)
}

println("[build_hexa_lsp] OK -> " + out)
exit(0)
