// ai_native вЂ” unified dashboard CLI (orchestrates all ai-native tools)
//
// !! DEPRECATED вЂ” interp retired (R7, [[feedback_no_interp_use_compiled]]).
// !! analyze_file() dispatches each sub-tool via `build/hexa_interp`, which
// !! is no longer built. run_capture() returns "" в†’ grades degrade to A+ on
// !! all inputs (false-clean). Selftest path still works (pure helpers).
// !! Rewrite to use compiled CLI or retire. Tracked in INBOX.log.md
// !! 2026-05-25T22:30Z.
//
// Runs the relevant subset of ai-native tooling on one or more .hexa files
// and emits a compact grade per file plus a repo summary.
//
// Invokes (via exec):
//   tool/ai_native_lint.hexa      L1-L4 syntactic rules
//   tool/ai_native_hotpath.hexa   static hot-path candidates
//   self/opt/algorithm_swap.hexa     bubble/insertion detection
//
// Grading (per file):
//   A+  no findings                           вЂ” exceptional
//   A   warnings only (non-strict)            вЂ” acceptable
//   B   >=1 block violation OR 3+ warnings    вЂ” fix before ship
//   C   >=3 blocks OR hotpath+algo_swap hit   вЂ” refactor needed
//   F   complex violations (>=10 findings)    вЂ” rewrite
//
// Usage:
//   hexa tool/ai_native.hexa <file.hexa> [file2 ...]
//   hexa tool/ai_native.hexa --all self/stdlib    # glob-like dir scan

fn is_alpha(c) { let k = char_code(c, 0); return (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }
fn is_alnum(c) { let k = char_code(c, 0); return (k >= 48 && k <= 57) || (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }

fn count_lines_with(text, substr) {
    let lines = text.split("\n")
    let mut n = 0
    let mut i = 0
    while i < len(lines) {
        if lines[i].contains(substr) { n = n + 1 }
        i = i + 1
    }
    return n
}

fn run_capture(cmd) {
    try {
        return exec(cmd + " 2>/dev/null").trim()
    } catch e { return "" }
}

fn grade_from_counts(blocks, warns, hot, swap) {
    if blocks >= 10 || warns >= 20 { return "F" }
    if blocks >= 3 || (hot >= 3 && swap >= 1) { return "C" }
    if blocks >= 1 || warns >= 3 { return "B" }
    if warns >= 1 || hot >= 1 { return "A" }
    return "A+"
}

fn analyze_file(path) {
    let bin = env_var("HEXA_LANG") + "/build/hexa_interp"
    let root = env_var("HEXA_LANG")

    // Lint вЂ” L1-L4
    let lint_out = run_capture("'" + bin + "' '" + root + "/tool/ai_native_lint.hexa' '" + path + "' | grep -v 'security warning' | grep -v 'PERF:'")
    let blocks = count_lines_with(lint_out, "[BLOCK")
    let warns = count_lines_with(lint_out, "[warn ")

    // Hotpath
    let hot_out = run_capture("'" + bin + "' '" + root + "/tool/ai_native_hotpath.hexa' '" + path + "' | grep -v 'security warning' | grep -v 'PERF:'")
    let hot = count_lines_with(hot_out, "@hot candidate")
    let inline = count_lines_with(hot_out, "@inline candidate")
    let memo = count_lines_with(hot_out, "@memoize candidate")

    // Algorithm swap
    let swap_out = run_capture("'" + bin + "' '" + root + "/self/opt/algorithm_swap.hexa' '" + path + "' | grep -v 'security warning' | grep -v 'PERF:'")
    let swap = count_lines_with(swap_out, "[SUGGEST swap]")

    let grade = grade_from_counts(blocks, warns, hot, swap)
    return [grade, blocks, warns, hot, inline, memo, swap]
}

fn pad(s, w) {
    let mut r = s
    while len(r) < w { r = r + " " }
    return r
}

fn list_dir_hexa(dir) {
    let raw = run_capture("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    return raw.split("\n")
}

fn cmd_selftest() -> i64 {
    println("[ai_native selftest]")
    // Exercise pure helpers: grade_from_counts + pad.
    if grade_from_counts(0, 0, 0, 0) != "A+" { println("[ai_native selftest] FAIL grade_from_counts(0,0,0,0)"); return 1 }
    if grade_from_counts(0, 1, 0, 0) != "A"  { println("[ai_native selftest] FAIL grade_from_counts warn=1"); return 1 }
    if grade_from_counts(1, 0, 0, 0) != "B"  { println("[ai_native selftest] FAIL grade_from_counts block=1"); return 1 }
    if grade_from_counts(3, 0, 0, 0) != "C"  { println("[ai_native selftest] FAIL grade_from_counts block=3"); return 1 }
    if grade_from_counts(10, 0, 0, 0) != "F" { println("[ai_native selftest] FAIL grade_from_counts block=10"); return 1 }
    if pad("x", 4) != "x   " { println("[ai_native selftest] FAIL pad"); return 1 }
    println("[ai_native selftest] OK")
    return 0
}

fn main() {
    let argv = args()
    if len(argv) > 1 && (argv[1] == "--selftest" || argv[1] == "selftest") { exit(cmd_selftest()) }
    let mut files = []
    let mut i = 1
    while i < len(argv) {
        let a = argv[i]
        if a == "--all" && i + 1 < len(argv) {
            let dir_files = list_dir_hexa(argv[i + 1])
            let mut k = 0
            while k < len(dir_files) { files.push(dir_files[k]); k = k + 1 }
            i = i + 2
            continue
        }
        files.push(a)
        i = i + 1
    }
    if len(files) == 0 {
        println("usage: ai_native.hexa <file.hexa> [file2 ...]")
        println("       ai_native.hexa --all <dir>")
        return
    }

    println("в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—")
    println("в•‘  ai-native dashboard вЂ” unified grade across L1-L4 + hotpath + algorithm_swap  в•‘")
    println("в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ")
    println("")
    println(pad("grade ", 7) + pad("block", 6) + pad("warn", 6) + pad("@hot", 6) + pad("@inl", 6) + pad("@mem", 6) + pad("swap", 6) + "file")
    println("в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”ґв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ")

    let mut grades = []
    let mut i2 = 0
    while i2 < len(files) {
        let f = files[i2]
        try {
            let r = analyze_file(f)
            let grade = r[0]
            grades.push(grade)
            println(pad(grade, 7) + pad(to_string(r[1]), 6) + pad(to_string(r[2]), 6) + pad(to_string(r[3]), 6) + pad(to_string(r[4]), 6) + pad(to_string(r[5]), 6) + pad(to_string(r[6]), 6) + f)
        } catch e { println("  error on " + f + ": " + e) }
        i2 = i2 + 1
    }

    // Tally grade distribution
    let mut cA_plus = 0
    let mut cA = 0
    let mut cB = 0
    let mut cC = 0
    let mut cF = 0
    let mut gi = 0
    while gi < len(grades) {
        let g = grades[gi]
        if g == "A+" { cA_plus = cA_plus + 1 }
        else if g == "A" { cA = cA + 1 }
        else if g == "B" { cB = cB + 1 }
        else if g == "C" { cC = cC + 1 }
        else if g == "F" { cF = cF + 1 }
        gi = gi + 1
    }
    println("")
    println("в•ђв•ђв•ђ summary в•ђв•ђв•ђ")
    println("  A+ : " + to_string(cA_plus))
    println("  A  : " + to_string(cA))
    println("  B  : " + to_string(cB))
    println("  C  : " + to_string(cC))
    println("  F  : " + to_string(cF))
    println("  total files analyzed: " + to_string(len(files)))
}
