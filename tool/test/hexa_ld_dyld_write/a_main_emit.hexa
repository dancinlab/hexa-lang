#!hexa strict
// tool/test/hexa_ld_dyld_write/a_main_emit.hexa
//   B9.C-7 (.c-leg tool/test hexa_ld batch · #1852 pattern) —
//   hexa_ld_dyld_write/a_main.c source emitter.
//
// Emits the hexa_ld phase-H inc4 PoC object-A source (first dyld import:
// `bl _write` BRANCH26 → __stubs → __got bind) verbatim.
//
// PROVEN-DEFERRED: hand-written `.c` is preserved per RUNTIME.flip.md
// L418-419 "active linker dev · 보수적 KEEP" policy.
//
// Invocation:
//   hexa-run tool/test/hexa_ld_dyld_write/a_main_emit.hexa <output-path>

let MODULE_NAME = "hexa_ld_dyld_write_a_main_emit"

fn emit_a_main_c() -> str {
    // Verbatim content of hand-written tool/test/hexa_ld_dyld_write/a_main.c
    let s = "// a_main.c — Phase-H inc4 PoC: first dyld import (`_write` from libSystem).\n" +
            "//\n" +
            "// Exercises the dyld function-import path that inc1/2/3 deliberately\n" +
            "// skipped:\n" +
            "//\n" +
            "//   `bl _write` (ARM64_RELOC_BRANCH26, n_sect=0 extern) → __stubs entry\n" +
            "//   → __la_symbol_ptr (or __got) slot → dyld-bound at load time.\n" +
            "//\n" +
            "// All previous inc1/2/3 PoCs reached libSystem syscalls via raw\n" +
            "// `svc #0x80` instructions; this one tests the actual symbol-bind\n" +
            "// surface that arbitrary hexa-native programs will need.\n" +
            "//\n" +
            "// Control/INPUT: compiled with `clang -c` to a .o that REFERENCES\n" +
            "// `_write` (n_sect=0 extern_ref); linked by hexa_ld (NO clang/ld/as in\n" +
            "// the produced exe's link).\n" +
            "//\n" +
            "// Expected behaviour:\n" +
            "//   stdout    = \"hi\\n\"  (3 bytes via _write)\n" +
            "//   exit code = 0       (raw svc #0x80 SYS_exit; exit syscall doesn't\n" +
            "//                        need an import — we want to isolate the\n" +
            "//                        _write bind to a single failure surface)\n" +
            "\n" +
            "// MSG defined in b_data.c (separate __cstring object — already\n" +
            "// validated by inc2 PAGE21/PAGEOFF12 cross-object path).\n" +
            "extern const char MSG[];\n" +
            "\n" +
            "__attribute__((naked, used))\n" +
            "void _start(void) {\n" +
            "    __asm__ volatile(\n" +
            "        // x0 = fd = 1\n" +
            "        \"mov  x0, #1\\n\"\n" +
            "        // x1 = &MSG (PAGE21 + PAGEOFF12 to __cstring) — inc2 path\n" +
            "        \"adrp x1, _MSG@PAGE\\n\"\n" +
            "        \"add  x1, x1, _MSG@PAGEOFF\\n\"\n" +
            "        // x2 = 3\n" +
            "        \"mov  x2, #3\\n\"\n" +
            "        // call write(1, MSG, 3) — BRANCH26 reloc against extern _write\n" +
            "        // (this is the inc4 dyld-import gap)\n" +
            "        \"bl   _write\\n\"\n" +
            "        // exit(0) via raw syscall — no extern dependency\n" +
            "        \"mov  x0, #0\\n\"\n" +
            "        \"mov  x16, #1\\n\"   // SYS_exit\n" +
            "        \"svc  #0x80\\n\"\n" +
            "    );\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "a_main.c" }
    let c_text = emit_a_main_c()
    let cmd = "cat > \"" + out_path + "\" <<'__HEXA_LD_DYLD_WRITE_A_MAIN_EMIT_EOF__'\n" +
              c_text + "__HEXA_LD_DYLD_WRITE_A_MAIN_EMIT_EOF__"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[hexa_ld_dyld_write_a_main_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[hexa_ld_dyld_write_a_main_emit] wrote " + out_path)
    exit(0)
}
