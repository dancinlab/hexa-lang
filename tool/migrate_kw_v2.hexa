// tool/migrate_kw_v2.hexa — KEYWORD_DEMOTE.md v2 perfect-design migration
//
// Migrates block-form keywords to `@`-attribute form for any repo that
// consumes hexa-lang (wilson, anima, hexa-bio, hexa-brain, hexa-mind,
// hexa-chip, phanes, demiurge, wisp, hexa-meta, hexa-os, hexa-codex, …).
//
// Phases 1–3 of KEYWORD_DEMOTE.md have already landed in hexa-lang itself:
//   Phase 1 — select, scope, guard, channel : REMOVED  (no migration needed;
//             block-form usage was 0/0 everywhere)
//   Phase 2 — derive, optimize              : → @derive, @optimize
//   Phase 3 — generate, verify, intent,
//             effect                        : → @generate, @verify, @intent, @effect
//
// This script rewrites the 6 keywords-that-became-@-attributes. Each
// pattern is anchored at line start (after optional indent) and requires
// the keyword to be followed by whitespace + a likely construct token,
// so identifier uses elsewhere on the line (`fn verify(…)`, `verify_smoke()`)
// are left untouched.
//
// USAGE
//   hexa run tool/migrate_kw_v2.hexa                # dry-run, current repo
//   hexa run tool/migrate_kw_v2.hexa --apply        # rewrite files
//   hexa run tool/migrate_kw_v2.hexa --check        # exit 1 if any file would change
//   hexa run tool/migrate_kw_v2.hexa /path/to/repo  # operate on another repo
//
// Idempotent: re-running on an already-migrated repo is a no-op.
// Only touches git-tracked .hexa files.

// ── line-rewrite helpers ──────────────────────────────────────────────

// Return (indent, rest) split where indent is the leading whitespace.
fn _split_indent(line: string) -> [string] {
    let mut i = 0
    let n = len(line)
    while i < n {
        let ch = line.substring(i, i + 1)
        if ch == " " || ch == "\t" { i = i + 1; continue }
        break
    }
    return [line.substring(0, i), line.substring(i, n)]
}

// Char predicates (substring-based; ascii-only is fine for hexa idents).
fn _is_alpha_or_us(ch: string) -> bool {
    if len(ch) == 0 { return false }
    if ch == "_" { return true }
    // crude: codepoint range via single-char string compare
    if ch >= "A" && ch <= "Z" { return true }
    if ch >= "a" && ch <= "z" { return true }
    return false
}

// Does `rest` begin with `kw` AS A WORD (next char is not ident-char)?
fn _word_begins_with(rest: string, kw: string) -> bool {
    let klen = len(kw)
    if len(rest) < klen { return false }
    if rest.substring(0, klen) != kw { return false }
    if len(rest) == klen { return true }
    let nxt = rest.substring(klen, klen + 1)
    if _is_alpha_or_us(nxt) { return false }
    // also reject digit continuation (e.g. `verify2`)
    if nxt >= "0" && nxt <= "9" { return false }
    return true
}

// After `kw`, peek at the next non-space token's first char. Returns "" on EOL.
fn _peek_after_kw(rest: string, kw: string) -> string {
    let mut i = len(kw)
    let n = len(rest)
    while i < n {
        let ch = rest.substring(i, i + 1)
        if ch == " " || ch == "\t" { i = i + 1; continue }
        return ch
    }
    return ""
}

// Should this line be rewritten? Returns the new line or "" if no change.
// `rest` is the line content after the leading indent. `indent` is restored
// at the prefix.
fn _maybe_rewrite(indent: string, rest: string) -> string {
    // verify  — followed by quoted string or ident (then `{` on same/next line)
    if _word_begins_with(rest, "verify") {
        let pk = _peek_after_kw(rest, "verify")
        if pk == "\"" || _is_alpha_or_us(pk) {
            return indent + "@" + rest
        }
    }
    // intent — followed by quoted string or ident
    if _word_begins_with(rest, "intent") {
        let pk = _peek_after_kw(rest, "intent")
        if pk == "\"" || _is_alpha_or_us(pk) {
            return indent + "@" + rest
        }
    }
    // effect — followed by an identifier (effect Name { … })
    if _word_begins_with(rest, "effect") {
        let pk = _peek_after_kw(rest, "effect")
        if _is_alpha_or_us(pk) {
            return indent + "@" + rest
        }
    }
    // generate — followed by `fn`, `{`, or ident
    if _word_begins_with(rest, "generate") {
        let pk = _peek_after_kw(rest, "generate")
        if pk == "{" || _is_alpha_or_us(pk) {
            return indent + "@" + rest
        }
    }
    // derive — `derive(Trait, …) for Type`
    if _word_begins_with(rest, "derive") {
        // peek right after `derive` (no whitespace allowed for `derive(`)
        if len(rest) > 6 {
            let nxt = rest.substring(6, 7)
            if nxt == "(" {
                return indent + "@" + rest
            }
        }
    }
    // optimize — `optimize fn …`
    if _word_begins_with(rest, "optimize") {
        // require `fn` after whitespace
        let mut j = 8
        let n = len(rest)
        while j < n {
            let ch = rest.substring(j, j + 1)
            if ch == " " || ch == "\t" { j = j + 1; continue }
            break
        }
        if j + 2 <= n && rest.substring(j, j + 2) == "fn" {
            // ensure word boundary after `fn`
            let after_idx = j + 2
            if after_idx == n { return indent + "@" + rest }
            let after_ch = rest.substring(after_idx, after_idx + 1)
            if !_is_alpha_or_us(after_ch) && !(after_ch >= "0" && after_ch <= "9") {
                return indent + "@" + rest
            }
        }
    }
    return ""
}

// ── per-file driver ───────────────────────────────────────────────────

// Returns 1 if file changed, 0 otherwise. Writes only when changed.
fn _migrate_file(path: string, apply: bool) -> int {
    let src = read_file(path)
    if type_of(src) != "string" { return 0 }
    let lines = src.split("\n")
    let mut out = []
    let mut hit = 0
    let mut i = 0
    let n = len(lines)
    while i < n {
        let line = lines[i]
        let parts = _split_indent(line)
        let indent = parts[0]
        let rest = parts[1]
        let rewritten = _maybe_rewrite(indent, rest)
        if rewritten != "" {
            out.push(rewritten)
            hit = hit + 1
        } else {
            out.push(line)
        }
        i = i + 1
    }
    if hit == 0 { return 0 }
    if apply {
        let _ = write_file(path, out.join("\n"))
    }
    return hit
}

// ── repo file enumeration (git ls-files) ──────────────────────────────

fn _list_hexa_files(repo: string) -> [string] {
    // Use exec to defer to git — works for any git-managed repo.
    let list_path = "/tmp/migrate_kw_v2_list.txt"
    let cmd = "git -C " + repo + " ls-files '*.hexa' > " + list_path + " 2>/dev/null"
    try { let _ = exec(cmd) } catch _e { return [] }
    let content = read_file(list_path)
    if type_of(content) != "string" { return [] }
    let raw = content.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(raw) {
        let p = raw[i].trim()
        if len(p) > 0 { out.push(p) }
        i = i + 1
    }
    return out
}

// ── main ──────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let mut apply = false
    let mut check = false
    let mut repo = "."
    let mut ai = 1
    while ai < len(argv) {
        let a = argv[ai]
        if a == "--apply" { apply = true }
        else if a == "--check" { check = true }
        else if a == "-h" || a == "--help" {
            println("usage: hexa run tool/migrate_kw_v2.hexa [--apply|--check] [<repo>]")
            return
        }
        else { repo = a }
        ai = ai + 1
    }

    let files = _list_hexa_files(repo)
    if len(files) == 0 {
        println("no tracked .hexa files in " + repo)
        return
    }

    let mut scanned = 0
    let mut touched = 0
    let mut total = 0
    let mut i = 0
    while i < len(files) {
        let rel = files[i]
        let path = repo + "/" + rel
        scanned = scanned + 1
        let hit = _migrate_file(path, apply)
        if hit > 0 {
            touched = touched + 1
            total = total + hit
            println(to_string(hit) + "  " + rel)
        }
        i = i + 1
    }

    println("")
    println("─── migrate_kw_v2 summary ─────────────────────────────")
    println("repo            : " + repo)
    println("files scanned   : " + to_string(scanned))
    println("files to migrate: " + to_string(touched))
    println("lines rewritten : " + to_string(total))
    if apply {
        println("mode            : APPLY (rewrote " + to_string(touched) + " files)")
    } else {
        if check {
            println("mode            : CHECK (no writes)")
            if touched > 0 { exit(1) }
        } else {
            println("mode            : DRY-RUN (no writes; re-run with --apply)")
        }
    }
}
