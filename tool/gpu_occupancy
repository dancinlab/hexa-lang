#!/bin/sh
# tool/gpu_occupancy — H2 round-3 GPU occupancy calculator
#
# Closed-form occupancy estimator for NVIDIA SMs. Given per-thread register
# count + per-block shared memory + threads-per-block, prints active blocks
# per SM and warp/thread occupancy.
#
# Usage:
#   gpu_occupancy <regs/thread> <shmem_bytes/block> <threads/block> [-arch=sm_80]
#
# Defaults: arch=sm_80 (A100).
#
# Closes GPU.md milestone H2.

set -eu

if [ $# -lt 3 ]; then
  cat >&2 <<EOF
usage: gpu_occupancy <regs/thread> <shmem_bytes/block> <threads/block> [-arch=sm_80]

  arch values: sm_70 sm_75 sm_80 sm_86 sm_89 sm_90 (default sm_80)
EOF
  exit 2
fi

REGS="$1"
SHMEM="$2"
TPB="$3"
ARCH="sm_80"

if [ $# -ge 4 ]; then
  case "$4" in
    -arch=*) ARCH="${4#-arch=}" ;;
  esac
fi

# Per-arch SM capacity tables (from CUDA C Programming Guide compute capability rows)
case "$ARCH" in
  sm_70)  MAX_REGS=65536; MAX_SHMEM=98304;  MAX_THREADS=2048; MAX_BLOCKS=32 ;;
  sm_75)  MAX_REGS=65536; MAX_SHMEM=65536;  MAX_THREADS=1024; MAX_BLOCKS=16 ;;
  sm_80)  MAX_REGS=65536; MAX_SHMEM=167936; MAX_THREADS=2048; MAX_BLOCKS=32 ;;
  sm_86)  MAX_REGS=65536; MAX_SHMEM=102400; MAX_THREADS=1536; MAX_BLOCKS=16 ;;
  sm_89)  MAX_REGS=65536; MAX_SHMEM=102400; MAX_THREADS=1536; MAX_BLOCKS=24 ;;
  sm_90)  MAX_REGS=65536; MAX_SHMEM=233472; MAX_THREADS=2048; MAX_BLOCKS=32 ;;
  *)      echo "gpu_occupancy: unsupported arch: $ARCH" >&2; exit 2 ;;
esac

# Constraints — each is a candidate ceiling on blocks/SM
BLOCKS_BY_REG=$(awk -v r="$REGS" -v t="$TPB" -v cap="$MAX_REGS" 'BEGIN { if (r*t > 0) print int(cap/(r*t)); else print 999 }')
BLOCKS_BY_SHM=$(awk -v s="$SHMEM" -v cap="$MAX_SHMEM" 'BEGIN { if (s > 0) print int(cap/s); else print 999 }')
BLOCKS_BY_THR=$(awk -v t="$TPB" -v cap="$MAX_THREADS" 'BEGIN { if (t > 0) print int(cap/t); else print 999 }')

# Active = min of all ceilings
ACTIVE=$(awk -v a="$BLOCKS_BY_REG" -v b="$BLOCKS_BY_SHM" -v c="$BLOCKS_BY_THR" -v d="$MAX_BLOCKS" '
  BEGIN {
    m = a
    if (b < m) m = b
    if (c < m) m = c
    if (d < m) m = d
    print m
  }')

WARPS_PER_BLOCK=$(awk -v t="$TPB" 'BEGIN { print int((t + 31) / 32) }')
ACTIVE_THREADS=$(awk -v a="$ACTIVE" -v t="$TPB" 'BEGIN { print a * t }')
OCC_PCT=$(awk -v at="$ACTIVE_THREADS" -v mt="$MAX_THREADS" 'BEGIN { if (mt > 0) printf "%d", (at * 100) / mt; else print 0 }')

cat <<EOF
=== $ARCH Occupancy ===
regs/thread:    $REGS
shmem/block:    $SHMEM B
threads/block:  $TPB
warps/block:    $WARPS_PER_BLOCK
---
blocks (reg):   $BLOCKS_BY_REG
blocks (shmem): $BLOCKS_BY_SHM
blocks (thr):   $BLOCKS_BY_THR
blocks (cap):   $MAX_BLOCKS
active blocks:  $ACTIVE
active threads: $ACTIVE_THREADS
occupancy:      ${OCC_PCT}%
EOF
