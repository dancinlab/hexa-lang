#!hexa strict
// tool/gen_c_text_byte_diff.hexa
//   B9.C — meta-generator: build a `<base>_byte_diff.hexa` gate-1 source-SHA
//   byte-diff oracle from a logical base name, following the #1851 pattern.
//
// The generated oracle proves that <base>_emit.hexa::emit_<base>_c()
// reproduces self/native/<base>.c byte-for-byte (gate-1 source-SHA, the
// activation criterion per #1851). It SKIPs gracefully once the hand-written
// `.c` is removed (emitter is then the SSOT).
//
// USAGE
//   hexa-run tool/gen_c_text_byte_diff.hexa <out_byte_diff.hexa> <base>
//
// gate-1 (source-SHA) is the strongest always-available proof and is the
// REQUIRED gate before the parent batches `git rm self/native/<base>.c`.

let MODULE_NAME = "gen_c_text_byte_diff"

fn main() {
    let argv = real_args()
    if argv.len() < 2 {
        println("usage: gen_c_text_byte_diff <out_byte_diff.hexa> <base>")
        exit(1)
    }
    let out_path = argv[0]
    let base     = argv[1]
    let upper    = base.replace("-", "_").to_upper()

    let src =
            "#!hexa strict\n"
          + "// self/native/" + base + "_byte_diff.hexa\n"
          + "//   B9.C (.c-text · #1851 pattern) — " + base + ".c byte-diff oracle.\n"
          + "//\n"
          + "// Proves self/native/" + base + "_emit.hexa::emit_" + base + "_c()\n"
          + "// reproduces self/native/" + base + ".c byte-for-byte (gate-1 source-SHA,\n"
          + "// the activation criterion per #1851). SKIPs once the hand-written `.c` is\n"
          + "// removed — the emitter is then the SSOT.\n"
          + "//\n"
          + "// ⚠ HARD GATE: byte-diff PASS is REQUIRED before\n"
          + "// `git rm self/native/" + base + ".c`.\n"
          + "//\n"
          + "// GENERATED by tool/gen_c_text_byte_diff.hexa — do not hand-edit.\n"
          + "//\n"
          + "// Run:\n"
          + "//   HEXA_HAL_ROOT=<repo-root> hexa-run self/native/" + base + "_byte_diff.hexa\n"
          + "\n"
          + "let MODULE_NAME = \"" + base + "_byte_diff\"\n"
          + "\n"
          + "let mut RUN  = 0\n"
          + "let mut FAIL = 0\n"
          + "\n"
          + "fn _check(ok: bool, label: str, detail: str) {\n"
          + "    RUN = RUN + 1\n"
          + "    let mark = if ok { \"PASS\" } else { \"FAIL\" }\n"
          + "    if !ok { FAIL = FAIL + 1 }\n"
          + "    println(\"  [\" + mark + \"] \" + label)\n"
          + "    if detail.len() > 0 { println(\"         · \" + detail) }\n"
          + "}\n"
          + "\n"
          + "fn _root() -> str {\n"
          + "    let env_root = env(\"HEXA_HAL_ROOT\")\n"
          + "    if env_root.len() > 0 { return env_root }\n"
          + "    return exec(\"pwd\").trim()\n"
          + "}\n"
          + "\n"
          + "fn _which(cmd: str) -> bool {\n"
          + "    let r = exec(\"command -v \" + cmd + \" >/dev/null 2>&1 && echo y || echo n\").trim()\n"
          + "    return r == \"y\"\n"
          + "}\n"
          + "\n"
          + "fn _exists(p: str) -> bool {\n"
          + "    let r = exec(\"[ -f \\\"\" + p + \"\\\" ] && echo y || echo n\").trim()\n"
          + "    return r == \"y\"\n"
          + "}\n"
          + "\n"
          + "fn _sha256(p: str) -> str {\n"
          + "    if _which(\"shasum\") {\n"
          + "        return exec(\"shasum -a 256 \\\"\" + p + \"\\\" 2>/dev/null | awk '{print $1}'\").trim()\n"
          + "    }\n"
          + "    if _which(\"sha256sum\") {\n"
          + "        return exec(\"sha256sum \\\"\" + p + \"\\\" 2>/dev/null | awk '{print $1}'\").trim()\n"
          + "    }\n"
          + "    return \"\"\n"
          + "}\n"
          + "\n"
          + "fn _hexa_run() -> str {\n"
          + "    if _which(\"hexa-run\") { return \"hexa-run\" }\n"
          + "    return \"/Users/ghost/.hx/bin/hexa-run\"\n"
          + "}\n"
          + "\n"
          + "fn main() {\n"
          + "    println(\"========================================================================\")\n"
          + "    println(\"  self/native — " + base + "_byte_diff: B9.C .c-text byte-diff oracle\")\n"
          + "    println(\"========================================================================\")\n"
          + "    println(\"  generator: self/native/" + base + "_emit.hexa\")\n"
          + "    println(\"  gate:      gate-1 source-SHA (activation criterion)\")\n"
          + "    println(\"\")\n"
          + "\n"
          + "    let root = _root()\n"
          + "    let src_dir = root + \"/self/native\"\n"
          + "    let orig_c  = src_dir + \"/" + base + ".c\"\n"
          + "    let emitter = src_dir + \"/" + base + "_emit.hexa\"\n"
          + "    let work_dir = exec(\"mktemp -d -t " + base + "_byte_diff.XXXXXX\").trim()\n"
          + "    if work_dir.len() == 0 {\n"
          + "        println(\"[FATAL] mktemp failed\")\n"
          + "        exit(1)\n"
          + "    }\n"
          + "    println(\"  scratch: \" + work_dir)\n"
          + "    println(\"\")\n"
          + "\n"
          + "    if !_exists(emitter) {\n"
          + "        _check(false, \"emitter self/native/" + base + "_emit.hexa present\", emitter)\n"
          + "        println(\"__HEXA_LANG_" + upper + "_BYTE_DIFF__ FAIL\")\n"
          + "        exit(1)\n"
          + "    }\n"
          + "    _check(true, \"emitter self/native/" + base + "_emit.hexa present\", emitter)\n"
          + "\n"
          + "    if !_exists(orig_c) {\n"
          + "        println(\"\")\n"
          + "        println(\"  POST-DELETION SKIP — hand-written " + base + ".c removed after this\")\n"
          + "        println(\"  oracle PASSed (gen ≡ orig). The emitter remains the SSOT; replay\")\n"
          + "        println(\"  via `git show <pre-deletion-sha>:self/native/" + base + ".c`.\")\n"
          + "        println(\"__HEXA_LANG_" + upper + "_BYTE_DIFF__ SKIP\")\n"
          + "        exit(0)\n"
          + "    }\n"
          + "    _check(true, \"hand-written self/native/" + base + ".c present\", orig_c)\n"
          + "\n"
          + "    let gen_c = work_dir + \"/" + base + ".c\"\n"
          + "    let out = exec(_hexa_run() + \" \\\"\" + emitter + \"\\\" \\\"\" + gen_c + \"\\\" 2>&1\")\n"
          + "    if !_exists(gen_c) {\n"
          + "        _check(false, \"gate-1 emitter wrote `.c`\", \"emit failed:\\n\" + out)\n"
          + "        println(\"__HEXA_LANG_" + upper + "_BYTE_DIFF__ FAIL\")\n"
          + "        exit(1)\n"
          + "    }\n"
          + "    let orig_sha = _sha256(orig_c)\n"
          + "    let gen_sha  = _sha256(gen_c)\n"
          + "    let ok = orig_sha.len() > 0 && orig_sha == gen_sha\n"
          + "    _check(ok, \"gate-1 source-text byte-identical (sha256(.c))\", \"orig=\" + orig_sha + \" gen=\" + gen_sha)\n"
          + "\n"
          + "    println(\"\")\n"
          + "    println(\"  B9.C " + base + ".c .c-text byte-identity:\")\n"
          + "    if FAIL == 0 {\n"
          + "        println(\"    PROVEN ✓ — hand-written " + base + ".c is fully hexa-emittable.\")\n"
          + "        println(\"    DELETION GATE OPEN — self/native/" + base + ".c may be `git rm`.\")\n"
          + "    } else {\n"
          + "        println(\"    BYTE-DIFF FAIL — emitter output diverges from hand-written `.c`.\")\n"
          + "    }\n"
          + "    let pass_n = RUN - FAIL\n"
          + "    println(\"========================================================================\")\n"
          + "    println(\"  \" + str(pass_n) + \"/\" + str(RUN) + \" checks passed\")\n"
          + "    if FAIL > 0 {\n"
          + "        println(\"__HEXA_LANG_" + upper + "_BYTE_DIFF__ FAIL\")\n"
          + "        exit(1)\n"
          + "    }\n"
          + "    println(\"__HEXA_LANG_" + upper + "_BYTE_DIFF__ PASS\")\n"
          + "    exit(0)\n"
          + "}\n"

    let wtag = "GEN_BYTE_DIFF_WRITE_EOF"
    let wcmd = "cat > \"" + out_path + "\" <<'" + wtag + "'\n" + src + wtag
    let _ = exec(wcmd)
    let ok2 = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if ok2 != "y" {
        println("[gen] FATAL: failed to write oracle: " + out_path)
        exit(1)
    }
    println("[gen] wrote oracle " + out_path)
    exit(0)
}
