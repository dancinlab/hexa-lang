// tool/atlas_promote_engine_candidates.hexa — BG-K anima-engine harvest promotion (2026-05-14)
//
// @version 0.1.0
// @capabilities [fs_read, fs_write]
//
// Promotes the BG-B harvest output —
//   incoming/notes/2026-05-14-anima-engine-harvest-candidates.n6
// (~560 candidate rows scanned from anima-engines/*_phi.hexa headers) —
// onto the runtime overlay at ~/.hx/data/atlas.overlay.n6.
//
// Follow BG-J pattern (tool/atlas_absorb_anima_hypotheses.hexa):
//   * BEGIN/END markers gate idempotent re-runs.
//   * Every promoted row carries `[needs-review]` grade.
//   * Every row carries `source = "<file>:<loc>"`, `scanned_at = "..."`,
//     and `citation_unverified = true` (the citation/text accuracy of
//     the BG-B header regex is NOT verified — a human reviewer is the
//     gating step before any rodata absorption).
//
// Pre-flight passes (before append):
//   1. DEDUP  — drop rows whose full raw payload (header + continuation
//      lines, normalized whitespace) already appeared earlier in the
//      input. Stable: first occurrence wins.
//   2. DE-NOISE (conservative — false-negative > false-positive):
//      Reject @L rows where the citation `source = ` value matches a
//      KNOWN-FALSE-POSITIVE marker introduced by the BG-B header regex.
//      Currently: a single literal-prefix match of "Moal " (the upstream
//      string is "Le Moal 2005" — the harvester's regex tripped on the
//      leading "Le "). Conservative on purpose: any future false-positive
//      marker must be added here explicitly; do NOT generalize to short
//      tokens (e.g. "Le ", "La ") because there are legitimate two-letter
//      surname prefixes in the citations.
//      Also reject @L rows where the source value is < 5 characters.
//
// Idempotency: if the overlay already contains the BEGIN marker the tool
// reports the planned reject list to stderr and exits without writing.
//
// Run:
//   hexa run tool/atlas_promote_engine_candidates.hexa

use "compiler/atlas/overlay"

let _SCANNED_AT = "2026-05-14"
let _BEGIN_MARKER = "# ===== ANIMA ENGINE HARVEST PROMOTION 2026-05-14 BEGIN ====="
let _END_MARKER   = "# ===== ANIMA ENGINE HARVEST PROMOTION 2026-05-14 END ====="
let _CANDIDATES_REL = "incoming/notes/2026-05-14-anima-engine-harvest-candidates.n6"
let _GRADE_NEW = "[needs-review]"

// ── string helpers ─────────────────────────────────────────────────────

fn _ltrim(s: string) -> string {
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c != " " && c != "\t" { break }
        i = i + 1
    }
    return s.substring(i, n)
}

fn _rtrim(s: string) -> string {
    let mut i = len(s)
    while i > 0 {
        let c = s.substring(i - 1, i)
        if c != " " && c != "\t" && c != "\r" { break }
        i = i - 1
    }
    return s.substring(0, i)
}

fn _trim(s: string) -> string {
    return _rtrim(_ltrim(s))
}

fn _starts_with(s: string, p: string) -> bool {
    let lp = len(p)
    if len(s) < lp { return false }
    return s.substring(0, lp) == p
}

// Extract the value inside `key = "<value>"` from a continuation line.
// Returns "" if the line shape doesn't match.
fn _continuation_value(line: string, key: string) -> string {
    let t = _ltrim(line)
    let prefix = key + " = \""
    if !_starts_with(t, prefix) { return "" }
    let rest = t.substring(len(prefix), len(t))
    // Trim trailing `"` if present.
    let n = len(rest)
    if n > 0 && rest.substring(n - 1, n) == "\"" {
        return rest.substring(0, n - 1)
    }
    return rest
}

// Identify the header @-token on a non-indented line. Returns one of
// "@P" / "@L" / "@?" / "" (not-a-header).
fn _header_kind(line: string) -> string {
    if _starts_with(line, "@P ") { return "@P" }
    if _starts_with(line, "@L ") { return "@L" }
    if _starts_with(line, "@? ") { return "@?" }
    return ""
}

fn _is_comment_or_blank(line: string) -> bool {
    let t = _ltrim(line)
    if len(t) == 0 { return true }
    if t.substring(0, 1) == "#" { return true }
    return false
}

// ── record-level data ──────────────────────────────────────────────────

@phase("parse_only")
pub struct Row {
    kind: string,            // "@P" | "@L" | "@?"
    header: string,          // full header line (no trailing \n)
    source_value: string,    // for @L: the `source = "..."` value; else ""
    scanned_from: string,    // the `scanned_from = "..."` value
    // Normalized de-dup key (header normalized + scanned_from normalized).
    dedup_key: string,
    // Reject reason, "" if kept.
    reject: string
}

fn _empty_row() -> Row {
    return Row {
        kind: "",
        header: "",
        source_value: "",
        scanned_from: "",
        dedup_key: "",
        reject: ""
    }
}

// Normalize the [grade] tag on a header line to [needs-review]. Some @?
// rows in the input use [hypothesis=open] — we collapse to the
// canonical needs-review marker so the smoke test sees a single grade.
fn _normalize_grade(header: string) -> string {
    // Find the last `[...]` block.
    let n = len(header)
    let mut lb = -1
    let mut rb = -1
    let mut i = n
    while i > 0 {
        let c = header.substring(i - 1, i)
        if c == "]" && rb < 0 { rb = i - 1 }
        else if c == "[" && rb >= 0 && lb < 0 { lb = i - 1; break }
        i = i - 1
    }
    if lb < 0 || rb < 0 || lb >= rb { return header }
    let before = header.substring(0, lb)
    let after  = header.substring(rb + 1, n)
    return before + _GRADE_NEW + after
}

// ── parsing the candidates file ────────────────────────────────────────

// Walk the candidates body line by line, grouping each non-indented
// `@P|@L|@?` header with its continuation lines. Returns array of Row.
fn _parse_candidates(body: string) -> array {
    let lines = body.split("\n")
    let n = len(lines)
    let rows = []
    let mut i = 0
    while i < n {
        let raw = to_string(lines[i])
        if _is_comment_or_blank(raw) {
            i = i + 1
            continue
        }
        let kind = _header_kind(raw)
        if kind == "" {
            // Stray continuation outside a record — skip.
            i = i + 1
            continue
        }
        let header = _rtrim(raw)
        let mut source_value = ""
        let mut scanned_from = ""
        // Collect continuation lines (indented).
        let mut j = i + 1
        while j < n {
            let next_raw = to_string(lines[j])
            if len(next_raw) == 0 { j = j + 1; break }
            // A non-indented line that is a header for the next record
            // OR a comment / blank ends the record.
            let first_char = next_raw.substring(0, 1)
            if first_char != " " && first_char != "\t" { break }
            // Extract known continuation values.
            let v_src = _continuation_value(next_raw, "source")
            if len(v_src) > 0 && len(source_value) == 0 {
                source_value = v_src
            }
            let v_scan = _continuation_value(next_raw, "scanned_from")
            if len(v_scan) > 0 && len(scanned_from) == 0 {
                scanned_from = v_scan
            }
            j = j + 1
        }
        let dedup_key = kind + "|" + header + "|" + source_value + "|" + scanned_from
        let row = Row {
            kind: kind,
            header: header,
            source_value: source_value,
            scanned_from: scanned_from,
            dedup_key: dedup_key,
            reject: ""
        }
        rows.push(row)
        i = j
    }
    return rows
}

// ── dedup + de-noise ──────────────────────────────────────────────────

// Mark duplicates (second + later occurrences of an identical dedup_key)
// with reject = "duplicate". Returns updated array (in-place mutation).
fn _mark_duplicates(rows: array) -> i64 {
    let n = len(rows)
    let mut removed = 0
    // Map dedup_key -> seen (array-based linear scan; n ~ 560 — fine).
    let seen_keys = []
    let mut i = 0
    while i < n {
        let row = rows[i]
        if len(row.reject) > 0 { i = i + 1; continue }
        let key = row.dedup_key
        let mut found = false
        let mut s = 0
        while s < len(seen_keys) {
            if to_string(seen_keys[s]) == key { found = true; break }
            s = s + 1
        }
        if found {
            rows[i] = Row {
                kind: row.kind,
                header: row.header,
                source_value: row.source_value,
                scanned_from: row.scanned_from,
                dedup_key: row.dedup_key,
                reject: "duplicate"
            }
            removed = removed + 1
        } else {
            seen_keys.push(key)
        }
        i = i + 1
    }
    return removed
}

// Conservative de-noise: reject @L rows whose `source =` matches a
// known false-positive marker (currently only "Moal " — the upstream
// is "Le Moal 2005", the BG-B regex stripped "Le ").
// Also reject @L rows whose source value is < 5 characters.
fn _mark_denoise(rows: array, reject_list: array) -> i64 {
    let n = len(rows)
    let mut removed = 0
    let mut i = 0
    while i < n {
        let row = rows[i]
        if len(row.reject) > 0 { i = i + 1; continue }
        if row.kind != "@L" { i = i + 1; continue }
        let src = row.source_value
        let lsrc = len(src)
        let mut reason = ""
        if lsrc < 5 {
            reason = "citation-too-short"
        } else if _starts_with(src, "Moal ") {
            // BG-B regex tripped on "Le Moal" — surface this single
            // known false-positive without over-generalizing.
            reason = "false-positive-Le-prefix"
        }
        if len(reason) > 0 {
            rows[i] = Row {
                kind: row.kind,
                header: row.header,
                source_value: row.source_value,
                scanned_from: row.scanned_from,
                dedup_key: row.dedup_key,
                reject: reason
            }
            reject_list.push(row.header + "  (reason=" + reason + ", source=\"" + src + "\")")
            removed = removed + 1
        }
        i = i + 1
    }
    return removed
}

// ── overlay emission ───────────────────────────────────────────────────

// Emit the canonical overlay block for a single kept row. We rewrite
// the grade tag to [needs-review] and replace the input's
// `scanned_from = "<path>:header"` with a richer continuation:
//
//   source             = "<file>:<loc>"    (was scanned_from)
//   scanned_at         = "2026-05-14"
//   citation_unverified = true              (mandatory for @L, advisory for @P/@?)
//   source_value       = "<original source>" (only for @L)
//   status             = "open"             (only for @? rows the input
//                                            already labeled [hypothesis=open])
fn _emit_row(row: Row, status_open: bool) -> string {
    let header = _normalize_grade(row.header)
    let parts = []
    parts.push(header)
    parts.push("\n")
    // Map scanned_from → source.
    if len(row.scanned_from) > 0 {
        parts.push("  source = \"")
        parts.push(row.scanned_from)
        parts.push("\"\n")
    }
    if len(row.source_value) > 0 {
        parts.push("  citation_source = \"")
        parts.push(row.source_value)
        parts.push("\"\n")
    }
    parts.push("  scanned_at = \"")
    parts.push(_SCANNED_AT)
    parts.push("\"\n")
    parts.push("  citation_unverified = true\n")
    if status_open {
        parts.push("  status = \"open\"\n")
    }
    return parts.join("")
}

// ── main ───────────────────────────────────────────────────────────────

fn main() {
    let cwd = "."
    let candidates_path = _CANDIDATES_REL
    let overlay = overlay_path()

    println("=== atlas_promote_engine_candidates (BG-K) ===")
    println("  candidates: " + candidates_path)
    println("  overlay:    " + overlay)
    println("  scanned_at: " + _SCANNED_AT)

    if !file_exists(candidates_path) {
        eprintln("error: candidates file missing: " + candidates_path)
        return
    }

    // Idempotency: bail if marker present.
    let overlay_exists = file_exists(overlay)
    if overlay_exists {
        let cur = read_file(overlay)
        if cur.index_of(_BEGIN_MARKER) >= 0 {
            eprintln("warning: overlay already contains '" + _BEGIN_MARKER + "' — skipping (idempotent re-run).")
            // Still re-compute the would-be reject list for transparency.
            let body = read_file(candidates_path)
            let rows = _parse_candidates(body)
            let rl = []
            let denoise_removed = _mark_denoise(rows, rl)
            eprintln("  re-computed reject list (de-noise): " + to_string(denoise_removed) + " row(s)")
            let mut k = 0
            while k < len(rl) {
                eprintln("    " + to_string(rl[k]))
                k = k + 1
            }
            println("done (skipped — already absorbed).")
            return
        }
    }

    let body = read_file(candidates_path)
    let rows = _parse_candidates(body)
    let total_in = len(rows)
    println("  parsed input rows: " + to_string(total_in))

    let dedup_removed = _mark_duplicates(rows)
    let reject_list = []
    let denoise_removed = _mark_denoise(rows, reject_list)

    // Count kinds in kept set + emit body.
    let mut cnt_p = 0
    let mut cnt_l = 0
    let mut cnt_q = 0
    let chunks = []
    chunks.push(_BEGIN_MARKER + "\n")
    chunks.push("# scope: 164 anima-engines/*_phi.hexa docstring scan (BG-B, 2026-05-14)\n")
    chunks.push("# CAUTION: citation accuracy NOT verified (e.g. \"Moal 2005\" actually\n")
    chunks.push("#          \"Le Moal 2005\" — regex tripped on \"Le\" prefix). ALL rows\n")
    chunks.push("#          tagged [needs-review]. Human review required before promotion\n")
    chunks.push("#          to rodata.\n")

    let n = len(rows)
    let mut i = 0
    while i < n {
        let row = rows[i]
        if len(row.reject) > 0 { i = i + 1; continue }
        // The "@? ...open = "" :: anima.engines [hypothesis=open]" rows
        // carry a structural status=open signal. Preserve it.
        let status_open = row.kind == "@?" && row.header.index_of("[hypothesis=open]") >= 0
        chunks.push(_emit_row(row, status_open))
        if row.kind == "@P" { cnt_p = cnt_p + 1 }
        else if row.kind == "@L" { cnt_l = cnt_l + 1 }
        else if row.kind == "@?" { cnt_q = cnt_q + 1 }
        i = i + 1
    }
    chunks.push(_END_MARKER + "\n")

    let payload = chunks.join("")
    let kept = cnt_p + cnt_l + cnt_q

    // Append.
    overlay_ensure_dir()
    append_file(overlay, payload)

    println("")
    println("  dedup removed:   " + to_string(dedup_removed))
    println("  de-noise reject: " + to_string(denoise_removed))
    println("  final promoted:  " + to_string(kept))
    println("    @P primitives: " + to_string(cnt_p))
    println("    @L citations:  " + to_string(cnt_l))
    println("    @? open ques.: " + to_string(cnt_q))

    if len(reject_list) > 0 {
        eprintln("")
        eprintln("  de-noise reject list:")
        let mut k = 0
        while k < len(reject_list) {
            eprintln("    - " + to_string(reject_list[k]))
            k = k + 1
        }
    }

    println("")
    println("done.")
}
