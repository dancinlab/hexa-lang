#!/usr/bin/env bash
# stage_prebuild_hexat — produce build/hexat (the bootstrap transpiler binary)
#   for the release build chain.
#
# Strategy mirrors stage_resolve_runtime_a:
#   1. If self/native/hexa_cc.c is present, build hexat from source via the
#      existing in-tree path ($CC against runtime.a + the native .c units).
#   2. Otherwise (graduated tree), try to pull build/hexat out of the prior
#      `edge` release tarball for this target.
#   3. Edge-miss fallback (P7): restore the pinned pre-graduation native .c
#      seeds from git and build hexat from source. Restored files are
#      EPHEMERAL — left uncommitted, rebuilt at CI time.
#
set -euo pipefail

TARGET="${1:-${TARGET:-}}"
CC="${CC:-cc}"
CFLAGS="${CFLAGS:--O2}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Pinned pre-graduation seed commit (parent of graduation commit 7906951c0).
FROZEN_SEED_REF="7906951c0^"

# The .c compilation units hexat_main.c needs: itself plus the three native
# .c files it #includes (hexa_cc.c, hexat_emit.c, atlas_embed.c). The headers
# runtime_decl.h / native_gate.h remain committed in the graduated tree.
# Derived from `git show $REF:self/native/hexat_main.c`.
FROZEN_HEXAT_C="
self/native/hexat_main.c
self/native/hexa_cc.c
self/native/hexat_emit.c
self/native/atlas_embed.c
"

mkdir -p build

build_hexat_from_source() {
  echo "[prebuild_hexat] building build/hexat from source"
  "$CC" $CFLAGS -I self -I self/native -o build/hexat \
    self/native/hexat_main.c build/runtime.a
  echo "[prebuild_hexat] built build/hexat from source"
}

restore_frozen_seed() {
  echo "[prebuild_hexat] restoring pinned pre-graduation native .c seeds from ${FROZEN_SEED_REF}"
  # shellcheck disable=SC2086
  git checkout "$FROZEN_SEED_REF" -- $FROZEN_HEXAT_C
}

# chicken-egg note: the very first edge tarball predated hexat-bundling, so a
# fresh edge may lack build/hexat; once one platform publishes a hexat-bearing
# tarball, the others can pull it. The frozen-seed fallback (P7) removes this
# dependency by rebuilding hexat from the pinned pre-graduation .c seeds, so
# every platform is self-sufficient without pulling edge.

# --- step 1: native .c present (seeds-present path, byte-equivalent) ---
if [ -f self/native/hexat_main.c ] && [ -f self/native/hexa_cc.c ]; then
  echo "[prebuild_hexat] native .c seeds present -> building hexat from source"
  build_hexat_from_source
  exit 0
fi

if [ -z "$TARGET" ]; then
  echo "[prebuild_hexat] ERROR: TARGET not set" >&2
  exit 1
fi

# --- step 2: graduated tree -> try edge release first ---
TARGET_TARBALL="hexa-${TARGET}.tar.gz"
echo "[prebuild_hexat] native .c absent -> trying edge release tarball for build/hexat"
if gh release download edge --pattern "$TARGET_TARBALL" --dir build --clobber 2>/dev/null \
   && tar -xzf "build/${TARGET_TARBALL}" -C build 2>/dev/null \
   && [ -f build/hexat ]; then
  echo "[prebuild_hexat] extracted build/hexat from edge tarball"
  exit 0
fi

# --- step 3: edge miss -> frozen-seed fallback (restore native .c, compile) ---
echo "[prebuild_hexat] edge tarball missing/unusable for ${TARGET} -> frozen-seed fallback"
restore_frozen_seed
build_hexat_from_source
exit 0
