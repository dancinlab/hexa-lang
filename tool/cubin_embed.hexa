// tool/cubin_embed.hexa — RFC 055 055-P3c.e cubin embed helper
//
// @version 0.0.1
// @capabilities [pure]
//
// Closes the last 055-P3c sub-slice (auto-embed UX) without requiring
// a compiler-internal change. Takes a PTX file (emitted by RFC 055
// 055-P3a's `--target=nvptx64-*` codegen / PR #85) plus a kernel
// symbol name and a sm-arch, and emits a generated `<basename>_cubin.hexa`
// source that declares:
//
//   pub fn <basename>_cubin_bytes() -> string
//   pub fn <basename>_cubin_len()   -> i64
//
// The cubin bytes are inlined as a hex-escaped string literal a host
// hexa program can pass directly to `gpu_launch(...)` (recognized as
// `_hx_cuda_launch_kernel(...)` by the deployed transpiler since
// PR #99 / 055-P3c.d).
//
// User pattern (manual but UX-closed):
//
//   hexa build vec_add.hexa --target=nvptx64-nvidia-cuda-sm80 \
//       -o vec_add.ptx                          # 055-P3a (PR #85)
//   hexa run tool/cubin_embed.hexa \
//       vec_add.ptx vadd 80 > vec_add_cubin.hexa   # this script
//   hexa build host_main.hexa -o host_bin       # gpu_launch wired
//       # where host_main.hexa imports `./vec_add_cubin.hexa` and
//       # calls gpu_launch(vec_add_cubin_bytes(),
//       #                  vec_add_cubin_len(),
//       #                  "vadd", gx, gy, gz, bx, by, bz, farrs, …)
//
// A future cycle MAY wire this into `hexa build` so a single
// `hexa build host_main.hexa` invocation auto-detects @gpu_kernel
// modules and does ptxas + embed internally. That is the
// convenience-UX layer above this helper — the helper itself is the
// durable primitive (hexa-native, no .sh dependency).
//
// @D hexa-first — this is the hexa-native answer; the earlier P1/P2
// dispatch scripts (tool/dispatch_r055_*.sh) remain .sh because they
// also orchestrate vast.ai / ssh which has no hexa-native binding.
// This helper only needs `exec()` (existing builtin) + read_file +
// write/stdout — all hexa stdlib.

fn _hex2(b: i64) -> string {
    let lut = "0123456789abcdef"
    let hi = (b / 16) % 16
    let lo = b % 16
    let mut s = ""
    s = s + lut.substring(hi, hi + 1)
    s = s + lut.substring(lo, lo + 1)
    return s
}

fn _basename_noext(path: string) -> string {
    let mut slash = -1
    let mut i = 0
    while i < len(path) {
        if path.substring(i, i + 1) == "/" { slash = i }
        i = i + 1
    }
    let from = if slash >= 0 { slash + 1 } else { 0 }
    let tail = path.substring(from, len(path))
    let mut dot = -1
    let mut j = 0
    while j < len(tail) {
        if tail.substring(j, j + 1) == "." { dot = j }
        j = j + 1
    }
    let to = if dot > 0 { dot } else { len(tail) }
    return tail.substring(0, to)
}

fn main() {
    let argv = args()
    // `args()` returns [program_name, user_arg0, user_arg1, ...] —
    // index 1 onward is the user-supplied args.
    if len(argv) < 3 {
        eprintln("usage: cubin_embed <kernel.ptx-or-.cubin> <kernel-symbol> [sm_arch=80]")
        eprintln("  e.g. cubin_embed vec_add.ptx vadd 80")
        exit(1)
    }
    let ptx = argv[1]
    let kernel_name = argv[2]
    let sm_arch = if len(argv) > 3 { argv[3] } else { "80" }

    // (1) ptxas → cubin. Fixed tempfile path; concurrent runs would
    // overwrite, which is fine for a developer-invoked tool. Cleanup
    // at end of run, best-effort. Skip ptxas if the input is already
    // a cubin (auto-detect by `.cubin` extension) — useful for hosts
    // without ptxas (Mac arm64), where the user can produce the cubin
    // elsewhere (ubu-2 / vast.ai) and just run this embed step locally.
    let ptx_len = len(ptx)
    let is_cubin = ptx_len > 6 && ptx.substring(ptx_len - 6, ptx_len) == ".cubin"
    let mut cubin_path = "/tmp/cubin_embed_tmp.cubin"
    if is_cubin {
        cubin_path = ptx
    } else {
        let cmd = "ptxas -arch=sm_" + sm_arch + " '" + ptx + "' -o '" + cubin_path + "' 2>&1"
        let pa = exec_with_status(cmd)
        let pout = pa[0]
        let prc = pa[1]
        if prc != 0 {
            eprintln("ERROR: ptxas failed (rc=" + to_string(prc) + ")")
            eprintln(pout)
            exit(2)
        }
    }

    // (2) Read cubin bytes + emit the hexa wrapper to stdout.
    let bytes = read_file_bytes(cubin_path)
    let cubin_len = len(bytes)
    if cubin_len <= 0 {
        eprintln("ERROR: cubin is empty: " + cubin_path)
        exit(3)
    }

    let basename = _basename_noext(ptx)
    let prefix = basename + "_cubin"

    println("// Generated by tool/cubin_embed.hexa (RFC 055 055-P3c.e)")
    println("// Source PTX:    " + ptx)
    println("// Kernel symbol: " + kernel_name)
    println("// Target arch:   sm_" + sm_arch)
    println("// Byte count:    " + to_string(cubin_len))
    println("//")
    println("// Pattern:")
    println("//   gpu_launch(" + prefix + "_bytes(), " + prefix + "_len(),")
    println("//              \"" + kernel_name + "\", gx, gy, gz, bx, by, bz, farrs, …)")
    println("")
    println("pub fn " + prefix + "_len() -> i64 {")
    println("    return " + to_string(cubin_len))
    println("}")
    println("")
    println("pub fn " + prefix + "_bytes() -> string {")
    print("    return \"")
    // Emit hex-escaped bytes — `\xHH` per byte. NUL-safe (hexa strings
    // carry length, not C-style NUL termination semantics).
    let mut bi = 0
    while bi < cubin_len {
        if bi > 0 && (bi % 16) == 0 {
            print("\\\n        ")
        }
        print("\\x")
        print(_hex2(bytes[bi]))
        bi = bi + 1
    }
    println("\"")
    println("}")

    // Cleanup tempfile (best-effort).
    let _ = exec("rm -f '" + cubin_path + "' 2>/dev/null")
}
