// tool/atlas_bulk_absorb.hexa — Wave 3.1 bulk staging-shard absorber
//
// @version 0.1.0
// @capabilities [fs_read, fs_write, exec]
//
// Ported from ~/core/n6/algorithms/atlas_absorb.hexa (CC0-1.0, absorbed 2026-05-13).
//
// What we keep from the n6 original:
//   - staging-shard discovery (atlas.append.*.n6 + optional --glob filter)
//   - idempotent flush (already-absorbed shards skipped on re-run)
//   - separator marker between shards (`# .. <basename> ..`)
//   - calls into overlay_append_lines, so the union view (rodata + overlay)
//     surfaces every absorbed entry on the next lookup.
//
// What we drop:
//   - chflags nouchg/uchg machinery — hexa-lang's overlay file lives in
//     ~/.hx/data/, not under a chflags-locked rodata SSOT.
//   - directory layout autodetect (n6/ vs atlas/) — we always target the
//     per-user overlay file resolved by overlay_path().
//   - archive-to-_absorbed/<ts>/ move — staging shards stay where they
//     are; CI can clean them up out-of-band.
//
// Use case: CI bulk-import of community-contributed `.n6` shards. Caller
// drops the shards into a staging directory, runs this tool, and the
// shards' contents fold into ~/.hx/data/atlas.overlay.n6 (where the
// merged lookup path picks them up). Rodata is not touched.
//
// Invocation:
//   hexa run tool/atlas_bulk_absorb.hexa <staging_dir> [--glob <pat>] [--dry-run]
//   defaults: --glob "atlas.append.*.n6"

use "compiler/atlas/parser"
use "compiler/atlas/overlay"

fn _now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _absorbed_marker_for(basename: string) -> string {
    return "# .. " + basename + " .."
}

// Check if the overlay file already contains the absorbed-shard marker
// for `basename`. We do a simple substring scan (overlay file is bounded
// by ~/.hx/data/ disk budget — at most a few MB) rather than a parse so
// the check stays fast even with thousands of entries.
fn _overlay_has_marker(marker: string) -> bool {
    let path = overlay_path()
    if !file_exists(path) { return false }
    if file_size(path) == 0 { return false }
    let body = read_file(path)
    return body.index_of(marker) >= 0
}

// List staging shards whose basename matches `glob`. The glob is a tiny
// matcher — only `*` is supported and only as a wildcard inside the
// basename. Default glob matches `atlas.append.*.n6`.
fn _list_shards(dir: string, glob: string) -> array {
    let out = []
    if !file_exists(dir) { return out }
    let entries = list_dir(dir)
    if type_of(entries) != "array" { return out }
    // Split glob into prefix*suffix.
    let star = glob.index_of("*")
    let mut prefix = glob
    let mut suffix = ""
    if star >= 0 {
        prefix = glob.substring(0, star)
        suffix = glob.substring(star + 1, len(glob))
    }
    let mut i = 0
    while i < len(entries) {
        let name = to_string(entries[i])
        let lp = len(prefix)
        let ls = len(suffix)
        let ln = len(name)
        if ln >= lp + ls && name.substring(0, lp) == prefix && name.substring(ln - ls, ln) == suffix {
            out.push(name)
        }
        i = i + 1
    }
    // Sort lexically for reproducibility.
    let mut a = 0
    while a < len(out) {
        let mut b = a + 1
        while b < len(out) {
            if to_string(out[b]) < to_string(out[a]) {
                let tmp = out[a]; out[a] = out[b]; out[b] = tmp
            }
            b = b + 1
        }
        a = a + 1
    }
    return out
}

// Absorb one shard. Returns 1 if absorbed, 0 if skipped (already done),
// -1 on error. `staging_dir` is the dir containing `basename`; we read
// the full file, prepend a marker line, append to the overlay file.
fn _absorb_one(staging_dir: string, basename: string, dry_run: bool) -> i64 {
    let marker = _absorbed_marker_for(basename)
    if _overlay_has_marker(marker) {
        println("  skip  " + basename + " (marker already present)")
        return 0
    }
    let path = staging_dir + "/" + basename
    if !file_exists(path) {
        println("  err   " + basename + " (file vanished)")
        return -1
    }
    let body = read_file(path)
    if dry_run {
        let preview_n = if len(body) > 80 { 80 } else { len(body) }
        let preview = body.substring(0, preview_n)
        println("  dry   " + basename + " (" + to_string(len(body)) + " bytes, preview: " + preview + "...)")
        return 1
    }
    let lines = []
    lines.push(marker)
    lines.push(body)
    overlay_append_lines(lines)
    println("  abs   " + basename + " (" + to_string(len(body)) + " bytes)")
    return 1
}

pub fn run_bulk_absorb(staging_dir: string, glob: string, dry_run: bool) -> i64 {
    println("=== atlas_bulk_absorb ===")
    println("  staging:  " + staging_dir)
    println("  glob:     " + glob)
    println("  dry-run:  " + (if dry_run { "yes" } else { "no" }))
    println("  overlay:  " + overlay_path())
    println("  ts:       " + _now_iso())

    if !file_exists(staging_dir) {
        println("error: staging dir not found: " + staging_dir)
        return 2
    }
    let shards = _list_shards(staging_dir, glob)
    println("  shards matched: " + to_string(len(shards)))

    if !dry_run { overlay_ensure_dir() }

    let mut absorbed = 0
    let mut skipped = 0
    let mut errors = 0
    let mut i = 0
    while i < len(shards) {
        let basename = to_string(shards[i])
        let rc = _absorb_one(staging_dir, basename, dry_run)
        if rc == 1 { absorbed = absorbed + 1 }
        else if rc == 0 { skipped = skipped + 1 }
        else { errors = errors + 1 }
        i = i + 1
    }
    println("")
    println("  absorbed: " + to_string(absorbed))
    println("  skipped:  " + to_string(skipped))
    println("  errors:   " + to_string(errors))
    if errors > 0 { return 1 }
    return 0
}

fn _parse_args(av: array) -> array {
    // Returns [staging_dir, glob, dry_run_flag]
    let n = len(av)
    let mut staging = ""
    let mut glob = "atlas.append.*.n6"
    let mut dry_run = "false"
    let mut i = 2
    while i < n {
        let a = to_string(av[i])
        if a == "--glob" && i + 1 < n {
            glob = to_string(av[i + 1])
            i = i + 2
        } else if a == "--dry-run" {
            dry_run = "true"
            i = i + 1
        } else if a == "--help" || a == "-h" {
            staging = "--help"
            i = i + 1
        } else if len(staging) == 0 {
            staging = a
            i = i + 1
        } else {
            i = i + 1
        }
    }
    return [staging, glob, dry_run]
}

fn main() {
    let av = argv()
    let parsed = _parse_args(av)
    let staging = to_string(parsed[0])
    let glob = to_string(parsed[1])
    let dry_run = to_string(parsed[2]) == "true"
    if staging == "--help" || len(staging) == 0 {
        println("usage: hexa run tool/atlas_bulk_absorb.hexa <staging_dir> [--glob <pat>] [--dry-run]")
        println("  default glob: atlas.append.*.n6")
        println("  default dst:  ~/.hx/data/atlas.overlay.n6")
        exit(2)
    }
    let rc = run_bulk_absorb(staging, glob, dry_run)
    exit(rc)
}

let _av = argv()

fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let script = to_string(_av[1])
    if script.ends_with("/atlas_bulk_absorb.hexa") { return true }
    if script == "atlas_bulk_absorb.hexa" { return true }
    return false
}

if _is_main() {
    main()
}
