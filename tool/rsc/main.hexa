// absorbed from ~/core/hexa-space/verify/run_all.hexa (MIT, hexa-space v1.0.0)
// tool/rsc/main.hexa — standalone CLI dispatcher for the RSC substrate.
//
// @version 0.1.0
// @capabilities [fs_read, exec]
//
// Usage:
//   hexa run tool/rsc/main.hexa falsifier      # per-falsifier closure ladder
//   hexa run tool/rsc/main.hexa lint           # numerics lint
//   hexa run tool/rsc/main.hexa saturation     # sat-1^sat-2^sat-3 probe
//   hexa run tool/rsc/main.hexa run-all        # all three gates aggregated
//
// Suggested wilson CLI surface (post-self/main wiring):
//   hexa rsc falsifier | hexa rsc lint | hexa rsc saturation | hexa rsc run-all

use "tool/rsc/falsifier_audit"
use "tool/rsc/saturation_check"
use "tool/rsc/lint_numerics"
use "tool/rsc/run_all"

fn _usage() {
    println("usage: hexa run tool/rsc/main.hexa <verb>")
    println("  verbs: falsifier | lint | saturation | run-all")
}

fn main() {
    let argv = args()
    let n = len(argv)
    // hexa run <script> <verb> => argv[2] == verb
    if n <= 2 { _usage(); exit(2) }
    let verb = argv[2]
    if verb == "falsifier" {
        let r = rsc_falsifier_audit_print()
        if r.pass { exit(0) } else { exit(1) }
    }
    if verb == "lint" {
        let r = rsc_lint_numerics_print()
        if r.pass { exit(0) } else { exit(1) }
    }
    if verb == "saturation" {
        let r = rsc_saturation_check_print()
        if r.pass { exit(0) } else { exit(1) }
    }
    if verb == "run-all" || verb == "all" {
        let r = rsc_run_all()
        if r.pass { exit(0) } else { exit(1) }
    }
    _usage()
    exit(2)
}
