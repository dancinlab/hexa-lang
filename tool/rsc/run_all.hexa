// absorbed from ~/core/hexa-space/verify/run_all.hexa (MIT, hexa-space v1.0.0)
// tool/rsc/run_all.hexa — orchestrator that aggregates the three RSC gates.
//
// @version 0.1.0
// @capabilities [fs_read, exec]
//
// Walks falsifier audit + saturation probe + lint, aggregates pass/fail,
// and emits the unified RSC sentinel.
//
// HONESTY (closure-honesty-contract):
//   PASS here means each gate returns true — bookkeeping closure, NOT
//   physics-settled. T3 = on-disk archival evidence (pin.* markers), NOT
//   live hardware telemetry. Saturated != falsified != confirmed.
//
// Sentinel: __HEXA_LANG_RSC_RUN_ALL__ PASS|FAIL

use "tool/rsc/falsifier_audit"
use "tool/rsc/saturation_check"
use "tool/rsc/lint_numerics"

pub struct RunAllResult {
    pass: bool,
    falsifier_pass: bool,
    saturation_pass: bool,
    lint_pass: bool
}

pub fn rsc_run_all() -> RunAllResult {
    println("========================================================================")
    println("  hexa-lang RSC — run_all aggregate sweep")
    println("========================================================================")
    println("")

    println("---- [1/3] falsifier audit ----")
    let fa = rsc_falsifier_audit_print()
    println("")

    println("---- [2/3] numerics lint ----")
    let lint = rsc_lint_numerics_print()
    println("")

    println("---- [3/3] saturation probe ----")
    let sat = rsc_saturation_check_print()
    println("")

    println("========================================================================")
    let passed = fa.pass && lint.pass && sat.pass
    let mut k = 0
    if fa.pass { k = k + 1 }
    if lint.pass { k = k + 1 }
    if sat.pass { k = k + 1 }
    println("  " + to_string(k) + "/3 gates passed  (falsifier=" + to_string(fa.pass) +
            "  lint=" + to_string(lint.pass) + "  saturation=" + to_string(sat.pass) + ")")
    println("")
    println("  HONESTY: PASS = bookkeeping closure (each gate true).")
    println("  T3 = on-disk archival evidence, NOT live hardware telemetry.")
    println("  Saturated != falsified != confirmed.")
    if passed {
        println("__HEXA_LANG_RSC_RUN_ALL__ PASS")
    } else {
        println("__HEXA_LANG_RSC_RUN_ALL__ FAIL")
    }
    return RunAllResult {
        pass: passed,
        falsifier_pass: fa.pass,
        saturation_pass: sat.pass,
        lint_pass: lint.pass
    }
}
