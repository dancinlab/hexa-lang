// absorbed from ~/core/hexa-space/verify/lint_numerics.hexa (MIT, hexa-space v1.0.0)
// tool/rsc/lint_numerics.hexa — 5-invariant lint over hexa-lang numerics_*.hexa.
//
// @version 0.1.0
// @capabilities [fs_read, exec]
//
// For every numerics_*.hexa under firmware/boards/<board>/verify/, verify:
//   #1 imports `self/runtime/math_pure` (no raw float-libm).
//   #2 emits `__HEXA_*_NUMERICS_<NAME>__` sentinel with PASS suffix.
//   #3 declares a `FALSIFIERS` array near top.
//   #4 has explicit `exit(0)` on success path.
//   #5 has `let mut RUN` and `let mut FAIL` counters.
//
// Sentinel: __HEXA_LANG_RSC_LINT__ PASS|FAIL — <n_pass>/<n_total>

use "tool/rsc/registry"

pub struct LintItem {
    path: string,
    rule_1_math_pure: bool,
    rule_2_sentinel: bool,
    rule_3_falsifiers: bool,
    rule_4_exit_zero: bool,
    rule_5_counters: bool
}

pub struct LintAudit {
    pass: bool,
    total_files: i64,
    total_checks: i64,
    failed_checks: i64,
    items: [LintItem],
    failures: [string]
}

fn _read_safe(p: string) -> string {
    if file_exists(p) == false { return "" }
    return read_file(p)
}

fn _has(haystack: string, needle: string) -> bool {
    if len(haystack) == 0 { return false }
    return haystack.contains(needle)
}

fn _discover_numerics() -> [string] {
    let cmd = "find " + rsc_root() + "/firmware/boards -path '*/verify/numerics_*.hexa' 2>/dev/null | sort"
    let r = exec_with_status(cmd)
    let raw = to_string(r[0])
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let p = lines[i].trim()
        if len(p) > 0 { out.push(p) }
        i = i + 1
    }
    return out
}

fn _audit_file(path: string) -> LintItem {
    let txt = _read_safe(path)
    let math_pure = _has(txt, "use \"self/runtime/math_pure\"")
    let sent_ok = _has(txt, "__HEXA_") && _has(txt, "__ PASS")
    let fals_ok = _has(txt, "FALSIFIERS")
    let exit_ok = _has(txt, "exit(0)")
    let run_ok  = _has(txt, "let mut RUN")
    let fail_ok = _has(txt, "let mut FAIL")
    return LintItem {
        path: path,
        rule_1_math_pure: math_pure,
        rule_2_sentinel: sent_ok,
        rule_3_falsifiers: fals_ok,
        rule_4_exit_zero: exit_ok,
        rule_5_counters: run_ok && fail_ok
    }
}

pub fn rsc_lint_numerics() -> LintAudit {
    let files = _discover_numerics()
    let mut items = []
    let mut failures = []
    let mut total_checks = 0
    let mut failed_checks = 0
    let mut i = 0
    while i < len(files) {
        let it = _audit_file(files[i])
        items.push(it)
        // 5 rules per file
        total_checks = total_checks + 5
        if !it.rule_1_math_pure  { failed_checks = failed_checks + 1; failures.push(it.path + " :: #1 math_pure import missing") }
        if !it.rule_2_sentinel   { failed_checks = failed_checks + 1; failures.push(it.path + " :: #2 __HEXA_*__ PASS sentinel missing") }
        if !it.rule_3_falsifiers { failed_checks = failed_checks + 1; failures.push(it.path + " :: #3 FALSIFIERS array missing") }
        if !it.rule_4_exit_zero  { failed_checks = failed_checks + 1; failures.push(it.path + " :: #4 exit(0) missing") }
        if !it.rule_5_counters   { failed_checks = failed_checks + 1; failures.push(it.path + " :: #5 RUN/FAIL counters missing") }
        i = i + 1
    }
    return LintAudit {
        pass: (len(files) > 0) && (failed_checks == 0),
        total_files: len(files),
        total_checks: total_checks,
        failed_checks: failed_checks,
        items: items,
        failures: failures
    }
}

pub fn rsc_lint_numerics_print() -> LintAudit {
    println("========================================================================")
    println("  hexa-lang RSC — numerics_*.hexa 5-invariant lint")
    println("========================================================================")
    println("  root: " + rsc_root())

    let result = rsc_lint_numerics()
    println("  files discovered: " + to_string(result.total_files))
    println("")

    let mut i = 0
    while i < len(result.items) {
        let it = result.items[i]
        let r1 = if it.rule_1_math_pure  { "v" } else { "x" }
        let r2 = if it.rule_2_sentinel   { "v" } else { "x" }
        let r3 = if it.rule_3_falsifiers { "v" } else { "x" }
        let r4 = if it.rule_4_exit_zero  { "v" } else { "x" }
        let r5 = if it.rule_5_counters   { "v" } else { "x" }
        println("  [" + r1 + r2 + r3 + r4 + r5 + "] " + it.path)
        i = i + 1
    }

    println("")
    let passed = result.total_checks - result.failed_checks
    println("  " + to_string(passed) + "/" + to_string(result.total_checks) + " lint checks pass")
    if result.failed_checks > 0 {
        println("  FAILURES:")
        let mut j = 0
        while j < len(result.failures) {
            println("    x " + result.failures[j])
            j = j + 1
        }
    }
    if result.pass {
        println("__HEXA_LANG_RSC_LINT__ PASS - " + to_string(passed) + "/" + to_string(result.total_checks))
    } else {
        println("__HEXA_LANG_RSC_LINT__ FAIL - " + to_string(passed) + "/" + to_string(result.total_checks))
    }
    return result
}
