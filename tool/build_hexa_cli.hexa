// tool/build_hexa_cli.hexa — native port of build_hexa_cli.sh.
//
// Compiles self/main.hexa (CLI dispatcher) and self/module_loader.hexa
// (import flattener) into native binaries via the hexat transpiler
// + clang + runtime.c. Replaces the retired .sh, removing the last
// .sh in the hexa-native tool/ tree (g_hexa_native_no_sh_py_writes).
//
// Produces:
//   build/hexa_cli_driver     — compiled self/main.hexa  (CLI dispatcher)
//   build/hexa_module_loader  — compiled self/module_loader.hexa
//
// Env:
//   CLANG                       compiler override (default: clang)
//   SKIP_TRANSPILE=1            reuse existing build/stage1/*.c
//   NO_SMOKE=1                  skip smoke test
//   LOCAL_BUILD=1               permit local Mac build (escape hatch)
//   HEXA_POOL_BUILD_HOST=<host> ack-only marker (PR2 will auto-offload)
//
// Flags (opt-in):
//   --install                   after a successful build, deploy
//                               build/hexa_cli_driver to the shim's targets
//                               (CANON M8 — closes the M3b deploy gap so a
//                               pull never leaves a stale deployed hexa).
//                               OFF by default — CI / fresh-clone never deploy.
//
// Re-entry gate (kick-storm Mac kill 2026-05-23 root cause —
// memory: feedback_pool_cli_offload_heavy_build):
//   On Mac (Darwin) without LOCAL_BUILD=1 the build REFUSES with a
//   hint pointing at `pool on mini`. The gate is the simplest
//   sufficient countermeasure (g0); auto-offload follows as a
//   separate PR.

fn _die(msg: string) {
    eprintln("build_hexa_cli: " + msg)
    exit(1)
}

fn _must_exist(path: string, hint: string) {
    if !file_exists(path) {
        _die(hint + " missing: " + path)
    }
}

fn _uname() -> string {
    return to_string(exec("uname")).trim()
}

fn _uname_m() -> string {
    return to_string(exec("uname -m")).trim()
}

// shell single-quote escape: ' → '\''
fn _shq(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            out = out + "'\\''"
        } else {
            out = out + c
        }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _run(cmd: string, label: string) {
    let r = exec_with_status(cmd)
    let rc = r[1]
    if rc != 0 {
        eprintln("build_hexa_cli: " + label + " failed (rc=" + to_string(rc) + ")")
        let out = to_string(r[0])
        if len(out) > 0 { eprintln(out) }
        exit(rc)
    }
}

fn _file_exists(p: string) -> bool {
    let r = exec_with_status("test -f " + _shq(p))
    return r[1] == 0
}

// _pick_hexat: select the committed hexat binary that matches the
// host (os, arch) triple. Returns absolute path under <repo>/self/native/.
//
// Layout (multiarch, 2026-05-24):
//   self/native/hexat                  — Mac arm64 (Mach-O), legacy name
//   self/native/hexat_linux_x86_64     — Linux x86_64 (ELF)
//
// The legacy name "hexat" is preserved for Mac arm64 to avoid churning
// the entire build chain (bootstrap.yml, build_hexa_cli_native.hexa, etc).
// Other (os, arch) pairs use a suffixed name so a single git commit can
// carry every host's binary.
//
// Background: PR #454 regen-ed hexat on Mac arm64 only, leaving Linux
// hosts (ubu-1/ubu-2) running a Mac binary via shared self/native/hexat
// — which SIGSEGVs / exec-fails on Linux. This helper lets Linux pick
// its own ELF without forcing every commit to rebuild every arch.
fn _pick_hexat(repo_root: string) -> string {
    // CANON M3b: the transpiler is a per-machine build artifact, not a
    // committed binary. Returns the expected build/hexat path; _do_build
    // bootstraps it from hexa_cc.c (cc hexa_cc.c runtime.c) when absent.
    return repo_root + "/build/hexat"
}

// REPO_ROOT — HEXA_LANG if set, else cwd.
fn _repo_root() -> string {
    let hl = env_var("HEXA_LANG")
    if hl != "" { return hl }
    return to_string(exec("pwd")).trim()
}

// Mac re-entry gate. Returns true iff the build must NOT proceed locally.
fn _refuse_local_on_mac() -> bool {
    if _uname() != "Darwin" { return false }
    if env_var("LOCAL_BUILD") == "1" { return false }
    return true
}

fn _print_refuse_hint(repo_root: string) {
    eprintln("REFUSE: build_hexa_cli is heavy on Mac arm64.")
    eprintln("  this guard exists because kick-storm + multi-agent")
    eprintln("  local builds killed the Mac (2026-05-23 incident).")
    eprintln("")
    eprintln("  pool offload (recommended):")
    eprintln("    pool on mini bash -lc " + _shq("cd " + repo_root + " && LOCAL_BUILD=1 tool/build_hexa_cli"))
    eprintln("")
    eprintln("  force local (will burden Mac):")
    eprintln("    LOCAL_BUILD=1 tool/build_hexa_cli")
}

// --install present anywhere in argv? Opt-in deploy gate (CANON M8).
fn _want_install() -> bool {
    let av = args()
    let n = len(av)
    let mut i = 0
    while i < n {
        if to_string(av[i]) == "--install" { return true }
        i = i + 1
    }
    return false
}

// $HOME, robustly (env first). Empty → caller skips the ~/.hx/bin targets.
fn _home() -> string {
    let h = env_var("HOME")
    if h != "" { return h }
    return to_string(exec("echo $HOME")).trim()
}

// Copy build/hexa_cli_driver into one shim target + codesign on Mac.
//
// GUARD (2026-05-26): never deploy a TRANSPILER binary to a driver shim
// target. The transpiler (hexa_v2 / `self/native/hexa_v2`) and the CLI driver
// (hexa_cli_driver) are distinct binaries; the shim target name `hxv2`
// resembles the transpiler name `hexa_v2`, and a mis-deploy put the transpiler
// at ~/.hx/bin/{hexa.real,hxv2}. Because the transpiler treats argv as
// `<in> <out>`, every `hexa parse <f>` then CLOBBERED <f> with an empty C stub
// and `hexa verify --expr …` printed "OK: --expr" (writing a stub to a file
// named `--expr`). Only the transpiler carries the codegen emit banner, so a
// driver_out that contains it is the wrong artifact — refuse rather than ship
// a source-destroying binary onto the shim.
fn _deploy_one(driver_out: string, dst: string, uname: string) {
    if dst == "" { return }
    let _banner = to_string(exec("strings " + _shq(driver_out)
        + " 2>/dev/null | grep -c 'Generated by HEXA self-host compiler'")).trim()
    if _banner != "0" && _banner != "" {
        _die("refusing to deploy a TRANSPILER as the driver: " + driver_out
            + " carries the self-host emit banner (expected build/hexa_cli_driver). "
            + "A transpiler at a driver shim target clobbers source on `hexa parse`.")
    }
    _run("cp -f " + _shq(driver_out) + " " + _shq(dst), "deploy → " + dst)
    if uname == "Darwin" {
        let _ = exec("codesign --force --sign - " + _shq(dst) + " 2>/dev/null || true")
    }
    println("  deployed: " + dst)
}

// CANON M8 — install step. The shim resolves ~/.hx/bin/hexa → main-worktree
// `hexa` shim → __hexa_dir = main-worktree → tries `hxv2` (preferred) →
// falls back to `hexa.real`. The root cause of the M3b deploy gap (M5
// diagnosis, PR #975) was that the build produced build/hexa_cli_driver but
// never copied it to these targets, so a post-pull deployed hexa stayed
// stale (PRE-M3b) and broke. This copies the fresh driver to all four
// targets so the gap can never recur. Opt-in (--install) — never auto-runs.
// INBOX 3 binary activation fix (2026-05-27, #1281/#1283 family): the
// shipped install was missing self/runtime.o, the cached object hexa
// cc --regen links against. cmd_cc() has a lazy stale-check that
// compiles runtime.o on first invocation, but a fresh-install user
// invoking `hexa verify` (which runs verify_cli via `hexa run`)
// hits the deployed driver's link step BEFORE cmd_cc gets a chance,
// failing with `runtime.o missing`. Build it as part of --install
// so the deploy is self-sufficient.
fn _install_runtime_o(repo_root: string, uname: string) {
    let rt_c = repo_root + "/self/runtime.c"
    let rt_o = repo_root + "/self/runtime.o"
    if !file_exists(rt_c) {
        eprintln("  warn: " + rt_c + " missing — skipped runtime.o pre-build")
        return
    }
    // Stale check — skip if .o newer than .c (same logic as cmd_cc).
    let stale = exec("[ " + _shq(rt_o) + " -nt " + _shq(rt_c) + " ] && printf cached || printf stale").trim()
    if stale == "cached" {
        println("  [rt.o] cached (" + rt_o + ")")
        return
    }
    let mut cmd = ""
    if uname == "Linux" {
        cmd = "clang -O2 -D_GNU_SOURCE -c " + _shq(rt_c) + " -o " + _shq(rt_o) + " 2>&1"
    } else {
        cmd = "clang -O2 -c " + _shq(rt_c) + " -o " + _shq(rt_o) + " 2>&1"
    }
    println("  [rt.o] " + cmd)
    let r = exec(cmd)
    if !file_exists(rt_o) {
        eprintln("  error: runtime.o build failed:")
        eprintln(r)
        return
    }
    println("  [rt.o] OK (" + rt_o + ")")
}

fn _install_driver(repo_root: string, uname: string) {
    let driver_out = repo_root + "/build/hexa_cli_driver"
    _must_exist(driver_out, "driver (build first)")
    println("")
    println("=== INSTALL (deploy to shim targets) ===")
    // INBOX 3 #1281/#1283: ensure self/runtime.o is present so
    // ~/.hx/bin/self/runtime.o (via symlink) resolves on first
    // `hexa cc --regen` / `hexa verify` invocation.
    _install_runtime_o(repo_root, uname)
    // main-worktree: hxv2 (shim-preferred) + hexa.real (fallback)
    _deploy_one(driver_out, repo_root + "/hxv2",      uname)
    _deploy_one(driver_out, repo_root + "/hexa.real", uname)
    // ~/.hx/bin: hxv2 + hexa.real
    let home = _home()
    if home != "" {
        let hxbin = home + "/.hx/bin"
        let _ = exec("mkdir -p " + _shq(hxbin))
        _deploy_one(driver_out, hxbin + "/hxv2",      uname)
        _deploy_one(driver_out, hxbin + "/hexa.real", uname)
    } else {
        eprintln("  warn: $HOME unresolved — skipped ~/.hx/bin targets")
    }
    println("=== INSTALL OK ===")
}

// B9.C-10 (F3) — regen the 16 self/native/*.c fragments `#include`d by
// runtime.c from their hexa emitters (self/native/<f>_emit.hexa, the SSOT).
//
// STRICTLY OPTIONAL: runs only when an external `hexa-run`/`hexa` is on PATH
// (the bootstrap hexat does not exist yet — chicken-egg) AND the emitter file
// is present. On SHA-identical regen the runtime.c TU is unchanged. If no
// hexa-run is available (fresh clone / CI seed) the build SKIPs the regen and
// uses the in-tree `.c` as-is — byte-for-byte identical to pre-B9.C-10.
fn _regen_native_includes(repo_root: string) {
    // Resolve an external hexa runner (prefer hexa-run, then hexa).
    let mut runner = ""
    let r1 = exec_with_status("command -v hexa-run >/dev/null 2>&1")
    if r1[1] == 0 {
        runner = "hexa-run"
    } else {
        let r2 = exec_with_status("command -v hexa >/dev/null 2>&1")
        if r2[1] == 0 { runner = "hexa run" }
    }
    if runner == "" {
        println("[0-pre] native .c regen SKIP — no external hexa-run on PATH (in-tree .c used)")
        return
    }
    let nat = repo_root + "/self/native"
    let bases = ["crypto_openssl", "crypto_sodium", "exec_argv_sha256", "exec_pipe", "fp_init", "mount", "namespace", "net", "persistent_pipe", "proc_fork", "pty", "signal_flock", "tensor_kernels", "term_ffi", "thread", "wait"]
    let mut done = 0
    let mut skipped = 0
    let mut i = 0
    while i < len(bases) {
        let base = bases[i]
        let emitter = nat + "/" + base + "_emit.hexa"
        let dst     = nat + "/" + base + ".c"
        if !_file_exists(emitter) {
            skipped = skipped + 1
            i = i + 1
            continue
        }
        // Regen into a scratch file first so a failed emit never clobbers a
        // good in-tree baseline; install only on success.
        let tmp = to_string(exec("mktemp -t regen_native_c.XXXXXX")).trim()
        if tmp == "" {
            eprintln("  warn: mktemp failed — regen " + base + ".c skipped (in-tree used)")
            skipped = skipped + 1
            i = i + 1
            continue
        }
        let regen = exec_with_status(runner + " " + _shq(emitter) + " " + _shq(tmp) + " >/dev/null 2>&1")
        if regen[1] == 0 && _file_exists(tmp) {
            let _ = exec("cp -f " + _shq(tmp) + " " + _shq(dst))
            done = done + 1
        } else {
            eprintln("  warn: emitter " + base + "_emit.hexa failed (rc=" + to_string(regen[1]) + ") — in-tree .c used")
            skipped = skipped + 1
        }
        let _ = exec("rm -f " + _shq(tmp))
        i = i + 1
    }
    println("[0-pre] native .c regen: " + to_string(done) + " regenerated from emitter SSOT, " + to_string(skipped) + " skipped (in-tree)")
}

// B9.C-10 (F3) — regen self/runtime_core.c (the CORE-tier fragment `#include`d
// by runtime.c at line 1762, RFC 061 amalgamation) from its hexa emitter
// (self/runtime_core_emit.hexa, the SSOT). Same STRICTLY-OPTIONAL contract as
// _regen_native_includes: runs only when an external hexa-run/hexa is on PATH
// AND the emitter is present; on SHA-identical regen the runtime.c TU is
// unchanged; on a fresh clone (no external runner) the in-tree .c is used as-is.
// runtime_core.c lives at self/ (NOT self/native/), so it gets its own step.
fn _regen_runtime_core(repo_root: string) {
    let mut runner = ""
    let r1 = exec_with_status("command -v hexa-run >/dev/null 2>&1")
    if r1[1] == 0 {
        runner = "hexa-run"
    } else {
        let r2 = exec_with_status("command -v hexa >/dev/null 2>&1")
        if r2[1] == 0 { runner = "hexa run" }
    }
    if runner == "" {
        println("[0-pre] runtime_core.c regen SKIP — no external hexa-run on PATH (in-tree .c used)")
        return
    }
    let emitter = repo_root + "/self/runtime_core_emit.hexa"
    let dst     = repo_root + "/self/runtime_core.c"
    if !_file_exists(emitter) {
        println("[0-pre] runtime_core.c regen SKIP — emitter absent (in-tree .c used)")
        return
    }
    let tmp = to_string(exec("mktemp -t regen_runtime_core_c.XXXXXX")).trim()
    if tmp == "" {
        eprintln("  warn: mktemp failed — regen runtime_core.c skipped (in-tree used)")
        return
    }
    let regen = exec_with_status(runner + " " + _shq(emitter) + " " + _shq(tmp) + " >/dev/null 2>&1")
    if regen[1] == 0 && _file_exists(tmp) {
        let _ = exec("cp -f " + _shq(tmp) + " " + _shq(dst))
        println("[0-pre] runtime_core.c regen: 1 regenerated from emitter SSOT")
    } else {
        eprintln("  warn: emitter runtime_core_emit.hexa failed (rc=" + to_string(regen[1]) + ") — in-tree .c used")
    }
    let _ = exec("rm -f " + _shq(tmp))
}

// B9.C — regen self/runtime_hi_gen.c (the HI-tier rt_str_* fragment `#include`d
// by self/runtime_core.c, RFC 061 amalgamation) from its hexa emitter
// (self/runtime_hi_gen_emit.hexa, the .c-text SSOT). Same STRICTLY-OPTIONAL
// contract as _regen_runtime_core: runs only when an external hexa-run/hexa is
// on PATH AND the emitter is present; on SHA-identical regen the runtime.c TU
// is unchanged; on a fresh clone (no external runner) the in-tree .c is used
// as-is. runtime_hi_gen.c lives at self/, so it gets its own step.
fn _regen_runtime_hi_gen(repo_root: string) {
    let mut runner = ""
    let r1 = exec_with_status("command -v hexa-run >/dev/null 2>&1")
    if r1[1] == 0 {
        runner = "hexa-run"
    } else {
        let r2 = exec_with_status("command -v hexa >/dev/null 2>&1")
        if r2[1] == 0 { runner = "hexa run" }
    }
    if runner == "" {
        println("[0-pre] runtime_hi_gen.c regen SKIP — no external hexa-run on PATH (in-tree .c used)")
        return
    }
    let emitter = repo_root + "/self/runtime_hi_gen_emit.hexa"
    let dst     = repo_root + "/self/runtime_hi_gen.c"
    if !_file_exists(emitter) {
        println("[0-pre] runtime_hi_gen.c regen SKIP — emitter absent (in-tree .c used)")
        return
    }
    let tmp = to_string(exec("mktemp -t regen_runtime_hi_gen_c.XXXXXX")).trim()
    if tmp == "" {
        eprintln("  warn: mktemp failed — regen runtime_hi_gen.c skipped (in-tree used)")
        return
    }
    let regen = exec_with_status(runner + " " + _shq(emitter) + " " + _shq(tmp) + " >/dev/null 2>&1")
    if regen[1] == 0 && _file_exists(tmp) {
        let _ = exec("cp -f " + _shq(tmp) + " " + _shq(dst))
        println("[0-pre] runtime_hi_gen.c regen: 1 regenerated from emitter SSOT")
    } else {
        eprintln("  warn: emitter runtime_hi_gen_emit.hexa failed (rc=" + to_string(regen[1]) + ") — in-tree .c used")
    }
    let _ = exec("rm -f " + _shq(tmp))
}

// B9.C-8 (.c-leg dispatch regen) — regen the THREE CUDA/forge bridge `.c`
// files that remote GPU dispatch scripts scp to a pod for `nvcc -x cu` /
// `clang -DHEXA_CUDA` build, from their hexa emitters (the SSOT):
//   - self/cuda/runtime_bf16.c    ← self/cuda/runtime_bf16_emit.hexa
//   - self/cuda/runtime_cuda.c    ← self/cuda/runtime_cuda_emit.hexa
//   - self/forge/forge_tier_v1.c  ← self/forge/forge_tier_v1_emit.hexa
//
// These three are NOT `#include`d into runtime.c — they are compiled
// independently on the GPU pod after scp. Wiring the regen here makes the
// canonical build path the activation surface for "regen-before-scp": a
// build run on a host with an external hexa-run refreshes all three `.c`
// from their emitters BEFORE any subsequent dispatch scp picks them up.
//
// SAFETY — identical STRICTLY-OPTIONAL contract as the runtime regens above:
//   · runs only when an external `hexa-run` (or `hexa`) is on PATH AND the
//     emitter exists (delegates to tool/regen_dispatch_c_artifacts.hexa, the
//     B9.C-8 regen-orchestrator SSOT — single entry point, sha-verified).
//   · the regenerated bytes are SHA-identical to the committed `.c` (gate-1
//     source-SHA PROVEN), so scp'd bytes are unchanged → nvcc is
//     deterministic on identical input → the GPU build/test is UNAFFECTED.
//     NO GPU re-verification is needed.
//   · if no hexa-run is available (fresh clone, CI seed) OR the orchestrator
//     is absent, the regen SKIPs and the in-tree `.c` is used as-is — the
//     build is byte-for-byte identical to the pre-wiring behavior, and the
//     hexa-cli build itself NEVER depends on these three `.c` (they are not
//     #include'd), so a regen failure can never break the build.
fn _regen_dispatch_c_artifacts(repo_root: string) {
    let mut runner = ""
    let r1 = exec_with_status("command -v hexa-run >/dev/null 2>&1")
    if r1[1] == 0 {
        runner = "hexa-run"
    } else {
        let r2 = exec_with_status("command -v hexa >/dev/null 2>&1")
        if r2[1] == 0 { runner = "hexa run" }
    }
    if runner == "" {
        println("[0-pre] cuda/forge dispatch .c regen SKIP — no external hexa-run on PATH (in-tree .c used)")
        return
    }
    let orch = repo_root + "/tool/regen_dispatch_c_artifacts.hexa"
    if !_file_exists(orch) {
        println("[0-pre] cuda/forge dispatch .c regen SKIP — orchestrator absent (in-tree .c used)")
        return
    }
    // Delegate to the B9.C-8 orchestrator (regen + gate-1 sha-verify vs the
    // in-tree `.c`). It exits 0 on all-regen-OK + all-sha-equal, 1 on drift /
    // emit failure. A non-zero rc here NEVER breaks the build — the three
    // `.c` are scp-only (not #include'd into runtime.c), so we only warn.
    let regen = exec_with_status(runner + " " + _shq(orch) + " >/dev/null 2>&1")
    if regen[1] == 0 {
        println("[0-pre] cuda/forge dispatch .c regen: 3 regenerated from emitter SSOT + sha-verified")
    } else {
        eprintln("  warn: regen_dispatch_c_artifacts rc=" + to_string(regen[1]) + " (drift/emit) — in-tree .c used (build unaffected: scp-only)")
    }
}

// ── B9.C — VENDOR FFI SHIM `.c`-text regen (step-0-pre) ───────────────────
//
// Regenerates the 6 vendor-EXEMPT self/native/*.c FFI shims from their hexa
// emitters (the SSOT):
//   - self/native/hxblas_linux.c    ← hxblas_linux_emit.hexa
//   - self/native/hxccl_linux.c     ← hxccl_linux_emit.hexa
//   - self/native/hxlmhead_linux.c  ← hxlmhead_linux_emit.hexa
//   - self/native/hxqwen14b.c       ← hxqwen14b_emit.hexa
//   - self/native/hxqwen32b.c       ← hxqwen32b_emit.hexa
//   - self/native/lora_cuda_host.c  ← lora_cuda_host_emit.hexa
//
// These are NOT `#include`d into runtime.c — they are compiled independently
// by the vendor `.so` build. Wiring the regen here makes the canonical build
// path the activation surface: a build run on a host with an external
// hexa-run refreshes all six `.c` from their emitters BEFORE any subsequent
// vendor compile picks them up.
//
// SAFETY — identical STRICTLY-OPTIONAL contract as _regen_dispatch_c_artifacts:
//   · runs only when an external `hexa-run` (or `hexa`) is on PATH AND the
//     orchestrator (tool/regen_vendor_native_c.hexa) exists.
//   · the regenerated bytes are SHA-identical to the committed `.c` (gate-1
//     source-SHA PROVEN by self/native/<base>_byte_diff.hexa), so the vendor
//     `cc`/`nvcc` (deterministic on identical input) produces the SAME
//     `.o`/`.so` → vendor build UNAFFECTED. NO vendor/GPU re-verification.
//   · if no hexa-run is available (fresh clone, CI seed) OR the orchestrator
//     is absent, the regen SKIPs and the in-tree `.c` is used as-is. The
//     hexa-cli build itself NEVER depends on these six `.c` (not #include'd),
//     so a regen failure can NEVER break the build.
fn _regen_vendor_native_c(repo_root: string) {
    let mut runner = ""
    let r1 = exec_with_status("command -v hexa-run >/dev/null 2>&1")
    if r1[1] == 0 {
        runner = "hexa-run"
    } else {
        let r2 = exec_with_status("command -v hexa >/dev/null 2>&1")
        if r2[1] == 0 { runner = "hexa run" }
    }
    if runner == "" {
        println("[0-pre] vendor FFI shim .c regen SKIP — no external hexa-run on PATH (in-tree .c used)")
        return
    }
    let orch = repo_root + "/tool/regen_vendor_native_c.hexa"
    if !_file_exists(orch) {
        println("[0-pre] vendor FFI shim .c regen SKIP — orchestrator absent (in-tree .c used)")
        return
    }
    let regen = exec_with_status(runner + " " + _shq(orch) + " >/dev/null 2>&1")
    if regen[1] == 0 {
        println("[0-pre] vendor FFI shim .c regen: 6 regenerated from emitter SSOT + sha-verified")
    } else {
        eprintln("  warn: regen_vendor_native_c rc=" + to_string(regen[1]) + " (drift/emit) — in-tree .c used (build unaffected: vendor-only)")
    }
}

fn _do_build(repo_root: string) {
    // multiarch-aware: Linux x86_64 → hexat_linux_x86_64; Mac arm64 → hexat.
    // Falls back to legacy "hexat" path when the arch-specific binary
    // hasn't been committed yet (pre-multiarch clones).
    let hexat   = _pick_hexat(repo_root)
    let main_hexa = repo_root + "/self/main.hexa"
    let ml_hexa   = repo_root + "/self/module_loader.hexa"
    let stage1    = repo_root + "/build/stage1"
    let main_c    = stage1 + "/main_native.c"
    let main_expanded = stage1 + "/main_expanded.hexa"
    let ml_c      = stage1 + "/module_loader.c"
    let driver_out = repo_root + "/build/hexa_cli_driver"
    let ml_out     = repo_root + "/build/hexa_module_loader"
    let runtime_c  = repo_root + "/self/runtime.c"
    let inc        = repo_root + "/self"

    _must_exist(main_hexa, "main source")
    _must_exist(ml_hexa,   "module_loader source")

    let _ = exec("mkdir -p " + _shq(stage1) + " " + _shq(repo_root + "/build"))

    let mut cc = env_var("CLANG")
    if cc == "" { cc = "clang" }

    let uname = _uname()
    let mut cflags = "-O2 -std=c11 -D_GNU_SOURCE -Wno-trigraphs -fbracket-depth=4096 -I " + _shq(inc)
    let mut ldflags = "-lpthread -lm -Wl,-stack_size,0x4000000"
    if uname == "Linux" {
        // -fbracket-depth is clang-only; bootstrap.yml uses bare gcc on Linux
        // and has no equivalent — Linux clang accepts -fbracket-depth so we
        // honour CLANG=clang, but default cc=clang on Linux is usually gcc.
        let mut bracket = " -fbracket-depth=4096"
        if cc == "gcc" || cc == "cc" { bracket = "" }
        cflags  = "-O2 -std=gnu11 -D_GNU_SOURCE -Wno-trigraphs" + bracket + " -I " + _shq(inc)
        ldflags = "-lpthread -lm -ldl"
    }

    // ── F3 ACTIVATION RUNBOOK · Path A — self-emit runtime primitive override.
    //
    // DEFAULT (HEXA_RT_SELFEMIT unset): no change. runtime.c keeps the
    // `static` hxlcl_* bodies; the driver/module_loader libc-extern set is
    // unchanged (0-extern invariant preserved — guard is strictly OPT-IN).
    //
    // The accumulated `.o` list lives here; the EMIT work happens AFTER the
    // hexat bootstrap (step 0) because emitting needs the transpiler. The
    // bootstrap hexat itself must be built with the DEFAULT (guard-off)
    // runtime — it does not depend on the self-emit symbols — so the
    // -DHEXA_RT_SELFEMIT cflag is applied only AFTER step 0.
    let mut selfemit_objs = ""

    // ── Step 0-pre (B9.C-10 · F3): regen runtime.c #include native fragments.
    //
    // runtime.c amalgamates 16 self/native/*.c fragments via `#include`. Each
    // is byte-identically hexa-emittable (self/native/<f>_emit.hexa is the
    // SSOT; B9.C-10 byte_diff oracles gate-1 source-SHA PASS). Refresh each
    // `.c` from its emitter BEFORE the bootstrap (step 0) and the runtime.c
    // compiles (steps 2 + 4) so the emitter is the authoritative source.
    //
    // SAFETY — the regen is STRICTLY OPTIONAL and never breaks the build:
    //   · runs only when an external `hexa-run` (or `hexa`) is on PATH AND the
    //     emitter exists. The bootstrap transpiler does not yet exist here
    //     (chicken-egg: hexat is built from runtime.c which #includes these),
    //     so the regen relies on a previously-installed hexa, exactly like the
    //     B9.C-8 regen-orchestrator bridge (tool/regen_dispatch_c_artifacts).
    //   · the regenerated bytes are SHA-identical to the committed `.c`, so the
    //     compiled runtime.c TU / hexa binary is unchanged (PERF UNCHANGED).
    //   · if no hexa-run is available (fresh clone, CI seed), the regen SKIPs
    //     and the in-tree `.c` (committed or already-present) is used as-is —
    //     the build is byte-for-byte identical to the pre-B9.C-10 behavior.
    _regen_native_includes(repo_root)
    // F3 — also regen the CORE-tier fragment self/runtime_core.c (same contract).
    _regen_runtime_core(repo_root)
    // B9.C — also regen the HI-tier fragment self/runtime_hi_gen.c (same contract).
    _regen_runtime_hi_gen(repo_root)
    // B9.C-8 — also regen the three CUDA/forge dispatch `.c` (runtime_bf16.c,
    // runtime_cuda.c, forge_tier_v1.c) from their emitters via the B9.C-8
    // orchestrator. These are scp-only (not #include'd into runtime.c), so the
    // regen is the "regen-before-scp" activation surface and can never break
    // this build — same STRICTLY-OPTIONAL contract as the regens above.
    _regen_dispatch_c_artifacts(repo_root)
    // B9.C — also regen the 6 vendor-EXEMPT FFI shim `.c` (hxblas_linux.c,
    // hxccl_linux.c, hxlmhead_linux.c, hxqwen14b.c, hxqwen32b.c,
    // lora_cuda_host.c) from their emitters via the vendor orchestrator. These
    // are vendor-`.so`-only (not #include'd into runtime.c), so the regen is
    // the "regen-before-vendor-build" activation surface and can never break
    // this build — same STRICTLY-OPTIONAL contract as the regens above.
    _regen_vendor_native_c(repo_root)

    // ── Step 0: bootstrap the transpiler artifact (CANON M3b · Go 1.4 C-seed).
    //   The transpiler is no longer a committed binary — build it per-machine
    //   from the arch-neutral hexa_cc.c so it is never arch-mismatched. The
    //   amalgam swap (#include "runtime.h" → "runtime.c") pulls the runtime
    //   bodies into a single TU (hexa_cc.c heads with the proto-only header).
    if !_file_exists(hexat) {
        println("[0/5] bootstrap transpiler: cc hexa_cc.c runtime.c → " + hexat)
        let hexa_cc_c = repo_root + "/self/native/hexa_cc.c"
        _must_exist(hexa_cc_c, "hexa_cc.c (transpiler C seed)")
        let amalgam = repo_root + "/build/_hexa_cc_amalgam.c"
        _run("sed 's|#include \"runtime.h\"|#include \"runtime.c\"|' " + _shq(hexa_cc_c) + " > " + _shq(amalgam), "amalgam hexa_cc.c")
        _run(cc + " " + cflags + " " + _shq(amalgam) + " -o " + _shq(hexat) + " " + ldflags, "bootstrap hexat")
        let _ = exec("rm -f " + _shq(amalgam))
    }
    _must_exist(hexat, "hexat (bootstrap from hexa_cc.c failed)")

    // ── F3 ACTIVATION RUNBOOK · Path A — emit the self-emit leaf objects.
    //
    // OPT-IN (HEXA_RT_SELFEMIT=1, arm64 Mach-O only): compile runtime.c with
    // -DHEXA_RT_SELFEMIT (each hxlcl_<name> becomes an `extern` declaration),
    // emit one hexa-native .o per leaf exporting the strong `_hxlcl_<name>`
    // symbol from rt_<name>'s self-emitted bytes, and ahead-link ALL of them
    // into both binaries. ld64 binds every `bl _hxlcl_<name>` callsite to the
    // self-emit .o — the C runtime's memset/memcpy/strcmp/… are replaced by
    // hexa-emitted machine code end-to-end. The B9.6a-7 batch activates the
    // reloc-free leaf family proven by #1836 (rt_memset).
    //
    // Runs AFTER step 0 so `hexat` exists. Each emit driver is self-contained
    // (no `use`) and is itself built with the DEFAULT (guard-off) runtime —
    // note the literal `-O2 -std=c11 …` cflags below, NOT the mutated `cflags`
    // — so it never depends on the symbol it produces. NONE of these drivers
    // are `use`-d by compiler/main.hexa → no regen / fixpoint risk (per #1836).
    if env_var("HEXA_RT_SELFEMIT") != "" {
        if uname != "Darwin" {
            eprintln("  warn: HEXA_RT_SELFEMIT only supports arm64 Mach-O (Darwin) — ignored")
        } else {
            println("[selfemit] F3 Path A · B9.6a-7 — 12 reloc-free leaf primitives → _hxlcl_* native overrides")
            println("[selfemit] F3 Path A · B9.6-C1 — class-C syscall ABI: getpid (raw svc #0x80) → _hxlcl_getpid")
            println("[selfemit] F3 Path A · B9.6-C2 — class-C syscall WITH arg+errno: close (svc + carry-flag) → _hxlcl_close")
            println("[selfemit] F3 Path A · B9.6-B1 — class-B calling-conv composite: atoi (frame + bl) → _hxlcl_atoi")
            println("[selfemit] F3 Path A · B9.6-B2 — class-B HARD copy-loop: strdup (frame + strlen-loop + bl malloc + copy-loop) → _hxlcl_strdup")
            println("[selfemit] F3 Path A · class-B HARD scale-out — strndup (cap-bounded copy-loop + bl malloc) → _hxlcl_strndup")
            println("[selfemit] F3 Path A · B9.6-E1 — class-E memory-lifecycle: munmap (unmap stub) → _hxlcl_munmap")
            // From here on the driver/module_loader runtime.c is compiled with
            // the guard ON so the hxlcl_* bodies become extern (resolved below).
            cflags = cflags + " -DHEXA_RT_SELFEMIT"
            let _ = exec("mkdir -p " + _shq(repo_root + "/build/selfemit"))
            // leaf basenames; each maps to emit_hxlcl_<n>_o.hexa, hxlcl_<n>.o,
            // and the env var HEXA_HXLCL_<UPPER>_O the driver reads.
            // B9.6-C1 appends `getpid` — the FIRST class-C (raw svc #0x80
            // syscall-ABI) primitive. It rides the SAME single-symbol emit
            // template as the reloc-free leaves (single _hxlcl_<n> export, no
            // reloc/struct-arg), differing only in that its body is a syscall
            // trap rather than a register/memory op. This opens the ~190-fn
            // layer-② hxlcl_* svc-wrapper subtrack (#1812 audit).
            //
            // B9.6-C2 appends `close` — the FIRST class-C with a syscall ARG
            // (fd) + the Darwin CARRY-FLAG error path + an errno store. Its .o
            // is NOT reloc-free: it carries 2 records (PAGE21/PAGEOFF12) against
            // an UNDEFINED-external `_hxlcl_errno`, which ld64 binds to runtime.c's
            // `hxlcl_errno` (non-static under the guard). At the recipe level it
            // is still a single emit driver writing one .o via one env var, so it
            // rides the SAME loop; only the .o internals differ. This is the
            // multi-arg + _cf (errno) template the remaining ~190 wrappers scale on.
            //
            // B9.6-B1 appends `atoi` — the FIRST class-B (calling-convention
            // composite). Unlike every prior leaf (single frame, no `bl`), its
            // body CALLS another runtime fn: frame + `bl _hxlcl_atoll` + epilogue.
            // Its .o carries 1 ARM64_RELOC_BRANCH26 reloc (offset 0x08) against an
            // UNDEFINED-external `_hxlcl_atoll`, which ld64 binds to runtime.c's
            // `hxlcl_atoll` (EXPORTED non-static under the guard via HXLCL_ATOLL_SC).
            // Link succeeds with LC_SYMTAB only — NO LC_DYSYMTAB (macho.hexa #1475
            // caveat RESOLVED). Still a single emit driver / one .o / one env var,
            // so it rides the SAME loop; only the .o internals differ (cross-object
            // call reloc). This opens the ~60-100-fn class-B call-bound subtrack.
            //
            // B9.6-E1 appends `munmap` — the FIRST class-E (GC/arena/malloc core)
            // primitive actually WIRED into the live runtime. class-E has NO classic
            // mark/sweep GC: reclamation is scope-pop + bulk arena-reset, and the
            // dealloc primitives (`hxlcl_free`/`hxlcl_munmap`) are no-op/constant-0
            // leaves over an mmap-backed bump allocator that never frees. munmap is
            // the unmap side — a 2-instr `mov w0,#0 / ret` success stub (the bump
            // allocator's "free" is a no-op). It rides the SAME single-symbol leaf
            // template (one export, no reloc). The ALLOC side (`hxlcl_malloc` =
            // state-reloc + `bl hxlcl_mmap` + header store; `hexa_arena_alloc` =
            // block-chain walk) is a class-A+B+C composite (not a single increment);
            // the bump allocator seed itself is the irreducible B9.8 floor. This is
            // the FIRST LIVE class-E wire — the rt_arena_* set (#1252/#1297/#1315)
            // emits an arena .o but the runtime never calls those symbols (shadow).
            //
            // B9.6-B2 appends `strdup` — the FIRST class-B HARD copy-loop primitive
            // ACTIVATED (38/640). Unlike B9.6-B1 atoi (5-instr tail-call wrapper),
            // strdup is a full composite: frame + scalar strlen loop + `bl _hxlcl_malloc`
            // + scalar copy loop + multi-BB shared epilogue (28 instr / 112 B, 1
            // ARM64_RELOC_BRANCH26 @0x30 against UNDEFINED-external `_hxlcl_malloc`).
            // ld64 binds the BRANCH26 to runtime.c's `hxlcl_malloc` (EXPORTED via
            // HXLCL_MALLOC_SC under the guard — same callee-export wrinkle as atoi's
            // HXLCL_ATOLL_SC). Behavioral-equivalence gate (NOT byte-id-vs-clang)
            // proven in PR #1911 (6/6 JIT-exec: empty / short / long / embedded
            // 0x01-0x03 / NULL passthrough / distinct-ptr exact-content). Rides the
            // SAME single-symbol emit loop; only the .o internals differ. Scales the
            // ~60-100 class-B HARD copy-loop family (strndup/atoll/atof template).
            // B9.6-C3 appends `getuid` — second 0-arg / cannot-fail svc-trap
            // (after getpid). EXACT rt_getpid byte shape with only the mov w16
            // immediate flipped (#20 → #24). No reloc, single-symbol export,
            // rides the SAME leaf template — driver = emit_hxlcl_getuid_o.hexa,
            // env var = HEXA_HXLCL_GETUID_O. Activates the LOOP slot for the
            // existing #1899 shadow (runtime_arm64::rt_getuid + runtime.c
            // L127-135 extern guard).
            // F3 class-B HARD scale-out — `strndup` joins the leaf loop alongside
            // strdup. Same single-symbol emit shape (1 defined + 1 undef + 1
            // BRANCH26), same _hxlcl_malloc callee-export wrinkle (reuses the
            // HXLCL_MALLOC_SC macro PR #1917 introduced). 2nd activated class-B
            // HARD primitive — proves the recipe scales mechanically.
            // B9.6-C10/C11/C14 append `fcntl` / `ioctl` / `select` — three
            // NON-_cf class-C svc primitives (no errno, no reloc). fcntl =
            // dual-sxtw + svc + ret (5-instr 20 B, SYS#92); ioctl = single-
            // sxtw + svc + ret (4-instr 16 B, SYS#54); select = sxtw + mov
            // x5,#0 + svc + ret (5-instr 20 B, SYS#93). Each rides the SAME
            // leaf template — driver = emit_hxlcl_<base>_o.hexa, env var =
            // HEXA_HXLCL_<UPPER>_O. Activates LOOP slots for the existing
            // #1899 shadows (runtime_arm64::rt_fcntl/rt_ioctl/rt_select +
            // runtime.c L170-176 / L184-192 extern guards).
            // B9.6-C4..C8 appends `dup2`/`mkdir`/`kill`/`fstat`/`stat` — 5 more
            // class-C svc-wrappers (errno-reloc + non-_cf, this PR's contribution).
            // dup2 = 2-arg int+int _cf (40 B, reloc 0x18/0x1c); mkdir = ptr+int _cf
            // (36 B, reloc 0x14/0x18); fstat = int+ptr _cf (36 B, reloc 0x14/0x18,
            // SYS#339 — first >255 SYS#); stat = ptr+ptr _cf (32 B, reloc 0x10/0x14
            // — no sxtw); kill = 2-arg int+int NON-_cf (20 B, no reloc — getuid
            // 2-arg analogue). The 4 _cf primitives use the v3 (undefined-external
            // errno) macho wrap; kill uses the single-symbol getuid wrap. Each
            // JIT-tested for happy + errno-fail. Activates LOOP slots for existing
            // B9.6-C4..C8 shadows (runtime_arm64::rt_{dup2,mkdir,kill,fstat,stat}
            // + runtime.c L142-204 extern guards).
            println("[selfemit] F3 Path A · B9.6-C3+C10+C11+C14 — class-C NON-_cf no-errno: getuid/fcntl/ioctl/select (+strndup B-HARD)")
            // ── B9.6-C9/C12/C13/C15/C16/C17 (io-family svc-wrapper batch) ──
            // The 6 io-family svc-wrappers — 5 errno-reloc primitives carrying
            // the rt_close PAGE21/PAGEOFF12 errno-store template (lseek/read/
            // write/waitpid/mmap), plus poll (3-arg NON-_cf, the FIRST uxtw
            // `mov w1,w1` for unsigned nfds — no errno path, no reloc, runtime.c
            // routes it through PLAIN `_hxlcl_syscall3`, not `_cf`). Each rides
            // the SAME single-symbol emit loop; only the .o internals differ
            // (SYS#, arg-widening count, presence/absence of cset/cbz tail).
            // Shadow emitters live in self/codegen/runtime_arm64.hexa
            // (rt_lseek/rt_read/rt_write/rt_poll/rt_waitpid/rt_mmap) and the
            // HEXA_RT_SELFEMIT extern guards in self/runtime.c are already
            // landed; this driver-set + loop registration closes the gap.
            println("[selfemit] F3 Path A · B9.6-C9 — class-C 3-arg _cf+errno: lseek (sxtw fd+whence + errno) → _hxlcl_lseek")
            println("[selfemit] F3 Path A · B9.6-C12 — class-C 3-arg _cf+errno: read (sxtw fd + errno) → _hxlcl_read")
            println("[selfemit] F3 Path A · B9.6-C13 — class-C 3-arg _cf+errno: write (sxtw fd + errno) → _hxlcl_write")
            println("[selfemit] F3 Path A · B9.6-C15 — class-C 3-arg NON-_cf: poll (uxtw nfds + sxtw timeout) → _hxlcl_poll")
            println("[selfemit] F3 Path A · B9.6-C16 — class-C 4-arg _cf+errno: waitpid (sxtw pid+opt + mov x3,#0 + errno) → _hxlcl_waitpid")
            println("[selfemit] F3 Path A · B9.6-C17 — class-C 6-arg _cf+errno: mmap (sxtw prot/flags/fd + errno) → _hxlcl_mmap")
            // B9.6-C4..C8 appends `dup2`/`mkdir`/`kill`/`fstat`/`stat` — 5 more
            // class-C svc-wrappers (errno-reloc + non-_cf, this PR's contribution).
            // dup2 = 2-arg int+int _cf (40 B, reloc 0x18/0x1c); mkdir = ptr+int _cf
            // (36 B, reloc 0x14/0x18); fstat = int+ptr _cf (36 B, reloc 0x14/0x18,
            // SYS#339 — first >255 SYS#); stat = ptr+ptr _cf (32 B, reloc 0x10/0x14
            // — no sxtw); kill = 2-arg int+int NON-_cf (20 B, no reloc — getuid
            // 2-arg analogue). The 4 _cf primitives use the v3 (undefined-external
            // errno) macho wrap; kill uses the single-symbol getuid wrap. Each
            // JIT-tested for happy + errno-fail.
            println("[selfemit] F3 Path A · B9.6-C4..C8 — 5 class-C svc-wrappers: dup2/mkdir/kill/fstat/stat (4 _cf errno-reloc + 1 NON-_cf no-reloc)")
            println("[selfemit] F3 Path A · class-B HARD libc-routed scale-out — free (1-instr ret noop, ZERO relocs) → _hxlcl_free")
            // F3 wave 2 — 4 class-C 0-arg cannot-fail svc-trap extensions of
            // getuid (geteuid/getegid/getgid/getppid). 16-byte body, no errno,
            // no reloc — getuid macho wrap; only SYS# byte + symbol name change.
            println("[selfemit] F3 Path A · wave 2 — 4 class-C 0-arg svc-traps: geteuid/getegid/getgid/getppid (getuid template extension)")
            let leaves = ["memset", "memcmp", "memcpy", "memmove", "strcmp", "strncmp", "strchr", "strrchr", "strcpy", "strncpy", "strcat", "strlen", "getpid", "close", "atoi", "munmap", "strdup", "getuid", "strndup", "fcntl", "ioctl", "select", "lseek", "read", "write", "poll", "waitpid", "mmap", "dup2", "mkdir", "kill", "fstat", "stat", "free", "geteuid", "getegid", "getgid", "getppid"]
            let upper  = ["MEMSET", "MEMCMP", "MEMCPY", "MEMMOVE", "STRCMP", "STRNCMP", "STRCHR", "STRRCHR", "STRCPY", "STRNCPY", "STRCAT", "STRLEN", "GETPID", "CLOSE", "ATOI", "MUNMAP", "STRDUP", "GETUID", "STRNDUP", "FCNTL", "IOCTL", "SELECT", "LSEEK", "READ", "WRITE", "POLL", "WAITPID", "MMAP", "DUP2", "MKDIR", "KILL", "FSTAT", "STAT", "FREE", "GETEUID", "GETEGID", "GETGID", "GETPPID"]
            let mut li = 0
            while li < len(leaves) {
                let n = leaves[li]
                let emit_hexa = repo_root + "/test/native_build/emit_hxlcl_" + n + "_o.hexa"
                _must_exist(emit_hexa, "emit_hxlcl_" + n + "_o.hexa (F3 Path A emit driver)")
                let emit_drv = repo_root + "/build/selfemit/emit_hxlcl_" + n
                let obj_path = repo_root + "/build/selfemit/hxlcl_" + n + ".o"
                let emit_c = repo_root + "/build/selfemit/emit_hxlcl_" + n + ".c"
                _run(_shq(hexat) + " " + _shq(emit_hexa) + " " + _shq(emit_c), "transpile emit driver " + n)
                _run(cc + " -O2 -std=c11 -D_GNU_SOURCE -Wno-trigraphs -fbracket-depth=4096 -I " + _shq(inc) + " " + _shq(emit_c) + " " + _shq(runtime_c) + " -o " + _shq(emit_drv) + " " + ldflags, "compile emit driver " + n)
                _run("HEXA_HXLCL_" + upper[li] + "_O=" + _shq(obj_path) + " " + _shq(emit_drv), "emit hxlcl_" + n + ".o")
                _must_exist(obj_path, "hxlcl_" + n + ".o (self-emit output)")
                selfemit_objs = selfemit_objs + " " + _shq(obj_path)
                li = li + 1
            }

            // ── B9.6 class-D — HexaVal struct-return ctor bundle (x0:x1 pair).
            //
            // The struct-return self-emit set (vs the single-x0 leaves above):
            // a MULTI-symbol .o exporting the runtime's universal HexaVal ctors —
            // _hexa_void / _hexa_int / _hexa_bool (#1858) + _hexa_float /
            // _hexa_enum_str / _hexa_enum_str_v (B9.6-D2 scale-out). Under
            // -DHEXA_RT_SELFEMIT runtime_core.c declares all six `extern` (no
            // body), and ld64 binds every HexaVal-producing callsite to the
            // self-emit .o. Verified byte-identical to `as -arch arm64` AND
            // JIT-exec-correct (returned {tag,value} reads back correct incl.
            // INT64_MIN/MAX, float NaN/Inf/±0/DBL_MAX/MIN, NULL/literal ptrs).
            // Single emitter, single multi-symbol .o, distinct env var.
            println("[selfemit] B9.6 class-D · HexaVal struct-return ctors → void/int/bool/float/enum_str/enum_str_v")
            let ctors_emit_hexa = repo_root + "/test/native_build/emit_hexa_val_ctors_o.hexa"
            _must_exist(ctors_emit_hexa, "emit_hexa_val_ctors_o.hexa (B9.6 class-D emit driver)")
            let ctors_emit_drv = repo_root + "/build/selfemit/emit_hexa_val_ctors"
            let ctors_obj_path = repo_root + "/build/selfemit/hexa_val_ctors.o"
            let ctors_emit_c = repo_root + "/build/selfemit/emit_hexa_val_ctors.c"
            _run(_shq(hexat) + " " + _shq(ctors_emit_hexa) + " " + _shq(ctors_emit_c), "transpile HexaVal ctor emit driver")
            _run(cc + " -O2 -std=c11 -D_GNU_SOURCE -Wno-trigraphs -fbracket-depth=4096 -I " + _shq(inc) + " " + _shq(ctors_emit_c) + " " + _shq(runtime_c) + " -o " + _shq(ctors_emit_drv) + " " + ldflags, "compile HexaVal ctor emit driver")
            _run("HEXA_VAL_CTORS_O=" + _shq(ctors_obj_path) + " " + _shq(ctors_emit_drv), "emit hexa_val_ctors.o")
            _must_exist(ctors_obj_path, "hexa_val_ctors.o (self-emit output)")
            selfemit_objs = selfemit_objs + " " + _shq(ctors_obj_path)

            // ── F3 ACTIVATION RUNBOOK · Path A · B9.6-D3 — class-D HexaVal-repr
            // body self-emit slot (4 primitives: rt_isalpha · rt_isalnum ·
            // rt_pthread_noop · rt_pthread_create_policy — PRs #1914 + #1923
            // shadows). Distinct from the class-B leaf loop (L705-L721):
            //   - emit driver path = test/native_build/emit_rt_<n>_classd_o.hexa
            //     (rt_ prefix, _classd suffix — NOT emit_hxlcl_<n>_o.hexa).
            //   - emitted symbol     = _rt_<n>            (NOT _hxlcl_<n>).
            //   - env var            = HEXA_RT_<UPPER>_CLASSD_O.
            //   - obj filename       = rt_<n>_classd.o.
            //   - runtime.c gate     = the `HexaVal rt_<n>(...)` body itself
            //     becomes `extern` (NOT a `hxlcl_<n>` helper) — see runtime.c
            //     L2029-block (rt_isalnum/_isalpha) + L2199-block (pthread).
            //     The HexaVal struct-return ABI (x0:x1 register PAIR, NRRP)
            //     means the extern decl matches the def byte-shape exactly.
            //   - callee-export      = NONE. `bl _hexa_bool` / `bl _hexa_int`
            //     bind into the ctor-bundle `.o` (hexa_val_ctors.o, see L735-
            //     L745) whose ctors are already non-static under HEXA_RT_SELFEMIT
            //     via the runtime_core_emit.hexa L1338-L1357 gate. No extra
            //     macro wrinkle (vs class-B's HXLCL_MALLOC_SC).
            // 4-gate verdict per primitive (see .verdicts/runtime-floor-closure/
            // F3-classd-activation-runbook.txt): (a) default 0-extern preserved,
            // (b) guard-on .o links + JIT-exec correct, (c) guard-on no-.o
            // link-fail, (d) self-host fixpoint structural (additive guards).
            // F3 class-D batch2 (this PR) appends 3 more leaf primitives:
            //   - rt_net_zero (hexa_int(0))   — net delegation stub
            //   - rt_posix_ok (hexa_int(0))   — POSIX delegation stub (cycle 6 ISO-1)
            //   - rt_net_fail (hexa_int(-1))  — net delegation stub (signed-negative
            //                                   payload, NEW MOVN axis on the template)
            // All 6 instr · 24 B · BRANCH26 @0x0C. Same _hexa_int callee, same
            // ctor-bundle bind path. Activation count 46/640 → 49/640.
            //
            // F3 class-D batch3 (NEW-AXES exploration · this branch) appends 3
            // more rt_fs_* primitives — the runtime.c L14129-block (gated 3-way
            // here):
            //   - rt_fs_stat            (hexa_void())   — 1-arg discard · NEW
            //                                              SHAPE (5 instr / 20 B /
            //                                              BRANCH26 @0x08 ·
            //                                              callee = _hexa_void
            //                                              NEW ctor dimension)
            //   - rt_fs_append_atomic   (hexa_int(-1))  — 2-arg discard · MOVN
            //                                              replicate of net_fail
            //   - rt_fs_rotate_if_over  (hexa_int(0))   — 3-arg discard · int(0)
            //                                              replicate of posix_ok
            // Activation count 49/640 → 52/640 (this PR), 55→58 with concurrent
            // batches.
            println("[selfemit] F3 Path A · B9.6-D3 — class-D HexaVal-repr bodies → 10 primitives (isalpha · isalnum · 2× pthread · net_zero · posix_ok · net_fail · fs_stat · fs_append_atomic · fs_rotate_if_over)")
            let classd = ["isalpha", "isalnum", "pthread_noop", "pthread_create_policy", "net_zero", "posix_ok", "net_fail", "fs_stat", "fs_append_atomic", "fs_rotate_if_over"]
            let classd_upper = ["ISALPHA", "ISALNUM", "PTHREAD_NOOP", "PTHREAD_CREATE_POLICY", "NET_ZERO", "POSIX_OK", "NET_FAIL", "FS_STAT", "FS_APPEND_ATOMIC", "FS_ROTATE_IF_OVER"]
            let mut ci = 0
            while ci < len(classd) {
                let cn = classd[ci]
                let cd_emit_hexa = repo_root + "/test/native_build/emit_rt_" + cn + "_classd_o.hexa"
                _must_exist(cd_emit_hexa, "emit_rt_" + cn + "_classd_o.hexa (F3 class-D emit driver)")
                let cd_emit_drv = repo_root + "/build/selfemit/emit_rt_" + cn + "_classd"
                let cd_obj_path = repo_root + "/build/selfemit/rt_" + cn + "_classd.o"
                let cd_emit_c = repo_root + "/build/selfemit/emit_rt_" + cn + "_classd.c"
                _run(_shq(hexat) + " " + _shq(cd_emit_hexa) + " " + _shq(cd_emit_c), "transpile class-D emit driver " + cn)
                _run(cc + " -O2 -std=c11 -D_GNU_SOURCE -Wno-trigraphs -fbracket-depth=4096 -I " + _shq(inc) + " " + _shq(cd_emit_c) + " " + _shq(runtime_c) + " -o " + _shq(cd_emit_drv) + " " + ldflags, "compile class-D emit driver " + cn)
                _run("HEXA_RT_" + classd_upper[ci] + "_CLASSD_O=" + _shq(cd_obj_path) + " " + _shq(cd_emit_drv), "emit rt_" + cn + "_classd.o")
                _must_exist(cd_obj_path, "rt_" + cn + "_classd.o (self-emit output)")
                selfemit_objs = selfemit_objs + " " + _shq(cd_obj_path)
                ci = ci + 1
            }
        }
    }

    // ── Step 1+2+3: chicken-egg flatten chain (bootstrap.yml parity).
    //
    // self/main.hexa `use`s 7 compiler frontend modules (lex/parse/lower/...);
    // hexat is a single-file transpiler with no `use` resolution. Therefore
    // transpiling main.hexa directly emits extern stubs that fail to link
    // (undefined references to lex / parse / lower / lower_hir / static_atlas /
    // codegen_emit_ptx_for_sm). The fix mirrors bootstrap.yml:
    //
    //   (1) hexat module_loader.hexa → module_loader.c        (zero `use`)
    //   (2) cc module_loader.c → build/hexa_module_loader        (binary)
    //   (3) hexa_module_loader main.hexa → main_expanded.hexa    (flatten)
    //   (4) hexat main_expanded.hexa → main_native.c           (transpile)
    //   (5) cc main_native.c → build/hexa_cli_driver             (binary)
    //
    // Mac arm64 only "worked" before this fix because a previously-built
    // build/stage1/main_native.c (flattened source from an earlier session)
    // remained on disk and SKIP_TRANSPILE-style stale-reuse masked the bug.
    // On a fresh Linux x86_64 clone there is no such cache, and the
    // single-step transpile path surfaces the chicken-egg immediately.
    if env_var("SKIP_TRANSPILE") == "" {
        println("[1/5] transpile module_loader.hexa → " + ml_c)
        _run(_shq(hexat) + " " + _shq(ml_hexa) + " " + _shq(ml_c), "transpile module_loader.hexa")

        println("[2/5] compile hexa_module_loader (stage-1 flattener)")
        // selfemit_objs is a space-prefixed list of quoted .o paths (empty
        // when HEXA_RT_SELFEMIT is unset → default link, 0-extra-objects).
        _run(cc + " " + cflags + " " + _shq(ml_c) + " " + _shq(runtime_c) + selfemit_objs + " -o " + _shq(ml_out) + " " + ldflags, "compile module_loader")

        println("[3/5] flatten main.hexa            → " + main_expanded)
        _run(_shq(ml_out) + " " + _shq(main_hexa) + " " + _shq(main_expanded), "flatten main.hexa")

        println("[3/5] transpile main_expanded.hexa → " + main_c)
        _run(_shq(hexat) + " " + _shq(main_expanded) + " " + _shq(main_c), "transpile main_expanded.hexa")
    }
    _must_exist(main_c, "transpiled C")
    _must_exist(ml_c,   "transpiled C")
    _must_exist(ml_out, "compiled module_loader")

    // ── Step 4: compile driver (runtime.c appended as 2nd TU)
    println("[4/5] compile hexa_cli_driver")
    _run(cc + " " + cflags + " " + _shq(main_c) + " " + _shq(runtime_c) + selfemit_objs + " -o " + _shq(driver_out) + " " + ldflags, "compile driver")

    // ── Step 4b: Darwin codesign
    if uname == "Darwin" {
        println("[4/5] codesign (Darwin)")
        let _x1 = exec("codesign --force --sign - " + _shq(driver_out) + " 2>/dev/null || true")
        let _x2 = exec("codesign --force --sign - " + _shq(ml_out)     + " 2>/dev/null || true")
    }

    // ── Step 4b: shadow install-layout in build/
    let _ = exec("mkdir -p " + _shq(repo_root + "/build/self/native") + " " + _shq(repo_root + "/build/self/forge"))
    let _ = exec("cp -f " + _shq(hexat)                                 + " " + _shq(repo_root + "/build/self/native/hexat"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/native/hexa_cc.c")    + " " + _shq(repo_root + "/build/self/native/hexa_cc.c"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/runtime.h")           + " " + _shq(repo_root + "/build/self/runtime.h"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/runtime.c")           + " " + _shq(repo_root + "/build/self/runtime.c"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/runtime_core.c")      + " " + _shq(repo_root + "/build/self/runtime_core.c"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/runtime_hi_gen.c")    + " " + _shq(repo_root + "/build/self/runtime_hi_gen.c"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/forge/forge_tier_v1.c") + " " + _shq(repo_root + "/build/self/forge/forge_tier_v1.c"))
    let _ = exec("cp -f " + _shq(repo_root + "/self/forge/forge_tier_v1.h") + " " + _shq(repo_root + "/build/self/forge/forge_tier_v1.h"))

    // native/*.c bodies — skip giant generated TUs not included by runtime.c
    let nat_dir = repo_root + "/self/native"
    let raw_c = to_string(exec("ls -1 " + _shq(nat_dir) + "/*.c 2>/dev/null")).trim()
    if raw_c != "" {
        let lines = raw_c.split("\n")
        let mut i = 0
        while i < len(lines) {
            let p = lines[i]
            let base = to_string(exec("basename " + _shq(p))).trim()
            if base != "hexa_cc.c" {
                let _ = exec("cp -f " + _shq(p) + " " + _shq(repo_root + "/build/self/native/" + base))
            }
            i = i + 1
        }
    }
    // native/*.h headers — all of them
    let raw_h = to_string(exec("ls -1 " + _shq(nat_dir) + "/*.h 2>/dev/null")).trim()
    if raw_h != "" {
        let lines = raw_h.split("\n")
        let mut i = 0
        while i < len(lines) {
            let p = lines[i]
            let base = to_string(exec("basename " + _shq(p))).trim()
            let _ = exec("cp -f " + _shq(p) + " " + _shq(repo_root + "/build/self/native/" + base))
            i = i + 1
        }
    }

    // ── Step 5: smoke
    if env_var("NO_SMOKE") == "" {
        println("[5/5] smoke")
        let tmp_base = to_string(exec("mktemp /tmp/hexa_cli_smoke.XXXXXX")).trim()
        let smoke_src = tmp_base + ".hexa"
        let smoke_bin = tmp_base + ".bin"
        write_file(smoke_src, "fn main() {\n    println(\"hexa-cli-smoke-ok\")\n}\n")

        let r1 = exec_with_status(_shq(driver_out) + " --version >/dev/null")
        if r1[1] != 0 { eprintln("  FAIL --version") exit(1) }
        println("  OK   --version")

        let r2 = exec_with_status(_shq(driver_out) + " parse " + _shq(smoke_src) + " >/dev/null")
        if r2[1] != 0 { eprintln("  FAIL parse") exit(1) }
        println("  OK   parse")

        let build_cmd = "HEXA_LANG=" + _shq(repo_root) + " HEXA_MAC_BUILD_OK=1 " +
                        _shq(driver_out) + " build " + _shq(smoke_src) +
                        " -o " + _shq(smoke_bin) + " >/dev/null"
        let r3 = exec_with_status(build_cmd)
        if r3[1] != 0 { eprintln("  FAIL build") exit(1) }
        let r4 = exec_with_status(_shq(smoke_bin) + " 2>&1")
        let got = to_string(r4[0]).trim()
        if got != "hexa-cli-smoke-ok" {
            eprintln("  FAIL build-run: got '" + got + "'")
            exit(1)
        }
        println("  OK   build (round-trip)")

        let _ = exec("rm -f " + _shq(tmp_base) + " " + _shq(smoke_src) + " " + _shq(smoke_bin))
    }

    println("")
    println("=== BUILD OK ===")
    let drv_sz = to_string(exec("wc -c < " + _shq(driver_out) + " | tr -d ' '")).trim()
    let ml_sz  = to_string(exec("wc -c < " + _shq(ml_out)     + " | tr -d ' '")).trim()
    println("  driver        : " + driver_out + " (" + drv_sz + " bytes)")
    println("  module_loader : " + ml_out     + " (" + ml_sz  + " bytes)")
}

fn main() {
    let repo_root = _repo_root()
    if _refuse_local_on_mac() {
        _print_refuse_hint(repo_root)
        exit(2)
    }
    _do_build(repo_root)
    // CANON M8 — opt-in deploy. Only when --install is passed; the build
    // alone (CI, fresh clone) never touches the shim targets.
    if _want_install() {
        _install_driver(repo_root, _uname())
    }
}
