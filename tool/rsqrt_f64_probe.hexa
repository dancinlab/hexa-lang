// tool/rsqrt_f64_probe.hexa — F-RSQRTF64-NUMERIC kernel
//
// PR #1335 (RFC 055 §13 f64 rsqrt = sqrt.rn.f64 + rcp.rn.f64) terminal
// numeric falsifier on ubu-2 RTX 5070 driver-JIT. Computes
// c[i] = rsqrt(a[i]) over a strictly positive f64 input range; the host
// harness compares against CPU libm 1.0/sqrt(x) with target
// max_rel_err < 1e-14 (round-to-nearest composition tightness).
//
// Input shape (host-side): N = 256, blockDim = 256, gridDim = 1.
// a[i] = (i + 1) * 0.1   (range [0.1, 25.6] — strictly positive,
//   covers small / large / typical magnitudes; rsqrt(0.1) ≈ 3.162,
//   rsqrt(25.6) ≈ 0.1976).

@gpu_kernel
fn rsqrt_f64_probe(a: [f64], c: [f64], n: i64) {
    let mut tid: i64 = to_i64(gpu_thread_id_x())
    if tid < n {
        c[to_i64(tid)] = rsqrt(a[to_i64(tid)])
    }
}
