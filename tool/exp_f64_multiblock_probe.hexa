// tool/exp_f64_multiblock_probe.hexa — F-EXPF64-MULTIBLOCK-NUMERIC kernel
//
// Validates PR #1341 (gpu_global_thread_id_x intrinsic) + PR #1333
// (f64 exp polynomial) together: a multi-block kernel using the
// canonical global-thread-index composition. Re-fires the exp f64
// numeric test but over a wider input range (N>blockDim) — the prior
// fire #1336 was single-block-constrained because gpu_thread_id_x
// is block-local.
//
// Host shape: N = 1024, blockDim = 256, gridDim = 4 (4 blocks).
// a[i] = (i / N) * 10.0 - 5.0 → range [-5, +5] over 1024 points.

@gpu_kernel
fn exp_f64_multiblock_probe(a: [f64], c: [f64], n: i64) {
    let mut gid: i64 = to_i64(gpu_global_thread_id_x())
    if gid < n {
        c[to_i64(gid)] = exp(a[to_i64(gid)])
    }
}
