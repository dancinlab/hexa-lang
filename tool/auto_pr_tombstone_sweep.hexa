// HEXA tool — auto-PR for tombstone sweep (RFC-017 5e: invalidation)
//
// @version 0.1.0
// @capabilities [pure, fs_read, fs_write, exec]
//
// When retroactive_sweep + cascade_tombstones together newly tombstone one
// or more L nodes, this helper opens a GitHub PR summarizing what changed
// so a human can review the prover-version transition.
//
// PUBLIC SURFACE
//   pub struct SweepSummary { ... }
//   pub fn auto_pr_tombstone_sweep(summary: SweepSummary) -> i64
//
// CI INFRA RESILIENCE
//   This tool ALWAYS returns 0. Failure to open a PR (gh missing, no auth,
//   network blip, branch-already-exists) must NOT poison the sweep. On any
//   failure path we write the rendered PR body to
//   /tmp/_tombstone_sweep_pr_body.{date}.txt and print the suggested
//   `gh pr create ...` command so an operator can complete the action by
//   hand.
//
// Catalog/diagnostic strings: ENGLISH ONLY (RFC-019 §6 + repo policy).

// -- Summary record ------------------------------------------------

pub struct TombstoneDisposition {
    node_id: string,
    reason: string,
    replacement_hint: string,
    kind: string             // "manual" | "sweep" | "cascade"
}

pub struct SweepSummary {
    prover_from: string,
    prover_to: string,
    atlas_root: string,
    seen: i64,
    passed: i64,
    skipped: i64,
    tombstoned_manual: i64,
    tombstoned_cascade: i64,
    dispositions: array,     // [TombstoneDisposition]
    manifest_path: string
}

pub fn empty_sweep_summary() -> SweepSummary {
    return SweepSummary {
        prover_from: "",
        prover_to: "",
        atlas_root: "",
        seen: 0,
        passed: 0,
        skipped: 0,
        tombstoned_manual: 0,
        tombstoned_cascade: 0,
        dispositions: [],
        manifest_path: ""
    }
}

pub fn make_disposition(node_id: string, reason: string,
                        replacement_hint: string, kind: string) -> TombstoneDisposition {
    return TombstoneDisposition {
        node_id: node_id,
        reason: reason,
        replacement_hint: replacement_hint,
        kind: kind
    }
}

// -- Helpers --------------------------------------------------------

fn _today_utc_p() -> string {
    let s = exec("date -u +%Y-%m-%d").trim()
    if len(s) == 0 { return "unknown-date" }
    return s
}

fn _stamp_utc_p() -> string {
    let s = exec("date -u +%Y%m%d_%H%M%S").trim()
    if len(s) == 0 { return "unknown-stamp" }
    return s
}

fn _gh_available() -> bool {
    let out = exec("command -v gh 2>/dev/null").trim()
    return len(out) > 0
}

fn _body_fallback_path(today: string) -> string {
    return "/tmp/_tombstone_sweep_pr_body." + today + ".txt"
}

// Hard kill-switch for smoke tests / dry-runs. Setting
// HEXA_AUTO_PR_DRY_RUN=1 in the environment writes the PR body file
// but skips git checkout and gh pr create. The function still
// returns 0 (CI infra resilience).
fn _dry_run_requested() -> bool {
    let v = to_string(env_var("HEXA_AUTO_PR_DRY_RUN"))
    if v == "1" { return true }
    if v == "true" { return true }
    if v == "yes" { return true }
    return false
}

// -- PR body renderer ----------------------------------------------

fn _render_pr_body(summary: SweepSummary) -> string {
    let parts = []
    parts.push("## Atlas tombstone sweep — prover ")
    parts.push(summary.prover_from)
    parts.push(" -> ")
    parts.push(summary.prover_to)
    parts.push("\n\n")
    parts.push("Auto-generated by tool/auto_pr_tombstone_sweep.hexa under\n")
    parts.push("RFC-017 Decision 5e (atlas_self_discovery.invalidation).\n\n")

    parts.push("### Counts\n\n")
    parts.push("| metric | value |\n")
    parts.push("| --- | --- |\n")
    parts.push("| atlas_root | `")
    parts.push(summary.atlas_root)
    parts.push("` |\n")
    parts.push("| L nodes seen | ")
    parts.push(to_string(summary.seen))
    parts.push(" |\n")
    parts.push("| L nodes passed | ")
    parts.push(to_string(summary.passed))
    parts.push(" |\n")
    parts.push("| L nodes skipped | ")
    parts.push(to_string(summary.skipped))
    parts.push(" |\n")
    parts.push("| L nodes tombstoned (manual + sweep) | ")
    parts.push(to_string(summary.tombstoned_manual))
    parts.push(" |\n")
    parts.push("| L nodes tombstoned (cascade) | ")
    parts.push(to_string(summary.tombstoned_cascade))
    parts.push(" |\n")
    let total = summary.tombstoned_manual + summary.tombstoned_cascade
    parts.push("| **total tombstoned** | **")
    parts.push(to_string(total))
    parts.push("** |\n\n")

    parts.push("### Per-tombstone disposition\n\n")
    if len(summary.dispositions) == 0 {
        parts.push("_(no individual dispositions recorded; see manifest.)_\n\n")
    } else {
        parts.push("| id | kind | reason | replacement hint |\n")
        parts.push("| --- | --- | --- | --- |\n")
        let mut i = 0
        while i < len(summary.dispositions) {
            let d = summary.dispositions[i]
            parts.push("| `L[")
            parts.push(d.node_id)
            parts.push("]` | ")
            parts.push(d.kind)
            parts.push(" | ")
            parts.push(d.reason)
            parts.push(" | ")
            if len(d.replacement_hint) > 0 {
                parts.push("`L[")
                parts.push(d.replacement_hint)
                parts.push("]`")
            } else {
                parts.push("_(none)_")
            }
            parts.push(" |\n")
            i = i + 1
        }
        parts.push("\n")
    }

    parts.push("### Manifest\n\n")
    parts.push("Full sweep + cascade manifest: `")
    parts.push(summary.manifest_path)
    parts.push("`\n\n")
    parts.push("### Review checklist\n\n")
    parts.push("- [ ] confirm prover version transition matches release notes\n")
    parts.push("- [ ] inspect each tombstoned L node: counter-example documented?\n")
    parts.push("- [ ] cite replacement L (where applicable) in dependent proofs\n")
    parts.push("- [ ] verify no live (`~/core/nexus/n6/`) atlas was modified by this run\n")
    return parts.join("")
}

// -- Branch + title helpers ----------------------------------------

fn _branch_name(stamp: string) -> string {
    return "auto/tombstone-sweep-" + stamp
}

fn _pr_title(summary: SweepSummary) -> string {
    let total = summary.tombstoned_manual + summary.tombstoned_cascade
    return "atlas: tombstone sweep " + summary.prover_from + " -> " +
           summary.prover_to + " (" + to_string(total) + " L tombstoned)"
}

fn _suggest_command(branch: string, title: string, body_path: string) -> string {
    return "gh pr create --base main --head " + branch +
           " --title \"" + title + "\"" +
           " --body-file " + body_path
}

// -- Public entrypoint ---------------------------------------------
//
// auto_pr_tombstone_sweep — open a PR (or fall back to writing the body to
// /tmp). Returns 0 ALWAYS. Failure modes are diagnostic only.

pub fn auto_pr_dry_run(summary: SweepSummary) -> i64 {
    let total_d = summary.tombstoned_manual + summary.tombstoned_cascade
    if total_d <= 0 { return 0 }
    let body_d = _render_pr_body(summary)
    let body_path_d = _body_fallback_path(_today_utc_p())
    write_file(body_path_d, body_d)
    println("auto_pr_dry_run: PR body written to " + body_path_d)
    return 0
}

pub fn auto_pr_tombstone_sweep(summary: SweepSummary) -> i64 {
    let total = summary.tombstoned_manual + summary.tombstoned_cascade
    if total <= 0 {
        println("auto_pr_tombstone_sweep: total=0 — nothing to PR; skip.")
        return 0
    }

    let today = _today_utc_p()
    let stamp = _stamp_utc_p()
    let body = _render_pr_body(summary)
    let body_path = _body_fallback_path(today)
    write_file(body_path, body)
    println("auto_pr_tombstone_sweep: PR body written to " + body_path)

    let branch = _branch_name(stamp)
    let title = _pr_title(summary)
    let suggested = _suggest_command(branch, title, body_path)

    if _dry_run_requested() {
        println("auto_pr_tombstone_sweep: HEXA_AUTO_PR_DRY_RUN set; PR body written, gh skipped.")
        println("auto_pr_tombstone_sweep: suggested command:")
        println("  " + suggested)
        return 0
    }

    if !_gh_available() {
        println("auto_pr_tombstone_sweep: `gh` not on PATH; skipping PR open.")
        println("auto_pr_tombstone_sweep: suggested command:")
        println("  " + suggested)
        return 0
    }

    // gh present — best-effort: create the branch + open PR. Each step is
    // wrapped to ensure failure does not return non-zero.
    let mk = exec("git checkout -b " + branch + " 2>&1")
    println("auto_pr_tombstone_sweep: git checkout -b -> " + to_string(mk).trim())

    let cmd = "gh pr create --base main --head " + branch +
              " --title \"" + title + "\"" +
              " --body-file " + body_path + " 2>&1"
    let out = to_string(exec(cmd)).trim()
    if len(out) == 0 {
        println("auto_pr_tombstone_sweep: gh produced no output (treating as failure).")
        println("auto_pr_tombstone_sweep: suggested command for manual retry:")
        println("  " + suggested)
        return 0
    }
    println("auto_pr_tombstone_sweep: gh output:")
    println(out)
    return 0
}
