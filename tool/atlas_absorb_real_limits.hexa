    ["boltzmann_constant",         "Boltzmann constant",         "k = 1.381e-23 J/K",                 "CODATA 2018 (exact, since 2019 SI redefinition)",                             "thermal-noise / Landauer erasure floor (kT*ln2 per bit)",                           "Physical",     71],
    ["stefan_boltzmann",           "Stefan-Boltzmann",           "P = sigma*epsilon*A*T^4",           "Stefan 1879; Boltzmann 1884",                                                 "radiative heat-rejection ceiling — sets terafab-orbital radiator area ~1,300 km^2", "Physical",     72],
    ["carnot_efficiency",          "Carnot efficiency",          "eta <= 1 - T_c/T_h",                "Carnot 1824 — Reflections on the Motive Power of Fire",                       "heat-engine efficiency upper bound; reversible Carnot cycle",                       "Physical",     73],
