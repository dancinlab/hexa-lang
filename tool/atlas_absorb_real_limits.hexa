// tool/atlas_absorb_real_limits.hexa — Wave 1.2 of hexa-bio absorption (2026-05-14)
//
// @version 0.1.0
// @capabilities [fs_read, fs_write]
//
// Read-only on ~/core/hexa-bio/. Emits:
//   compiler/atlas/real_limits.gen.hexa  (21 real-limit @C nodes:
//                                          6 Mathematical + 8 Physical + 7 Engineering)
//
// Source SSOT (Apache-2.0, dancinlab Wave K 2026-05-12, hexa-bio v1.1.0):
//   ~/core/hexa-bio/LATTICE_POLICY.md  §1.2  (lines 58..88)
//
// Run:
//   hexa run tool/atlas_absorb_real_limits.hexa
//
// Reproducibility: re-running this tool should regenerate the
// .gen.hexa file byte-identically. The tool ALSO performs a drift
// check against the source markdown: each declared row's `name`
// substring must still appear on the recorded `source_line`. If a
// row drifted, the tool prints `DRIFT` for that row but still emits
// (manual reconciliation step).

// ── string escaping (mirrors compiler/atlas/embed.hexa::_escape_string) ──

fn _escape_char(c: string) -> string {
    if c == "\\" { return "\\\\" }
    if c == "\"" { return "\\\"" }
    if c == "\n" { return "\\n" }
    if c == "\r" { return "\\r" }
    if c == "\t" { return "\\t" }
    return c
}

fn _escape_string(s: string) -> string {
    let n = len(s)
    let chunks = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        chunks.push(_escape_char(c))
        i = i + 1
    }
    return chunks.join("")
}

// All 21 §1.2 rows are real-limit ground truth (g1 real-limits-first).
// raw body already tags each row [11*] (verified-ceiling); the structured
// GradeInfo now matches, so consumers filtering `grade.verified == true`
// see the same set as text-pattern scans for [11*].
let _VERIFIED_GRADE = "GradeInfo { value: 11, verified: true, breakthrough: false, hypothesis: false }"
let _ZERO_EDGES = "EdgeInfo { depends_on: [], derives: [], applications: [], equivalents: [], converges: [], verified_by: [], breakthroughs: [] }"

fn _emit_node(kind: string, id: string, raw: string, source_file: string, source_line) -> string {
    let parts = []
    parts.push("    AtlasNode { kind: \"")
    parts.push(_escape_string(kind))
    parts.push("\", id: \"")
    parts.push(_escape_string(id))
    parts.push("\", raw: \"")
    parts.push(_escape_string(raw))
    parts.push("\", source_file: \"")
    parts.push(_escape_string(source_file))
    parts.push("\", source_line: ")
    parts.push(to_string(source_line))
    parts.push(", grade: ")
    parts.push(_VERIFIED_GRADE)
    parts.push(", edges: ")
    parts.push(_ZERO_EDGES)
    parts.push(" }")
    return parts.join("")
}

// ── canonical row table ────────────────────────────────────────────────
//
// Per absorption-plan §A: source markdown table has 21 rows across 3
// categories. We declare them here once with the snake-name, the §1.2
// header `name` (used for drift check), the formula/source/comment
// triple, category tag, and source_line. Run the generator, the
// rodata gets emitted byte-identically.
//
// Each row: [snake_id, header_name, formula_or_source, citation, comment, category, source_line]

