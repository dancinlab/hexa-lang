    ["kolmogorov_complexity",      "Kolmogorov complexity",      "K(x) lower bound",                  "Kolmogorov 1965 — Three Approaches to the Quantitative Definition of Information", "algorithmic compression / learning lower bound",                                  "Mathematical", 59],
    ["computability",              "Computability",              "Halting / Rice",                    "Turing 1936 — On Computable Numbers; Rice 1953",                              "automation ceiling — undecidability of nontrivial semantic predicates",             "Mathematical", 60],
    ["bekenstein_bound",           "Bekenstein bound",           "S <= 2*pi*k*R*E/(hbar*c)",          "Bekenstein 1981 — Universal upper bound on the entropy-to-energy ratio",      "information density ceiling for any bounded region",                                "Mathematical", 61],
    ["statistical_power",          "Statistical power",          "beta = f(alpha, n, effect_size)",   "Cohen 1988 — Statistical Power Analysis for the Behavioral Sciences",         "hypothesis-test power floor — sample size vs. effect-size tradeoff",                "Mathematical", 62],
    ["pac_learning_bound",         "PAC-learning bound",         "sample_complexity ~ VC/epsilon^2",  "Valiant 1984 — A Theory of the Learnable; Vapnik-Chervonenkis 1971",          "ML generalization sample-complexity lower bound via VC dimension",                  "Mathematical", 63],

