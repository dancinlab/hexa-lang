fn _row_raw(row) -> string {
    let snake = to_string(row[0])
    let formula = to_string(row[2])
    let citation = to_string(row[3])
    let comment = to_string(row[4])
    let category = to_string(row[5])
    let cat_lc =
        if category == "Mathematical" { "mathematical" }
        else if category == "Physical" { "physical" }
        else { "engineering" }
    let parts = []
    parts.push("@C real_limits.")
    parts.push(snake)
    parts.push(" = ")
    parts.push(formula)
    parts.push(" :: real_limits.")
    parts.push(cat_lc)
    parts.push(" [11*]\n")
    parts.push("  category: ")
    parts.push(category)
    parts.push("\n  citation: ")
    parts.push(citation)
    parts.push("\n  comment: ")
    parts.push(comment)
    return parts.join("")
}

fn _emit_real_limits() -> string {
    let parts = []
    parts.push("@phase(\"parse_only\")\n")
    parts.push("pub let REAL_LIMITS: [AtlasNode] = [\n")
    let n = len(_ROWS)
    let mut i = 0
    while i < n {
        let row = _ROWS[i]
        let snake = to_string(row[0])
        let source_line = row[6]
        let raw = _row_raw(row)
        parts.push(_emit_node("C", "real_limits." + snake, raw, "LATTICE_POLICY.md", source_line))
        if i + 1 < n { parts.push(",") }
        parts.push("\n")
        i = i + 1
    }
    parts.push("]\n\n")
    return parts.join("")
}

fn _emit_file() -> string {
    let parts = []
    parts.push("// absorbed from ~/core/hexa-bio/LATTICE_POLICY.md §1.2 (Apache-2.0, hexa-bio v1.1.0, dancinlab 2026-05-14)\n")
    parts.push("// SSOT snapshot — regenerate via tool/atlas_absorb_real_limits.hexa\n")
    parts.push("//\n")
    parts.push("// REAL_LIMITS — 21 real-limit rows from LATTICE_POLICY.md §1.2:\n")
    parts.push("//   6  Mathematical (analytic)         lines 58..63\n")
    parts.push("//   8  Physical     (constants+laws)   lines 69..76\n")
    parts.push("//   7  Engineering  (industry/regulatory) lines 82..88\n")
    parts.push("//\n")
    parts.push("// Each row is an @C AtlasNode whose `raw` carries the canonical\n")
    parts.push("// formula/citation/comment triple. Category is encoded both in the\n")
    parts.push("// `raw` body (`category: Mathematical|Physical|Engineering`) and in\n")
    parts.push("// the id prefix (`real_limits.<snake_name>`).\n")
    parts.push("//\n")
    parts.push("// Deployment trail: LATTICE_POLICY was distributed dancinlab-wide on\n")
    parts.push("// Wave K (2026-05-12); this file makes the §1.2 table addressable\n")
    parts.push("// as rodata for any hexa-lang component that needs to anchor a\n")
    parts.push("// verifier against real limits (vs. lattice tautologies).\n")
    parts.push("\n")
    parts.push("use \"compiler/atlas/parser\"\n")
    parts.push("\n")
    parts.push(_emit_real_limits())
    parts.push("// public count accessors — let smoke tests assert without\n")
    parts.push("// walking the parse_only-decorated array.\n")
    parts.push("pub fn real_limits_count() -> i64 { return len(REAL_LIMITS) }\n")
    parts.push("\n")
    parts.push("pub fn real_limits() -> [AtlasNode] { return REAL_LIMITS }\n")
    parts.push("\n")
    parts.push("// Filter by category. `cat` matches the `category: ` field embedded in\n")
    parts.push("// each node's `raw` body. Returns Mathematical (6) / Physical (8) /\n")
    parts.push("// Engineering (7) subsets.\n")
    parts.push("pub fn real_limits_by_category(cat: string) -> [AtlasNode] {\n")
    parts.push("    let needle = \"category: \" + cat\n")
    parts.push("    let out = []\n")
    parts.push("    let n = len(REAL_LIMITS)\n")
    parts.push("    let mut i = 0\n")
    parts.push("    while i < n {\n")
    parts.push("        let node = REAL_LIMITS[i]\n")
    parts.push("        if node.raw.contains(needle) {\n")
    parts.push("            out.push(node)\n")
    parts.push("        }\n")
    parts.push("        i = i + 1\n")
    parts.push("    }\n")
    parts.push("    return out\n")
    parts.push("}\n")
    return parts.join("")
}

// ── drift check (read-only against the source markdown) ────────────────
//
// For each row, the recorded source_line in LATTICE_POLICY.md must
// still contain the row's header_name as a substring. This catches
// upstream §1.2 edits without modifying anything in hexa-bio.

fn _check_drift(src_path: string) -> i64 {
    let text = read_file(src_path)
    if len(text) == 0 {
        println("  warn: source not readable at " + src_path + " — skipping drift check")
        return 0
    }
    let lines = text.split("\n")
    let n_lines = len(lines)
    let n_rows = len(_ROWS)
    let mut drift = 0
    let mut i = 0
    while i < n_rows {
        let row = _ROWS[i]
        let name = to_string(row[1])
        let line_no = row[6]
        if line_no < 1 || line_no > n_lines {
            println("  DRIFT  " + name + " — source_line " + to_string(line_no) + " out of range")
            drift = drift + 1
        } else {
            let line = to_string(lines[line_no - 1])
            if !line.contains(name) {
                println("  DRIFT  " + name + " — line " + to_string(line_no) + " does not contain header name")
                drift = drift + 1
            }
        }
        i = i + 1
    }
    return drift
}

// ── driver ─────────────────────────────────────────────────────────────

fn main() {
    let home = env("HOME")
    let src = home + "/core/hexa-bio/LATTICE_POLICY.md"

    println("real-limits absorption — wave 1.2")
    println("  source: " + src)
    println("  rows:   " + to_string(len(_ROWS)) + " (expected 21: 6 + 8 + 7)")

    let drift = _check_drift(src)
    if drift == 0 {
        println("  drift:  OK — all rows match source line headers")
    } else {
        println("  drift:  " + to_string(drift) + " row(s) drifted (see above) — emitting anyway")
    }

    let out = "compiler/atlas/real_limits.gen.hexa"
    let body = _emit_file()
    write_file(out, body)
    println("  wrote:  " + out + " (" + to_string(len(body)) + " bytes)")

    println("done.")
}
