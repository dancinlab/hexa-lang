    ["starship_reusable_cost",     "Starship reusable cost",     "$X/kg (measured)",                  "SpaceX public Starship cost disclosures; FAA launch filings",                 "orbital-deploy economic ceiling — $ per kg to LEO at scale",                        "Engineering",  84],
