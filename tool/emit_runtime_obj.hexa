// tool/emit_runtime_obj.hexa — HEXA-CC-NATIVE N3a
//
// Emit a single hexa-native Mach-O relocatable object (`MH_OBJECT`,
// arm64) that EXPORTS the minimal runtime symbols a natively-compiled
// program references but does not define itself:
//
//   _hexa_exit       — HexaVal-ABI adapter (mov x0,x1) + rt_exit svc #0x80
//   _hexa_set_args    — no-op `ret` stub (sufficient for the exit-only
//                       corpus; full argv-capture body is a later increment)
//
// WHY (RFC 063 § P1 / HEXA-CC-NATIVE N3a): the native obj-emit path
// (`aprime_cc --emit=obj --backend=native`) already produces a Mach-O .o
// with ZERO external forks (N0/P3-ZERO-EXTERN), whose ONLY undefined
// symbols are `_hexa_exit` + `_hexa_set_args` (measured: N3-smoke verdict).
// This tool packages the native runtime bytes — which already exist in
// self/codegen/runtime_arm64.hexa (rt_exit) — as a linkable .o exporting
// those symbols, so N3b can have hexa_ld link {user.o, runtime.o} into a
// runnable executable with NO clang/as/ld in the link step.
//
// SELF-CONTAINED: the macho_obj_wrap_v3 serializer + push helpers are
// inlined verbatim from self/codegen/macho.hexa (same convention as
// test/native_build/poc_multi_sym_emit.hexa + emit_hexa_exit_native_o.hexa),
// because a multi-`use`/`import` driver fails to link on build hosts
// lacking the compiled module_loader, and the installed `hexa` cannot
// codegen struct-bearing imports. This file uses only arrays + push +
// write_bytes — no struct field access — so it runs under the interp.
//
// VERIFY (falsifier F-HEXA-CC-NATIVE-N3A):
//   hexa run tool/emit_runtime_obj.hexa /tmp/runtime_native.o
//   nm -U /tmp/runtime_native.o  → _hexa_exit (T) AND _hexa_set_args (T)
//   nm -u /tmp/runtime_native.o  → empty (self-contained, no imports)
//
// Usage: hexa run tool/emit_runtime_obj.hexa [OUT]   (default build/runtime_native.o)

// ═══ Runtime symbol bodies (verbatim arm64 bytes) ════════════════════

// _hexa_exit — HexaVal-ABI adapter + rt_exit primitive (20 bytes).
//   CALLER ABI (aprime_cc _STMT_CALL pair-args): x0=tag, x1=payload(code)
//   ADAPTER : mov x0, x1                         (payload -> exit-code)
//   PRIMITIVE: rt_exit (self/codegen/runtime_arm64.hexa L36, 16 bytes)
fn hexa_exit_bytes() -> [int] {
    let mut c = []
    // mov x0, x1   (orr x0,xzr,x1)   0xAA0103E0 → e0 03 01 aa
    c.push(0xe0).push(0x03).push(0x01).push(0xaa)
    // stp x29, x30, [sp, #-16]!      0xA9BF7BFD → fd 7b bf a9
    c.push(253).push(123).push(191).push(169)
    // mov x29, sp                     0x910003FD → fd 03 00 91
    c.push(253).push(3).push(0).push(145)
    // mov x16, #1 (SYS_exit)          0xD2800030 → 30 00 80 d2
    c.push(48).push(0).push(128).push(210)
    // svc #0x80                       0xD4001001 → 01 10 00 d4
    c.push(1).push(16).push(0).push(212)
    return c
}

// _hexa_set_args — no-op `ret` stub (4 bytes). The exit-only corpus never
// reads argv; the C runtime's hexa_set_args(argc, argv) merely stashes
// them. A bare `ret` is a correct no-op for that case.
//   ret   0xD65F03C0 → c0 03 5f d6
fn hexa_set_args_bytes() -> [int] {
    let mut c = []
    c.push(192).push(3).push(95).push(214)
    return c
}

// ═══ macho_obj_wrap_v3 + helpers (verbatim inline from self/codegen/macho.hexa,
//     mirrors test/native_build/poc_multi_sym_emit.hexa) ═══════════════

fn push_u16_le(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

fn push_u32_le(buf: [int], val: int) -> [int] {
    return buf
      .push(val % 256)
      .push((val / 256) % 256)
      .push((val / 65536) % 256)
      .push((val / 16777216) % 256)
}

fn push_u64_le(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le(buf, val % 0x100000000)
    return push_u32_le(b, val / 0x100000000)
}

fn align_to(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

fn macho_obj_wrap_v3(code: [int],
                     sym_name_bytes: [[int]],
                     sym_offsets: [int],
                     sym_sections: [int],
                     state_bytes: [int],
                     reloc_offs: [int],
                     reloc_kinds: [int],
                     reloc_symnums: [int]) -> [int] {
    let mut out = []
    let code_size  = len(code)
    let state_size = len(state_bytes)
    let nreloc     = len(reloc_offs)
    let nsyms      = len(sym_name_bytes)

    let mut sym_strx: [int] = []
    let mut strtab_size = 1
    let mut si = 0
    while si < nsyms {
        sym_strx.push(strtab_size)
        strtab_size = strtab_size + len(sym_name_bytes[si])
        si = si + 1
    }

    let mut nsects = 1
    if state_size > 0 { nsects = 2 }

    let segment_cmd_size = 72 + 80 * nsects
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let header_size = 32
    let code_offset = align_to(header_size + sizeofcmds, 8)

    let mut const_offset = code_offset + code_size
    if state_size > 0 {
        const_offset = align_to(code_offset + code_size, 8)
    }
    let data_end = const_offset + state_size

    let reloc_offset = align_to(data_end, 4)
    let reloc_size   = 8 * nreloc
    let symtab_offset = reloc_offset + reloc_size
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size * nsyms
    let total_end = strtab_offset + strtab_size

    // Mach-O header (32 bytes)
    out = push_u32_le(out, 0xFEEDFACF)
    out = push_u32_le(out, 0x0100000C)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 3)
    out = push_u32_le(out, sizeofcmds)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    // LC_SEGMENT_64
    out = push_u32_le(out, 0x19)
    out = push_u32_le(out, segment_cmd_size)
    let mut i0 = 0
    while i0 < 16 { out.push(0); i0 = i0 + 1 }
    out = push_u64_le(out, 0)
    out = push_u64_le(out, total_end - code_offset)
    out = push_u64_le(out, code_offset)
    out = push_u64_le(out, total_end - code_offset)
    out = push_u32_le(out, 7)
    out = push_u32_le(out, 7)
    out = push_u32_le(out, nsects)
    out = push_u32_le(out, 0)

    // section_64 __text (80 bytes)
    out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j0 = 0
    while j0 < 10 { out.push(0); j0 = j0 + 1 }
    out.push(95).push(95).push(84).push(69).push(88).push(84)
    j0 = 0
    while j0 < 10 { out.push(0); j0 = j0 + 1 }
    out = push_u64_le(out, 0)
    out = push_u64_le(out, code_size)
    out = push_u32_le(out, code_offset)
    out = push_u32_le(out, 2)
    out = push_u32_le(out, reloc_offset)
    out = push_u32_le(out, nreloc)
    out = push_u32_le(out, 0x80000400)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)
    out = push_u32_le(out, 0)

    if state_size > 0 {
        out.push(95).push(95).push(99).push(111).push(110).push(115).push(116)
        let mut j1 = 0
        while j1 < 9 { out.push(0); j1 = j1 + 1 }
        out.push(95).push(95).push(84).push(69).push(88).push(84)
        j1 = 0
        while j1 < 10 { out.push(0); j1 = j1 + 1 }
        out = push_u64_le(out, code_size)
        out = push_u64_le(out, state_size)
        out = push_u32_le(out, const_offset)
        out = push_u32_le(out, 3)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
        out = push_u32_le(out, 0)
    }

    // LC_SYMTAB (24 bytes)
    out = push_u32_le(out, 0x02)
    out = push_u32_le(out, symtab_cmd_size)
    out = push_u32_le(out, symtab_offset)
    out = push_u32_le(out, nsyms)
    out = push_u32_le(out, strtab_offset)
    out = push_u32_le(out, strtab_size)

    // LC_BUILD_VERSION (24 bytes)
    out = push_u32_le(out, 0x32)
    out = push_u32_le(out, build_version_cmd_size)
    out = push_u32_le(out, 1)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0x000E0000)
    out = push_u32_le(out, 0)

    while len(out) < code_offset { out.push(0) }
    let mut k0 = 0
    while k0 < len(code) { out.push(code[k0]); k0 = k0 + 1 }

    if state_size > 0 {
        while len(out) < const_offset { out.push(0) }
        let mut sb = 0
        while sb < state_size { out.push(state_bytes[sb]); sb = sb + 1 }
    }

    while len(out) < reloc_offset { out.push(0) }
    let mut ri = 0
    while ri < nreloc {
        let r_off    = reloc_offs[ri]
        let r_kind   = reloc_kinds[ri]
        let r_symnum = reloc_symnums[ri]
        out = push_u32_le(out, r_off)
        let mut r_pcrel = 0
        if r_kind == 3 { r_pcrel = 1 }
        let r_length = 2
        let r_extern = 1
        let bits = (r_symnum % 0x1000000)
                 + (r_pcrel * 0x1000000)
                 + (r_length * 0x2000000)
                 + (r_extern * 0x8000000)
                 + ((r_kind % 16) * 0x10000000)
        out = push_u32_le(out, bits)
        ri = ri + 1
    }

    while len(out) < symtab_offset { out.push(0) }
    let mut sj = 0
    while sj < nsyms {
        let s_strx    = sym_strx[sj]
        let s_offset  = sym_offsets[sj]
        let s_section = sym_sections[sj]
        let mut n_value = s_offset
        if s_section == 2 { n_value = code_size + s_offset }
        out = push_u32_le(out, s_strx)
        out.push(0x0E + 0x01)
        out.push(s_section)
        out = push_u16_le(out, 0)
        out = push_u64_le(out, n_value)
        sj = sj + 1
    }

    // String table: "\0<name0>\0<name1>\0..."
    out.push(0)
    let mut sk = 0
    while sk < nsyms {
        let nb = sym_name_bytes[sk]
        let mut nbi = 0
        while nbi < len(nb) {
            out.push(nb[nbi])
            nbi = nbi + 1
        }
        sk = sk + 1
    }

    return out
}

// ═══ driver ══════════════════════════════════════════════════════════

fn main() {
    println("=== emit_runtime_obj — N3a native runtime .o (_hexa_exit + _hexa_set_args) ===")

    let args = argv()
    let mut out_path = "build/runtime_native.o"
    if len(args) > 2 { out_path = args[2] }

    // ── Concatenate __text: _hexa_exit (offset 0, 20B) then
    //    _hexa_set_args (offset 20, 4B). Both are leaf/syscall bodies
    //    with NO cross-symbol BL, so no relocations are needed. ──
    let hexa_exit = hexa_exit_bytes()
    let set_args  = hexa_set_args_bytes()
    println("_hexa_exit     bytes : " + to_string(len(hexa_exit)) + " (20 expected)")
    println("_hexa_set_args bytes : " + to_string(len(set_args)) + " (4 expected)")

    let mut code = []
    let mut ce = 0
    while ce < len(hexa_exit) { code.push(hexa_exit[ce]); ce = ce + 1 }
    let set_args_off = len(code)
    let mut ca = 0
    while ca < len(set_args) { code.push(set_args[ca]); ca = ca + 1 }
    println("total __text    : " + to_string(len(code)) + " (24 expected)")

    // Sanity — _hexa_exit svc trailer @16, _hexa_set_args ret @20.
    if code[0] != 0xe0 || code[3] != 0xaa { println("FAIL: _hexa_exit mov x0,x1 prefix") ; return }
    if code[16] != 1 || code[19] != 212  { println("FAIL: _hexa_exit svc trailer") ; return }
    if code[20] != 192 || code[23] != 214 { println("FAIL: _hexa_set_args ret") ; return }
    println("byte sanity     : mov-prefix + svc@16 + ret@20 OK")

    // ── Symbol tables — two __text (section 1) external symbols ──
    // "_hexa_exit\0"     = 95 104 101 120 97 95 101 120 105 116 0   (11)
    // "_hexa_set_args\0" = 95 104 101 120 97 95 115 101 116 95 97 114 103 115 0 (15)
    let mut name_exit = []
    name_exit.push(95).push(104).push(101).push(120).push(97).push(95).push(101).push(120).push(105).push(116).push(0)

    let mut name_set_args = []
    name_set_args.push(95).push(104).push(101).push(120).push(97).push(95).push(115).push(101).push(116).push(95).push(97).push(114).push(103).push(115).push(0)

    let mut sym_name_bytes = []
    sym_name_bytes.push(name_exit).push(name_set_args)

    let mut sym_offsets = []
    sym_offsets.push(0).push(set_args_off)

    let mut sym_sections = []
    sym_sections.push(1).push(1)

    // No relocs, no __const.
    let state_bytes   = []
    let reloc_offs    = []
    let reloc_kinds   = []
    let reloc_symnums = []

    let obj = macho_obj_wrap_v3(code, sym_name_bytes, sym_offsets,
                                sym_sections, state_bytes,
                                reloc_offs, reloc_kinds, reloc_symnums)
    println("obj size        : " + to_string(len(obj)) + " bytes total")

    // MH_MAGIC_64 = FEEDFACF → CF FA ED FE
    if obj[0] != 207 || obj[1] != 250 || obj[2] != 237 || obj[3] != 254 {
        println("FAIL: MH_MAGIC_64 mismatch") ; return
    }
    if obj[12] != 1 { println("FAIL: filetype != MH_OBJECT") ; return }
    println("MH_MAGIC_64     : cf fa ed fe · filetype 1 (MH_OBJECT) OK")

    write_bytes(out_path, obj)
    println("wrote           : " + out_path)
    println("[N3a] EMIT OK — verify: nm -U " + out_path + " → _hexa_exit + _hexa_set_args")
}

// auto-invoke handles main()
