#!/usr/bin/env bash
# stage_resolve_runtime_a — produce build/runtime.a for the release build.
#
# Strategy:
#   1. If self/runtime.c is present (seeds-present / pre-graduation tree),
#      compile it from source: $CC $CFLAGS -I self -c self/runtime.c -> .o, ar rcs.
#   2. Otherwise (graduated tree, .c removed), try to pull build/runtime.a out
#      of the prior `edge` release tarball for this target.
#   3. Edge-miss fallback (P7): if the edge tarball is missing/unusable (e.g.
#      edge only ships one arch), restore the pinned pre-graduation .c seeds
#      from git and fall through to the from-source compile (step 1's logic).
#      Restored files are EPHEMERAL — left uncommitted, rebuilt at CI time.
#
set -euo pipefail

TARGET="${1:-${TARGET:-}}"
CC="${CC:-cc}"
CFLAGS="${CFLAGS:--O2}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Pinned pre-graduation seed commit (parent of the graduation commit
# 7906951c0 "graduate: remove committed transpiler+runtime C seeds (.c=0)").
# This is the only authoritative source for self/runtime.c (no SSOT emitter).
FROZEN_SEED_REF="7906951c0^"

# The exact .c set self/runtime.c needs to compile: runtime.c itself,
# every runtime/*.c fragment it #includes, and native/hexa_cc.c (also
# #included by runtime.c). Derived from `git show $REF:self/runtime.c`.
FROZEN_RUNTIME_C="
self/runtime.c
self/native/hexa_cc.c
self/runtime/io.c
self/runtime/mem.c
self/runtime/str.c
self/runtime/map.c
self/runtime/vec.c
self/runtime/math.c
self/runtime/fs.c
self/runtime/proc.c
self/runtime/net.c
self/runtime/time.c
self/runtime/json.c
self/runtime/atlas.c
self/runtime/sys.c
self/runtime/rand.c
self/runtime/hash.c
self/runtime/sort.c
self/runtime/utf8.c
self/runtime/regex.c
self/runtime/bigint.c
self/runtime/complex.c
self/runtime/thread.c
self/runtime/signal.c
"

build_from_source() {
  echo "[resolve_runtime_a] compiling build/runtime.a from self/runtime.c"
  "$CC" $CFLAGS -I self -c self/runtime.c -o build/runtime.o
  ar rcs build/runtime.a build/runtime.o
  echo "[resolve_runtime_a] built build/runtime.a from source"
}

restore_frozen_seed() {
  echo "[resolve_runtime_a] restoring pinned pre-graduation .c seeds from ${FROZEN_SEED_REF}"
  # shellcheck disable=SC2086
  git checkout "$FROZEN_SEED_REF" -- $FROZEN_RUNTIME_C
}

mkdir -p build

# --- step 1: seeds-present path (byte-unchanged) ---
if [ -f self/runtime.c ]; then
  echo "[resolve_runtime_a] self/runtime.c present -> compiling from source"
  build_from_source
  exit 0
fi

if [ -z "$TARGET" ]; then
  echo "[resolve_runtime_a] ERROR: TARGET not set" >&2
  exit 1
fi

# --- step 2: graduated tree -> try edge release first ---
TARGET_TARBALL="hexa-${TARGET}.tar.gz"
echo "[resolve_runtime_a] self/runtime.c absent -> trying edge release tarball"
if gh release download edge --pattern "$TARGET_TARBALL" --dir build --clobber 2>/dev/null \
   && tar -xzf "build/${TARGET_TARBALL}" -C build 2>/dev/null \
   && [ -f build/runtime.a ]; then
  echo "[resolve_runtime_a] extracted build/runtime.a from edge tarball"
  exit 0
fi

# --- step 3: edge miss -> frozen-seed fallback (restore .c, compile from source) ---
echo "[resolve_runtime_a] edge tarball missing/unusable for ${TARGET} -> frozen-seed fallback"
restore_frozen_seed
build_from_source
exit 0
