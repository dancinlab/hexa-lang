// tool/verify_cli.hexa — `hexa verify {<id>|--expr|--fence|--verifier-cmd|rubric|list}`
//
// @version 0.2.0
// @capabilities [fs_read, fs_write]
//
// SINGLE verification entry-point. Uses the BINARY BUILT-IN ATLAS
// (dist/atlas.hxc via hxc_loader — the fast byte-canonical path; we do
// NOT `use embedded.gen`, whose multi-MB struct-literal module-load hangs
// the interp) + the hexa-native CALCULATORS (compiler/atlas/symbolic/*)
// to actually VERIFY a claimed closed-form and assign a tier — not just
// register it (cf. `hexa atlas` = read/stage SSOT, NOT a verifier).
//
// Cross-project tier rubric (dancinlab-wide, LATTICE_POLICY real-limits
// -first; carries: atlas/CLAUDE.md g_self_verify·g_tier_default_insufficient
// ·g_external_calc_forbidden · anima HEXAD g_verdict_tier_blue(a) · TECS-L
// n6-replication Tier1/2/3 · hexa-bio AXIS speculation-fence):
//   🔵 SUPPORTED-FORMAL    hexa-native calc reproduces the closed-form
//                          exactly (g_self_verify; TECS-L Tier1; HEXAD 🔵)
//   🟡 SUPPORTED-BY-CITATION atlas/literature has it, no hexa-native recompute
//   🟠 INSUFFICIENT         not in atlas + no calc path (g_tier_default)
//   🟠 DEFERRED             external hw/data/API dep (g_external_calc_forbidden)
//   ⚪ SPECULATION-FENCED   imagination/metaphor (hexa-bio AXIS class) —
//                          verification N/A, honest fence (g4; SF ≠ proven)
//
// Wired from self/main.hexa (`verify` → this). Runnable now:
//   hexa run tool/verify_cli.hexa <id>

use "compiler/atlas/static_index"
use "compiler/atlas/merger"
use "compiler/atlas/symbolic/congruence_chain_engine"
use "self/stdlib/fs"
use "compiler/atlas/calc_dispatch"   // calc_eps / calc_is_float_fn / calc_is_zero_arg_float_fn — float-recompute SSOT
use "stdlib/consciousness/iit4/faithful_phi"   // VERIFY-KIT V5.2 — iit4_faithful_phi recompute engine (n<=8 exact MIP-EI)
use "self/runtime/bignum_mini_pure"            // VERIFY-KIT V10 — arbitrary-precision σ(P)=2P at p where P overflows int64
use "stdlib/core/math"                          // sopfr() — sum of prime factors w/ multiplicity (resolves verify_cli:431 arm)

// HXC retired 2026-05-22 — verify now reads from static_atlas() which
// parses n6/atlas.n6 via the merger (no hxc). HXC_PATH constant kept as
// a no-op string only so any external reference still resolves.
let HXC_PATH: string = "n6/atlas.n6"
let ABSORB_LEDGER: string = "atlas/inbox/verified_equations.tape"

// --absorb anywhere in argv → fold a 🔵 verdict into the g7 inbox.
fn _has_absorb(rest) -> bool {
    let mut i = 0
    while i < len(rest) {
        if to_string(rest[i]) == "--absorb" { return true }
        i = i + 1
    }
    return false
}

// --no-absorb anywhere in argv → opt-out of the DEFAULT auto-absorb-to-atlas
// path (commons.tape @D g69 — domain finalization gate). Auto-absorb fires
// IMPLICITLY on 🔵/🟢 verdicts; --no-absorb suppresses it (backward-compat for
// callers that want pure verify without side-effects). NEVER fires on 🔴/🟠
// (no point folding falsified/deferred atoms).
fn _has_no_absorb(rest) -> bool {
    let mut i = 0
    while i < len(rest) {
        if to_string(rest[i]) == "--no-absorb" { return true }
        i = i + 1
    }
    return false
}

// --compute anywhere in argv → force VERIFY-KIT V2 value-less COMPUTE mode
// (the `--expr` verb computes & prints fn(args) instead of re-confirming a
// supplied <v>). Lets multi-operand compute (`--expr gcd 12 8 --compute`)
// stay unambiguous vs the 1-op VERIFY form. The len-3 1-op compute case
// (`--expr sigma 7`) auto-detects without the marker.
fn _has_compute(rest) -> bool {
    let mut i = 0
    while i < len(rest) {
        if to_string(rest[i]) == "--compute" { return true }
        i = i + 1
    }
    return false
}

// VERIFY-KIT V3 — `--tol <eps>` round-tolerance flag (literature-rounded
// comparison). OPT-IN only: when absent, the verify path keeps its current
// STRICT ε=1e-9 gate (a 🔴 beyond ε stays 🔴). When `--tol <eps>` is present
// and the recompute lands within <eps> of the claimed value (but not within
// the strict ε), the float path emits 🟢 SUPPORTED-NUMERICAL (round-tolerant)
// instead of a spurious 🔴 — e.g. literature's 6-digit Tc=14.55 vs the engine's
// 14.5511. CRITICAL: tolerance is for literature ROUNDING, NOT a way to launder
// failures — a deterministic disagreement BEYOND the stated <eps> still 🔴.
// Returns true iff `--tol` appears as a flag token in argv.
fn _has_tol(rest) -> bool {
    let mut i = 0
    while i < len(rest) {
        if to_string(rest[i]) == "--tol" { return true }
        i = i + 1
    }
    return false
}

// _get_tol — parse the float operand FOLLOWING the `--tol` flag. Returns 0.0
// (= no tolerance) when `--tol` is absent or has no trailing value, so an
// unparsed/missing eps degrades to STRICT behavior (never silently widens).
fn _get_tol(rest) -> float {
    let mut i = 0
    while i < len(rest) {
        if to_string(rest[i]) == "--tol" && (i + 1) < len(rest) {
            return _parse_float(to_string(rest[i + 1]))
        }
        i = i + 1
    }
    return 0.0
}

// _strip_tol — return a copy of `rest` with the `--tol <eps>` flag PAIR removed,
// so the downstream arity detection (has5/has6/has7 / operand counting) is not
// thrown off by the extra two tokens. Mirrors the --absorb/--no-absorb/--compute
// flag-tolerance already in the dispatch.
fn _strip_tol(rest) -> array {
    let mut out: array = []
    let mut i = 0
    while i < len(rest) {
        let tk = to_string(rest[i])
        if tk == "--tol" {
            // skip the flag AND its value operand (if present)
            i = i + 2
        } else {
            out.push(rest[i])
            i = i + 1
        }
    }
    return out
}

// _auto_absorb_via_atlas — DEFAULT auto-absorb path (commons.tape @D g69).
// Delegates to `hexa atlas register --from-verify <fn> <args...> <v>` which
// folds the verified atom DIRECTLY into compiler/atlas/embedded.gen.hexa
// (the binary-builtin SSOT — visible to next `hexa atlas lookup` with no
// rebuild). args_str_space is the space-separated args (operands only, no fn
// name). v_str is the claimed value (int or float decimal echo).
fn _auto_absorb_via_atlas(fn_name: string, args_str_space: string, v_str: string) {
    // collapse any double-space when args_str_space is empty (0-arg constants)
    let mut invoke = "hexa atlas register --from-verify " + fn_name
    if len(args_str_space) > 0 { invoke = invoke + " " + args_str_space }
    invoke = invoke + " " + v_str
    let out = to_string(exec(invoke + " 2>&1"))
    // print a single-line auto-absorb echo (the atlas register prints its
    // own multi-line block; we surface a compact summary here). Recognise
    // both the freshly-folded form and the idempotent skip forms (an
    // already-registered atom is a successful no-op — same SSOT state).
    if out.contains("folded @F") {
        println("  absorb = ✓ auto-folded into compiler/atlas/embedded.gen.hexa (default · @D g69)")
    } else if out.contains("already registered") || out.contains("already present in embedded.gen.hexa") {
        println("  absorb = · already in atlas — idempotent skip (default · @D g69)")
    } else {
        // honest degrade — print the raw invocation tail so the caller can debug
        println("  absorb = ⚠ atlas register did NOT confirm fold; invocation:")
        println("           " + invoke)
    }
}

// append a self-verified equation as a g7 atlas verdict entry (append-only
// inbox ledger). Legit 🔵 under g_self_verify — these ARE hexa-native
// verified (NOT sympy carry). Reviewer-merge → MAIN.tape (cycle_033/035
// pattern). Works for equations NOT YET in the atlas — verify computes &
// proves them; --absorb grows the binary built-in atlas with the result.
fn _absorb(label: string, evidence: string, anchor: string) {
    let mut body = read_file_safe(ABSORB_LEDGER)
    if len(body) == 0 {
        body = "#!/usr/bin/env tape\n"
        body = body + "# atlas/inbox/verified_equations.tape — `hexa verify --absorb` ledger\n"
        body = body + "# g7 inbox: hexa-native self-verified 🔵 equations (g_self_verify;\n"
        body = body + "# NOT sympy carry). Reviewer-merge → MAIN.tape (cycle_033/035 pattern).\n"
        body = body + "@V := \"tape\" :: spec [active]\n  version = \"1.2\"\n\n"
    }
    let ent = "@D verified_" + _slug(label) + " := \"" + label
        + "\" :: verdict [d=2026-05-16 active]\n"
        + "  status = \"🔵 SUPPORTED-FORMAL\"\n"
        + "  evidence = \"" + evidence + "\"\n"
        + "  stage = \"Stage 1 — hexa-native recompute (hexa verify)\"\n"
        + "  anchor = \"" + anchor + "\"\n"
        + "  cite = \"hexa verify self-verified (g_self_verify · TECS-L Tier1)\"\n"
        + "  provenance = \"tool/verify_cli.hexa --absorb · binary built-in atlas + calculators\"\n\n"
    write_file_safe(ABSORB_LEDGER, body + ent)
    println("  absorb = → " + ABSORB_LEDGER + " (@D verified_" + _slug(label) + ", g7 inbox)")
}

fn _slug(s: string) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let c = s[i]
        if (c >= "a" && c <= "z") || (c >= "0" && c <= "9") { out = out + c }
        else if c >= "A" && c <= "Z" { out = out + c }
        else { out = out + "_" }
        i = i + 1
    }
    return out
}

// only FIXED keywords are subs; a bare <id> is picked up by the n>=3
// fallback (real args start at index 2) — mirrors tool/calc_cli.hexa.
// (do NOT treat arbitrary non-dash tokens as subs: that wrongly matches
//  the expanded-script path at argv[1] under `hexa run`.)
fn _is_sub(a) -> bool {
    return a == "rubric" || a == "list" || a == "help" || a == "--help" || a == "-h"
        || a == "--expr" || a == "--fence" || a == "--blue-max"
        || a == "--verifier-cmd"
}

fn _slice_args() -> array {
    let av = args()
    let n = len(av)
    let mut i = 1
    while i < n {
        let a = to_string(av[i])
        if _is_sub(a) {
            let mut out = []
            let mut j = i
            while j < n { out.push(av[j]); j = j + 1 }
            return out
        }
        i = i + 1
    }
    if n >= 3 {
        let mut out = []
        let mut j = 2
        while j < n { out.push(av[j]); j = j + 1 }
        return out
    }
    return []
}

