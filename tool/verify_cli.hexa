    if fn_name == "f_funnel_composite" {
        if argc < 2 { return _NOCALC_F }
        return _f_funnel_composite(a0, a1)
    }
    // в”Җв”Җ FUSION F4 вҖ” ideal-MHD ОІ-limit / q* / kink (Troyon 1984, gate (d)) в”Җ
    //   beta_max_pct(ОІ_N, I_p, a, B)   4-arg: Troyon ОІ-limit [%]
    //   beta_n(ОІ[%], I_p, a, B)        4-arg: inverse Troyon (achieved ОІ_N)
    //   q_star(a, B, R, I_p)           4-arg: cylindrical edge safety factor
    if fn_name == "beta_max_pct" {
        if argc < 4 { return _NOCALC_F }
        return _beta_max_pct(a0, a1, a2, a3)
    }
    if fn_name == "beta_n" {
        if argc < 4 { return _NOCALC_F }
        return _beta_n(a0, a1, a2, a3)
    }
    if fn_name == "q_star" {
        if argc < 4 { return _NOCALC_F }
        return _q_star(a0, a1, a2, a3)
    }
    // в”Җв”Җ Bio-physical Phase 3 (demiurge cross-domain V2 closure) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    //   higuchi(k_H, t)                   2-arg: k_H * sqrt(t)
    //   tafel(a, b, j)                    3-arg: a + b * log10(j)
    //   hagen_poiseuille(r, dP, mu, L)    4-arg: pi*r^4*dP / (8*mu*L)
    if fn_name == "higuchi" {
        if argc < 2 { return _NOCALC_F }
        return _higuchi(a0, a1)
    }
    if fn_name == "tafel" {
        if argc < 3 { return _NOCALC_F }
        return _tafel(a0, a1, a2)
    }
    if fn_name == "hagen_poiseuille" {
        if argc < 4 { return _NOCALC_F }
        return _hagen_poiseuille(a0, a1, a2, a3)
    }
    // в”Җв”Җ TTR-ORAL / TTR-LAC bundle (topical PK + laser optics В· INBOX T22:35Z) в”Җв”Җ
    //   higuchi_flux(C0, Dm, t)            3-arg: sqrt(2В·C0В·DmВ·t/ПҖ)
    //   fick_steady_flux(P, О”C)            2-arg: PВ·О”C
    //   partition_coeff(C_oct, C_water)    2-arg: log10(C_oct/C_water)
    //   permeability_skin(D, K, h)         3-arg: DВ·K/h
    //   auc_first_order(C0, ke)            2-arg: C0/ke
    //   clearance(dose, auc)               2-arg: dose/auc
    //   beer_lambert_log10(I0, Оө, c, L)    4-arg: I0В·10^(-ОөВ·cВ·L)
    //   fluence(P, A, t)                   3-arg: PВ·t/A
    //   beam_waist(w0, z, zR)              3-arg: w0В·sqrt(1+(z/zR)ВІ)
    //   rayleigh_range(w0, О»)              2-arg: ПҖВ·w0ВІ/О»
    //   absorption_depth(Оұ)                1-arg: 1/Оұ
    if fn_name == "higuchi_flux" {
        if argc < 3 { return _NOCALC_F }
        return _higuchi_flux(a0, a1, a2)
    }
    if fn_name == "fick_steady_flux" {
        if argc < 2 { return _NOCALC_F }
        return _fick_steady_flux(a0, a1)
    }
    if fn_name == "partition_coeff" {
        if argc < 2 { return _NOCALC_F }
        return _partition_coeff(a0, a1)
    }
    if fn_name == "permeability_skin" {
        if argc < 3 { return _NOCALC_F }
        return _permeability_skin(a0, a1, a2)
    }
    if fn_name == "auc_first_order" {
        if argc < 2 { return _NOCALC_F }
        return _auc_first_order(a0, a1)
    }
    if fn_name == "clearance" {
        if argc < 2 { return _NOCALC_F }
        return _clearance(a0, a1)
    }
    if fn_name == "beer_lambert_log10" {
        if argc < 4 { return _NOCALC_F }
        return _beer_lambert_log10(a0, a1, a2, a3)
    }
    if fn_name == "fluence" {
        if argc < 3 { return _NOCALC_F }
        return _fluence(a0, a1, a2)
    }
    if fn_name == "beam_waist" {
        if argc < 3 { return _NOCALC_F }
        return _beam_waist(a0, a1, a2)
    }
    if fn_name == "rayleigh_range" {
        if argc < 2 { return _NOCALC_F }
        return _rayleigh_range(a0, a1)
    }
    if fn_name == "absorption_depth" {
        return _absorption_depth(a0)
    }
    // Penning-trap eigenmotion (ANTIMATTER capture - charged-particle 3-freq):
    //   penning_omega_plus(w_c, w_z)   2-arg: w_c/2 + sqrt((w_c/2)^2 - w_z^2/2)
    //   penning_omega_minus(w_c, w_z)  2-arg: w_c/2 - sqrt((w_c/2)^2 - w_z^2/2)
    //   penning_invariance(w_c, w_z)   2-arg: sqrt(w+^2 + w_z^2 + w-^2) == w_c
    if fn_name == "penning_omega_plus" {
        if argc < 2 { return _NOCALC_F }
        return _penning_omega_plus(a0, a1)
    }
    if fn_name == "penning_omega_minus" {
        if argc < 2 { return _NOCALC_F }
        return _penning_omega_minus(a0, a1)
    }
    if fn_name == "penning_invariance" {
        if argc < 2 { return _NOCALC_F }
        return _penning_invariance(a0, a1)
    }
    // в”Җв”Җ Three-body recombination scaling (ANTIMATTER в“№н•©м„ұ) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    //   recomb_3body_exponent()        0-arg: вҲ’9/2 = вҲ’4.5 (T-scaling exponent)
    //   recomb_3body_tratio(T_hi,T_lo) 2-arg: (T_hi/T_lo)^4.5 (Оұ-ratio)
    if fn_name == "recomb_3body_exponent" { return _recomb_3body_exponent() }
    if fn_name == "recomb_3body_tratio" {
        if argc < 2 { return _NOCALC_F }
        return _recomb_3body_tratio(a0, a1)
    }
    return _NOCALC_F
}

// WIPE-OK: float membership predicates hoisted to the shared SSOT
// compiler/atlas/calc_dispatch (calc_is_float_fn / calc_is_zero_arg_float_fn),
// which BOTH verify_cli and atlas_cli `use`. The local _is_float_fn /
// _is_zero_arg_float_fn copies are removed вҖ” adding a float fn now needs ONE
// edit (calc_dispatch's table), never a verifyвҶ”atlas mirror sync. Call sites
// above were repointed to calc_is_float_fn() / calc_is_zero_arg_float_fn().

// trim trailing zeros of a floatвҶ’string for tidy verdict echo.
fn _fstr(x: float) -> string {
    return to_string(x)
}

// nodes_of_kind вҖ” return the per-kind bucket of an AtlasIndex by kind
// letter (P|C|L|E|F|R|S|X|Q). Mirrors static_index field layout; kept
// local so verify_cli stays a single `main`-bearing tool.
fn nodes_of_kind(idx, kind: string) -> array {
    if kind == "P" { return idx.p_nodes }
    if kind == "C" { return idx.c_nodes }
    if kind == "L" { return idx.l_nodes }
    if kind == "E" { return idx.e_nodes }
    if kind == "F" { return idx.f_nodes }
    if kind == "R" { return idx.r_nodes }
    if kind == "S" { return idx.s_nodes }
    if kind == "X" { return idx.x_nodes }
    if kind == "Q" { return idx.q_nodes }
    return []
}

// extract trailing "= <int>" claimed value from a raw header before "::".
fn _claimed_value(raw: string) -> int {
    let mut head = raw
    let ci = head.index_of("::")
    if ci >= 0 { head = head.slice(0, ci) }
    // last '=' segment
    let mut last = ""
    let parts = head.split("=")
    if len(parts) >= 2 {
        last = parts[len(parts) - 1]
    }
    let t = last.trim()
    return to_int(t)
}

fn cmd_verify_id(rest) {
    if len(rest) < 1 {
        println("error: usage: hexa verify <id>")
        exit(2)
    }
    let target = to_string(rest[0])
    // hxc retired 2026-05-22: pull the bucketed AtlasIndex from static_atlas
    // (which parses n6/atlas.n6 via the merger) and walk all 9 kinds.
    let idx = static_atlas()
    let total = len(idx.p_nodes) + len(idx.c_nodes) + len(idx.l_nodes) + len(idx.e_nodes) + len(idx.f_nodes) + len(idx.r_nodes) + len(idx.s_nodes) + len(idx.x_nodes) + len(idx.q_nodes)
    if total == 0 {
        println("verify " + target)
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = atlas (n6/atlas.n6) empty/absent")
        return
    }
    let kinds = ["P", "C", "L", "E", "F", "R", "S", "X", "Q"]
    let mut found = false
    let mut nraw = ""
    let mut nkind = ""
    let mut ki = 0
    while ki < len(kinds) && !found {
        let bucket = nodes_of_kind(idx, kinds[ki])
        let mut i = 0
        while i < len(bucket) {
            let nd = bucket[i]
            if nd.id == target {
                found = true
                nraw = nd.raw
                nkind = nd.kind
                i = len(bucket)
            } else {
                i = i + 1
            }
        }
        ki = ki + 1
    }
    println("verify " + target + "   (atlas: " + to_string(total) + " nodes from atlas.n6)")
    if !found {
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = id not in atlas; no closed-form to recompute")
        return
    }
    println("  atlas  = @" + nkind + " " + target + " (registered)")
    // try hexa-native recompute: find a known fn(6) form in raw
    let claimed = _claimed_value(nraw)
    let mut fnm = ""
    if nraw.contains("divisor_sum") { fnm = "divisor_sum" }
    else if nraw.contains("euler_totient") { fnm = "euler_totient" }
    else if nraw.contains("divisor_count") { fnm = "divisor_count" }
    else if nraw.contains("mobius") { fnm = "mobius" }
    if len(fnm) == 0 {
        println("  tier   = рҹҹЎ SUPPORTED-BY-CITATION")
        println("  reason = atlas-registered; no hexa-native calc path for this form")
        return
    }
    let got = _recompute(fnm, 6)
    if got == claimed && claimed != NOCALC {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  == claimed " + to_string(claimed))
        println("  tier   = рҹ”ө SUPPORTED-FORMAL")
        println("  reason = hexa-native closed-form reproduced (g_self_verify В· TECS-L Tier1)")
        if _has_absorb(rest) {
            _absorb(target + " = " + to_string(claimed),
                    "@" + nkind + " " + target + " В· " + fnm + "(6)=" + to_string(got) + " == atlas-claimed " + to_string(claimed),
                    "[compiler invariant вҖ” hexa-native NT closed-form, g_self_verify]")
        }
    } else if claimed == NOCALC {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  vs claimed (unparsed)")
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = claimed value unparsed from raw вҖ” cannot adjudicate")
    } else {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  != claimed " + to_string(claimed))
        println("  tier   = рҹ”ҙ FALSIFIED")
        println("  reason = hexa-native calc DETERMINISTICALLY disagrees with the claim вҖ”")
        println("           closed negative (TECS-L result-agnostic; вү  INSUFFICIENT)")
    }
}

// cmd_expr_float вҖ” the рҹҹў NUMERICAL path. fn_name is a registered float
// transform (welch_t_crit В· wilson_hilferty_p В· chsh_tsirelson В· hardy_bound
// В· exp_release В· ldl_pct В· beer_lambert В· nnt В· arr В· ln_hr_to_hr
// В· hill В· cheng_prusoff В· fick1 В· laplace В· stokes_einstein
// В· higuchi В· tafel В· hagen_poiseuille).
// Args + claimed value are parsed as floats; the recompute is compared with
// tolerance Оө (NOT exact-eq, the honest libm-class gate). Within Оө вҶ’
// рҹҹў SUPPORTED-NUMERICAL; deterministic out-of-Оө вҶ’ рҹ”ҙ FALSIFIED.
//   0-arg:  --expr <fn> <v>                         (rest len 3; closed-form constant)
//   1-arg:  --expr <fn> <a0> <v>                    (rest len 4)
//   2-arg:  --expr <fn> <a0> <a1> <v>               (rest len 5)
//   3-arg:  --expr <fn> <a0> <a1> <a2> <v>          (rest len 6; bio Phase 1/2)
//   4-arg:  --expr <fn> <a0> <a1> <a2> <a3> <v>     (rest len 7; bio Phase 3 вҖ” hagen_poiseuille)
// cmd_expr_float_compute вҖ” VERIFY-KIT V1 value-less COMPUTE mode for float
// fns (the float counterpart of cmd_expr_compute). The legacy cmd_expr_float
// always consumes the trailing operand as the EXPECTED value <v>, so a 3-arg
// float fn invoked with its 3 operands (no <v>) was mis-parsed as a 2-arg
// VERIFY (the 3rd operand swallowed as <v>) вҖ” the allen_dynes_tc(О»,Пү_log,Ој*)
// arity gap. With --compute every non-flag operand after the fn name is an
// ARG, the value is COMPUTED via the SAME _recompute_float helper, and the
// result is printed `COMPUTE: <fn>(<args>) = <value>` + self-verified twice.
// This is the delegation target for `atlas register --from-verify` вҖ” register
// shells out in compute mode so it never needs its own recompute mirror.
fn cmd_expr_float_compute(rest, fnm: string) {
    // collect non-flag operand strings after the fn name (rest[0]=--expr,
    // rest[1]=fn, rest[2..]=operands вҲӘ flags).
    let mut ops_str: array = []
    let mut k = 2
    while k < len(rest) {
        let tk = to_string(rest[k])
        if tk != "--absorb" && tk != "--no-absorb" && tk != "--compute" { ops_str.push(tk) }
        k = k + 1
    }
    let argc = len(ops_str)
    let mut a0 = 0.0
    let mut a1 = 0.0
    let mut a2 = 0.0
    let mut a3 = 0.0
    if argc >= 1 { a0 = _parse_float(to_string(ops_str[0])) }
    if argc >= 2 { a1 = _parse_float(to_string(ops_str[1])) }
    if argc >= 3 { a2 = _parse_float(to_string(ops_str[2])) }
    if argc >= 4 { a3 = _parse_float(to_string(ops_str[3])) }
    let mut arg_echo = ""
    if argc >= 1 { arg_echo = _fstr(a0) }
    if argc >= 2 { arg_echo = arg_echo + "," + _fstr(a1) }
    if argc >= 3 { arg_echo = arg_echo + "," + _fstr(a2) }
    if argc >= 4 { arg_echo = arg_echo + "," + _fstr(a3) }
    let label = fnm + "(" + arg_echo + ")"
    let got = _recompute_float(fnm, a0, a1, a2, a3, argc)
    if got == _NOCALC_F {
        println("verify --expr " + label + "  (compute mode)")
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = float calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute_float (кі„мӮ°кё°мӢңмҠӨн…ң к°ңм„  нӣ„ліҙ)")
        return
    }
    // self-verify: recompute a SECOND time вҖ” deterministic calc MUST agree.
    let got2 = _recompute_float(fnm, a0, a1, a2, a3, argc)
    println("COMPUTE: " + label + " = " + _fstr(got))
    if _fabs(got - got2) <= calc_eps() {
        println("  tier   = рҹҹў SUPPORTED-NUMERICAL  (hexa-native libm-class compute, self-verified deterministic В· g_self_verify В· TECS-L n6-rep Tier2)")
    } else {
        println("  tier   = рҹ”ҙ FALSIFIED  (recompute non-deterministic: " + _fstr(got) + " vs " + _fstr(got2) + " вҖ” calculator bug)")
    }
}

fn cmd_expr_float(rest_in, fnm: string) {
    // VERIFY-KIT V3 вҖ” capture the OPT-IN round-tolerance, then strip the
    // `--tol <eps>` flag pair so the arity detection (has5/has6/has7) below is
    // not skewed by the two extra tokens. tol == 0.0 вҮ’ no tolerance вҮ’ the
    // STRICT Оө=1e-9 gate is preserved (current behavior, unchanged).
    let tol = _get_tol(rest_in)
    let tol_on = _has_tol(rest_in)
    let rest = _strip_tol(rest_in)
    let zero_arg = calc_is_zero_arg_float_fn(fnm)
    // VERIFY-KIT V1 вҖ” explicit value-less COMPUTE marker routes BEFORE the
    // VERIFY arity parse (which would swallow the last operand as <v>). 0-arg
    // constants keep their `--expr <fn> <v>` VERIFY form, so --compute on a
    // 0-arg fn (no operands at all) still falls through to compute argc=0.
    if _has_compute(rest) {
        cmd_expr_float_compute(rest, fnm)
        return
    }
    let has7 = len(rest) >= 7 && to_string(rest[6]) != "--absorb" && to_string(rest[6]) != "--no-absorb"
    let has6 = len(rest) >= 6 && to_string(rest[5]) != "--absorb" && to_string(rest[5]) != "--no-absorb"
    let has5 = len(rest) >= 5 && to_string(rest[4]) != "--absorb" && to_string(rest[4]) != "--no-absorb"
    let mut a0 = 0.0
    let mut a1 = 0.0
    let mut a2 = 0.0
    let mut a3 = 0.0
    let mut v = 0.0
    let mut argc = 1
    let mut label = ""
    if zero_arg {
        v = _parse_float(to_string(rest[2]))
        argc = 0
        label = fnm + "()=" + _fstr(v)
    } else if has7 {
        a0 = _parse_float(to_string(rest[2]))
        a1 = _parse_float(to_string(rest[3]))
        a2 = _parse_float(to_string(rest[4]))
        a3 = _parse_float(to_string(rest[5]))
        v = _parse_float(to_string(rest[6]))
        argc = 4
        label = fnm + "(" + _fstr(a0) + "," + _fstr(a1) + "," + _fstr(a2) + "," + _fstr(a3) + ")=" + _fstr(v)
    } else if has6 {
        a0 = _parse_float(to_string(rest[2]))
        a1 = _parse_float(to_string(rest[3]))
        a2 = _parse_float(to_string(rest[4]))
        v = _parse_float(to_string(rest[5]))
        argc = 3
        label = fnm + "(" + _fstr(a0) + "," + _fstr(a1) + "," + _fstr(a2) + ")=" + _fstr(v)
    } else if has5 {
        a0 = _parse_float(to_string(rest[2]))
        a1 = _parse_float(to_string(rest[3]))
        v = _parse_float(to_string(rest[4]))
        argc = 2
        label = fnm + "(" + _fstr(a0) + "," + _fstr(a1) + ")=" + _fstr(v)
    } else {
        a0 = _parse_float(to_string(rest[2]))
        v = _parse_float(to_string(rest[3]))
        argc = 1
        label = fnm + "(" + _fstr(a0) + ")=" + _fstr(v)
    }
    let got = _recompute_float(fnm, a0, a1, a2, a3, argc)
    println("verify --expr " + label)
    if got == _NOCALC_F {
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = float calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute_float (кі„мӮ°кё°мӢңмҠӨн…ң к°ңм„  нӣ„ліҙ)")
        return
    }
    let diff = _fabs(got - v)
    if diff <= calc_eps() {
        println("  calc   = " + _fstr(got) + "  вүҲ expected " + _fstr(v) + "  (|О”|=" + _fstr(diff) + " вүӨ Оө=1e-9)")
        println("  tier   = рҹҹў SUPPORTED-NUMERICAL  (hexa-native libm-class recompute, TECS-L n6-rep Tier2)")
        // --absorb (legacy ledger path) вҖ” kept for backward-compat
        if _has_absorb(rest) {
            _absorb(label, fnm + " hexa-native numerical recompute = " + _fstr(got) + " вүҲ claimed " + _fstr(v) + " (|О”|=" + _fstr(diff) + " вүӨ 1e-9)",
                    "[numerical transform вҖ” hexa-native libm-class recompute, TECS-L Tier2]")
        }
        // DEFAULT auto-absorb-to-atlas (commons.tape @D g69). Opt-out with
        // --no-absorb. Mirrors cmd_expr arity dispatch above to assemble the
        // operand list + claimed-value echo for `hexa atlas register`.
        if !_has_no_absorb(rest) {
            let mut args_space = ""
            if zero_arg {
                args_space = ""    // 0-arg constant: empty operand list
            } else if has7 {
                args_space = to_string(rest[2]) + " " + to_string(rest[3]) + " " + to_string(rest[4]) + " " + to_string(rest[5])
            } else if has6 {
                args_space = to_string(rest[2]) + " " + to_string(rest[3]) + " " + to_string(rest[4])
            } else if has5 {
                args_space = to_string(rest[2]) + " " + to_string(rest[3])
            } else {
                args_space = to_string(rest[2])
            }
            let mut v_str = ""
            if zero_arg { v_str = to_string(rest[2]) }
            else if has7 { v_str = to_string(rest[6]) }
            else if has6 { v_str = to_string(rest[5]) }
            else if has5 { v_str = to_string(rest[4]) }
            else { v_str = to_string(rest[3]) }
            _auto_absorb_via_atlas(fnm, args_space, v_str)
        }
    } else if tol_on && diff <= tol {
        // VERIFY-KIT V3 вҖ” OPT-IN round-tolerance band: the claim is OUTSIDE the
        // strict Оө=1e-9 gate but WITHIN the explicitly-stated <eps>. This is the
        // literature-rounding case (e.g. Tc=14.55 vs the engine's 14.5511) вҖ” a
        // 6-digit-rounded value, NOT a real falsification. Emit рҹҹў with an
        // explicit within-tol note. Tolerance is opt-in for literature-rounded
        // comparisons, NOT a way to launder failures.
        println("  calc   = " + _fstr(got) + "  вүҲ expected " + _fstr(v) + "  (within tol " + _fstr(tol) + ", calc=" + _fstr(got) + " vs expected=" + _fstr(v) + ", |О”|=" + _fstr(diff) + ")")
        println("  tier   = рҹҹў SUPPORTED-NUMERICAL  (round-tolerant: literature-rounded value within opt-in --tol " + _fstr(tol) + ", TECS-L n6-rep Tier2)")
        // NOTE: round-tolerant рҹҹў does NOT auto-absorb вҖ” the atlas SSOT folds the
        // ENGINE's full-precision value via its own compute path (VERIFY-KIT V1),
        // never the literature-rounded operand. So no _absorb / auto-absorb here.
    } else {
        // STRICT рҹ”ҙ: deterministic disagreement BEYOND Оө (and beyond <tol> when
        // --tol was given). A рҹ”ҙ past the stated eps stays рҹ”ҙ вҖ” falsification
        // integrity preserved.
        if tol_on {
            println("  calc   = " + _fstr(got) + "  вү  expected " + _fstr(v) + "  (|О”|=" + _fstr(diff) + " > tol=" + _fstr(tol) + ")")
            println("  tier   = рҹ”ҙ FALSIFIED  (disagrees beyond the stated --tol " + _fstr(tol) + " вҖ” tolerance does NOT launder failures, TECS-L result-agnostic closed negative)")
        } else {
            println("  calc   = " + _fstr(got) + "  вү  expected " + _fstr(v) + "  (|О”|=" + _fstr(diff) + " > Оө=1e-9)")
            println("  tier   = рҹ”ҙ FALSIFIED  (calc deterministically disagrees beyond Оө вҖ” TECS-L result-agnostic closed negative)")
        }
    }
}

// cmd_expr_compute вҖ” VERIFY-KIT V2 (P0b): VALUE-LESS COMPUTE MODE.
//
// The legacy `--expr` forms all require the EXPECTED value <v> as the trailing
// operand вҖ” so the CLI can only RE-CONFIRM a known value, never COMPUTE a
// fresh one. catalogue-mirror sweeps (OEIS/DLMF/ARXIV) that want `Пғ(7)=?`
// hit this wall. V2 adds a value-less form: drop the trailing <v> and the CLI
// computes + prints the value via the SAME `_recompute*` helper, then
// self-verifies (recompute twice вҶ’ must be deterministic).
//
//   1-operand compute:  --expr <fn> <n>          (rest len 3)
//   2-operand compute:  --expr <fn> <a> <b>      (rest len 4)
//   3-operand compute:  --expr <fn> <a> <b> <c>  (rest len 5)
//
// DISAMBIGUATION RULE (operand-count): the compute form is the verify form
// with EXACTLY ONE FEWER operand (the trailing <v> omitted). So `--expr sigma
// 7` (len 3) = COMPUTE Пғ(7); `--expr sigma 7 8` (len 4) = VERIFY Пғ(7)==8.
// For 2-operand fns: `--expr gcd 12 8` (len 4) = COMPUTE gcd(12,8); `--expr
// gcd 12 8 4` (len 5) = VERIFY gcd(12,8)==4. The single len-3 collision with
// the 0-arg float VERIFY form (`--expr chsh_tsirelson <v>`) is already routed
// AWAY before this helper runs (cmd_expr sends 0-arg float fns to the float
// path), so the int compute path is unambiguous.
//
// Output: `COMPUTE: <fn>(<args>) = <value>` (no atlas auto-absorb вҖ” compute
// is a read; absorb stays on the value-bearing verify forms only).
fn cmd_expr_compute(rest, ops: int) {
    let fnm = to_string(rest[1])
    let mut got = NOCALC
    let mut label = ""
    if ops == 3 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        let c = to_int(to_string(rest[4]))
        got = _recompute3(fnm, a, b, c)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + "," + to_string(c) + ")"
    } else if ops == 2 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        got = _recompute2(fnm, a, b)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + ")"
    } else {
        let nn = to_int(to_string(rest[2]))
        got = _recompute(fnm, nn)
        label = fnm + "(" + to_string(nn) + ")"
    }
    if got == NOCALC {
        println("verify --expr " + label + "  (compute mode)")
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute (кі„мӮ°кё°мӢңмҠӨн…ң к°ңм„  нӣ„ліҙ)")
        return
    }
    // self-verify: recompute a SECOND time вҖ” deterministic calc MUST agree.
    let mut got2 = NOCALC
    if ops == 3 {
        got2 = _recompute3(fnm, to_int(to_string(rest[2])), to_int(to_string(rest[3])), to_int(to_string(rest[4])))
    } else if ops == 2 {
        got2 = _recompute2(fnm, to_int(to_string(rest[2])), to_int(to_string(rest[3])))
    } else {
        got2 = _recompute(fnm, to_int(to_string(rest[2])))
    }
    println("COMPUTE: " + label + " = " + to_string(got))
    if got2 == got {
        println("  tier   = рҹ”ө SUPPORTED-FORMAL  (hexa-native closed-form compute, self-verified deterministic В· g_self_verify В· TECS-L Tier1)")
    } else {
        println("  tier   = рҹ”ҙ FALSIFIED  (recompute non-deterministic: " + to_string(got) + " vs " + to_string(got2) + " вҖ” calculator bug)")
    }
}

fn cmd_expr(rest_in) {
    // 0-operand:  --expr <fn> <v>                    (rest len 3; chsh_tsirelson)
    // 1-operand:  --expr <fn> <n> <v>                (rest len 4)
    // 2-operand:  --expr <fn> <a> <b> <v>            (rest len 5)
    // 3-operand:  --expr <fn> <a> <b> <c> <v>        (rest len 6)
    // 4-operand:  --expr <fn> <a> <b> <c> <d> <v>    (rest len 7; bio Phase 3 hagen_poiseuille)
    //
    // VERIFY-KIT V2 вҖ” VALUE-LESS COMPUTE MODE (the verify form minus its
    // trailing <v>): `--expr <fn> <n>` computes & prints fn(n) instead of
    // re-confirming a known value. See cmd_expr_compute for the disambiguation
    // rule. Routed below AFTER the float path so float fns keep their forms.
    //
    // VERIFY-KIT V3 вҖ” capture the OPT-IN `--tol <eps>` round-tolerance, then
    // operate on a STRIPPED copy of argv so the operand-count / arity detection
    // is not skewed by the two extra `--tol <eps>` tokens. The float path
    // (cmd_expr_float) strips internally too вҖ” pass it the ORIGINAL argv so the
    // flag survives the call boundary. tol == 0.0 вҮ’ STRICT (current behavior).
    let tol = _get_tol(rest_in)
    let tol_on = _has_tol(rest_in)
    let rest = _strip_tol(rest_in)
    let fnm_pre = if len(rest) >= 2 { to_string(rest[1]) } else { "" }
    let zero_arg_pre = calc_is_zero_arg_float_fn(fnm_pre)
    if len(rest) < 3 {
        println("error: usage: hexa verify --expr <fn> <n> [<v>]  |  <fn> <a> <b> [<v>]  [--absorb] [--tol <eps>]")
        println("       (compute mode: omit <v> to COMPUTE; provide <v> to VERIFY)")
        exit(2)
    }
    let fnm = to_string(rest[1])
    // float-NUMERICAL forms (welch_t_crit В· wilson_hilferty_p В· chsh_tsirelson
    // В· hardy_bound) route to the рҹҹў path BEFORE the int parser truncates
    // real-valued args. (Float fns include the only int-shaped len-3 VERIFY
    // collision вҖ” the 0-arg constants like chsh_tsirelson вҖ” so once float fns
    // are routed away, the int compute path below is unambiguous.)
    if calc_is_float_fn(fnm) {
        // pass the ORIGINAL argv (with --tol intact) вҖ” cmd_expr_float strips it
        cmd_expr_float(rest_in, fnm)
        return
    }
    // в”Җв”Җ VERIFY-KIT V2 (P0b) вҖ” value-less COMPUTE routing (int fns) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // Count operand args (exclude trailing --absorb/--no-absorb flags) and the
    // explicit --compute marker. COMPUTE fires when (a) --compute is present,
    // or (b) the operand list is len-3 (`--expr <fn> <n>`) вҖ” the canonical
    // OEIS Пғ(7) case (no int 0-op VERIFY form exists, so len-3 is unambiguous).
    // Multi-operand compute (`--expr gcd 12 8`) needs the explicit --compute
    // marker to stay unambiguous vs the 1-op VERIFY form `--expr <fn> <n> <v>`.
    let mut ops = 0
    let mut k = 1
    while k < len(rest) {
        let tk = to_string(rest[k])
        if tk != "--absorb" && tk != "--no-absorb" && tk != "--compute" { ops = ops + 1 }
        k = k + 1
    }
    // ops counts fn + operands; operand count = ops - 1.
    let force_compute = _has_compute(rest)
    if force_compute || ops == 2 {
        // ops==2 вҶ’ fn + 1 operand (len-3 1-op compute). force_compute honours
        // the marked arity (operand count = ops-1). cmd_expr_compute dispatches
        // on the operand count (1/2/3).
        let operand_ct = ops - 1
        cmd_expr_compute(rest, operand_ct)
        return
    }
    let mut got = NOCALC
    let mut label = ""
    let mut v = 0
    let n6 = len(rest) >= 6 && to_string(rest[5]) != "--absorb" && to_string(rest[5]) != "--no-absorb"
    let n5 = len(rest) >= 5 && to_string(rest[4]) != "--absorb" && to_string(rest[4]) != "--no-absorb"
    if n6 {
        // 3-operand: --expr <fn> <a> <b> <c> <v>  (tknn_chern p q r вҶ’ Chern t)
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        let c = to_int(to_string(rest[4]))
        v = to_int(to_string(rest[5]))
        got = _recompute3(fnm, a, b, c)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + "," + to_string(c) + ")=" + to_string(v)
    } else if n5 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        v = to_int(to_string(rest[4]))
        got = _recompute2(fnm, a, b)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + ")=" + to_string(v)
    } else {
        let nn = to_int(to_string(rest[2]))
        v = to_int(to_string(rest[3]))
        got = _recompute(fnm, nn)
        label = fnm + "(" + to_string(nn) + ")=" + to_string(v)
    }
    println("verify --expr " + label)
    if got == NOCALC {
        println("  tier   = рҹҹ  INSUFFICIENT")
        println("  reason = calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute (кі„мӮ°кё°мӢңмҠӨн…ң к°ңм„  нӣ„ліҙ)")
        return
    }
    if got == v {
        println("  calc   = " + to_string(got) + "  == expected " + to_string(v))
        println("  tier   = рҹ”ө SUPPORTED-FORMAL  (hexa-native closed-form, g_self_verify В· TECS-L Tier1)")
        // --absorb (legacy ledger path) вҖ” kept for backward-compat
        if _has_absorb(rest) {
            _absorb(label, fnm + " hexa-native recompute = " + to_string(got) + " == claimed " + to_string(v),
                    "[compiler invariant вҖ” hexa-native NT closed-form, g_self_verify]")
        }
        // DEFAULT auto-absorb-to-atlas (commons.tape @D g69 вҖ” domain
        // finalization gate). Opt-out with --no-absorb. Fires only on
        // рҹ”ө/рҹҹў (never рҹ”ҙ/рҹҹ  вҖ” no point folding falsified/deferred).
        if !_has_no_absorb(rest) {
            // build space-separated operand echo from the parsed args. We
            // emit just the operand list вҖ” the dispatch arity (n6/n5/else)
            // chooses how many operands; the atlas-register CLI then
            // re-routes via the generic verify-delegation adapter.
            let mut args_space = ""
            if len(rest) >= 6 && to_string(rest[5]) != "--absorb" && to_string(rest[5]) != "--no-absorb" {
                args_space = to_string(rest[2]) + " " + to_string(rest[3]) + " " + to_string(rest[4])
            } else if len(rest) >= 5 && to_string(rest[4]) != "--absorb" && to_string(rest[4]) != "--no-absorb" {
                args_space = to_string(rest[2]) + " " + to_string(rest[3])
            } else {
                args_space = to_string(rest[2])
            }
            _auto_absorb_via_atlas(fnm, args_space, to_string(v))
        }
    } else {
        // VERIFY-KIT V3 вҖ” OPT-IN round-tolerance for the int path too. An exact
        // int closed-form rarely needs tolerance, but a literature-rounded
        // INTEGER claim (or a coarse-grained expected value) can land within an
        // explicit <eps>. |got вҲ’ v| вүӨ tol (and tol was explicitly given) вҮ’ рҹҹў
        // round-tolerant. Beyond tol stays рҹ”ҙ вҖ” tolerance never launders a fail.
        let idiff = if got > v { got - v } else { v - got }
        let idiff_f = to_float(idiff)
        if tol_on && idiff_f <= tol {
            println("  calc   = " + to_string(got) + "  вүҲ expected " + to_string(v) + "  (within tol " + _fstr(tol) + ", calc=" + to_string(got) + " vs expected=" + to_string(v) + ", |О”|=" + to_string(idiff) + ")")
            println("  tier   = рҹҹў SUPPORTED-NUMERICAL  (round-tolerant: claim within opt-in --tol " + _fstr(tol) + ", TECS-L n6-rep Tier2)")
            // round-tolerant рҹҹў does NOT auto-absorb (the atlas folds the
            // engine's exact value, never the rounded operand).
        } else if tol_on {
            println("  calc   = " + to_string(got) + "  != expected " + to_string(v) + "  (|О”|=" + to_string(idiff) + " > tol=" + _fstr(tol) + ")")
            println("  tier   = рҹ”ҙ FALSIFIED  (disagrees beyond the stated --tol " + _fstr(tol) + " вҖ” tolerance does NOT launder failures, TECS-L result-agnostic closed negative)")
        } else {
            println("  calc   = " + to_string(got) + "  != expected " + to_string(v))
            println("  tier   = рҹ”ҙ FALSIFIED  (calc deterministically disagrees вҖ” TECS-L result-agnostic closed negative)")
        }
    }
}

fn cmd_fence(rest) {
    let mut claim = ""
    let mut i = 1
    while i < len(rest) {
        if i > 1 { claim = claim + " " }
        claim = claim + to_string(rest[i])
        i = i + 1
    }
    println("verify --fence")
    println("  claim  = " + claim)
    println("  tier   = вҡӘ SPECULATION-FENCED")
    println("  reason = imagination/metaphor class (hexa-bio AXIS) вҖ” verification")
    println("           N/A by design; NOT a proven atlas atom (g4 honest fence,")
    println("           SF вү  verified вҖ” atlas certification intrinsically N/A)")
}

// cmd_blue_max вҖ” BLUE-MAX рҹ”ө-pair audit for a domain (commons.tape @D g69 вҖ”
// domain finalization gate). Delegates to stdlib/verify/blue_max_audit.hexa
// (the pure-hexa audit kernel вҖ” also runnable directly via `hexa run`).
//
// Usage: hexa verify --blue-max <DOMAIN>
//
// Output: deterministic tier matrix table + рҹ”ө-pair coverage + verdict.
// Verdict line: вң… BLUE-MAX PASS (domain absorbed=true gate cleared) OR
// вҡ  MISSING-PAIRS: <list> (add integer-root рҹ”ө atom(s) per BLUE-MAX pattern).
fn cmd_blue_max(rest) {
    if len(rest) < 2 {
        println("error: usage: hexa verify --blue-max <DOMAIN>")
        println("       (e.g. ANTIMATTER В· NUCLEAR В· RTSC В· QMIRROR В· BIO)")
        exit(2)
    }
    let dom = to_string(rest[1])
    let out = to_string(exec("hexa run stdlib/verify/blue_max_audit.hexa " + dom + " 2>&1"))
    println(out)
}

fn main() {
    let a = _slice_args()
    if len(a) == 0 { cmd_rubric(); return }
    let sub = to_string(a[0])
    if sub == "rubric" || sub == "list" || sub == "help" || sub == "--help" || sub == "-h" {
        cmd_rubric()
    } else if sub == "--expr" {
        cmd_expr(a)
    } else if sub == "--fence" {
        cmd_fence(a)
    } else if sub == "--blue-max" {
        cmd_blue_max(a)
    } else {
        cmd_verify_id(a)
    }
}
