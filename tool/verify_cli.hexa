    //   permeability_skin(D, K, h)         3-arg: D·K/h
    //   auc_first_order(C0, ke)            2-arg: C0/ke
    //   clearance(dose, auc)               2-arg: dose/auc
    //   beer_lambert_log10(I0, ε, c, L)    4-arg: I0·10^(-ε·c·L)
    //   fluence(P, A, t)                   3-arg: P·t/A
    //   beam_waist(w0, z, zR)              3-arg: w0·sqrt(1+(z/zR)²)
    //   rayleigh_range(w0, λ)              2-arg: π·w0²/λ
    //   absorption_depth(α)                1-arg: 1/α
    if fn_name == "higuchi_flux" {
        if argc < 3 { return _NOCALC_F }
        return _higuchi_flux(a0, a1, a2)
    }
    if fn_name == "fick_steady_flux" {
        if argc < 2 { return _NOCALC_F }
        return _fick_steady_flux(a0, a1)
    }
    if fn_name == "partition_coeff" {
        if argc < 2 { return _NOCALC_F }
        return _partition_coeff(a0, a1)
    }
    if fn_name == "permeability_skin" {
        if argc < 3 { return _NOCALC_F }
        return _permeability_skin(a0, a1, a2)
    }
    if fn_name == "auc_first_order" {
        if argc < 2 { return _NOCALC_F }
        return _auc_first_order(a0, a1)
    }
    if fn_name == "clearance" {
        if argc < 2 { return _NOCALC_F }
        return _clearance(a0, a1)
    }
    if fn_name == "beer_lambert_log10" {
        if argc < 4 { return _NOCALC_F }
        return _beer_lambert_log10(a0, a1, a2, a3)
    }
    if fn_name == "fluence" {
        if argc < 3 { return _NOCALC_F }
        return _fluence(a0, a1, a2)
    }
    if fn_name == "beam_waist" {
        if argc < 3 { return _NOCALC_F }
        return _beam_waist(a0, a1, a2)
    }
    if fn_name == "rayleigh_range" {
        if argc < 2 { return _NOCALC_F }
        return _rayleigh_range(a0, a1)
    }
    if fn_name == "absorption_depth" {
        return _absorption_depth(a0)
    }
    // Penning-trap eigenmotion (ANTIMATTER capture - charged-particle 3-freq):
    //   penning_omega_plus(w_c, w_z)   2-arg: w_c/2 + sqrt((w_c/2)^2 - w_z^2/2)
    //   penning_omega_minus(w_c, w_z)  2-arg: w_c/2 - sqrt((w_c/2)^2 - w_z^2/2)
    //   penning_invariance(w_c, w_z)   2-arg: sqrt(w+^2 + w_z^2 + w-^2) == w_c
    if fn_name == "penning_omega_plus" {
        if argc < 2 { return _NOCALC_F }
        return _penning_omega_plus(a0, a1)
    }
    if fn_name == "penning_omega_minus" {
        if argc < 2 { return _NOCALC_F }
        return _penning_omega_minus(a0, a1)
    }
    if fn_name == "penning_invariance" {
        if argc < 2 { return _NOCALC_F }
        return _penning_invariance(a0, a1)
    }
    // ── Three-body recombination scaling (ANTIMATTER ⓹합성) ────────────
    //   recomb_3body_exponent()        0-arg: −9/2 = −4.5 (T-scaling exponent)
    //   recomb_3body_tratio(T_hi,T_lo) 2-arg: (T_hi/T_lo)^4.5 (α-ratio)
    if fn_name == "recomb_3body_exponent" { return _recomb_3body_exponent() }
    if fn_name == "recomb_3body_tratio" {
        if argc < 2 { return _NOCALC_F }
        return _recomb_3body_tratio(a0, a1)
    }
    // ── VERIFY-KIT V5.2 — faithful Φ recompute (stdlib iit4 engine) ─────
    //   phi_demo(case_id)  1-arg: recompute faithful Φ★ on a HARDCODED
    //   canonical small state (Option A — minimal wire, no farr CLI grammar).
    //   case 1 = a 3-node correlated state (Φ > 0); case 0 = a 3-node
    //   disconnected (independent-cell) control (Φ ≈ 0). The recompute calls
    //   iit4_faithful_phi (n<=8 exact MIP-EI); --tol gates the 🟢 numerical.
    if fn_name == "phi_demo" {
        return _phi_demo(to_int(a0))
    }
    // ── UFO — integrated-vehicle closed-form atoms (UFO/sim/decks) ──────
    //   ufo_isp_fuel_ratio(μ)  1-arg: γμβ |η=1 (F-ANTI-3 effective I_sp / c/g)
    //   ufo_rocket_beta(μ)     1-arg: √(1−1/γ²) |η=1 (relativistic exhaust β)
    //   ufo_gl_derating(r)     1-arg: 1−r² (HTS B(T)/B₀ thermal derating)
    //   ufo_mli_shield(N)      1-arg: 1/(N+1) (cryostat MLI radiation shield)
    if fn_name == "ufo_isp_fuel_ratio" { return _ufo_isp_fuel_ratio(a0) }
    if fn_name == "ufo_rocket_beta" { return _ufo_rocket_beta(a0) }
    if fn_name == "ufo_gl_derating" { return _ufo_gl_derating(a0) }
    if fn_name == "ufo_mli_shield" { return _ufo_mli_shield(a0) }
    // UFO V2 — n6-lattice formal-algebra (⚪ physics-fenced · exact integer identities)
    if fn_name == "ufo_lattice_sigma_pow" { return _ufo_lattice_sigma_pow(a0) }
    if fn_name == "ufo_warp_composite" { return _ufo_warp_composite(a0) }
    if fn_name == "ufo_lattice_master" { return _ufo_lattice_master(a0) }
    return _NOCALC_F
}

// _phi_demo — VERIFY-KIT V5.2 wire + V5.3 calibrate. Recompute faithful Φ★ on
// a hardcoded canonical n×dim state via the promoted stdlib engine
// (faithful_phi.hexa). Option A: the state is BUILT IN-FN (no comma-sep CLI
// grammar) so the wire proves end-to-end recompute without a farr verb. n_bins=4.
//
//   case 1 — 3 cells × 6 dim-steps, cells 0/1/2 strongly co-varying
//            (the SAME ramp): high pairwise MI ⇒ every cut is costly ⇒ Φ★ > 0.
//   case 0 — 3 cells × 6 dim-steps, cell 2 is a CONSTANT (zero MI to all):
//            the MIP isolates cell 2 at cut cost ≈ 0 ⇒ Φ★ ≈ 0 (control).
//
// V5.3 CALIBRATION (.verdicts/verify-kit-iit-calibrate/v5_3.txt):
//   case-1 Φ★ = 3.83659 is now ANCHORED to an INDEPENDENT same-substrate
//   reference — a from-spec Python reimplementation of the MI-MIP algorithm
//   reproduces 3.836592 (|Δ| = 1.67e-06, within tol 1e-3). So 3.83659 is no
//   longer just the engine's self-value; it is independently confirmed.
//   HONEST: this is a continuous-MI INTEGRATION PROXY, NOT PyPhi discrete-TPM
//   IIT 4.0. PyPhi's canonical small-system Φ = 2.3125 (basic_network) is a
//   DIFFERENT quantity over a DIFFERENT substrate (cause-effect TPM, not
//   pairwise-MI of a trajectory) — by construction they do not coincide.
fn _phi_demo(case_id: int) -> float {
    let n = 3
    let dim = 6
    let n_bins = 4
    let state = farr_zeros(n * dim)
    if case_id == 0 {
        // control — cells 0,1 co-vary (a ramp); cell 2 is constant ⇒ MI≈0.
        let _ = farr_set(state, 0 * dim + 0, 0.0)
        let _ = farr_set(state, 0 * dim + 1, 1.0)
        let _ = farr_set(state, 0 * dim + 2, 2.0)
        let _ = farr_set(state, 0 * dim + 3, 3.0)
        let _ = farr_set(state, 0 * dim + 4, 4.0)
        let _ = farr_set(state, 0 * dim + 5, 5.0)
        let _ = farr_set(state, 1 * dim + 0, 0.0)
        let _ = farr_set(state, 1 * dim + 1, 1.0)
        let _ = farr_set(state, 1 * dim + 2, 2.0)
        let _ = farr_set(state, 1 * dim + 3, 3.0)
        let _ = farr_set(state, 1 * dim + 4, 4.0)
        let _ = farr_set(state, 1 * dim + 5, 5.0)
        // cell 2 constant 7.0 across all steps ⇒ zero variance ⇒ MI 0 to all.
        let mut d = 0
        while d < dim { let _ = farr_set(state, 2 * dim + d, 7.0); d = d + 1 }
    } else {
        // case 1 (default) — all 3 cells follow the SAME ramp ⇒ high pairwise
        // MI on every pair ⇒ no cheap cut ⇒ faithful Φ★ > 0.
        let mut c = 0
        while c < n {
            let mut d = 0
            while d < dim {
                let _ = farr_set(state, c * dim + d, d * 1.0)
                d = d + 1
            }
            c = c + 1
        }
    }
    let phi = iit4_faithful_phi(state, n, dim, n_bins)
    let _ = farr_free(state)
    return phi
}

// WIPE-OK: float membership predicates hoisted to the shared SSOT
// compiler/atlas/calc_dispatch (calc_is_float_fn / calc_is_zero_arg_float_fn),
// which BOTH verify_cli and atlas_cli `use`. The local _is_float_fn /
// _is_zero_arg_float_fn copies are removed — adding a float fn now needs ONE
// edit (calc_dispatch's table), never a verify↔atlas mirror sync. Call sites
// above were repointed to calc_is_float_fn() / calc_is_zero_arg_float_fn().

// trim trailing zeros of a float→string for tidy verdict echo.
fn _fstr(x: float) -> string {
    return to_string(x)
}

// nodes_of_kind — return the per-kind bucket of an AtlasIndex by kind
// letter (P|C|L|E|F|R|S|X|Q). Mirrors static_index field layout; kept
// local so verify_cli stays a single `main`-bearing tool.
fn nodes_of_kind(idx, kind: string) -> array {
    if kind == "P" { return idx.p_nodes }
    if kind == "C" { return idx.c_nodes }
    if kind == "L" { return idx.l_nodes }
    if kind == "E" { return idx.e_nodes }
    if kind == "F" { return idx.f_nodes }
    if kind == "R" { return idx.r_nodes }
    if kind == "S" { return idx.s_nodes }
    if kind == "X" { return idx.x_nodes }
    if kind == "Q" { return idx.q_nodes }
    return []
}

// extract trailing "= <int>" claimed value from a raw header before "::".
fn _claimed_value(raw: string) -> int {
    let mut head = raw
    let ci = head.index_of("::")
    if ci >= 0 { head = head.slice(0, ci) }
    // last '=' segment
    let mut last = ""
    let parts = head.split("=")
    if len(parts) >= 2 {
        last = parts[len(parts) - 1]
    }
    let t = last.trim()
    return to_int(t)
}

fn cmd_verify_id(rest) {
    if len(rest) < 1 {
        println("error: usage: hexa verify <id>")
        exit(2)
    }
    let target = to_string(rest[0])
    // hxc retired 2026-05-22: pull the bucketed AtlasIndex from static_atlas
    // (which parses n6/atlas.n6 via the merger) and walk all 9 kinds.
    let idx = static_atlas()
    let total = len(idx.p_nodes) + len(idx.c_nodes) + len(idx.l_nodes) + len(idx.e_nodes) + len(idx.f_nodes) + len(idx.r_nodes) + len(idx.s_nodes) + len(idx.x_nodes) + len(idx.q_nodes)
    if total == 0 {
        println("verify " + target)
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = atlas (n6/atlas.n6) empty/absent")
        return
    }
    let kinds = ["P", "C", "L", "E", "F", "R", "S", "X", "Q"]
    let mut found = false
    let mut nraw = ""
    let mut nkind = ""
    let mut ki = 0
    while ki < len(kinds) && !found {
        let bucket = nodes_of_kind(idx, kinds[ki])
        let mut i = 0
        while i < len(bucket) {
            let nd = bucket[i]
            if nd.id == target {
                found = true
                nraw = nd.raw
                nkind = nd.kind
                i = len(bucket)
            } else {
                i = i + 1
            }
        }
        ki = ki + 1
    }
    println("verify " + target + "   (atlas: " + to_string(total) + " nodes from atlas.n6)")
    if !found {
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = id not in atlas; no closed-form to recompute")
        return
    }
    println("  atlas  = @" + nkind + " " + target + " (registered)")
    // try hexa-native recompute: find a known fn(6) form in raw
    let claimed = _claimed_value(nraw)
    let mut fnm = ""
    if nraw.contains("divisor_sum") { fnm = "divisor_sum" }
    else if nraw.contains("euler_totient") { fnm = "euler_totient" }
    else if nraw.contains("divisor_count") { fnm = "divisor_count" }
    else if nraw.contains("mobius") { fnm = "mobius" }
    if len(fnm) == 0 {
        println("  tier   = 🟡 SUPPORTED-BY-CITATION")
        println("  reason = atlas-registered; no hexa-native calc path for this form")
        return
    }
    let got = _recompute(fnm, 6)
    if got == claimed && claimed != NOCALC {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  == claimed " + to_string(claimed))
        println("  tier   = 🔵 SUPPORTED-FORMAL")
        println("  reason = hexa-native closed-form reproduced (g_self_verify · TECS-L Tier1)")
        if _has_absorb(rest) {
            _absorb(target + " = " + to_string(claimed),
                    "@" + nkind + " " + target + " · " + fnm + "(6)=" + to_string(got) + " == atlas-claimed " + to_string(claimed),
                    "[compiler invariant — hexa-native NT closed-form, g_self_verify]")
        }
    } else if claimed == NOCALC {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  vs claimed (unparsed)")
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = claimed value unparsed from raw — cannot adjudicate")
    } else {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  != claimed " + to_string(claimed))
        println("  tier   = 🔴 FALSIFIED")
        println("  reason = hexa-native calc DETERMINISTICALLY disagrees with the claim —")
        println("           closed negative (TECS-L result-agnostic; ≠ INSUFFICIENT)")
    }
}

// cmd_expr_float — the 🟢 NUMERICAL path. fn_name is a registered float
// transform (welch_t_crit · wilson_hilferty_p · chsh_tsirelson · hardy_bound
// · exp_release · ldl_pct · beer_lambert · nnt · arr · ln_hr_to_hr
// · hill · cheng_prusoff · fick1 · laplace · stokes_einstein
// · higuchi · tafel · hagen_poiseuille).
// Args + claimed value are parsed as floats; the recompute is compared with
// tolerance ε (NOT exact-eq, the honest libm-class gate). Within ε →
// 🟢 SUPPORTED-NUMERICAL; deterministic out-of-ε → 🔴 FALSIFIED.
//   0-arg:  --expr <fn> <v>                         (rest len 3; closed-form constant)
//   1-arg:  --expr <fn> <a0> <v>                    (rest len 4)
//   2-arg:  --expr <fn> <a0> <a1> <v>               (rest len 5)
//   3-arg:  --expr <fn> <a0> <a1> <a2> <v>          (rest len 6; bio Phase 1/2)
//   4-arg:  --expr <fn> <a0> <a1> <a2> <a3> <v>     (rest len 7; bio Phase 3 — hagen_poiseuille)
// cmd_expr_float_compute — VERIFY-KIT V1 value-less COMPUTE mode for float
// fns (the float counterpart of cmd_expr_compute). The legacy cmd_expr_float
// always consumes the trailing operand as the EXPECTED value <v>, so a 3-arg
// float fn invoked with its 3 operands (no <v>) was mis-parsed as a 2-arg
// VERIFY (the 3rd operand swallowed as <v>) — the allen_dynes_tc(λ,ω_log,μ*)
// arity gap. With --compute every non-flag operand after the fn name is an
// ARG, the value is COMPUTED via the SAME _recompute_float helper, and the
// result is printed `COMPUTE: <fn>(<args>) = <value>` + self-verified twice.
// This is the delegation target for `atlas register --from-verify` — register
// shells out in compute mode so it never needs its own recompute mirror.
fn cmd_expr_float_compute(rest, fnm: string) {
    // collect non-flag operand strings after the fn name (rest[0]=--expr,
    // rest[1]=fn, rest[2..]=operands ∪ flags).
    let mut ops_str: array = []
    let mut k = 2
    while k < len(rest) {
        let tk = to_string(rest[k])
        if tk != "--absorb" && tk != "--no-absorb" && tk != "--compute" { ops_str.push(tk) }
        k = k + 1
    }
    let argc = len(ops_str)
    let mut a0 = 0.0
    let mut a1 = 0.0
    let mut a2 = 0.0
    let mut a3 = 0.0
    if argc >= 1 { a0 = _parse_float(to_string(ops_str[0])) }
    if argc >= 2 { a1 = _parse_float(to_string(ops_str[1])) }
    if argc >= 3 { a2 = _parse_float(to_string(ops_str[2])) }
    if argc >= 4 { a3 = _parse_float(to_string(ops_str[3])) }
    let mut arg_echo = ""
    if argc >= 1 { arg_echo = _fstr(a0) }
    if argc >= 2 { arg_echo = arg_echo + "," + _fstr(a1) }
    if argc >= 3 { arg_echo = arg_echo + "," + _fstr(a2) }
    if argc >= 4 { arg_echo = arg_echo + "," + _fstr(a3) }
    let label = fnm + "(" + arg_echo + ")"
    let got = _recompute_float(fnm, a0, a1, a2, a3, argc)
    if got == _NOCALC_F {
        println("verify --expr " + label + "  (compute mode)")
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = float calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute_float (계산기시스템 개선 후보)")
        return
    }
    // self-verify: recompute a SECOND time — deterministic calc MUST agree.
    let got2 = _recompute_float(fnm, a0, a1, a2, a3, argc)
    // INBOX #1910 fix-at-source — the COMPUTE line is the canonical handoff
    // to `atlas register --from-verify` (cmd_expr_float_compute is its
    // delegation target; see _adapt_verify_compute in tool/atlas_cli.hexa).
    // `_fstr(got)` returns the %g 6-sig-fig display form (e.g. 227.501),
    // which is fine for human eyes but lossy for the round-trip atlas needs:
    // _is_rounding_of(claimed, engine) gates a rounded literal as a plausible
    // rounding of the engine value, and only works when the engine value is
    // the EXACT recomputed double (not its display rounding).  We append a
    // `[raw=<full-precision>]` suffix using json_stringify, which routes to
    // _shortest_double() in self/runtime.c (the shortest %g form that
    // strtod-round-trips to the same double — matches CPython repr() /
    // json.dumps() shortest representation).  atlas_cli's
    // _parse_compute_value PREFERS the [raw=...] suffix when present and
    // falls back to the post-`=` tail otherwise (back-compat for any caller
    // that hasn't been upgraded).  Pure echo change — no recompute touched.
    println("COMPUTE: " + label + " = " + _fstr(got) + " [raw=" + json_stringify(got) + "]")
    if _fabs(got - got2) <= calc_eps() {
        println("  tier   = 🟢 SUPPORTED-NUMERICAL  (hexa-native libm-class compute, self-verified deterministic · g_self_verify · TECS-L n6-rep Tier2)")
    } else {
        println("  tier   = 🔴 FALSIFIED  (recompute non-deterministic: " + _fstr(got) + " vs " + _fstr(got2) + " — calculator bug)")
    }
}

fn cmd_expr_float(rest_in, fnm: string) {
    // VERIFY-KIT V3 — capture the OPT-IN round-tolerance, then strip the
    // `--tol <eps>` flag pair so the arity detection (has5/has6/has7) below is
    // not skewed by the two extra tokens. tol == 0.0 ⇒ no tolerance ⇒ the
    // STRICT ε=1e-9 gate is preserved (current behavior, unchanged).
    let tol = _get_tol(rest_in)
    let tol_on = _has_tol(rest_in)
    let rest = _strip_tol(rest_in)
    let zero_arg = calc_is_zero_arg_float_fn(fnm)
    // VERIFY-KIT V1 — explicit value-less COMPUTE marker routes BEFORE the
    // VERIFY arity parse (which would swallow the last operand as <v>). 0-arg
    // constants keep their `--expr <fn> <v>` VERIFY form, so --compute on a
    // 0-arg fn (no operands at all) still falls through to compute argc=0.
    if _has_compute(rest) {
        cmd_expr_float_compute(rest, fnm)
        return
    }
    let has7 = len(rest) >= 7 && to_string(rest[6]) != "--absorb" && to_string(rest[6]) != "--no-absorb"
    let has6 = len(rest) >= 6 && to_string(rest[5]) != "--absorb" && to_string(rest[5]) != "--no-absorb"
    let has5 = len(rest) >= 5 && to_string(rest[4]) != "--absorb" && to_string(rest[4]) != "--no-absorb"
    let mut a0 = 0.0
    let mut a1 = 0.0
    let mut a2 = 0.0
    let mut a3 = 0.0
    let mut v = 0.0
    let mut argc = 1
    let mut label = ""
    if zero_arg {
        v = _parse_float(to_string(rest[2]))
        argc = 0
        label = fnm + "()=" + _fstr(v)
    } else if has7 {
        a0 = _parse_float(to_string(rest[2]))
        a1 = _parse_float(to_string(rest[3]))
        a2 = _parse_float(to_string(rest[4]))
        a3 = _parse_float(to_string(rest[5]))
        v = _parse_float(to_string(rest[6]))
        argc = 4
        label = fnm + "(" + _fstr(a0) + "," + _fstr(a1) + "," + _fstr(a2) + "," + _fstr(a3) + ")=" + _fstr(v)
    } else if has6 {
        a0 = _parse_float(to_string(rest[2]))
        a1 = _parse_float(to_string(rest[3]))
        a2 = _parse_float(to_string(rest[4]))
        v = _parse_float(to_string(rest[5]))
        argc = 3
        label = fnm + "(" + _fstr(a0) + "," + _fstr(a1) + "," + _fstr(a2) + ")=" + _fstr(v)
    } else if has5 {
        a0 = _parse_float(to_string(rest[2]))
        a1 = _parse_float(to_string(rest[3]))
        v = _parse_float(to_string(rest[4]))
        argc = 2
        label = fnm + "(" + _fstr(a0) + "," + _fstr(a1) + ")=" + _fstr(v)
    } else {
        a0 = _parse_float(to_string(rest[2]))
        v = _parse_float(to_string(rest[3]))
        argc = 1
        label = fnm + "(" + _fstr(a0) + ")=" + _fstr(v)
    }
    let got = _recompute_float(fnm, a0, a1, a2, a3, argc)
    println("verify --expr " + label)
    if got == _NOCALC_F {
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = float calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute_float (계산기시스템 개선 후보)")
        return
    }
    let diff = _fabs(got - v)
    if diff <= calc_eps() {
        println("  calc   = " + _fstr(got) + "  ≈ expected " + _fstr(v) + "  (|Δ|=" + _fstr(diff) + " ≤ ε=1e-9)")
        println("  tier   = 🟢 SUPPORTED-NUMERICAL  (hexa-native libm-class recompute, TECS-L n6-rep Tier2)")
        // --absorb (legacy ledger path) — kept for backward-compat
        if _has_absorb(rest) {
            _absorb(label, fnm + " hexa-native numerical recompute = " + _fstr(got) + " ≈ claimed " + _fstr(v) + " (|Δ|=" + _fstr(diff) + " ≤ 1e-9)",
                    "[numerical transform — hexa-native libm-class recompute, TECS-L Tier2]")
        }
        // DEFAULT auto-absorb-to-atlas (commons.tape @D g69). Opt-out with
        // --no-absorb. Mirrors cmd_expr arity dispatch above to assemble the
        // operand list + claimed-value echo for `hexa atlas register`.
        if !_has_no_absorb(rest) {
            let mut args_space = ""
            if zero_arg {
                args_space = ""    // 0-arg constant: empty operand list
            } else if has7 {
                args_space = to_string(rest[2]) + " " + to_string(rest[3]) + " " + to_string(rest[4]) + " " + to_string(rest[5])
            } else if has6 {
                args_space = to_string(rest[2]) + " " + to_string(rest[3]) + " " + to_string(rest[4])
            } else if has5 {
                args_space = to_string(rest[2]) + " " + to_string(rest[3])
            } else {
                args_space = to_string(rest[2])
            }
            let mut v_str = ""
            if zero_arg { v_str = to_string(rest[2]) }
            else if has7 { v_str = to_string(rest[6]) }
            else if has6 { v_str = to_string(rest[5]) }
            else if has5 { v_str = to_string(rest[4]) }
            else { v_str = to_string(rest[3]) }
            _auto_absorb_via_atlas(fnm, args_space, v_str)
        }
    } else if tol_on && diff <= tol {
        // VERIFY-KIT V3 — OPT-IN round-tolerance band: the claim is OUTSIDE the
        // strict ε=1e-9 gate but WITHIN the explicitly-stated <eps>. This is the
        // literature-rounding case (e.g. Tc=14.55 vs the engine's 14.5511) — a
        // 6-digit-rounded value, NOT a real falsification. Emit 🟢 with an
        // explicit within-tol note. Tolerance is opt-in for literature-rounded
        // comparisons, NOT a way to launder failures.
        println("  calc   = " + _fstr(got) + "  ≈ expected " + _fstr(v) + "  (within tol " + _fstr(tol) + ", calc=" + _fstr(got) + " vs expected=" + _fstr(v) + ", |Δ|=" + _fstr(diff) + ")")
        println("  tier   = 🟢 SUPPORTED-NUMERICAL  (round-tolerant: literature-rounded value within opt-in --tol " + _fstr(tol) + ", TECS-L n6-rep Tier2)")
        // NOTE: round-tolerant 🟢 does NOT auto-absorb — the atlas SSOT folds the
        // ENGINE's full-precision value via its own compute path (VERIFY-KIT V1),
        // never the literature-rounded operand. So no _absorb / auto-absorb here.
    } else {
        // STRICT 🔴: deterministic disagreement BEYOND ε (and beyond <tol> when
        // --tol was given). A 🔴 past the stated eps stays 🔴 — falsification
        // integrity preserved.
        if tol_on {
            println("  calc   = " + _fstr(got) + "  ≠ expected " + _fstr(v) + "  (|Δ|=" + _fstr(diff) + " > tol=" + _fstr(tol) + ")")
            println("  tier   = 🔴 FALSIFIED  (disagrees beyond the stated --tol " + _fstr(tol) + " — tolerance does NOT launder failures, TECS-L result-agnostic closed negative)")
        } else {
            println("  calc   = " + _fstr(got) + "  ≠ expected " + _fstr(v) + "  (|Δ|=" + _fstr(diff) + " > ε=1e-9)")
            println("  tier   = 🔴 FALSIFIED  (calc deterministically disagrees beyond ε — TECS-L result-agnostic closed negative)")
        }
    }
}

// cmd_expr_compute — VERIFY-KIT V2 (P0b): VALUE-LESS COMPUTE MODE.
//
// The legacy `--expr` forms all require the EXPECTED value <v> as the trailing
// operand — so the CLI can only RE-CONFIRM a known value, never COMPUTE a
// fresh one. catalogue-mirror sweeps (OEIS/DLMF/ARXIV) that want `σ(7)=?`
// hit this wall. V2 adds a value-less form: drop the trailing <v> and the CLI
// computes + prints the value via the SAME `_recompute*` helper, then
// self-verifies (recompute twice → must be deterministic).
//
//   1-operand compute:  --expr <fn> <n>          (rest len 3)
//   2-operand compute:  --expr <fn> <a> <b>      (rest len 4)
//   3-operand compute:  --expr <fn> <a> <b> <c>  (rest len 5)
//
// DISAMBIGUATION RULE (operand-count): the compute form is the verify form
// with EXACTLY ONE FEWER operand (the trailing <v> omitted). So `--expr sigma
// 7` (len 3) = COMPUTE σ(7); `--expr sigma 7 8` (len 4) = VERIFY σ(7)==8.
// For 2-operand fns: `--expr gcd 12 8` (len 4) = COMPUTE gcd(12,8); `--expr
// gcd 12 8 4` (len 5) = VERIFY gcd(12,8)==4. The single len-3 collision with
// the 0-arg float VERIFY form (`--expr chsh_tsirelson <v>`) is already routed
// AWAY before this helper runs (cmd_expr sends 0-arg float fns to the float
// path), so the int compute path is unambiguous.
//
// Output: `COMPUTE: <fn>(<args>) = <value>` (no atlas auto-absorb — compute
// is a read; absorb stays on the value-bearing verify forms only).
fn cmd_expr_compute(rest, ops: int) {
    let fnm = to_string(rest[1])
    let mut got = NOCALC
    let mut label = ""
    if ops == 3 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        let c = to_int(to_string(rest[4]))
        got = _recompute3(fnm, a, b, c)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + "," + to_string(c) + ")"
    } else if ops == 2 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        got = _recompute2(fnm, a, b)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + ")"
    } else {
        let nn = to_int(to_string(rest[2]))
        got = _recompute(fnm, nn)
        label = fnm + "(" + to_string(nn) + ")"
    }
    if got == NOCALC {
        println("verify --expr " + label + "  (compute mode)")
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute (계산기시스템 개선 후보)")
        return
    }
    // self-verify: recompute a SECOND time — deterministic calc MUST agree.
    let mut got2 = NOCALC
    if ops == 3 {
        got2 = _recompute3(fnm, to_int(to_string(rest[2])), to_int(to_string(rest[3])), to_int(to_string(rest[4])))
    } else if ops == 2 {
        got2 = _recompute2(fnm, to_int(to_string(rest[2])), to_int(to_string(rest[3])))
    } else {
        got2 = _recompute(fnm, to_int(to_string(rest[2])))
    }
    println("COMPUTE: " + label + " = " + to_string(got))
    if got2 == got {
        println("  tier   = 🔵 SUPPORTED-FORMAL  (hexa-native closed-form compute, self-verified deterministic · g_self_verify · TECS-L Tier1)")
    } else {
        println("  tier   = 🔴 FALSIFIED  (recompute non-deterministic: " + to_string(got) + " vs " + to_string(got2) + " — calculator bug)")
    }
}

fn cmd_expr(rest_in) {
    // 0-operand:  --expr <fn> <v>                    (rest len 3; chsh_tsirelson)
    // 1-operand:  --expr <fn> <n> <v>                (rest len 4)
    // 2-operand:  --expr <fn> <a> <b> <v>            (rest len 5)
    // 3-operand:  --expr <fn> <a> <b> <c> <v>        (rest len 6)
    // 4-operand:  --expr <fn> <a> <b> <c> <d> <v>    (rest len 7; bio Phase 3 hagen_poiseuille)
    //
    // VERIFY-KIT V2 — VALUE-LESS COMPUTE MODE (the verify form minus its
    // trailing <v>): `--expr <fn> <n>` computes & prints fn(n) instead of
    // re-confirming a known value. See cmd_expr_compute for the disambiguation
    // rule. Routed below AFTER the float path so float fns keep their forms.
    //
    // VERIFY-KIT V3 — capture the OPT-IN `--tol <eps>` round-tolerance, then
    // operate on a STRIPPED copy of argv so the operand-count / arity detection
    // is not skewed by the two extra `--tol <eps>` tokens. The float path
    // (cmd_expr_float) strips internally too — pass it the ORIGINAL argv so the
    // flag survives the call boundary. tol == 0.0 ⇒ STRICT (current behavior).
    let tol = _get_tol(rest_in)
    let tol_on = _has_tol(rest_in)
    let rest = _strip_tol(rest_in)
    let fnm_pre = if len(rest) >= 2 { to_string(rest[1]) } else { "" }
    let zero_arg_pre = calc_is_zero_arg_float_fn(fnm_pre)
    if len(rest) < 3 {
        println("error: usage: hexa verify --expr <fn> <n> [<v>]  |  <fn> <a> <b> [<v>]  [--absorb] [--tol <eps>]")
        println("       (compute mode: omit <v> to COMPUTE; provide <v> to VERIFY)")
        exit(2)
    }
    let fnm = to_string(rest[1])
    // float-NUMERICAL forms (welch_t_crit · wilson_hilferty_p · chsh_tsirelson
    // · hardy_bound) route to the 🟢 path BEFORE the int parser truncates
    // real-valued args. (Float fns include the only int-shaped len-3 VERIFY
    // collision — the 0-arg constants like chsh_tsirelson — so once float fns
    // are routed away, the int compute path below is unambiguous.)
    if calc_is_float_fn(fnm) {
        // pass the ORIGINAL argv (with --tol intact) — cmd_expr_float strips it
        cmd_expr_float(rest_in, fnm)
        return
    }
    // ── VERIFY-KIT V2 (P0b) — value-less COMPUTE routing (int fns) ──────────
    // Count operand args (exclude trailing --absorb/--no-absorb flags) and the
    // explicit --compute marker. COMPUTE fires when (a) --compute is present,
    // or (b) the operand list is len-3 (`--expr <fn> <n>`) — the canonical
    // OEIS σ(7) case (no int 0-op VERIFY form exists, so len-3 is unambiguous).
    // Multi-operand compute (`--expr gcd 12 8`) needs the explicit --compute
    // marker to stay unambiguous vs the 1-op VERIFY form `--expr <fn> <n> <v>`.
    let mut ops = 0
    let mut k = 1
    while k < len(rest) {
        let tk = to_string(rest[k])
        if tk != "--absorb" && tk != "--no-absorb" && tk != "--compute" { ops = ops + 1 }
        k = k + 1
    }
    // ops counts fn + operands; operand count = ops - 1.
    let force_compute = _has_compute(rest)
    if force_compute || ops == 2 {
        // ops==2 → fn + 1 operand (len-3 1-op compute). force_compute honours
        // the marked arity (operand count = ops-1). cmd_expr_compute dispatches
        // on the operand count (1/2/3).
        let operand_ct = ops - 1
        cmd_expr_compute(rest, operand_ct)
        return
    }
    let mut got = NOCALC
    let mut label = ""
    let mut v = 0
    let n6 = len(rest) >= 6 && to_string(rest[5]) != "--absorb" && to_string(rest[5]) != "--no-absorb"
    let n5 = len(rest) >= 5 && to_string(rest[4]) != "--absorb" && to_string(rest[4]) != "--no-absorb"
    if n6 {
        // 3-operand: --expr <fn> <a> <b> <c> <v>  (tknn_chern p q r → Chern t)
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        let c = to_int(to_string(rest[4]))
        v = to_int(to_string(rest[5]))
        got = _recompute3(fnm, a, b, c)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + "," + to_string(c) + ")=" + to_string(v)
    } else if n5 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        v = to_int(to_string(rest[4]))
        got = _recompute2(fnm, a, b)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + ")=" + to_string(v)
    } else {
        let nn = to_int(to_string(rest[2]))
        v = to_int(to_string(rest[3]))
        got = _recompute(fnm, nn)
        label = fnm + "(" + to_string(nn) + ")=" + to_string(v)
    }
    println("verify --expr " + label)
    if got == NOCALC {
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute (계산기시스템 개선 후보)")
        return
    }
    if got == v {
        println("  calc   = " + to_string(got) + "  == expected " + to_string(v))
        println("  tier   = 🔵 SUPPORTED-FORMAL  (hexa-native closed-form, g_self_verify · TECS-L Tier1)")
        // --absorb (legacy ledger path) — kept for backward-compat
        if _has_absorb(rest) {
            _absorb(label, fnm + " hexa-native recompute = " + to_string(got) + " == claimed " + to_string(v),
                    "[compiler invariant — hexa-native NT closed-form, g_self_verify]")
        }
        // DEFAULT auto-absorb-to-atlas (commons.tape @D g69 — domain
        // finalization gate). Opt-out with --no-absorb. Fires only on
        // 🔵/🟢 (never 🔴/🟠 — no point folding falsified/deferred).
        if !_has_no_absorb(rest) {
            // build space-separated operand echo from the parsed args. We
            // emit just the operand list — the dispatch arity (n6/n5/else)
            // chooses how many operands; the atlas-register CLI then
            // re-routes via the generic verify-delegation adapter.
            let mut args_space = ""
            if len(rest) >= 6 && to_string(rest[5]) != "--absorb" && to_string(rest[5]) != "--no-absorb" {
                args_space = to_string(rest[2]) + " " + to_string(rest[3]) + " " + to_string(rest[4])
            } else if len(rest) >= 5 && to_string(rest[4]) != "--absorb" && to_string(rest[4]) != "--no-absorb" {
                args_space = to_string(rest[2]) + " " + to_string(rest[3])
            } else {
                args_space = to_string(rest[2])
            }
            _auto_absorb_via_atlas(fnm, args_space, to_string(v))
        }
    } else {
        // VERIFY-KIT V3 — OPT-IN round-tolerance for the int path too. An exact
        // int closed-form rarely needs tolerance, but a literature-rounded
        // INTEGER claim (or a coarse-grained expected value) can land within an
        // explicit <eps>. |got − v| ≤ tol (and tol was explicitly given) ⇒ 🟢
        // round-tolerant. Beyond tol stays 🔴 — tolerance never launders a fail.
        let idiff = if got > v { got - v } else { v - got }
        let idiff_f = to_float(idiff)
        if tol_on && idiff_f <= tol {
            println("  calc   = " + to_string(got) + "  ≈ expected " + to_string(v) + "  (within tol " + _fstr(tol) + ", calc=" + to_string(got) + " vs expected=" + to_string(v) + ", |Δ|=" + to_string(idiff) + ")")
            println("  tier   = 🟢 SUPPORTED-NUMERICAL  (round-tolerant: claim within opt-in --tol " + _fstr(tol) + ", TECS-L n6-rep Tier2)")
            // round-tolerant 🟢 does NOT auto-absorb (the atlas folds the
            // engine's exact value, never the rounded operand).
        } else if tol_on {
            println("  calc   = " + to_string(got) + "  != expected " + to_string(v) + "  (|Δ|=" + to_string(idiff) + " > tol=" + _fstr(tol) + ")")
            println("  tier   = 🔴 FALSIFIED  (disagrees beyond the stated --tol " + _fstr(tol) + " — tolerance does NOT launder failures, TECS-L result-agnostic closed negative)")
        } else {
            println("  calc   = " + to_string(got) + "  != expected " + to_string(v))
            println("  tier   = 🔴 FALSIFIED  (calc deterministically disagrees — TECS-L result-agnostic closed negative)")
        }
    }
}

fn cmd_fence(rest) {
    let mut claim = ""
    let mut i = 1
    while i < len(rest) {
        if i > 1 { claim = claim + " " }
        claim = claim + to_string(rest[i])
        i = i + 1
    }
    println("verify --fence")
    println("  claim  = " + claim)
    println("  tier   = ⚪ SPECULATION-FENCED")
    println("  reason = imagination/metaphor class (hexa-bio AXIS) — verification")
    println("           N/A by design; NOT a proven atlas atom (g4 honest fence,")
    println("           SF ≠ verified — atlas certification intrinsically N/A)")
}

// cmd_blue_max — BLUE-MAX 🔵-pair audit for a domain (commons.tape @D g69 —
// domain finalization gate). Delegates to stdlib/verify/blue_max_audit.hexa
// (the pure-hexa audit kernel — also runnable directly via `hexa run`).
//
// Usage: hexa verify --blue-max <DOMAIN>
//
// Output: deterministic tier matrix table + 🔵-pair coverage + verdict.
// Verdict line: ✅ BLUE-MAX PASS (domain absorbed=true gate cleared) OR
// ⚠ MISSING-PAIRS: <list> (add integer-root 🔵 atom(s) per BLUE-MAX pattern).
fn cmd_blue_max(rest) {
    if len(rest) < 2 {
        println("error: usage: hexa verify --blue-max <DOMAIN>")
        println("       (e.g. ANTIMATTER · NUCLEAR · RTSC · QMIRROR · BIO)")
        exit(2)
    }
    let dom = to_string(rest[1])
    let out = to_string(exec("hexa run stdlib/verify/blue_max_audit.hexa " + dom + " 2>&1"))
    println(out)
}

// cmd_verifier — VERIFY-KIT V8: PLUGGABLE EXTERNAL verifier arm.
//
// `hexa verify --verifier-cmd "<sh-cmd>" --claim "<text>" [--expect "<str>"]`
//
// Connects `hexa verify` to the phanes "tenants bring a verifier" model: a
// domain/tenant plugs its OWN deterministic checker; hexa delegates to it and
// maps its result to a tier. The external command IS the verifier — hexa
// records its verdict VERBATIM and self-judges NOTHING (g5: no LLM judge).
//
// Tier mapping (deterministic, result-agnostic per TECS-L):
//   exit 0, no --expect              → 🟢 SUPPORTED-NUMERICAL (verifier passed)
//   exit 0, --expect matches stdout  → 🟢 SUPPORTED-NUMERICAL
//   exit 0, --expect MISmatch stdout → 🔴 FALSIFIED (expected-string disagrees)
//   exit 1..126 (nonzero)            → 🔴 FALSIFIED (verifier rejected — closed neg)
//   exit 127 / fork / pipe error     → 🟠 INSUFFICIENT (no verifier path / error)
//
// The external verifier MUST be deterministic (same input → same verdict);
// a nondeterministic cmd voids the tier. No auto-absorb: a tenant's external
// verdict is delegated, not an atlas-certified hexa-native recompute.
fn cmd_verifier(rest) {
    // rest[0] = "--verifier-cmd"; scan the remaining tokens for the cmd +
    // --claim + --expect, tolerating any token order.
    let mut vcmd = ""
    let mut claim = ""
    let mut expect = ""
    let mut have_expect = false
    let mut i = 1
    while i < len(rest) {
        let tok = to_string(rest[i])
        if tok == "--verifier-cmd" && i + 1 < len(rest) {
            vcmd = to_string(rest[i + 1])
            i = i + 2
        } else if tok == "--claim" && i + 1 < len(rest) {
            claim = to_string(rest[i + 1])
            i = i + 2
        } else if tok == "--expect" && i + 1 < len(rest) {
            expect = to_string(rest[i + 1])
            have_expect = true
            i = i + 2
        } else if i == 1 && tok != "--claim" && tok != "--expect" {
            // bare first operand: the verifier cmd (allow positional form)
            vcmd = tok
            i = i + 1
        } else {
            i = i + 1
        }
    }
    println("verify --verifier-cmd  (VERIFY-KIT V8 — pluggable external verifier, phanes tenant-verifier model)")
    println("  claim    = " + claim)
    println("  verifier = " + vcmd)
    if len(vcmd) == 0 {
        println("  tier   = 🟠 INSUFFICIENT  (no --verifier-cmd path supplied — nothing to delegate to)")
        exit(2)
    }
    // delegate: run the tenant's checker, capture [stdout, stderr, exit_code].
    let res = exec_capture(vcmd)
    let vout = to_string(res[0]).trim()
    let verr = to_string(res[1]).trim()
    let rc = to_int(res[2])
    // record the external verdict VERBATIM (g5 — no paraphrase, no LLM judge).
    println("  ext rc   = " + to_string(rc))
    if len(vout) > 0 { println("  ext out  = " + vout) }
    if len(verr) > 0 { println("  ext err  = " + verr) }
    if rc == 127 {
        // no-such-command / exec failure → no verifier path
        println("  tier   = 🟠 INSUFFICIENT  (verifier cmd not found / exec failed rc=127 — no checker path)")
        return
    }
    if rc != 0 {
        // tenant's checker REJECTED → closed negative, NOT laundered
        println("  tier   = 🔴 FALSIFIED  (external verifier rejected rc=" + to_string(rc) + " — TECS-L result-agnostic closed negative; failures NOT laundered)")
        return
    }
    // rc == 0 → verifier passed. If --expect supplied, gate on stdout match.
    if have_expect {
        if vout == expect || vout.contains(expect) {
            println("  expect = matched (\"" + expect + "\")")
            println("  tier   = 🟢 SUPPORTED-NUMERICAL  (external verifier passed AND stdout matches --expect — delegated, deterministic)")
        } else {
            println("  expect = MISMATCH (wanted \"" + expect + "\", got \"" + vout + "\")")
            println("  tier   = 🔴 FALSIFIED  (verifier exit 0 but stdout disagrees with --expect — closed negative, not laundered)")
        }
        return
    }
    println("  tier   = 🟢 SUPPORTED-NUMERICAL  (external verifier passed rc=0 — delegated to tenant checker, deterministic)")
}

fn main() {
    let a = _slice_args()
    if len(a) == 0 { cmd_rubric(); return }
    let sub = to_string(a[0])
    if sub == "rubric" || sub == "list" || sub == "help" || sub == "--help" || sub == "-h" {
        cmd_rubric()
    } else if sub == "--expr" {
        cmd_expr(a)
    } else if sub == "--fence" {
        cmd_fence(a)
    } else if sub == "--blue-max" {
        cmd_blue_max(a)
    } else if sub == "--verifier-cmd" {
        cmd_verifier(a)
    } else {
        cmd_verify_id(a)
    }
}
