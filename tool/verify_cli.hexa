fn _ufo_lattice_master(phi: float) -> float {
    return 12.0 * phi
}

// float dispatch — fn_name → recompute. 0-arg fns ignore a0/a1/a2/a3
// (constants); 1-arg fns take a0; 2-arg take a0,a1; 3-arg take a0,a1,a2;
// 4-arg take a0,a1,a2,a3 (Phase 3 — hagen_poiseuille). Returns _NOCALC_F
// when no float path exists (caller then tries the int path / degrades).
// The 🟢 NUMERICAL companion to _recompute.
fn _recompute_float(fn_name: string, a0: float, a1: float, a2: float, a3: float, argc: int) -> float {
    if fn_name == "wakefield_e0_gv_m" { return _wakefield_e0_gv_m(a0) }
