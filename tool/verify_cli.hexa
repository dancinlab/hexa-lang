// tool/verify_cli.hexa — `hexa verify {<id>|--expr|--fence|rubric|list}`
//
// @version 0.2.0
// @capabilities [fs_read, fs_write]
//
// SINGLE verification entry-point. Uses the BINARY BUILT-IN ATLAS
// (dist/atlas.hxc via hxc_loader — the fast byte-canonical path; we do
// NOT `use embedded.gen`, whose multi-MB struct-literal module-load hangs
// the interp) + the hexa-native CALCULATORS (compiler/atlas/symbolic/*)
// to actually VERIFY a claimed closed-form and assign a tier — not just
// register it (cf. `hexa atlas` = read/stage SSOT, NOT a verifier).
//
// Cross-project tier rubric (dancinlab-wide, LATTICE_POLICY real-limits
// -first; carries: atlas/CLAUDE.md g_self_verify·g_tier_default_insufficient
// ·g_external_calc_forbidden · anima HEXAD g_verdict_tier_blue(a) · TECS-L
// n6-replication Tier1/2/3 · hexa-bio AXIS speculation-fence):
//   🔵 SUPPORTED-FORMAL    hexa-native calc reproduces the closed-form
//                          exactly (g_self_verify; TECS-L Tier1; HEXAD 🔵)
//   🟡 SUPPORTED-BY-CITATION atlas/literature has it, no hexa-native recompute
//   🟠 INSUFFICIENT         not in atlas + no calc path (g_tier_default)
//   🟠 DEFERRED             external hw/data/API dep (g_external_calc_forbidden)
//   ⚪ SPECULATION-FENCED   imagination/metaphor (hexa-bio AXIS class) —
//                          verification N/A, honest fence (g4; SF ≠ proven)
//
// Wired from self/main.hexa (`verify` → this). Runnable now:
//   hexa run tool/verify_cli.hexa <id>

use "compiler/atlas/hxc_loader"
use "compiler/atlas/symbolic/congruence_chain_engine"
use "self/stdlib/fs"

let HXC_PATH: string = "dist/atlas.hxc"
let ABSORB_LEDGER: string = "atlas/inbox/verified_equations.tape"

// --absorb anywhere in argv → fold a 🔵 verdict into the g7 inbox.
fn _has_absorb(rest) -> bool {
    let mut i = 0
    while i < len(rest) {
        if to_string(rest[i]) == "--absorb" { return true }
        i = i + 1
    }
    return false
}

// append a self-verified equation as a g7 atlas verdict entry (append-only
// inbox ledger). Legit 🔵 under g_self_verify — these ARE hexa-native
// verified (NOT sympy carry). Reviewer-merge → MAIN.tape (cycle_033/035
// pattern). Works for equations NOT YET in the atlas — verify computes &
// proves them; --absorb grows the binary built-in atlas with the result.
fn _absorb(label: string, evidence: string, anchor: string) {
    let mut body = read_file_safe(ABSORB_LEDGER)
    if len(body) == 0 {
        body = "#!/usr/bin/env tape\n"
        body = body + "# atlas/inbox/verified_equations.tape — `hexa verify --absorb` ledger\n"
        body = body + "# g7 inbox: hexa-native self-verified 🔵 equations (g_self_verify;\n"
        body = body + "# NOT sympy carry). Reviewer-merge → MAIN.tape (cycle_033/035 pattern).\n"
        body = body + "@V := \"tape\" :: spec [active]\n  version = \"1.2\"\n\n"
    }
    let ent = "@D verified_" + _slug(label) + " := \"" + label
        + "\" :: verdict [d=2026-05-16 active]\n"
        + "  status = \"🔵 SUPPORTED-FORMAL\"\n"
        + "  evidence = \"" + evidence + "\"\n"
        + "  stage = \"Stage 1 — hexa-native recompute (hexa verify)\"\n"
        + "  anchor = \"" + anchor + "\"\n"
        + "  cite = \"hexa verify self-verified (g_self_verify · TECS-L Tier1)\"\n"
        + "  provenance = \"tool/verify_cli.hexa --absorb · binary built-in atlas + calculators\"\n\n"
    write_file_safe(ABSORB_LEDGER, body + ent)
    println("  absorb = → " + ABSORB_LEDGER + " (@D verified_" + _slug(label) + ", g7 inbox)")
}

fn _slug(s: string) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let c = s[i]
        if (c >= "a" && c <= "z") || (c >= "0" && c <= "9") { out = out + c }
        else if c >= "A" && c <= "Z" { out = out + c }
        else { out = out + "_" }
        i = i + 1
    }
    return out
}

// only FIXED keywords are subs; a bare <id> is picked up by the n>=3
// fallback (real args start at index 2) — mirrors tool/calc_cli.hexa.
// (do NOT treat arbitrary non-dash tokens as subs: that wrongly matches
//  the expanded-script path at argv[1] under `hexa run`.)
fn _is_sub(a) -> bool {
    return a == "rubric" || a == "list" || a == "help" || a == "--help" || a == "-h"
        || a == "--expr" || a == "--fence"
}

fn _slice_args() -> array {
    let av = args()
    let n = len(av)
    let mut i = 1
    while i < n {
        let a = to_string(av[i])
        if _is_sub(a) {
            let mut out = []
            let mut j = i
            while j < n { out.push(av[j]); j = j + 1 }
            return out
        }
        i = i + 1
    }
    if n >= 3 {
        let mut out = []
        let mut j = 2
        while j < n { out.push(av[j]); j = j + 1 }
        return out
    }
    return []
}

fn cmd_rubric() {
    println("hexa verify — cross-project tier rubric (TECS-L-aligned, LATTICE_POLICY real-limits-first)")
    println("")
    println("  🔵 SUPPORTED-FORMAL      hexa-native calc reproduces a CLOSED-FORM/symbolic")
    println("                           identity exactly — TECS-L n6-rep Tier 1 (pure-math,")
    println("                           deterministic) · g_self_verify · anima HEXAD g_verdict_tier_blue(a)")
    println("  🟢 SUPPORTED-NUMERICAL   hexa-native NUMERICAL recompute matches (libm/Newton,")
    println("                           non-symbolic) — TECS-L n6-rep Tier 2 (~10min suite)")
    println("  🟡 SUPPORTED-BY-CITATION atlas/literature registered, NO hexa recompute")
    println("                           (external sympy/citation carry — never auto-🔵)")
    println("  🟠 INSUFFICIENT          not in atlas + no calc path (g_tier_default default)")
    println("  🟠 DEFERRED              external hw/data/API dep — TECS-L Tier 3 (GPU) /")
    println("                           g_external_calc_forbidden (closure-external)")
    println("  🔴 FALSIFIED             calc DETERMINISTICALLY disagrees with the claim —")
    println("                           a CLOSED negative (TECS-L result-agnostic: PASS or")
    println("                           FAIL both verified-closed; ≠ INSUFFICIENT)")
    println("  ⚪ SPECULATION-FENCED    imagination/metaphor (hexa-bio AXIS) — verify N/A,")
    println("                           SF ≠ proven (g4 honest fence)")
    println("")
    println("usage:")
    println("  hexa verify <id> [--absorb]              atlas atom: lookup + calc recompute")
    println("  hexa verify --expr <fn> <n> <v> [--absorb]   recompute fn(n)==v hexa-native")
    println("  hexa verify --expr <fn> <a> <b> <v> [--absorb]   2-operand (sigma_k/jacobi/...)")
    println("  hexa verify --fence <claim>              ⚪ SPECULATION-FENCED (honest)")
    println("  hexa verify rubric | list                this rubric")
    println("")
    println("  --absorb : a 🔵 result is folded into atlas/inbox/verified_equations.tape")
    println("             (g7 inbox · self-verified, g_self_verify · reviewer-merge → MAIN.tape).")
    println("             Verifies & absorbs equations NOT YET in the atlas — verify computes")
    println("             them; the binary built-in atlas grows with proven closed-forms.")
    println("  calc fns : sigma|sigma_0|sigma_2|phi|mu|tau|is_perfect|aliquot|gamma0_index|")
    println("             gamma0_cusps|gamma0_genus|isotropy_lcm|first_cusp_form_weight")
    println("             2-op: sigma_k|jacobi|kronecker|dim_cusp_forms  (extend _recompute on gap)")
}

let NOCALC: int = -999999

// recompute a number-theoretic closed-form by function name — the
// hexa-native 🔵 path (g_self_verify · TECS-L Tier1). Returns NOCALC if
// the calculator system has no path (caller → 🟡/🟠, and --absorb prints a
// "calc gap" line so the gap is recorded for a calculator-system upgrade).
// Coverage spans the full congruence_chain_engine surface; extend here
// when a real equation has no path ("계산기시스템 부족하면 개선").
fn _recompute(fn_name: string, n: int) -> int {
    if fn_name == "divisor_sum" || fn_name == "sigma" || fn_name == "sigma_1" { return sigma_k(n, 1) }
    if fn_name == "sigma_0" { return sigma_k(n, 0) }
    if fn_name == "sigma_2" { return sigma_k(n, 2) }
    if fn_name == "euler_totient" || fn_name == "euler_phi" || fn_name == "phi" { return euler_phi(n) }
    if fn_name == "mobius" || fn_name == "mu" { return mobius(n) }
    if fn_name == "divisor_count" || fn_name == "tau" { return len(divisors(n)) }
    if fn_name == "is_perfect" {
        // perfect ⟺ σ(n) = 2n  (Euclid–Euler; 6,28,496,…) → 1 / 0
        if sigma_k(n, 1) == 2 * n { return 1 }
        return 0
    }
    if fn_name == "aliquot" { return sigma_k(n, 1) - n }
    if fn_name == "gamma0_index"   { return gamma0_index(n) }
    if fn_name == "gamma0_cusps"   { return gamma0_cusps(n) }
    if fn_name == "gamma0_genus"   { return gamma0_genus(n) }
    if fn_name == "isotropy_lcm"   { return isotropy_lcm(n) }
    if fn_name == "first_cusp_form_weight" { return first_cusp_form_weight(n) }
    return NOCALC
}

// two-arg NT forms (k-th divisor power sum · Jacobi/Kronecker symbols).
fn _recompute2(fn_name: string, a: int, b: int) -> int {
    if fn_name == "sigma_k"   { return sigma_k(a, b) }
    if fn_name == "jacobi"    { return jacobi_symbol(a, b) }
    if fn_name == "kronecker" { return kronecker_symbol(a, b) }
    if fn_name == "dim_cusp_forms" { return dim_cusp_forms(a, b) }
    return NOCALC
}

// extract trailing "= <int>" claimed value from a raw header before "::".
fn _claimed_value(raw: string) -> int {
    let mut head = raw
    let ci = head.index_of("::")
    if ci >= 0 { head = head.slice(0, ci) }
    // last '=' segment
    let mut last = ""
    let parts = head.split("=")
    if len(parts) >= 2 {
        last = parts[len(parts) - 1]
    }
    let t = last.trim()
    return to_int(t)
}

fn cmd_verify_id(rest) {
    if len(rest) < 1 {
        println("error: usage: hexa verify <id>")
        exit(2)
    }
    let target = to_string(rest[0])
    let nodes = load_atlas_hxc(HXC_PATH)
    if len(nodes) == 0 {
        println("verify " + target)
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = binary built-in atlas (dist/atlas.hxc) empty/absent")
        return
    }
    let mut found = false
    let mut nraw = ""
    let mut nkind = ""
    let mut i = 0
    while i < len(nodes) {
        let nd = nodes[i]
        if nd.id == target {
            found = true
            nraw = nd.raw
            nkind = nd.kind
            i = len(nodes)
        } else {
            i = i + 1
        }
    }
    println("verify " + target + "   (binary built-in atlas: " + to_string(len(nodes)) + " nodes)")
    if !found {
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = id not in atlas; no closed-form to recompute")
        return
    }
    println("  atlas  = @" + nkind + " " + target + " (registered)")
    // try hexa-native recompute: find a known fn(6) form in raw
    let claimed = _claimed_value(nraw)
    let mut fnm = ""
    if nraw.contains("divisor_sum") { fnm = "divisor_sum" }
    else if nraw.contains("euler_totient") { fnm = "euler_totient" }
    else if nraw.contains("divisor_count") { fnm = "divisor_count" }
    else if nraw.contains("mobius") { fnm = "mobius" }
    if len(fnm) == 0 {
        println("  tier   = 🟡 SUPPORTED-BY-CITATION")
        println("  reason = atlas-registered; no hexa-native calc path for this form")
        return
    }
    let got = _recompute(fnm, 6)
    if got == claimed && claimed != NOCALC {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  == claimed " + to_string(claimed))
        println("  tier   = 🔵 SUPPORTED-FORMAL")
        println("  reason = hexa-native closed-form reproduced (g_self_verify · TECS-L Tier1)")
        if _has_absorb(rest) {
            _absorb(target + " = " + to_string(claimed),
                    "@" + nkind + " " + target + " · " + fnm + "(6)=" + to_string(got) + " == atlas-claimed " + to_string(claimed),
                    "[compiler invariant — hexa-native NT closed-form, g_self_verify]")
        }
    } else if claimed == NOCALC {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  vs claimed (unparsed)")
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = claimed value unparsed from raw — cannot adjudicate")
    } else {
        println("  calc   = " + fnm + "(6) = " + to_string(got) + "  != claimed " + to_string(claimed))
        println("  tier   = 🔴 FALSIFIED")
        println("  reason = hexa-native calc DETERMINISTICALLY disagrees with the claim —")
        println("           closed negative (TECS-L result-agnostic; ≠ INSUFFICIENT)")
    }
}

fn cmd_expr(rest) {
    // 1-operand:  --expr <fn> <n> <v>            (rest len 4)
    // 2-operand:  --expr <fn> <a> <b> <v>        (rest len 5)
    if len(rest) < 4 {
        println("error: usage: hexa verify --expr <fn> <n> <v>  |  <fn> <a> <b> <v>  [--absorb]")
        exit(2)
    }
    let fnm = to_string(rest[1])
    let mut got = NOCALC
    let mut label = ""
    let mut v = 0
    let n5 = len(rest) >= 5 && to_string(rest[4]) != "--absorb"
    if n5 {
        let a = to_int(to_string(rest[2]))
        let b = to_int(to_string(rest[3]))
        v = to_int(to_string(rest[4]))
        got = _recompute2(fnm, a, b)
        label = fnm + "(" + to_string(a) + "," + to_string(b) + ")=" + to_string(v)
    } else {
        let nn = to_int(to_string(rest[2]))
        v = to_int(to_string(rest[3]))
        got = _recompute(fnm, nn)
        label = fnm + "(" + to_string(nn) + ")=" + to_string(v)
    }
    println("verify --expr " + label)
    if got == NOCALC {
        println("  tier   = 🟠 INSUFFICIENT")
        println("  reason = calculator system has NO path for '" + fnm + "'")
        println("  gap    = extend tool/verify_cli.hexa::_recompute (계산기시스템 개선 후보)")
        return
    }
    if got == v {
        println("  calc   = " + to_string(got) + "  == expected " + to_string(v))
        println("  tier   = 🔵 SUPPORTED-FORMAL  (hexa-native closed-form, g_self_verify · TECS-L Tier1)")
        if _has_absorb(rest) {
            _absorb(label, fnm + " hexa-native recompute = " + to_string(got) + " == claimed " + to_string(v),
                    "[compiler invariant — hexa-native NT closed-form, g_self_verify]")
        }
    } else {
        println("  calc   = " + to_string(got) + "  != expected " + to_string(v))
        println("  tier   = 🔴 FALSIFIED  (calc deterministically disagrees — TECS-L result-agnostic closed negative)")
    }
}

fn cmd_fence(rest) {
    let mut claim = ""
    let mut i = 1
    while i < len(rest) {
        if i > 1 { claim = claim + " " }
        claim = claim + to_string(rest[i])
        i = i + 1
    }
    println("verify --fence")
    println("  claim  = " + claim)
    println("  tier   = ⚪ SPECULATION-FENCED")
    println("  reason = imagination/metaphor class (hexa-bio AXIS) — verification")
    println("           N/A by design; NOT a proven atlas atom (g4 honest fence,")
    println("           SF ≠ verified — atlas certification intrinsically N/A)")
}

fn main() {
    let a = _slice_args()
    if len(a) == 0 { cmd_rubric(); return }
    let sub = to_string(a[0])
    if sub == "rubric" || sub == "list" || sub == "help" || sub == "--help" || sub == "-h" {
        cmd_rubric()
    } else if sub == "--expr" {
        cmd_expr(a)
    } else if sub == "--fence" {
        cmd_fence(a)
    } else {
        cmd_verify_id(a)
    }
}
