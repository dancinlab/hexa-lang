#!hexa strict
// tool/regen_vendor_native_c.hexa
//   B9.C (.c-text · #1850/#1851 pattern) — single-command regen + gate-1
//   sha-verify for the 6 vendor-EXEMPT self/native/*.c FFI shims that vendor
//   `.so` builds compile independently (NOT `#include`d into runtime.c).
//
// ── WHY THIS EXISTS ────────────────────────────────────────────────────
//
// Six hand-written FFI shims are byte-identically hexa-emittable (gate-1
// source-SHA PROVEN by self/native/<base>_byte_diff.hexa):
//   - self/native/hxblas_linux.c    ← hxblas_linux_emit.hexa
//   - self/native/hxccl_linux.c     ← hxccl_linux_emit.hexa
//   - self/native/hxlmhead_linux.c  ← hxlmhead_linux_emit.hexa
//   - self/native/hxqwen14b.c       ← hxqwen14b_emit.hexa
//   - self/native/hxqwen32b.c       ← hxqwen32b_emit.hexa
//   - self/native/lora_cuda_host.c  ← lora_cuda_host_emit.hexa
//
// Source-SHA equivalence (gate-1) is the binding gate: because each emitter
// reproduces its `.c` byte-for-byte, regenerating the `.c` from the emitter
// (the SSOT) ships the SAME bytes the vendor `cc`/`nvcc` would compile →
// deterministic compiler on identical input → identical `.o`/`.so` → vendor
// build UNAFFECTED. No vendor re-verification (or GPU fire) is needed.
//
// "regen-before-build" is the activation pattern: a host with an external
// hexa-run runs this orchestrator FIRST (refreshing each `.c` from its
// emitter), then the vendor build picks up the freshly-regenerated `.c`.
// Once a `.c` is `git rm`'d, the regen recreates it on demand, sha-identical.
//
// ── USAGE ──────────────────────────────────────────────────────────────
//
//   # regen all 6 + verify sha-equivalence vs the in-tree `.c`:
//   hexa-run tool/regen_vendor_native_c.hexa
//
//   # regen only (when the `.c` has been git-rm'd — emitter is the SSOT):
//   hexa-run tool/regen_vendor_native_c.hexa --regen-only
//
//   # exit 0 = all regen OK (and, unless --regen-only, all sha-equal);
//   # exit 1 = a regen failed or a sha mismatch (drift) was detected.
//
// HEXA_HAL_ROOT overrides the repo-root autodetect (defaults to `pwd`).

let MODULE_NAME = "regen_vendor_native_c"

let mut RUN  = 0
let mut FAIL = 0

fn _root() -> str {
    let env_root = env("HEXA_HAL_ROOT")
    if env_root.len() > 0 { return env_root }
    return exec("pwd").trim()
}

fn _which(cmd: str) -> bool {
    let r = exec("command -v " + cmd + " >/dev/null 2>&1 && echo y || echo n").trim()
    return r == "y"
}

fn _exists(p: str) -> bool {
    let r = exec("[ -f \"" + p + "\" ] && echo y || echo n").trim()
    return r == "y"
}

fn _sha256(p: str) -> str {
    if _which("shasum") {
        return exec("shasum -a 256 \"" + p + "\" 2>/dev/null | awk '{print $1}'").trim()
    }
    if _which("sha256sum") {
        return exec("sha256sum \"" + p + "\" 2>/dev/null | awk '{print $1}'").trim()
    }
    return ""
}

fn _hexa_run() -> str {
    if _which("hexa-run") { return "hexa-run" }
    return "/Users/ghost/.hx/bin/hexa-run"
}

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// Regenerate one `.c` from its emitter into `dst`. When `regen_only` is
// false AND an in-tree baseline exists, also assert sha-equivalence vs the
// (pre-regen) baseline.
fn regen_one(root: str, emitter_rel: str, dst_rel: str, regen_only: bool) {
    let emitter = root + "/" + emitter_rel
    let dst     = root + "/" + dst_rel

    if !_exists(emitter) {
        _check(false, "emitter present: " + emitter_rel, "MISSING — cannot regen " + dst_rel)
        return
    }

    let had_baseline = _exists(dst)
    let baseline_sha = if had_baseline { _sha256(dst) } else { "" }

    let tmp = exec("mktemp -t regen_vendor_c.XXXXXX").trim()
    if tmp.len() == 0 {
        _check(false, "regen " + dst_rel, "mktemp scratch failed")
        return
    }
    let cmd = _hexa_run() + " \"" + emitter + "\" \"" + tmp + "\" >/dev/null 2>&1; echo $?"
    let rc = exec(cmd).trim()
    if rc != "0" || !_exists(tmp) {
        _check(false, "regen " + dst_rel, "emitter exit rc=" + rc)
        let _ = exec("rm -f \"" + tmp + "\"")
        return
    }

    let gen_sha = _sha256(tmp)

    if regen_only || !had_baseline {
        let _ = exec("mkdir -p \"$(dirname \"" + dst + "\")\" 2>/dev/null; cp -f \"" + tmp + "\" \"" + dst + "\"")
        let _ = exec("rm -f \"" + tmp + "\"")
        _check(_exists(dst), "regen " + dst_rel + " (no-baseline · emitter SSOT)", "sha=" + gen_sha)
        return
    }

    let equal = baseline_sha == gen_sha && gen_sha.len() > 0
    let _ = exec("cp -f \"" + tmp + "\" \"" + dst + "\"")
    let _ = exec("rm -f \"" + tmp + "\"")
    let detail = if equal {
        "gate-1 byte-identical · sha=" + gen_sha
    } else {
        "⚠ DRIFT — baseline=" + baseline_sha + " gen=" + gen_sha
    }
    _check(equal, "regen+verify " + dst_rel, detail)
}

fn main() {
    println("========================================================================")
    println("  B9.C — regen_vendor_native_c: 6 vendor FFI shim `.c` regen + sha-verify")
    println("========================================================================")

    let argv = real_args()
    let mut regen_only = false
    let mut i = 0
    while i < argv.len() {
        if argv[i] == "--regen-only" { regen_only = true }
        i = i + 1
    }

    let root = _root()
    println("  repo-root: " + root)
    println("  mode:      " + (if regen_only { "--regen-only (emitter SSOT, no baseline compare)" } else { "regen + gate-1 sha-verify vs in-tree `.c`" }))
    println("")

    let bases = ["hxblas_linux", "hxccl_linux", "hxlmhead_linux", "hxqwen14b", "hxqwen32b", "lora_cuda_host"]
    let mut bi = 0
    while bi < bases.len() {
        regen_one(root, "self/native/" + bases[bi] + "_emit.hexa", "self/native/" + bases[bi] + ".c", regen_only)
        bi = bi + 1
    }

    println("")
    let pass_n = RUN - FAIL
    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " artifacts regenerated"
            + (if regen_only { "" } else { " + verified sha-identical" }))
    if FAIL > 0 {
        println("__HEXA_LANG_REGEN_VENDOR_NATIVE_C__ FAIL")
        exit(1)
    }
    println("__HEXA_LANG_REGEN_VENDOR_NATIVE_C__ PASS")
    exit(0)
}
