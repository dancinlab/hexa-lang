// Minimal repro for Gotcha A — param name shadows stdlib function.
//
// Pilot context: orbital Kepler hexa-native port (commit 2ffe3620, agent
// a586b01f) needed eccentricity param. Calling it `e: float` produced
// broken C because the codegen treats every bare `e` in the function body
// as a fn-reference to the stdlib `e()` (Euler's constant) and emits
//
//     hexa_fn_new((void*)e, 0)
//
// even though `e` here is a local parameter. The pilot worked around it
// by renaming param → `ecc`. This file isolates the language-level bug
// so the codegen identifier-resolution can be fixed (local scope must
// shadow module-global names).
//
// Five wrap sites in self/codegen_c2.hexa (3389, 4106, 4844, 5537, 5608)
// all gate on `_is_known_fn_global(name)` WITHOUT checking
// `_gen2_name_in_cur_params(name) || _gen2_name_in_cur_lets(name)`.
//
// Expected after fix: `kepler_repro(0.9)` compiles AND prints 1.8.
// Before fix: emitted C has `hexa_fn_new((void*)e, 0)` where `e` is the
// local HexaVal — clang errors with "incompatible pointer types".

use "stdlib/core/math/float"

fn kepler_repro(e: float) -> float {
    // Pass the param to another fn — this triggers wrap site 4844
    // (user-fn call arg auto-wrap) because the codegen thinks `e` is
    // the stdlib `e()` fn-ref.
    return double_it(e)
}

fn double_it(x: float) -> float {
    return x + x
}

fn main() -> int {
    let r = kepler_repro(0.9)
    println(to_string(r))
    return 0
}
