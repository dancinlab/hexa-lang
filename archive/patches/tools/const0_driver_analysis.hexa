#!hexa strict
// inbox/tools/const0_driver_analysis.hexa — rfc_006 §5 d4 closure diagnostic.
//
// @version 0.0.1
// @capabilities [io, blif, diagnostic]
// @stability supporting (RFC 006 §5 d4 closure, parallel to read_verilog
//   elaboration work in stdlib/yosys/read_verilog.hexa)
// @since 2026-05-22
//
// CLEAN-ROOM PROVENANCE
//   upstream code : none (pure-hexa diagnostic walker)
//   upstream spec : ABC `_const0_` placeholder convention — ABC emits one
//                   `.gate _const0_ z=<net>` for every net that was
//                   referenced by an output port / latch D-input / gate
//                   pin but had no driver in the input BLIF. The mapped
//                   BLIF then ties those nets to a const-0 driver so
//                   `read_blif` round-trips without an un-driven-net
//                   error.
//
// WHY: post-ABC BLIF for router_d4 contains 1610 `.gate _const0_`
// placeholders. To close §5 d4 we need to know *who* reads those nets
// (latch D-input vs. comb gate fanin vs. module output port). This
// tool gives the BIN for read_verilog.hexa's richer elaboration work
// (Agent 1) — without it, that work is guessing.
//
// USAGE
//   const0_driver_analysis <blif-path>
//
// OUTPUT
//   _const0_ driver analysis (<basename>):
//   total: N _const0_ nets
//
//   by consumer pattern:
//     latch D-input:       N
//     combinational input: N
//     output port:         N
//     no consumer:         N
//
//   top 10 consumer cell types:
//     <count> <cell_type>
//     ...
//
//   top 20 net-name prefixes:
//     <count> <prefix>
//     ...
//
// HONESTY: this tool is read-only — it never edits BLIF, RTLIL, or
// stdlib code. It is purely a diagnostic surface for an open §5 question.

// ─── BLIF source loading ────────────────────────────────────────────────

// Read the BLIF text from disk. Empty string means missing / unreadable.
fn _load_blif(path: str) -> str {
    return read_file(path)
}

// Fold BLIF line continuations: any line ending in '\' is joined with
// the next line (BLIF spec §3 — line continuation). We strip the
// trailing backslash and join with a single space so downstream
// tokenization stays whitespace-split-based.
fn _fold_continuations(text: str) -> [str] {
    let raw = text.split("\n")
    let mut out: [str] = []
    let mut acc = ""
    let mut i = 0
    while i < len(raw) {
        let ln = raw[i]
        if ln.ends_with("\\") {
            // Strip the trailing backslash, accumulate.
            let body = ln.substring(0, len(ln) - 1)
            if acc == "" { acc = body } else { acc = acc + " " + body }
        } else {
            if acc == "" {
                out = out.push(ln)
            } else {
                out = out.push(acc + " " + ln)
                acc = ""
            }
        }
        i = i + 1
    }
    if acc != "" { out = out.push(acc) }
    return out
}

// Split a line on whitespace (space / tab), collapsing runs. We do
// this manually so the tokenizer matches BLIF's free-format expectation.
fn _ws_split(line: str) -> [str] {
    let mut tokens: [str] = []
    let mut buf = ""
    let mut i = 0
    while i < len(line) {
        let c = line.substring(i, i + 1)
        if c == " " {
            if len(buf) > 0 { tokens = tokens.push(buf); buf = "" }
        } else {
            if c == "\t" {
                if len(buf) > 0 { tokens = tokens.push(buf); buf = "" }
            } else {
                buf = buf + c
            }
        }
        i = i + 1
    }
    if len(buf) > 0 { tokens = tokens.push(buf) }
    return tokens
}

// ─── BLIF index ─────────────────────────────────────────────────────────

// Light-weight tables we'll build in one pass.
struct BlifIndex {
    const0_nets:   [str],   // every net z=<net> from `.gate _const0_`
    output_ports:  [str],   // module-level outputs (from .outputs)
    latch_d:       [str],   // D-input of each latch (.latch <D> <Q> ...)
    latch_q:       [str],   // Q-output of each latch (.latch <D> <Q> ...)
    // Per-net consumer roll-up (for top-N): cell_type seen reading the net.
    // We collect (consumer_net, cell_type, pin) triples here so the
    // analysis pass can cross-reference. To keep memory bounded for
    // 1610-net designs we record only `_const0_` consumers in the second
    // pass below.
    gate_lines:    [str],   // raw `.gate` lines (we re-walk them in pass 2)
}

fn _new_index() -> BlifIndex {
    return BlifIndex {
        const0_nets: [],
        output_ports: [],
        latch_d: [],
        latch_q: [],
        gate_lines: [],
    }
}

// First pass — populate the structural tables.
fn _build_index(lines: [str]) -> BlifIndex {
    let mut ix = _new_index()
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if len(ln) == 0 { i = i + 1; continue }
        // BLIF comments start with '#' (lifted from abc_emit_blif header).
        if ln.substring(0, 1) == "#" { i = i + 1; continue }
        let toks = _ws_split(ln)
        if len(toks) == 0 { i = i + 1; continue }
        let head = toks[0]
        if head == ".outputs" {
            let mut k = 1
            while k < len(toks) {
                ix.output_ports = ix.output_ports.push(toks[k])
                k = k + 1
            }
        }
        if head == ".latch" {
            // .latch <D> <Q> [type clk] <init>
            if len(toks) >= 3 {
                ix.latch_d = ix.latch_d.push(toks[1])
                ix.latch_q = ix.latch_q.push(toks[2])
            }
        }
        if head == ".gate" {
            // .gate <cell_type> [pin=net ...]
            if len(toks) >= 2 {
                let cell = toks[1]
                if cell == "_const0_" {
                    // The const0 placeholder declares a net via z=<net>.
                    let mut k = 2
                    while k < len(toks) {
                        let kv = toks[k].split("=")
                        if len(kv) == 2 {
                            // Accept any pin name (typically 'z') —
                            // ABC's const0 uses lowercase z.
                            ix.const0_nets = ix.const0_nets.push(kv[1])
                        }
                        k = k + 1
                    }
                }
                // Record the raw line so pass 2 can scan consumer pins.
                ix.gate_lines = ix.gate_lines.push(ln)
            }
        }
        i = i + 1
    }
    return ix
}

// ─── Consumer cross-reference ───────────────────────────────────────────

// Membership check on a [str]. Linear scan; the largest table here is
// `const0_nets` (~1610 for d4) — quadratic over gate_lines (~tens of k)
// is acceptable for a one-shot diagnostic, but we short-circuit early.
fn _contains(list: [str], target: str) -> int {
    let mut i = 0
    while i < len(list) {
        if list[i] == target { return 1 }
        i = i + 1
    }
    return 0
}

// Sort-helper aggregation: insert (key, +1) into parallel arrays,
// returning the new pair.
struct Histogram {
    names:  [str],
    counts: [int],
}

fn _new_hist() -> Histogram {
    return Histogram { names: [], counts: [] }
}

fn _hist_add(h: Histogram, key: str) -> Histogram {
    let mut names = h.names
    let mut counts = h.counts
    let mut i = 0
    while i < len(names) {
        if names[i] == key {
            counts[i] = counts[i] + 1
            return Histogram { names: names, counts: counts }
        }
        i = i + 1
    }
    names = names.push(key)
    counts = counts.push(1)
    return Histogram { names: names, counts: counts }
}

// Return indices into hist sorted by descending count. Simple
// selection-sort against a small histogram (typically O(10-100)).
fn _hist_top_indices(h: Histogram, n: int) -> [int] {
    let mut order: [int] = []
    let mut used: [int] = []
    let total = len(h.names)
    let mut i = 0
    while i < total { used = used.push(0); i = i + 1 }
    let mut k = 0
    while k < n {
        if k >= total { return order }
        let mut best = 0 - 1
        let mut best_count = 0 - 1
        let mut j = 0
        while j < total {
            if used[j] == 0 {
                if h.counts[j] > best_count {
                    best = j
                    best_count = h.counts[j]
                }
            }
            j = j + 1
        }
        if best < 0 { return order }
        used[best] = 1
        order = order.push(best)
        k = k + 1
    }
    return order
}

// Extract a name prefix for grouping. Conventions seen in router_d4:
//   fifo_mem[3]                 → fifo_mem
//   fifo_head[2]__b1            → fifo_head
//   rr_ptr__b0                  → rr_ptr
//   out_data[1]                 → out_data
//   new_n4959                   → new_n      (synthetic ABC name)
//   n70                         → n          (ABC internal node)
// We cut on the first '[' or '__' or first digit run, whichever comes
// first; that gives the structural family.
fn _prefix_of(s: str) -> str {
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "[" { return s.substring(0, i) }
        if c == "_" {
            if i + 1 < len(s) {
                if s.substring(i + 1, i + 2) == "_" {
                    return s.substring(0, i)
                }
            }
        }
        // Synthetic names like `new_n4959`, `n70` — cut at the first
        // digit.
        if c >= "0" {
            if c <= "9" {
                return s.substring(0, i)
            }
        }
        i = i + 1
    }
    return s
}

// ─── Main classification pass ───────────────────────────────────────────

struct AnalysisReport {
    total:           int,
    n_latch_d:       int,
    n_comb_input:    int,
    n_output_port:   int,
    n_no_consumer:   int,
    cell_hist:       Histogram,
    prefix_hist:     Histogram,
}

fn _analyze(ix: BlifIndex) -> AnalysisReport {
    let mut n_latch_d = 0
    let mut n_comb_input = 0
    let mut n_output_port = 0
    let mut n_no_consumer = 0
    let mut cell_hist = _new_hist()
    let mut prefix_hist = _new_hist()
    let mut ci = 0
    while ci < len(ix.const0_nets) {
        let net = ix.const0_nets[ci]
        // Always update the prefix histogram (per-net, independent of
        // consumer classification).
        prefix_hist = _hist_add(prefix_hist, _prefix_of(net))
        // Classification priority: output > latch_d > comb input > none.
        // Multiple roles possible (e.g. net is both a latch D-input AND
        // a module output) — we report under the highest-priority bucket
        // so the histogram sums to `total`.
        let is_output = _contains(ix.output_ports, net)
        let is_latch_d = _contains(ix.latch_d, net)
        let mut classified = 0
        if is_output == 1 {
            n_output_port = n_output_port + 1
            classified = 1
        } else {
            if is_latch_d == 1 {
                n_latch_d = n_latch_d + 1
                classified = 1
            }
        }
        // Even if classified as output/latch, also record which comb
        // cells consume the net (for the consumer-cell-type histogram —
        // a net can be both latch D-input AND fanin to other comb gates).
        let mut gi = 0
        let mut had_comb = 0
        while gi < len(ix.gate_lines) {
            let gl = ix.gate_lines[gi]
            // Cheap substring probe — `=<net>` is unique enough on
            // pin-value tokens because nets never contain '='.
            // We do BOTH `=<net>` and `=<net> ` / `=<net>` end-of-line.
            let probe = "=" + net
            let pos = gl.find(probe)
            if pos >= 0 {
                // Confirm the match ends at a word boundary (space or EOL).
                let endpos = pos + len(probe)
                let mut ok = 0
                if endpos >= len(gl) {
                    ok = 1
                } else {
                    let nxt = gl.substring(endpos, endpos + 1)
                    if nxt == " " { ok = 1 }
                    if nxt == "\t" { ok = 1 }
                }
                if ok == 1 {
                    let gtoks = _ws_split(gl)
                    if len(gtoks) >= 2 {
                        let cell_type = gtoks[1]
                        // Skip `_const0_` itself (the driver, not a consumer).
                        if cell_type != "_const0_" {
                            cell_hist = _hist_add(cell_hist, cell_type)
                            had_comb = 1
                        }
                    }
                }
            }
            gi = gi + 1
        }
        if classified == 0 {
            if had_comb == 1 {
                n_comb_input = n_comb_input + 1
            } else {
                n_no_consumer = n_no_consumer + 1
            }
        }
        ci = ci + 1
    }
    return AnalysisReport {
        total: len(ix.const0_nets),
        n_latch_d: n_latch_d,
        n_comb_input: n_comb_input,
        n_output_port: n_output_port,
        n_no_consumer: n_no_consumer,
        cell_hist: cell_hist,
        prefix_hist: prefix_hist,
    }
}

// ─── Report emission ────────────────────────────────────────────────────

fn _print_hist(label: str, h: Histogram, top_n: int) {
    println("")
    println(label)
    let idx = _hist_top_indices(h, top_n)
    let mut i = 0
    while i < len(idx) {
        let k = idx[i]
        println("  " + str(h.counts[k]) + "  " + h.names[k])
        i = i + 1
    }
    if len(idx) == 0 {
        println("  (empty)")
    }
}

fn _print_report(blif_path: str, r: AnalysisReport) {
    println("_const0_ driver analysis (" + blif_path + "):")
    println("total: " + str(r.total) + " _const0_ nets")
    println("")
    println("by consumer pattern:")
    println("  latch D-input:       " + str(r.n_latch_d))
    println("  combinational input: " + str(r.n_comb_input))
    println("  output port:         " + str(r.n_output_port))
    println("  no consumer:         " + str(r.n_no_consumer))
    _print_hist("top 10 consumer cell types:", r.cell_hist, 10)
    _print_hist("top 20 net-name prefixes:", r.prefix_hist, 20)
    // Provenance note on classification semantics.
    println("")
    println("(classification priority: output > latch_d > comb > none;")
    println(" cell-type histogram counts comb consumers per net even when")
    println(" net is bucketed as latch_d/output — multi-fanout is normal.)")
}

// ─── Self-test (synthetic falsifier) ────────────────────────────────────

fn _selftest() {
    let synth = ".model t\n"
        + ".inputs a b\n"
        + ".outputs y orph\n"
        + ".gate sky130_fd_sc_hd__and2_1 A=a B=b X=mid\n"
        + ".gate sky130_fd_sc_hd__buf_1 A=mid X=feeds_q\n"
        + ".latch feeds_q my_q 2\n"
        + ".gate _const0_ z=y\n"
        + ".gate _const0_ z=danglingD\n"
        + ".latch danglingD my_q2 2\n"
        + ".gate _const0_ z=fan_in_only\n"
        + ".gate sky130_fd_sc_hd__buf_1 A=fan_in_only X=somewhere\n"
        + ".gate _const0_ z=orphan_net\n"
        + ".end\n"
    let lines = _fold_continuations(synth)
    let ix = _build_index(lines)
    let r = _analyze(ix)
    let mut ok = 1
    if r.total != 4 { println("[selftest] FAIL total=" + str(r.total)); ok = 0 }
    if r.n_output_port != 1 { println("[selftest] FAIL output_port=" + str(r.n_output_port)); ok = 0 }
    if r.n_latch_d != 1 { println("[selftest] FAIL latch_d=" + str(r.n_latch_d)); ok = 0 }
    if r.n_comb_input != 1 { println("[selftest] FAIL comb_input=" + str(r.n_comb_input)); ok = 0 }
    if r.n_no_consumer != 1 { println("[selftest] FAIL no_consumer=" + str(r.n_no_consumer)); ok = 0 }
    if ok == 1 {
        println("[selftest] PASS — synthetic BLIF classified correctly")
    } else {
        println("[selftest] FAIL — see lines above")
        exit(1)
    }
}

// ─── main ───────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    // Self-test mode: no args.
    if len(argv) < 2 {
        _selftest()
        println("")
        println("usage: const0_driver_analysis <blif-path>")
        println("")
        println("  Reads a (post-ABC) BLIF and emits a histogram of how")
        println("  _const0_ placeholder nets are consumed (latch D-input,")
        println("  combinational fanin, module output port, orphan).")
        return
    }
    let path = argv[1]
    let text = _load_blif(path)
    if len(text) == 0 {
        println("[const0_diag] FAIL — could not read BLIF: " + path)
        exit(2)
    }
    let lines = _fold_continuations(text)
    let ix = _build_index(lines)
    let r = _analyze(ix)
    _print_report(path, r)
}
