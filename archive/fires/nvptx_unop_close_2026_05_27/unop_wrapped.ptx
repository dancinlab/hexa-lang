// Manual wrapper to ptxas-check the INBOX 1665 emit surfaces in
// isolation. The codegen-emitted neg + add + mul lines are spliced
// into a complete .entry kernel so ptxas can validate grammar.
// ASCII only - driver-JIT ptxas rejects non-ASCII PTX text.
.version 7.8
.target sm_80
.address_size 64

.visible .entry unop_neg_kernel(.param .u64 out_ptr, .param .u64 in_ptr)
{
    .reg .u64 %rd0;
    .reg .u64 %rd1;
    .reg .f64 %fd0;
    .reg .f64 %fd1;
    .reg .f64 %fd2;
    .reg .f64 %fd3;

    ld.param.u64 %rd0, [in_ptr];
    ld.param.u64 %rd1, [out_ptr];
    ld.global.f64 %fd0, [%rd0];              // load input
    neg.f64 %fd1, %fd0;                       // (1) register-neg
    add.f64 %fd2, %fd1, 0d3FF8000000000000;   // (3) +1.5 const-hex
    mul.f64 %fd3, %fd2, 0dBFF8000000000000;   // (3) -1.5 const-hex bug-1663
    st.global.f64 [%rd1], %fd3;
    ret;
}
