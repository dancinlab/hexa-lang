// host_check.hexa — flame ag_linear FP32 Metal e2e (fwd + bwd) numeric oracle
// ════════════════════════════════════════════════════════════════════════
//
// Drives the FULL autograd path through the new HEXA_METAL=1 env-gates
// for ag_linear forward (N40, _ag_linear_metal_fp32_fwd) AND ag_linear
// backward (N53, _ag_linear_metal_fp32_bwd) in stdlib/flame/ag_tape.hexa.
//
// Topology: 2-layer Linear chain with autograd tape.
//   x  [B=128, D=128]
//   W1 [D=128, H=256]    → h = x @ W1     [B=128, H=256]
//   W2 [H=256, C=64]     → y = h @ W2     [B=128, C=64]
//   L  = sum(y)          → dy = ones      [B=128, C=64]
//
// Both matmuls trip the 8192 dim-gate inside ag_linear's fwd/bwd
// env-gate (M·K and K·N both > 8192). So under HEXA_METAL=1 BOTH
// linears get FP32 Metal dispatch for fwd AND bwd (4 MPS calls per
// forward+backward pass: 2 fwd matmul, 2 bwd dx via NT_b, 2 bwd dW via
// NT_a — 6 MPS calls total).
//
// Falsifier: F-RFC075-FLAME-AG-LINEAR-E2E-METAL-NUMERIC-EQ
//   Compare HEXA_METAL=1 numerics (FP32 GPU) against env-unset numerics
//   (FP64 CPU host-scalar matmul_bwd_auto):
//     - max_rel_err(y_GPU,  y_CPU)  < 5e-3
//     - max_rel_err(dW1_GPU, dW1_CPU) < 5e-3
//     - max_rel_err(dW2_GPU, dW2_CPU) < 5e-3
//     - max_rel_err(dx_GPU,  dx_CPU)  < 5e-3
//   5e-3 budget = FP32 SGEMM round-trip floor for K∈{128,256} chained.

use "stdlib/flame/tensor_lib"
use "stdlib/flame/ag_tape"

// ── shape constants ────────────────────────────────────────────────────
let B = 128
let D = 128
let H = 256
let C = 64

// ── LCG fill (host scalar, deterministic) ──────────────────────────────
fn lcg_fill(t: int, n: int, seed: int) {
    let mut s = seed
    let mut i = 0
    while i < n {
        // s = s * 6364136223846793005 + 1442695040888963407 (mod 2^64)
        let new_s = s * 6364136223846793005 + 1442695040888963407
        s = new_s
        // bits24 = (s >> 40) & 0xFFFFFF  →  [-1, 1)
        let bits24 = (s / 1099511627776) % 16777216
        let v = (to_float(bits24) / 8388608.0) - 1.0
        t_set(t, i, v)
        i = i + 1
    }
}

// ── max relative error across two tensors ──────────────────────────────
fn max_rel_err(a: int, b: int, n: int) -> float {
    let mut max_rel = 0.0
    let mut i = 0
    while i < n {
        let av = t_get(a, i)
        let bv = t_get(b, i)
        let mut d = av - bv
        if d < 0.0 { d = 0.0 - d }
        let mut denom = bv
        if denom < 0.0 { denom = 0.0 - denom }
        denom = denom + 1.0e-9
        let rel = d / denom
        if rel > max_rel { max_rel = rel }
        i = i + 1
    }
    return max_rel
}

// ── run one forward+backward pass through the autograd tape ────────────
// Returns 5 ids: [y, dW1, dW2, dx, tape]  (4 grad tensors + handle for free)
fn run_e2e(x: int, W1: int, W2: int) -> int {
    let tp = ag_t_begin(4)
    let zb_h = t_zeros(H)
    let zb_c = t_zeros(C)
    let h_t = ag_linear(tp, x,   W1, zb_h, B, D, H)
    let y_t = ag_linear(tp, h_t, W2, zb_c, B, H, C)
    // seed: ones gradient (loss = sum(y), so dy = ones)
    let seed = t_zeros(B * C)
    let mut k = 0
    while k < B * C {
        t_set(seed, k, 1.0)
        k = k + 1
    }
    ag_backward_reg(tp, y_t, seed)
    // collect: y output + grads via ag_grad(tape, tensor_id)
    let dW1 = ag_grad(tp, W1)
    let dW2 = ag_grad(tp, W2)
    let dx  = ag_grad(tp, x)
    // pack into result tuple via output tensor
    let out = t_zeros(5)
    t_set(out, 0, to_float(y_t))
    t_set(out, 1, to_float(dW1))
    t_set(out, 2, to_float(dW2))
    t_set(out, 3, to_float(dx))
    t_set(out, 4, to_float(tp))
    t_free(seed)
    t_free(zb_h)
    t_free(zb_c)
    return out
}

// ── main ───────────────────────────────────────────────────────────────
println("-- F-RFC075-FLAME-AG-LINEAR-E2E-METAL-NUMERIC-EQ --")
print("  shape: B=")
print(B)
print(" D=")
print(D)
print(" H=")
print(H)
print(" C=")
println(C)

let metal_env = env("HEXA_METAL")
print("  HEXA_METAL=")
println(metal_env)

let dim_gate_1 = B * D
let dim_gate_2 = D * H
let dim_gate_3 = H * C
print("  dim-gate (must exceed 8192): B*D=")
print(dim_gate_1)
print(" D*H=")
print(dim_gate_2)
print(" H*C=")
println(dim_gate_3)

// Build deterministic inputs (shared across both runs)
let x  = t_zeros(B * D)
let W1 = t_zeros(D * H)
let W2 = t_zeros(H * C)
lcg_fill(x,  B * D, 305419896)        // 0x12345678
lcg_fill(W1, D * H, -1698898192)      // 0x9ABCDEF0 as signed int (overflow ok)
lcg_fill(W2, H * C, -19088744)        // 0xFEDCBA98 as signed int

// Single pass through the autograd tape — whatever HEXA_METAL is set
// to in the process env decides fwd+bwd routing. The dim-gate is
// identical for both modes, so the same dispatch is taken end-to-end.
let result = run_e2e(x, W1, W2)
let y_id   = to_int(t_get(result, 0))
let dW1_id = to_int(t_get(result, 1))
let dW2_id = to_int(t_get(result, 2))
let dx_id  = to_int(t_get(result, 3))

// Sanity: print a couple of y elements + max abs of grads (to detect NaN/Inf)
print("  y[0..3]=")
print(t_get(y_id, 0))
print(" ")
print(t_get(y_id, 1))
print(" ")
print(t_get(y_id, 2))
println("")

let mut mx_dW1 = 0.0
let mut i1 = 0
while i1 < D * H {
    let v = t_get(dW1_id, i1)
    let vv = if v < 0.0 { 0.0 - v } else { v }
    if vv > mx_dW1 { mx_dW1 = vv }
    i1 = i1 + 1
}
let mut mx_dW2 = 0.0
let mut i2 = 0
while i2 < H * C {
    let v = t_get(dW2_id, i2)
    let vv = if v < 0.0 { 0.0 - v } else { v }
    if vv > mx_dW2 { mx_dW2 = vv }
    i2 = i2 + 1
}
let mut mx_dx = 0.0
let mut i3 = 0
while i3 < B * D {
    let v = t_get(dx_id, i3)
    let vv = if v < 0.0 { 0.0 - v } else { v }
    if vv > mx_dx { mx_dx = vv }
    i3 = i3 + 1
}
print("  max|dW1|=")
print(mx_dW1)
print(" max|dW2|=")
print(mx_dW2)
print(" max|dx|=")
println(mx_dx)

// Dump y for this run to a flat tensor we can use as oracle: emit the
// first 8 elements + the 4 summary maxima so the driver script can
// compare across two runs of this binary (HEXA_METAL=1 vs unset).
print("ORACLE ")
print(t_get(y_id, 0)) print(" ")
print(t_get(y_id, 1)) print(" ")
print(t_get(y_id, 2)) print(" ")
print(t_get(y_id, 3)) print(" ")
print(t_get(y_id, 4)) print(" ")
print(t_get(y_id, 5)) print(" ")
print(t_get(y_id, 6)) print(" ")
print(t_get(y_id, 7)) print(" ")
print(t_get(dW1_id, 0)) print(" ")
print(t_get(dW1_id, 1)) print(" ")
print(t_get(dW2_id, 0)) print(" ")
print(t_get(dW2_id, 1)) print(" ")
print(t_get(dx_id, 0)) print(" ")
print(t_get(dx_id, 1)) print(" ")
print(mx_dW1) print(" ")
print(mx_dW2) print(" ")
println(mx_dx)
