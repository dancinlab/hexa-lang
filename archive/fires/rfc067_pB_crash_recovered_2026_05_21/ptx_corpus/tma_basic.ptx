.version 8.0
.target sm_90
.address_size 64
.shared .align 16 .b8 dst[256];
.visible .entry tma_basic(.param .u64 src)
{
    .reg .b64 %rd1, %rd2, %rd3;
    .reg .b32 %r0;
    ld.param.u64 %rd1, [src];
    mov.b64 %rd2, dst;
    cvta.shared.u64 %rd3, %rd2;
    cvta.to.shared.u64 %rd3, %rd3;
    mov.u32 %r0, 256;
    cp.async.bulk.shared::cta.global [%rd3], [%rd1], %r0;
    ret;
}
