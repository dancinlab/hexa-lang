.version 7.8
.target sm_80
.address_size 64
.visible .entry test (.param .u64 a, .param .u64 b, .param .u64 c)
{
    .reg .u64 %rd<5>;
    .reg .f16 %fh<5>;
    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [c];
    ld.global.f16 %fh0, [%rd0];
    ld.global.f16 %fh1, [%rd1];
    add.f16 %fh2, %fh0, %fh1;
    st.global.f16 [%rd2], %fh2;
    ret;
}
