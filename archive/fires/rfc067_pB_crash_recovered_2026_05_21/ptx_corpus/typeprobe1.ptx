.version 7.8
.target sm_80
.address_size 64
.visible .entry t1 (.param .u64 a, .param .u64 b, .param .u64 c) {
    .reg .u64 %rd<5>;
    .reg .b16 %h<5>;
    ld.param.u64 %rd0, [a]; ld.param.u64 %rd1, [b]; ld.param.u64 %rd2, [c];
    ld.global.b16 %h0, [%rd0];
    ld.global.b16 %h1, [%rd1];
    add.f16 %h2, %h0, %h1;
    st.global.b16 [%rd2], %h2;
    ret;
}
