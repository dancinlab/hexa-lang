// RFC 068 P4 bf16 silicon fire kernel.
//
// PTX 8.0 ptxas 12.0 finding (GPU.md sec2c probe): `.reg .bf16` syntax
// fails to parse, but `.reg .b16` containers + `add.bf16` opcode
// combination compiles cleanly under -arch=sm_90+. RTX 5070 sm_120
// driver JIT is forward-compatible with sm_90 PTX.

.version 8.0
.target sm_90
.address_size 64

.visible .entry bf16_vadd (
    .param .u64 a,
    .param .u64 b,
    .param .u64 c,
    .param .u64 n
)
{
    .reg .u64 %rd<10>;
    .reg .u32 %r<10>;
    .reg .pred %p1;
    .reg .b16 %fb<5>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [c];
    ld.param.u64 %rd3, [n];

    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r3, %r0, %r1, %r2;

    cvt.s32.s64 %r4, %rd3;
    setp.ge.s32 %p1, %r3, %r4;
    @%p1 bra $exit;

    cvt.u64.u32 %rd4, %r3;
    shl.b64 %rd5, %rd4, 1;
    add.u64 %rd6, %rd0, %rd5;
    add.u64 %rd7, %rd1, %rd5;
    add.u64 %rd8, %rd2, %rd5;

    ld.global.b16 %fb0, [%rd6];
    ld.global.b16 %fb1, [%rd7];
    add.bf16 %fb2, %fb0, %fb1;
    st.global.b16 [%rd8], %fb2;

$exit:
    ret;
}
