//
// F-FUSION-ATTN-ROOFLINE round 7 v2 -- TMA (SWIZZLE_NONE) + double-buffer fused
// flash-attention, canonical non-trans mma.sync.m16n8k16 (proven by oracle).
// N=2048 d=64. Per-CTA BM=64 query rows, 4-warp 2x2. grid.x=N/64=32. block=128.
// Both GEMMs use the A.B^T non-trans path; QK^T feeds K direct, P.V feeds V^T
// (transposed in smem each KV block). smem ~99136 B (opt-in dyn shared).
// ASCII-only PTX. .target sm_120a + .version 8.7.
//
.version 8.7
.target sm_120a
.address_size 64

.extern .shared .align 128 .b8 _smem[];

.visible .entry flash_attn_tma_v2 (
    .param .align 64 .b8 tmap_q_param[128],
    .param .align 64 .b8 tmap_k_param[128],
    .param .align 64 .b8 tmap_v_param[128],
    .param .u64 o_ptr_param,
    .param .u32 n_seq_param,
    .param .f32 scale_param
)
{
    .reg .pred %p1,%p2,%p3,%p4,%pwait,%pt0,%pfin;
    .reg .b32 %r<200>;
    .reg .b64 %rd<48>;
    .reg .f32 %f<48>;
    .reg .f32 %fc<32>;
    .reg .b32 %ra<8>;
    .reg .b32 %rbl<4>;
    .reg .b32 %rbh<4>;
    .reg .b16 %h<4>;
    .reg .b64 %tok;
    .reg .b32 %smem_base,%smem_q,%smem_k0,%smem_k1,%smem_v0,%smem_v1;
    .reg .b32 %smem_vt0,%smem_vt1,%smem_s,%smem_p,%smem_o,%smem_m,%smem_l,%smem_c,%smem_mbar;
    .reg .b32 %smem_kcur,%smem_vcur,%smem_vtcur,%smem_kmbar;
    .reg .b64 %tmap_q_addr,%tmap_k_addr,%tmap_v_addr,%tmap_pp,%o_addr;
    .reg .b32 %kb,%parity,%x0,%y0,%tx_count,%arr_count;

    mov.b64 %tmap_pp, tmap_q_param; cvta.param.u64 %tmap_q_addr, %tmap_pp;
    mov.b64 %tmap_pp, tmap_k_param; cvta.param.u64 %tmap_k_addr, %tmap_pp;
    mov.b64 %tmap_pp, tmap_v_param; cvta.param.u64 %tmap_v_addr, %tmap_pp;
    ld.param.u64 %o_addr, [o_ptr_param];
    ld.param.u32 %r0, [n_seq_param];
    ld.param.f32 %f40, [scale_param];

    mov.u32 %smem_base, _smem;
    add.u32 %smem_q,   %smem_base, 0;
    add.u32 %smem_k0,  %smem_base, 8192;
    add.u32 %smem_k1,  %smem_base, 16384;
    add.u32 %smem_v0,  %smem_base, 24576;
    add.u32 %smem_v1,  %smem_base, 32768;
    add.u32 %smem_vt0, %smem_base, 40960;
    add.u32 %smem_vt1, %smem_base, 49152;
    add.u32 %smem_s,   %smem_base, 57344;
    add.u32 %smem_p,   %smem_base, 73728;
    add.u32 %smem_o,   %smem_base, 81920;
    add.u32 %smem_m,   %smem_base, 98304;
    add.u32 %smem_l,   %smem_base, 98560;
    add.u32 %smem_c,   %smem_base, 98816;
    add.u32 %smem_mbar,%smem_base, 99072;

    mov.u32 %r1, %tid.x;
    shr.u32 %r2, %r1, 5;
    shr.u32 %r3, %r2, 1;          // m_tile
    and.b32 %r4, %r2, 1;          // n_tile
    and.b32 %r50, %r1, 31;        // lane
    mul.lo.u32 %r22, %r3, 4096;   // a_band = m_tile*32*128
    mul.lo.u32 %r24, %r4, 4096;   // b_band = n_tile*32*128
    and.b32 %r57, %r50, 15;       // r15
    shr.u32 %r58, %r50, 4;        // lane>>4
    shl.b32 %r58, %r58, 3;        // chalf = (lane>>4)*8
    shl.b32 %r59, %r58, 1;        // chalf*2 (byte)
    shr.u32 %r90, %r50, 2;        // lane>>2
    and.b32 %r91, %r50, 3;
    shl.b32 %r91, %r91, 1;        // (lane&3)*2

    mov.u32 %r5, %ctaid.x;
    shl.b32 %r6, %r5, 6;          // qrow_base = ctaid.x*64

    setp.eq.s32 %pt0, %r1, 0;
    @!%pt0 bra $L_init_done;
    mov.u32 %arr_count, 1;
    mbarrier.init.shared.b64 [%smem_mbar], %arr_count;
    mbarrier.init.shared.b64 [%smem_mbar+8], %arr_count;
    mbarrier.init.shared.b64 [%smem_mbar+16], %arr_count;
    fence.proxy.async.shared::cta;
$L_init_done:
    bar.sync 0;

    // Q TMA load (once)
    @!%pt0 bra $L_q_skip;
    mov.u32 %x0, 0; mov.u32 %y0, %r6;
    cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%smem_q], [%tmap_q_addr, {%x0, %y0}], [%smem_mbar];
    mov.u32 %tx_count, 8192;
    mbarrier.arrive.expect_tx.release.cta.shared::cta.b64 %tok, [%smem_mbar], %tx_count;
$L_q_skip:
    mov.u32 %parity, 0;
$L_qw:
    mbarrier.try_wait.parity.shared::cta.b64 %pwait, [%smem_mbar], %parity;
    @!%pwait bra $L_qw;
    bar.sync 0;

    // init m/l/O
    setp.ge.u32 %p1, %r1, 64;
    @%p1 bra $L_mls;
      shl.b32 %r7, %r1, 2;
      add.u32 %r8, %smem_m, %r7; mov.f32 %f1, 0fFF800000; st.shared.f32 [%r8], %f1;
      add.u32 %r9, %smem_l, %r7; mov.f32 %f2, 0f00000000; st.shared.f32 [%r9], %f2;
$L_mls:
    mov.f32 %f2, 0f00000000; shl.b32 %r10, %r1, 2;
$L_oz:
    setp.ge.u32 %p2, %r10, 16384; @%p2 bra $L_ozd;
    add.u32 %r11, %smem_o, %r10; st.shared.f32 [%r11], %f2;
    add.u32 %r10, %r10, 512; bra $L_oz;
$L_ozd:
    bar.sync 0;

    // prologue: issue KV block 0 into slot 0
    setp.eq.s32 %pt0, %r1, 0;
    @!%pt0 bra $L_pres;
    mov.u32 %x0, 0; mov.u32 %y0, 0;
    cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%smem_k0], [%tmap_k_addr, {%x0, %y0}], [%smem_mbar+8];
    cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%smem_v0], [%tmap_v_addr, {%x0, %y0}], [%smem_mbar+8];
    mov.u32 %tx_count, 16384;
    mbarrier.arrive.expect_tx.release.cta.shared::cta.b64 %tok, [%smem_mbar+8], %tx_count;
$L_pres:

    mov.u32 %kb, 0;
$L_bl:
    setp.ge.u32 %p1, %kb, 32; @%p1 bra $L_bd;
    and.b32 %r12, %kb, 1; setp.eq.u32 %p2, %r12, 0;
    selp.b32 %smem_kcur, %smem_k0, %smem_k1, %p2;
    selp.b32 %smem_vcur, %smem_v0, %smem_v1, %p2;
    selp.b32 %smem_vtcur, %smem_vt0, %smem_vt1, %p2;
    shl.b32 %r13, %r12, 3; add.u32 %smem_kmbar, %smem_mbar, 8; add.u32 %smem_kmbar, %smem_kmbar, %r13;
    shr.u32 %r14, %kb, 1; and.b32 %parity, %r14, 1;
$L_kw:
    mbarrier.try_wait.parity.shared::cta.b64 %pwait, [%smem_kmbar], %parity;
    @!%pwait bra $L_kw;
    bar.sync 0;

    // issue next KV block into other slot
    add.u32 %r15, %kb, 1; setp.ge.u32 %p3, %r15, 32; @%p3 bra $L_ns;
    setp.eq.s32 %pt0, %r1, 0; @!%pt0 bra $L_ns;
      and.b32 %r16, %r15, 1; setp.eq.u32 %p4, %r16, 0;
      selp.b32 %r17, %smem_k0, %smem_k1, %p4;
      selp.b32 %r18, %smem_v0, %smem_v1, %p4;
      shl.b32 %r19, %r16, 3; add.u32 %r20, %smem_mbar, 8; add.u32 %r20, %r20, %r19;
      shl.b32 %y0, %r15, 6; mov.u32 %x0, 0;
      cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
          [%r17], [%tmap_k_addr, {%x0, %y0}], [%r20];
      cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
          [%r18], [%tmap_v_addr, {%x0, %y0}], [%r20];
      mov.u32 %tx_count, 16384;
      mbarrier.arrive.expect_tx.release.cta.shared::cta.b64 %tok, [%r20], %tx_count;
$L_ns:

    // transpose V (cur slot) -> Vt (cur slot): sVt[d=nn][key=kk] = sV[kk][nn]
    // 128 threads cover 64*64=4096 elements, 32 per thread
    shl.b32 %r40, %r1, 2;          // thread*4 byte (over V as 2-byte elems? use elem idx)
    mov.u32 %r41, %r1;             // elem idx start = tid
$L_vt:
    setp.ge.u32 %p4, %r41, 4096; @%p4 bra $L_vtd;
    // kk = idx/64, nn = idx%64 ; src = sVcur + idx*2 ; dst = sVtcur + (nn*64+kk)*2
    shr.u32 %r42, %r41, 6;         // kk
    and.b32 %r43, %r41, 63;        // nn
    shl.b32 %r44, %r41, 1;         // src byte
    add.u32 %r44, %smem_vcur, %r44;
    ld.shared.b16 %h0, [%r44];
    shl.b32 %r45, %r43, 6;         // nn*64
    add.u32 %r45, %r45, %r42;      // nn*64+kk
    shl.b32 %r45, %r45, 1;         // *2
    add.u32 %r45, %smem_vtcur, %r45;
    st.shared.b16 [%r45], %h0;
    add.u32 %r41, %r41, 128; bra $L_vt;
$L_vtd:
    bar.sync 0;

    // QK^T -> S
    mov.f32 %fc0, 0f00000000;
    mov.f32 %fc1, 0f00000000;
    mov.f32 %fc2, 0f00000000;
    mov.f32 %fc3, 0f00000000;
    mov.f32 %fc4, 0f00000000;
    mov.f32 %fc5, 0f00000000;
    mov.f32 %fc6, 0f00000000;
    mov.f32 %fc7, 0f00000000;
    mov.f32 %fc8, 0f00000000;
    mov.f32 %fc9, 0f00000000;
    mov.f32 %fc10, 0f00000000;
    mov.f32 %fc11, 0f00000000;
    mov.f32 %fc12, 0f00000000;
    mov.f32 %fc13, 0f00000000;
    mov.f32 %fc14, 0f00000000;
    mov.f32 %fc15, 0f00000000;
    mov.f32 %fc16, 0f00000000;
    mov.f32 %fc17, 0f00000000;
    mov.f32 %fc18, 0f00000000;
    mov.f32 %fc19, 0f00000000;
    mov.f32 %fc20, 0f00000000;
    mov.f32 %fc21, 0f00000000;
    mov.f32 %fc22, 0f00000000;
    mov.f32 %fc23, 0f00000000;
    mov.f32 %fc24, 0f00000000;
    mov.f32 %fc25, 0f00000000;
    mov.f32 %fc26, 0f00000000;
    mov.f32 %fc27, 0f00000000;
    mov.f32 %fc28, 0f00000000;
    mov.f32 %fc29, 0f00000000;
    mov.f32 %fc30, 0f00000000;
    mov.f32 %fc31, 0f00000000;

    // ==== mma K-step 0 (k_byte=0) non-trans A.B^T ====
    shl.b32 %r78, %r57, 7;            // r15*128
    add.u32 %r79, %r78, 0;
    add.u32 %r79, %r79, %r59;         // + chalf*2 (r59)
    add.u32 %r60, %r22, %r79;
    add.u32 %r60, %smem_q, %r60;      // a_lo
    add.u32 %r62, %r60, 2048;         // a_hi (+16 rows)
    add.u32 %r64, %r24, %r79;
    add.u32 %r61, %smem_kcur, %r64;      // b_lo
    add.u32 %r63, %r61, 2048;         // b_hi
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra0,%ra1,%ra2,%ra3}, [%r60];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra4,%ra5,%ra6,%ra7}, [%r62];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbl0,%rbl1,%rbl2,%rbl3}, [%r61];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbh0,%rbh1,%rbh2,%rbh3}, [%r63];
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc0,%fc1,%fc2,%fc3}, {%ra0,%ra1,%ra2,%ra3}, {%rbl0,%rbl2}, {%fc0,%fc1,%fc2,%fc3};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc4,%fc5,%fc6,%fc7}, {%ra0,%ra1,%ra2,%ra3}, {%rbl1,%rbl3}, {%fc4,%fc5,%fc6,%fc7};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc8,%fc9,%fc10,%fc11}, {%ra0,%ra1,%ra2,%ra3}, {%rbh0,%rbh2}, {%fc8,%fc9,%fc10,%fc11};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc12,%fc13,%fc14,%fc15}, {%ra0,%ra1,%ra2,%ra3}, {%rbh1,%rbh3}, {%fc12,%fc13,%fc14,%fc15};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc16,%fc17,%fc18,%fc19}, {%ra4,%ra5,%ra6,%ra7}, {%rbl0,%rbl2}, {%fc16,%fc17,%fc18,%fc19};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc20,%fc21,%fc22,%fc23}, {%ra4,%ra5,%ra6,%ra7}, {%rbl1,%rbl3}, {%fc20,%fc21,%fc22,%fc23};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc24,%fc25,%fc26,%fc27}, {%ra4,%ra5,%ra6,%ra7}, {%rbh0,%rbh2}, {%fc24,%fc25,%fc26,%fc27};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc28,%fc29,%fc30,%fc31}, {%ra4,%ra5,%ra6,%ra7}, {%rbh1,%rbh3}, {%fc28,%fc29,%fc30,%fc31};
    // ==== mma K-step 1 (k_byte=32) non-trans A.B^T ====
    shl.b32 %r78, %r57, 7;            // r15*128
    add.u32 %r79, %r78, 32;
    add.u32 %r79, %r79, %r59;         // + chalf*2 (r59)
    add.u32 %r60, %r22, %r79;
    add.u32 %r60, %smem_q, %r60;      // a_lo
    add.u32 %r62, %r60, 2048;         // a_hi (+16 rows)
    add.u32 %r64, %r24, %r79;
    add.u32 %r61, %smem_kcur, %r64;      // b_lo
    add.u32 %r63, %r61, 2048;         // b_hi
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra0,%ra1,%ra2,%ra3}, [%r60];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra4,%ra5,%ra6,%ra7}, [%r62];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbl0,%rbl1,%rbl2,%rbl3}, [%r61];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbh0,%rbh1,%rbh2,%rbh3}, [%r63];
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc0,%fc1,%fc2,%fc3}, {%ra0,%ra1,%ra2,%ra3}, {%rbl0,%rbl2}, {%fc0,%fc1,%fc2,%fc3};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc4,%fc5,%fc6,%fc7}, {%ra0,%ra1,%ra2,%ra3}, {%rbl1,%rbl3}, {%fc4,%fc5,%fc6,%fc7};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc8,%fc9,%fc10,%fc11}, {%ra0,%ra1,%ra2,%ra3}, {%rbh0,%rbh2}, {%fc8,%fc9,%fc10,%fc11};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc12,%fc13,%fc14,%fc15}, {%ra0,%ra1,%ra2,%ra3}, {%rbh1,%rbh3}, {%fc12,%fc13,%fc14,%fc15};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc16,%fc17,%fc18,%fc19}, {%ra4,%ra5,%ra6,%ra7}, {%rbl0,%rbl2}, {%fc16,%fc17,%fc18,%fc19};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc20,%fc21,%fc22,%fc23}, {%ra4,%ra5,%ra6,%ra7}, {%rbl1,%rbl3}, {%fc20,%fc21,%fc22,%fc23};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc24,%fc25,%fc26,%fc27}, {%ra4,%ra5,%ra6,%ra7}, {%rbh0,%rbh2}, {%fc24,%fc25,%fc26,%fc27};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc28,%fc29,%fc30,%fc31}, {%ra4,%ra5,%ra6,%ra7}, {%rbh1,%rbh3}, {%fc28,%fc29,%fc30,%fc31};
    // ==== mma K-step 2 (k_byte=64) non-trans A.B^T ====
    shl.b32 %r78, %r57, 7;            // r15*128
    add.u32 %r79, %r78, 64;
    add.u32 %r79, %r79, %r59;         // + chalf*2 (r59)
    add.u32 %r60, %r22, %r79;
    add.u32 %r60, %smem_q, %r60;      // a_lo
    add.u32 %r62, %r60, 2048;         // a_hi (+16 rows)
    add.u32 %r64, %r24, %r79;
    add.u32 %r61, %smem_kcur, %r64;      // b_lo
    add.u32 %r63, %r61, 2048;         // b_hi
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra0,%ra1,%ra2,%ra3}, [%r60];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra4,%ra5,%ra6,%ra7}, [%r62];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbl0,%rbl1,%rbl2,%rbl3}, [%r61];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbh0,%rbh1,%rbh2,%rbh3}, [%r63];
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc0,%fc1,%fc2,%fc3}, {%ra0,%ra1,%ra2,%ra3}, {%rbl0,%rbl2}, {%fc0,%fc1,%fc2,%fc3};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc4,%fc5,%fc6,%fc7}, {%ra0,%ra1,%ra2,%ra3}, {%rbl1,%rbl3}, {%fc4,%fc5,%fc6,%fc7};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc8,%fc9,%fc10,%fc11}, {%ra0,%ra1,%ra2,%ra3}, {%rbh0,%rbh2}, {%fc8,%fc9,%fc10,%fc11};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc12,%fc13,%fc14,%fc15}, {%ra0,%ra1,%ra2,%ra3}, {%rbh1,%rbh3}, {%fc12,%fc13,%fc14,%fc15};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc16,%fc17,%fc18,%fc19}, {%ra4,%ra5,%ra6,%ra7}, {%rbl0,%rbl2}, {%fc16,%fc17,%fc18,%fc19};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc20,%fc21,%fc22,%fc23}, {%ra4,%ra5,%ra6,%ra7}, {%rbl1,%rbl3}, {%fc20,%fc21,%fc22,%fc23};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc24,%fc25,%fc26,%fc27}, {%ra4,%ra5,%ra6,%ra7}, {%rbh0,%rbh2}, {%fc24,%fc25,%fc26,%fc27};
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc28,%fc29,%fc30,%fc31}, {%ra4,%ra5,%ra6,%ra7}, {%rbh1,%rbh3}, {%fc28,%fc29,%fc30,%fc31};
    // ==== mma K-step 3 (k_byte=96) non-trans A.B^T ====
    shl.b32 %r78, %r57, 7;            // r15*128
    add.u32 %r79, %r78, 96;
    add.u32 %r79, %r79, %r59;         // + chalf*2 (r59)
    add.u32 %r60, %r22, %r79;
    add.u32 %r60, %smem_q, %r60;      // a_lo
    add.u32 %r62, %r60, 2048;         // a_hi (+16 rows)
    add.u32 %r64, %r24, %r79;
    add.u32 %r61, %smem_kcur, %r64;      // b_lo
    add.u32 %r63, %r61, 2048;         // b_hi
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra0,%ra1,%ra2,%ra3}, [%r60];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%ra4,%ra5,%ra6,%ra7}, [%r62];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbl0,%rbl1,%rbl2,%rbl3}, [%r61];
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%rbh0,%rbh1,%rbh2,%rbh3}, [%r63];
    mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32 {%fc0,%fc1,%fc2,%fc3}, {%ra0,%ra1,%ra2,%ra3}, {%rbl0,%rbl2}, {%fc0,%fc1,%fc2,%fc3};
