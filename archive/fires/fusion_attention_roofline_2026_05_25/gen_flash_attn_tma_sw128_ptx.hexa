}}
"""
    return body

SHAPES = [2048, 4096]
if __name__ == "__main__":
    outdir = Path("/tmp/roofline_gen")
    for N in SHAPES:
        txt = gen(N)
        p = outdir / f"flash_attn_tma_sw128_{N}.ptx"
        p.write_text(txt)
        print(f"wrote {p.name} ({len(txt)} bytes)")
