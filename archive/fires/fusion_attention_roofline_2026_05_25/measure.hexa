#!/usr/bin/env bash
# F-FUSION-ATTN-ROOFLINE measure script (runnable copy; provenance .hexa committed).
# Builds the mma oracle + the TMA host, validates numeric, then times the wall.
# GPU GATE: caller must confirm nvidia-smi shows 0 compute procs before running.
set -euo pipefail
NVCC="${NVCC:-/usr/local/cuda-12.0/bin/nvcc}"
[ -x "$NVCC" ] || NVCC="$(command -v nvcc)"
DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$DIR"

echo "=== build mma oracle (sm_90a JIT->sm_120) ==="
$NVCC -O2 -arch=sm_90a -o fa_mma_oracle fa_mma_oracle.cu -lm

echo "=== build TMA roofline host (sm_120a) ==="
$NVCC -O2 -arch=sm_120a -o fa_roofline_host fa_roofline_host.c -lcuda -lcublas -lm

echo "=== mma fragment oracle (numeric de-risk, no TMA) ==="
./fa_mma_oracle 2048
./fa_mma_oracle 4096

echo "=== TMA SWIZZLE_128B + double-buffer fused attention (numeric + wall) ==="
: > result_partial.json
./fa_roofline_host flash_attn_tma_sw128_2048.ptx 2048
./fa_roofline_host flash_attn_tma_sw128_4096.ptx 4096

echo "=== done; see result_partial.json ==="
