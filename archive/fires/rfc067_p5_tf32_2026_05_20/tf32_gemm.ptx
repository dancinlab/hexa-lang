// RFC 067 P5 TF32 -- WMMA TF32 single-tile silicon fire.
//
// Single warp computes M=16, N=16, K=8 GEMM using the TF32 Tensor Core
// mnemonic: wmma.mma.sync.aligned.row.col.m16n16k8.f32.tf32.tf32.f32.
//
// TF32 is f32-with-truncated-mantissa (1 sign + 8 exp + 10 mantissa,
// upper 19 bits of f32). Inputs/outputs in this kernel are .f32-shaped
// (stored as full 32-bit values; Tensor Core truncates the lower 13
// mantissa bits at multiply time). Accumulation is full f32.
//
// PTX ISA fragment shapes for m16n16k8.tf32:
//   - A: 4 x .b32 per thread (row-major)
//   - B: 4 x .b32 per thread (col-major)
//   - C/D: 8 x .f32 per thread (accumulator, same as f16 case since
//     output tile m16n16=256 / 32 threads = 8 elements per thread)
//
// Layout: A row-major (M x K = 16 x 8), B col-major (K x N = 8 x 16),
// C row-major (M x N = 16 x 16, f32). Stride 8 (K dim) for A and B,
// stride 16 (N dim) for C store.
//
// GPU.md sec 2c -- WMMA TF32 silicon fire (Ampere+ Tensor Core path).

.version 8.0
.target sm_90
.address_size 64

.visible .entry tf32_gemm (
    .param .u64 a,
    .param .u64 b,
    .param .u64 c
)
{
    .reg .u64 %rd<8>;
    .reg .b32 %ra<4>;
    .reg .b32 %rb<4>;
    .reg .f32 %fc<8>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [c];

    // Zero the accumulator (8 .f32 per thread).
    mov.f32 %fc0, 0f00000000;
    mov.f32 %fc1, 0f00000000;
    mov.f32 %fc2, 0f00000000;
    mov.f32 %fc3, 0f00000000;
    mov.f32 %fc4, 0f00000000;
    mov.f32 %fc5, 0f00000000;
    mov.f32 %fc6, 0f00000000;
    mov.f32 %fc7, 0f00000000;

    // A row-major: stride = K = 8 elements per row.
    wmma.load.a.sync.aligned.row.m16n16k8.global.tf32
        {%ra0, %ra1, %ra2, %ra3}, [%rd0], 8;

    // B col-major: stride = K = 8 elements per column.
    wmma.load.b.sync.aligned.col.m16n16k8.global.tf32
        {%rb0, %rb1, %rb2, %rb3}, [%rd1], 8;

    // Tensor Core multiply-accumulate (TF32 inputs, f32 accumulate).
    wmma.mma.sync.aligned.row.col.m16n16k8.f32.tf32.tf32.f32
        {%fc0, %fc1, %fc2, %fc3, %fc4, %fc5, %fc6, %fc7},
        {%ra0, %ra1, %ra2, %ra3},
        {%rb0, %rb1, %rb2, %rb3},
        {%fc0, %fc1, %fc2, %fc3, %fc4, %fc5, %fc6, %fc7};

    // C row-major: stride = N = 16 elements per row.
    wmma.store.d.sync.aligned.row.m16n16k8.global.f32
        [%rd2], {%fc0, %fc1, %fc2, %fc3, %fc4, %fc5, %fc6, %fc7}, 16;
    ret;
}
