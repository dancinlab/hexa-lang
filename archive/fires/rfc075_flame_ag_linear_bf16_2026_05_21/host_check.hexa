// host_check.hexa — flame ag_linear bf16 precision tier numeric oracle
// ════════════════════════════════════════════════════════════════════════
//
// Drives the autograd forward path through the new HEXA_BF16=1 env-gate
// for ag_linear forward (`_ag_linear_metal_bf16_fwd` in stdlib/flame/
// ag_tape.hexa). The bf16 gate stacks on top of HEXA_METAL=1 + dim-gate
// (>8192 elements per LHS/RHS), so it only kicks in when both are set.
//
// Topology: 2-layer Linear chain.
//   x  [B=128, D=128]
//   W1 [D=128, H=256]    → h = x @ W1     [B=128, H=256]
//   W2 [H=256, C=64]     → y = h @ W2     [B=128, C=64]
//
// Both matmuls trip the 8192 dim-gate (B·D = 16384 > 8192,
// D·H = 32768, H·C = 16384). So under HEXA_BF16=1 + HEXA_METAL=1 BOTH
// linears get the bf16-rounded FP32 SGEMM path. Under HEXA_METAL=1
// (no bf16) BOTH get plain FP32 SGEMM (N40 path). Default = FP64 CPU.
//
// Falsifier: F-RFC075-FLAME-AG-LINEAR-BF16-NUMERIC-EQ
//   Compare HEXA_BF16=1 + HEXA_METAL=1 numerics (bf16 round + FP32 GPU)
//   against env-unset numerics (FP64 CPU host-scalar farr_matmul):
//     - max_rel_err(y_bf16, y_FP64) < 1e-2
//   1e-2 budget = bf16 mantissa floor (7-bit mantissa, ~3 decimal digits).
//   The FP32 (HEXA_METAL=1 only) baseline uses 5e-3 per N40/N58.
//
// This is a SINGLE-RUN host_check — the binary is run three times by the
// driver (env unset, HEXA_METAL=1, HEXA_METAL=1+HEXA_BF16=1) and the
// ORACLE lines are diffed in the driver. The driver may also be invoked
// without HEXA_METAL — in which case the bf16 path is bypassed (gate
// requires both env vars + shape).

use "stdlib/flame/tensor_lib"
use "stdlib/flame/ag_tape"

// ── shape constants (match the FP32 e2e oracle so dim-gate trips) ──────
let B = 128
let D = 128
let H = 256
let C = 64

// ── LCG fill (host scalar, deterministic, matches host_check.hexa) ─────
fn lcg_fill(t: int, n: int, seed: int) {
    let mut s = seed
    let mut i = 0
    while i < n {
        let new_s = s * 6364136223846793005 + 1442695040888963407
        s = new_s
        let bits24 = (s / 1099511627776) % 16777216
        let v = (to_float(bits24) / 8388608.0) - 1.0
        t_set(t, i, v)
        i = i + 1
    }
}

// ── max relative error across two tensors ──────────────────────────────
fn max_rel_err(a: int, b: int, n: int) -> float {
    let mut max_rel = 0.0
    let mut i = 0
    while i < n {
        let av = t_get(a, i)
        let bv = t_get(b, i)
        let mut d = av - bv
        if d < 0.0 { d = 0.0 - d }
        let mut denom = bv
        if denom < 0.0 { denom = 0.0 - denom }
        denom = denom + 1.0e-9
        let rel = d / denom
        if rel > max_rel { max_rel = rel }
        i = i + 1
    }
    return max_rel
}

// ── one forward pass through the autograd tape (fwd only — bf16 cycle
//    is scoped to forward; bwd helper is N53 FP32, unchanged here) ──────
fn run_fwd(x: int, W1: int, W2: int) -> int {
    let tp = ag_t_begin(4)
    let zb_h = t_zeros(H)
    let zb_c = t_zeros(C)
    let h_t = ag_linear(tp, x,   W1, zb_h, B, D, H)
    let y_t = ag_linear(tp, h_t, W2, zb_c, B, H, C)
    t_free(zb_h)
    t_free(zb_c)
    return y_t
}

// ── main ───────────────────────────────────────────────────────────────
println("-- F-RFC075-FLAME-AG-LINEAR-BF16-NUMERIC-EQ --")
print("  shape: B=")
print(B)
print(" D=")
print(D)
print(" H=")
print(H)
print(" C=")
println(C)

let metal_env = env("HEXA_METAL")
let bf16_env  = env("HEXA_BF16")
print("  HEXA_METAL=")
println(metal_env)
print("  HEXA_BF16=")
println(bf16_env)

let dim_gate_1 = B * D
let dim_gate_2 = D * H
let dim_gate_3 = H * C
print("  dim-gate (must exceed 8192): B*D=")
print(dim_gate_1)
print(" D*H=")
print(dim_gate_2)
print(" H*C=")
println(dim_gate_3)

// Build deterministic inputs (shared across all three env-mode runs)
let x  = t_zeros(B * D)
let W1 = t_zeros(D * H)
let W2 = t_zeros(H * C)
lcg_fill(x,  B * D, 305419896)
lcg_fill(W1, D * H, -1698898192)
lcg_fill(W2, H * C, -19088744)

let y_t = run_fwd(x, W1, W2)

// Sanity prints + ORACLE line (driver compares across runs)
print("  y[0..3]=")
print(t_get(y_t, 0))
print(" ")
print(t_get(y_t, 1))
print(" ")
print(t_get(y_t, 2))
println("")

let mut mx_y = 0.0
let mut i1 = 0
while i1 < B * C {
    let v = t_get(y_t, i1)
    let vv = if v < 0.0 { 0.0 - v } else { v }
    if vv > mx_y { mx_y = vv }
    i1 = i1 + 1
}
print("  max|y|=")
println(mx_y)

print("ORACLE ")
print(t_get(y_t, 0)) print(" ")
print(t_get(y_t, 1)) print(" ")
print(t_get(y_t, 2)) print(" ")
print(t_get(y_t, 3)) print(" ")
print(t_get(y_t, 4)) print(" ")
print(t_get(y_t, 5)) print(" ")
print(t_get(y_t, 6)) print(" ")
print(t_get(y_t, 7)) print(" ")
println(mx_y)
