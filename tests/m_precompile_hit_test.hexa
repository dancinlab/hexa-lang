// tests/m_precompile_hit_test.hexa — GO M2/M3 e2e demo:
//
// Verifies cmd_run's release/precompile/ lookup HITs a pre-staged binary
// and SKIPS the clang fork (cold-cache fork-storm mitigation, internal axis).
//
// Strategy:
//   1. Create an isolated fake $HEXA_LANG dir under /tmp.
//   2. Write a tiny probe.hexa source there.
//   3. Compute its cache key (sha256(source).substring(0,16) + "_" + version_str()).
//   4. Drop a SHELL-SCRIPT "fake binary" at release/precompile/hexa_run.<key>
//      that just `exit 42` (sentinel). chmod +x.
//   5. Invoke `HEXA_LANG=<fake> HEXA_PRECOMPILE_TRACE=1 hexa run <probe>`
//      where <probe> is the actual probe path. Capture stderr+rc.
//   6. PASS iff rc == 42 AND stderr contains "[precompile] HIT".
//
// NOTE: a shell script is not a real native binary, but cmd_run only
// `exec`s the path — the kernel honors the shebang. The hit/exec
// contract is what we're testing, not the binary format.
//
// Env required:
//   HEXA_BIN  absolute path to the hexa CLI (set by integration harness).
//             Falls back to `command -v hexa` if unset.

fn _shq(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" { out = out + "'\\''" } else { out = out + c }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _hexa_bin() -> string {
    let e = env("HEXA_BIN")
    if len(e) > 0 { return e }
    let p = to_string(exec("command -v hexa 2>/dev/null")).trim()
    return p
}

// MUST stay in lockstep with self/main.hexa::version_str().
fn _version_str() -> string {
    return "0.1.0-dispatch"
}

fn _contains(hay: string, needle: string) -> bool {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return true }
    if m > n { return false }
    let mut i = 0
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return true }
        i = i + 1
    }
    return false
}

fn _fail(msg: string) {
    eprintln("FAIL: " + msg)
    exit(1)
}

fn main() {
    let hexa_bin = _hexa_bin()
    if len(hexa_bin) == 0 { _fail("HEXA_BIN unset and `hexa` not on PATH") }

    // Set up isolated fake HEXA_LANG layout.
    let stamp = to_string(mono_ns())
    let root = "/tmp/m_precompile_hit_" + stamp
    let _mk = exec("rm -rf " + _shq(root) + " && mkdir -p " + _shq(root) + "/release/precompile && mkdir -p " + _shq(root) + "/self")
    // Marker so resolve_hxroot-style probes recognize this as a hexa root
    // (cmd_run's _precompile_lookup only checks HEXA_LANG envvar — no
    // structural validation needed). We still drop a stub for hygiene.
    let _stub = exec("printf '' > " + _shq(root + "/self/main.hexa"))

    // Probe script — content determines the cache key.
    let probe = root + "/probe_" + stamp + ".hexa"
    let src = "fn main() { println(\"REAL_BUILD_RAN\") }\nmain()\n"
    let _w = exec("printf %s " + _shq(src) + " > " + _shq(probe))

    let h = sha256_file(probe)
    let key = h.substring(0, 16) + "_" + _version_str()
    let target = root + "/release/precompile/hexa_run." + key

    // Fake "binary" — shell script with sentinel exit code 42 + sentinel
    // stdout marker. cmd_run exec()s the path directly; kernel honors #!.
    let fake = "#!/bin/sh\necho PRECOMPILE_HIT_SENTINEL\nexit 42\n"
    let _w2 = exec("printf %s " + _shq(fake) + " > " + _shq(target) + " && chmod +x " + _shq(target))

    if !file_exists(target) { _fail("could not stage fake precompile binary at " + target) }

    // Invoke hexa run with the fake HEXA_LANG. We use exec_with_status so
    // we can read both rc and combined stdout+stderr. cmd_run prints the
    // body to stdout (the sentinel "PRECOMPILE_HIT_SENTINEL") and our
    // trace to stderr ("[precompile] HIT ...").
    let env_prefix = "HEXA_LANG=" + _shq(root) + " HEXA_PRECOMPILE_TRACE=1 "
    let cmd = env_prefix + _shq(hexa_bin) + " run " + _shq(probe) + " 2>&1; echo \"__RC__=$?\""
    let out = to_string(exec(cmd))

    // Parse rc.
    let mark = "__RC__="
    let ml = len(mark)
    let ol = len(out)
    let mut mi = -1
    let mut sj = ol - ml
    while sj >= 0 {
        if out.substring(sj, sj + ml) == mark { mi = sj; sj = -1 } else { sj = sj - 1 }
    }
    let mut rc = -1
    if mi >= 0 {
        let mut rs = out.substring(mi + ml, ol)
        let rsl = len(rs)
        if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" { rs = rs.substring(0, rsl - 1) }
        rc = parse_int_str(rs)
    }
    let body = if mi >= 0 { out.substring(0, mi) } else { out }

    // Cleanup before asserting (don't leak /tmp on FAIL — easier rerun).
    let _rm = exec("rm -rf " + _shq(root))

    let hit = _contains(body, "[precompile] HIT")
    let sent = _contains(body, "PRECOMPILE_HIT_SENTINEL")

    if !hit {
        eprintln("---- output ----")
        eprintln(body)
        _fail("expected '[precompile] HIT' in stderr (precompile probe never ran or env not honored)")
    }
    if !sent {
        eprintln("---- output ----")
        eprintln(body)
        _fail("expected 'PRECOMPILE_HIT_SENTINEL' in stdout (fake binary never exec'd)")
    }
    if rc != 42 {
        eprintln("---- output ----")
        eprintln(body)
        _fail("expected rc=42 (sentinel), got rc=" + to_string(rc) + " — real build path likely ran instead of precompile hit")
    }

    println("PASS: precompile HIT — key=" + key + " exec rc=42 sentinel observed")
}

