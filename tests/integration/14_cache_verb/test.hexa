// 14_cache_verb — `hexa cache <subverb>` smoke (GO M4).
//
// Validates that all 4 subverbs run, exit 0, and emit recognizable banners:
//   stat · list · verify · clean (dry-run)
//
// Uses an isolated HOME so the test does not depend on (or mutate) the
// user's real ~/.hexa-cache.
//
// Driven by the harness: HEXA_BIN must point at the dispatcher binary.
// Returns 0 on PASS, 1 on FAIL, 77 on SKIP.

fn shell(cmd: string) -> string {
    return exec(cmd)
}

fn main() {
    let hb = env_var("HEXA_BIN")
    if len(hb) == 0 {
        println("SKIP: HEXA_BIN not set")
        exit(77)
    }

    let tmp = exec("mktemp -d -t hexa_cache_test.XXXXXX | tr -d '\\n'")
    if len(tmp) == 0 {
        println("FAIL: mktemp failed")
        exit(1)
    }
    let _mk = exec("mkdir -p " + tmp + "/.hexa-cache")
    // Seed two fake entries — one non-empty, one zero-size (verify flag bait).
    let _w1 = exec("printf 'aaa' > " + tmp + "/.hexa-cache/hexa_run.fake_abc")
    let _w2 = exec("printf '' > " + tmp + "/.hexa-cache/hexa_run.empty_def")

    let envp = "HOME=" + tmp + " "

    // --- stat ---
    let out_stat = exec(envp + hb + " cache stat 2>&1; echo __RC=$?")
    if !out_stat.contains("hexa cache stat") || !out_stat.contains("entries:") {
        println("FAIL: stat banner missing")
        println(out_stat)
        exit(1)
    }
    if !out_stat.contains("__RC=0") {
        println("FAIL: stat rc != 0")
        println(out_stat)
        exit(1)
    }

    // --- list ---
    let out_list = exec(envp + hb + " cache list 2>&1; echo __RC=$?")
    if !out_list.contains("hexa cache list") {
        println("FAIL: list banner missing")
        println(out_list)
        exit(1)
    }

    // --- verify (expected rc=1 because we seeded an empty entry) ---
    let out_ver = exec(envp + hb + " cache verify 2>&1; echo __RC=$?")
    if !out_ver.contains("empty/broken:") {
        println("FAIL: verify missing empty/broken line")
        println(out_ver)
        exit(1)
    }

    // --- clean (dry-run, no flags) ---
    let out_clean = exec(envp + hb + " cache clean 2>&1; echo __RC=$?")
    if !out_clean.contains("dry-run") {
        println("FAIL: clean missing dry-run notice")
        println(out_clean)
        exit(1)
    }
    if !out_clean.contains("__RC=0") {
        println("FAIL: clean rc != 0")
        println(out_clean)
        exit(1)
    }

    // --- clean --prune --older-than=0 → should remove everything ---
    let out_prune = exec(envp + hb + " cache clean --prune --older-than=0 2>&1; echo __RC=$?")
    if !out_prune.contains("__RC=0") {
        println("FAIL: clean --prune rc != 0")
        println(out_prune)
        exit(1)
    }

    let _rm = exec("rm -rf " + tmp)
    println("PASS: 4 subverbs (stat · list · verify · clean) smoke OK")
    exit(0)
}
