// M0 milestone — codegen broadening (C6) regalloc fixture.
//
// @version 0.1.0
// @capabilities [pure]
//
// Exercises the linear-scan register allocator (Poletto-Sarkar 1999):
// a 40-local chain so the interval count exceeds the 16-slot arm64
// pool (x10..x15 + x19..x28) for short stretches and forces register
// reuse for the 6-slot x86_64 pool (rax/rbx + r12..r15) — but NOT
// spilling, because each `lN = l(N-1) + 1` only keeps `l(N-1)` and
// `lN` simultaneously live (live-set always 2).
//
// Driver-level compile path does not yet reach codegen on real source
// (multi-file lower not wired); verification runs from
// tests/m0/regalloc_test.hexa, which hand-builds the equivalent MIR
// and asserts on the emitted .s.
fn many_locals(a: i32) -> i32 {
    let l1  = a + 1
    let l2  = l1 + 1
    let l3  = l2 + 1
    let l4  = l3 + 1
    let l5  = l4 + 1
    let l6  = l5 + 1
    let l7  = l6 + 1
    let l8  = l7 + 1
    let l9  = l8 + 1
    let l10 = l9 + 1
    let l11 = l10 + 1
    let l12 = l11 + 1
    let l13 = l12 + 1
    let l14 = l13 + 1
    let l15 = l14 + 1
    let l16 = l15 + 1
    let l17 = l16 + 1
    let l18 = l17 + 1
    let l19 = l18 + 1
    let l20 = l19 + 1
    let l21 = l20 + 1
    let l22 = l21 + 1
    let l23 = l22 + 1
    let l24 = l23 + 1
    let l25 = l24 + 1
    let l26 = l25 + 1
    let l27 = l26 + 1
    let l28 = l27 + 1
    let l29 = l28 + 1
    let l30 = l29 + 1
    let l31 = l30 + 1
    let l32 = l31 + 1
    let l33 = l32 + 1
    let l34 = l33 + 1
    let l35 = l34 + 1
    let l36 = l35 + 1
    let l37 = l36 + 1
    let l38 = l37 + 1
    let l39 = l38 + 1
    let l40 = l39 + 1
    return l40
}
