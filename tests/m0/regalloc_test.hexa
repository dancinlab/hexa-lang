// M0 milestone — codegen broadening (C6) regalloc smoke test.
//
// @version 0.1.0
// @capabilities [pure]
//
// Hand-builds the MIR equivalent of tests/m0/regalloc.hexa
// (`fn many_locals(a) -> i32 { let l1 = a + 1; ...; let l40 = l39 + 1;
// return l40 }`) and asserts that the post-C6 linear-scan allocator
// produces:
//
//   1. arm64-apple-darwin: at least one register from the C6 pool
//      (x10..x15, x19..x28) appears at least 3 times in the asm —
//      proving register reuse via interval expiry.
//   2. x86_64-linux-gnu:  at least one pool register (rax/rbx +
//      r12..r15) appears multiple times — same reuse contract.
//   3. No two simultaneously-live locals share a register: scan the
//      first 5 chain steps, confirm distinct destination registers
//      across consecutive `add` instructions (relaxed v1 check).
//   4. No `nop ; unhandled stmt kind` regression markers.
//
// Driven by stage0 hexa interpreter:
//   RESOURCE_LOCAL_HEXA=1 hexa_interp run tests/m0/regalloc_test.hexa
//
// Exit codes: 0 = PASS, 1 = FAIL.

import "../../compiler/ir/mir.hexa"
import "../../compiler/ir/lir.hexa"
import "../../compiler/codegen/arm64_darwin.hexa"
import "../../compiler/codegen/x86_64_linux.hexa"
import "../../compiler/emit/asm.hexa"

// ── MIR construction helpers ────────────────────────────────

fn _local(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name }
}

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local", local_id: local_id,
        int_val: 0, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _op_const_int(v: i64) -> Operand {
    return Operand {
        kind: "const_int", local_id: -1,
        int_val: v, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _stmt_binop(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return Stmt {
        kind: "binop", dst: dst, op: op,
        args: xs, target_block: -1, target_block_else: -1
    }
}

fn _stmt_return(src: Operand) -> Stmt {
    let mut xs = []
    xs.push(src)
    return Stmt {
        kind: "return", dst: _miss_local(), op: "",
        args: xs, target_block: -1, target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

// ── Build many_locals() MIR ─────────────────────────────────
//
// MIR shape (param a = L0):
//   bb0:
//     L1  = L0 + 1   (l1 = a + 1)
//     ...
//     L40 = L39 + 1
//     return L40
fn _build_many_locals(n: i64) -> MModule {
    let a = _local(0, "a")

    let mut locals = []
    locals.push(a)
    let mut i = 1
    while i < n + 1 {
        locals.push(_local(i, "l" + to_string(i)))
        i = i + 1
    }

    let mut stmts = []
    let mut k = 1
    while k < n + 1 {
        let dst = locals[k]
        let prev = locals[k - 1]
        stmts.push(_stmt_binop(dst, "+", _op_local(prev.id), _op_const_int(1)))
        k = k + 1
    }
    stmts.push(_stmt_return(_op_local(locals[n].id)))

    let mut blocks = []
    blocks.push(_block(0, stmts))

    let mut params = []
    params.push(a)

    let mf = MFunc {
        name: "many_locals",
        params: params,
        return_local: locals[n],
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "regalloc.hexa", funcs: fns, globals: [] }
}

// ── Substring + count helpers ───────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    let h = hay.chars()
    let n = needle.chars()
    let hn = len(h)
    let nn = len(n)
    if nn == 0 { return true }
    if nn > hn { return false }
    let mut i = 0
    while i + nn < hn + 1 {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if h[i + j] != n[j] { ok = false; break }
            j = j + 1
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

fn _count_occurrences(hay: string, needle: string) -> i64 {
    let h = hay.chars()
    let n = needle.chars()
    let hn = len(h)
    let nn = len(n)
    if nn == 0 { return 0 }
    if nn > hn { return 0 }
    let mut count = 0
    let mut i = 0
    while i + nn < hn + 1 {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if h[i + j] != n[j] { ok = false; break }
            j = j + 1
        }
        if ok { count = count + 1 }
        i = i + 1
    }
    return count
}

fn _max_reg_uses(asm: string, regs: [string]) -> i64 {
    let mut best = 0
    let mut i = 0
    while i < len(regs) {
        let n = _count_occurrences(asm, regs[i])
        if n > best { best = n }
        i = i + 1
    }
    return best
}

// ── arm64 driver ────────────────────────────────────────────

fn _check_arm64(mm: MModule) -> bool {
    println("")
    println("── arm64 / apple-darwin (arm64-apple-darwin) ──")

    let lm = codegen_arm64_darwin(mm)
    let asm = emit_asm(lm)
    println("  emit_asm output (" + to_string(len(asm.chars())) + " bytes)")

    let mut ok = true

    let mut pool: [string] = []
    pool.push("x10")
    pool.push("x11")
    pool.push("x12")
    pool.push("x13")
    pool.push("x14")
    pool.push("x15")
    pool.push("x19")
    pool.push("x20")
    pool.push("x21")
    pool.push("x22")
    pool.push("x23")
    pool.push("x24")
    pool.push("x25")
    pool.push("x26")
    pool.push("x27")
    pool.push("x28")

    let best = _max_reg_uses(asm, pool)
    println("  best pool-reg occurrence count: " + to_string(best))
    if best < 3 {
        println("  FAIL: expected at least one pool reg used 3+ times " +
                "(saw max " + to_string(best) + ")")
        ok = false
    } else {
        println("  ok: pool register reuse evident")
    }

    if !_contains(asm, "x0") {
        println("  FAIL: param ingress reg `x0` missing")
        ok = false
    } else { println("  ok: param ingress (x0) present") }

    if _contains(asm, "unhandled stmt kind") {
        println("  FAIL: unhandled stmt kind comment present")
        ok = false
    } else { println("  ok: no unhandled stmt comments") }

    if _contains(asm, "sub sp, sp, #") {
        println("  WARN: spill prologue present (allocator may have " +
                "spilled conservatively)")
    } else {
        println("  ok: no spill frame for 40-local chain (live-set <= 2)")
    }

    return ok
}

// ── x86_64 driver ───────────────────────────────────────────

fn _check_x86_64(mm: MModule) -> bool {
    println("")
    println("── x86_64 / linux-gnu (x86_64-linux-gnu) ──")

    let lm = codegen_x86_64_linux(mm)
    let asm = emit_asm(lm)
    println("  emit_asm output (" + to_string(len(asm.chars())) + " bytes)")

    let mut ok = true

    let mut pool: [string] = []
    pool.push("rax")
    pool.push("rbx")
    pool.push("r12")
    pool.push("r13")
    pool.push("r14")
    pool.push("r15")

    let best = _max_reg_uses(asm, pool)
    println("  best pool-reg occurrence count: " + to_string(best))
    if best < 6 {
        println("  FAIL: expected at least one pool reg used 6+ times " +
                "(saw max " + to_string(best) + ")")
        ok = false
    } else {
        println("  ok: pool register reuse evident")
    }

    if !_contains(asm, "rdi") {
        println("  FAIL: param ingress reg `rdi` missing")
        ok = false
    } else { println("  ok: param ingress (rdi) present") }

    if _contains(asm, "unhandled stmt kind") {
        println("  FAIL: unhandled stmt kind comment present")
        ok = false
    } else { println("  ok: no unhandled stmt comments") }

    if _contains(asm, "sub rsp, ") {
        println("  WARN: spill prologue (`sub rsp, ...`) present")
    } else {
        println("  ok: no spill frame for 40-local chain")
    }

    return ok
}

// ── Driver ──────────────────────────────────────────────────

fn main() {
    println("══════════════════════════════════════════════")
    println("  M0 — regalloc smoke (C6 linear-scan)")
    println("══════════════════════════════════════════════")

    let mm = _build_many_locals(40)

    let mut ok = true
    let ok_arm = _check_arm64(mm)
    if !ok_arm { ok = false }
    let ok_x86 = _check_x86_64(mm)
    if !ok_x86 { ok = false }

    println("")
    println("══════════════════════════════════════════════")
    if ok {
        println("PASS: regalloc — register reuse + no spill on 40-local chain.")
        println("══════════════════════════════════════════════")
        exit(0)
    }
    println("FAIL: regalloc contract not satisfied.")
    println("══════════════════════════════════════════════")
    exit(1)
}
