// M0 milestone — codegen broadening (Gap 15) loop smoke test.
//
// @version 0.1.0
// @capabilities [pure]
//
// Hand-builds the MIR equivalent of the source in tests/m0/loop.hexa:
//
//   fn sum10() -> i32 {
//       let mut s = 0
//       let mut i = 0
//       while i < 10 {
//           s = s + i
//           i = i + 1
//       }
//       return s
//   }
//
// Asserts that the produced .s text contains:
//   - a comparison (`cmp` mnemonic on both targets),
//   - a backward branch to the loop header (block label appears more
//     than once across the asm — one for definition, one for the
//     branch back-edge),
//   - an `add` mnemonic for the body increments.
//
// Driven by stage0 hexa interpreter:
//   RESOURCE_LOCAL_HEXA=1 hexa_interp run tests/m0/loop_test.hexa
//
// Exit codes: 0 = PASS, 1 = FAIL.

import "../../compiler/ir/mir.hexa"
import "../../compiler/ir/lir.hexa"
import "../../compiler/codegen/arm64_darwin.hexa"
import "../../compiler/codegen/x86_64_linux.hexa"
import "../../compiler/emit/asm.hexa"

// ── MIR construction helpers ────────────────────────────────

fn _local(id: i64, name: string) -> Local {
    return Local { id: id, arena_id: 1, type_id: 0, name_hint: name }
}

fn _miss_local() -> Local {
    return Local { id: -1, arena_id: 0, type_id: 0, name_hint: "" }
}

fn _op_local(local_id: i64) -> Operand {
    return Operand {
        kind: "local", local_id: local_id,
        int_val: 0, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _op_const_int(v: i64) -> Operand {
    return Operand {
        kind: "const_int", local_id: -1,
        int_val: v, float_val: 0.0, str_val: "", global_id: -1
    }
}

fn _stmt_assign(dst: Local, src: Operand) -> Stmt {
    let mut xs = []
    xs.push(src)
    return Stmt {
        kind: STMT_ASSIGN, dst: dst, op: "",
        args: xs, target_block: -1, target_block_else: -1
    }
}

fn _stmt_binop(dst: Local, op: string, a: Operand, b: Operand) -> Stmt {
    let mut xs = []
    xs.push(a)
    xs.push(b)
    return Stmt {
        kind: STMT_BINOP, dst: dst, op: op,
        args: xs, target_block: -1, target_block_else: -1
    }
}

fn _stmt_br(target_block: i64) -> Stmt {
    return Stmt {
        kind: STMT_BR, dst: _miss_local(), op: "",
        args: [], target_block: target_block, target_block_else: -1
    }
}

fn _stmt_br_cond(cond_local: Local, then_block: i64, else_block: i64) -> Stmt {
    let mut xs = []
    xs.push(_op_local(cond_local.id))
    return Stmt {
        kind: STMT_BR_COND, dst: _miss_local(), op: "",
        args: xs,
        target_block: then_block, target_block_else: else_block
    }
}

fn _stmt_return(src: Operand) -> Stmt {
    let mut xs = []
    xs.push(src)
    return Stmt {
        kind: STMT_RETURN, dst: _miss_local(), op: "",
        args: xs, target_block: -1, target_block_else: -1
    }
}

fn _block(id: i64, stmts: [Stmt]) -> Block {
    return Block { id: id, stmts: stmts, preds: [], succs: [] }
}

// ── Build sum10() MIR ───────────────────────────────────────
//
// Block layout:
//   bb0 (entry): s = 0; i = 0; goto bb1
//   bb1 (head) : t_cmp = i < 10; br_cond t_cmp -> bb2 else bb3
//   bb2 (body) : s = s + i; i = i + 1; goto bb1   ← back-edge
//   bb3 (exit) : return s
fn _build_sum10() -> MModule {
    let s     = _local(0, "s")
    let i     = _local(1, "i")
    let t_cmp = _local(2, "t_cmp")
    let t_si  = _local(3, "t_si")
    let t_i1  = _local(4, "t_i1")
    let retL  = _local(5, "ret")

    // bb0
    let mut bb0_stmts = []
    bb0_stmts.push(_stmt_assign(s, _op_const_int(0)))
    bb0_stmts.push(_stmt_assign(i, _op_const_int(0)))
    bb0_stmts.push(_stmt_br(1))

    // bb1 (head): t_cmp = i < 10
    let mut bb1_stmts = []
    bb1_stmts.push(_stmt_binop(t_cmp, "<", _op_local(i.id), _op_const_int(10)))
    bb1_stmts.push(_stmt_br_cond(t_cmp, 2, 3))

    // bb2 (body): s = s + i; i = i + 1; goto bb1
    let mut bb2_stmts = []
    bb2_stmts.push(_stmt_binop(t_si, "+", _op_local(s.id), _op_local(i.id)))
    bb2_stmts.push(_stmt_assign(s, _op_local(t_si.id)))
    bb2_stmts.push(_stmt_binop(t_i1, "+", _op_local(i.id), _op_const_int(1)))
    bb2_stmts.push(_stmt_assign(i, _op_local(t_i1.id)))
    bb2_stmts.push(_stmt_br(1))

    // bb3 (exit): return s
    let mut bb3_stmts = []
    bb3_stmts.push(_stmt_return(_op_local(s.id)))

    let mut blocks = []
    blocks.push(_block(0, bb0_stmts))
    blocks.push(_block(1, bb1_stmts))
    blocks.push(_block(2, bb2_stmts))
    blocks.push(_block(3, bb3_stmts))

    let mut params = []
    let mut locals = []
    locals.push(s)
    locals.push(i)
    locals.push(t_cmp)
    locals.push(t_si)
    locals.push(t_i1)
    locals.push(retL)

    let mf = MFunc {
        name: "sum10",
        params: params,
        return_local: retL,
        locals: locals,
        blocks: blocks,
        entry_block: 0,
        arena_root: 1
    }
    let mut fns = []
    fns.push(mf)
    return MModule { file: "loop.hexa", funcs: fns, globals: [] }
}

// ── Substring + count helpers ───────────────────────────────

fn _contains(hay: string, needle: string) -> bool {
    let h = hay.chars()
    let n = needle.chars()
    let hn = len(h)
    let nn = len(n)
    if nn == 0 { return true }
    if nn > hn { return false }
    let mut i = 0
    while i + nn < hn + 1 {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if h[i + j] != n[j] {
                ok = false
                break
            }
            j = j + 1
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

fn _count_occurrences(hay: string, needle: string) -> i64 {
    let h = hay.chars()
    let n = needle.chars()
    let hn = len(h)
    let nn = len(n)
    if nn == 0 { return 0 }
    if nn > hn { return 0 }
    let mut count = 0
    let mut i = 0
    while i + nn < hn + 1 {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if h[i + j] != n[j] {
                ok = false
                break
            }
            j = j + 1
        }
        if ok { count = count + 1 }
        i = i + 1
    }
    return count
}

// ── Per-target driver ───────────────────────────────────────

fn _run_target(label: string, target: string,
               want_back_branch: string,
               loop_header_label: string) -> bool {
    println("")
    println("── " + label + " (" + target + ") ──")

    let mm = _build_sum10()
    let mut lm = codegen_arm64_darwin(mm)
    if target == "x86_64-linux-gnu" { lm = codegen_x86_64_linux(mm) }
    let asm = emit_asm(lm)

    println("  emit_asm output (" + to_string(len(asm.chars())) + " bytes):")
    println("------ BEGIN .s ------")
    println(asm)
    println("------- END .s -------")

    let mut ok = true

    if !_contains(asm, "cmp ") {
        println("  FAIL: missing `cmp` opcode")
        ok = false
    } else { println("  ok: `cmp` opcode present") }

    // Loop header label appears at definition AND at back-branch
    // target (≥ 2 occurrences in asm text).
    let n_label_hits = _count_occurrences(asm, loop_header_label)
    if n_label_hits < 2 {
        println("  FAIL: loop header `" + loop_header_label +
                "` only appears " + to_string(n_label_hits) +
                " times — back-edge missing")
        ok = false
    } else {
        println("  ok: loop header `" + loop_header_label +
                "` appears " + to_string(n_label_hits) + " times")
    }

    if !_contains(asm, want_back_branch) {
        println("  FAIL: missing back-branch `" + want_back_branch + "`")
        ok = false
    } else { println("  ok: back-branch present") }

    if !_contains(asm, "add ") {
        println("  FAIL: missing `add` opcode (body increments)")
        ok = false
    } else { println("  ok: `add` opcode present") }

    return ok
}

fn main() {
    println("══════════════════════════════════════════════")
    println("  M0 — loop smoke (Gap 15 codegen broadening)")
    println("══════════════════════════════════════════════")

    let mut ok = true

    // arm64: backward branch is `b _L<modhash>_sum10_bb1`. After
    // Stage1 C8 the block label gains a per-source modhash prefix
    // (first 4 hex of sha256(module.file)) so we can no longer grep
    // for the bare `_Lsum10_bb1` form. Switch to a fn-suffix grep
    // (`sum10_bb1`) that survives any modhash prefixing — the back
    // edge still terminates with that suffix, and we still count
    // 2+ hits (definition + branch target).
    let ok_arm = _run_target("arm64 / apple-darwin",
                             "arm64-apple-darwin",
                             "sum10_bb1",
                             "sum10_bb1")
    if !ok_arm { ok = false }

    // x86_64: backward branch is `jmp .L<modhash>_sum10_bb1`.
    // Same Stage1 C8 fn-suffix-grep treatment.
    let ok_x86 = _run_target("x86_64 / linux-gnu",
                             "x86_64-linux-gnu",
                             "sum10_bb1",
                             "sum10_bb1")
    if !ok_x86 { ok = false }

    println("")
    println("══════════════════════════════════════════════")
    if ok {
        println("PASS: loop smoke — cmp + back-edge + add both targets.")
        println("══════════════════════════════════════════════")
        exit(0)
    }
    println("FAIL: loop smoke contract not satisfied.")
    println("══════════════════════════════════════════════")
    exit(1)
}
