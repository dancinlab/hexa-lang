// M0 milestone — codegen broadening (Gap 15) source fixture.
//
// Companion to tests/m0/concat.hexa: this exercise covers loops with a
// backward branch + a comparison. The driver-level compile path does
// not yet reach codegen on real source — verification runs from
// tests/m0/loop_test.hexa, which hand-builds the equivalent MIR and
// asserts the produced .s contains:
//   - a comparison opcode (`cmp` on arm64, `cmp` on x86_64)
//   - a conditional branch back to the loop header
//   - one or more arithmetic adds for the body increments.
fn sum10() -> i32 {
    let mut s = 0
    let mut i = 0
    while i < 10 {
        s = s + i
        i = i + 1
    }
    return s
}
