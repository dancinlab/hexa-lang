// tests/m_cache_gc_test.hexa — GO M1 milestone: ~/.hexa-cache automatic GC.
//
// Validates the `_hexa_cache_gc(cache_dir, cap_mb, ttl_days)` policy that
// `self/main.hexa` invokes at the top of cmd_run / cmd_run_user_direct /
// _batch_run_one / cmd_build. The test re-implements the GC body inline
// (the helper is private to the driver) and exercises it against a
// fabricated cache dir, then asserts the post-state.
//
// Three scenarios:
//   (A) tmp-orphan sweep   — *.tmp.<ns> older than 60 min are deleted
//   (B) TTL eviction       — hexa_run.* older than ttl_days deleted
//   (C) LRU cap eviction   — total bytes over cap → oldest deleted first
//
// Exit codes:
//   0 — all 3 scenarios PASS
//   1 — any scenario FAIL

fn _trim(s: string) -> string {
    return s.trim()
}

fn _exec(cmd: string) -> string {
    return to_string(exec(cmd))
}

fn _exists(path: string) -> bool {
    return _trim(_exec("test -e " + path + " && printf ok || printf no")) == "ok"
}

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn parse_int_str(s: string) -> i64 {
    // Minimal positive-int parser used inside the cache-GC body. POSIX
    // `awk` filters and prints the integer; we then read it digit-wise.
    let cleaned = _trim(_exec("printf %s " + _shq(s) + " | awk '{ if ($1 ~ /^[0-9]+$/) print int($1); else print 0 }'"))
    let n = len(cleaned)
    if n == 0 { return 0 }
    let mut r: i64 = 0
    let mut i = 0
    while i < n {
        let c = cleaned.substring(i, i + 1)
        let mut d: i64 = 0
        if c == "1" { d = 1 }
        if c == "2" { d = 2 }
        if c == "3" { d = 3 }
        if c == "4" { d = 4 }
        if c == "5" { d = 5 }
        if c == "6" { d = 6 }
        if c == "7" { d = 7 }
        if c == "8" { d = 8 }
        if c == "9" { d = 9 }
        r = r * 10 + d
        i = i + 1
    }
    return r
}

// ─── _hexa_cache_gc, inline copy of the self/main.hexa helper ───────
//
// Kept byte-equivalent to the driver so the test exercises the same
// shell semantics. Any change in self/main.hexa must mirror here (and
// vice-versa) — a future shared-module extract would deduplicate.
fn _hexa_cache_gc(cache_dir: string, cap_mb: i64, ttl_days: i64) {
    let _sent = cache_dir + "/.gc_last"
    let _skip = _trim(_exec("[ -f " + _shq(_sent) + " ] && find " + _shq(_sent) + " -mmin -1 2>/dev/null | grep -c . || printf 0"))
    if _skip == "1" { return }
    let _tmp_cl = _exec("find " + _shq(cache_dir) + " -maxdepth 1 -name '*.tmp.*' -mmin +60 -delete 2>/dev/null")
    if ttl_days > 0 {
        let _ttl_cl = _exec("find " + _shq(cache_dir) + " -maxdepth 1 -name 'hexa_run.*' -mtime +" + to_string(ttl_days) + " -delete 2>/dev/null")
    }
    if cap_mb > 0 {
        let _cap_kb = cap_mb * 1024
        let _used_s = _trim(_exec("du -sk " + _shq(cache_dir) + " 2>/dev/null | awk '{print $1}'"))
        let _used_kb = parse_int_str(_used_s)
        if _used_kb > _cap_kb {
            let _lru = "set -e; CAP=" + to_string(_cap_kb) + "; DIR=" + _shq(cache_dir) + ";"
                + " for f in $(ls -1tr \"$DIR\" 2>/dev/null | grep '^hexa_run\\.'); do"
                + "   U=$(du -sk \"$DIR\" 2>/dev/null | awk '{print $1}');"
                + "   [ \"$U\" -le \"$CAP\" ] && break;"
                + "   rm -f \"$DIR/$f\" 2>/dev/null;"
                + " done"
            let _lru_r = _exec(_lru + " 2>/dev/null")
        }
    }
    let _touch = _exec("touch " + _shq(_sent) + " 2>/dev/null")
}

// ─── test scaffolding ──────────────────────────────────────────────
fn _mkfake_dir() -> string {
    let d = _trim(_exec("mktemp -d -t hexa_cache_gc_test 2>/dev/null"))
    return d
}

fn _count_glob(dir: string, pat: string) -> i64 {
    let c = _trim(_exec("ls -1 " + _shq(dir) + "/" + pat + " 2>/dev/null | wc -l | tr -d ' '"))
    return parse_int_str(c)
}

fn _scenario_tmp_orphan() -> bool {
    let d = _mkfake_dir()
    if len(d) == 0 { println("  [A] mktemp failed"); return false }
    // 3 fresh tmp files (should survive) + 3 stale (>60 min old).
    _exec("touch " + _shq(d) + "/hexa_run.aaa.tmp.1 " + _shq(d) + "/hexa_run.bbb.tmp.2 " + _shq(d) + "/hexa_run.ccc.tmp.3 2>/dev/null")
    _exec("touch " + _shq(d) + "/hexa_run.x.tmp.9 " + _shq(d) + "/hexa_run.y.tmp.8 " + _shq(d) + "/hexa_run.z.tmp.7 2>/dev/null")
    // Backdate the latter 3 by 2 hours.
    _exec("touch -t 200001010000 " + _shq(d) + "/hexa_run.x.tmp.9 " + _shq(d) + "/hexa_run.y.tmp.8 " + _shq(d) + "/hexa_run.z.tmp.7 2>/dev/null")
    _hexa_cache_gc(d, 2048, 30)
    let n_tmp = _count_glob(d, "*.tmp.*")
    _exec("rm -rf " + _shq(d) + " 2>/dev/null")
    // Expected: 3 fresh survive, 3 stale gone.
    if n_tmp != 3 {
        println("  [A] FAIL: expected 3 surviving *.tmp.*, got " + to_string(n_tmp))
        return false
    }
    println("  [A] PASS: tmp orphan sweep — 3 fresh kept, 3 stale evicted")
    return true
}

fn _scenario_ttl() -> bool {
    let d = _mkfake_dir()
    if len(d) == 0 { println("  [B] mktemp failed"); return false }
    // 2 fresh hexa_run.* + 2 old (>30 days).
    _exec("touch " + _shq(d) + "/hexa_run.fresh1_v1 " + _shq(d) + "/hexa_run.fresh2_v1 2>/dev/null")
    _exec("touch " + _shq(d) + "/hexa_run.old1_v1 " + _shq(d) + "/hexa_run.old2_v1 2>/dev/null")
    _exec("touch -t 202001010000 " + _shq(d) + "/hexa_run.old1_v1 " + _shq(d) + "/hexa_run.old2_v1 2>/dev/null")
    // TTL=30 days, cap=0 disables LRU so we isolate TTL.
    _hexa_cache_gc(d, 0, 30)
    let n_run = _count_glob(d, "hexa_run.*")
    _exec("rm -rf " + _shq(d) + " 2>/dev/null")
    if n_run != 2 {
        println("  [B] FAIL: expected 2 surviving hexa_run.*, got " + to_string(n_run))
        return false
    }
    println("  [B] PASS: TTL eviction — 2 fresh kept, 2 stale evicted")
    return true
}

fn _scenario_lru_cap() -> bool {
    let d = _mkfake_dir()
    if len(d) == 0 { println("  [C] mktemp failed"); return false }
    // 5 files × 1 MiB each = 5 MiB. Cap = 2 MiB → expect <=3 survive
    // (du counts blocks so leave a small headroom). 2 oldest deleted.
    // Use `dd` for portable 1 MiB sparse-free files.
    _exec("dd if=/dev/zero of=" + _shq(d) + "/hexa_run.a_v1 bs=1024 count=1024 2>/dev/null")
    _exec("touch -t 202101010000 " + _shq(d) + "/hexa_run.a_v1 2>/dev/null")
    _exec("dd if=/dev/zero of=" + _shq(d) + "/hexa_run.b_v1 bs=1024 count=1024 2>/dev/null")
    _exec("touch -t 202201010000 " + _shq(d) + "/hexa_run.b_v1 2>/dev/null")
    _exec("dd if=/dev/zero of=" + _shq(d) + "/hexa_run.c_v1 bs=1024 count=1024 2>/dev/null")
    _exec("touch -t 202301010000 " + _shq(d) + "/hexa_run.c_v1 2>/dev/null")
    _exec("dd if=/dev/zero of=" + _shq(d) + "/hexa_run.d_v1 bs=1024 count=1024 2>/dev/null")
    _exec("touch -t 202401010000 " + _shq(d) + "/hexa_run.d_v1 2>/dev/null")
    _exec("dd if=/dev/zero of=" + _shq(d) + "/hexa_run.e_v1 bs=1024 count=1024 2>/dev/null")
    // e_v1 stays fresh.
    let before = _count_glob(d, "hexa_run.*")
    _hexa_cache_gc(d, 2, 0)  // cap = 2 MiB, TTL = 0 (disabled)
    let after = _count_glob(d, "hexa_run.*")
    // Check oldest (a_v1, b_v1) got evicted, newest (d_v1, e_v1) survived.
    let a_alive = _exists(d + "/hexa_run.a_v1")
    let e_alive = _exists(d + "/hexa_run.e_v1")
    _exec("rm -rf " + _shq(d) + " 2>/dev/null")
    if before != 5 {
        println("  [C] FAIL: setup wrong, before=" + to_string(before))
        return false
    }
    if after >= 5 {
        println("  [C] FAIL: no eviction, after=" + to_string(after))
        return false
    }
    if a_alive {
        println("  [C] FAIL: oldest (a_v1) should be evicted but survived")
        return false
    }
    if !e_alive {
        println("  [C] FAIL: newest (e_v1) should survive but evicted")
        return false
    }
    println("  [C] PASS: LRU cap eviction — before=" + to_string(before) + " after=" + to_string(after) + " (oldest gone, newest kept)")
    return true
}

pub fn main() -> i32 {
    println("[m_cache_gc_test] start (GO M1 — ~/.hexa-cache automatic GC)")
    let mut ok = true
    if !_scenario_tmp_orphan() { ok = false }
    if !_scenario_ttl()         { ok = false }
    if !_scenario_lru_cap()     { ok = false }
    if ok {
        println("[m_cache_gc_test] ALL 3 SCENARIOS PASS")
        return 0
    }
    println("[m_cache_gc_test] FAIL")
    return 1
}
