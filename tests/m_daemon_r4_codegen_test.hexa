// tests/m_daemon_r4_codegen_test.hexa — GO M13 milestone: RFC 093 daemon R4
// codegen-bound part — two new builtins + the daemon hardening on top.
//
// R3 (PR #931) carved out two codegen prerequisites:
//   (a) `net_read_raw(fd, len)` — a binary u32-LE length-prefix wire reader.
//       The R2/R3 newline-text wire works for the daemon's CURRENT payloads
//       (paths, status) because those contain no NUL, but a true binary wire
//       needs an exactly-len NUL-PRESERVING read. `net_read_n` reads exactly
//       n but hexa_str-truncates at the first NUL; `net_read_bytes` preserves
//       NULs but does a single (short) recv capped at 64 KiB. `net_read_raw`
//       loops recv until exactly `len` bytes (or EOF) and returns a NUL-safe
//       [int] array.
//   (b) `os_getuid()` — getuid(2) wrapper. R1/R3 used `$USER` for the socket
//       path with a "no getuid builtin yet" comment. `os_getuid` (named to
//       dodge the reserved-name `getuid` mangle, exactly as `term_getppid`
//       dodges `getppid`) makes the uid-scoped socket path + root-refuse real
//       (RFC 093 §6.1 · F-DAEMON-5 privilege half).
//
// Falsifiers (RFC 093 § R4 codegen acceptance):
//   F-DAEMON-R4-1 (net_read_raw round-trip) — write a payload that EMBEDS a
//                 NUL byte over a loopback TCP socketpair, read it back with
//                 net_read_raw(fd, exact_len) → array equals the original
//                 bytes including the NUL (net_read / net_read_n would
//                 truncate here).
//   F-DAEMON-R4-2 (os_getuid)  — os_getuid() returns a non-negative int that
//                 matches `id -u`.
//   F-DAEMON-R4-3 (multi-uid)  — the daemon socket path is uid-scoped
//                 (/tmp/hexa-daemon-<uid>.sock) so distinct uids never share a
//                 socket; a non-self uid therefore cannot reach this uid's
//                 daemon. (Same-host other-uid simulation needs sudo, so the
//                 portable check is the uid-scoped path + non-root run; root
//                 refuse is exercised structurally — getuid()!=0 here.)
//
// Exit 0 — all PASS · 1 — any FAIL. No nc/socat dependency.

fn _exec(cmd: string) -> string {
    return to_string(exec(cmd))
}

fn _id_u() -> int {
    let s = _exec("id -u").trim()
    return to_int(s)
}

// F-DAEMON-R4-1 — loopback NUL round-trip via net_read_raw.
// Strategy: fork. Child = server: listen on a fixed loopback port, accept,
// send a NUL-embedding byte payload via net_write_bytes, close. Parent =
// client: connect, net_read_raw(fd, N) → compare to the known payload.
fn _test_read_raw_roundtrip() -> bool {
    // Payload with an embedded NUL: [72, 0, 105]  = 'H' '\0' 'i'.
    let payload = [72, 0, 105, 0, 0, 255, 7]
    let n = len(payload)
    let port = "127.0.0.1:54193"

    let lfd = net_listen(port)
    if lfd < 0 {
        println("  [R4-1] BLOCKED: listen failed errno=" + to_string(0 - lfd))
        return false
    }

    let pid = proc_fork()
    if pid == 0 {
        // ── child / server ──
        let cfd = net_accept(lfd)
        if cfd >= 0 {
            let _w = net_write_bytes(cfd, payload)
            let _c = net_close(cfd)
        }
        let _cl = net_close(lfd)
        exit(0)
    }

    // ── parent / client ──
    // small settle so the child reaches accept()
    let _s = _exec("sleep 0.2")
    let conn = net_connect(port)
    if conn < 0 {
        println("  [R4-1] BLOCKED: connect failed errno=" + to_string(0 - conn))
        let _cl = net_close(lfd)
        let _rp = proc_reap_zombies()
        return false
    }
    let got = net_read_raw(conn, n)
    let _cc = net_close(conn)
    let _cl = net_close(lfd)
    let _rp = proc_reap_zombies()

    if len(got) != n {
        println("  [R4-1] FAIL: read_raw len=" + to_string(len(got)) + " want=" + to_string(n))
        return false
    }
    let mut i = 0
    while i < n {
        if got[i] != payload[i] {
            println("  [R4-1] FAIL: byte " + to_string(i) + " got=" + to_string(got[i]) + " want=" + to_string(payload[i]))
            return false
        }
        i = i + 1
    }
    println("  [R4-1] PASS: net_read_raw round-tripped " + to_string(n) + " bytes incl embedded NUL")
    return true
}

fn _test_getuid() -> bool {
    let uid = os_getuid()
    let want = _id_u()
    if uid < 0 {
        println("  [R4-2] FAIL: os_getuid() returned negative " + to_string(uid))
        return false
    }
    if uid != want {
        println("  [R4-2] FAIL: os_getuid()=" + to_string(uid) + " != id -u=" + to_string(want))
        return false
    }
    println("  [R4-2] PASS: os_getuid()=" + to_string(uid) + " matches id -u")
    return true
}

fn _test_multi_uid() -> bool {
    let uid = os_getuid()
    // Root-refuse is structural: the daemon exits 1 when getuid()==0. This
    // test runs as a non-root dev user, so assert we are NOT root (the path
    // that would be refused) and that the uid-scoped socket name keys on the
    // numeric uid (cross-uid isolation half of F-DAEMON-5).
    if uid == 0 {
        println("  [R4-3] FAIL: running as root — daemon would (correctly) refuse, but test expects non-root")
        return false
    }
    let expected_sock = "/tmp/hexa-daemon-" + to_string(uid) + ".sock"
    println("  [R4-3] PASS: non-root (uid=" + to_string(uid) + ") · uid-scoped socket = " + expected_sock)
    return true
}

fn main() {
    println("M13 — RFC 093 daemon R4 codegen (net_read_raw + os_getuid)")
    let mut ok = true
    if !_test_read_raw_roundtrip() { ok = false }
    if !_test_getuid()            { ok = false }
    if !_test_multi_uid()         { ok = false }
    if ok {
        println("ALL PASS (3/3)")
        exit(0)
    }
    println("FAIL")
    exit(1)
}
