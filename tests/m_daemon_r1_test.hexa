// tests/m_daemon_r1_test.hexa — GO M10 milestone: `hexa daemon` R1 prototype
// end-to-end (RFC 093 Phase 1 — socket protocol skeleton + verb dispatch).
//
// 4-step lifecycle:
//   (1) daemon start (bg)         — fork + bind unix socket
//   (2) daemon status             — PING/PONG roundtrip → exit 0
//   (3) daemon echo "<text>"      — ECHO loopback roundtrip
//   (4) daemon stop               — SHUTDOWN ack → server unlinks socket
//                                   follow-up status → exit 1
//
// Exit codes:
//   0 — all 4 steps PASS
//   1 — any step FAIL
//
// R1 scope (per RFC 093 § Phase plan): socket + verb + lifecycle ONLY,
// no compile logic. The test exercises the full message frame round-trip
// without depending on `nc`/`socat` — both client and server are driven
// through the `hexa daemon` CLI itself.

fn _trim(s: string) -> string {
    return s.trim()
}

fn _exec(cmd: string) -> string {
    return to_string(exec(cmd))
}

fn _exists(path: string) -> bool {
    return _trim(_exec("test -e " + path + " && printf ok || printf no")) == "ok"
}

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_hexa_bin() -> string {
    // Prefer the same driver that runs *this* script — env HEXA_BIN > $HEXA_LANG/hexa
    // > on-PATH `hexa`. Mirrors the daemon-start-bg argv0 resolution so we
    // exercise the same dispatcher across the test (no client/server skew).
    let env_bin = env_var("HEXA_BIN")
    if len(env_bin) > 0 { return env_bin }
    let root = env_var("HEXA_LANG")
    if len(root) > 0 {
        let p = root + "/hexa"
        if _exists(p) { return p }
    }
    return "hexa"
}

fn _temp_socket_path() -> string {
    // Unique per-process under /tmp (NOT $TMPDIR / /var/folders) so the
    // path stays well within sockaddr_un.sun_path's ~104-byte limit on
    // macOS. mono_ns() gives a collision-free suffix without forking
    // mktemp (whose -u template expansion differs BSD vs GNU).
    return "/tmp/hexa_daemon_r1_test." + to_string(mono_ns()) + ".sock"
}

fn _wait_for_socket(sock_path: string, max_ms: i64) -> bool {
    let mut waited = 0
    while waited < max_ms {
        if _exists(sock_path) { return true }
        sleep_ms(50)
        waited = waited + 50
    }
    return false
}

fn _wait_for_socket_gone(sock_path: string, max_ms: i64) -> bool {
    let mut waited = 0
    while waited < max_ms {
        if !_exists(sock_path) { return true }
        sleep_ms(50)
        waited = waited + 50
    }
    return false
}

pub fn main() -> i32 {
    println("[m_daemon_r1_test] start (GO M10 — RFC 093 R1 prototype)")

    let bin = _resolve_hexa_bin()
    let sock = _temp_socket_path()
    println("  bin=" + bin)
    println("  sock=" + sock)

    let mut ok = true

    // ─── step (1): daemon start (bg) ───────────────────────────────
    // Spawn directly via shell `&` so we don't depend on `hexa daemon
    // start-bg` (that path is itself under test). Idle TTL 30 s keeps
    // the server alive long enough for the 4-step sequence even on a
    // slow CI runner, but bounded so a crashed test doesn't leak.
    let log_path = sock + ".log"
    let _spawn = _exec("nohup " + _shq(bin) + " daemon start --socket " + _shq(sock) + " --idle-ttl 30 > " + _shq(log_path) + " 2>&1 &")
    if _wait_for_socket(sock, 3000) {
        println("  [1] PASS: daemon start — socket bound (" + sock + ")")
    } else {
        let log_tail = _trim(_exec("tail -20 " + _shq(log_path) + " 2>/dev/null"))
        println("  [1] FAIL: socket never appeared within 3 s")
        println("       log: " + log_tail)
        ok = false
    }

    // ─── step (2): daemon status — PING/PONG ───────────────────────
    if ok {
        let status_pair = exec_with_status(_shq(bin) + " daemon status --socket " + _shq(sock) + " 2>&1")
        let status_out = to_string(status_pair[0])
        let status_rc = to_string(status_pair[1])
        if status_rc == "0" && status_out.contains("alive") {
            println("  [2] PASS: daemon status — alive ack")
        } else {
            println("  [2] FAIL: status rc=" + status_rc + " out=" + status_out.trim())
            ok = false
        }
    }

    // ─── step (3): daemon echo — ECHO loopback ─────────────────────
    if ok {
        let msg = "hello-r1-skeleton"
        let echo_out = _trim(_exec(_shq(bin) + " daemon echo " + _shq(msg) + " --socket " + _shq(sock) + " 2>&1"))
        let want = "ECHO " + msg
        if echo_out == want {
            println("  [3] PASS: daemon echo — loopback (\"" + msg + "\")")
        } else {
            println("  [3] FAIL: echo expected '" + want + "', got '" + echo_out + "'")
            ok = false
        }
    }

    // ─── step (4): daemon stop — SHUTDOWN ack + socket unlinked ────
    if ok {
        let stop_pair = exec_with_status(_shq(bin) + " daemon stop --socket " + _shq(sock) + " 2>&1")
        let stop_rc = to_string(stop_pair[1])
        if stop_rc != "0" {
            println("  [4a] FAIL: stop rc=" + stop_rc)
            ok = false
        } else if !_wait_for_socket_gone(sock, 3000) {
            println("  [4b] FAIL: socket file still present 3 s after stop (" + sock + ")")
            ok = false
        } else {
            // Sanity: follow-up status should now exit 1 ("not running").
            let post_pair = exec_with_status(_shq(bin) + " daemon status --socket " + _shq(sock) + " 2>&1")
            let post_rc = to_string(post_pair[1])
            if post_rc == "1" {
                println("  [4] PASS: daemon stop — SHUTDOWN ack + socket gone + post-status=1")
            } else {
                println("  [4c] FAIL: post-stop status rc=" + post_rc + " (expected 1)")
                ok = false
            }
        }
    }

    // Cleanup the spawn log + any residual socket on failure paths.
    let _cl1 = _exec("rm -f " + _shq(log_path) + " 2>/dev/null")
    let _cl2 = _exec("rm -f " + _shq(sock) + " 2>/dev/null")

    if ok {
        println("[m_daemon_r1_test] ALL 4 STEPS PASS")
        return 0
    }
    println("[m_daemon_r1_test] FAIL")
    return 1
}
