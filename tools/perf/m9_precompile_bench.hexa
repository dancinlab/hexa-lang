// tools/perf/m9_precompile_bench.hexa — GO M9: precompile HIT perf measurement.
//
// Measures the wall-time benefit of the M2 release-time precompile pipeline.
// For a target .hexa script, compares:
//
//   COLD  — ~/.hexa-cache + release/precompile/ entry both absent, so
//           `hexa run <target>` forks the full clang build (cold cost).
//   HIT   — release/precompile/hexa_run.<key> pre-staged (the M2 builder
//           ran at "release time"), so cmd_run's _precompile_lookup HITs
//           and SKIPS the clang fork — exec only.
//
// Cache key (MUST match self/main.hexa::cmd_run and tool/build_precompile.hexa):
//     key = sha256(source).substring(0,16) + "_" + version_str()
//
// Protocol (N=5 default): each phase removes both the ~/.hexa-cache binary
// AND any release/precompile/ entry first (so COLD is genuinely cold and
// nothing leaks between samples), times one `hexa run <target> <args>`
// with mono_ns(), and records the wall delta. The HIT phase first builds
// the precompile entry once, then leaves it in place across all N samples
// (that is the production scenario — shipped binary, repeated first-calls).
//
// Metrics reported per phase: avg · p50 · min · max (ms) + COLD/HIT speedup.
//
// Usage:
//   hexa run tools/perf/m9_precompile_bench.hexa
//   hexa run tools/perf/m9_precompile_bench.hexa <target.hexa> [-- <args...>]
//   N=10 hexa run tools/perf/m9_precompile_bench.hexa
//
// Env:
//   HEXA_BIN   absolute path to the hexa CLI (else argv[0] / `command -v hexa`).
//   N          sample count per phase (default 5).
//   HEXA_LANG  repo root (used by cmd_run's precompile anchor #1 AND here to
//              stage release/precompile/). Auto-resolved from cwd if unset.
//
// NOTE: COLD removes the ~/.hexa-cache entry for the target only (keyed,
// surgical) — never the whole cache. HIT staging writes to
// $HEXA_LANG/release/precompile/ (gitignored) and is removed on exit.

fn _shq(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" { out = out + "'\\''" } else { out = out + c }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _die(msg: string) {
    eprintln("m9_bench: " + msg)
    exit(1)
}

fn _contains(hay: string, needle: string) -> bool {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return true }
    if m > n { return false }
    let mut i = 0
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return true }
        i = i + 1
    }
    return false
}

// MUST stay in lockstep with self/main.hexa::version_str().
fn _version_str() -> string {
    let ov = env("HEXA_PRECOMPILE_VERSION")
    if len(ov) > 0 { return ov }
    return "0.1.0-dispatch"
}

fn _hexa_bin() -> string {
    let e = env("HEXA_BIN")
    if len(e) > 0 { return e }
    let av = args()
    if len(av) > 0 {
        let real = to_string(exec("realpath " + _shq(av[0]) + " 2>/dev/null")).trim()
        if len(real) > 0 {
            let dn = to_string(exec("dirname " + _shq(real))).trim()
            let cand = dn + "/hexa"
            if file_exists(cand) { return cand }
        }
    }
    let p = to_string(exec("command -v hexa 2>/dev/null")).trim()
    return p
}

fn _resolve_repo() -> string {
    let h = env("HEXA_LANG")
    if len(h) > 0 && file_exists(h + "/self/main.hexa") { return h }
    if file_exists("./self/main.hexa") {
        return to_string(exec("pwd")).trim()
    }
    _die("cannot locate repo root (need self/main.hexa); set HEXA_LANG")
    return ""
}

fn _cache_dir() -> string {
    let home = env("HOME")
    if len(home) > 0 { return home + "/.hexa-cache" }
    return "./.hexa-cache"
}

// Run `hexa run <target> <args>` once, return wall-time in nanoseconds.
// Discards output (we only care about wall time). Asserts rc==0 unless
// trace_hit is set, in which case it also requires "[precompile] HIT" in
// stderr (proves the HIT path actually fired).
fn _timed_run(hexa_bin: string, repo: string, target: string, argstr: string, trace_hit: bool) -> int {
    // HEXA_LANG anchors the precompile probe; HEXA_PRECOMPILE_TRACE surfaces HIT.
    // Merge stderr into stdout (2>&1) so the "[precompile] HIT" trace is
    // captured in `out` directly — avoids a temp-file whose shell $$ differs
    // between the write exec and a later read exec.
    let env_prefix = "HEXA_LANG=" + _shq(repo) + " HEXA_PRECOMPILE_TRACE=1 "
    let cmd = env_prefix + _shq(hexa_bin) + " run " + _shq(target) + argstr + " 2>&1; echo \"__RC__=$?\""
    let t0 = mono_ns()
    let out = to_string(exec(cmd))
    let t1 = mono_ns()
    let dt = t1 - t0
    // rc parse
    let mark = "__RC__="
    let ml = len(mark)
    let ol = len(out)
    let mut mi = -1
    let mut sj = ol - ml
    while sj >= 0 {
        if out.substring(sj, sj + ml) == mark { mi = sj; sj = -1 } else { sj = sj - 1 }
    }
    let mut rc = -1
    if mi >= 0 {
        let mut rs = out.substring(mi + ml, ol)
        let rsl = len(rs)
        if rsl > 0 && rs.substring(rsl - 1, rsl) == "\n" { rs = rs.substring(0, rsl - 1) }
        rc = rs.parse_int()
    }
    if rc != 0 {
        eprintln("---- run output (rc=" + to_string(rc) + ") ----")
        eprintln(out)
        _die("target run failed (rc=" + to_string(rc) + ")")
    }
    if trace_hit {
        // body = captured stdout+stderr (minus the rc marker) — the trace
        // "[precompile] HIT" is emitted to stderr by cmd_run, merged here.
        let body = if mi >= 0 { out.substring(0, mi) } else { out }
        if !_contains(body, "[precompile] HIT") {
            eprintln("---- run output ----")
            eprintln(body)
            _die("HIT phase but no '[precompile] HIT' trace — precompile probe never fired")
        }
    }
    return dt
}

// Sort an int array ascending (small N — insertion sort).
fn _sort(a: [int]) -> [int] {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n { out.push(a[i]); i = i + 1 }
    let mut p = 1
    while p < n {
        let key = out[p]
        let mut q = p - 1
        while q >= 0 && out[q] > key {
            out[q + 1] = out[q]
            q = q - 1
        }
        out[q + 1] = key
        p = p + 1
    }
    return out
}

fn _ns_to_ms_str(ns: int) -> string {
    // integer ms with 1 decimal (ns/100000 -> tenths of ms)
    let tenths = ns / 100000
    let whole = tenths / 10
    let frac = tenths - whole * 10
    return to_string(whole) + "." + to_string(frac)
}

struct Stats {
    avg: int,
    p50: int,
    lo: int,
    hi: int,
}

fn _stats(samples: [int]) -> Stats {
    let s = _sort(samples)
    let n = len(s)
    let mut sum = 0
    let mut i = 0
    while i < n { sum = sum + s[i]; i = i + 1 }
    let avg = sum / n
    let p50 = s[n / 2]
    return Stats { avg: avg, p50: p50, lo: s[0], hi: s[n - 1] }
}

fn main() {
    let repo = _resolve_repo()
    let hexa_bin = _hexa_bin()
    if len(hexa_bin) == 0 { _die("cannot locate `hexa` binary") }

    // Parse args: first non-flag = target, everything after "--" = target args.
    let av = args()
    let mut target = "tool/atlas_cli.hexa"
    let mut targ_args = "--help"
    let mut have_target = false
    let mut after_dd = false
    let mut argstr = ""
    let mut ai = 1
    while ai < len(av) {
        let a = av[ai]
        if after_dd {
            argstr = argstr + " " + _shq(a)
        } else if a == "--" {
            after_dd = true
            argstr = ""   // explicit args override default
        } else if !have_target {
            target = a
            have_target = true
            targ_args = "(none unless -- given)"
            argstr = ""
        }
        ai = ai + 1
    }
    if !have_target {
        // default target keeps its default arg
        argstr = " " + _shq(targ_args)
    }

    let abs_target = if file_exists(target) { target } else { repo + "/" + target }
    if !file_exists(abs_target) { _die("target not found: " + target) }

    // Sample count.
    let mut n = 5
    let nenv = env("N")
    if len(nenv) > 0 {
        let pv = nenv.parse_int()
        if pv > 0 { n = pv }
    }

    let src_hash = sha256_file(abs_target)
    let key = src_hash.substring(0, 16) + "_" + _version_str()
    let cache_dir = _cache_dir()
    let cache_entry = cache_dir + "/hexa_run." + key
    let pre_dir = repo + "/release/precompile"
    let pre_entry = pre_dir + "/hexa_run." + key

    println("== GO M9 precompile perf bench ==")
    println("host_uname : " + to_string(exec("uname -sm")).trim())
    println("hexa_bin   : " + hexa_bin)
    println("repo       : " + repo)
    println("target     : " + target + " (" + to_string(exec("wc -l < " + _shq(abs_target))).trim() + " lines)")
    println("args       : " + (if len(argstr) > 0 { argstr } else { "(none)" }))
    println("cache_key  : " + key)
    println("samples N  : " + to_string(n))
    println("")

    // ---- COLD phase ----
    println("-- COLD phase (no cache, no precompile entry; full clang fork each) --")
    let _rm_pre0 = exec("rm -f " + _shq(pre_entry) + " 2>/dev/null")
    let mut cold = []
    let mut ci = 0
    while ci < n {
        // remove keyed cache entry + any inflight tmp so each sample is cold
        let _rm = exec("rm -f " + _shq(cache_entry) + " " + _shq(cache_entry) + ".tmp.* 2>/dev/null")
        let dt = _timed_run(hexa_bin, repo, target, argstr, false)
        cold.push(dt)
        println("  cold[" + to_string(ci) + "] = " + _ns_to_ms_str(dt) + " ms")
        ci = ci + 1
    }

    // ---- HIT phase ----
    println("")
    println("-- HIT phase (release/precompile/ staged; clang fork skipped) --")
    // Build the precompile entry ONCE (this is the release-time step).
    let _mk = exec("mkdir -p " + _shq(pre_dir) + " 2>/dev/null")
    let _rm_cache = exec("rm -f " + _shq(cache_entry) + " 2>/dev/null")  // ensure HIT, not warm-cache
    let build_cmd = _shq(hexa_bin) + " build " + _shq(abs_target) + " -o " + _shq(pre_entry) + " 2>&1; echo \"__RC__=$?\""
    println("  staging precompile entry (one-time release build)...")
    let bout = to_string(exec(build_cmd))
    if !file_exists(pre_entry) {
        eprintln(bout)
        _die("precompile staging build failed — cannot run HIT phase")
    }
    println("  staged: " + pre_entry)
    let mut hit = []
    let mut hi = 0
    while hi < n {
        // remove warm-cache so the ONLY fast path is the precompile HIT
        let _rm = exec("rm -f " + _shq(cache_entry) + " 2>/dev/null")
        let dt = _timed_run(hexa_bin, repo, target, argstr, true)
        hit.push(dt)
        println("  hit[" + to_string(hi) + "]  = " + _ns_to_ms_str(dt) + " ms")
        hi = hi + 1
    }

    // cleanup staged precompile entry (gitignored, but keep tree clean)
    let _cleanup = exec("rm -f " + _shq(pre_entry) + " 2>/dev/null")

    // ---- Report ----
    let cs = _stats(cold)
    let hs = _stats(hit)
    println("")
    println("== RESULTS (ms) ==")
    println("phase   avg      p50      min      max")
    println("COLD    " + _ns_to_ms_str(cs.avg) + "    " + _ns_to_ms_str(cs.p50) + "    " + _ns_to_ms_str(cs.lo) + "    " + _ns_to_ms_str(cs.hi))
    println("HIT     " + _ns_to_ms_str(hs.avg) + "    " + _ns_to_ms_str(hs.p50) + "    " + _ns_to_ms_str(hs.lo) + "    " + _ns_to_ms_str(hs.hi))
    println("")
    // speedup = cold_avg / hit_avg (integer x100 for 2-decimal)
    if hs.avg > 0 {
        let ratio_x100 = (cs.avg * 100) / hs.avg
        let whole = ratio_x100 / 100
        let frac = ratio_x100 - whole * 100
        let fracs = if frac < 10 { "0" + to_string(frac) } else { to_string(frac) }
        let saved_ns = cs.avg - hs.avg
        println("speedup (avg) : " + to_string(whole) + "." + fracs + "x  (COLD/HIT)")
        println("wall saved    : " + _ns_to_ms_str(saved_ns) + " ms/call (avg)")
    }
    println("")
    println("PASS: M9 precompile bench complete (N=" + to_string(n) + ")")
}
