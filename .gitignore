# CANON M3: the transpiler is a build artifact (build/hexa_v2), built
# per-machine from the arch-neutral C seed self/native/hexa_cc.c via
# `hexa cc` (Go 1.4 C-seed model). No transpiler binary lives in git —
# build/hexa_v2 is always arch-correct, closing the committed-binary
# arch-leak class. M1 retired the suffixed variants; M3b dropped the
# committed seeds (hexa_v2 / hexa_v2_linux_x86_64). All must stay out of git.
self/native/hexa_v2
self/native/hexa_v2_linux_x86_64
self/native/hexa_v2_baseline
self/native/hexa_v2_test
self/native/hexa_v2_nobt71
self/native/hexa_v2_pre71
self/native/hexa_v2_rfc011

# CANON M5/M8: repo-root deployed CLI driver — shim-preferred `hxv2` target
# written by `tool/build_hexa_cli --install` (fallback `hexa.real`). Per-host
# deploy artifact, not source — keep out of git.
/hxv2

# Compiled native shared libraries under self/native — built locally from
# the .c/.cu sources in the same directory. Do not ship binaries.
self/native/*.dylib
self/native/*.so

# BT-HEXA-28 Meta² fixpoint certificate chain — local-only (git history is
