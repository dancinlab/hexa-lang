/target/
hexa_test
hexa.prev*
playground/pkg/
hexa_old
.growth/
.DS_Store
build/
# baseline native interpreter source — must survive gitignore (SH-P3-1 소실 방지)
!build/artifacts/hexa_native_baseline.c
# bash wrapper shim — must survive gitignore so `git checkout` materializes
# the tracked blob (PR #421 added this via `git add -f`).  Recurrence guard
# vs (a) stale pre-#421 copies on older branches, (b) `git clean -fdx` wipe.
# Cycle-8 PR #444 side-finding (anima 2026-05-23) traced root cause here.
!hexa
ready

.claude/*
!.claude/skills/
!.claude/settings.json
!.claude/hooks/
!.claude/commands/

# Python bytecode noise
__pycache__/
*.pyc

# AOT build cache (hexa run)
.hexa-cache/

# GO M2/M3 — release precompile output dir (binaries staged at release time
# by tool/build_precompile.hexa from tool/precompile.json; tarball-shipped,
# not source-controlled — same provenance as build/).
release/precompile/

# Scratch space
tmp/

# hx install destinations for third-party packages (e.g. lib/yoga via `hx install yoga`)
# Use a sibling-level negate so first-party dirs (e.g. lib/hxnccl) stay tracked.
lib/*/
!lib/hxnccl/
!lib/hxpyembed/
# Build artefacts inside first-party libs are still ignored.
lib/hxnccl/build/
lib/hxpyembed/build/

# Rust baseline benchmark build artifacts (cargo target/)
bench/rust_baseline/target/

# Large data files (exceeds GitHub 100MB limit)
shared/discovery_log.jsonl

# Removed legacy Rust build (commits 08caf07 / 94ffd0f)
src/
Cargo.toml
Cargo.lock
.cargo/

