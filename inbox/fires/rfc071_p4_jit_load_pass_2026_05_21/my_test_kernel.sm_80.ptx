// RFC 055 055-P0 - hexa-native NVPTX emit | target=nvptx64-nvidia-cuda-sm80
.version 7.0
.target sm_80
.address_size 64

.visible .entry my_test_kernel (
    .param .u64 my_test_kernel_param_0,
    .param .u64 my_test_kernel_param_1,
    .param .u64 my_test_kernel_param_2,
    .param .u64 my_test_kernel_param_3
)
{
    .reg .u64 %rd0;
    .reg .u64 %rd1;
    .reg .u64 %rd2;
    .reg .u64 %rd3;
    .reg .u32 %r4;
    .reg .u32 %r5;
    .reg .u32 %r6;
    .reg .u32 %r7;
    .reg .u32 %r8;
    .reg .u32 %r9;
    .reg .u64 %rd10;
    .reg .pred %p11;
    .reg .u64 %rd13;
    .reg .u64 %rd14;
    .reg .u64 %rd15;
    .reg .u64 %rd16;
    .reg .u64 %rd17;
    .reg .u64 %rd18;
$L_0:
    mov.u32 %r4, %ctaid.x;  // gpu_block_id_x()
    mov.u32 %r5, %ntid.x;  // gpu_block_dim_x()
    mul.lo.s32 %r6, %r4, %r5;  // binop *
    mov.u32 %r7, %tid.x;  // gpu_thread_id_x()
    add.s32 %r8, %r6, %r7;  // binop +
    mov.u32 %r9, %r8;  // assign
    cvt.s64.s32 %rd10, %r9;  // to_i64 (s32 to s64)
    setp.lt.s64 %p11, %rd10, %rd3;  // cmp <
    @%p11 bra $L_1;  // br_cond true -> $L_1
    bra $L_2;  // br_cond false -> $L_2
$L_1:
    cvt.s64.s32 %rd13, %r9;  // to_i64 (s32 to s64)
    cvt.s64.s32 %rd14, %r9;  // to_i64 (s32 to s64)
    mov.u64 %rd15, %rd0;  // assign
    cvt.s64.s32 %rd16, %r9;  // to_i64 (s32 to s64)
    mov.u64 %rd17, %rd1;  // assign
    add.s64 %rd18, %rd15, %rd17;  // binop +
    bra $L_2;  // br -> $L_2
$L_2:
    ret;  // return
}
