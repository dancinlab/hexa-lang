// RFC 067 P4 -- single-tile wmma f16xf16=f32 16x16 silicon fire.
//
// Computes one 16x16 GEMM tile via Tensor Core wmma:
//   C[16x16] = A[16x16] * B[16x16]   (A row-major f16, B col-major f16, C f32)
//
// Uses the wmma mnemonics RFC 067's codegen (PR #177) emits:
//   wmma.load.a.sync.aligned.row.m16n16k16.f16
//   wmma.load.b.sync.aligned.col.m16n16k16.f16
//   wmma.mma.sync.aligned.row.col.m16n16k16.f32.f16.f16.f32
//   wmma.store.d.sync.aligned.row.m16n16k16.f32
//
// Single warp (32 threads); each fragment is 8 .b32 regs per thread for
// A/B (.f16 packed 2:1) and 8 .f32 regs per thread for C/D (accumulator).
//
// Launched 1 block (32 threads) -- entire 16x16 tile computed by one warp.

.version 7.8
.target sm_80
.address_size 64

.visible .entry wmma_16x16 (
    .param .u64 a,
    .param .u64 b,
    .param .u64 c
)
{
    .reg .u64 %rd<5>;
    .reg .b32 %ra<8>;
    .reg .b32 %rb<8>;
    .reg .f32 %fc<8>;

    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [c];

    // Load A fragment: row-major, stride 16 (default), f16 elements.
    wmma.load.a.sync.aligned.row.m16n16k16.global.f16
        {%ra0, %ra1, %ra2, %ra3, %ra4, %ra5, %ra6, %ra7}, [%rd0];

    // Load B fragment: col-major, stride 16, f16 elements.
    wmma.load.b.sync.aligned.col.m16n16k16.global.f16
        {%rb0, %rb1, %rb2, %rb3, %rb4, %rb5, %rb6, %rb7}, [%rd1];

    // Zero-init C accumulator fragment.
    mov.f32 %fc0, 0f00000000;
    mov.f32 %fc1, 0f00000000;
    mov.f32 %fc2, 0f00000000;
    mov.f32 %fc3, 0f00000000;
    mov.f32 %fc4, 0f00000000;
    mov.f32 %fc5, 0f00000000;
    mov.f32 %fc6, 0f00000000;
    mov.f32 %fc7, 0f00000000;

    // D = A * B + C  (here C = 0 so D = A*B).
    wmma.mma.sync.aligned.row.col.m16n16k16.f32.f32
        {%fc0, %fc1, %fc2, %fc3, %fc4, %fc5, %fc6, %fc7},
        {%ra0, %ra1, %ra2, %ra3, %ra4, %ra5, %ra6, %ra7},
        {%rb0, %rb1, %rb2, %rb3, %rb4, %rb5, %rb6, %rb7},
        {%fc0, %fc1, %fc2, %fc3, %fc4, %fc5, %fc6, %fc7};

    // Store D fragment: row-major, stride 16, f32 elements.
    wmma.store.d.sync.aligned.row.m16n16k16.global.f32
        [%rd2], {%fc0, %fc1, %fc2, %fc3, %fc4, %fc5, %fc6, %fc7};

    ret;
}
