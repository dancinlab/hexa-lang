.version 8.0
.target sm_90
.address_size 64
.shared .align 8 .b64 bar;
.visible .entry mbarrier_test()
{
    .reg .b64 %rdb, %rds;
    .reg .b32 %r<3>;
    mov.b64 %rdb, bar;
    cvta.shared.u64 %rds, %rdb;
    cvta.to.shared.u64 %rds, %rds;
    mov.u32 %r0, 1;
    mbarrier.init.shared::cta.b64 [%rds], %r0;
    ret;
}
