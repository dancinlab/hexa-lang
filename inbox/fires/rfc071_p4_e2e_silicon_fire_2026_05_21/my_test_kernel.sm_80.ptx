// RFC 055 055-P0 - hexa-native NVPTX emit | target=nvptx64-nvidia-cuda-sm80
.version 7.0
.target sm_80
.address_size 64

.visible .entry my_test_kernel (
    .param .u64 my_test_kernel_param_0,
    .param .u64 my_test_kernel_param_1,
    .param .u64 my_test_kernel_param_2,
    .param .u64 my_test_kernel_param_3
)
{
    .reg .u32 %r4;
    .reg .u32 %r5;
    .reg .f64 %fd6;
    .reg .u32 %r7;
    .reg .f64 %fd8;
    .reg .f64 %fd9;
    .reg .u64 %rd10;
    .reg .f64 %fd11;
    .reg .u64 %rd13;
    .reg .u64 %rd14;
    .reg .f64 %fd15;
    .reg .u64 %rd16;
    .reg .f64 %fd17;
    .reg .f64 %fd18;
$L_0:
    mov.u32 %r4, %ctaid.x;  // gpu_block_id_x()
    mov.u32 %r5, %ntid.x;  // gpu_block_dim_x()
    mul.f64 %fd6, %r4, %r5;  // binop *
    mov.u32 %r7, %tid.x;  // gpu_thread_id_x()
    add.f64 %fd8, %fd6, %r7;  // binop +
    mov.f64 %fd9, %fd8;  // assign
    cvt.s64.s32 %rd10, %fd9;  // to_i64 (s32 to s64)
    // RFC 055 055-P0 - unsupported binop: <
    @%fd11 bra $L_1;  // br_cond true -> $L_1
    bra $L_2;  // br_cond false -> $L_2
$L_1:
    cvt.s64.s32 %rd13, %fd9;  // to_i64 (s32 to s64)
    cvt.s64.s32 %rd14, %fd9;  // to_i64 (s32 to s64)
    mov.f64 %fd15, %fd0;  // assign
    cvt.s64.s32 %rd16, %fd9;  // to_i64 (s32 to s64)
    mov.f64 %fd17, %fd1;  // assign
    add.f64 %fd18, %fd15, %fd17;  // binop +
    mov.f64 %fd-1, %fd2;  // assign
    bra $L_2;  // br -> $L_2
$L_2:
    ret;  // return
}
