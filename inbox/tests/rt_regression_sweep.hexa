ck(416, "rt_one_hot", t_one_hot(2, 4).join(",") == "0.0,0.0,1.0,0.0")

// ---- FAMILY 5: HexaVal-backed builtins — array callbacks (codes 500-599) ----
// these route through rt_array_map / rt_array_filter / rt_array_fold etc.
let src = [1, 2, 3, 4, 5]
ck(501, "rt_array_map (.map)", src.map(|x| x * 2).join(",") == "2,4,6,8,10")
