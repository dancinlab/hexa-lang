ck(407, "rt_array_unique_float", t_array_unique_float(arr1).join(",") == "3.0,1.0,4.0,5.0")
ck(408, "rt_array_reverse_float", t_array_reverse_float([1.0, 2.0, 3.0]).join(",") == "3.0,2.0,1.0")
