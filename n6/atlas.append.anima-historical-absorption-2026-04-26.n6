# ── @F  Formulas  (CPGD, L_cell, L_IX, AN11) ──────────────────
@F P_S_projector = "V^T · V" :: anima.cpgd.algebra [11*]
  <- template_count
  => "orthogonal projector onto template subspace S; V rows = 16 eigenvecs"
  => "idempotent (P_S · P_S = P_S), symmetric (P_S^T = P_S)"
