  => "update: W_{k+1} = W_k − lr · (grad · P_S) ⇒ W_k ∈ S ∀k"
  |> edu/lora/cpgd_wrapper.hexa L281-L325 build_projector + verify_idempotent

@F W_init_closed_form = "W_0 = V (each row v_i)" :: anima.cpgd.init [11*]
