// HEXA Standard Library — crystal (science stack)
//
// hexa-native absorption of pymatgen (LBNL, MIT) + the Materials Project
// REST client (mp_api). Crystal-structure container, space-group ops,
// phase-diagram primitives, and a stdlib-`net` MP query path.
//
// Status: STAGE-1 — Lattice + Structure containers + constructors +
// pure-stdlib accessors (volume / abc / num_sites) landed. Stage-2
// primitives (from_cif / SpacegroupAnalyzer / PhaseDiagram / MP-net
// query) still pending.
//
// ── Migration plan ──────────────────────────────────────────────────
//   Stage 1 (DONE here): Lattice/Structure structs + lattice_new +
//     structure_new + lattice_volume + lattice_abc + structure_num_sites
//     + structure_species + structure_volume — enough surface for
//     hexa-matter `pymatgen_structure_io.py` /
//     `pymatgen_phasediagram_smoke.py` callers to be migrated onto
//     this package (callers pass explicit lattice matrices + species +
//     fractional coords; no pymatgen shell-out).
//   Stage 2 (dependency hexa-native port): pymatgen primitives —
//     Structure ops, SpacegroupAnalyzer, PhaseDiagram, CIF reader,
//     the Materials Project net query — get hexa-native kernels here.
//
// ── Public API ──────────────────────────────────────────────────────
//   pub struct Lattice      — matrix : [[float;3];3]
//   pub struct Structure    — lattice : Lattice, species : [str],
//                             frac_coords : [[float;3]]
//   pub fn lattice_new(matrix) -> Lattice
//   pub fn lattice_volume(L) -> float                 (|det| matrix)
//   pub fn lattice_abc(L) -> [float;3]                (row-vector norms)
//   pub fn structure_new(lattice, species, frac) -> Structure
//   pub fn structure_num_sites(s) -> int
//   pub fn structure_species(s) -> [str]
//   pub fn structure_volume(s) -> float
//   pub fn structure_from_spacegroup(sg, L, species, coords) (Stage 2)
//   pub fn structure_from_cif(path) -> Structure        (Stage 2)
//   pub fn mp_summary_query(api_key, formula) -> ...     (Stage 2; net)
//   pub fn energy_above_hull(structure, refs) -> float   (Stage 2)
//
// ── Dependencies (hexa stdlib) ──────────────────────────────────────
//   (Stage 1 dependency-free — arrays + closed-form 3x3 det + sqrt.
//    tensor/ linalg/ net/ atoms/ enter at Stage 2.)
//
// Absorbs: pymatgen, mp_api   Used by: hexa-matter   Sibling: atoms, mlff
// Honesty: MP data is DFT-COMPUTED (CC-BY 4.0), never a measurement.
// Cross-link: .roadmap.stdlib (science-stack subdomains)

pub struct Lattice {
    matrix: any      // [[float;3];3] — row lattice vectors (Å)
}

pub struct Structure {
    lattice: any,    // Lattice
    species: any,    // [str]          — per-site element, length N
    frac_coords: any // [[float;3]; N] — fractional coordinates
}

pub fn lattice_new(matrix: any) -> Lattice {
    return Lattice { matrix: matrix }
}

// pymatgen Lattice.volume — |det(matrix)| for the row-vector 3x3.
pub fn lattice_volume(L: Lattice) -> float {
    let m = L.matrix
    let r0 = m[0]
    let r1 = m[1]
    let r2 = m[2]
    let a00 = r0[0]
    let a01 = r0[1]
    let a02 = r0[2]
    let a10 = r1[0]
    let a11 = r1[1]
    let a12 = r1[2]
    let a20 = r2[0]
    let a21 = r2[1]
    let a22 = r2[2]
    let t0 = a00 * (a11 * a22 - a12 * a21)
    let t1 = a01 * (a10 * a22 - a12 * a20)
    let t2 = a02 * (a10 * a21 - a11 * a20)
    let det = t0 - t1 + t2
    if det < 0.0 { return -det }
    return det
}

// pymatgen Lattice.abc — the three row-vector lengths (Å).
pub fn lattice_abc(L: Lattice) -> any {
    let m = L.matrix
    let r0 = m[0]
    let r1 = m[1]
    let r2 = m[2]
    let n0 = sqrt(r0[0] * r0[0] + r0[1] * r0[1] + r0[2] * r0[2])
    let n1 = sqrt(r1[0] * r1[0] + r1[1] * r1[1] + r1[2] * r1[2])
    let n2 = sqrt(r2[0] * r2[0] + r2[1] * r2[1] + r2[2] * r2[2])
    return [n0, n1, n2]
}

pub fn structure_new(lattice: Lattice, species: any, frac: any) -> Structure {
    return Structure { lattice: lattice, species: species, frac_coords: frac }
}

pub fn structure_num_sites(s: Structure) -> int {
    return len(s.species)
}

pub fn structure_species(s: Structure) -> any {
    return s.species
}

pub fn structure_volume(s: Structure) -> float {
    return lattice_volume(s.lattice)
}

// ── Stage-2 kernel: fractional <-> cartesian + angles ───────────────
// pymatgen Lattice convention: matrix rows are the a,b,c lattice
// vectors; cart = frac @ matrix, frac = cart @ inv(matrix).

// Closed-form 3x3 inverse (adjugate / det). Row-major.
pub fn lattice_inverse(L: Lattice) -> any {
    let m = L.matrix
    let r0 = m[0]
    let r1 = m[1]
    let r2 = m[2]
    let m00 = r0[0]
    let m01 = r0[1]
    let m02 = r0[2]
    let m10 = r1[0]
    let m11 = r1[1]
    let m12 = r1[2]
    let m20 = r2[0]
    let m21 = r2[1]
    let m22 = r2[2]
    let c00 = m11 * m22 - m12 * m21
    let c01 = m10 * m22 - m12 * m20
    let c02 = m10 * m21 - m11 * m20
    let det = m00 * c00 - m01 * c01 + m02 * c02
    let i00 = c00 / det
    let i01 = (m02 * m21 - m01 * m22) / det
    let i02 = (m01 * m12 - m02 * m11) / det
    let i10 = (m12 * m20 - m10 * m22) / det
    let i11 = (m00 * m22 - m02 * m20) / det
    let i12 = (m02 * m10 - m00 * m12) / det
    let i20 = (m10 * m21 - m11 * m20) / det
    let i21 = (m01 * m20 - m00 * m21) / det
    let i22 = (m00 * m11 - m01 * m10) / det
    return [[i00, i01, i02], [i10, i11, i12], [i20, i21, i22]]
}

// frac (Nx3) -> cartesian (Nx3): cart_i = sum_k frac_k * matrix_row_k.
pub fn lattice_frac_to_cart(L: Lattice, frac: any) -> any {
    let m = L.matrix
    let r0 = m[0]
    let r1 = m[1]
    let r2 = m[2]
    let mut out: any = []
    let mut i = 0
    while i < len(frac) {
        let f = frac[i]
        let f0 = f[0]
        let f1 = f[1]
        let f2 = f[2]
        let cx = f0 * r0[0] + f1 * r1[0] + f2 * r2[0]
        let cy = f0 * r0[1] + f1 * r1[1] + f2 * r2[1]
        let cz = f0 * r0[2] + f1 * r1[2] + f2 * r2[2]
        out.push([cx, cy, cz])
        i = i + 1
    }
    return out
}

// cartesian (Nx3) -> frac (Nx3): frac = cart @ inv(matrix).
pub fn lattice_cart_to_frac(L: Lattice, cart: any) -> any {
    let inv = lattice_inverse(L)
    let v0 = inv[0]
    let v1 = inv[1]
    let v2 = inv[2]
    let mut out: any = []
    let mut i = 0
    while i < len(cart) {
        let c = cart[i]
        let c0 = c[0]
        let c1 = c[1]
        let c2 = c[2]
        let fx = c0 * v0[0] + c1 * v1[0] + c2 * v2[0]
        let fy = c0 * v0[1] + c1 * v1[1] + c2 * v2[1]
        let fz = c0 * v0[2] + c1 * v1[2] + c2 * v2[2]
        out.push([fx, fy, fz])
        i = i + 1
    }
    return out
}

// pymatgen Lattice.angles — (alpha, beta, gamma) in degrees.
// alpha = angle(b,c), beta = angle(a,c), gamma = angle(a,b).
pub fn lattice_angles(L: Lattice) -> any {
    let m = L.matrix
    let a = m[0]
    let b = m[1]
    let c = m[2]
    let na = sqrt(a[0] * a[0] + a[1] * a[1] + a[2] * a[2])
    let nb = sqrt(b[0] * b[0] + b[1] * b[1] + b[2] * b[2])
    let nc = sqrt(c[0] * c[0] + c[1] * c[1] + c[2] * c[2])
    let bc = b[0] * c[0] + b[1] * c[1] + b[2] * c[2]
    let ac = a[0] * c[0] + a[1] * c[1] + a[2] * c[2]
    let ab = a[0] * b[0] + a[1] * b[1] + a[2] * b[2]
    let pi = acos(-1.0)
    let alpha = acos(bc / (nb * nc)) * 180.0 / pi
    let beta = acos(ac / (na * nc)) * 180.0 / pi
    let gamma = acos(ab / (na * nb)) * 180.0 / pi
    return [alpha, beta, gamma]
}

// Convenience: a Structure's cartesian site coordinates.
pub fn structure_cart_coords(s: Structure) -> any {
    return lattice_frac_to_cart(s.lattice, s.frac_coords)
}

// ── Stage-2 kernel: 2-endpoint convex-hull distance ─────────────────
// pymatgen PhaseDiagram.get_e_above_hull, restricted to a binary
// (2-endpoint) tie-line — the bounded case hexa-matter's NOVEL
// candidate screen uses. `refs` = [[x0, e0], [x1, e1]] two reference
// points (composition fraction x in [0,1], formation energy e per
// atom); query = [x, e]. Returns e − e_hull(x) where e_hull is the
// linear interpolation between the two endpoints (0 on the tie-line,
// >0 above, <0 below — caller clamps if a strict hull is wanted).
// Full multi-point lower-convex-hull is Stage-2.5 (needs a hull
// sweep + facet search; this binary form is exact and self-checked).
pub fn energy_above_hull(query: any, refs: any) -> float {
    let r0 = refs[0]
    let r1 = refs[1]
    let x0 = r0[0]
    let e0 = r0[1]
    let x1 = r1[0]
    let e1 = r1[1]
    let qx = query[0]
    let qe = query[1]
    let frac = (qx - x0) / (x1 - x0)
    let e_hull = e0 + frac * (e1 - e0)
    return qe - e_hull
}

pub fn crystal_status() -> str {
    return "STAGE-2 (partial) — Stage-1 + lattice_inverse/frac_to_cart/cart_to_frac/angles + structure_cart_coords + energy_above_hull(binary) (absorbs: pymatgen, mp_api; CIF/Spacegroup/multi-point-hull/MP-net still Stage-2)"
}
