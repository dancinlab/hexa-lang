// stdlib/regex.hexa — restricted regular-expression engine.
//
// Pure (no syscall); allocates AST maps + position-set arrays.
//
// Supported syntax:
//   literal chars · `.` (any) · `[...]` char class (ranges, `^` negation)
//   `\d \w \s \D \W \S` · `\b` word boundary · `\n \t \r` · escaped metachars
//   `*` `+` `?` quantifiers (greedy) · `|` alternation · `(...)` grouping
//   `^` `$` anchors (line-aware: also match around `\n`)
//
// Engine: the pattern is parsed to an AST, then matched by a position-set
// simulation — `_re_set(node, text, pos)` returns every index the input
// could advance to. This is NFA-style: no backtracking, no catastrophic
// blowup; every (node, pos) explores a position set bounded by the text
// length, so it always terminates.
//
// Public API:
//   regex_test(pattern, text)  -> bool        — pattern matches a substring
//   regex_find(pattern, text)  -> array       — [start, end] of leftmost
//                                               (then longest) match, or []
//   regex_match(pattern, text) -> bool        — pattern matches the WHOLE text
//
// Strings are UTF-8 byte arrays; classes / boundaries operate per-byte,
// which is exact for ASCII patterns + text.

// ── char-class predicates ──────────────────────────────────────────────

fn _re_is_word(k: int) -> bool {
    if k >= 48 && k <= 57 { return true }
    if k >= 65 && k <= 90 { return true }
    if k >= 97 && k <= 122 { return true }
    if k == 95 { return true }
    return false
}

// ── AST node constructors (nodes are maps keyed by "k") ────────────────

fn _re_n(k: string) -> map {
    let m = json_parse("{}")
    m["k"] = k
    return m
}

fn _re_lit(c: string) -> map {
    let m = _re_n("lit")
    m["c"] = c
    return m
}

fn _re_class(ranges: array, neg: bool) -> map {
    let m = _re_n("class")
    m["ranges"] = ranges
    m["neg"] = neg
    return m
}

fn _re_star(inner: map) -> map {
    let m = _re_n("star")
    m["inner"] = inner
    return m
}

fn _re_quest(inner: map) -> map {
    let m = _re_n("quest")
    m["inner"] = inner
    return m
}

fn _re_concat(items: array) -> map {
    let m = _re_n("concat")
    m["items"] = items
    return m
}

fn _re_alt(branches: array) -> map {
    let m = _re_n("alt")
    m["branches"] = branches
    return m
}

fn _re_pr(node: map, nxt: int) -> map {
    let m = json_parse("{}")
    m["node"] = node
    m["next"] = nxt
    return m
}

// class node for an escape letter — d/w/s and negated D/W/S
fn _re_class_for_esc(letter: string) -> map {
    let mut ranges = []
    let mut neg = false
    let lo = letter.to_lower()
    if lo == "d" {
        ranges.push([48, 57])
    } else if lo == "w" {
        ranges.push([48, 57])
        ranges.push([65, 90])
        ranges.push([97, 122])
        ranges.push([95, 95])
    } else if lo == "s" {
        ranges.push([9, 13])
        ranges.push([32, 32])
    }
    if letter == "D" || letter == "W" || letter == "S" { neg = true }
    return _re_class(ranges, neg)
}

// ── parser (recursive descent) ─────────────────────────────────────────
// Each _re_parse_* returns a map { node, next }.

fn _re_parse_class(pat: string, start: int) -> map {
    // `start` points just past the opening `[`.
    let n = len(pat)
    let mut i = start
    let mut neg = false
    if i < n && pat[i] == "^" {
        neg = true
        i = i + 1
    }
    let mut ranges = []
    let mut guard = 0
    while i < n && pat[i] != "]" && guard < 100000 {
        if pat[i] == "\\" && i + 1 < n {
            let e = pat[i + 1]
            let el = e.to_lower()
            if el == "d" || el == "w" || el == "s" {
                let sub = _re_class_for_esc(e)
                let sr = sub["ranges"]
                let mut si = 0
                while si < len(sr) {
                    ranges.push(sr[si])
                    si = si + 1
                }
            } else {
                let k = char_code(e, 0)
                ranges.push([k, k])
            }
            i = i + 2
        } else if i + 2 < n && pat[i + 1] == "-" && pat[i + 2] != "]" {
            let lo = char_code(pat[i], 0)
            let hi = char_code(pat[i + 2], 0)
            ranges.push([lo, hi])
            i = i + 3
        } else {
            let k = char_code(pat[i], 0)
            ranges.push([k, k])
            i = i + 1
        }
        guard = guard + 1
    }
    if i < n && pat[i] == "]" { i = i + 1 }
    return _re_pr(_re_class(ranges, neg), i)
}

fn _re_parse_atom(pat: string, i: int) -> map {
    let n = len(pat)
    if i >= n { return _re_pr(_re_concat([]), i) }
    let c = pat[i]
    if c == "(" {
        let inner = _re_parse_alt(pat, i + 1)
        let mut nx = inner["next"]
        if nx < n && pat[nx] == ")" { nx = nx + 1 }
        return _re_pr(inner["node"], nx)
    }
    if c == "[" {
        return _re_parse_class(pat, i + 1)
    }
    if c == "." {
        return _re_pr(_re_n("any"), i + 1)
    }
    if c == "^" {
        return _re_pr(_re_n("bol"), i + 1)
    }
    if c == "$" {
        return _re_pr(_re_n("eol"), i + 1)
    }
    if c == "\\" && i + 1 < n {
        let e = pat[i + 1]
        let el = e.to_lower()
        if el == "d" || el == "w" || el == "s" {
            return _re_pr(_re_class_for_esc(e), i + 2)
        }
        if e == "b" {
            return _re_pr(_re_n("wb"), i + 2)
        }
        if e == "n" { return _re_pr(_re_lit("\n"), i + 2) }
        if e == "t" { return _re_pr(_re_lit("\t"), i + 2) }
        if e == "r" { return _re_pr(_re_lit("\r"), i + 2) }
        return _re_pr(_re_lit(e), i + 2)
    }
    return _re_pr(_re_lit(c), i + 1)
}

fn _re_parse_repeat(pat: string, i: int) -> map {
    let atom = _re_parse_atom(pat, i)
    let mut node = atom["node"]
    let mut nx = atom["next"]
    let n = len(pat)
    if nx < n {
        let q = pat[nx]
        if q == "*" {
            node = _re_star(node)
            nx = nx + 1
        } else if q == "+" {
            node = _re_concat([node, _re_star(node)])
            nx = nx + 1
        } else if q == "?" {
            node = _re_quest(node)
            nx = nx + 1
        }
    }
    return _re_pr(node, nx)
}

fn _re_parse_concat(pat: string, i: int) -> map {
    let n = len(pat)
    let mut items = []
    let mut idx = i
    let mut guard = 0
    while idx < n && pat[idx] != "|" && pat[idx] != ")" && guard < 100000 {
        let r = _re_parse_repeat(pat, idx)
        items.push(r["node"])
        let nx = r["next"]
        if nx == idx { idx = idx + 1 }
        else { idx = nx }
        guard = guard + 1
    }
    return _re_pr(_re_concat(items), idx)
}

fn _re_parse_alt(pat: string, i: int) -> map {
    let n = len(pat)
    let first = _re_parse_concat(pat, i)
    let mut branches = [first["node"]]
    let mut idx = first["next"]
    let mut guard = 0
    while idx < n && pat[idx] == "|" && guard < 100000 {
        let r = _re_parse_concat(pat, idx + 1)
        branches.push(r["node"])
        idx = r["next"]
        guard = guard + 1
    }
    if len(branches) == 1 {
        return _re_pr(branches[0], idx)
    }
    return _re_pr(_re_alt(branches), idx)
}

// ── matcher (position-set simulation) ──────────────────────────────────

fn _re_uniq(arr: array) -> array {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        let v = arr[i]
        let mut seen = false
        let mut j = 0
        while j < len(out) {
            if out[j] == v { seen = true }
            j = j + 1
        }
        if !seen { out.push(v) }
        i = i + 1
    }
    return out
}

fn _re_class_hit(node: map, k: int) -> bool {
    let ranges = node["ranges"]
    let mut inside = false
    let mut i = 0
    while i < len(ranges) {
        let r = ranges[i]
        if k >= r[0] && k <= r[1] { inside = true }
        i = i + 1
    }
    if node["neg"] { return !inside }
    return inside
}

// Returns every end index reachable by matching `node` at `pos`.
fn _re_set(node: map, text: string, pos: int) -> array {
    let n = len(text)
    let k = node["k"]

    if k == "lit" {
        if pos < n && text[pos] == node["c"] { return [pos + 1] }
        return []
    }
    if k == "any" {
        if pos < n { return [pos + 1] }
        return []
    }
    if k == "class" {
        if pos < n && _re_class_hit(node, char_code(text[pos], 0)) {
            return [pos + 1]
        }
        return []
    }
    if k == "bol" {
        if pos == 0 { return [pos] }
        if text[pos - 1] == "\n" { return [pos] }
        return []
    }
    if k == "eol" {
        if pos == n { return [pos] }
        if text[pos] == "\n" { return [pos] }
        return []
    }
    if k == "wb" {
        let mut before = false
        if pos > 0 && _re_is_word(char_code(text[pos - 1], 0)) { before = true }
        let mut after = false
        if pos < n && _re_is_word(char_code(text[pos], 0)) { after = true }
        if before != after { return [pos] }
        return []
    }
    if k == "concat" {
        let items = node["items"]
        let mut cur = [pos]
        let mut ii = 0
        while ii < len(items) {
            let mut nxt = []
            let mut ci = 0
            while ci < len(cur) {
                let adv = _re_set(items[ii], text, cur[ci])
                let mut ai = 0
                while ai < len(adv) {
                    nxt.push(adv[ai])
                    ai = ai + 1
                }
                ci = ci + 1
            }
            cur = _re_uniq(nxt)
            if len(cur) == 0 { return [] }
            ii = ii + 1
        }
        return cur
    }
    if k == "alt" {
        let branches = node["branches"]
        let mut out = []
        let mut bi = 0
        while bi < len(branches) {
            let adv = _re_set(branches[bi], text, pos)
            let mut ai = 0
            while ai < len(adv) {
                out.push(adv[ai])
                ai = ai + 1
            }
            bi = bi + 1
        }
        return _re_uniq(out)
    }
    if k == "quest" {
        let out = [pos]
        let adv = _re_set(node["inner"], text, pos)
        let mut ai = 0
        let mut acc = out
        while ai < len(adv) {
            acc.push(adv[ai])
            ai = ai + 1
        }
        return _re_uniq(acc)
    }
    if k == "star" {
        let inner = node["inner"]
        let mut seen = [pos]
        let mut frontier = [pos]
        let mut guard = 0
        while len(frontier) > 0 && guard < 100000 {
            let mut nf = []
            let mut fi = 0
            while fi < len(frontier) {
                let adv = _re_set(inner, text, frontier[fi])
                let mut ai = 0
                while ai < len(adv) {
                    let q = adv[ai]
                    let mut known = false
                    let mut si = 0
                    while si < len(seen) {
                        if seen[si] == q { known = true }
                        si = si + 1
                    }
                    if !known {
                        seen.push(q)
                        nf.push(q)
                    }
                    ai = ai + 1
                }
                fi = fi + 1
            }
            frontier = nf
            guard = guard + 1
        }
        return seen
    }
    return []
}

// ── public API ─────────────────────────────────────────────────────────

fn regex_test(pattern: string, text: string) -> bool {
    let ast = _re_parse_alt(pattern, 0)
    let node = ast["node"]
    let n = len(text)
    let mut start = 0
    while start <= n {
        let ends = _re_set(node, text, start)
        if len(ends) > 0 { return true }
        start = start + 1
    }
    return false
}

fn regex_find(pattern: string, text: string) -> array {
    let ast = _re_parse_alt(pattern, 0)
    let node = ast["node"]
    let n = len(text)
    let mut start = 0
    while start <= n {
        let ends = _re_set(node, text, start)
        if len(ends) > 0 {
            let mut best = ends[0]
            let mut i = 1
            while i < len(ends) {
                if ends[i] > best { best = ends[i] }
                i = i + 1
            }
            return [start, best]
        }
        start = start + 1
    }
    return []
}

fn regex_match(pattern: string, text: string) -> bool {
    let ast = _re_parse_alt(pattern, 0)
    let ends = _re_set(ast["node"], text, 0)
    let n = len(text)
    let mut i = 0
    while i < len(ends) {
        if ends[i] == n { return true }
        i = i + 1
    }
    return false
}
