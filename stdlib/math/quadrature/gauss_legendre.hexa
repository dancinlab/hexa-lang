#!hexa strict
// ============================================================================
// stdlib/math/quadrature/gauss_legendre.hexa — 6-point Gauss-Legendre quadrature
//
// Pure-math numerical-integration primitive. The 6-point Gauss-Legendre rule
// integrates ∫_a^b f(x) dx by sampling f at the 6 roots of the degree-6
// Legendre polynomial P₆ (affine-mapped from the canonical [−1, 1] interval)
// and accumulating the corresponding Gauss weights.
//
// Order property (the reason this primitive exists):
//   An n-point Gauss-Legendre rule is EXACT for all polynomials of degree
//   ≤ 2n − 1.  For n = 6 that is degree ≤ 11.  So ∫_0^1 x^11 dx = 1/12 comes
//   out to floating-point exactness, while x^12 begins to incur a (small)
//   quadrature error.  No domain (Eliashberg / orbital / ...) is baked in;
//   downstream callers `use` this module and supply their own integrand.
//
// Eliashberg motivation (NOVEL-TOOL R1-d):
//   The Eliashberg spectral moments —
//       λ      = 2 ∫ α²F(ω)/ω dω
//       ω_log  = exp[ (2/λ) ∫ α²F(ω)·ln ω / ω dω ]
//       ω₂     = sqrt[ (2/λ) ∫ α²F(ω)·ω dω ]
//   are presently evaluated by trapezoidal sums on a non-uniform ω grid.
//   A Gauss-Legendre panel rule integrates the smooth α²F/ω kernel to higher
//   order than trapezoid for the same number of kernel evaluations.  This file
//   ships the generic primitive; the Eliashberg wrapper layers on top.
//
// Honest scope (commons g3):
//   · Real finite interval [a, b]; f must be a real-valued smooth integrand
//     supplied by NAME (closures are spotty under hexa AOT — we dispatch
//     through `_integrand(name, x)`, mirroring stdlib/math/ode.hexa).
//   · Single-panel 6-point rule.  For wildly oscillatory / singular kernels,
//     compose panels (caller concern) or raise the node count.
//   · scipy provides scipy.integrate.fixed_quad — this is the atlas-foldable,
//     dependency-free stdlib counterpart (+ Eliashberg-tuned weights export).
//
// Node / weight provenance: Abramowitz & Stegun, Handbook of Mathematical
// Functions, Table 25.4 (n = 6); cross-checked Numerical Recipes §4.6.
// Canonical interval [−1, 1], symmetric ± pairs:
//   ±0.2386191860831969  w = 0.4679139345726910
//   ±0.6612093864662645  w = 0.3607615730481386
//   ±0.9324695142031521  w = 0.1713244923791704
//   Σ w = 2  (exact for ∫_{-1}^1 1 dx = 2).
//
// Surface (pure functions):
//   fn gauss_legendre_6_nodes()              → [x₁ … x₆]   (on [−1, 1])
//   fn gauss_legendre_6_weights()            → [w₁ … w₆]
//   fn gauss_legendre_6(name, a, b)          → ∫_a^b f dx  (f dispatched by name)
//   fn gauss_legendre_6_on(name, a, b)       → alias (explicit "_on interval")
//   fn _integrand(name, x)                   → registered test integrands
//
// Self-test (this file): 5 closed-form falsifiers
//   F1  ∫_0^1 x^11 dx     = 1/12              (degree 11 — exact limit)
//   F2  ∫_0^1 x^12 dx     ≈ 1/13              (degree 12 — small error onset)
//   F3  ∫_{-1}^1 1 dx     = 2                 (Σ weights)
//   F4  ∫_0^π sin x dx    = 2                 (transcendental accuracy)
//   F5  ∫_2^5 x² dx       = 39                (affine-map correctness)
//
// Run:
//     hexa run stdlib/math/quadrature/gauss_legendre.hexa
//
// @version 0.1.0
// @capabilities [pure]
// @no-lock-needed

use "self/runtime/math_pure"

let VERSION = "0.1.0"

// ─── check harness ──────────────────────────────────────────────────────

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

fn abs_f(x: float) -> float { if x < 0.0 { return -x } return x }

fn rel_err(a: float, b: float) -> float {
    let d = abs_f(a - b)
    let abs_b = abs_f(b)
    if abs_b < 1.0e-30 { return d }
    return d / abs_b
}

// ─── 6-point Gauss-Legendre nodes + weights (Abramowitz-Stegun 25.4) ─────
//
// Canonical interval [−1, 1].  Returned as flat arrays in matched order so
// node[i] pairs with weight[i].  Symmetric ± pairs, Σ weights = 2.

fn gauss_legendre_6_nodes() -> [float] {
    return [
        -0.9324695142031521,
        -0.6612093864662645,
        -0.2386191860831969,
         0.2386191860831969,
         0.6612093864662645,
         0.9324695142031521,
    ]
}

fn gauss_legendre_6_weights() -> [float] {
    return [
        0.1713244923791704,
        0.3607615730481386,
        0.4679139345726910,
        0.4679139345726910,
        0.3607615730481386,
        0.1713244923791704,
    ]
}

// ─── integrand dispatch (by name — AOT-safe, mirrors ode.hexa) ──────────
//
// Closures are unreliable under hexa AOT; we route integrands through a
// named switch.  New test/Eliashberg integrands go here (and the doc table).
//   "x11"  : x^11      (degree-11 polynomial — exact for 6-point)
//   "x12"  : x^12      (degree-12 polynomial — small quadrature error)
//   "one"  : 1         (constant — Σ weights probe)
//   "sin"  : sin(x)    (transcendental)
//   "x2"   : x^2       (degree-2 polynomial — affine-map probe)

fn _integrand(name: string, x: float) -> float {
    if name == "x11" { return pow_pure(x, 11.0) }
    if name == "x12" { return pow_pure(x, 12.0) }
    if name == "one" { return 1.0 }
    if name == "sin" { return sin_pure(x) }
    if name == "x2"  { return x * x }
    // Unknown integrand → 0 so the sum visibly stalls rather than throwing.
    return 0.0
}

// ─── core quadrature ─────────────────────────────────────────────────────
//
// 6-point Gauss-Legendre on [a, b].  Affine map x = ½(b−a)·t + ½(b+a) sends
// the canonical node t ∈ [−1, 1] into [a, b]; dx = ½(b−a) dt, so the rule is
//   ∫_a^b f dx = ½(b−a) · Σᵢ wᵢ · f( ½(b−a)·tᵢ + ½(b+a) ).
fn gauss_legendre_6(name: string, a: float, b: float) -> float {
    let nodes = gauss_legendre_6_nodes()
    let weights = gauss_legendre_6_weights()

    let half_len = 0.5 * (b - a)
    let mid = 0.5 * (b + a)

    let mut acc: float = 0.0
    let mut i: int = 0
    while i < 6 {
        let t = nodes[i]
        let w = weights[i]
        let x = half_len * t + mid
        acc = acc + w * _integrand(name, x)
        i = i + 1
    }
    return half_len * acc
}

// Explicit-interval alias (reads clearer at some call sites).
fn gauss_legendre_6_on(name: string, a: float, b: float) -> float {
    return gauss_legendre_6(name, a, b)
}

// ─── anchor checks (5 closed-form falsifiers) ───────────────────────────

// F1: ∫_0^1 x^11 dx = 1/12.  Degree 11 = the exact ceiling of the 6-point
// rule (2n−1 = 11), so this must agree to floating-point exactness.
let TARGET_X11: float = 0.08333333333333333333   // 1/12
fn check_f1_x11_exact() {
    let v = gauss_legendre_6("x11", 0.0, 1.0)
    _check(rel_err(v, TARGET_X11) < 1.0e-12,
        "F1  ∫_0^1 x^11 dx = 1/12  (degree-11 EXACT limit)",
        "got=" + str(v) + "  target=" + str(TARGET_X11) +
        "  rel_err=" + str(rel_err(v, TARGET_X11)))
}

// F2: ∫_0^1 x^12 dx = 1/13.  Degree 12 exceeds the exact ceiling, so a small
// (non-zero) quadrature error is expected — bounded, not exact.
let TARGET_X12: float = 0.07692307692307692308   // 1/13
fn check_f2_x12_small_error() {
    let v = gauss_legendre_6("x12", 0.0, 1.0)
    let e = rel_err(v, TARGET_X12)
    // Error is non-zero (degree > 11) yet tiny for this smooth monomial.
    _check(e < 1.0e-3,
        "F2  ∫_0^1 x^12 dx ≈ 1/13  (degree-12 small-error onset)",
        "got=" + str(v) + "  target=" + str(TARGET_X12) + "  rel_err=" + str(e))
}

// F3: ∫_{-1}^1 1 dx = 2.  Equivalent to Σ weights = 2.
let TARGET_ONE: float = 2.0
fn check_f3_const_weight_sum() {
    let v = gauss_legendre_6("one", -1.0, 1.0)
    _check(rel_err(v, TARGET_ONE) < 1.0e-14,
        "F3  ∫_{-1}^1 1 dx = 2  (Σ weights)",
        "got=" + str(v) + "  target=" + str(TARGET_ONE) +
        "  rel_err=" + str(rel_err(v, TARGET_ONE)))
}

// F4: ∫_0^π sin x dx = 2.  Transcendental integrand — single-panel 6-point
// accuracy on a smooth full half-period.
let TARGET_SIN: float = 2.0
fn check_f4_sin() {
    let v = gauss_legendre_6("sin", 0.0, pi_pure())
    _check(rel_err(v, TARGET_SIN) < 1.0e-6,
        "F4  ∫_0^π sin x dx = 2  (transcendental)",
        "got=" + str(v) + "  target=" + str(TARGET_SIN) +
        "  rel_err=" + str(rel_err(v, TARGET_SIN)))
}

// F5: ∫_2^5 x² dx = (125 − 8)/3 = 39.  Probes the affine [a,b] map on a
// non-symmetric interval not containing 0.
let TARGET_X2: float = 39.0
fn check_f5_affine() {
    let v = gauss_legendre_6("x2", 2.0, 5.0)
    _check(rel_err(v, TARGET_X2) < 1.0e-12,
        "F5  ∫_2^5 x² dx = 39  (affine-map correctness)",
        "got=" + str(v) + "  target=" + str(TARGET_X2) +
        "  rel_err=" + str(rel_err(v, TARGET_X2)))
}

// Extra: weight symmetry + Σ = 2 directly from the exported arrays.
fn check_weights_sum_two() {
    let w = gauss_legendre_6_weights()
    let mut s: float = 0.0
    let mut i: int = 0
    while i < 6 { s = s + w[i] i = i + 1 }
    _check(rel_err(s, 2.0) < 1.0e-14,
        "Σ exported weights = 2",
        "Σw=" + str(s))
}

// Extra: node antisymmetry — nodes[i] = −nodes[5−i].
fn check_nodes_antisymmetric() {
    let n = gauss_legendre_6_nodes()
    let ok = abs_f(n[0] + n[5]) < 1.0e-15 &&
             abs_f(n[1] + n[4]) < 1.0e-15 &&
             abs_f(n[2] + n[3]) < 1.0e-15
    _check(ok,
        "nodes antisymmetric  nodes[i] = −nodes[5−i]",
        "n0+n5=" + str(n[0] + n[5]) + "  n1+n4=" + str(n[1] + n[4]) +
        "  n2+n3=" + str(n[2] + n[3]))
}


// ─── falsifiers ─────────────────────────────────────────────────────────

let FALSIFIERS = [
    "F1 break — ∫_0^1 x^11 ≠ 1/12 (rel > 1e-12) → DEMOTE node/weight table (degree-11 exactness lost)",
    "F2 break — ∫_0^1 x^12 error > 1e-3 → DEMOTE affine map or weights (degree-12 onset too large)",
    "F3 break — ∫_{-1}^1 1 ≠ 2 (rel > 1e-14) → DEMOTE weights (Σ w must equal 2)",
    "F4 break — ∫_0^π sin x ≠ 2 (rel > 1e-6) → DEMOTE sin_pure path or canonical→[a,b] map",
    "F5 break — ∫_2^5 x² ≠ 39 (rel > 1e-12) → DEMOTE affine map ½(b−a)t + ½(b+a)",
    "weight-sum break — Σ exported weights ≠ 2 → DEMOTE gauss_legendre_6_weights table",
    "node-symmetry break — nodes not antisymmetric → DEMOTE gauss_legendre_6_nodes table",
]


// ─── main ───────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/math/quadrature — 6-point Gauss-Legendre (exact ≤ degree 11)")
    println("========================================================================")
    println("  nodes ±0.2386191861, ±0.6612093865, ±0.9324695142   (Abramowitz-Stegun 25.4)")
    println("  weights 0.4679139346, 0.3607615730, 0.1713244924     Σw = 2")
    println("  ∫_a^b f dx = ½(b−a)·Σ wᵢ f(½(b−a)tᵢ + ½(b+a))")
    println("")

    println("  Anchor checks (5 closed-form falsifiers + 2 extras):")
    check_f1_x11_exact()
    check_f2_x12_small_error()
    check_f3_const_weight_sum()
    check_f4_sin()
    check_f5_affine()
    check_weights_sum_two()
    check_nodes_antisymmetric()

    println("")
    println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  6-point Gauss-Legendre quadrature self-test FAILED — see per-check output above.")
        println("__HEXA_STDLIB_MATH_QUADRATURE_GAUSS_LEGENDRE__ FAIL")
        exit(1)
    }
    println("  6-point Gauss-Legendre quadrature primitive: PASS")
    println("__HEXA_STDLIB_MATH_QUADRATURE_GAUSS_LEGENDRE__ PASS")
    exit(0)
}
