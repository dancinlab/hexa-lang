// HEXA Standard Library — math/bitops
//
// @version 0.1.0
// @capabilities [pure]
//
// Integer bit primitives. Promoted from anima HEXAD/LIFE phi_native.hexa
// (`_phi_pow2` / `_phi_bit_set`) per RFC stdlib_scaffold §3.
//
// The anima source used a multiplication accumulator for 2^k because the
// porting spec assumed hexa bit-shift was uncertain. The compiler in fact
// codegens `<<` / `&` as native C int operators, so the canonical primitives
// use them directly — the integer result is identical (byte-equal preserved).
//
// Surface:
//   pub fn pow2_int(k: int) -> int            // 2^k for k >= 0
//   pub fn bit_set(mask: int, b: int) -> int  // 1 if bit b set in mask, else 0

pub fn pow2_int(k: int) -> int {
    return 1 << k
}

pub fn bit_set(mask: int, b: int) -> int {
    if (mask & (1 << b)) != 0 { return 1 }
    return 0
}
