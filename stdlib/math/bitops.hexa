// HEXA Standard Library — math/bitops
//
// @version 0.1.0
// @capabilities [pure]
//
// Integer bitops via arithmetic (hexa native bit-shift status uncertain).
// Both fns assume k, b ≥ 0 and bounded by int64 range (pow2_int(62) max).
//
// Surface:
//   pub fn pow2_int(k: int) -> int           // 2^k for k ≥ 0
//   pub fn bit_set(mask: int, b: int) -> int // 1 if bit b of mask set, else 0
//
// Used by IIT bipartition enumerators (anima/HEXAD/LIFE/lib/phi_native.hexa
// § phi_native_spatial step 3c) and 33+ duplicate `_pow2` / `_bit_set`
// helpers across anima (.STDLIB survey 2026-05-24).

pub fn pow2_int(k: int) -> int {
    let mut v = 1
    let mut i = 0
    while i < k {
        v = v * 2
        i = i + 1
    }
    return v
}

pub fn bit_set(mask: int, b: int) -> int {
    let pw = pow2_int(b)
    if (mask / pw) % 2 == 1 { return 1 }
    return 0
}
