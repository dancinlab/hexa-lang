// @ci_gate — pure · network-free · deterministic (stdlib_selftest_aggregate --ci-gate)
//
// stdlib/cloud/fill_plan_test.hexa — CONCURRENT-FILL 발사 플랜 생성기
// (fill_plan.hexa, project.tape d_parallel_fire T1) 의 selftest.
//
// 단언:
//   - 128-core pod + 9 decks(deck당 8 ranks) → 동시 job >1, Σ-np ≤ physcores,
//     어떤 job 도 oversubscribe 안 함. script 가 background(&) + 전면 순차
//     `wait` 루프 아님(rolling `wait -n`).
//   - 작은 pod(8-core) + 1 deck → 동시 job 1 의 올바른(단일) 플랜.
//   - 거대 단일 job(ranks > physcores) → slots=1, oversubscribed=1 로 표기.
//
// Run:   hexa run stdlib/cloud/fill_plan_test.hexa
// PASS:  exits 0, prints "fill_plan_test PASS".
use "stdlib/cloud/fill_plan"

fn _check(case: str, got: int, want: int) {
    if got != want {
        println("  FAIL: " + case + " — got " + to_string(got) + " want " + to_string(want))
        exit(1)
    }
    println("  ok: " + case)
}

fn _has(s: str, t: str) -> int {
    if s.contains(t) {
        return 1
    }
    return 0
}

fn _is_empty(s: str) -> int {
    if s == "" {
        return 1
    }
    return 0
}

fn _le(case: str, got: int, cap: int) {
    if got > cap {
        println("  FAIL: " + case + " — got " + to_string(got) + " > cap " + to_string(cap))
        exit(1)
    }
    println("  ok: " + case + " (" + to_string(got) + " ≤ " + to_string(cap) + ")")
}

fn main() {
    // ── case 0 (DEFAULT = 1 deck/pod): 128-core, 9 decks, bin_pack=0 ────
    // d_parallel_fire 1순위 = 후보 1개 = pod 1개. ample budget 라도 concurrent=1.
    // (2026-05-30 ysbh6 q2 NaN · cabeh8 _ph0 disk 전멸 이후 멀티-deck 패킹은 opt-in.)
    let d0 = dft_fill_plan(128, 9, 8, 12, 0)
    _check("default 128/9/8: slots = physcores/ranks = 16 (core budget)", d0.slots, 16)
    _check("default 128/9/8: concurrent = 1 (1 deck/pod)", d0.concurrent_jobs, 1)
    _check("default 128/9/8: Σ-np = 8 (single deck)", d0.sum_np, 8)
    _check("default 128/9/8: no oversubscribe", d0.oversubscribed, 0)
    // 기본 경로는 BIN-PACK 경고를 내지 않는다(packing 안 하므로).
    _check("default 128/9/8: no bin-pack WARN (empty)", _is_empty(fill_bin_pack_warn(0, 9)), 1)
    // SLOTS=concurrent 이 script 에 박혀 onstart 루프도 한 번에 1개만 돌린다.
    _check("default 128/9/8: script SLOTS=1 (onstart honors 1 deck/pod)", _has(d0.script, "SLOTS=1\n"), 1)

    // ── case 1 (BIN-PACK opt-in): 128-core, 9 decks, 8 ranks, bin_pack=1 ─
    let p = dft_fill_plan(128, 9, 8, 12, 1)
    _check("128/9/8(bin-pack): slots = physcores/ranks = 16", p.slots, 16)
    _check("128/9/8(bin-pack): concurrent = min(9,16) = 9", p.concurrent_jobs, 9)
    // bin-pack 핵심: 동시 job > 1 (순차 체인 아님)
    if p.concurrent_jobs <= 1 {
        println("  FAIL: 128/9/8(bin-pack) emitted a single-job (sequential) plan")
        exit(1)
    }
    println("  ok: 128/9/8(bin-pack) concurrent_jobs > 1 (" + to_string(p.concurrent_jobs) + ")")
    // Σ -np ≤ physcores
    _le("128/9/8(bin-pack): Σ-np ≤ physcores", p.sum_np, p.physcores)
    // 어떤 job 도 oversubscribe 안 함
    _check("128/9/8(bin-pack): no oversubscribe", p.oversubscribed, 0)
    // script 가 동시 발사 형태 — background & + rolling wait -n, OMP/MKL=1
    _check("128/9/8: script backgrounds jobs (&)", _has(p.script, ") &\n"), 1)
    _check("128/9/8: script uses rolling wait -n (not full sequential wait)", _has(p.script, "wait -n"), 1)
    _check("128/9/8: OMP_NUM_THREADS=1", _has(p.script, "OMP_NUM_THREADS=1"), 1)
    _check("128/9/8: MKL_NUM_THREADS=1", _has(p.script, "MKL_NUM_THREADS=1"), 1)
    _check("128/9/8: OPENBLAS_NUM_THREADS=1", _has(p.script, "OPENBLAS_NUM_THREADS=1"), 1)
    _check("128/9/8: OMPI_ALLOW_RUN_AS_ROOT=1", _has(p.script, "OMPI_ALLOW_RUN_AS_ROOT=1"), 1)
    _check("128/9/8: OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1", _has(p.script, "OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1"), 1)
    _check("128/9/8: per-job timeout cap", _has(p.script, "timeout \"${WALLTIME_H}h\""), 1)
    _check("128/9/8: --allow-run-as-root -np per job", _has(p.script, "--allow-run-as-root -np"), 1)
    _check("128/9/8: --bind-to none", _has(p.script, "--bind-to none"), 1)
    // 순차 전면 루프 금지 — `for ...; do ...; wait; done` 한 줄 패턴 부재
    _check("128/9/8: NOT a sequential per-deck full-wait loop", _has(p.script, "; wait; done"), 0)

    // ── case 2: 작은 pod(8-core), 1 deck → 단일 올바른 플랜 (bin-pack 무관) ──
    let q = dft_fill_plan(8, 1, 8, 6, 1)
    _check("8/1/8: slots = 1", q.slots, 1)
    _check("8/1/8: concurrent = 1", q.concurrent_jobs, 1)
    _le("8/1/8: Σ-np ≤ physcores", q.sum_np, q.physcores)
    _check("8/1/8: no oversubscribe", q.oversubscribed, 0)
    _check("8/1/8: still emits a valid launch (background &)", _has(q.script, ") &\n"), 1)

    // ── case 3: 거대 단일 job (ranks > physcores) → slots=1, over=1 ──────
    let r = dft_fill_plan(8, 4, 16, 6, 1)
    _check("8/4/16: slots clamped to 1", r.slots, 1)
    _check("8/4/16: concurrent = 1", r.concurrent_jobs, 1)
    _check("8/4/16: oversubscribed flagged", r.oversubscribed, 1)

    // ── case 4 (bin-pack): d4 generic — 다른 (physcores, decks, ranks) 불변식 ─
    let t = dft_fill_plan(64, 20, 4, 10, 1)
    _check("64/20/4(bin-pack): slots = 16", t.slots, 16)
    _check("64/20/4(bin-pack): concurrent = min(20,16) = 16", t.concurrent_jobs, 16)
    _le("64/20/4(bin-pack): Σ-np ≤ physcores", t.sum_np, t.physcores)
    _check("64/20/4(bin-pack): no oversubscribe", t.oversubscribed, 0)
    _check("64/20/4(bin-pack): disk_bound=0 (core-only path unconstrained)", t.disk_bound, 0)
    _check("64/20/4(bin-pack): disk_slots == core slots (unconstrained)", t.disk_slots, t.slots)

    // ── case 5 (DISK core-bound, bin-pack): 128c/8ranks/9decks, 500GB/10GB ─
    // disk_slots=50 ≫ core_slots=16 → DISK 가 안 깎음. concurrent = min(9,16)=9.
    let dc = dft_fill_plan_disk(128, 8, 9, 12, 500, 10, 1)
    _check("disk core-bound: core slots = 16", dc.slots, 16)
    _check("disk core-bound: disk_slots = floor(500/10) = 50", dc.disk_slots, 50)
    _check("disk core-bound: concurrent = min(16,50,9) = 9", dc.concurrent_jobs, 9)
    _check("disk core-bound: disk_bound=0 (ample disk)", dc.disk_bound, 0)
    _le("disk core-bound: Σ-np ≤ physcores", dc.sum_np, dc.physcores)
    _check("disk core-bound: no oversubscribe", dc.oversubscribed, 0)
    // bin-pack dft_fill_plan(128,9,8,..,1) 과 동일한 concurrent 인지 회귀 단언:
    let core_only = dft_fill_plan(128, 9, 8, 12, 1)
    _check("disk core-bound: matches bin-pack core-only concurrent", dc.concurrent_jobs, core_only.concurrent_jobs)

    // ── case 6 (DISK-bound, bin-pack): 128c/8ranks/9decks, 30GB/10GB ────────
    // disk_slots=3 < core_slots=16 → DISK 가 깎는다. concurrent = min(16,3,9)=3.
    let db = dft_fill_plan_disk(128, 8, 9, 12, 30, 10, 1)
    _check("disk-bound: core_slots would be 16", fill_slots(128, 8), 16)
    _check("disk-bound: disk_slots = floor(30/10) = 3", db.disk_slots, 3)
    _check("disk-bound: concurrent = min(16,3,9) = 3", db.concurrent_jobs, 3)
    _check("disk-bound: disk_bound flag set (3 < 16 core-slots)", db.disk_bound, 1)
    _check("disk-bound: eff slots clamped to 3", db.slots, 3)
    _le("disk-bound: Σ-np ≤ physcores", db.sum_np, db.physcores)
    _check("disk-bound: no oversubscribe", db.oversubscribed, 0)
    // WHY 노출 — script 에 disk-bound 한 줄이 박혀 운영자가 이유를 본다.
    _check("disk-bound: script surfaces 'disk-bound:' reason", _has(db.script, "disk-bound:"), 1)
    _check("disk-bound: script still backgrounds jobs (&)", _has(db.script, ") &\n"), 1)
    _check("disk-bound: script uses rolling wait -n", _has(db.script, "wait -n"), 1)

    // ── case 6b (DEFAULT disk path = 1 deck/pod): same args, bin_pack=0 ────
    // bin_pack=0 → concurrent=1 regardless of disk, disk_bound suppressed.
    let db0 = dft_fill_plan_disk(128, 8, 9, 12, 30, 10, 0)
    _check("default-disk: concurrent = 1 (1 deck/pod)", db0.concurrent_jobs, 1)
    _check("default-disk: disk_bound suppressed (single deck)", db0.disk_bound, 0)
    _check("default-disk: script SLOTS=1", _has(db0.script, "SLOTS=1\n"), 1)
    _check("default-disk: no disk-bound line (single deck)", _has(db0.script, "disk-bound:"), 0)

    // ── case 7 (scratch ≤ 0 → DISK 무제약 == bin-pack core-only) ────────────
    let un = dft_fill_plan_disk(128, 8, 9, 12, 30, 0, 1)
    _check("unconstrained(scratch=0): disk_slots == core_slots", un.disk_slots, un.slots)
    _check("unconstrained(scratch=0): disk_bound=0", un.disk_bound, 0)
    _check("unconstrained(scratch=0): concurrent == core-only", un.concurrent_jobs, core_only.concurrent_jobs)
    // negative scratch 도 동일하게 무제약 처리:
    let un2 = dft_fill_plan_disk(128, 8, 9, 12, 30, -5, 1)
    _check("unconstrained(scratch<0): disk_bound=0", un2.disk_bound, 0)
    _check("unconstrained(scratch<0): concurrent == core-only", un2.concurrent_jobs, core_only.concurrent_jobs)
    // script 에는 disk-bound 줄이 없어야(무제약이므로):
    _check("unconstrained: script has NO 'disk-bound:' line", _has(un.script, "disk-bound:"), 0)

    // ── case 8 (BIN-PACK WARN string — Part 3) ──────────────────────────
    // engage = bin_pack==1 AND n_decks>1. default/single-deck → empty.
    _check("warn: bin_pack=0 → empty (default, no packing)", _is_empty(fill_bin_pack_warn(0, 9)), 1)
    _check("warn: bin_pack=1 n_decks=1 → empty (1 deck, nothing packed)", _is_empty(fill_bin_pack_warn(1, 1)), 1)
    let w = fill_bin_pack_warn(1, 6)
    _check("warn: bin_pack=1 n_decks=6 → non-empty", _is_empty(w), 0)
    _check("warn: cites N decks on 1 pod", _has(w, "6 decks on 1 pod"), 1)
    _check("warn: cites 5-18GB _ph0 scratch", _has(w, "5-18GB _ph0 scratch"), 1)
    _check("warn: cites davcio No space left", _has(w, "davcio \"No space left\""), 1)
    _check("warn: cites d_parallel_fire preference", _has(w, "Prefer 1 deck/pod (d_parallel_fire)"), 1)
    _check("warn: notes --bin-pack was set", _has(w, "Proceeding because --bin-pack was set"), 1)

    println("fill_plan_test PASS")
}
