// @ci_gate — pure · network-free · deterministic (stdlib_selftest_aggregate --ci-gate)
// stdlib/cloud/composite_idle_test.hexa — falsifiers for the COMPOSITE idle
// classifier `_should_autokill_composite` in stdlib/cloud/watchdog.
//
// 동기 (2026-05-29 RTSC 누수 사고): vast pod 6개(192-256 cores)가 rent 됐지만
// deck 가 dispatch 되지 않아 영원히 idle billing. util-단독 분류기는 "느리지만
// 일하는" pod 의 momentary 저-util 을 idle 로 오인할 위험이 있다. COMPOSITE
// 분류기는 4-신호(uptime · util · compute-proc · workdir)를 ALL 요구하므로
// 일하는 pod 은 항상 살아남는다. 본 테스트가 그 false-positive guard 를 잠근다.
//
// LLM-free · network-free · NO live pod terminate. 모든 케이스는 순수 결정
// 함수만 운동한다. _should_autokill_composite 는 module-private(`_` prefix)
// 이므로 watchdog_test.hexa 와 동일하게 test-local oracle(`_oracle_composite`)
// 로 동등 로직을 재현 — privacy 우회 없이 호출자 관점에서 검증.
//
// Run:   hexa run stdlib/cloud/composite_idle_test.hexa
// PASS:  exits 0, prints "composite_idle_test PASS — N/N cases".

use "stdlib/cloud/watchdog"

// ── util-cap oracle (mirror of _should_autokill) ─────────────────────
fn _oracle_util(uptime_min: int, util: int, threshold: int, cap: int) -> int {
    if threshold < 5 { return 0 }
    if cap < 0 { return 0 }
    if cap > 99 { return 0 }
    if uptime_min < 0 { return 0 }
    if util < 0 { return 0 }
    if uptime_min < threshold { return 0 }
    if util > cap { return 0 }
    return 1
}

// ── composite oracle (mirror of _should_autokill_composite) ──────────
//
// 결정 contract (watchdog.hexa):
//   util-cap 게이트 통과 == 0                       → 0 (살림)
//   has_compute_proc != 0  (있음 1 / 미지 -1)       → 0 (살림)
//   has_workdir      != 0  (있음 1 / 미지 -1)       → 0 (살림)
//   else                                            → 1 (kill)
fn _oracle_composite(uptime_min: int, util: int, has_proc: int, has_wd: int, threshold: int, cap: int) -> int {
    if _oracle_util(uptime_min, util, threshold, cap) == 0 { return 0 }
    if has_proc != 0 { return 0 }
    if has_wd != 0 { return 0 }
    return 1
}

fn _fail(case: str, msg: str) {
    println("FAIL " + case + ": " + msg)
    exit(1)
}

fn main() {
    // recommended defaults per the locked decision: threshold 60 min, cap 5%.
    let THR = 60
    let CAP = 5

    // ── HERO case (mandatory false-positive guard): the RTSC leak ──
    // idle pod = no compute proc (0) · no workdir (0) · 0% util · 90 min uptime
    // → KILLED.
    if _oracle_composite(90, 0, 0, 0, THR, CAP) != 1 {
        _fail("idle_killed", "idle leak (no proc · no workdir · 0% · 90min) → KILL 예상")
    }
    println("case idle_killed PASS — rented-never-dispatched pod (no proc/workdir, 0%, 90min) → KILL")

    // ── HERO case (the load-bearing spare): a working pod ──
    // compute proc PRESENT (1) even at momentary 0% util · no workdir · long
    // uptime → SPARED. This is the case util-only would wrongly kill.
    if _oracle_composite(600, 0, 1, 0, THR, CAP) != 0 {
        _fail("working_spared", "working pod (compute proc present, momentary 0% util) → SPARE 예상")
    }
    println("case working_spared PASS — slow-but-working pod (compute proc, momentary 0% util) → SPARE")

    // ── workdir-only present → SPARE (someone copied a deck; about to run) ──
    if _oracle_composite(600, 0, 0, 1, THR, CAP) != 0 {
        _fail("workdir_spared", "workdir present → SPARE 예상")
    }
    println("case workdir_spared PASS — workdir present (deck staged) → SPARE")

    // ── proc UNKNOWN (-1, probe failed) → SPARE (보수적) ──
    if _oracle_composite(600, 0, -1, 0, THR, CAP) != 0 {
        _fail("proc_unknown_spared", "compute-proc 미지(-1) → SPARE 예상")
    }
    println("case proc_unknown_spared PASS — proc probe failed (-1) → SPARE (conservative)")

    // ── workdir UNKNOWN (-1) → SPARE ──
    if _oracle_composite(600, 0, 0, -1, THR, CAP) != 0 {
        _fail("wd_unknown_spared", "workdir 미지(-1) → SPARE 예상")
    }
    println("case wd_unknown_spared PASS — workdir probe failed (-1) → SPARE (conservative)")

    // ── fresh pod under threshold → SPARE even if empty ──
    if _oracle_composite(10, 0, 0, 0, THR, CAP) != 0 {
        _fail("fresh_spared", "uptime 10min (< 60) → SPARE 예상")
    }
    println("case fresh_spared PASS — fresh empty pod (10min < 60) → SPARE")

    // ── busy util above cap, empty otherwise → SPARE (util gate) ──
    if _oracle_composite(600, 40, 0, 0, THR, CAP) != 0 {
        _fail("busy_util_spared", "util 40% > cap 5% → SPARE 예상")
    }
    println("case busy_util_spared PASS — util 40% > cap → SPARE")

    // ── boundary: uptime == threshold, util == cap, empty → KILL ──
    if _oracle_composite(60, 5, 0, 0, THR, CAP) != 1 {
        _fail("boundary_killed", "uptime==thr · util==cap · empty → KILL 예상")
    }
    println("case boundary_killed PASS — uptime==thr & util==cap & empty → KILL")

    // ── uptime unknown (-1) → SPARE (util gate -1 미지) ──
    if _oracle_composite(-1, 0, 0, 0, THR, CAP) != 0 {
        _fail("uptime_unknown_spared", "uptime 미지(-1) → SPARE 예상")
    }
    println("case uptime_unknown_spared PASS — uptime unknown → SPARE")

    // ── snapshot data-path: composite snapshot from a live record degrades
    //    every signal to a safe value when the M5 record has no ssh endpoint
    //    (empty host → probe -1 → SPARE). Build a synthetic empty PodRecord. ──
    // (we exercise the pure oracle above; the live snapshot helper is network-
    //  bound and intentionally not invoked in this hermetic test.)

    println("composite_idle_test PASS — 9/9 cases")
    exit(0)
}
