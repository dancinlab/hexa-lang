// stdlib/cloud/runpod.hexa — RunPod provider (cycle B-2 + B-2.1).
//
// Each public function tries the runpodctl CLI first (cleaner JSON output,
// official tool — handles auth retries, edge cases) and falls back to the
// GraphQL API on local-CLI absence or failure. Set RUNPODCTL_DISABLE=1 in
// the environment to force the API-fallback path (useful for testing).
//
// CLI route — exec → runpodctl create pod / pod get / remove pod
// API route — POST → https://api.runpod.io/graphql?api_key=… (curl via
//   stdlib/http; JSON parse via stdlib/alloc/json_object).
//
// pool-route bypass — runpod API calls run LOCAL (cred-bound, Keychain on
// the local Mac). pool-route should NOT relay these to a remote host that
// lacks `secret get runpod.api_key`; otherwise a 401 surfaces from a remote
// `runpodctl` invocation that simply had no key. The local-paths whitelist
// (~/.sidecar/local-paths) is the enforcement surface — this file is the
// documentation marker.

use "stdlib/http"
use "stdlib/alloc/json_object"
use "stdlib/cloud/cloud"

// ── result shapes ────────────────────────────────────────────────────

struct RunPodPod {
    ok:           int,   // 1 iff pod was created
    pod_id:       str,   // RunPod pod id (empty on failure)
    cost_per_hr:  str,   // dollars-per-hour (RunPod `costPerHr`); "" if absent (M3 cost-cap rate source)
    message:      str
}

struct RunPodSshPort {
    ok:      int,   // 1 iff a public port-22 mapping is ready
    ip:      str,   // pod public IP
    port:    str,   // public port mapped to 22 (string form for ssh -p)
    message: str
}

fn _runpod_fail_pod(msg: str) -> RunPodPod {
    return RunPodPod { ok: 0, pod_id: "", cost_per_hr: "", message: msg }
}

// _runpod_cost_str — coerce a parsed JSON value to a plain $/hr string.
// RunPod reports `costPerHr` as a float (e.g. 1.89); accept int too. Any
// other shape (null / missing / string-typed) returns "" (cost-cap inert).
fn _runpod_cost_str(v) -> str {
    let t = type_of(v)
    if t == "float" || t == "int" {
        return to_string(v)
    }
    if t == "string" {
        return to_string(v)
    }
    return ""
}

fn _runpod_fail_port(msg: str) -> RunPodSshPort {
    return RunPodSshPort { ok: 0, ip: "", port: "", message: msg }
}

// ── runpodctl detection ──────────────────────────────────────────────

// _runpodctl_path — return the runpodctl binary path if available, else "".
// `RUNPODCTL_DISABLE=1` in the env forces the API-fallback path even if
// runpodctl is installed (useful when testing the fallback).
fn _runpodctl_path() -> str {
    if env_var("RUNPODCTL_DISABLE") == "1" {
        return ""
    }
    let home_bin = env_var("HOME") + "/bin/runpodctl"
    if file_exists(home_bin) {
        return home_bin
    }
    let on_path = exec("command -v runpodctl 2>/dev/null").trim()
    return on_path
}

// ── credential resolution — single SSOT for CLI · dispatch · watchdog ──

// _toml_str_field — extract a flat-TOML `<key> = "<value>"` (first match, "" if none).
fn _toml_str_field(toml: str, key: str) -> str {
    let lines = toml.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.index_of(key) == 0 {
            let q0 = ln.index_of("\"")
            if q0 >= 0 {
                let rest = ln.substring(q0 + 1, len(ln))
                let q1 = rest.index_of("\"")
                if q1 >= 0 { return rest.substring(0, q1) }
            }
        }
        i = i + 1
    }
    return ""
}

// runpod_api_key — resolve the RunPod API key, canonical order:
//   1. `secret get runpod.api_key`  (macOS Keychain SSOT)
//   2. ~/.runpod/config.toml  `api_key = "…"`  (runpodctl maintains it)
//   3. RUNPOD_API_KEY env
// Every path (cloud CLI · fire dispatch · idle-orphan watchdog) auths the same
// way — no manual env setup, no stale-key drift, no un-killable orphan from a
// watchdog that simply lacked a key.
fn runpod_api_key() -> str {
    let s = exec("secret get runpod.api_key 2>/dev/null").trim()
    if len(s) > 0 { return s }
    let toml = read_file(env_var("HOME") + "/.runpod/config.toml")
    let k = _toml_str_field(toml, "api_key")
    if len(k) > 0 { return k }
    return env_var("RUNPOD_API_KEY")
}

// cloud_runpod_api_key — M7 auto-bootstrap. Env-passthrough first
// (RUNPOD_API_KEY honored when set), then Keychain via `secret get
// runpod.api_key`, then ~/.runpod/config.toml. Returns "" when nothing
// resolves — caller decides how to react. Identical resolution surface
// across every `cloud` verb so the user never sets env vars manually.
// pool-route bypass: runpod API calls run LOCAL (cred-bound) — pool-route
// should NOT relay this resolver to a remote host.
fn cloud_runpod_api_key() -> str {
    let env_key = env_var("RUNPOD_API_KEY")
    if len(env_key) > 0 { return env_key }
    let s = exec("secret get runpod.api_key 2>/dev/null").trim()
    if len(s) > 0 { return s }
    let toml = read_file(env_var("HOME") + "/.runpod/config.toml")
    let k = _toml_str_field(toml, "api_key")
    if len(k) > 0 { return k }
    return ""
}

// cloud_runpod_must_have_api_key — resolve via cloud_runpod_api_key and
// hard-exit with a uniform missing-key hint when empty. `verb` labels the
// surfacing CLI verb (rent · down · ssh-port · …) so the user sees which
// path tripped. Never prints the key itself.
fn cloud_runpod_must_have_api_key(verb: str) -> str {
    let k = cloud_runpod_api_key()
    if len(k) > 0 { return k }
    println("[cloud] " + verb + ": missing runpod.api_key — set it: secret set runpod.api_key <YOUR_KEY> (https://runpod.io/console/user/settings)")
    exit(2)
    return ""
}

// cloud_runpod_401_hint — uniform hint string appended to any RunPod API
// failure whose payload (HTTP status text or GraphQL error body) contains
// a 401 / unauthorized signal. Caller concatenates onto the surfaced
// message; never prints the key itself. Case-permissive over the common
// runpodctl + curl surfacings ("401 Unauthorized", "Unauthorized",
// "unauthorized", "statuscode 401", "Invalid API key", "invalid api key").
fn cloud_runpod_401_hint(payload: str) -> str {
    let unauth = payload.index_of("401") >= 0
        || payload.index_of("Unauthorized") >= 0
        || payload.index_of("unauthorized") >= 0
        || payload.index_of("UNAUTHORIZED") >= 0
        || payload.index_of("Invalid API key") >= 0
        || payload.index_of("invalid api key") >= 0
    if unauth {
        return " — [cloud] runpod 401 — API key invalid or revoked. Refresh: secret rotate runpod.api_key (https://runpod.io/console/user/settings)"
    }
    return ""
}

// runpod_local_pubkey — the local SSH public key, so every pod we create is
// reachable from THIS host. A pod created without our key is publickey-denied:
// a crashed-dispatch orphan then can't be inspected/torn-down over ssh, only
// via runpodctl. ed25519 → rsa fallback.
fn runpod_local_pubkey() -> str {
    let home = env_var("HOME")
    let ed = read_file(home + "/.ssh/id_ed25519.pub").trim()
    if len(ed) > 0 { return ed }
    return read_file(home + "/.ssh/id_rsa.pub").trim()
}

// _shq_local — POSIX-quote a token for the local /bin/sh -c. Mirrors
// cloud.hexa's _shq; kept local here so this module does not depend on a
// private export. Wraps in single quotes; a literal ' becomes '\''.
fn _shq_local(s: str) -> str {
    let mut out = "'"
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            out = out + "'\\''"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out + "'"
}

// ── API transport (GraphQL, fallback path) ───────────────────────────

fn _runpod_post(api_key: str, body: str, timeout_sec: int) -> str {
    let url = "https://api.runpod.io/graphql?api_key=" + api_key
    let h = #{"Content-Type": "application/json"}
    return http_post_with_headers(url, h, body, timeout_sec)
}

// ── pod create ───────────────────────────────────────────────────────

fn _runpod_create_cli(rpc: str, gpu_type: str, image: str, pubkey: str, name: str) -> RunPodPod {
    // runpodctl 2.x: `pod create` (new form). Deprecated `create pod` emits
    // a warning line that breaks json_parse. Flags renamed: --gpu-id /
    // --image / --container-disk-in-gb / --cloud-type. --env now takes a
    // JSON object, not KEY=val. Pubkeys are ASCII without ", \, or control
    // chars, so plain concatenation produces valid JSON.
    let env_json = "{\"PUBLIC_KEY\":\"" + pubkey + "\"}"
    let cmd = _shq_local(rpc) + " pod create"
        + " --gpu-id " + _shq_local(gpu_type)
        + " --image " + _shq_local(image)
        + " --name " + _shq_local(name)
        + " --env " + _shq_local(env_json)
        + " --ports 22/tcp"
        + " --container-disk-in-gb 80"
        + " --volume-mount-path /workspace"
        + " --cloud-type SECURE"
        + " -o json 2>&1"
    let out = exec(cmd)
    let parsed = json_parse(out)
    let id_v = json_object_get(parsed, "id")
    if type_of(id_v) == "string" {
        let pid = to_string(id_v)
        if len(pid) > 0 {
            // `costPerHr` (float $/hr) when runpodctl surfaces it; "" otherwise
            // (M3 cost-cap rate source — inert when absent, TTL unaffected).
            let cph = _runpod_cost_str(json_object_get(parsed, "costPerHr"))
            return RunPodPod { ok: 1, pod_id: pid, cost_per_hr: cph, message: "created (cli) on " + gpu_type }
        }
    }
    let snippet = out.substring(0, 200)
    return _runpod_fail_pod("create (cli) failed: " + snippet + cloud_runpod_401_hint(snippet))
}

fn _runpod_create_api(api_key: str, gpu_type: str, image: str, pubkey: str, name: str) -> RunPodPod {
    // `costPerHr` is on the Pod type returned by the mutation — request it so
    // the M3 cost-cap has a rate source captured at create time.
    let body = "{\"query\":\"mutation { podFindAndDeployOnDemand(input:{cloudType: ALL, gpuCount:1, volumeInGb:0, containerDiskInGb:80, minVcpuCount:8, minMemoryInGb:32, gpuTypeId:\\\"" + gpu_type + "\\\", name:\\\"" + name + "\\\", imageName:\\\"" + image + "\\\", dockerArgs:\\\"\\\", ports:\\\"22/tcp\\\", volumeMountPath:\\\"/workspace\\\", env:[{key:\\\"PUBLIC_KEY\\\", value:\\\"" + pubkey + "\\\"}]}) { id machineId costPerHr } }\"}"
    let resp = _runpod_post(api_key, body, 60)
    if len(resp) == 0 {
        return _runpod_fail_pod("create (api): empty response (HTTPS / auth failure)")
    }
    let parsed = json_parse(resp)
    let id_v = json_object_get_path(parsed, "data.podFindAndDeployOnDemand.id")
    if type_of(id_v) == "string" {
        let pid = to_string(id_v)
        if len(pid) > 0 {
            let cph = _runpod_cost_str(json_object_get_path(parsed, "data.podFindAndDeployOnDemand.costPerHr"))
            return RunPodPod { ok: 1, pod_id: pid, cost_per_hr: cph, message: "created (api) on " + gpu_type }
        }
    }
    return _runpod_fail_pod("create (api): no id in response (no capacity / bad input)" + cloud_runpod_401_hint(resp))
}

// runpod_create — try CLI first, fall back to GraphQL API on CLI absence
// or failure. `api_key` is only used by the API fallback path.
fn runpod_create(api_key: str, gpu_type: str, image: str, pubkey: str, name: str) -> RunPodPod {
    let rpc = _runpodctl_path()
    if len(rpc) > 0 {
        let r = _runpod_create_cli(rpc, gpu_type, image, pubkey, name)
        if r.ok == 1 {
            return r
        }
    }
    return _runpod_create_api(api_key, gpu_type, image, pubkey, name)
}

// runpod_create_cascade — try each GPU type in order; first that succeeds
// wins. RunPod capacity for any single GPU is bursty.
fn runpod_create_cascade(api_key: str, gpu_types: [str], image: str, pubkey: str, name: str) -> RunPodPod {
    let mut i = 0
    while i < len(gpu_types) {
        let r = runpod_create(api_key, gpu_types[i], image, pubkey, name)
        if r.ok == 1 {
            return r
        }
        exec("sleep 4")
        i = i + 1
    }
    return _runpod_fail_pod("create_cascade: no GPU type succeeded")
}

// ── ssh-port query + wait ────────────────────────────────────────────

// runpodctl emits one of three JSON shapes depending on version:
//   shape-A (canonical):  { ssh: { ip: "1.2.3.4", port: 11863 } }
//   shape-B (variant):    { ssh: { host: "1.2.3.4", port: 11863 } }
//   shape-C (0.5+ flat):  { publicIp: "1.2.3.4", ports: [{ type: "ssh", port: 11863 }, ...] }
// Anima M3 fire (INBOX #1734, 2026-05-28) hit shape-C — old CLI arm only saw
// shape-A and degraded to the GraphQL fallback. We now try all three before
// declaring "no ssh info yet" so the resolver covers every runpodctl version
// in the wild without needing the API key for the fallback.
fn _runpod_get_ssh_port_cli(rpc: str, pod_id: str) -> RunPodSshPort {
    let cmd = _shq_local(rpc) + " pod get " + _shq_local(pod_id) + " -o json 2>&1"
    let out = exec(cmd)
    let parsed = json_parse(out)

    // shape-A: ssh.ip + ssh.port (int)
    let ip_a = json_object_get_path(parsed, "ssh.ip")
    let port_a = json_object_get_path(parsed, "ssh.port")
    if type_of(ip_a) == "string" && type_of(port_a) == "int" {
        let ipstr = to_string(ip_a)
        let portstr = to_string(port_a)
        if len(ipstr) > 0 && len(portstr) > 0 {
            return RunPodSshPort { ok: 1, ip: ipstr, port: portstr, message: "port 22 (cli/ssh.ip)" }
        }
    }

    // shape-B: ssh.host + ssh.port (int)
    let host_b = json_object_get_path(parsed, "ssh.host")
    if type_of(host_b) == "string" && type_of(port_a) == "int" {
        let hoststr = to_string(host_b)
        let portstr = to_string(port_a)
        if len(hoststr) > 0 && len(portstr) > 0 {
            return RunPodSshPort { ok: 1, ip: hoststr, port: portstr, message: "port 22 (cli/ssh.host)" }
        }
    }

    // shape-C: publicIp + ports[].{type=="ssh"}.port (runpodctl 0.5+)
    let pub_ip = json_object_get_path(parsed, "publicIp")
    let ports_v = json_object_get_path(parsed, "ports")
    if type_of(pub_ip) == "string" && type_of(ports_v) == "array" {
        let ipstr = to_string(pub_ip)
        if len(ipstr) > 0 {
            let mut i = 0
            while i < len(ports_v) {
                let p = ports_v[i]
                let ptype = json_object_get_str(p, "type", "")
                let pport = json_object_get_int(p, "port", 0)
                if ptype == "ssh" && pport > 0 {
                    return RunPodSshPort { ok: 1, ip: ipstr, port: to_string(pport), message: "port 22 (cli/publicIp+ports)" }
                }
                i = i + 1
            }
        }
    }

    return _runpod_fail_port("get_ssh_port (cli): no ssh info yet")
}

fn _runpod_get_ssh_port_api(api_key: str, pod_id: str) -> RunPodSshPort {
    let body = "{\"query\":\"query { pod(input:{podId:\\\"" + pod_id + "\\\"}) { runtime { ports { ip publicPort privatePort isIpPublic } } } }\"}"
    let resp = _runpod_post(api_key, body, 30)
    if len(resp) == 0 {
        return _runpod_fail_port("get_ssh_port (api): empty response")
    }
    let parsed = json_parse(resp)
    let ports_v = json_object_get_path(parsed, "data.pod.runtime.ports")
    if type_of(ports_v) != "array" {
        return _runpod_fail_port("get_ssh_port (api): runtime not provisioned yet" + cloud_runpod_401_hint(resp))
    }
    let mut i = 0
    while i < len(ports_v) {
        let p = ports_v[i]
        let priv_port = json_object_get_int(p, "privatePort", 0)
        let is_pub = json_object_get(p, "isIpPublic")
        let p_ip = json_object_get_str(p, "ip", "")
        let p_port = json_object_get_int(p, "publicPort", 0)
        if priv_port == 22 && is_pub == true && len(p_ip) > 0 && p_port > 0 {
            return RunPodSshPort { ok: 1, ip: p_ip, port: to_string(p_port), message: "port 22 (api)" }
        }
        i = i + 1
    }
    return _runpod_fail_port("get_ssh_port (api): port 22 not yet mapped")
}

// runpod_get_ssh_port — try CLI first, fall back to GraphQL API.
fn runpod_get_ssh_port(api_key: str, pod_id: str) -> RunPodSshPort {
    let rpc = _runpodctl_path()
    if len(rpc) > 0 {
        let r = _runpod_get_ssh_port_cli(rpc, pod_id)
        if r.ok == 1 {
            return r
        }
    }
    return _runpod_get_ssh_port_api(api_key, pod_id)
}

// ── cost-per-hour query (M3 cost-cap rate fallback) ──────────────────
//
// `costPerHr` is captured at create time (see runpod_create); this is the
// follow-up source for the case where the create response did NOT carry it
// (older runpodctl shapes, or a CLI `pod create` JSON that omits the field).
// CLI `pod get -o json` exposes `costPerHr`; the GraphQL `pod` query has the
// same field on the Pod type. Returns the $/hr string, "" if neither path
// surfaces it (cost-cap stays inert — TTL still enforces).

fn _runpod_cost_per_hr_cli(rpc: str, pod_id: str) -> str {
    let cmd = _shq_local(rpc) + " pod get " + _shq_local(pod_id) + " -o json 2>&1"
    let out = exec(cmd)
    let parsed = json_parse(out)
    return _runpod_cost_str(json_object_get(parsed, "costPerHr"))
}

fn _runpod_cost_per_hr_api(api_key: str, pod_id: str) -> str {
    let body = "{\"query\":\"query { pod(input:{podId:\\\"" + pod_id + "\\\"}) { costPerHr } }\"}"
    let resp = _runpod_post(api_key, body, 30)
    if len(resp) == 0 {
        return ""
    }
    let parsed = json_parse(resp)
    return _runpod_cost_str(json_object_get_path(parsed, "data.pod.costPerHr"))
}

// runpod_pod_cost_per_hr — best-effort $/hr lookup for a live pod. Tries the
// CLI `pod get` first, then the GraphQL `pod` query. "" if unavailable.
fn runpod_pod_cost_per_hr(api_key: str, pod_id: str) -> str {
    if len(pod_id) == 0 {
        return ""
    }
    let rpc = _runpodctl_path()
    if len(rpc) > 0 {
        let c = _runpod_cost_per_hr_cli(rpc, pod_id)
        if len(c) > 0 {
            return c
        }
    }
    return _runpod_cost_per_hr_api(api_key, pod_id)
}

// runpod_pod_opts — canonical ssh_opts for an ephemeral RunPod pod.
// `ServerAliveInterval=15` + `ServerAliveCountMax=3` keep an idle ssh from
// being declared dead by transient network noise (45s of unanswered
// keepalives → clean exit, instead of a TCP-stale timeout that took several
// minutes and confused poll-loop strike counters in the wild).
fn runpod_pod_opts(port: str) -> [str] {
    return ["-p", port, "-o", "StrictHostKeyChecking=no", "-o", "UserKnownHostsFile=/dev/null", "-o", "ServerAliveInterval=15", "-o", "ServerAliveCountMax=3"]
}

// runpod_wait_ssh — poll the port map AND a real `echo` round-trip via
// ssh until both succeed, or the budget elapses.
fn runpod_wait_ssh(api_key: str, pod_id: str, max_tries: int, sleep_each_sec: int) -> RunPodSshPort {
    let mut i = 0
    let sleep_cmd = "sleep " + to_string(sleep_each_sec)
    while i < max_tries {
        let p = runpod_get_ssh_port(api_key, pod_id)
        if p.ok == 1 {
            let probe = cloud_run_opts("root@" + p.ip, runpod_pod_opts(p.port), ["echo", "__RUNPOD_UP__"])
            if probe.ok == 1 {
                if probe.stdout_.index_of("__RUNPOD_UP__") >= 0 {
                    return p
                }
            }
        }
        exec(sleep_cmd)
        i = i + 1
    }
    return _runpod_fail_port("wait_ssh: never ready in " + to_string(max_tries * sleep_each_sec) + "s")
}

// ── teardown ─────────────────────────────────────────────────────────

fn _runpod_terminate_cli(rpc: str, pod_id: str) -> int {
    // runpodctl 2.x: `pod delete` (new form) — aliases: rm / remove. The
    // top-level `runpod remove pod` is deprecated.
    let cmd = _shq_local(rpc) + " pod delete " + _shq_local(pod_id) + " -o json 2>&1"
    let out = exec(cmd)
    // Best-effort: any output containing "error" is a failure; otherwise
    // treat as success (runpodctl prints a short confirmation). 401 is a
    // cred miss (pool-route to a host without the key, or a revoked key) —
    // surface the canonical hint inline so the operator can self-recover.
    let hint = cloud_runpod_401_hint(out)
    if len(hint) > 0 {
        println("[cloud] runpod terminate (cli) failed:" + hint)
        return 0
    }
    if out.index_of("error") >= 0 {
        return 0
    }
    if out.index_of("Error") >= 0 {
        return 0
    }
    return 1
}

fn _runpod_terminate_api(api_key: str, pod_id: str) -> int {
    let body = "{\"query\":\"mutation { podTerminate(input:{podId:\\\"" + pod_id + "\\\"}) }\"}"
    let resp = _runpod_post(api_key, body, 30)
    if len(resp) > 0 {
        return 1
    }
    return 0
}

// runpod_terminate — terminate the pod. Best-effort; tries CLI first,
// falls back to API. Returns 1 on apparent success, 0 on failure or
// empty pod_id.
fn runpod_terminate(api_key: str, pod_id: str) -> int {
    if len(pod_id) == 0 {
        return 0
    }
    let rpc = _runpodctl_path()
    if len(rpc) > 0 {
        if _runpod_terminate_cli(rpc, pod_id) == 1 {
            return 1
        }
    }
    return _runpod_terminate_api(api_key, pod_id)
}

// runpod_terminate_unless — conditional teardown. Terminate the pod unless
// `skip` is true, in which case the pod is left running and 1 is returned
// (no-op success). Closes the one surface gap the PURE dispatcher's
// `pod_terminate(pod_id, save_pod)` stub needed: `runpod_terminate` itself
// is unconditional, so a `save_pod="yes"` path that must KEEP the pod alive
// had no first-class helper. Folding the branch into stdlib keeps every
// dispatcher callsite a single call (no `if save_pod { } else { terminate }`
// boilerplate duplicated per launcher) and keeps the "kept-alive == success"
// semantics in one place. Returns 1 when skipped, else delegates to
// runpod_terminate (1 success / 0 failure).
fn runpod_terminate_unless(api_key: str, pod_id: str, skip: bool) -> int {
    if skip {
        return 1
    }
    return runpod_terminate(api_key, pod_id)
}

// ── pod list ─────────────────────────────────────────────────────────

struct RunPodList {
    ok:      int,     // 1 iff a runpodctl invocation returned (possibly empty) results
    pod_ids: [str],   // discovered pod ids
    message: str
}

fn _runpod_list_fail(msg: str) -> RunPodList {
    return RunPodList { ok: 0, pod_ids: [], message: msg }
}

// _first_token — return the prefix of `s` up to the first whitespace
// (space or tab), or the whole string if no whitespace is present.
fn _first_token(s: str) -> str {
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" {
            return s.substring(0, i)
        }
        i = i + 1
    }
    return s
}

// _runpod_is_help_text — does the output look like cobra/runpodctl usage or
// help text rather than a pod listing? A wrong subcommand (e.g. the plural
// `get pods`) makes runpodctl print its usage block, whose lines previously
// got split into fake pod ids: Usage:, Available, Flags:, Global, Use.
// (handoff hexa-lang a71ec0dd.)
fn _runpod_is_help_text(out: str) -> int {
    if out.index_of("Usage:") >= 0 { return 1 }
    if out.index_of("Available Commands:") >= 0 { return 1 }
    if out.index_of("Global Flags:") >= 0 { return 1 }
    if out.index_of("unknown command") >= 0 { return 1 }
    if out.index_of("unknown flag") >= 0 { return 1 }
    return 0
}

// _runpod_valid_pod_id — is `tok` shaped like a real RunPod pod id? RunPod
// ids are lowercase alphanumeric (a-z, 0-9) tokens, ~10-24 chars, with no
// punctuation/uppercase/whitespace. This rejects help-text words such as
// "Usage:", "Available", "Flags:", "Global", "Use" (uppercase + colons)
// and table headers, so a degraded CLI invocation can never fabricate pods.
fn _runpod_valid_pod_id(tok: str) -> int {
    let n = len(tok)
    if n < 8 { return 0 }
    if n > 32 { return 0 }
    let mut i = 0
    let mut has_digit = 0
    while i < n {
        let c = tok.substring(i, i + 1)
        let is_lower = c >= "a" && c <= "z"
        let is_digit = c >= "0" && c <= "9"
        if !is_lower && !is_digit {
            return 0
        }
        if is_digit { has_digit = 1 }
        i = i + 1
    }
    // a real pod id carries at least one digit; an all-letter lowercase word
    // (e.g. "available") would otherwise slip through.
    return has_digit
}

// _runpod_strip_to_json — drop a leading non-JSON banner (e.g. the
// `warning: 'runpodctl get pod' is deprecated …` line runpodctl prints
// before the JSON array) by slicing from the first `[` or `{`. Returns the
// input unchanged when no JSON opener is found.
fn _runpod_strip_to_json(out: str) -> str {
    let lb = out.index_of("[")
    let ob = out.index_of("{")
    let mut start = lb
    if ob >= 0 && (start < 0 || ob < start) {
        start = ob
    }
    if start < 0 {
        return out
    }
    return out.substring(start, len(out))
}

// _runpod_list_new — `runpodctl pod list -o json` (2.x form). Returns
// ok=0 when the new verb is rejected (runpodctl < 2.x), so the caller
// can fall through to the deprecated form.
fn _runpod_list_new(rpc: str) -> RunPodList {
    let cmd = _shq_local(rpc) + " pod list -o json 2>&1"
    let out = exec(cmd)
    if out.index_of("unknown command") >= 0 {
        return _runpod_list_fail("list (new): runpodctl too old")
    }
    if out.index_of("unrecognized") >= 0 {
        return _runpod_list_fail("list (new): runpodctl too old")
    }
    if _runpod_is_help_text(out) == 1 {
        return _runpod_list_fail("list (new): runpodctl too old")
    }
    let parsed = json_parse(_runpod_strip_to_json(out))
    if type_of(parsed) != "array" {
        return _runpod_list_fail("list (new): non-array JSON")
    }
    let mut ids = []
    let mut i = 0
    while i < len(parsed) {
        let id_v = json_object_get(parsed[i], "id")
        if type_of(id_v) == "string" {
            let id_s = to_string(id_v)
            if len(id_s) > 0 {
                ids.push(id_s)
            }
        }
        i = i + 1
    }
    return RunPodList { ok: 1, pod_ids: ids, message: "list (new) — " + to_string(len(ids)) + " pods" }
}

// _runpod_list_old — `runpodctl get pod` (1.x form, deprecated). The verb
// is SINGULAR (`get pod`); the plural `get pods` is NOT a runpodctl verb —
// it errors and prints the usage block, whose lines (Usage:, Available,
// Flags:, Global, Use) previously got split into fake pod ids (handoff
// hexa-lang a71ec0dd). Under runpodctl 2.x `get pod` still works but emits
// a `deprecated:`/`warning:` banner on stdout that must be skipped.
// First whitespace-separated token of each non-header, non-banner,
// non-empty line = pod id, but only if it passes the pod-id shape check —
// so help/error text can never fabricate pods.
fn _runpod_list_old(rpc: str) -> RunPodList {
    let cmd = _shq_local(rpc) + " get pod -o json 2>&1"
    let out = exec(cmd)
    // a wrong/rejected subcommand prints usage text → clean error, no pods.
    if _runpod_is_help_text(out) == 1 {
        return _runpod_list_fail("list (old): runpodctl returned usage/help text (bad subcommand or flag)")
    }
    // 2.x `get pod -o json` emits a 1-line warning banner then a JSON array.
    let parsed = json_parse(_runpod_strip_to_json(out))
    if type_of(parsed) == "array" {
        let mut ids = []
        let mut k = 0
        while k < len(parsed) {
            let id_v = json_object_get(parsed[k], "id")
            if type_of(id_v) == "string" {
                let id_s = to_string(id_v)
                if len(id_s) > 0 {
                    ids.push(id_s)
                }
            }
            k = k + 1
        }
        return RunPodList { ok: 1, pod_ids: ids, message: "list (old) — " + to_string(len(ids)) + " pods" }
    }
    // text-table fallback (very old runpodctl that ignores -o json).
    let lines = out.split("\n")
    let mut ids = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let n = len(line)
        let is_banner = line.index_of("deprecated") >= 0 || line.index_of("warning:") >= 0
        let is_id_hdr = n >= 2 && line.substring(0, 2) == "ID"
        let is_pid_hdr = n >= 6 && line.substring(0, 6) == "POD ID"
        if n > 0 && !is_banner && !is_id_hdr && !is_pid_hdr {
            let tok = _first_token(line)
            if _runpod_valid_pod_id(tok) == 1 {
                ids.push(tok)
            }
        }
        i = i + 1
    }
    return RunPodList { ok: 1, pod_ids: ids, message: "list (old) — " + to_string(len(ids)) + " pods" }
}

// runpod_list_pods — return the active pod ids known to the local
// runpodctl. Tries the canonical 2.x `pod list -o json` form first; on
// `unknown command`/`unrecognized` falls back to the deprecated 1.x
// `get pod -o json` form (SINGULAR — the plural `get pods` is not a
// runpodctl verb and only prints usage text). Stable interface for
// downstream orphan-detection / lifecycle scripts independent of the
// installed runpodctl version (inbox patch
// cloud-runpod-session-findings-anima-2026-05-23 R1; handoff a71ec0dd).
fn runpod_list_pods() -> RunPodList {
    let rpc = _runpodctl_path()
    if len(rpc) == 0 {
        return _runpod_list_fail("runpodctl not found")
    }
    let r = _runpod_list_new(rpc)
    if r.ok == 1 {
        return r
    }
    return _runpod_list_old(rpc)
}

// ── env-var passthrough audit (G5 — anima 2026-05-24 cycle 15) ───────
//
// Closed-form, LLM-free check that bridges a dispatcher script (bash, the
// thing that runs `runpodctl pod create … --env AXIS_LR=… --env AXIS_BSZ=…`)
// to the train script it kicks off on the pod (typically Python). The G5
// failure mode the audit defends against:
//
//   - dispatcher defines `AXIS_FOO=...` and (correctly) propagates it to
//     the pod via `--env AXIS_FOO=$AXIS_FOO`,
//   - but the train script never reads `AXIS_FOO` from `os.environ` AND
//     never accepts a `--axis-foo` argparse flag wired to it,
//   - so the env-var rides into the pod and is silently dropped.
//
// In anima's R8 saga (2026-05-24 cycle 15) this turned a 7-config fan-out
// into a trivial-identity 2-config run, sinking ~$10 of GPU spend before
// the post-hoc audit caught it. This helper is the preflight surface for
// that class of bug: source-level grep of two text files, regex-shape
// only, no LLM, no remote execution.
//
// Scope: pattern detection is intentionally conservative (regex / substring
// only). Edge cases the patch's falsifier list calls out:
//   F-G5-4  multi-line `$CMD` (line-continuation backslash) — handled by
//           reading the whole file as one string before scanning.
//   F-G5-5  bash `${AXIS_FOO:-default}` form — handled by also matching
//           `${VAR` (no closing `}` required at this layer, so `${VAR:-x}`,
//           `${VAR}`, and bare `$VAR` all count as passthrough).
//
// Consumption detection in Python recognizes three idioms (any one passes):
//   1. argparse:     add_argument("--axis-foo"  | "--axis_foo")
//   2. environ.get:  os.environ.get("AXIS_FOO" | 'AXIS_FOO')
//   3. environ[]:    os.environ["AXIS_FOO"]  / os.getenv("AXIS_FOO")
//
// The result struct is verdict-shaped so callers can either gate launch
// (refuse() on non-empty missing_*) or warn-and-proceed (override flag).

struct EnvPassthroughResult {
    ok:                   int,      // 1 iff every env-var is both passed and consumed
    missing_passthrough:  [str],    // env-vars defined in dispatcher but NOT forwarded to train
    missing_consumption:  [str],    // env-vars forwarded to train but NOT read by train script
    message:              str
}

fn _env_pt_fail(msg: str) -> EnvPassthroughResult {
    return EnvPassthroughResult { ok: 0, missing_passthrough: [], missing_consumption: [], message: msg }
}

// _flag_form — convert "AXIS_HEAD_LR" into "--axis-head-lr" (lowercase,
// underscore → hyphen). argparse convention used by every Python script
// we ship; the underscore form ("--axis_head_lr") is also recognised as
// a fallback in the consumer scan.
fn _flag_form(name: str) -> str {
    let mut out = "--"
    let mut i = 0
    let n = len(name)
    while i < n {
        let c = name.substring(i, i + 1)
        let cc = char_code(c)
        if cc >= 65 && cc <= 90 {
            // uppercase A-Z → lowercase a-z
            out = out + chr(cc + 32)
        } else if c == "_" {
            out = out + "-"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out
}

// _flag_form_underscore — "AXIS_HEAD_LR" → "--axis_head_lr". The argparse
// underscore variant some scripts use directly.
fn _flag_form_underscore(name: str) -> str {
    let mut out = "--"
    let mut i = 0
    let n = len(name)
    while i < n {
        let c = name.substring(i, i + 1)
        let cc = char_code(c)
        if cc >= 65 && cc <= 90 {
            out = out + chr(cc + 32)
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out
}

// _dispatcher_forwards — scan the dispatcher source for ANY syntactic
// reference to the env-var that suggests it is forwarded to the pod or
// the train command. Conservative match — accepts:
//   "$VAR"        bare expansion
//   "${VAR"       brace expansion (`${VAR}`, `${VAR:-default}`, etc.)
//   "--env VAR=", "--env=VAR=", "--env=VAR ", "-e VAR="    runpodctl --env flag
//   "VAR=$VAR" inside the train command line (passthrough idiom)
// Returns 1 iff at least one such reference exists.
fn _dispatcher_forwards(src: str, name: str) -> int {
    if src.index_of("$" + name) >= 0 { return 1 }
    if src.index_of("${" + name) >= 0 { return 1 }
    if src.index_of("--env " + name + "=") >= 0 { return 1 }
    if src.index_of("--env=" + name + "=") >= 0 { return 1 }
    if src.index_of("--env " + name + " ") >= 0 { return 1 }
    if src.index_of("-e " + name + "=") >= 0 { return 1 }
    if src.index_of("-e " + name + " ") >= 0 { return 1 }
    return 0
}

// _python_consumes — scan a Python train script for any of the three
// supported consumption idioms keyed on `name`. argparse flag check uses
// both the hyphenated and underscored forms to match either convention.
fn _python_consumes(src: str, name: str) -> int {
    // argparse — both styles
    let flag_h = _flag_form(name)              // --axis-head-lr
    let flag_u = _flag_form_underscore(name)   // --axis_head_lr
    if src.index_of("\"" + flag_h + "\"") >= 0 { return 1 }
    if src.index_of("'" + flag_h + "'") >= 0 { return 1 }
    if src.index_of("\"" + flag_u + "\"") >= 0 { return 1 }
    if src.index_of("'" + flag_u + "'") >= 0 { return 1 }
    // os.environ / os.getenv
    if src.index_of("os.environ.get(\"" + name + "\"") >= 0 { return 1 }
    if src.index_of("os.environ.get('" + name + "'") >= 0 { return 1 }
    if src.index_of("os.environ[\"" + name + "\"]") >= 0 { return 1 }
    if src.index_of("os.environ['" + name + "']") >= 0 { return 1 }
    if src.index_of("os.getenv(\"" + name + "\"") >= 0 { return 1 }
    if src.index_of("os.getenv('" + name + "'") >= 0 { return 1 }
    // bare `environ.get("VAR"` — some scripts `from os import environ`
    if src.index_of("environ.get(\"" + name + "\"") >= 0 { return 1 }
    if src.index_of("environ.get('" + name + "'") >= 0 { return 1 }
    if src.index_of("environ[\"" + name + "\"]") >= 0 { return 1 }
    if src.index_of("environ['" + name + "']") >= 0 { return 1 }
    if src.index_of("getenv(\"" + name + "\"") >= 0 { return 1 }
    if src.index_of("getenv('" + name + "'") >= 0 { return 1 }
    return 0
}

// cloud_validate_env_passthrough — closed-form audit that every env-var
// in `env_vars` is forwarded by `dispatcher_script` (bash) AND consumed
// by `train_script` (Python). Returns an EnvPassthroughResult whose
// `missing_passthrough` and `missing_consumption` arrays are empty iff
// the wiring is intact end-to-end. `ok == 1` <=> both arrays empty.
//
// Either path may be empty; an empty file reads as "no references", so
// every env-var lands in the corresponding `missing_*` list — exactly
// the failure mode the audit is built to flag.
//
// Caller policy: REFUSE (exit non-zero) on `ok == 0` unless an
// `--allow-unwired-env` style override is set; the helper itself does
// not exit, it only reports.
fn cloud_validate_env_passthrough(
    dispatcher_script: str,
    train_script:      str,
    env_vars:          [str]
) -> EnvPassthroughResult {
    if len(env_vars) == 0 {
        return EnvPassthroughResult { ok: 1, missing_passthrough: [], missing_consumption: [], message: "no env-vars to audit" }
    }
    if !file_exists(dispatcher_script) {
        return _env_pt_fail("dispatcher script not found: " + dispatcher_script)
    }
    if !file_exists(train_script) {
        return _env_pt_fail("train script not found: " + train_script)
    }
    let disp_src = read_file(dispatcher_script)
    let train_src = read_file(train_script)
    let mut missing_pt = []
    let mut missing_co = []
    let mut i = 0
    while i < len(env_vars) {
        let name = env_vars[i]
        if _dispatcher_forwards(disp_src, name) == 0 {
            missing_pt.push(name)
        }
        if _python_consumes(train_src, name) == 0 {
            missing_co.push(name)
        }
        i = i + 1
    }
    let ok_flag = if len(missing_pt) == 0 && len(missing_co) == 0 { 1 } else { 0 }
    let msg = if ok_flag == 1 {
        "env-var passthrough audit PASS — " + to_string(len(env_vars)) + " vars wired"
    } else {
        "env-var passthrough audit FAIL — " + to_string(len(missing_pt)) + " missing passthrough, " + to_string(len(missing_co)) + " missing consumption"
    }
    return EnvPassthroughResult { ok: ok_flag, missing_passthrough: missing_pt, missing_consumption: missing_co, message: msg }
}
