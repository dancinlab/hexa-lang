// HEXA Standard Library — cloud/fill_plan
//
// @version 0.1.0
// @capabilities [pure]
//
// CONCURRENT-FILL 발사 플랜 생성기 (project.tape d_parallel_fire 강제화 T1).
//
// 기존 deck-dispatch 경로(dft_dispatch.hexa)는 pod 1대당 deck 1개만
// 처리한다. N개의 deck 을 한 pod 에 쌓으면 운영자가 손으로 작성한
// `onstart.sh` 의 `for deck; do run; wait; done` 순차 체인이 돈다 —
// 128-core pod 가 8 ranks(deck 1개)만 돌리고 8+ deck 이 idle 로 줄서서
// 15× core 낭비(2026-05-29 vast 38095989 실측).
//
// 이 모듈은 그 자리를 메우는 CANONICAL 홈이다: (physcores, n_decks,
// ranks_per_deck) 만 받아 deck 들을 동시(concurrent)에, pod core budget
// 한도(Σ -np ≤ physcores)까지 background 로 발사하는 launch 스크립트를
// 순수 함수로 emit 한다. d4 generic — count/name hardcoding 없음, 오직
// (physcores, n_decks, ranks_per_deck, walltime) 입력으로만 구동.
//
// 핵심 불변식:
//   - slots = physcores / ranks_per_deck   (동시 슬롯 수, ≥1 강제)
//   - 어떤 단일 job 도 oversubscribe 안 함  (ranks_per_deck ≤ physcores)
//   - 동시 job 수 = min(n_decks, slots)
//   - 각 job: OMP_NUM_THREADS=MKL_NUM_THREADS=1 · timeout <walltime>h ·
//     mpirun --allow-run-as-root -np <ranks_per_deck> --bind-to none ph.x
//     -in ph.in · background(&) · pid 기록 · 마지막에 wait
//   - 순차 `for deck; do run; wait; done` 루프 금지.
//
// Single-module 라이브러리(no `use`) — repo hexa_v2 로 직접 transpile.

// ── FillPlan — 발사 플랜의 구조화된 결과 ──────────────────────────────
// 스크립트 텍스트(script)와, selftest/audit 가 직접 단언할 수 있는 파생
// 수치(slots/concurrent_jobs/sum_np/oversubscribed)를 함께 담는다.
struct FillPlan {
    physcores: int,
    n_decks: int,
    ranks_per_deck: int,
    slots: int,           // physcores / ranks_per_deck (동시 슬롯 수)
    concurrent_jobs: int, // min(n_decks, slots) — 1차 배치에서 동시 발사 수
    sum_np: int,          // concurrent_jobs * ranks_per_deck (≤ physcores 불변)
    oversubscribed: int,  // 1 == 어떤 job 이 physcores 초과 (위반) — 항상 0 이어야
    script: str,
}

// fill_slots — pod core budget 에서 동시 슬롯 수를 계산한다.
// slots = floor(physcores / ranks_per_deck). ranks_per_deck 가 physcores
// 보다 크면(거대 단일 job) 슬롯은 최소 1 — 그 job 하나만 발사(oversub 별도 표기).
fn fill_slots(physcores: int, ranks_per_deck: int) -> int {
    if ranks_per_deck <= 0 {
        return 1
    }
    let s = physcores / ranks_per_deck
    if s < 1 {
        return 1
    }
    return s
}

// _fill_min — 두 정수 중 작은 값.
fn _fill_min(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

// dft_fill_plan — CONCURRENT-FILL launch 플랜을 생성한다.
//
// (physcores, n_decks, ranks_per_deck, walltime_h) → FillPlan.
// 생성된 script 는 deck 디렉터리 배열(DECKS=...)을 돌며 동시 슬롯 한도까지
// background 로 ph.x 를 발사하고, 슬롯이 차면 `wait -n` 으로 한 자리 비면
// 다음 deck 을 채운다(rolling concurrent fill). 순차 `wait` 전면 루프 아님.
pub fn dft_fill_plan(physcores: int, n_decks: int, ranks_per_deck: int, walltime_h: int) -> FillPlan {
    let slots = fill_slots(physcores, ranks_per_deck)
    let concurrent = _fill_min(n_decks, slots)
    let sum_np = concurrent * ranks_per_deck
    let mut over = 0
    if ranks_per_deck > physcores {
        over = 1
    }

    let mut s = "#!/usr/bin/env bash\n"
    s = s + "# CONCURRENT-FILL launch (project.tape d_parallel_fire) — generated by dft_fill_plan.\n"
    s = s + "# physcores=" + to_string(physcores) + " n_decks=" + to_string(n_decks)
        + " ranks_per_deck=" + to_string(ranks_per_deck) + " slots=" + to_string(slots)
        + " concurrent=" + to_string(concurrent) + " sum_np=" + to_string(sum_np) + "\n"
    s = s + "set -uo pipefail\n"
    s = s + "cd \"$(dirname \"$0\")\"\n"
    s = s + "\n"
    s = s + "# 한 deck = 한 ph.x job. 어느 시점에도 동시 job 수 ≤ SLOTS, Σ(-np) ≤ PHYSCORES.\n"
    s = s + "PHYSCORES=" + to_string(physcores) + "\n"
    s = s + "RANKS_PER_DECK=" + to_string(ranks_per_deck) + "\n"
    s = s + "SLOTS=" + to_string(slots) + "\n"
    s = s + "WALLTIME_H=" + to_string(walltime_h) + "\n"
    s = s + "export OMP_NUM_THREADS=1\n"
    s = s + "export MKL_NUM_THREADS=1\n"
    s = s + "\n"
    s = s + "# DECKS = 발사할 deck 디렉터리들. 디스패처가 실제 목록으로 치환한다.\n"
    s = s + "DECKS=( \"$@\" )\n"
    s = s + "[ \"${#DECKS[@]}\" -eq 0 ] && DECKS=( */ )\n"
    s = s + "\n"
    s = s + "declare -a PIDS=()\n"
    s = s + "running=0\n"
    s = s + "for d in \"${DECKS[@]}\"; do\n"
    s = s + "  d=\"${d%/}\"\n"
    s = s + "  [ -f \"$d/ph.in\" ] || { echo \"skip $d (no ph.in)\"; continue; }\n"
    s = s + "  # 슬롯이 다 차 있으면 한 job 이 끝날 때까지만 기다린다(rolling fill, 전면 wait 아님).\n"
    s = s + "  if [ \"$running\" -ge \"$SLOTS\" ]; then\n"
    s = s + "    wait -n\n"
    s = s + "    running=$((running-1))\n"
    s = s + "  fi\n"
    s = s + "  ( cd \"$d\" && setsid timeout \"${WALLTIME_H}h\" \\\n"
    s = s + "      mpirun --allow-run-as-root -np \"$RANKS_PER_DECK\" --bind-to none \\\n"
    s = s + "      ph.x -in ph.in > ph.out 2>&1 ) &\n"
    s = s + "  PIDS+=( $! )\n"
    s = s + "  running=$((running+1))\n"
    s = s + "  echo \"launched $d pid=$! (-np $RANKS_PER_DECK, slot $running/$SLOTS)\"\n"
    s = s + "done\n"
    s = s + "\n"
    s = s + "# 남은 모든 background job 수확.\n"
    s = s + "rc=0\n"
    s = s + "for p in \"${PIDS[@]}\"; do wait \"$p\" || rc=1; done\n"
    s = s + "echo \"FILL DONE (rc=$rc)\"\n"
    s = s + "exit $rc\n"

    return FillPlan {
        physcores: physcores,
        n_decks: n_decks,
        ranks_per_deck: ranks_per_deck,
        slots: slots,
        concurrent_jobs: concurrent,
        sum_np: sum_np,
        oversubscribed: over,
        script: s,
    }
}
