// stdlib/cloud/pod_registry_guard_test.hexa — guard for the registry pod-id
// sink filter (#1229 B). `pod_registry_record` drops any token that is not a
// provider pod-id (ssh destination / host / IP / path / argv fragment), which
// is what poisoned `cloud reconcile` with phantom GHOST rows (#1229 A). This
// mirrors `_pod_id_looks_valid` verbatim (the established mirror-test pattern —
// see reconcile_test.hexa — since the source fn is private + pod_registry.hexa
// is import-safe but the fn is `_`-prefixed). Keep byte-identical to source.
//
// Run:   hexa run stdlib/cloud/pod_registry_guard_test.hexa
// PASS:  exits 0, prints "pod_registry_guard_test PASS".

// ── mirror of pod_registry.hexa:_pod_id_looks_valid ─────────────────────
fn _pod_id_looks_valid(pod_id: str) -> int {
    let n = len(pod_id)
    if n == 0 {
        return 0
    }
    if pod_id.substring(0, 1) == "-" {
        return 0
    }
    let mut i = 0
    while i < n {
        let c = pod_id.substring(i, i + 1)
        if c == "@" || c == "/" || c == "." || c == " " || c == "\t" {
            return 0
        }
        i = i + 1
    }
    return 1
}

fn _ck(name: str, got: int, want: int) {
    if got != want {
        println("  FAIL: " + name + " got " + to_string(got) + " want " + to_string(want))
        exit(1)
    }
    println("  ok: " + name)
}

fn main() {
    // valid provider pod-ids → tracked
    _ck("vast numeric id", _pod_id_looks_valid("12345678"), 1)
    _ck("runpod alnum id", _pod_id_looks_valid("abc123def"), 1)
    _ck("runpod hyphen id", _pod_id_looks_valid("pod-9x7q2"), 1)
    _ck("underscore id", _pod_id_looks_valid("ab_12"), 1)
    // pollution shapes → dropped (host / IP / path / flag / empty)
    _ck("ssh destination", _pod_id_looks_valid("root@1.2.3.4"), 0)
    _ck("proxy host (dots)", _pod_id_looks_valid("proxyN" + "." + "host" + "." + "tld"), 0)
    _ck("bare IP", _pod_id_looks_valid("88.90.102.66"), 0)
    _ck("path fragment", _pod_id_looks_valid("/root/run.sh"), 0)
    _ck("flag fragment", _pod_id_looks_valid("--help"), 0)
    _ck("flag insecure", _pod_id_looks_valid("--insecure"), 0)
    _ck("empty", _pod_id_looks_valid(""), 0)
    println("pod_registry_guard_test PASS")
}
