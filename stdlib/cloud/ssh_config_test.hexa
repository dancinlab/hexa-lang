// stdlib/cloud/ssh_config_test.hexa — guard for the #1155 zero-flag
// ~/.ssh/config auto-injection (vast.hexa: vast_ssh_config_block / _splice).
// Mirrors the pure source fns verbatim (established mirror-test pattern — the
// source is import-safe but the splice's correctness is the safety-critical
// part since it rewrites the user's ~/.ssh/config). Keep byte-identical.
//
// Run:   hexa run stdlib/cloud/ssh_config_test.hexa
// PASS:  exits 0, prints "ssh_config_test PASS".

fn _vast_cfg_begin(ip: str) -> str { return "# >>> hexa-cloud vast " + ip + " >>>" }
fn _vast_cfg_end(ip: str) -> str { return "# <<< hexa-cloud vast " + ip + " <<<" }

fn vast_ssh_config_block(ip: str, identity: str) -> str {
    return _vast_cfg_begin(ip) + "\n"
        + "Host " + ip + "\n"
        + "    IdentityFile " + identity + "\n"
        + "    IdentitiesOnly yes\n"
        + "    StrictHostKeyChecking no\n"
        + "    UserKnownHostsFile /dev/null\n"
        + _vast_cfg_end(ip)
}

fn vast_ssh_config_splice(existing: str, ip: str, identity: str) -> str {
    let begin = _vast_cfg_begin(ip)
    let end = _vast_cfg_end(ip)
    let lines = existing.split("\n")
    let mut kept = []
    let mut skip = 0
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln == begin {
            skip = 1
        } else {
            if ln == end {
                skip = 0
            } else {
                if skip == 0 {
                    kept.push(ln)
                }
            }
        }
        i = i + 1
    }
    let mut base = ""
    let mut j = 0
    while j < len(kept) {
        if j > 0 {
            base = base + "\n"
        }
        base = base + kept[j]
        j = j + 1
    }
    let block = vast_ssh_config_block(ip, identity)
    let trimmed = base.trim()
    if len(trimmed) == 0 {
        return block + "\n"
    }
    return trimmed + "\n\n" + block + "\n"
}

fn _ck(name: str, got: int, want: int) {
    if got != want {
        println("  FAIL: " + name + " got " + to_string(got) + " want " + to_string(want))
        exit(1)
    }
    println("  ok: " + name)
}

fn _count(s: str, sub: str) -> int {
    let mut n = 0
    let mut i = 0
    let l = len(sub)
    while i + l <= len(s) {
        if s.substring(i, i + l) == sub {
            n = n + 1
            i = i + l
        } else {
            i = i + 1
        }
    }
    return n
}

fn _has(s: str, t: str) -> int {
    if s.contains(t) {
        return 1
    }
    return 0
}

fn main() {
    let ip_a = "1.2.3.4"
    let key = "/home/u/.ssh/id_vast_anima"

    // empty config → just the managed block
    let e1 = vast_ssh_config_splice("", ip_a, key)
    _ck("empty: Host ip", _has(e1, "Host " + ip_a), 1)
    _ck("empty: IdentityFile key", _has(e1, "IdentityFile " + key), 1)
    _ck("empty: one begin marker", _count(e1, "# >>> hexa-cloud vast " + ip_a), 1)

    // user content preserved verbatim
    let user = "Host myserver\n    User bob\n    Port 2222\n"
    let e2 = vast_ssh_config_splice(user, ip_a, key)
    _ck("user: keeps myserver", _has(e2, "Host myserver"), 1)
    _ck("user: keeps User bob", _has(e2, "User bob"), 1)
    _ck("user: adds vast block", _has(e2, "Host " + ip_a), 1)

    // idempotent: re-splice same ip → replaced, never duplicated
    let e3 = vast_ssh_config_splice(e2, ip_a, key)
    _ck("idempotent: one begin marker", _count(e3, "# >>> hexa-cloud vast " + ip_a), 1)
    _ck("idempotent: one Host ip line", _count(e3, "Host " + ip_a + "\n"), 1)
    _ck("idempotent: user content intact", _has(e3, "Host myserver"), 1)

    // a second ip coexists with the first
    let ip_b = "9.8.7.6"
    let e4 = vast_ssh_config_splice(e3, ip_b, key)
    _ck("two ips: A present", _count(e4, "# >>> hexa-cloud vast " + ip_a), 1)
    _ck("two ips: B present", _count(e4, "# >>> hexa-cloud vast " + ip_b), 1)

    // NO Port directive — --port stays caller-controlled (no service hijack)
    _ck("block has no Port directive", _has(vast_ssh_config_block(ip_a, key), "Port "), 0)

    println("ssh_config_test PASS")
}
