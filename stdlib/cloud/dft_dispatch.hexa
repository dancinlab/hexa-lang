// stdlib/cloud/dft_dispatch.hexa — `hexa cloud dft-run <deck-dir>`: a guarded
// one-command DFT electron-phonon pod dispatcher (QE pw.x / ph.x).
//
// Absorbs the demiurge RTSC campaign's hand-roll checklist
// (demiurge/exports/sweep/DFT_POD_DISPATCH_RECIPE.md, INBOX #1249) into code so
// the four repeated-mistake classes can no longer happen by omission:
//
//   ① RENT      — verified + reliability>0.97 offers, `--direct` create (already
//                 in vast_create), and a TCP `echo REACHABLE` precheck that
//                 destroys + re-rents an unreachable pod (proxy-only / dead host).
//   ② TRANSPORT — IP/port from the PLURAL `show instances --raw` ground-truth
//                 (vast_direct_endpoint; the single `show instance <id>` crashes
//                 on a null start_date, #1239) and the bare public IP, never the
//                 cloud-guard-blocked proxy host.
//   ③ CHAIN     — a hexa-native relax→scf coordinate parser (NO hand-parser:
//                 mg2pth6 / mgb2h both FATAL'd on hand-parsers), `-np = physical
//                 cores` (Core(s)×Socket(s), NOT nproc → no oversubscribe thrash),
//                 `--allow-run-as-root`, `recover=.true.`, `timeout`, `setsid`.
//   ④ MONITOR   — numeric instance-id only in the registry (#1229 argv-fragment
//                 guard), an imaginary-mode<-5cm⁻¹ fast unstable verdict, and a
//                 non-interactive teardown so a finished/failed pod never orphans.
//
// LIBRARY MODULE — no `main()` here on purpose: the verb lives in cloud_cli.hexa
// (`hexa cloud dft-run …` → dft_run) and the pure helpers are `use`-able by
// dft_dispatch_test.hexa without auto-firing a top-level main (INBOX G2).
//
// SAFE BY DEFAULT — a bare `hexa cloud dft-run <deck>` is PREVIEW: it validates
// the deck, prints the guarded plan, and (if a local relax.out exists) runs the
// coordinate parser so you can eyeball the result — spending NOTHING. Only the
// explicit `--go` / `--detach` / `--resume` flags rent a billing pod and dispatch.
//
// DISPATCH MODES — three explicit, $-incurring entry points:
//   --go      SYNCHRONOUS — rent → relax → scf → el-ph → verdict → teardown all
//             in ONE local process (HOURS — exceeds the 10-min Bash cap). Kept
//             100% intact for back-compat (/system & single-shot callers).
//   --detach  PHASE-1 (option α) — rent + provision + launch relax DETACHED on
//             the pod (cloud_nohup → remote log), register, write a state stamp,
//             return 0. NO teardown. The long work runs on the POD, so the local
//             process exits immediately (no Bash-cap overrun, no forbidden local
//             `( nohup dft-run --go & )` double-fork / launchd-zombie fork-storm).
//   --resume  PHASE-2 — EXPLICIT + IDEMPOTENT. Reads the state stamp, copies the
//             outputs back, runs the LOCAL hexa-native coord parser, and advances
//             ONE terminal step: relax-done → assemble + launch scf+ph detached;
//             ph-terminal → harvest + dft_phonon_stable verdict + teardown. NOT an
//             auto-poll loop (re-invoke per candidate; a no-op while a step runs).
//   PACED CAMPAIGN — `--detach` every candidate (each on its own pod, d_parallel_
//   fire), then poll `--resume <deck>` per candidate to walk each to its verdict.
//
// DECK CONVENTION (<deck-dir>/) — BOTH layouts accepted (d4 one generic path):
//   • relax : vc-relax.in (deck-gen native) OR relax.in (legacy)
//   • ph    : ph.in
//   • scf   : a WHOLE scf.in (deck-gen native — auto-split at the
//             ATOMIC_POSITIONS block) OR explicit scf.in.head + scf.in.tail
//             (legacy). The relaxed CELL_PARAMETERS+ATOMIC_POSITIONS block is
//             spliced BETWEEN head and tail so K_POINTS etc. in the tail are
//             preserved; the assembled deck is written to scf.in.gen so a
//             whole-scf.in source template is never clobbered.
//   • pseudo/

use "stdlib/cloud/cloud"
use "stdlib/cloud/vast"
use "stdlib/cloud/pod_registry"
use "stdlib/cloud/preflight_dft"  // tls_dft_mpi_sweet_spot — d11 pre-rent OOM mem-budget gate (Fix-deck-1)
use "stdlib/io"  // write_text — atomic plaintext write of the .validated stamp (dft_run)

// Bohr radius in angstrom — the QE `alat`→angstrom cell conversion factor
// the recipe pins (CELL_PARAMETERS (alat=X) vectors × (X·BOHR_ANGSTROM)).
let DFT_BOHR_ANGSTROM = 0.52917720859

// ── small pure scanners ──────────────────────────────────────────────

// _dft_tokens — split on runs of spaces/tabs (QE output is variably spaced).
fn _dft_tokens(s: str) -> [str] {
    let mut toks = []
    let mut cur = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        let cc = char_code(c)
        if cc == 32 || cc == 9 {
            if len(cur) > 0 {
                toks.push(cur)
                cur = ""
            }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 {
        toks.push(cur)
    }
    return toks
}

// _dft_is_num — does the token start like a number (digit / sign / dot)?
fn _dft_is_num(t: str) -> int {
    if len(t) == 0 {
        return 0
    }
    let c0 = t.substring(0, 1)
    let cc = char_code(c0)
    if cc >= 48 && cc <= 57 {
        return 1
    }
    if c0 == "-" || c0 == "+" || c0 == "." {
        return 1
    }
    return 0
}

// _dft_atof — strip non-numeric trailing/leading junk (e.g. "5.89)" / "alat=")
// then parse as float. Keeps digits, sign, dot, exponent marker.
fn _dft_atof(s: str) -> float {
    let mut clean = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        let cc = char_code(c)
        let is_digit = cc >= 48 && cc <= 57
        let is_sym = c == "." || c == "-" || c == "+" || c == "e" || c == "E"
        if is_digit || is_sym {
            clean = clean + c
        }
        i = i + 1
    }
    if len(clean) == 0 {
        return 0.0
    }
    return clean.parse_float()
}

// _dft_atoi — digit-only base-10 (ignores sign; phys quantities are positive).
fn _dft_atoi(s: str) -> int {
    let mut i = 0
    let mut v = 0
    let n = len(s)
    while i < n {
        let cc = char_code(s.substring(i, i + 1))
        if cc >= 48 && cc <= 57 {
            v = v * 10 + (cc - 48)
        }
        i = i + 1
    }
    return v
}

// _dft_paren_inner — substring between the first '(' and the next ')'.
fn _dft_paren_inner(s: str) -> str {
    let n = len(s)
    let mut i = 0
    let mut start = -1
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "(" {
            start = i + 1
        }
        if c == ")" {
            if start >= 0 && i > start {
                return s.substring(start, i).trim()
            }
        }
        i = i + 1
    }
    return ""
}

// _dft_is_pos_line — an ATOMIC_POSITIONS row starts with an element symbol.
fn _dft_is_pos_line(t: str) -> int {
    if len(t) == 0 {
        return 0
    }
    let cc = char_code(t.substring(0, 1))
    if cc >= 65 && cc <= 90 {
        return 1
    }
    if cc >= 97 && cc <= 122 {
        return 1
    }
    return 0
}

// _dft_scale_vec — a cell-vector line "x y z" → the same vector × scale,
// re-emitted. Returns "" when the line is not 3 numeric tokens (so the
// caller can skip blanks / labels between CELL_PARAMETERS and the vectors).
fn _dft_scale_vec(line: str, scale: float) -> str {
    let toks = _dft_tokens(line.trim())
    if len(toks) < 3 {
        return ""
    }
    let base = len(toks) - 3
    if _dft_is_num(toks[base]) == 0 {
        return ""
    }
    if _dft_is_num(toks[base + 1]) == 0 {
        return ""
    }
    if _dft_is_num(toks[base + 2]) == 0 {
        return ""
    }
    let x = _dft_atof(toks[base]) * scale
    let y = _dft_atof(toks[base + 1]) * scale
    let z = _dft_atof(toks[base + 2]) * scale
    return "  " + to_string(x) + "   " + to_string(y) + "   " + to_string(z)
}

// ── ① rent query (guard) ─────────────────────────────────────────────

// dft_rent_query — the offer predicates the recipe pins on top of
// vast_search_offers' verified+rentable defaults. reliability>0.97 (low-cost
// interruptibles preempt in ~13h → lost runs) overrides the default >=0.95
// via vastai last-wins; physical-core + bandwidth floors keep el-ph viable.
//
// COST CAP (d7) — el-ph (`pw.x` mpirun) is CPU-bound and uses 0% GPU, so the
// directive-d7 sizing for these small (4–7 atom) RTSC cells is pool/CPU, NOT a
// GPU node. With no price ceiling the guard grabbed top-tier B200 pods at
// $4.25–12.13/hr (~4–6× overspend on an idle GPU). `dph_total<2.0` excludes
// that B200 tier while still admitting cheap CPU/commodity-GPU nodes that meet
// the cpu_cores/RAM floors. A caller `--query` (via `extra`) is appended AFTER
// the cap so a big job can raise it (vastai last-wins on a repeated key).
// `extra` appends caller predicates (e.g. a gpu_name filter, or a dph override).
pub fn dft_rent_query(extra: str) -> str {
    let base = "reliability>0.97 cpu_cores_effective>=16 inet_down>=200 dph_total<2.0"
    if len(extra) > 0 {
        return base + " " + extra
    }
    return base
}

// COST LEVER (handoff 23ffc7ed) — el-ph is CPU-bound (QE 6.7 CPU-only · ph.x has
// no GPU path pre-7.2) yet the GPU-inclusive `dft_rent_query` keeps landing on
// idle RTX-PRO/B200 nodes "rented for their CPUs" (~$1.5/hr, GPU 0% util). The
// CPU-FIRST tier keeps the SAME reliability/core/bandwidth floors but tightens
// the price ceiling to a CPU-class rate (`dph_total<0.6`) and adds NO gpu_name
// requirement — so a cheap reliable CPU offer wins when one exists. The dispatch
// tries this tier FIRST and only falls back to `dft_rent_query` (current GPU-
// inclusive behavior, byte-for-byte) when no CPU offer clears the floor.
pub fn dft_rent_query_cpu_first(extra: str) -> str {
    let base = "reliability>0.97 cpu_cores_effective>=16 inet_down>=200 dph_total<0.6"
    if len(extra) > 0 {
        return base + " " + extra
    }
    return base
}

// dft_rent_query_tiers — the ordered offer-selection tiers: CPU-first, then the
// GPU-inclusive fallback. The rent path iterates these in order and rents the
// first tier that yields an offer (see _dft_rent_first_offer). Element [1] is
// EXACTLY `dft_rent_query(extra)` so the fallback preserves current behavior.
pub fn dft_rent_query_tiers(extra: str) -> [str] {
    return [dft_rent_query_cpu_first(extra), dft_rent_query(extra)]
}

// _dft_query_to_cpu_first — PURE: derive the CPU-first form of an ALREADY-built
// GPU-inclusive query by retightening the price ceiling to the CPU rate. The
// only floor that differs between the two tiers is `dph_total`, so swapping that
// one token turns the GPU query (possibly carrying a runtime suffix such as
// `cpu_ram>=…`) into its CPU-first sibling without re-threading `extra`.
fn _dft_query_to_cpu_first(gpu_query: str) -> str {
    return gpu_query.replace("dph_total<2.0", "dph_total<0.6")
}

// _dft_rent_first_offer — try the CPU-first tier, then fall back to the supplied
// GPU-inclusive query (current behavior). Returns the first tier whose search
// yields a rentable offer; if the CPU tier is empty it transparently retries the
// GPU query, so a scarce-CPU-offer day still rents exactly as it does today.
fn _dft_rent_first_offer(gpu_query: str) -> VastOffer {
    let cpu_query = _dft_query_to_cpu_first(gpu_query)
    if cpu_query != gpu_query {
        println("[dft-run] ① RENT tier-1 (CPU-first): `" + cpu_query + "`")
        let cpu = vast_search_offers(cpu_query, 1)
        if cpu.ok == 1 {
            println("[dft-run]   CPU-first offer cleared — renting it (GPU premium avoided).")
            return cpu
        }
        println("[dft-run]   no CPU-first offer cleared the floor — falling back to GPU-inclusive tier.")
    }
    println("[dft-run] ① RENT tier-2 (GPU-inclusive fallback): `" + gpu_query + "`")
    return vast_search_offers(gpu_query, 1)
}

// ── ③ relax → scf coordinate parser (guard) ──────────────────────────

// dft_relax_to_scf_coords — given a QE pw.x relax stdout, return the
// `CELL_PARAMETERS (angstrom)` + `ATOMIC_POSITIONS (<kind>)` block ready to
// splice into scf.in. Reads the LAST "Begin final coordinates" block; the
// alat-units cell vectors are scaled to angstrom (× alat·BOHR_ANGSTROM) and
// the atomic positions pass through verbatim. Returns "" when no final-
// coordinates block is present (relax did not converge / output truncated)
// — the caller then FATALs rather than dispatch scf on stale coordinates.
pub fn dft_relax_to_scf_coords(relax_out: str) -> str {
    let lines = relax_out.split("\n")
    let n = len(lines)
    let mut begin = -1
    let mut i = 0
    while i < n {
        if lines[i].contains("Begin final coordinates") {
            begin = i
        }
        i = i + 1
    }
    if begin < 0 {
        return ""
    }
    // locate CELL_PARAMETERS + ATOMIC_POSITIONS headers within the block.
    let mut cell_at = -1
    let mut pos_at = -1
    let mut alat = 0.0
    let mut pos_kind = "crystal"
    let mut j = begin
    while j < n {
        let ln = lines[j]
        if ln.contains("CELL_PARAMETERS") {
            cell_at = j
            alat = _dft_atof(_dft_paren_inner(ln))
        }
        if ln.contains("ATOMIC_POSITIONS") {
            pos_at = j
            let k = _dft_paren_inner(ln)
            if len(k) > 0 {
                pos_kind = k
            }
        }
        if ln.contains("End final coordinates") {
            j = n
        } else {
            j = j + 1
        }
    }
    let mut out = ""
    if cell_at >= 0 && alat > 0.0 {
        out = out + "CELL_PARAMETERS (angstrom)\n"
        let scale = alat * DFT_BOHR_ANGSTROM
        let mut k = cell_at + 1
        let mut got = 0
        while k < n && got < 3 {
            let v = _dft_scale_vec(lines[k], scale)
            if len(v) > 0 {
                out = out + v + "\n"
                got = got + 1
            }
            k = k + 1
        }
    }
    if pos_at >= 0 {
        out = out + "ATOMIC_POSITIONS (" + pos_kind + ")\n"
        let mut p = pos_at + 1
        while p < n {
            let t = lines[p].trim()
            if len(t) == 0 {
                p = n
            } else {
                if t.contains("End final coordinates") {
                    p = n
                } else {
                    if _dft_is_pos_line(t) == 1 {
                        out = out + t + "\n"
                        p = p + 1
                    } else {
                        p = n
                    }
                }
            }
        }
    }
    return out
}

// _dft_head_ibrav0 — force `ibrav = 0` + drop celldm() in the scf head.
// The relaxed geometry is injected as `CELL_PARAMETERS (angstrom)`, but QE
// FORBIDS CELL_PARAMETERS when ibrav≠0 (it expects celldm) → pw.x exits 1. A
// deck written for the "ibrav=N + manually-replace celldm" workflow (e.g.
// ibrav=3 BCC) is thus incompatible with CELL_PARAMETERS injection. Rewrite
// every `ibrav = N` to `ibrav = 0` and DROP every `celldm(...)` line so
// `ibrav=0 + CELL_PARAMETERS (angstrom)` is a self-contained valid cell.
fn _dft_head_ibrav0(head: str) -> str {
    let lines = head.split("\n")
    let mut out = ""
    let mut i = 0
    let n = len(lines)
    while i < n {
        let ln = lines[i]
        if ln.contains("ibrav") && ln.contains("=") {
            out = out + "  ibrav = 0\n"
        } else if ln.contains("celldm") {
            // dropped — ibrav=0 + CELL_PARAMETERS (angstrom) needs no celldm
        } else {
            out = out + ln + "\n"
        }
        i = i + 1
    }
    return out
}

// _dft_strip_geom_cards — drop any ATOMIC_POSITIONS / CELL_PARAMETERS block
// (the card header + its blank / element-led coordinate rows / 3-numeric
// vector rows) from the scf tail. The split's tail must be K_POINTS-onward,
// but a deck whose ATOMIC_POSITIONS block is immediately followed by another
// (or whose split left the original positions in) yields a DUPLICATE coords
// card after injection → QE `card_atomic_positions (2)` → scf exit 1. This
// guarantees the injected CELL_PARAMETERS+ATOMIC_POSITIONS is the ONLY geom.
fn _dft_strip_geom_cards(tail: str) -> str {
    let lines = tail.split("\n")
    let n = len(lines)
    let mut out = ""
    let mut i = 0
    while i < n {
        let t = lines[i].trim()
        if t.contains("ATOMIC_POSITIONS") || t.contains("CELL_PARAMETERS") {
            // skip the card header + following blank/coord/vector rows
            i = i + 1
            let mut skipping = 1
            while i < n && skipping == 1 {
                let u = lines[i].trim()
                let toks = _dft_tokens(u)
                let mut dropline = 0
                if len(u) == 0 {
                    dropline = 1
                } else if _dft_is_coord_row(u) == 1 {
                    dropline = 1
                } else if len(toks) == 3 && _dft_is_num(toks[0]) == 1 && _dft_is_num(toks[1]) == 1 && _dft_is_num(toks[2]) == 1 {
                    dropline = 1
                }
                if dropline == 1 {
                    i = i + 1
                } else {
                    skipping = 0
                }
            }
        } else {
            out = out + lines[i] + "\n"
            i = i + 1
        }
    }
    return out
}

// dft_assemble_scf — splice the generated coords between the deck's
// scf.in.head (control namelists + ATOMIC_SPECIES) and scf.in.tail
// (K_POINTS etc.). The head is ibrav-normalized to 0 (injected geometry is
// CELL_PARAMETERS) and the tail is stripped of any leftover geometry card so
// the injected ATOMIC_POSITIONS is the ONLY one (no duplicate-card scf crash).
pub fn dft_assemble_scf(head: str, coords: str, tail: str) -> str {
    return dft_assemble_scf_cell(head, coords, tail, "")
}

// dft_assemble_scf_cell — like dft_assemble_scf, but with the SOURCE deck's
// CELL_PARAMETERS card as an ibrav=0 fallback. The relaxed `coords` normally
// carry their own `CELL_PARAMETERS (angstrom)`; but a relax.out whose final cell
// is NOT in `(alat=X)` units yields coords with NO cell card → an ibrav=0 deck
// would then have ZERO cell → pw.x `cell_base_init (1)`. When coords lack a cell
// AND `cell` (the source CELL_PARAMETERS) is present, the source card is injected
// before the positions so the cell is never silently dropped. Canonical emit
// order: namelists+ATOMIC_SPECIES (ibrav→0) · CELL_PARAMETERS · ATOMIC_POSITIONS
// · K_POINTS — every namelist FIRST, every card AFTER (the QE input contract).
pub fn dft_assemble_scf_cell(head: str, coords: str, tail: str, cell: str) -> str {
    let mut out = _dft_head_ibrav0(head)
    if len(out) > 0 {
        if !out.contains("\n") {
            out = out + "\n"
        } else {
            let last = out.substring(len(out) - 1, len(out))
            if last != "\n" {
                out = out + "\n"
            }
        }
    }
    // ibrav=0 fallback: if the relaxed coords carry no CELL_PARAMETERS, keep the
    // source deck's cell so an ibrav=0 input is never left cell-less.
    if !coords.contains("CELL_PARAMETERS") && len(cell) > 0 {
        out = out + cell
    }
    out = out + coords
    if len(tail) > 0 {
        out = out + _dft_strip_geom_cards(tail)
    }
    return out
}

// ── deck-layout adaptation — accept the deck-gen NATIVE layout ────────
//
// The deck-gen (stdlib/deck/rtsc.hexa) emits {vc-relax.in, scf.in (whole),
// ph.in} — NOT the {relax.in, scf.in.head, scf.in.tail} convention dft_run was
// born with. Rather than force decks to re-shape (blocked by the deck-guard),
// the DISPATCHER adapts: it accepts `vc-relax.in` as the relax input and
// AUTO-SPLITS a whole `scf.in` into head/tail at the ATOMIC_POSITIONS block so
// the relaxed coords slot between them (reusing dft_assemble_scf). Explicit
// scf.in.head/.tail still win when present (back-compat).

// _dft_is_coord_row — a real ATOMIC_POSITIONS coordinate row: element-led AND
// the 3 trailing tokens are numeric ("S 0.0 0.0 0.0"). This is STRICTER than
// _dft_is_pos_line (element-led only) so a following CARD keyword that also
// starts with a capital letter — `K_POINTS automatic`, `CELL_PARAMETERS …`,
// `OCCUPATIONS` — is NOT mistaken for a coordinate row and correctly begins the
// tail. (The earlier letter-only test swallowed K_POINTS into the dropped block.)
fn _dft_is_coord_row(line: str) -> int {
    let toks = _dft_tokens(line.trim())
    if len(toks) < 4 {
        return 0
    }
    if _dft_is_pos_line(toks[0]) == 0 {
        return 0
    }
    let base = len(toks) - 3
    if _dft_is_num(toks[base]) == 0 {
        return 0
    }
    if _dft_is_num(toks[base + 1]) == 0 {
        return 0
    }
    if _dft_is_num(toks[base + 2]) == 0 {
        return 0
    }
    return 1
}

// DftScfSplit — a whole scf.in PARSED into canonical QE sections. head = ALL
// namelists (&control …/ &system …/ …, in source order) + the ATOMIC_SPECIES
// card; tail = K_POINTS + any other trailing non-geometry card; cell = the
// SOURCE CELL_PARAMETERS card (kept for the ibrav=0 fallback when the relaxed
// coords lack a cell). The source ATOMIC_POSITIONS + CELL_PARAMETERS are NOT in
// head/tail — the relaxed coords replace them. ok==0 when no namelist was found.
struct DftScfSplit {
    ok:   int,
    head: str,
    tail: str,
    cell: str
}

// _dft_card_kind — if a trimmed line OPENS a QE card, return that card keyword
// (ATOMIC_SPECIES / ATOMIC_POSITIONS / CELL_PARAMETERS / K_POINTS / OCCUPATIONS
// / CONSTRAINTS / ATOMIC_VELOCITIES / ADDITIONAL_K_POINTS / SOLVENTS / HUBBARD).
// "" otherwise. The keyword must be the FIRST token (so a comment / coordinate
// row that merely mentions a card name is not mistaken for a card header).
fn _dft_card_kind(line: str) -> str {
    let toks = _dft_tokens(line.trim())
    if len(toks) == 0 {
        return ""
    }
    let w = toks[0]
    if w == "ATOMIC_SPECIES" { return "ATOMIC_SPECIES" }
    if w == "ATOMIC_POSITIONS" { return "ATOMIC_POSITIONS" }
    if w == "CELL_PARAMETERS" { return "CELL_PARAMETERS" }
    if w == "K_POINTS" { return "K_POINTS" }
    if w == "OCCUPATIONS" { return "OCCUPATIONS" }
    if w == "CONSTRAINTS" { return "CONSTRAINTS" }
    if w == "ATOMIC_VELOCITIES" { return "ATOMIC_VELOCITIES" }
    if w == "ADDITIONAL_K_POINTS" { return "ADDITIONAL_K_POINTS" }
    if w == "SOLVENTS" { return "SOLVENTS" }
    if w == "HUBBARD" { return "HUBBARD" }
    return ""
}

// dft_scf_split — PARSE a whole scf.in into its sections REGARDLESS of source
// order, then re-emit in canonical QE layout. A valid pw.x input requires every
// namelist FIRST (each closed with `/`), THEN the cards; a positional "split at
// ATOMIC_POSITIONS" mis-orders ibrav=0 decks (CELL_PARAMETERS after positions)
// and ghost decks (cards interleaved before the namelist keys). We instead walk
// the file: namelist blocks (`&NAME … /`) are concatenated in source order into
// `head`; the ATOMIC_SPECIES card is appended to `head`; CELL_PARAMETERS is kept
// aside in `cell`; ATOMIC_POSITIONS is DROPPED (relaxed coords replace it); every
// other card (K_POINTS, OCCUPATIONS, …) goes to `tail`. dft_assemble_scf then
// emits head + [cell-or-relaxed] + coords + tail = a layout-robust canonical scf.in.
pub fn dft_scf_split(whole: str) -> DftScfSplit {
    let lines = whole.split("\n")
    let n = len(lines)
    let mut namelists = ""
    let mut species = ""
    let mut cell = ""
    let mut tail = ""
    let mut saw_namelist = 0
    let mut i = 0
    while i < n {
        let raw = lines[i]
        let t = raw.trim()
        // namelist block: opens with `&NAME`, runs through its closing `/`.
        if len(t) > 0 && t.substring(0, 1) == "&" {
            saw_namelist = 1
            namelists = namelists + raw + "\n"
            i = i + 1
            while i < n {
                let nraw = lines[i]
                namelists = namelists + nraw + "\n"
                i = i + 1
                if nraw.trim() == "/" {
                    break
                }
            }
            continue
        }
        let kind = _dft_card_kind(t)
        if len(kind) > 0 {
            // gather the card header + its body (every line until the next card
            // header or namelist start or EOF).
            let mut body = raw + "\n"
            i = i + 1
            while i < n {
                let braw = lines[i]
                let bt = braw.trim()
                if len(bt) > 0 && bt.substring(0, 1) == "&" {
                    break
                }
                if len(_dft_card_kind(bt)) > 0 {
                    break
                }
                body = body + braw + "\n"
                i = i + 1
            }
            if kind == "ATOMIC_SPECIES" {
                species = species + body
            } else if kind == "CELL_PARAMETERS" {
                cell = cell + body
            } else if kind == "ATOMIC_POSITIONS" {
                // dropped — the relaxed coords supply the positions.
            } else {
                tail = tail + body
            }
            continue
        }
        // a blank / stray comment line OUTSIDE any block: keep it attached to the
        // namelist region (pre-card whitespace/comments) so head reads naturally.
        if saw_namelist == 1 && len(species) == 0 && len(cell) == 0 && len(tail) == 0 {
            namelists = namelists + raw + "\n"
        }
        i = i + 1
    }
    if saw_namelist == 0 {
        return DftScfSplit { ok: 0, head: "", tail: "", cell: "" }
    }
    return DftScfSplit { ok: 1, head: namelists + species, tail: tail, cell: cell }
}

// dft_relax_input_name — the relax input filename a deck provides: prefer the
// deck-gen native `vc-relax.in`, fall back to the legacy `relax.in`. Returns ""
// when neither is present.
pub fn dft_relax_input_name(deck: str) -> str {
    let has_vc = exec("test -f '" + deck + "/vc-relax.in' && printf yes || printf no") == "yes"
    if has_vc { return "vc-relax.in" }
    let has_relax = exec("test -f '" + deck + "/relax.in' && printf yes || printf no") == "yes"
    if has_relax { return "relax.in" }
    return ""
}

// dft_scf_head_tail — resolve a deck's scf head/tail. Explicit scf.in.head +
// scf.in.tail WIN (back-compat). Else AUTO-SPLIT a whole scf.in at its
// ATOMIC_POSITIONS block. ok==0 when neither path yields a usable head/tail.
pub fn dft_scf_head_tail(deck: str) -> DftScfSplit {
    let has_head = exec("test -f '" + deck + "/scf.in.head' && printf yes || printf no") == "yes"
    let has_tail = exec("test -f '" + deck + "/scf.in.tail' && printf yes || printf no") == "yes"
    if has_head && has_tail {
        return DftScfSplit { ok: 1,
            head: read_file(deck + "/scf.in.head"),
            tail: read_file(deck + "/scf.in.tail"),
            cell: "" }
    }
    let has_scf = exec("test -f '" + deck + "/scf.in' && printf yes || printf no") == "yes"
    if has_scf {
        return dft_scf_split(read_file(deck + "/scf.in"))
    }
    return DftScfSplit { ok: 0, head: "", tail: "", cell: "" }
}

// ── ④ stability verdict (guard) ──────────────────────────────────────

// dft_phonon_stable — scan a ph.x stdout for phonon frequencies (the
// "[cm-1]" column). Returns 0 (UNSTABLE) the moment any mode is below
// -5 cm⁻¹ (imaginary → no full-BZ wait needed), 1 (stable: all real), or
// -1 (inconclusive: no frequency lines found).
pub fn dft_phonon_stable(ph_out: str) -> int {
    let lines = ph_out.split("\n")
    let n = len(lines)
    let mut found = 0
    let mut i = 0
    while i < n {
        let ln = lines[i]
        if ln.contains("cm-1") {
            let cm = _dft_extract_cm1(ln)
            if cm > -100000.0 {
                found = 1
                if cm < -5.0 {
                    return 0
                }
            }
        }
        i = i + 1
    }
    if found == 0 {
        return -1
    }
    return 1
}

// _dft_extract_cm1 — the numeric token immediately before a "cm-1" token on
// a QE freq line ("freq ( 1) = 123.4 [THz] = -41.2 [cm-1]"). Sentinel
// -123456789.0 when no value precedes a cm-1 token.
fn _dft_extract_cm1(line: str) -> float {
    let toks = _dft_tokens(line)
    let mut i = 0
    let mut last_num = -123456789.0
    while i < len(toks) {
        let t = toks[i]
        if t.contains("cm-1") {
            return last_num
        }
        if _dft_is_num(t) == 1 {
            last_num = _dft_atof(t)
        }
        i = i + 1
    }
    return -123456789.0
}

// ── ③ physical-core count (guard) ────────────────────────────────────

// dft_physcores — Core(s) per socket × Socket(s) from `lscpu` output. This
// is the real -np cap; using nproc (which counts SMT threads) oversubscribes
// (14 phys cores, -np 26 → load 246 thrash, 25h / 0 q-points). 0 when the
// two fields are not both present.
pub fn dft_physcores(lscpu_out: str) -> int {
    let lines = lscpu_out.split("\n")
    let mut cps = 0
    let mut sockets = 0
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln.contains("Core(s) per socket") {
            cps = _dft_last_int(ln)
        }
        if ln.contains("Socket(s)") {
            sockets = _dft_last_int(ln)
        }
        i = i + 1
    }
    if cps <= 0 {
        return 0
    }
    if sockets <= 0 {
        return 0
    }
    return cps * sockets
}

// _dft_last_int — the last numeric token on a line (lscpu "K:  V" rows).
fn _dft_last_int(line: str) -> int {
    let toks = _dft_tokens(line)
    let mut i = 0
    let mut v = 0
    while i < len(toks) {
        let t = toks[i]
        if _dft_is_num(t) == 1 {
            v = _dft_atoi(t)
        }
        i = i + 1
    }
    return v
}

// ── flag scanning (self-contained — cloud_cli's helpers are private) ──

fn _dft_has_flag(av: [str], start: int, flag: str) -> int {
    let mut i = start
    while i < len(av) {
        if av[i] == flag {
            return 1
        }
        i = i + 1
    }
    return 0
}

fn _dft_flag_val(av: [str], start: int, flag: str, default_v: str) -> str {
    let mut i = start
    while i < len(av) {
        if av[i] == flag {
            if i + 1 < len(av) {
                return av[i + 1]
            }
        }
        i = i + 1
    }
    return default_v
}

// _dft_is_bool_flag — flags that take NO value (so the positional scanner must
// skip 1, not 2). `--bin-pack` is boolean (the opt-in toggle); --validate/--go/
// --force/--detach/--resume are the other booleans. Everything else
// (--query/--walltime-h/…) takes a value. Keep in lockstep with the dft_run
// flag parse.
fn _dft_is_bool_flag(t: str) -> int {
    if t == "--bin-pack" || t == "--validate" || t == "--go" || t == "--force"
        || t == "--detach" || t == "--resume" {
        return 1
    }
    return 0
}

// first positional arg after `start` that is not a flag / flag value.
fn _dft_first_positional(av: [str], start: int) -> str {
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if len(t) >= 2 && t.substring(0, 2) == "--" {
            if _dft_is_bool_flag(t) == 1 {
                i = i + 1
            } else {
                i = i + 2
            }
        } else {
            return t
        }
    }
    return ""
}

// _dft_count_positionals — how many positional (deck-dir) args were passed.
// Used to detect a MULTI-deck invocation so dft-run can refuse a silent
// bin-pack (default = 1 deck / pod, d_parallel_fire). Boolean flags skip 1,
// value flags skip 2 (mirrors _dft_first_positional).
fn _dft_count_positionals(av: [str], start: int) -> int {
    let mut i = start
    let mut n = 0
    while i < len(av) {
        let t = av[i]
        if len(t) >= 2 && t.substring(0, 2) == "--" {
            if _dft_is_bool_flag(t) == 1 {
                i = i + 1
            } else {
                i = i + 2
            }
        } else {
            n = n + 1
            i = i + 1
        }
    }
    return n
}

// ── transport (guard ②) ──────────────────────────────────────────────

// _dft_ssh_opts — bare-IP direct-connect ssh options with the vast identity
// explicitly presented (#1155: hexa cloud otherwise never offers a matching
// key → publickey denied). ConnectTimeout makes the reachability precheck a
// real TCP test, not a hang.
fn _dft_ssh_opts(port: str, identity: str) -> [str] {
    return ["-p", port,
            "-i", identity,
            "-o", "IdentitiesOnly=yes",
            "-o", "StrictHostKeyChecking=no",
            "-o", "UserKnownHostsFile=/dev/null",
            "-o", "ConnectTimeout=14",
            "-o", "ServerAliveInterval=20",
            "-o", "ServerAliveCountMax=3"]
}

// ── ③ remote chain script ────────────────────────────────────────────

// _dft_mpi_env — single-threaded BLAS (OMP/MKL/OPENBLAS=1) + root-MPI env
// for every mpirun-emitting command. OMP/MKL/OPENBLAS=1 stops each MPI rank's
// BLAS thread fan-out from over-subscribing the pod cores (055b38f8); the two
// OMPI_ALLOW_RUN_AS_ROOT vars keep prterun from dying when the pod runs as
// root and a given mpirun path doesn't honor --allow-run-as-root (f06b0a4c,
// belt-and-suspenders — the flag is still passed below).
fn _dft_mpi_env() -> str {
    return "export OMP_NUM_THREADS=1 && export MKL_NUM_THREADS=1"
        + " && export OPENBLAS_NUM_THREADS=1 && export OMPI_ALLOW_RUN_AS_ROOT=1"
        + " && export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1"
}

// _dft_provision_cmd — install Quantum ESPRESSO on a bare pod before the chain.
// The default rent image is ubuntu:22.04 (no QE), so `pw.x` is absent → relax
// dies with exit 127 (command not found). This idempotent step installs the
// Debian `quantum-espresso` package (provides /usr/bin/pw.x · ph.x, MPI-built)
// + `openmpi-bin` (mpirun), but ONLY when pw.x is not already present — so a
// QE-preinstalled `--image` short-circuits the apt install. Prints `pw.x OK`
// (caller asserts it) when both pw.x and mpirun resolve.
fn _dft_provision_cmd() -> str {
    return "command -v pw.x >/dev/null 2>&1 || { export DEBIAN_FRONTEND=noninteractive"
        + " && apt-get update -qq && apt-get install -y -qq quantum-espresso openmpi-bin"
        + " > /root/provision.log 2>&1; }; "
        + "command -v pw.x >/dev/null 2>&1 && command -v mpirun >/dev/null 2>&1"
        + " && echo 'pw.x OK' || echo 'pw.x MISSING'"
}

// _dft_pseudo_cmd — fetch the deck's pseudopotentials into ./pseudo before the
// chain. The deck inputs reference UPF files by name (ATOMIC_SPECIES) with
// `pseudo_dir = './pseudo'`, but the deck upload carries no .UPF (they're large
// + shared) → pw.x exits 1 (pseudo not found). This parses every `*.UPF` name
// from the deck's *.in files and wgets each from the QE PSL server into
// /root/deck/pseudo (idempotent — skips a UPF already present + non-empty).
// Prints `PSEUDO OK` (caller asserts) when all referenced UPFs are present.
fn _dft_pseudo_cmd() -> str {
    return "cd /root/deck && mkdir -p pseudo && "
        // NORMALIZE outdir/pseudo_dir to the pod-relative ./out · ./pseudo BEFORE
        // anything reads them. A deck authored elsewhere can carry a stale ABSOLUTE
        // path (e.g. a ghost host's /home/<user>/rtsc_<m>/out) that does NOT exist
        // on a fresh pod → pw.x dies immediately (no outdir to write, no pseudo_dir
        // to read). Anchored to line-start so QE comment lines (leading `!`) are
        // never touched. Makes every deck path-robust regardless of where it was
        // generated (RTSC ghost-pulled perovskite decks hit this, 2026-05-31).
        + "sed -i \"s|^[[:space:]]*outdir.*|  outdir = './out'|; s|^[[:space:]]*pseudo_dir.*|  pseudo_dir = './pseudo'|\" *.in 2>/dev/null; "
        + "need=$(grep -hoE '[A-Za-z0-9._+-]+[.]UPF' *.in 2>/dev/null | sort -u) && "
        + "miss=0; for upf in $need; do "
        + "[ -s \"pseudo/$upf\" ] || wget -q --tries=3 --timeout=30 -O \"pseudo/$upf\" "
        + "\"https://pseudopotentials.quantum-espresso.org/upf_files/$upf\" 2>/dev/null; "
        // DISABLE GIPAW reconstruction in every fetched UPF. PSL-1.0.0 pseudos
        // declare has_gipaw="true" and carry a GIPAW (NMR/EPR) reconstruction
        // section whose format-version the apt QE UPF-v2 reader chokes on —
        // pw.x dies on relax with `end of file reached, tag PP_GIPAW_ORBITALS
        // not found` (exit 2). el-ph / scf / relax / phonon NEVER use GIPAW, so
        // flipping the header flag makes pw.x skip the section entirely (no read,
        // no EOF crash). Confirmed: Li2MgH16 @250GPa failed 3× this way (NOT OOM
        // — the pod had 238 GB free), 2026-05-31. QE-users mail-archive recommends
        // patching the GIPAW format-version; disabling the unused flag is simpler.
        + "[ -s \"pseudo/$upf\" ] && sed -i 's/has_gipaw=\"true\"/has_gipaw=\"false\"/' \"pseudo/$upf\"; "
        + "[ -s \"pseudo/$upf\" ] || { echo \"PSEUDO_MISS $upf\"; miss=1; }; done; "
        + "[ \"$miss\" = 0 ] && echo \"PSEUDO OK\" || echo \"PSEUDO FAIL\""
}

// _dft_relax_cmd — the guarded relax invocation (setsid death-immune, walltime
// cap, phys-core -np, root MPI). Output → relax.out. `relax_name` is the deck's
// relax input filename (vc-relax.in deck-gen native, or relax.in legacy).
fn _dft_relax_cmd(np: int, walltime_h: int, relax_name: str) -> str {
    return "cd /root/deck && " + _dft_mpi_env() + " && setsid timeout " + to_string(walltime_h)
        + "h mpirun -np " + to_string(np) + " --allow-run-as-root pw.x -ndiag 1 -in " + relax_name + " > relax.out 2>&1"
}

// _dft_scf_cmd — scf on the generated geometry.
fn _dft_scf_cmd(np: int, walltime_h: int) -> str {
    return "cd /root/deck && " + _dft_mpi_env() + " && setsid timeout " + to_string(walltime_h)
        + "h mpirun -np " + to_string(np) + " --allow-run-as-root pw.x -ndiag 1 -in scf.in > scf.out 2>&1"
}

// _dft_ph_cmd — el-ph with recover=.true. (resume across the walltime cap).
fn _dft_ph_cmd(np: int, walltime_h: int) -> str {
    return "cd /root/deck && " + _dft_mpi_env() + " && setsid timeout " + to_string(walltime_h)
        + "h mpirun -np " + to_string(np) + " --allow-run-as-root ph.x -in ph.in > ph.out 2>&1"
}

// ── orchestrator ─────────────────────────────────────────────────────

// ── d16 dry-run stamp gate (rent→idle leak guard) ────────────────────
//
// A deck is UNRENTABLE until it passes a d16 free 1-iteration dry-run. The
// dry-run writes `<deck>/.validated` (timestamp + host); the `--go` rent path
// REFUSES a deck dir lacking a fresh stamp unless `--force`. This is the
// systemic guard against "rent → deck blocked/invalid → pod sits idle billing"
// — the validation is FREE (local pw.x dry-run, electron_maxstep=1, or a
// structural namelist sanity when pw.x is absent) and happens BEFORE any spend.

let DFT_STAMP_NAME = ".validated"

// _dft_stamp_path — the stamp file for a deck dir.
fn _dft_stamp_path(deck: str) -> str {
    return deck + "/" + DFT_STAMP_NAME
}

// _dft_stamp_fresh — a stamp is "fresh" if it exists AND is newer than every
// deck input (relax.in/ph.in/scf.in.head/scf.in.tail). An edit after the
// dry-run invalidates the stamp → must re-validate (a stale deck never rents
// on an old PASS). `find -newer` returns the stamp iff no input is newer.
fn _dft_stamp_fresh(deck: str) -> bool {
    let sp = _dft_stamp_path(deck)
    let exists = exec("test -f '" + sp + "' && printf yes || printf no") == "yes"
    if !exists { return false }
    // any input newer than the stamp → stale
    let newer = exec("find '" + deck + "' -maxdepth 1 -type f "
        + "\\( -name relax.in -o -name ph.in -o -name scf.in.head -o -name scf.in.tail "
        + "-o -name '*.in' \\) -newer '" + sp + "' 2>/dev/null | head -1")
    if len(newer) > 0 { return false }
    return true
}

// _dft_write_stamp — record a PASS: timestamp (UTC ISO-8601) + host + the
// validation method used. Written ONLY after a successful dry-run.
fn _dft_write_stamp(deck: str, method: str) -> bool {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    let host = exec("hostname -s 2>/dev/null || hostname")
    let body = "validated=" + ts + "\nhost=" + host + "\nmethod=" + method
        + "\ndeck=" + deck + "\n"
    return write_text(_dft_stamp_path(deck), body)
}

// _dft_dryrun — the FREE d16 1-iteration dry-run. Prefers a real QE pw.x
// 1-electron-step run on relax.in (catches directive/basis/namelist errors a
// billing pod would otherwise hit); if pw.x is absent locally, falls back to a
// structural namelist sanity (balanced &…/ blocks + required cards present).
// Returns "" on PASS, else a non-empty error string.
fn _dft_dryrun(deck: str) -> str {
    let relax_name = dft_relax_input_name(deck)
    if len(relax_name) == 0 { return "no relax input (vc-relax.in / relax.in) — empty deck" }
    let have_pw = exec("command -v pw.x >/dev/null 2>&1 && printf yes || printf no") == "yes"
    if have_pw {
        // electron_maxstep=1 · 1 SCF iter — exercises the parser + setup only.
        let cmd = "cd '" + deck + "' && rm -f .dryrun.out && "
            + "sed 's/electron_maxstep[ ]*=[ ]*[0-9]*/electron_maxstep = 1/; "
            + "s/nstep[ ]*=[ ]*[0-9]*/nstep = 1/' '" + relax_name + "' > .dryrun.in 2>/dev/null && "
            + "timeout 300 pw.x -in .dryrun.in > .dryrun.out 2>&1; "
            + "if grep -qiE 'Error in routine|%%%%%%%|stopping' .dryrun.out; then "
            + "printf 'QE_ERROR'; else printf 'OK'; fi"
        let res = exec(cmd)
        if res.contains("OK") { return "" }
        let tail = exec("tail -8 '" + deck + "/.dryrun.out' 2>/dev/null")
        return "QE dry-run reported a deck error:\n" + tail
    }
    // Fallback: structural sanity — &… / block balance + required cards.
    let relax = read_file(deck + "/" + relax_name)
    if len(relax) == 0 { return relax_name + " empty or unreadable" }
    let opens = exec("grep -cE '^[ ]*&[A-Za-z]' '" + deck + "/" + relax_name + "'")
    let closes = exec("grep -cE '^[ ]*/[ ]*$' '" + deck + "/" + relax_name + "'")
    if opens != closes {
        return "namelist block imbalance — " + opens + " '&NAME' opens vs "
            + closes + " '/' closes (a malformed deck would crash pw.x)"
    }
    if !relax.contains("ATOMIC_POSITIONS") {
        return "no ATOMIC_POSITIONS card — empty/partial deck"
    }
    if !relax.contains("K_POINTS") {
        return "no K_POINTS card — empty/partial deck"
    }
    return ""
}

// dft_validate — `hexa cloud dft-run <deck> --validate`. Runs the FREE d16
// dry-run; on PASS writes `<deck>/.validated`, on FAIL leaves no stamp and
// surfaces the error. This is the gate the `--go` rent path requires.
fn dft_validate(deck: str) -> int {
    println("[dft-run] --validate: d16 FREE 1-iteration dry-run on " + deck)
    let have_pw = exec("command -v pw.x >/dev/null 2>&1 && printf yes || printf no") == "yes"
    let method = if have_pw { "qe-pw.x-1iter" } else { "structural-sanity" }
    let err = _dft_dryrun(deck)
    if len(err) > 0 {
        println("[dft-run] ✗ dry-run FAILED — no .validated stamp written:")
        println(err)
        println("[dft-run] fix the deck, then re-run `hexa cloud dft-run " + deck + " --validate`.")
        return 1
    }
    let ok = _dft_write_stamp(deck, method)
    if !ok {
        println("[dft-run] dry-run PASSED but could not write stamp " + _dft_stamp_path(deck))
        return 1
    }
    println("[dft-run] ✓ dry-run PASSED (" + method + ") — wrote " + _dft_stamp_path(deck))
    println("[dft-run] deck is now RENTABLE: `hexa cloud dft-run " + deck + " --go`")
    return 0
}

// ── 2-phase detach state stamp (--detach / --resume, option α) ───────
//
// The forbidden background workaround was `( nohup dft-run --go & )` — a
// launchd-zombie double-fork that ran the WHOLE synchronous chain (hours) in
// a detached LOCAL process. Option α replaces it with a 2-phase contract that
// never blocks past the Bash cap and never double-forks locally:
//
//   --detach  (phase-1): rent → provision → pseudo → launch RELAX *detached on
//             the pod* (cloud_nohup → remote logfile), register the pod, write
//             a small state stamp under the deck, return 0. NO teardown — the
//             pod keeps running the relax while the local process exits.
//   --resume  (phase-2, EXPLICIT + IDEMPOTENT): reads the state stamp, copies
//             relax.out / scf.out / ph.out back, runs the LOCAL hexa-native
//             coord parser, and advances ONE terminal step — relax-done →
//             assemble+launch scf+ph detached; ph-terminal → harvest+verdict+
//             teardown. Re-invokable (a no-op when the current step is still
//             running). NOT an auto-poll loop (that would hang past the cap).
//
// The stamp is a tiny KEY=VALUE plaintext (own d4 generic format, never a
// per-deck branch). It carries the endpoint + run parameters --resume needs so
// phase-2 is self-contained from a fresh local process.

let DFT_DETACH_STATE = ".dft_detach.state"

// _dft_state_path — the detach state stamp for a deck dir.
fn _dft_state_path(deck: str) -> str {
    return deck + "/" + DFT_DETACH_STATE
}

// _dft_write_state — persist the phase / endpoint / run params so --resume can
// reconstruct the pod context from a fresh local process. KEY=VALUE plaintext.
fn _dft_write_state(deck: str, phase: str, iid: str, host: str, port: str,
                    identity: str, np: int, walltime_h: int, relax_name: str) -> bool {
    let body = "phase=" + phase + "\ninstance_id=" + iid + "\nhost=" + host
        + "\nport=" + port + "\nidentity=" + identity + "\nnp=" + to_string(np)
        + "\nwalltime_h=" + to_string(walltime_h) + "\nrelax_name=" + relax_name
        + "\ndeck=" + deck + "\n"
    return write_text(_dft_state_path(deck), body)
}

// _dft_endpoint_resolved — PURE: 1 iff BOTH host and port are non-empty (the
// state-stamp endpoint actually mapped). The `--resume` cost-incident
// (#38751850) read a stamp whose endpoint was EMPTY (`@ :`), could not reach
// the pod, and tore it down on a misread. A `--resume` MUST NOT proceed to any
// teardown decision unless this is 1 — an unresolved endpoint is a transport/
// transient condition, never a science failure.
fn _dft_endpoint_resolved(host: str, port: str) -> int {
    if len(host) == 0 {
        return 0
    }
    if len(port) == 0 {
        return 0
    }
    return 1
}

// --detach idempotency action codes (the pre-rent guard verdict). `--detach`
// USED to ALWAYS rent a fresh pod — re-firing a deck that already had a live
// detached pod left the old one idle + billing (the ~12 dup-idle-pod leak,
// 2026-06-01). The guard mirrors `--resume`'s reachability discipline so a
// re-fire of an ALREADY-LIVE deck is an idempotent no-op (advance with
// `--resume`), and only a genuinely-dead pod licenses a fresh rent.
let DFT_DETACH_RENT = 0       // no live pod recorded → rent fresh (today's path)
let DFT_DETACH_SKIP = 1       // a live pod is reachable → SKIP rent (idempotent no-op)
let DFT_DETACH_REPLACE = 2    // a recorded pod is unreachable/stale → teardown then rent

// _dft_detach_guard_action — PURE: decide whether `--detach` should rent. Inputs
// model the impure probe so this is network-free + unit-testable (mirrors the
// resolve/endpoint tests). `force`=1 ALWAYS rents (expert re-fire, old behavior).
// `has_state`=1 iff the deck's `.dft_detach.state` records a pod (instance_id +
// resolved host/port). `reachable`=1 iff a lightweight liveness probe reached it.
//   - force                       → RENT     (bypass the guard entirely)
//   - no recorded pod             → RENT     (first detach for this deck)
//   - recorded pod + reachable    → SKIP     (live — re-fire is a no-op; use --resume)
//   - recorded pod + unreachable  → REPLACE  (stale billing pod — teardown then rent)
fn _dft_detach_guard_action(force: int, has_state: int, reachable: int) -> int {
    if force == 1 {
        return DFT_DETACH_RENT
    }
    if has_state == 0 {
        return DFT_DETACH_RENT
    }
    if reachable == 1 {
        return DFT_DETACH_SKIP
    }
    return DFT_DETACH_REPLACE
}

// _dft_remote_read_ok — 1 iff a CloudResult represents a remote command that
// actually reached the pod (ok==1). A transport failure surfaces as ok==0 with
// exit_code 255 (ssh transport) or -1 (no exit-code marker / dead shell);
// either way the result carries NO information about the science, so a
// `--resume` must treat it as transient (abort, no teardown) rather than a
// confirmed stage failure. Only ok==1 (remote exit 0) licenses reading stdout
// for __DFT_FAILED__ / coordinate-absence and, if confirmed, tearing down.
fn _dft_remote_read_ok(r: CloudResult) -> int {
    if r.ok == 1 {
        return 1
    }
    return 0
}

// _dft_state_field — read one KEY=VALUE field from the detach state stamp.
// Returns "" when the stamp or the key is absent (caller decides the fallback).
fn _dft_state_field(deck: str, key: str) -> str {
    let sp = _dft_state_path(deck)
    let exists = exec("test -f '" + sp + "' && printf yes || printf no") == "yes"
    if !exists { return "" }
    let raw = read_file(sp)
    let lines = raw.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        let pre = key + "="
        if len(ln) >= len(pre) && ln.substring(0, len(pre)) == pre {
            return ln.substring(len(pre), len(ln)).trim()
        }
        i = i + 1
    }
    return ""
}

// dft_run — `hexa cloud dft-run <deck-dir> [--validate] [--go] [--force] [...]`.
// PREVIEW unless --go. --validate runs the FREE dry-run + writes the stamp.
pub fn dft_run(av: [str], start: int) -> int {
    let deck = _dft_first_positional(av, start)
    if len(deck) == 0 {
        println("[dft-run] usage: hexa cloud dft-run <deck-dir> [--validate] [--go|--detach|--resume] [--force] [--bin-pack] [--identity PATH] [--query Q] [--walltime-h N] [--image IMG] [--disk GiB] [--owner TAG]")
        println("           <deck-dir> must contain: (vc-relax.in | relax.in) · ph.in · (scf.in | scf.in.head + scf.in.tail) · pseudo/")
        println("           default = PREVIEW (validate + plan + parse a local relax.out if present, $0).")
        println("           --validate : run the FREE d16 1-iter dry-run + write a `.validated` stamp (required before --go/--detach).")
        println("           --go       : rent + run the WHOLE chain SYNCHRONOUSLY in this process (hours — blocks past the 10-min cap).")
        println("           --detach   : phase-1 — rent + provision + launch relax DETACHED on the pod, then return 0 (NO teardown).")
        println("           --resume   : phase-2 — advance ONE terminal step (relax→scf+ph detached; ph-terminal→harvest+verdict+teardown). Idempotent.")
        println("                        paced campaign: `--detach` each candidate, then poll `--resume` per candidate — no `( nohup --go & )` double-fork.")
        println("           --force    : override the stamp gate (expert — rents an unvalidated deck).")
        println("           --bin-pack : DEFAULT = ONE deck / pod (d_parallel_fire). dft-run dispatches a SINGLE deck per pod;")
        println("                        passing >1 deck dir without --bin-pack is REFUSED (silent pod overload guard, ysbh6/cabeh8 2026-05-30).")
        println("                        For genuine multi-deck-on-one-pod packing, generate the deck with spec pack_one_pod=true (fill_plan concurrent-fill).")
        return 2
    }
    let validate_only = _dft_has_flag(av, start, "--validate")
    let go = _dft_has_flag(av, start, "--go")
    let detach = _dft_has_flag(av, start, "--detach")
    let resume_flag = _dft_has_flag(av, start, "--resume")
    let force = _dft_has_flag(av, start, "--force")
    let bin_pack = _dft_has_flag(av, start, "--bin-pack")

    // DEFAULT = ONE deck / pod (project.tape d_parallel_fire). dft-run dispatches
    // a SINGLE deck per pod (the relax→scf→el-ph chain below is single-deck). If
    // the caller passed MORE than one positional deck dir, that is a multi-deck
    // intent — refuse to silently bin-pack them onto one pod (the 2026-05-30
    // ysbh6 q2-NaN · cabeh8 _ph0-disk-exhaustion failure class). Multi-deck-on-
    // one-pod packing is an EXPLICIT opt-in via the deck generator spec
    // pack_one_pod=true (fill_plan concurrent-fill), NOT a dft-run default.
    let n_positional = _dft_count_positionals(av, start)
    if n_positional > 1 {
        if bin_pack == 0 {
            println("[dft-run] ✗ REFUSED — " + to_string(n_positional) + " deck dirs passed without --bin-pack.")
            println("[dft-run]   default = ONE deck / pod (d_parallel_fire). dft-run runs a SINGLE deck per pod;")
            println("[dft-run]   it does NOT silently pack multiple decks onto one pod (ysbh6 q2 NaN · cabeh8 _ph0 disk exhaustion, 2026-05-30).")
            println("[dft-run]   → fire each deck on its OWN pod (one `dft-run <deck> --go` per deck, parallel — d17 vast.ai first), OR")
            println("[dft-run]   → for genuine one-pod-multi-deck packing, generate the deck with spec pack_one_pod=true (fill_plan concurrent-fill).")
            return 2
        }
        // --bin-pack present AND multi-deck → WARN before firing (Part 3).
        println("⚠ bin-pack: " + to_string(n_positional)
            + " decks on 1 pod — each el-ph q-point needs 5-18GB _ph0 scratch; "
            + "ensure free_disk ≥ concurrent_q × 18GB or runs crash "
            + "(davcio \"No space left\") + thrash. Prefer 1 deck/pod (d_parallel_fire). "
            + "Proceeding because --bin-pack was set.")
    }
    let identity = _dft_flag_val(av, start, "--identity", env_var("HOME") + "/.ssh/id_vast_anima")
    let extra_q = _dft_flag_val(av, start, "--query", "")
    let walltime_h = _dft_atoi(_dft_flag_val(av, start, "--walltime-h", "12"))
    let image = _dft_flag_val(av, start, "--image", "ubuntu:22.04")
    let disk = _dft_atoi(_dft_flag_val(av, start, "--disk", "60"))
    let owner = _dft_flag_val(av, start, "--owner", "(hexa-cloud dft-run)")

    // deck validation — accept BOTH layouts (d4 single generic path):
    //   • relax  : vc-relax.in (deck-gen native) OR relax.in (legacy)
    //   • scf    : a WHOLE scf.in (auto-split at ATOMIC_POSITIONS) OR explicit
    //              scf.in.head + scf.in.tail (legacy)
    let relax_name = dft_relax_input_name(deck)
    let has_relax = len(relax_name) > 0
    let has_ph = exec("test -f '" + deck + "/ph.in' && printf yes || printf no") == "yes"
    let scf = dft_scf_head_tail(deck)
    let has_scf = scf.ok == 1
    let m_relax = if has_relax { "found (" + relax_name + ")" } else { "MISSING (vc-relax.in / relax.in required)" }
    let m_ph = if has_ph { "found" } else { "MISSING (required)" }
    let m_scf = if has_scf {
        if exec("test -f '" + deck + "/scf.in.head' && printf yes || printf no") == "yes" {
            "found (scf.in.head + scf.in.tail)"
        } else {
            "found (whole scf.in — auto-split at ATOMIC_POSITIONS)"
        }
    } else {
        "MISSING (scf.in whole, or scf.in.head + scf.in.tail, required)"
    }
    println("[dft-run] deck: " + deck)
    println("  relax        : " + m_relax)
    println("  ph.in        : " + m_ph)
    println("  scf          : " + m_scf)
    if !has_relax || !has_ph || !has_scf {
        println("[dft-run] deck incomplete — see DECK CONVENTION in dft_dispatch.hexa. Aborting.")
        return 2
    }

    // --validate — run the FREE d16 dry-run + write the `.validated` stamp.
    if validate_only == 1 {
        return dft_validate(deck)
    }

    // ① rent query preview
    let query = dft_rent_query(extra_q)
    println("[dft-run] ① rent guard: offers `verified=true rentable=true " + query + "` + create --direct")

    // ③ parse a local relax.out, if any, so the user can eyeball coords pre-spend
    let has_relax_out = exec("test -f '" + deck + "/relax.out' && printf yes || printf no") == "yes"
    if has_relax_out {
        let coords = dft_relax_to_scf_coords(read_file(deck + "/relax.out"))
        if len(coords) == 0 {
            println("[dft-run] ③ relax.out present but NO 'Begin final coordinates' parsed — relax unconverged / truncated (hand-parse FORBIDDEN).")
        } else {
            println("[dft-run] ③ parsed scf geometry from local relax.out →")
            println(coords)
        }
    } else {
        println("[dft-run] ③ no local relax.out (the relax stage produces it on the pod).")
    }

    // The d16 fire-gate decision, computed up-front so both the PREVIEW report
    // and the --go precondition share ONE source of truth. blocked == TRUE iff a
    // --go MUST refuse to rent: no fresh `.validated` stamp AND no --force.
    let fresh = _dft_stamp_fresh(deck)
    let blocked = !fresh && force == 0

    // --resume (phase-2) operates on an ALREADY-rented pod recorded in the
    // detach state stamp — it does NOT rent, so the d16 .validated gate (a
    // pre-rent guard) does not apply. Dispatch it before the rent-only gates.
    if resume_flag == 1 {
        return _dft_resume(deck)
    }

    if go == 0 && detach == 0 {
        let stamped = if fresh { "fresh ✓ — RENTABLE" } else { "MISSING/stale — run --validate first (NOT rentable)" }
        println("[dft-run] ② transport: bare-IP via `show instances --raw`, identity " + identity)
        println("[dft-run] ③ chain: -np = phys cores (lscpu Core×Socket) · --allow-run-as-root · recover=.true. · timeout " + to_string(walltime_h) + "h · setsid")
        println("[dft-run] ④ monitor: numeric-id registry · imaginary-mode<-5cm⁻¹ → unstable · non-interactive teardown")
        println("[dft-run] .validated stamp: " + stamped)
        println("[dft-run] PREVIEW — --go runs the chain SYNCHRONOUSLY (hours, blocks); --detach launches relax")
        println("[dft-run]   detached on the pod + returns 0, then `--resume` advances each terminal step ($-incurring).")
        return 0
    }

    // FIRE PRECONDITION (d16 gate) — refuse to rent for a deck that has not
    // passed a fresh FREE dry-run. This is the systemic rent→idle leak guard:
    // a blocked/invalid deck never reaches a billing pod. --force overrides.
    // Applies to BOTH the synchronous --go path and the --detach launch (both rent).
    if blocked {
        println("[dft-run] ✗ REFUSED — no fresh `.validated` stamp for " + deck)
        println("[dft-run]   a deck must pass a FREE d16 dry-run before it can rent a billing pod")
        println("[dft-run]   (systemic guard vs rent→deck-blocked→pod-idle billing leak).")
        println("[dft-run]   run:  hexa cloud dft-run " + deck + " --validate")
        println("[dft-run]   then: hexa cloud dft-run " + deck + " --go      (synchronous, blocks hours), OR")
        println("[dft-run]         hexa cloud dft-run " + deck + " --detach  (launch relax detached, return 0)")
        println("[dft-run]   (expert override: add --force to rent an unvalidated deck.)")
        return 2
    }
    if !fresh && force == 1 {
        println("[dft-run] ⚠ --force: renting an UNVALIDATED deck (no fresh .validated stamp) — leak risk on the user.")
    }

    // --detach (phase-1) — rent + provision + launch relax DETACHED on the pod,
    // register, write the state stamp, return 0 (NO teardown). Phase-2 advance
    // is the explicit `--detach`→`--resume` handoff (option α; replaces the
    // forbidden `( nohup dft-run --go & )` local double-fork).
    if detach == 1 {
        return _dft_detach(deck, image, disk, owner, query, identity, walltime_h, relax_name, force)
    }

    return _dft_go(deck, image, disk, owner, query, identity, walltime_h, relax_name)
}

// _dft_go — the $-incurring path. Rents → resolves the direct endpoint →
// reachability precheck → uploads the deck → runs relax → harvests +
// hexa-parses the geometry → assembles + runs scf → runs el-ph → renders the
// stability verdict → tears the pod down. Each remote stage is a single
// guarded cloud_exec (timeout-capped), so an outage surfaces as a stage error
// rather than a silent hang.
fn _dft_go(deck: str, image: str, disk: int, owner: str, query: str, identity: str, walltime_h: int, relax_name: str) -> int {
    println("[dft-run] ① RENT — searching verified offers (CPU-first → GPU fallback)...")
    let offer = _dft_rent_first_offer(query)
    if offer.ok == 0 {
        println("[dft-run] rent: " + offer.message)
        return 1
    }
    println("[dft-run] picked offer " + offer.offer_id)
    let inst = vast_create(offer.offer_id, image, disk)
    if inst.ok == 0 {
        vast_offer_release(offer.offer_id)
        println("[dft-run] create: " + inst.message)
        return 1
    }
    // ④ registry — numeric instance-id ONLY (no argv fragments, #1229).
    pod_registry_record(inst.instance_id, owner, "running")
    vast_offer_release(offer.offer_id)
    println("[dft-run] created + registered instance " + inst.instance_id)

    // ② wait for boot, then resolve the DIRECT bare-IP endpoint.
    let _w = vast_wait_ssh(inst.instance_id, 30, 20)
    let ep = vast_direct_endpoint(inst.instance_id)
    if ep.ok == 0 {
        println("[dft-run] ② transport: " + ep.message)
        println("[dft-run] instance " + inst.instance_id + " kept + tracked (cloud list); not auto-destroyed.")
        return 1
    }
    let host = "root@" + ep.host
    let ssh_opts = _dft_ssh_opts(ep.port, identity)
    println("[dft-run] ② direct endpoint " + ep.host + ":" + ep.port + " (identity " + identity + ")")

    // ① reachability precheck — TCP echo. unreachable → destroy + abort.
    let reach = cloud_exec_opts(host, ssh_opts, "echo REACHABLE")
    if reach.ok == 0 || !reach.stdout_.contains("REACHABLE") {
        println("[dft-run] ① reachability FAILED (" + reach.message + ") — destroying unreachable pod " + inst.instance_id)
        let _d = vast_destroy(inst.instance_id)
        pod_registry_forget(inst.instance_id)
        println("[dft-run] re-run `hexa cloud dft-run <deck> --go` to try another offer.")
        return 1
    }
    println("[dft-run] ① reachability OK")

    // upload the deck
    let up = cloud_copy_to_recursive_opts(host, ssh_opts, deck, "/root/deck")
    if up.ok == 0 {
        println("[dft-run] upload: " + up.message)
        return _dft_teardown(inst.instance_id, 1)
    }

    // ③ phys-core -np
    let lscpu = cloud_exec_opts(host, ssh_opts, "lscpu")
    let np_raw = dft_physcores(lscpu.stdout_)
    let np = if np_raw > 0 { np_raw } else { 8 }
    println("[dft-run] ③ -np=" + to_string(np) + " (phys cores)")

    // ③ provision — install QE on the bare pod (idempotent; skipped if pw.x
    // already present from a QE `--image`). Without this a bare ubuntu:22.04
    // pod has no pw.x → relax dies exit 127.
    println("[dft-run] ③ provision QE (apt quantum-espresso if pw.x absent)...")
    let prov = cloud_exec_opts(host, ssh_opts, _dft_provision_cmd())
    if prov.ok == 0 || !prov.stdout_.contains("pw.x OK") {
        println("[dft-run] provision: QE install/verify FAILED — " + prov.message)
        println("[dft-run]   (see /root/provision.log on the pod; or pass --image with QE preinstalled)")
        return _dft_teardown(inst.instance_id, 1)
    }
    println("[dft-run] ③ provision OK — pw.x + mpirun present")

    // ③ pseudo fetch — download referenced UPFs into ./pseudo (deck carries
    // none). Without this pw.x exits 1 (pseudopotential not found).
    println("[dft-run] ③ pseudo fetch (UPF → ./pseudo from QE PSL server)...")
    let ps = cloud_exec_opts(host, ssh_opts, _dft_pseudo_cmd())
    if ps.ok == 0 || !ps.stdout_.contains("PSEUDO OK") {
        println("[dft-run] pseudo: fetch FAILED — " + ps.message + " · " + ps.stdout_)
        return _dft_teardown(inst.instance_id, 1)
    }
    println("[dft-run] ③ pseudo OK — UPFs in ./pseudo")

    // ③ relax — run on the deck's relax input (vc-relax.in native / relax.in legacy)
    println("[dft-run] ③ relax (" + relax_name + ", timeout " + to_string(walltime_h) + "h)...")
    let relax = cloud_exec_opts(host, ssh_opts, _dft_relax_cmd(np, walltime_h, relax_name))
    if relax.ok == 0 {
        println("[dft-run] relax stage: " + relax.message)
        // diagnostics-before-teardown: pull relax.out + print its tail so a
        // pw.x input/runtime error is visible (the pod is about to be destroyed).
        let _hf = cloud_copy_from_opts(host, ssh_opts, "/root/deck/relax.out", deck + "/relax.out")
        let rt = cloud_exec_opts(host, ssh_opts, "tail -40 /root/deck/relax.out 2>/dev/null")
        println("[dft-run] ── relax.out tail ──\n" + rt.stdout_ + "\n[dft-run] ── end ──")
        return _dft_teardown(inst.instance_id, 1)
    }
    // harvest relax.out + hexa-native coordinate parse (NO hand-parser)
    let _hr = cloud_copy_from_opts(host, ssh_opts, "/root/deck/relax.out", deck + "/relax.out")
    let coords = dft_relax_to_scf_coords(read_file(deck + "/relax.out"))
    if len(coords) == 0 {
        println("[dft-run] ③ FATAL: relax produced no 'Begin final coordinates' — not dispatching scf on stale geometry.")
        return _dft_teardown(inst.instance_id, 1)
    }
    // assemble scf.in = head + parsed coords + tail. The head/tail come from
    // explicit scf.in.head/.tail OR an auto-split of a whole scf.in — resolved
    // BEFORE we write, so a whole-scf.in deck's source template is not clobbered
    // (the assembled deck is written to scf.in.gen; the pod's scf.in is the gen).
    let split = dft_scf_head_tail(deck)
    if split.ok == 0 {
        println("[dft-run] ③ FATAL: could not resolve scf head/tail (no scf.in[.head/.tail]).")
        return _dft_teardown(inst.instance_id, 1)
    }
    let scf_in = dft_assemble_scf_cell(split.head, coords, split.tail, split.cell)
    write_file(deck + "/scf.in.gen", scf_in)
    let _us = cloud_copy_to_opts(host, ssh_opts, deck + "/scf.in.gen", "/root/deck/scf.in")

    // ③ scf
    println("[dft-run] ③ scf...")
    let scf = cloud_exec_opts(host, ssh_opts, _dft_scf_cmd(np, walltime_h))
    if scf.ok == 0 {
        println("[dft-run] scf stage: " + scf.message)
        return _dft_teardown(inst.instance_id, 1)
    }

    // ③ el-ph
    println("[dft-run] ③ el-ph (ph.x, recover=.true.)...")
    let ph = cloud_exec_opts(host, ssh_opts, _dft_ph_cmd(np, walltime_h))
    let _hp = cloud_copy_from_opts(host, ssh_opts, "/root/deck/ph.out", deck + "/ph.out")

    // ④ stability verdict
    let verdict = dft_phonon_stable(read_file(deck + "/ph.out"))
    if verdict == 0 {
        println("[dft-run] ④ VERDICT: UNSTABLE (imaginary mode < -5 cm⁻¹) — closed-negative.")
    } else {
        if verdict == 1 {
            println("[dft-run] ④ VERDICT: dynamically stable (all real modes in computed q-set) — harvest λ/ω_log/Tc.")
        } else {
            println("[dft-run] ④ VERDICT: inconclusive (no frequencies parsed) — inspect ph.out.")
        }
    }
    println("[dft-run] results harvested to " + deck + "/{relax.out,scf.out,ph.out}.")
    return _dft_teardown(inst.instance_id, 0)
}

// ── option α phase-1: --detach launch ────────────────────────────────

// _dft_remote_logfile — the pod-side logfile a detached stage writes to. One
// file per stage so a --resume tail can attach to the live one.
fn _dft_remote_logfile(stage: str) -> str {
    return "/root/deck/." + stage + ".detach.log"
}

// _dft_detach_argv — wrap a guarded stage shell-string (the reused _dft_*_cmd,
// which already does `cd /root/deck && … > <out> 2>&1`) into a `sh -lc` argv so
// cloud_nohup_opts launches it DETACHED on the pod. A login shell (-l) restores
// PATH/conda the non-interactive nohup shell would otherwise lose (the detached
// remote env-loss class). cloud_nohup adds its own `> logfile 2>&1` wrapper.
fn _dft_detach_argv(stage_cmd: str) -> [str] {
    return ["sh", "-lc", stage_cmd]
}

// _dft_scfph_cmd — the scf→el-ph CHAIN as one detached shell-string. scf must
// finish before ph starts, so the two reused guarded commands are joined with
// `&&` (ph runs only on a clean scf). The relaxed geometry was already spliced
// into /root/deck/scf.in by --resume (LOCAL parse + upload) before this launch.
//
// PATH-NORMALIZE the uploaded scf.in first: it carries the SOURCE deck's &control
// namelist verbatim (via the split), so a ghost-pulled deck's stale ABSOLUTE
// outdir/pseudo_dir (e.g. /home/aiden/rtsc_sch9/out — does NOT exist on the pod)
// would crash pw.x. The pre-relax `_dft_pseudo_cmd` sed ran BEFORE this fresh
// scf.in existed on the pod, so we re-apply the SAME anchored normalize here so
// the regenerated scf.in is pod-relative (./out · ./pseudo) before scf reads it.
//
// ph.in carries the SAME ghost-pulled stale-absolute disease, but in the &inputph
// namelist: `outdir = '/home/aiden/rtsc_<slug>/out'` (ph must read scf's outdir)
// AND `fildyn = '/home/aiden/rtsc_<slug>/<slug>.dyn'` — an aiden-host path absent
// on the pod. ph.x then dies in q_points: `cannot open file .../<slug>.dyn0`. The
// scf-only sed above never touched ph.in, so we mirror it: outdir → './out' (so ph
// reads scf's checkpoint), and fildyn/fildvscf → a BARE basename (strip any leading
// dir, abs or rel). ph.x runs with cwd /root/deck (_dft_ph_cmd cd's there), so a
// bare `<slug>.dyn` lands `<slug>.dyn0` in /root/deck — findable by q_points.
fn _dft_scfph_cmd(np: int, walltime_h: int) -> str {
    let norm = "cd /root/deck && sed -i \"s|^[[:space:]]*outdir.*|  outdir = './out'|; "
        + "s|^[[:space:]]*pseudo_dir.*|  pseudo_dir = './pseudo'|\" scf.in 2>/dev/null"
        + " && sed -i \"s|^[[:space:]]*outdir.*|  outdir = './out'|; "
        + "s|^\\([[:space:]]*fildyn[[:space:]]*=[[:space:]]*'\\).*/\\([^/']*'\\)|\\1\\2|; "
        + "s|^\\([[:space:]]*fildvscf[[:space:]]*=[[:space:]]*'\\).*/\\([^/']*'\\)|\\1\\2|\" "
        + "ph.in 2>/dev/null"
    return norm + " && " + _dft_scf_cmd(np, walltime_h) + " && " + _dft_ph_cmd(np, walltime_h)
}

// _dft_stage_probe_cmd — a remote one-liner that classifies a detached stage
// HONESTLY (the QE "JOB DONE" checkpoint trap: a bare JOB DONE grep is NOT
// terminal — ph.out prints it per invocation, and a walltime-killed run prints
// it too before STOP 1). `procname` is the running binary (pw.x / ph.x), `out`
// the stage stdout file. Emits exactly one of:
//   __DFT_RUNNING__  — the binary is still alive (pgrep hit) → resume is a no-op
//   __DFT_FAILED__   — process gone AND a crash/timeout signature in `out`
//                      (Error in routine / STOP [1-9] / Maximum CPU time / no JOB DONE)
//   __DFT_DONE__     — process gone AND a clean JOB DONE with no failure line
// The failure set is checked BEFORE the JOB DONE set (failure-first), mirroring
// cloud_tail_cmd_taxonomy's ordering, so a timed-out run never reads as DONE.
fn _dft_stage_probe_cmd(procname: str, out: str) -> str {
    return "if pgrep -x " + procname + " >/dev/null 2>&1; then echo __DFT_RUNNING__; "
        + "elif [ ! -s /root/deck/" + out + " ]; then echo __DFT_FAILED__; "
        + "elif grep -qE 'Error in routine|STOP [1-9]|Maximum CPU time exceeded|max_seconds' /root/deck/" + out + "; then echo __DFT_FAILED__; "
        + "elif grep -q 'JOB DONE' /root/deck/" + out + "; then echo __DFT_DONE__; "
        + "else echo __DFT_FAILED__; fi"
}

// _dft_failure_is_walltime — PURE sub-classifier for a `__DFT_FAILED__` stage:
// is the failure a NORMAL walltime cap (recover-relaunchable) or a GENUINE crash
// (teardown/defer)? `out_text` is the harvested stage stdout (ph.out / relax.out).
//
// The pod-side self-resume daemon (`_dft_self_resume_wrap`) ALREADY encodes this
// distinction implicitly: its loop predicate is "until __DFT_DONE__", so any
// non-DONE — including a `Maximum CPU time exceeded` walltime kill — triggers a
// recover-relaunch, NOT a teardown. The CONTROLLER `--resume` branch never got
// that treatment and tore the pod down on ANY `__DFT_FAILED__`, DESTROYING a
// healthy-but-walltime-killed phonon pod plus its accumulated q-point progress.
// This makes the SAME walltime-vs-crash split explicit and TESTABLE so the
// controller can match the daemon (d19 reuse — same signature set, no new oracle).
//
// Returns 1 iff a walltime-cap signature is present (QE `Maximum CPU time
// exceeded` / the `max_seconds` namelist clamp). Returns 0 for a genuine crash
// (Error in routine / STOP [1-9] / segfault / OOM) or an empty/absent stdout.
// The walltime set is the SAME pair the probe's failure grep checks; the crash
// set is everything else that probe folds into `__DFT_FAILED__`.
fn _dft_failure_is_walltime(out_text: str) -> int {
    if out_text.contains("Maximum CPU time exceeded") {
        return 1
    }
    if out_text.contains("max_seconds") {
        return 1
    }
    return 0
}

// _dft_self_resume_wrap — wrap a guarded LONG-RUNNING compute stage in a POD-SIDE
// self-restart loop so a per-pod walltime kill is followed by an AUTOMATIC
// recover-relaunch on the SAME pod — no controller `--resume` round-trip.
//
// The QE el-ph (ph.x) checkpoints via `recover=.true.` (ph.in deck-gen, rtsc.hexa)
// and must be RE-LAUNCHED to walk past the ~12h walltime cap. Before this, a
// single `_dft_scfph_cmd` nohup'd by `--detach`/`--resume` sat IDLE after the
// first walltime kill until the controller re-issued `--resume`; a session-restart
// dropped that heartbeat → 13/20 jobs stalled, billing with zero progress.
//
// COMPLETION PREDICATE — reuses the EXISTING honest terminal probe
// (`_dft_stage_probe_cmd`, the QE JOB DONE checkpoint-trap guard): the stage is
// terminal iff the probe emits `__DFT_DONE__` (process gone AND a clean JOB DONE
// AND no crash/timeout signature). A walltime kill reads as `__DFT_FAILED__`
// (Maximum CPU time / max_seconds) — which is PRECISELY the recover case — so the
// loop condition is "until DONE", NOT "until not-FAILED", and each iteration
// re-runs the guarded stage (with recover) to advance the next q-points.
//
// LOOP BOUND — capped at `max_cycles` walltime windows (a corrupt-recover or a
// genuine non-walltime crash would otherwise spin), logging each cycle so a tail
// shows progress. The stage_cmd is the reused guarded builder (mpirun/env/recover
// untouched) — this only WRAPS it; we never duplicate the compute invocation.
fn _dft_self_resume_wrap(stage_cmd: str, procname: str, out: str, max_cycles: int) -> str {
    let probe = _dft_stage_probe_cmd(procname, out)
    return "n=0; while [ \"$(" + probe + ")\" != __DFT_DONE__ ] && [ $n -lt "
        + to_string(max_cycles) + " ]; do n=$((n+1)); "
        + "echo \"[dft-self-resume] cycle $n/" + to_string(max_cycles)
        + " (recover relaunch) $(date -u +%FT%TZ)\"; "
        + stage_cmd + "; sleep 5; done; "
        + "echo \"[dft-self-resume] loop exit after $n cycle(s) — probe=$(" + probe + ")\""
}

// ── d11 pre-rent OOM gate (Fix-deck-1) ───────────────────────────────
//
// The whole RTSC wave3b --detach batch SIGKILL'd at SCF iter#2 (~71s, uniform) —
// an OOM signature: a superhydride relax under-provisioned RAM on a pod whose
// only RAM-relevant offer floor was implicit. d11 (size the job before paid GPU
// rent) requires a HARD mem-budget gate BEFORE the billing rent: refuse-or-
// down-size when atoms·basis·np won't fit the offer RAM, rather than renting and
// OOM-killing. The budget math is NOT reimplemented here — it is delegated whole
// to tls_dft_mpi_sweet_spot (stdlib/cloud/preflight_dft); this code only parses a
// DftSpec out of the deck and reads the verdict.

// RAM floor (GiB) the gate sizes the relax against AND then pins into the rent
// query (cpu_ram>=N) so the rented offer is GUARANTEED to satisfy the closed-form
// fit — without it the fit would be against a hypothetical the offer query never
// enforced (the wave3b leak). 64 GiB is a sane mid-tier vast CPU-node floor.
let DFT_DETACH_RAM_FLOOR = 64

// _dft_field_int — the integer value of a QE namelist `key = value` field in
// `text` (first match). e.g. `nat = 10` → 10, `ecutwfc = 80` → 80. 0 if absent.
fn _dft_field_int(text: str, key: str) -> int {
    let lines = text.split("\n")
    let mut i = 0
    while i < len(lines) {
        let t = lines[i].trim()
        if t.contains(key) && t.contains("=") {
            // value = the last numeric token on the line (after `key = …`).
            return _dft_last_int(t)
        }
        i = i + 1
    }
    return 0
}

// _dft_deck_spec — parse the deck's relax input into a DftSpec for the OOM gate.
// Atoms come from the ATOMIC_POSITIONS coordinate-row count (authoritative; falls
// back to the `nat =` field). n_basis_pw is the standard plane-wave count estimate
// ≈ (1/6π²)·(2·Ecut)^{3/2}·V_cell with V_cell ≈ n_atoms × 60 bohr³ (superhydride
// per-atom volume) — this is an INPUT estimate, not budget math. method_id=0 (SCF;
// the relax's per-step cost is SCF-dominated). All integer arithmetic (g-idiom).
fn _dft_deck_spec(deck: str) -> DftSpec {
    let relax_name = dft_relax_input_name(deck)
    let mut text = ""
    if len(relax_name) > 0 {
        text = read_file(deck + "/" + relax_name)
    }
    // atoms — count real ATOMIC_POSITIONS coordinate rows; fall back to `nat =`.
    let lines = text.split("\n")
    let mut n_atoms = 0
    let mut in_pos = 0
    let mut i = 0
    while i < len(lines) {
        let raw = lines[i]
        if raw.contains("ATOMIC_POSITIONS") {
            in_pos = 1
        } else if in_pos == 1 {
            if _dft_is_coord_row(raw) == 1 {
                n_atoms = n_atoms + 1
            } else if len(raw.trim()) > 0 {
                in_pos = 0
            }
        }
        i = i + 1
    }
    if n_atoms <= 0 { n_atoms = _dft_field_int(text, "nat") }
    if n_atoms <= 0 { n_atoms = 1 }
    // ecutwfc (Ry) — drives the plane-wave count; default 80 (deck-gen RTSC).
    let mut ecut = _dft_field_int(text, "ecutwfc")
    if ecut <= 0 { ecut = 80 }
    // 2·Ecut → integer (2·Ecut)^{3/2} via isqrt of the cube (closed-form input).
    let two_ec = 2 * ecut
    let cube = two_ec * two_ec * two_ec
    let pw_factor = _dft_isqrt(cube)            // ≈ (2·Ecut)^{3/2}
    let v_cell = n_atoms * 60                    // bohr³ — superhydride per-atom vol
    // n_basis ≈ pw_factor · V / (6π² ≈ 59); minimum 1.
    let mut n_basis = pw_factor * v_cell / 59
    if n_basis < 1 { n_basis = 1 }
    // electrons — informational band count; ≈ 8 per atom for hydride cells.
    let n_elec = n_atoms * 8
    return DftSpec {
        n_atoms:     n_atoms,
        n_basis_pw:  n_basis,
        n_kpoints:   1,          // irreducible-k after symmetry; conservative 1
        n_spin:      1,
        n_electrons: n_elec,
        cutoff_ry:   ecut,
        method_id:   0           // SCF — relax per-step cost is SCF-dominated
    }
}

// _dft_isqrt — integer floor(sqrt(n)) (Newton). pure helper for the PW estimate.
fn _dft_isqrt(n: int) -> int {
    if n < 2 { return n }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

// _dft_oom_preflight — d11 HARD gate. Sizes the deck's relax (DftSpec) against the
// RAM floor via tls_dft_mpi_sweet_spot (REUSED budget math) BEFORE the paid rent.
// Returns the recommended MPI rank count to CLAMP -np to, or 0 to REFUSE the fire
// (the relax won't fit even one rank on the floor → renting would OOM-kill it, the
// wave3b pattern). Prints a clear [dft-run] verdict either way.
fn _dft_oom_preflight(deck: str) -> int {
    let spec = _dft_deck_spec(deck)
    let node = DftNodeSpec {
        total_mem_gib: DFT_DETACH_RAM_FLOOR,
        n_cpu_cores:   16,       // the rent query's cpu_cores_effective>=16 floor
        has_gpu:       0,
        gpu_mem_gib:   0
    }
    let rec = tls_dft_mpi_sweet_spot(spec, node)
    println("[dft-run] ⓪ OOM preflight (d11) — " + to_string(spec.n_atoms) + " atoms · ~"
        + to_string(spec.n_basis_pw) + " PW basis · per-rank ~" + to_string(rec.per_rank_mem_gib)
        + " GiB vs " + to_string(DFT_DETACH_RAM_FLOOR) + " GiB floor")
    if rec.kind == "mem-bound-zero" {
        println("[dft-run] ⓪ ✗ REFUSED — one MPI rank needs ~" + to_string(rec.per_rank_mem_gib)
            + " GiB but the " + to_string(DFT_DETACH_RAM_FLOOR) + " GiB offer floor can't fit it.")
        println("[dft-run]   renting would OOM-kill the relax (wave3b SIGKILL@iter#2 pattern). NOT firing.")
        println("[dft-run]   reduce ecutwfc / cell size, or rent a larger-RAM node manually (--query cpu_ram>=N).")
        return 0
    }
    println("[dft-run] ⓪ OK — relax fits; -np clamped to " + to_string(rec.recommended_np)
        + " (mem-budget sweet-spot, eff " + to_string(rec.efficiency_bp) + "bp)")
    return rec.recommended_np
}

// _dft_detach — option α PHASE-1. Rents → resolves the direct endpoint →
// reachability precheck → uploads the deck → provisions QE → fetches pseudos →
// launches RELAX *detached on the pod* (cloud_nohup → remote logfile) → records
// the pod in the registry → writes the detach state stamp → returns 0. There is
// NO teardown: the pod keeps running the relax after this local process exits.
// Advance with `hexa cloud dft-run <deck> --resume` (phase-2). This replaces the
// forbidden `( nohup dft-run --go & )` local double-fork — the long work runs on
// the POD, not in a detached local process, so the Bash cap is never exceeded.
fn _dft_detach(deck: str, image: str, disk: int, owner: str, query: str, identity: str, walltime_h: int, relax_name: str, force: int) -> int {
    println("[dft-run] ━ DETACH (phase-1) — rent + provision + launch relax detached on the pod ━")

    // ⓪ IDEMPOTENCY GUARD (the dup-idle-pod recurrence-stopper, 2026-06-01) —
    // before renting, check whether THIS deck already records a live detached
    // pod in `.dft_detach.state`. Without this, re-running `--detach` on a deck
    // that already has a live pod rents a SECOND billing pod and orphans the
    // first (the ~12 idle dup pods this leak produced). --force bypasses it.
    let g_iid = _dft_state_field(deck, "instance_id")
    let g_host = _dft_state_field(deck, "host")
    let g_port = _dft_state_field(deck, "port")
    let g_phase = _dft_state_field(deck, "phase")
    // a recorded pod = stamp present, endpoint resolved, and NOT already torn
    // down (phase done/failed → the pod is gone, so a re-fire is a legit rent).
    let alive_phase = if g_phase == "done" { 0 } else if g_phase == "failed" { 0 } else { 1 }
    let has_state = if len(g_iid) > 0 && _dft_endpoint_resolved(g_host, g_port) == 1 && alive_phase == 1 { 1 } else { 0 }
    // probe reachability via the CANONICAL transport (the same cloud_exec_opts
    // the rest of this file uses for both direct-IP and vast-proxy endpoints).
    let mut reachable = 0
    if has_state == 1 && force == 0 {
        let g_identity = _dft_state_field(deck, "identity")
        let g_sshhost = "root@" + g_host
        let g_opts = _dft_ssh_opts(g_port, g_identity)
        let g_probe = cloud_exec_opts(g_sshhost, g_opts, "echo REACHABLE")
        if g_probe.ok == 1 && g_probe.stdout_.contains("REACHABLE") {
            reachable = 1
        }
    }
    let action = _dft_detach_guard_action(force, has_state, reachable)
    if action == DFT_DETACH_SKIP {
        println("[dft-run] " + deck + " already has a live detached pod " + g_iid + "@" + g_host + ":" + g_port
            + " (stage `" + g_phase + "`) — NOT renting a second pod.")
        println("[dft-run]   advance it: hexa cloud dft-run " + deck + " --resume   (or --force to rent a fresh pod anyway)")
        return 0
    }
    if action == DFT_DETACH_REPLACE {
        println("[dft-run] " + deck + " has a recorded pod " + g_iid + "@" + g_host + ":" + g_port
            + " that is UNREACHABLE (dead / proxy-only) — re-firing.")
        // tear the stale billing pod down FIRST (state records the instance id),
        // so the re-fire never leaves it idle. No id → can't auto-tear-down.
        if len(g_iid) > 0 {
            println("[dft-run]   tearing down stale instance " + g_iid + " before renting fresh...")
            let _td = vast_destroy(g_iid)
            pod_registry_forget(g_iid)
        } else {
            println("[dft-run]   ⚠ no instance_id recorded — cannot auto-tear-down; proceeding to rent (check `hexa cloud pods` for an orphan).")
        }
    }

    // ⓪ d11 HARD OOM gate (Fix-deck-1) — size the relax BEFORE the paid rent. A
    // 0 verdict means even one rank won't fit the RAM floor → REFUSE (don't rent
    // an OOM-doomed pod). Otherwise clamp -np to the mem-budget sweet-spot AND pin
    // cpu_ram>=floor into the offer query so the rented node actually has the RAM
    // the closed-form fit assumed (the wave3b leak: no enforced RAM floor).
    let np_cap = _dft_oom_preflight(deck)
    if np_cap <= 0 {
        return 1
    }
    let ram_query = query + " cpu_ram>=" + to_string(DFT_DETACH_RAM_FLOOR)
    println("[dft-run] ① RENT — searching verified offers (CPU-first → GPU fallback)...")
    let offer = _dft_rent_first_offer(ram_query)
    if offer.ok == 0 {
        println("[dft-run] rent: " + offer.message)
        return 1
    }
    println("[dft-run] picked offer " + offer.offer_id)
    let inst = vast_create(offer.offer_id, image, disk)
    if inst.ok == 0 {
        vast_offer_release(offer.offer_id)
        println("[dft-run] create: " + inst.message)
        return 1
    }
    // ④ registry — numeric instance-id ONLY (no argv fragments, #1229).
    pod_registry_record(inst.instance_id, owner, "running")
    vast_offer_release(offer.offer_id)
    println("[dft-run] created + registered instance " + inst.instance_id)

    // ② wait for boot, then resolve the DIRECT bare-IP endpoint.
    let _w = vast_wait_ssh(inst.instance_id, 30, 20)
    let ep = vast_direct_endpoint(inst.instance_id)
    if ep.ok == 0 {
        println("[dft-run] ② transport: " + ep.message)
        println("[dft-run] instance " + inst.instance_id + " kept + tracked (cloud list); not auto-destroyed.")
        return 1
    }
    let host = "root@" + ep.host
    let ssh_opts = _dft_ssh_opts(ep.port, identity)
    println("[dft-run] ② direct endpoint " + ep.host + ":" + ep.port + " (identity " + identity + ")")

    // ① reachability precheck — TCP echo. unreachable → destroy + abort.
    let reach = cloud_exec_opts(host, ssh_opts, "echo REACHABLE")
    if reach.ok == 0 || !reach.stdout_.contains("REACHABLE") {
        println("[dft-run] ① reachability FAILED (" + reach.message + ") — destroying unreachable pod " + inst.instance_id)
        let _d = vast_destroy(inst.instance_id)
        pod_registry_forget(inst.instance_id)
        println("[dft-run] re-run `hexa cloud dft-run <deck> --detach` to try another offer.")
        return 1
    }
    println("[dft-run] ① reachability OK")

    // upload the deck
    let up = cloud_copy_to_recursive_opts(host, ssh_opts, deck, "/root/deck")
    if up.ok == 0 {
        println("[dft-run] upload: " + up.message)
        return _dft_teardown(inst.instance_id, 1)
    }

    // ③ phys-core -np, CLAMPED to the ⓪ OOM-gate mem-budget sweet-spot (np_cap) so
    // a high-core but modest-RAM node can't over-subscribe ranks into an OOM kill.
    let lscpu = cloud_exec_opts(host, ssh_opts, "lscpu")
    let np_raw = dft_physcores(lscpu.stdout_)
    let np_phys = if np_raw > 0 { np_raw } else { 8 }
    let np = if np_phys < np_cap { np_phys } else { np_cap }
    if np < np_phys {
        println("[dft-run] ③ -np=" + to_string(np) + " (phys " + to_string(np_phys)
            + " → clamped to ⓪ mem-budget sweet-spot " + to_string(np_cap) + ")")
    } else {
        println("[dft-run] ③ -np=" + to_string(np) + " (phys cores)")
    }

    // ③ provision QE (idempotent; skipped if pw.x present from a QE --image).
    println("[dft-run] ③ provision QE (apt quantum-espresso if pw.x absent)...")
    let prov = cloud_exec_opts(host, ssh_opts, _dft_provision_cmd())
    if prov.ok == 0 || !prov.stdout_.contains("pw.x OK") {
        println("[dft-run] provision: QE install/verify FAILED — " + prov.message)
        return _dft_teardown(inst.instance_id, 1)
    }
    println("[dft-run] ③ provision OK — pw.x + mpirun present")

    // ③ pseudo fetch — download referenced UPFs into ./pseudo.
    println("[dft-run] ③ pseudo fetch (UPF → ./pseudo from QE PSL server)...")
    let ps = cloud_exec_opts(host, ssh_opts, _dft_pseudo_cmd())
    if ps.ok == 0 || !ps.stdout_.contains("PSEUDO OK") {
        println("[dft-run] pseudo: fetch FAILED — " + ps.message + " · " + ps.stdout_)
        return _dft_teardown(inst.instance_id, 1)
    }
    println("[dft-run] ③ pseudo OK — UPFs in ./pseudo")

    // ③ launch RELAX DETACHED — cloud_nohup runs the (reused) guarded relax cmd
    // on the pod, output → relax.out, wrapper noise → the remote logfile, and
    // returns immediately with the remote PID. NO synchronous wait, NO teardown.
    let relax_log = _dft_remote_logfile("relax")
    let relax_argv = _dft_detach_argv(_dft_relax_cmd(np, walltime_h, relax_name))
    let launched = cloud_nohup_opts(host, ssh_opts, relax_argv, relax_log)
    if launched.ok == 0 {
        println("[dft-run] ③ relax detach launch FAILED — " + launched.message)
        return _dft_teardown(inst.instance_id, 1)
    }
    println("[dft-run] ③ relax LAUNCHED detached — remote pid " + to_string(launched.pid) + " · log " + relax_log)

    // write the detach state stamp so --resume can reconstruct the pod context.
    let wrote = _dft_write_state(deck, "relax", inst.instance_id, ep.host, ep.port,
                                 identity, np, walltime_h, relax_name)
    if !wrote {
        println("[dft-run] ⚠ could not write detach state stamp " + _dft_state_path(deck)
            + " — --resume will not find the pod (instance " + inst.instance_id + " is tracked in `cloud list`).")
    }
    println("[dft-run] ━ DETACH OK — pod " + inst.instance_id + " is running relax; this process is DONE (no teardown). ━")
    println("[dft-run]   monitor : hexa cloud tail " + host + " " + relax_log)
    println("[dft-run]   advance : hexa cloud dft-run " + deck + " --resume   (parse relax→scf+ph; idempotent, re-invokable)")
    return 0
}

// _dft_resume — option α PHASE-2. EXPLICIT + IDEMPOTENT terminal-step advance
// over the pod recorded by --detach. NOT an auto-poll loop (re-invoke once per
// candidate; it returns immediately). It reads the state stamp, reconstructs the
// endpoint, probes the CURRENT stage, and advances ONE terminal step:
//
//   phase=relax, relax DONE  → copy relax.out back, LOCAL hexa-native coord
//                              parse (NO pod-side hand-parse, @L2), assemble scf,
//                              upload, launch scf→ph CHAIN detached, stamp phon.
//   phase=relax, STILL RUNNING → no-op, return 0 (re-invoke later).
//   phase=phon,  ph DONE     → copy scf.out + ph.out back, dft_phonon_stable
//                              verdict, TEARDOWN, stamp done.
//   phase=phon,  STILL RUNNING → no-op, return 0.
//   any stage FAILED         → pull the tail for diagnosis, TEARDOWN(1).
//
// The long compute lives on the POD; --resume only ever does fast local I/O +
// one ssh probe + (at a boundary) a parse/upload/launch — never a blocking wait.
fn _dft_resume(deck: str) -> int {
    let iid = _dft_state_field(deck, "instance_id")
    if len(iid) == 0 {
        println("[dft-run] --resume: no detach state stamp at " + _dft_state_path(deck) + " — run `--detach` first.")
        return 2
    }
    let phase = _dft_state_field(deck, "phase")
    if phase == "done" {
        println("[dft-run] --resume: deck " + deck + " already at terminal `done` (instance " + iid + " torn down). Nothing to do.")
        return 0
    }
    let host_ip = _dft_state_field(deck, "host")
    let port = _dft_state_field(deck, "port")
    let identity = _dft_state_field(deck, "identity")
    let relax_name = _dft_state_field(deck, "relax_name")
    let np = _dft_atoi(_dft_state_field(deck, "np"))
    let walltime_h = _dft_atoi(_dft_state_field(deck, "walltime_h"))
    // TRANSPORT GUARD (cost a real pod — Li2MgH16 #38751850): if the endpoint
    // never resolved (empty host OR port → the `instance ... @ :` symptom), the
    // pod is UNREACHABLE, not failed. We cannot read relax.out, so we must NEVER
    // read that as a science failure and tear the pod down. Abort transiently
    // and leave the pod intact for a `--resume` retry once the endpoint maps.
    if _dft_endpoint_resolved(host_ip, port) == 0 {
        println("[dft-run] --resume: ABORT (no teardown) — endpoint UNRESOLVED in the state stamp (host='" + host_ip + "' port='" + port + "').")
        println("[dft-run]   the pod may be alive + billing but its host:port is not yet mapped — a TRANSPORT/transient condition, NOT a relax failure.")
        println("[dft-run]   retry: hexa cloud dft-run " + deck + " --resume   ·   verify: hexa cloud pods / vastai show instance " + iid)
        return 3
    }
    let host = "root@" + host_ip
    let ssh_opts = _dft_ssh_opts(port, identity)
    println("[dft-run] --resume: instance " + iid + " @ " + host_ip + ":" + port + " · stage `" + phase + "`")

    if phase == "relax" {
        // probe relax terminal (honest — pw.x dead AND clean JOB DONE).
        let probe = cloud_exec_opts(host, ssh_opts, _dft_stage_probe_cmd("pw.x", "relax.out"))
        // TRANSPORT GUARD: a probe that never reached the pod (ssh transport
        // failure — exit 255, or no exit-code marker exit -1) tells us NOTHING
        // about the science. Reading an unreachable pod as "relax FAILED" is
        // exactly what destroyed #38751850. Abort transiently — no teardown.
        if _dft_remote_read_ok(probe) == 0 {
            println("[dft-run] --resume: ABORT (no teardown) — relax probe could not reach the pod (" + probe.message + ").")
            println("[dft-run]   transport error (ssh 255 / no marker) is NOT a relax failure — leaving pod " + iid + " intact for retry.")
            println("[dft-run]   retry: hexa cloud dft-run " + deck + " --resume   ·   verify: hexa cloud pods / vastai show instance " + iid)
            return 3
        }
        if probe.stdout_.contains("__DFT_RUNNING__") {
            println("[dft-run] --resume: relax STILL RUNNING on the pod — re-invoke `--resume` later.")
            println("[dft-run]   monitor: hexa cloud tail " + host + " " + _dft_remote_logfile("relax"))
            return 0
        }
        // harvest relax.out + LOCAL coord parse (@L2 — never hand-parse on the pod).
        let hr = cloud_copy_from_opts(host, ssh_opts, "/root/deck/relax.out", deck + "/relax.out")
        // TRANSPORT GUARD: if the relax.out download itself failed (transport
        // error / file unreadable), `coords` will be empty for a NON-science
        // reason. Never read a failed read as "relax FAILED → teardown".
        if hr.ok == 0 {
            println("[dft-run] --resume: ABORT (no teardown) — could not download relax.out from the pod (" + hr.message + ").")
            println("[dft-run]   a failed remote read is a TRANSPORT condition, NOT 'relax FAILED' — leaving pod " + iid + " intact for retry.")
            println("[dft-run]   retry: hexa cloud dft-run " + deck + " --resume   ·   verify: hexa cloud pods / vastai show instance " + iid)
            return 3
        }
        let coords = dft_relax_to_scf_coords(read_file(deck + "/relax.out"))
        // CONFIRMED science failure ONLY now: the pod was reachable, the probe
        // reported __DFT_FAILED__ OR relax.out is present yet genuinely lacks
        // final coordinates. Teardown is safe here (no transport ambiguity).
        if probe.stdout_.contains("__DFT_FAILED__") || len(coords) == 0 {
            println("[dft-run] --resume: relax FAILED / no 'Begin final coordinates' — not dispatching scf on stale geometry.")
            let rt = cloud_exec_opts(host, ssh_opts, "tail -40 /root/deck/relax.out 2>/dev/null")
            println("[dft-run] ── relax.out tail ──\n" + rt.stdout_ + "\n[dft-run] ── end ──")
            let _ws = _dft_write_state(deck, "failed", iid, host_ip, port, identity, np, walltime_h, relax_name)
            return _dft_teardown(iid, 1)
        }
        // assemble scf = head + LOCAL-parsed coords + tail; write scf.in.gen (no
        // source clobber); upload as the pod's scf.in.
        let split = dft_scf_head_tail(deck)
        if split.ok == 0 {
            println("[dft-run] --resume: FATAL — could not resolve scf head/tail (no scf.in[.head/.tail]).")
            return _dft_teardown(iid, 1)
        }
        let scf_in = dft_assemble_scf_cell(split.head, coords, split.tail, split.cell)
        write_file(deck + "/scf.in.gen", scf_in)
        let _us = cloud_copy_to_opts(host, ssh_opts, deck + "/scf.in.gen", "/root/deck/scf.in")
        // launch scf→ph CHAIN detached (one terminal step; ph runs only on clean scf).
        // SELF-RESUME: wrap the el-ph compute stage in a pod-side recover loop so a
        // walltime kill auto-relaunches (recover=.true.) on the SAME pod until ph is
        // terminal — no controller `--resume` round-trip (the 13/20-stalled fix).
        let phon_log = _dft_remote_logfile("phon")
        let phon_cmd = _dft_self_resume_wrap(_dft_scfph_cmd(np, walltime_h), "ph.x", "ph.out", 8)
        let phon_argv = _dft_detach_argv(phon_cmd)
        let launched = cloud_nohup_opts(host, ssh_opts, phon_argv, phon_log)
        if launched.ok == 0 {
            println("[dft-run] --resume: scf→ph detach launch FAILED — " + launched.message)
            return _dft_teardown(iid, 1)
        }
        let _ws2 = _dft_write_state(deck, "phon", iid, host_ip, port, identity, np, walltime_h, relax_name)
        println("[dft-run] --resume: relax DONE → scf→ph CHAIN LAUNCHED detached (pid " + to_string(launched.pid) + " · log " + phon_log + ")")
        println("[dft-run]   monitor: hexa cloud tail " + host + " " + phon_log)
        println("[dft-run]   advance: hexa cloud dft-run " + deck + " --resume   (harvest+verdict+teardown on ph-terminal)")
        return 0
    }

    if phase == "phon" {
        // probe ph terminal HONESTLY (ph.x dead AND clean JOB DONE — not the
        // per-invocation checkpoint marker). scf precedes ph in the chain, so a
        // ph.x that ran at all implies scf completed.
        let probe = cloud_exec_opts(host, ssh_opts, _dft_stage_probe_cmd("ph.x", "ph.out"))
        // TRANSPORT GUARD: an unreachable pod (ssh 255 / no marker) tells us
        // nothing — never fall through to a verdict (which would teardown) on a
        // transport failure. Abort transiently, leave the pod intact.
        if _dft_remote_read_ok(probe) == 0 {
            println("[dft-run] --resume: ABORT (no teardown) — ph probe could not reach the pod (" + probe.message + ").")
            println("[dft-run]   transport error (ssh 255 / no marker) is NOT a ph failure — leaving pod " + iid + " intact for retry.")
            println("[dft-run]   retry: hexa cloud dft-run " + deck + " --resume   ·   verify: hexa cloud pods / vastai show instance " + iid)
            return 3
        }
        // scf could still be running (ph.x not yet spawned) — pw.x alive counts as running too.
        let scfprobe = cloud_exec_opts(host, ssh_opts, "pgrep -x pw.x >/dev/null 2>&1 && echo __DFT_RUNNING__ || echo __DFT_IDLE__")
        if probe.stdout_.contains("__DFT_RUNNING__") || scfprobe.stdout_.contains("__DFT_RUNNING__") {
            println("[dft-run] --resume: scf/ph STILL RUNNING on the pod — re-invoke `--resume` later.")
            println("[dft-run]   monitor: hexa cloud tail " + host + " " + _dft_remote_logfile("phon"))
            return 0
        }
        // harvest scf.out + ph.out.
        let _hs = cloud_copy_from_opts(host, ssh_opts, "/root/deck/scf.out", deck + "/scf.out")
        let _hp = cloud_copy_from_opts(host, ssh_opts, "/root/deck/ph.out", deck + "/ph.out")
        if probe.stdout_.contains("__DFT_FAILED__") {
            // WALLTIME-vs-CRASH split (the destructive-teardown fix, 2026-06-01).
            // `__DFT_FAILED__` collapses TWO disjoint conditions: a NORMAL walltime
            // cap (`Maximum CPU time exceeded` / `max_seconds`) — which is exactly
            // the recover case the pod-side self-resume daemon walks past — and a
            // GENUINE crash. Tearing the pod down on the former DESTROYS a healthy
            // phonon pod plus its accumulated q-point progress (the live 38709875
            // loss at 5/8 q-points). So: classify on the HARVESTED ph.out, and on a
            // walltime kill RECOVER-RELAUNCH on the SAME pod (wrapped in the
            // self-resume loop so it also self-heals going forward) — DO NOT destroy.
            if _dft_failure_is_walltime(read_file(deck + "/ph.out")) == 1 {
                println("[dft-run] --resume: ph WALLTIME-KILLED (Maximum CPU time / max_seconds) — NOT a crash.")
                println("[dft-run]   recover-relaunching el-ph (recover=.true.) on the SAME pod " + iid + " — NO teardown (q-point progress preserved).")
                let phon_log = _dft_remote_logfile("phon")
                let phon_cmd = _dft_self_resume_wrap(_dft_scfph_cmd(np, walltime_h), "ph.x", "ph.out", 8)
                let phon_argv = _dft_detach_argv(phon_cmd)
                let relaunched = cloud_nohup_opts(host, ssh_opts, phon_argv, phon_log)
                if relaunched.ok == 0 {
                    // relaunch transport failure is NOT a science failure — leave the
                    // pod intact (d_defer_no_delete) for a retry rather than tearing down.
                    println("[dft-run] --resume: recover-relaunch detach FAILED — " + relaunched.message)
                    println("[dft-run]   leaving pod " + iid + " INTACT (transport fail ≠ science fail) — retry: hexa cloud dft-run " + deck + " --resume")
                    return 3
                }
                let _wp = _dft_write_state(deck, "phon", iid, host_ip, port, identity, np, walltime_h, relax_name)
                println("[dft-run] --resume: el-ph RECOVER-RELAUNCHED detached (pid " + to_string(relaunched.pid) + " · log " + phon_log + ").")
                println("[dft-run]   monitor: hexa cloud tail " + host + " " + phon_log + "   ·   advance: hexa cloud dft-run " + deck + " --resume")
                return 0
            }
            // GENUINE crash (Error in routine / STOP [1-9] / segfault / OOM — not a
            // walltime cap): the existing teardown/defer behavior is correct.
            println("[dft-run] --resume: ph (or scf) CRASHED before a clean JOB DONE (non-walltime signature) — closed as failure.")
            let pt = cloud_exec_opts(host, ssh_opts, "tail -40 /root/deck/ph.out 2>/dev/null")
            println("[dft-run] ── ph.out tail ──\n" + pt.stdout_ + "\n[dft-run] ── end ──")
            let _wf = _dft_write_state(deck, "failed", iid, host_ip, port, identity, np, walltime_h, relax_name)
            return _dft_teardown(iid, 1)
        }
        // ④ stability verdict on the harvested ph.out.
        let verdict = dft_phonon_stable(read_file(deck + "/ph.out"))
        if verdict == 0 {
            println("[dft-run] ④ VERDICT: UNSTABLE (imaginary mode < -5 cm⁻¹) — closed-negative.")
        } else {
            if verdict == 1 {
                println("[dft-run] ④ VERDICT: dynamically stable (all real modes in computed q-set) — harvest λ/ω_log/Tc.")
            } else {
                println("[dft-run] ④ VERDICT: inconclusive (no frequencies parsed) — inspect ph.out.")
            }
        }
        println("[dft-run] results harvested to " + deck + "/{relax.out,scf.out,ph.out}.")
        let _wd = _dft_write_state(deck, "done", iid, host_ip, port, identity, np, walltime_h, relax_name)
        return _dft_teardown(iid, 0)
    }

    if phase == "failed" {
        println("[dft-run] --resume: deck " + deck + " is at terminal `failed` (pod torn down). Re-`--detach` to retry.")
        return 1
    }
    println("[dft-run] --resume: unknown stage `" + phase + "` in the state stamp — inspect " + _dft_state_path(deck) + ".")
    return 2
}

// _dft_teardown — non-interactive destroy + registry forget (④ orphan guard).
fn _dft_teardown(iid: str, rc: int) -> int {
    println("[dft-run] ④ teardown: destroying instance " + iid)
    let _d = vast_destroy(iid)
    pod_registry_forget(iid)
    return rc
}
