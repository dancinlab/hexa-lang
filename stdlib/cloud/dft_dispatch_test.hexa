// stdlib/cloud/dft_dispatch_test.hexa — unit tests for the PURE helpers of
// the `hexa cloud dft-run` dispatcher (dft_dispatch.hexa, INBOX #1249) plus
// the vast direct-endpoint parser (vast.hexa, INBOX #1239(2)).
//
// These are the verifiable core of the feature — the cost-bearing e2e
// (rent/ssh/chain) cannot run without vastai + a live GPU, but the QE
// coordinate parser, the stability verdict, the physical-core count, the
// rent-query builder, and the bare-IP endpoint parser are all pure string
// transforms this file exercises against fixtures.
//
// Both modules are libraries (no top-level main), so `use` is side-effect
// free here (unlike cloud_cli.hexa, whose main() auto-fires on import).
//
// Run:   hexa run stdlib/cloud/dft_dispatch_test.hexa
// PASS:  exits 0, prints "dft_dispatch_test PASS".

use "stdlib/cloud/dft_dispatch"
use "stdlib/cloud/vast"

// _check — established stdlib-cloud test shape (got/want ints; see
// early_life_check_test.hexa). Avoids if-expressions as call arguments.
fn _check(case: str, got: int, want: int) {
    if got != want {
        println("  FAIL: " + case + " — got " + to_string(got) + " want " + to_string(want))
        exit(1)
    }
    println("  ok: " + case)
}

fn _has(s: str, t: str) -> int {
    if s.contains(t) {
        return 1
    }
    return 0
}

fn _seq(a: str, b: str) -> int {
    if a == b {
        return 1
    }
    return 0
}

fn _bool_int(b: bool) -> int {
    if b {
        return 1
    }
    return 0
}

// _lt_index — 1 iff substring `a` first appears strictly before substring `b`
// in `s` (both must be present). Used to assert command-token ORDERING
// (scf before ph; the failure-first grep before the JOB DONE grep).
fn _lt_index(s: str, a: str, b: str) -> int {
    let ia = s.index_of(a)
    let ib = s.index_of(b)
    if ia < 0 || ib < 0 {
        return 0
    }
    if ia < ib {
        return 1
    }
    return 0
}

fn main() {
    // ── ③ relax → scf coordinate parser ──────────────────────────────
    // alat=1.0 → scale = BOHR_ANGSTROM = 0.52917720859, so the x-axis cell
    // vector "1.0 0.0 0.0" → 0.529177..., a robust prefix to assert against.
    let relax_out = "     bfgs converged in 5 scf cycles\n"
        + "Begin final coordinates\n"
        + "     new unit-cell volume =    100.0 a.u.^3\n"
        + "CELL_PARAMETERS (alat=  1.00000000)\n"
        + "   1.000000000   0.000000000   0.000000000\n"
        + "   0.000000000   1.000000000   0.000000000\n"
        + "   0.000000000   0.000000000   1.000000000\n"
        + "ATOMIC_POSITIONS (crystal)\n"
        + "Mg       0.000000000   0.000000000   0.000000000\n"
        + "B        0.333333333   0.666666667   0.500000000\n"
        + "End final coordinates\n"
    let coords = dft_relax_to_scf_coords(relax_out)
    _check("parser: emits CELL_PARAMETERS (angstrom)", _has(coords, "CELL_PARAMETERS (angstrom)"), 1)
    _check("parser: emits ATOMIC_POSITIONS (crystal)", _has(coords, "ATOMIC_POSITIONS (crystal)"), 1)
    _check("parser: alat->angstrom scaled x-axis (0.529...)", _has(coords, "0.529"), 1)
    _check("parser: Mg position passed through", _has(coords, "Mg"), 1)
    _check("parser: B position passed through", _has(coords, "B "), 1)

    // no "Begin final coordinates" → "" (caller FATALs, never hand-parses).
    let bad = dft_relax_to_scf_coords("     convergence NOT achieved\n SCF correction\n")
    _check("parser: unconverged relax -> empty (no hand-parse)", len(bad), 0)

    // ── scf.in assembly (head + coords + tail) ───────────────────────
    let scf = dft_assemble_scf("&control\n  calculation='scf'\n/\n", coords, "K_POINTS automatic\n8 8 8 0 0 0\n")
    _check("assemble: keeps head namelist", _has(scf, "calculation='scf'"), 1)
    _check("assemble: splices coords", _has(scf, "CELL_PARAMETERS (angstrom)"), 1)
    _check("assemble: keeps tail K_POINTS", _has(scf, "K_POINTS automatic"), 1)

    // ── ④ phonon stability verdict ───────────────────────────────────
    let stable_ph = "     freq (  1) =       0.123456 [THz] =       4.117890 [cm-1]\n"
        + "     freq (  2) =       3.456789 [THz] =     115.30 [cm-1]\n"
    _check("verdict: all-real -> stable(1)", dft_phonon_stable(stable_ph), 1)

    let unstable_ph = "     freq (  1) =      -1.234567 [THz] =     -41.18 [cm-1]\n"
        + "     freq (  2) =       3.456789 [THz] =     115.30 [cm-1]\n"
    _check("verdict: imaginary <-5cm-1 -> unstable(0)", dft_phonon_stable(unstable_ph), 0)

    // a tiny -3 cm-1 (numerical noise, > -5) is NOT flagged unstable.
    let noise_ph = "     freq (  1) =      -0.09 [THz] =      -3.01 [cm-1]\n"
    _check("verdict: -3cm-1 noise -> stable(1)", dft_phonon_stable(noise_ph), 1)

    _check("verdict: no freqs -> inconclusive(-1)", dft_phonon_stable("ph.x : nothing here\n"), -1)

    // ── ③ physical-core count (lscpu) ────────────────────────────────
    let lscpu = "Architecture:            x86_64\n"
        + "CPU(s):                  56\n"
        + "Thread(s) per core:      2\n"
        + "Core(s) per socket:      14\n"
        + "Socket(s):               2\n"
        + "NUMA node(s):            2\n"
    _check("physcores: 14x2 = 28 (not nproc 56)", dft_physcores(lscpu), 28)
    _check("physcores: missing fields -> 0", dft_physcores("Architecture: x86_64\n"), 0)

    // ── ① rent query guard ───────────────────────────────────────────
    let q = dft_rent_query("")
    _check("rent query: reliability>0.97 floor", _has(q, "reliability>0.97"), 1)
    _check("rent query: 16+ phys cores", _has(q, "cpu_cores_effective>=16"), 1)
    // d7 cost cap — the default MUST carry a dph ceiling so the CPU-bound el-ph
    // workload never grabs a $4–12/hr B200 GPU tier (the live-money overspend).
    _check("rent query: dph_total<2.0 cost cap (d7)", _has(q, "dph_total<2.0"), 1)
    let q2 = dft_rent_query("gpu_name=RTX_4090")
    _check("rent query: appends caller predicate", _has(q2, "gpu_name=RTX_4090"), 1)
    // a user --query can RAISE the cap — its token is appended AFTER the default
    // so vastai last-wins lets a big job opt into a beefier/pricier node.
    let q3 = dft_rent_query("dph_total<8.0")
    _check("rent query: caller --query overrides cap (last-wins)",
        _lt_index(q3, "dph_total<2.0", "dph_total<8.0"), 1)

    // ── ② bare-IP direct endpoint parser (#1239(2) fix) ──────────────
    let inst_json = "[{\"id\": 12345, \"public_ipaddr\": \"1.2.3.4\", \"ports\": {\"22/tcp\": [{\"HostPort\": \"40012\"}]}}]"
    let ep = vast_parse_direct_endpoint(inst_json, "12345")
    _check("endpoint: ok=1 for present instance", ep.ok, 1)
    _check("endpoint: bare public_ipaddr host", _seq(ep.host, "1.2.3.4"), 1)
    _check("endpoint: 22/tcp HostPort", _seq(ep.port, "40012"), 1)
    let ep_absent = vast_parse_direct_endpoint(inst_json, "99999")
    _check("endpoint: ok=0 for absent instance", ep_absent.ok, 0)

    // ── option α phase-1: --detach flag parse + detached relax command shape ──
    // --detach / --resume are BOOLEAN flags (take no value): the positional
    // scanner must skip ONE token, so the deck dir is still resolved after them.
    _check("flag: --detach is boolean", _dft_is_bool_flag("--detach"), 1)
    _check("flag: --resume is boolean", _dft_is_bool_flag("--resume"), 1)
    let av_d = ["dft-run", "/decks/CaBeH8", "--detach"]
    _check("parse: --detach has_flag", _dft_has_flag(av_d, 1, "--detach"), 1)
    _check("parse: deck positional past --detach", _seq(_dft_first_positional(av_d, 1), "/decks/CaBeH8"), 1)
    _check("parse: --detach is 1 positional (no value swallow)", _dft_count_positionals(av_d, 1), 1)
    let av_r = ["dft-run", "--resume", "/decks/ScH9"]
    _check("parse: deck positional past leading --resume", _seq(_dft_first_positional(av_r, 1), "/decks/ScH9"), 1)

    // detached relax = the SAME guarded relax cmd, wrapped in a `sh -lc` argv for
    // cloud_nohup (login shell → detached-env-loss guard). Shape contract: argv
    // is ["sh","-lc", <relax cmd>] and the inner cmd is the reused _dft_relax_cmd.
    let relax_cmd = _dft_relax_cmd(28, 12, "vc-relax.in")
    let argv = _dft_detach_argv(relax_cmd)
    _check("detach argv: sh launcher", _seq(argv[0], "sh"), 1)
    _check("detach argv: login -c", _seq(argv[1], "-lc"), 1)
    _check("detach argv: carries the relax invocation", _has(argv[2], "pw.x -ndiag 1 -in vc-relax.in"), 1)
    _check("detach argv: relax output → relax.out", _has(argv[2], "> relax.out"), 1)
    // phase-1 launches relax DETACHED — it must NOT contain scf / ph / teardown.
    _check("detach argv: no scf in phase-1 relax launch", _has(argv[2], "scf.in"), 0)
    _check("detach argv: no ph in phase-1 relax launch", _has(argv[2], "ph.in"), 0)
    // per-stage remote logfile (cloud_nohup target — a --resume tail attaches here).
    _check("detach: relax remote logfile path", _seq(_dft_remote_logfile("relax"), "/root/deck/.relax.detach.log"), 1)

    // ── detach state stamp round-trip (the --detach→--resume handoff SSOT) ──
    let sdeck = "/tmp/dft_detach_state_test"
    let _mk = exec("mkdir -p '" + sdeck + "'")
    let wrote = _dft_write_state(sdeck, "relax", "12345", "1.2.3.4", "40012",
                                 "/home/u/.ssh/id_vast_anima", 28, 12, "vc-relax.in")
    _check("state: write_state ok", _bool_int(wrote), 1)
    _check("state: phase field", _seq(_dft_state_field(sdeck, "phase"), "relax"), 1)
    _check("state: instance_id field", _seq(_dft_state_field(sdeck, "instance_id"), "12345"), 1)
    _check("state: host field", _seq(_dft_state_field(sdeck, "host"), "1.2.3.4"), 1)
    _check("state: port field", _seq(_dft_state_field(sdeck, "port"), "40012"), 1)
    _check("state: np field", _seq(_dft_state_field(sdeck, "np"), "28"), 1)
    _check("state: relax_name field", _seq(_dft_state_field(sdeck, "relax_name"), "vc-relax.in"), 1)
    _check("state: absent key → empty", len(_dft_state_field(sdeck, "nope")), 0)
    let _rm = exec("rm -rf '" + sdeck + "'")
    _check("state: missing stamp → empty field", len(_dft_state_field(sdeck, "phase")), 0)

    // ── option α phase-2: --resume scf→ph chain + honest terminal probe ──
    // the phase-2 launch is the scf→ph CHAIN as ONE detached command: scf first,
    // ph only on a clean scf (&&). The geometry was spliced LOCALLY into scf.in.
    let scfph = _dft_scfph_cmd(28, 12)
    _check("scfph: runs scf.in", _has(scfph, "pw.x -ndiag 1 -in scf.in"), 1)
    _check("scfph: runs ph.in", _has(scfph, "ph.x -in ph.in"), 1)
    _check("scfph: scf BEFORE ph (chained &&)", _lt_index(scfph, "scf.in", "ph.in"), 1)
    _check("scfph: gates ph on clean scf (&&)", _has(scfph, " && "), 1)
    let phon_argv = _dft_detach_argv(scfph)
    _check("scfph: wrapped sh -lc for detach", _seq(phon_argv[1], "-lc"), 1)
    _check("phon remote logfile path", _seq(_dft_remote_logfile("phon"), "/root/deck/.phon.detach.log"), 1)

    // honest terminal probe (the QE JOB DONE checkpoint trap, MEMORY 2026-05-29):
    // a bare JOB DONE grep is NOT terminal. The probe is FAILURE-FIRST and emits
    // exactly one of RUNNING / FAILED / DONE; pgrep gates RUNNING before any grep.
    let rprobe = _dft_stage_probe_cmd("pw.x", "relax.out")
    _check("probe: pgrep liveness gate first", _has(rprobe, "pgrep -x pw.x"), 1)
    _check("probe: RUNNING marker", _has(rprobe, "__DFT_RUNNING__"), 1)
    _check("probe: DONE marker", _has(rprobe, "__DFT_DONE__"), 1)
    _check("probe: FAILED marker", _has(rprobe, "__DFT_FAILED__"), 1)
    _check("probe: checks JOB DONE", _has(rprobe, "JOB DONE"), 1)
    // failure-first ordering — the crash/timeout grep must precede the JOB DONE grep
    // so a timed-out run (which ALSO prints JOB DONE) classifies as FAILED not DONE.
    _check("probe: failure signature BEFORE JOB DONE (checkpoint-trap guard)",
        _lt_index(rprobe, "Maximum CPU time exceeded", "JOB DONE"), 1)
    _check("probe: STOP [1-9] crash signature", _has(rprobe, "STOP [1-9]"), 1)
    let pprobe = _dft_stage_probe_cmd("ph.x", "ph.out")
    _check("probe: ph.x binary + ph.out file", _has(pprobe, "pgrep -x ph.x"), 1)

    // resume terminal-step contract: a missing state stamp → run --detach first.
    let nodeck = "/tmp/dft_resume_nostate_test"
    let _rmn = exec("rm -rf '" + nodeck + "' && mkdir -p '" + nodeck + "'")
    _check("resume: no state stamp → refuse (2)", _dft_resume(nodeck), 2)
    // a 'done' phase is idempotent — re-resume is a clean no-op (0), no teardown.
    let _wd = _dft_write_state(nodeck, "done", "777", "h", "p", "id", 8, 12, "vc-relax.in")
    _check("resume: terminal 'done' → idempotent no-op (0)", _dft_resume(nodeck), 0)
    let _rmn2 = exec("rm -rf '" + nodeck + "'")

    println("dft_dispatch_test PASS")
}
