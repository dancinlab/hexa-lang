// @ci_gate — pure · network-free · deterministic (stdlib_selftest_aggregate --ci-gate)
// stdlib/cloud/reconcile_test.hexa — falsifiers for the multi-provider
// reconcile classification in stdlib/cloud/pod_registry.
//
// LLM-free, network-free, no registry-file dependency. The live
// cloud_reconcile_print() unions runpod_list_pods().pod_ids with
// vast_list_instances().instance_ids before classifying; the GHOST bug
// was querying ONLY runpod, so every live vast instance fell through to
// GHOST. This test locks the property the fix relies on: a registry pod
// is GHOST iff it is absent from the MERGED provider set — i.e. a vast id
// present in the vast list keeps a vast-tracked pod OK even when the
// runpod list omits it.
//
// Mirrors watchdog_test.hexa: a test-local oracle (`_klass`) reproduces
// the classification over explicit (registry-id, merged-provider-ids)
// inputs, so the assertion is hermetic (no ~/.hexa-cloud/pods.jsonl read).
//
// Run:   hexa run stdlib/cloud/reconcile_test.hexa
// PASS:  exits 0, prints "reconcile_test PASS — N/N cases".

// ── oracle (test-local mirror of pod_registry_reconcile_rows membership) ─
//
// Classification contract (pod_registry.hexa):
//   registry id ∈ merged provider set              → "OK"
//   registry id ∉ merged set AND status != closed  → "GHOST"
//   (provider id ∉ registry → "ORPHAN", exercised via _orphan below)
fn _id_in(ids: [str], id: str) -> int {
    let mut i = 0
    while i < len(ids) {
        if ids[i] == id { return 1 }
        i = i + 1
    }
    return 0
}

fn _klass(reg_id: str, reg_status: str, provider_ids: [str]) -> str {
    if _id_in(provider_ids, reg_id) == 1 { return "OK" }
    if reg_status != "closed" { return "GHOST" }
    return "__skip__"
}

// _merge — the union cloud_reconcile_print performs (runpod ++ vast).
fn _merge(runpod_ids: [str], vast_ids: [str]) -> [str] {
    let mut out = []
    let mut i = 0
    while i < len(runpod_ids) { out.push(runpod_ids[i]); i = i + 1 }
    let mut j = 0
    while j < len(vast_ids) { out.push(vast_ids[j]); j = j + 1 }
    return out
}

fn _fail(case: str, msg: str) {
    println("FAIL " + case + ": " + msg)
    exit(1)
}

fn _eq(case: str, got: str, want: str) {
    if got != want { _fail(case, "got " + got + " want " + want) }
}

fn main() {
    let mut n = 0

    // The exact INBOX falsifier (2026-05-25T06:37Z): vast instances
    // 37618320 / 37619639 are RUNNING on vast but absent from the runpod
    // list. Pre-fix (runpod-only set) → GHOST. Post-fix (merged set) → OK.
    let runpod = []                      // runpod has 0 live pods
    let vast = ["37618320", "37619639"]  // both live on vast
    let merged = _merge(runpod, vast)

    _eq("inbox-37618320", _klass("37618320", "running", merged), "OK"); n = n + 1
    _eq("inbox-37619639", _klass("37619639", "running", merged), "OK"); n = n + 1

    // Regression guard: querying ONLY runpod (the bug) misclassifies both.
    _eq("bug-runpod-only-1", _klass("37618320", "running", runpod), "GHOST"); n = n + 1
    _eq("bug-runpod-only-2", _klass("37619639", "running", runpod), "GHOST"); n = n + 1

    // A genuinely-gone pod (in neither live set) stays GHOST after the fix.
    _eq("genuine-ghost", _klass("37610503", "running", merged), "GHOST"); n = n + 1

    // A runpod-tracked pod present in the runpod half stays OK in the union.
    let merged2 = _merge(["rp-aaa"], vast)
    _eq("runpod-half-ok", _klass("rp-aaa", "running", merged2), "OK"); n = n + 1

    // A closed registry row absent from both is skipped (reconciled history).
    _eq("closed-skipped", _klass("old-x", "closed", merged), "__skip__"); n = n + 1

    println("reconcile_test PASS — " + str(n) + "/" + str(n) + " cases")
}
