// stdlib/cloud/pod_registry.hexa — minimal persistent pod registry (MVP).
//
// `hexa cloud` is the single gateway through which pods get dispatched, but
// before this module the only trace of a launched pod was the volatile state
// of the launching shell (dispatch.log + an attached Monitor). A reboot / new
// session / different machine lost that handle entirely → the pod became an
// ORPHAN: still billing, results unrecoverable, no poll/pull handle. See
// archive/patches/hexa-cloud-pod-registry-tracking-2026-05-24.md for the
// incident (7× A100 @ $10.43/h with zero local trace after a reboot).
//
// This MVP is the minimal SSOT it asks for: an append-only JSONL file at
// $HOME/.hexa-cloud/pods.jsonl, a single write helper the `run`/`nohup` verbs
// call, and a `cloud orphans` read verb that lists tracked pods and flags
// stale ones. Provider provisioning (rent/destroy) is DEFERRED to RFC 088
// P-series — this registry only tracks pods that get launched/used, it does
// not create them. runpod_list_pods() cross-reconcile is a documented BONUS,
// landed below (reconcile/adopt/forget) as the PR #761 follow-up.

use "stdlib/cloud/runpod"
use "stdlib/cloud/vast"

// ── paths ────────────────────────────────────────────────────────────

// _reg_dir / _reg_file — $HOME-resolved registry location (g13 portable).
// Mirrors vast.hexa's _vast_claim_dir so both live under ~/.hexa-cloud.
fn _reg_dir() -> str {
    return env_var("HOME") + "/.hexa-cloud"
}

fn _reg_file() -> str {
    return _reg_dir() + "/pods.jsonl"
}

// _reg_shq — POSIX-quote a token for the local /bin/sh -c (mkdir/date).
fn _reg_shq(s: str) -> str {
    let mut out = "'"
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            out = out + "'\\''"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out + "'"
}

// ── time ─────────────────────────────────────────────────────────────

// _reg_now_iso — UTC ISO-8601 timestamp (date -u). "" if unavailable.
fn _reg_now_iso() -> str {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null").trim()
}

// _reg_now_sec — unix epoch seconds; 0 if unavailable (staleness degrades
// to "not stale" rather than false-flagging everything).
fn _reg_now_sec() -> int {
    let s = exec("date +%s 2>/dev/null").trim()
    return _reg_atoi(s)
}

// _reg_iso_to_sec — epoch seconds for an ISO-8601 UTC ts via `date -d`/`-jf`.
// Returns -1 if the platform's date(1) cannot parse it (e.g. BSD without the
// -j form), so staleness math degrades to "skip" rather than mis-flag.
fn _reg_iso_to_sec(iso: str) -> int {
    if len(iso) == 0 {
        return -1
    }
    let q = _reg_shq(iso)
    // GNU date first, then BSD/macOS `-jf`. Both print epoch on success.
    let cmd = "date -u -d " + q + " +%s 2>/dev/null || date -u -jf %Y-%m-%dT%H:%M:%SZ " + q + " +%s 2>/dev/null"
    let s = exec(cmd).trim()
    return _reg_atoi(s)
}

// _reg_atoi — leading run of decimal digits; -1 if none.
fn _reg_atoi(s: str) -> int {
    let n = len(s)
    let mut i = 0
    let mut val = 0
    let mut got = 0
    while i < n {
        let cc = char_code(s.substring(i, i + 1))
        if cc >= 48 && cc <= 57 {
            val = val * 10 + (cc - 48)
            got = 1
            i = i + 1
        } else {
            i = n
        }
    }
    if got == 0 {
        return -1
    }
    return val
}

// ── JSON value escaping / field extraction ───────────────────────────

// _reg_jstr — JSON-escape a string value (quotes, backslash, newline) so a
// label/purpose with a quote can't break the JSONL line.
fn _reg_jstr(s: str) -> str {
    let mut out = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\"" {
            out = out + "\\\""
        } else if c == "\\" {
            out = out + "\\\\"
        } else if c == "\n" {
            out = out + "\\n"
        } else if c == "\t" {
            out = out + "\\t"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out
}

// _reg_field — extract the string value of "key":"value" from one JSONL
// line. Conservative: assumes the value has no escaped quote (true for the
// fields we write: ids, labels, ISO ts, status). "" if the key is absent.
fn _reg_field(line: str, key: str) -> str {
    let marker = "\"" + key + "\":\""
    let at = line.index_of(marker)
    if at < 0 {
        return ""
    }
    let start = at + len(marker)
    let mut i = start
    let n = len(line)
    while i < n {
        if line.substring(i, i + 1) == "\"" {
            return line.substring(start, i)
        }
        i = i + 1
    }
    return ""
}

// ── write helper (the single gateway hook) ───────────────────────────

// pod_registry_record — append/update one pod's record in pods.jsonl. The
// `cloud run` / `cloud nohup` verbs call this after a dispatch so every pod
// that goes through the gateway lands in one SSOT. Same-id re-dispatch
// updates the existing record's last_seen + status in place (the file is
// rewritten with the prior records minus the matching id, then the fresh
// record appended) so the file does not grow one line per poll.
//
// `pod_id`  — the PROVIDER pod/instance id ONLY (numeric vast instance-id or
//             alphanumeric runpod pod-id). NOT an ssh destination, path, or
//             argv fragment — reconcile matches this id against the provider
//             live-id sets, so an `root@<ip>` / `ssh1.vast.ai` / `/root/run.sh`
//             / bare-flag value can never match and pollutes the table with
//             phantom GHOST rows (INBOX #1229 B → A). `_pod_id_looks_valid`
//             rejects those shapes.
// `label`   — free-form purpose/name ("p21h-v3-qwen", launching repo, ...).
// `status`  — "running" | "closed" | "lost".

// _pod_id_looks_valid — a provider pod-id is a bare token (vast: digits;
// runpod: alnum + `-`/`_`). Reject ssh destinations (`@`), hosts / IPs (`.`),
// paths (`/`), whitespace (argv fragments), and leading-`-` flag values — the
// pollution classes filed in INBOX #1229 B. 1 = looks like a real id, 0 = drop.
fn _pod_id_looks_valid(pod_id: str) -> int {
    let n = len(pod_id)
    if n == 0 {
        return 0
    }
    if pod_id.substring(0, 1) == "-" {
        return 0
    }
    let mut i = 0
    while i < n {
        let c = pod_id.substring(i, i + 1)
        if c == "@" || c == "/" || c == "." || c == " " || c == "\t" {
            return 0
        }
        i = i + 1
    }
    return 1
}

fn pod_registry_record(pod_id: str, label: str, status: str) {
    if len(pod_id) == 0 {
        return
    }
    // Sink guard (#1229 B): never record a non-pod-id token (ssh destination,
    // host/IP, path, or argv fragment) — it only ever GHOSTs in reconcile.
    if _pod_id_looks_valid(pod_id) == 0 {
        eprintln("[cloud] registry: refusing non-pod-id '" + pod_id
            + "' (expected a provider instance-id; use `cloud adopt <id>` to track an existing pod)")
        return
    }
    let dir = _reg_dir()
    let _ = exec("mkdir -p " + _reg_shq(dir) + " 2>/dev/null")
    let path = _reg_file()
    let now = _reg_now_iso()

    // Preserve the original created_at if this id is already tracked.
    let mut created = now
    let mut rebuilt = ""
    if file_exists(path) {
        let body = read_file(path)
        let lines = body.split("\n")
        let mut i = 0
        while i < len(lines) {
            let line = lines[i]
            if len(line) > 0 {
                let id = _reg_field(line, "pod_id")
                if id == pod_id {
                    let prev = _reg_field(line, "created_at")
                    if len(prev) > 0 {
                        created = prev
                    }
                    // drop the stale record; the fresh one is appended below
                } else {
                    rebuilt = rebuilt + line + "\n"
                }
            }
            i = i + 1
        }
    }

    let rec = "{\"pod_id\":\"" + _reg_jstr(pod_id) + "\","
        + "\"label\":\"" + _reg_jstr(label) + "\","
        + "\"created_at\":\"" + _reg_jstr(created) + "\","
        + "\"last_seen\":\"" + _reg_jstr(now) + "\","
        + "\"status\":\"" + _reg_jstr(status) + "\"}"
    rebuilt = rebuilt + rec + "\n"
    write_file(path, rebuilt)
}

// ── read verb (cloud orphans) ────────────────────────────────────────

// PodRow — one parsed registry record, plus the derived staleness flag.
struct PodRow {
    pod_id:     str,
    label:      str,
    created_at: str,
    last_seen:  str,
    status:     str,
    stale:      int    // 1 iff created > stale_hours ago and not closed
}

// pod_registry_rows — parse pods.jsonl into PodRow records, flagging each as
// stale when its created_at is older than `stale_hours` and its status is not
// "closed". Empty list when the registry file does not exist yet.
fn pod_registry_rows(stale_hours: int) -> [PodRow] {
    let mut rows = []
    let path = _reg_file()
    if !file_exists(path) {
        return rows
    }
    let now = _reg_now_sec()
    let threshold = stale_hours * 3600
    let body = read_file(path)
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if len(line) > 0 {
            let id = _reg_field(line, "pod_id")
            if len(id) > 0 {
                let created = _reg_field(line, "created_at")
                let status = _reg_field(line, "status")
                let mut stale = 0
                if status != "closed" && now > 0 {
                    let csec = _reg_iso_to_sec(created)
                    if csec > 0 && (now - csec) > threshold {
                        stale = 1
                    }
                }
                rows.push(PodRow {
                    pod_id: id,
                    label: _reg_field(line, "label"),
                    created_at: created,
                    last_seen: _reg_field(line, "last_seen"),
                    status: status,
                    stale: stale
                })
            }
        }
        i = i + 1
    }
    return rows
}

// cloud_orphans_print — render the registry to stdout, flagging stale pods.
// `stale_hours` is the age threshold (default caller passes 6). Returns the
// number of stale rows so the verb can set a nonzero exit when orphans exist.
fn cloud_orphans_print(stale_hours: int) -> int {
    let rows = pod_registry_rows(stale_hours)
    if len(rows) == 0 {
        println("[cloud] pod registry empty (" + _reg_file() + ")")
        println("[cloud] pods dispatched via `cloud run` / `cloud nohup` are tracked here.")
        return 0
    }
    println("POD/HOST                 STATUS    CREATED               LABEL          FLAG")
    let mut stale_n = 0
    let mut i = 0
    while i < len(rows) {
        let r = rows[i]
        let mut flag = "ok"
        if r.stale == 1 {
            flag = "STALE >" + str(stale_hours) + "h"
            stale_n = stale_n + 1
        }
        println(_reg_pad(r.pod_id, 24) + " " + _reg_pad(r.status, 9) + " "
            + _reg_pad(r.created_at, 21) + " " + _reg_pad(r.label, 14) + " " + flag)
        i = i + 1
    }
    println("[cloud] " + str(len(rows)) + " tracked · " + str(stale_n)
        + " stale (created > " + str(stale_hours) + "h ago, not closed) · " + _reg_file())
    return stale_n
}

// _reg_pad — right-pad `s` to `width` columns for a fixed-width table.
fn _reg_pad(s: str, width: int) -> str {
    let mut out = s
    let mut i = len(s)
    while i < width {
        out = out + " "
        i = i + 1
    }
    return out
}

// ── adopt / forget (write verbs) ──────────────────────────────────────

// pod_registry_adopt — register a previously-untracked pod into the
// registry so it regains a poll/pull/lifecycle handle. This is the
// recovery path for an ORPHAN found by reconcile (provider-RUNNING but
// absent from pods.jsonl). `label` carries the free-form purpose. Reuses
// pod_registry_record so the same-id de-dup + created_at preservation
// behaviour applies (re-adopting an id just refreshes last_seen). Returns
// 1 on success, 0 when the id is empty.
fn pod_registry_adopt(pod_id: str, label: str) -> int {
    if len(pod_id) == 0 {
        return 0
    }
    pod_registry_record(pod_id, label, "running")
    return 1
}

// pod_registry_forget — mark a tracked pod's record status=closed (the
// GHOST recovery path: registry-tracked but provider-gone). The record is
// kept (closed rows are excluded from staleness flagging) rather than
// deleted so the launch history survives. Returns 1 if the id was found
// and flipped, 0 if the id is absent / registry empty.
//
// Cleanup symmetry (INBOX 2026-05-28): `cloud reconcile` flags GHOST rows
// by their literal `pod_id` field, which for legacy rows can be an ssh-form
// (`root@<ip>` · `ssh1.vast.ai`), a bare IP, an alias (`ubu-2`), or even a
// `--help`-as-id edge case — values the #1229 `_pod_id_looks_valid` sink
// guard now rejects at WRITE time, but which already sit in the registry.
// forget MUST be able to close any of those (the reconcile→forget loop is
// otherwise half-closed: numeric GHOSTs forget, ssh-form GHOSTs accumulate
// forever). So this closes the matched row IN PLACE — a literal-match
// status flip that does NOT route through pod_registry_record, whose sink
// guard would refuse the very ssh-form/IP/alias ids we are cleaning up. The
// guard stays intact for record/adopt, so no NEW pollution enters; forget
// only closes what physically exists, regardless of id shape.
fn pod_registry_forget(pod_id: str) -> int {
    if len(pod_id) == 0 {
        return 0
    }
    let path = _reg_file()
    if !file_exists(path) {
        return 0
    }
    let body = read_file(path)
    let lines = body.split("\n")
    let now = _reg_now_iso()
    let mut found = 0
    let mut rebuilt = ""
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if len(line) > 0 {
            if found == 0 && _reg_field(line, "pod_id") == pod_id {
                // Close this row in place: preserve label + created_at, flip
                // status=closed, refresh last_seen. Rebuilt verbatim so an
                // ssh-form / IP / alias / flag-as-id row (legacy pollution
                // the write-side guard now blocks) can still be closed.
                found = 1
                let label = _reg_field(line, "label")
                let created = _reg_field(line, "created_at")
                rebuilt = rebuilt
                    + "{\"pod_id\":\"" + _reg_jstr(pod_id) + "\","
                    + "\"label\":\"" + _reg_jstr(label) + "\","
                    + "\"created_at\":\"" + _reg_jstr(created) + "\","
                    + "\"last_seen\":\"" + _reg_jstr(now) + "\","
                    + "\"status\":\"closed\"}\n"
            } else {
                rebuilt = rebuilt + line + "\n"
            }
        }
        i = i + 1
    }
    if found == 0 {
        return 0
    }
    write_file(path, rebuilt)
    return 1
}

// ── reconcile (ORPHAN / GHOST / OK classification) ────────────────────

// ReconRow — one classified pod after cross-referencing the registry
// against the provider's live pod list.
struct ReconRow {
    pod_id: str,
    label:  str,        // registry label, or "(unknown)" for an ORPHAN
    status: str,        // registry status, or "running" for a live ORPHAN
    klass:  str         // "ORPHAN" | "GHOST" | "OK"
}

// _recon_id_in — membership test for a pod id in a [str] list.
fn _recon_id_in(ids: [str], pod_id: str) -> int {
    let mut i = 0
    while i < len(ids) {
        if ids[i] == pod_id {
            return 1
        }
        i = i + 1
    }
    return 0
}

// pod_registry_reconcile_rows — classify every pod across the registry and
// the supplied provider id list. `provider_ids` is the set of pod ids the
// provider reports as live (from runpod_list_pods().pod_ids). A non-closed
// registry row whose id is absent from provider_ids is a GHOST; a registry
// row present in provider_ids is OK; a provider id absent from the registry
// is an ORPHAN. Closed registry rows that the provider no longer reports are
// skipped (already-reconciled history, not a ghost). Pure over its inputs —
// the caller fetches the provider list, so this is deterministically
// testable with a canned id list (no live runpodctl).
fn pod_registry_reconcile_rows(provider_ids: [str]) -> [ReconRow] {
    let mut out = []
    let rows = pod_registry_rows(0)   // 0h threshold: no staleness math needed here
    // Pass 1: every registry row → OK (in provider list) or GHOST (gone).
    let mut i = 0
    while i < len(rows) {
        let r = rows[i]
        if _recon_id_in(provider_ids, r.pod_id) == 1 {
            out.push(ReconRow { pod_id: r.pod_id, label: r.label, status: r.status, klass: "OK" })
        } else if r.status != "closed" {
            out.push(ReconRow { pod_id: r.pod_id, label: r.label, status: r.status, klass: "GHOST" })
        }
        i = i + 1
    }
    // Pass 2: every provider id not in the registry → ORPHAN.
    let mut p = 0
    while p < len(provider_ids) {
        let pid = provider_ids[p]
        let mut tracked = 0
        let mut k = 0
        while k < len(rows) {
            if rows[k].pod_id == pid {
                tracked = 1
                k = len(rows)
            } else {
                k = k + 1
            }
        }
        if tracked == 0 {
            out.push(ReconRow { pod_id: pid, label: "(unknown)", status: "running", klass: "ORPHAN" })
        }
        p = p + 1
    }
    return out
}

// cloud_reconcile_print — fetch the provider pod lists and print the
// ORPHAN/GHOST/OK reconcile table. Returns the count of ORPHAN+GHOST rows so
// the verb can exit nonzero when the registry and provider disagree.
//
// The registry is provider-agnostic (it tracks both runpod and vast pods),
// so reconcile MUST union BOTH provider live-id sets before classifying — a
// vast-provisioned pod that is RUNNING on vast.ai must not classify GHOST
// merely because the runpod list omits it (and vice versa). Querying only
// runpod was the GHOST-misclassification bug: every live vast instance fell
// through to GHOST. When a provider's CLI is unavailable its set is empty
// (the honest "I can't see that provider" degrade, distinct from a confirmed
// teardown) — only pods absent from BOTH live sets classify GHOST.
fn cloud_reconcile_print() -> int {
    let rl = runpod_list_pods()
    let vl = vast_list_instances()
    let mut provider_ids = []
    let mut ri = 0
    while ri < len(rl.pod_ids) {
        provider_ids.push(rl.pod_ids[ri])
        ri = ri + 1
    }
    let mut vi = 0
    while vi < len(vl.instance_ids) {
        provider_ids.push(vl.instance_ids[vi])
        vi = vi + 1
    }
    if rl.ok == 0 && vl.ok == 0 {
        println("[cloud] both provider lists unavailable (runpod: " + rl.message
            + " · vast: " + vl.message + ") — reconciling against empty set")
    } else if rl.ok == 0 {
        println("[cloud] runpod list unavailable (" + rl.message + ") — vast-only provider set")
    } else if vl.ok == 0 {
        println("[cloud] vast list unavailable (" + vl.message + ") — runpod-only provider set")
    }
    let rows = pod_registry_reconcile_rows(provider_ids)
    if len(rows) == 0 {
        println("[cloud] reconcile clean — no tracked pods and no live provider pods (" + _reg_file() + ")")
        return 0
    }
    println("POD/HOST                 STATUS    LABEL          CLASS")
    let mut drift = 0
    let mut i = 0
    while i < len(rows) {
        let r = rows[i]
        if r.klass != "OK" {
            drift = drift + 1
        }
        println(_reg_pad(r.pod_id, 24) + " " + _reg_pad(r.status, 9) + " "
            + _reg_pad(r.label, 14) + " " + r.klass)
        i = i + 1
    }
    println("[cloud] " + str(len(rows)) + " reconciled · " + str(drift)
        + " drift (ORPHAN=adopt|stop · GHOST=forget) · " + _reg_file())
    return drift
}

// ── M5 — agent-crash-safe pod registry @ ~/.hx/cloud/active-pods.json ─
//
// Canonical M5 SSOT (CLOUD.md M5): a single-file JSON registry written
// ATOMICALLY via temp-file + rename(2). The legacy JSONL above remains for
// backwards compat (read by `cloud orphans`/`cloud reconcile`). The new
// `~/.hx/cloud/active-pods.json` carries the richer per-pod record that M2
// (TTL deadman) and M3 (cost cap) extend in place — the schema reserves
// `ttl_sec` · `max_cost_usd` · `cumulative_cost_usd` keys NOW so no schema
// migration is needed when those milestones land.
//
// Crash-safety: every mutation writes `<path>.tmp.<pid>` first, then
// rename(2) to the final path. POSIX rename is atomic on the same fs, so a
// reader either sees the prior valid state or the new valid state, never a
// partial write. The dir + file are `chmod 700`/`600` (private — may hold
// ssh endpoints + provider ids).
//
// Wire points (additive — existing pod_registry_record/forget/adopt
// untouched): `cloud rent` success → pod_registry_add(...status=READY).
// `cloud down` confirmed teardown → pod_registry_remove(id). Status flips
// (STOPPING, GONE) go through pod_registry_update_status.

// _m5_dir / _m5_path — canonical M5 location (g13 $HOME-resolved).
fn _m5_dir() -> str {
    return env_var("HOME") + "/.hx/cloud"
}

fn pod_registry_path() -> str {
    return _m5_dir() + "/active-pods.json"
}

// _m5_pid — current process pid (for the temp-file suffix). Falls back to
// the timestamp ns when /bin/sh is unavailable so two near-simultaneous
// writes still pick distinct temp names.
fn _m5_pid() -> str {
    let s = exec("echo $$ 2>/dev/null").trim()
    if len(s) > 0 {
        return s
    }
    return exec("date +%s%N 2>/dev/null").trim()
}

// _m5_ensure_dir — mkdir -p the registry dir + chmod 700 (private).
fn _m5_ensure_dir() {
    let dir = _m5_dir()
    let _ = exec("mkdir -p " + _reg_shq(dir) + " 2>/dev/null && chmod 700 " + _reg_shq(dir) + " 2>/dev/null")
}

// PodRecord — one parsed M5 record. Fields mirror the JSON schema 1-to-1.
struct PodRecord {
    id:                    str,
    provider:              str,    // "runpod" | "vast" | "ssh"
    created_at:            str,    // ISO-8601 UTC
    rented_by:             str,    // optional agent tag ("" if absent)
    ssh_host:              str,
    ssh_port:              str,
    status:                str,    // "RENTING" | "READY" | "STOPPING" | "GONE"
    ttl_sec:               int,    // -1 = unset (M2 will populate)
    max_cost_usd:          str,    // "" = unset (M3; str to preserve "5.00")
    cumulative_cost_usd:   str     // "0.0" default (M3 will accrue)
}

// _m5_numfield — sniff the bare (unquoted) value of "key":value out of a
// flat JSON record, stopping at `,` or `}`. Returns "" if absent. Used for
// JSON-numeric/null fields (ttl_sec, cumulative_cost_usd) that the writer
// emits unquoted, which the quoted-string `_reg_field` reader cannot see.
fn _m5_numfield(rec: str, key: str) -> str {
    let marker = "\"" + key + "\":"
    let at = rec.index_of(marker)
    if at < 0 {
        return ""
    }
    let start = at + len(marker)
    let n = len(rec)
    let mut i = start
    while i < n {
        let c = rec.substring(i, i + 1)
        if c == "," || c == "}" {
            return rec.substring(start, i).trim()
        }
        i = i + 1
    }
    return rec.substring(start, n).trim()
}

// _m5_parse — minimal JSON-array reader for our flat schema. We do NOT
// pull in stdlib/alloc/json here to keep the M5 layer dependency-free
// (the legacy JSONL above also hand-rolls its parsing). Records are split
// on the top-level `},{` separator inside the "pods":[ ... ] array. Each
// record's fields are read via the same `_reg_field` helper used above.
fn _m5_parse_records(body: str) -> [PodRecord] {
    let mut out = []
    let pods_at = body.index_of("\"pods\":[")
    if pods_at < 0 {
        return out
    }
    let start = pods_at + 8
    // Scan to the matching closing `]` at brace-depth 0.
    let n = len(body)
    let mut i = start
    let mut depth = 0
    let mut end = -1
    while i < n {
        let c = body.substring(i, i + 1)
        if c == "{" {
            depth = depth + 1
        } else if c == "}" {
            depth = depth - 1
        } else if c == "]" && depth == 0 {
            end = i
            i = n
        }
        i = i + 1
    }
    if end < 0 {
        return out
    }
    let arr = body.substring(start, end)
    // Split on `},{` boundary (works because our writer emits records
    // separated by exactly `},{` with no whitespace).
    let chunks = arr.split("},{")
    let mut k = 0
    while k < len(chunks) {
        let mut rec = chunks[k]
        // Re-add the stripped braces (split removed them on both sides).
        if rec.index_of("{") != 0 {
            rec = "{" + rec
        }
        if rec.substring(len(rec) - 1, len(rec)) != "}" {
            rec = rec + "}"
        }
        let id = _reg_field(rec, "id")
        if len(id) > 0 {
            // `ttl_sec` is JSON-numeric/null — we hand-emit it unquoted, so
            // sniff the value directly out of the record bytes (_reg_field
            // only reads quoted strings).
            let mut ttl = -1
            let ttl_num = _m5_numfield(rec, "ttl_sec")
            if len(ttl_num) > 0 && ttl_num != "null" {
                ttl = _reg_atoi(ttl_num)
            }
            // `cumulative_cost_usd` likewise unquoted; default "0.0" when absent.
            let mut cum = _m5_numfield(rec, "cumulative_cost_usd")
            if len(cum) == 0 || cum == "null" {
                cum = "0.0"
            }
            out.push(PodRecord {
                id: id,
                provider: _reg_field(rec, "provider"),
                created_at: _reg_field(rec, "created_at"),
                rented_by: _reg_field(rec, "rented_by"),
                ssh_host: _reg_field(rec, "ssh_host"),
                ssh_port: _reg_field(rec, "ssh_port"),
                status: _reg_field(rec, "status"),
                ttl_sec: ttl,
                max_cost_usd: _reg_field(rec, "max_cost_usd"),
                cumulative_cost_usd: cum
            })
        }
        k = k + 1
    }
    return out
}

// pod_registry_load — read the canonical M5 file, return the parsed
// records. Empty list when the file is absent OR mid-write corrupt (the
// atomic-write contract makes the latter impossible, but degrade safely).
fn pod_registry_load() -> [PodRecord] {
    let path = pod_registry_path()
    if !file_exists(path) {
        return []
    }
    let body = read_file(path)
    if len(body.trim()) == 0 {
        return []
    }
    return _m5_parse_records(body)
}

// _m5_emit_record — serialize one PodRecord as a flat JSON object (no
// outer braces stripping; the array writer joins with `,`).
fn _m5_emit_record(r: PodRecord) -> str {
    let mut ttl_field = "null"
    if r.ttl_sec >= 0 {
        ttl_field = str(r.ttl_sec)
    }
    let mut cost_field = "0.0"
    if len(r.cumulative_cost_usd) > 0 {
        cost_field = r.cumulative_cost_usd
    }
    let mut max_cost_field = "null"
    if len(r.max_cost_usd) > 0 {
        max_cost_field = "\"" + _reg_jstr(r.max_cost_usd) + "\""
    }
    return "{\"id\":\"" + _reg_jstr(r.id) + "\","
        + "\"provider\":\"" + _reg_jstr(r.provider) + "\","
        + "\"created_at\":\"" + _reg_jstr(r.created_at) + "\","
        + "\"rented_by\":\"" + _reg_jstr(r.rented_by) + "\","
        + "\"ssh_host\":\"" + _reg_jstr(r.ssh_host) + "\","
        + "\"ssh_port\":\"" + _reg_jstr(r.ssh_port) + "\","
        + "\"status\":\"" + _reg_jstr(r.status) + "\","
        + "\"ttl_sec\":" + ttl_field + ","
        + "\"max_cost_usd\":" + max_cost_field + ","
        + "\"cumulative_cost_usd\":" + cost_field + "}"
}

// _m5_write_atomic — write the records to ~/.hx/cloud/active-pods.json
// via temp-file + rename(2). The temp file lives in the SAME directory
// as the target so rename is on the same fs (atomic). `chmod 600` runs
// on the temp BEFORE the rename so the final file is private from the
// moment it appears at its canonical path.
fn _m5_write_atomic(records: [PodRecord]) {
    _m5_ensure_dir()
    let path = pod_registry_path()
    let tmp = path + ".tmp." + _m5_pid()
    let mut body = "{\"version\":1,\"pods\":["
    let mut i = 0
    while i < len(records) {
        if i > 0 {
            body = body + ","
        }
        body = body + _m5_emit_record(records[i])
        i = i + 1
    }
    body = body + "]}\n"
    write_file(tmp, body)
    let _ = exec("chmod 600 " + _reg_shq(tmp) + " 2>/dev/null && mv -f " + _reg_shq(tmp) + " " + _reg_shq(path))
}

// _m5_find — return the index of `pod_id` in `records`, or -1.
fn _m5_find(records: [PodRecord], pod_id: str) -> int {
    let mut i = 0
    while i < len(records) {
        if records[i].id == pod_id {
            return i
        }
        i = i + 1
    }
    return -1
}

// pod_registry_add — register a freshly-rented pod. Idempotent on `id`
// (same id → update in place, preserving created_at). Returns 1 on
// success, 0 on empty id.
fn pod_registry_add(pod_id: str, provider: str, ssh_host: str, ssh_port: str, status: str) -> int {
    if len(pod_id) == 0 {
        return 0
    }
    if _pod_id_looks_valid(pod_id) == 0 {
        eprintln("[cloud] M5: refusing non-pod-id '" + pod_id + "'")
        return 0
    }
    let mut records = pod_registry_load()
    let now = _reg_now_iso()
    let agent_tag = env_var("HEXA_AGENT_TAG")
    let idx = _m5_find(records, pod_id)
    if idx >= 0 {
        // update in place, preserve created_at
        let prev = records[idx]
        records[idx] = PodRecord {
            id: pod_id,
            provider: provider,
            created_at: prev.created_at,
            rented_by: prev.rented_by,
            ssh_host: ssh_host,
            ssh_port: ssh_port,
            status: status,
            ttl_sec: prev.ttl_sec,
            max_cost_usd: prev.max_cost_usd,
            cumulative_cost_usd: prev.cumulative_cost_usd
        }
    } else {
        records.push(PodRecord {
            id: pod_id,
            provider: provider,
            created_at: now,
            rented_by: agent_tag,
            ssh_host: ssh_host,
            ssh_port: ssh_port,
            status: status,
            ttl_sec: -1,
            max_cost_usd: "",
            cumulative_cost_usd: "0.0"
        })
    }
    _m5_write_atomic(records)
    return 1
}

// pod_registry_update_status — flip a pod's status (READY → STOPPING,
// etc.). Returns 1 on a successful flip, 0 if `pod_id` is absent.
fn pod_registry_update_status(pod_id: str, status: str) -> int {
    if len(pod_id) == 0 {
        return 0
    }
    let mut records = pod_registry_load()
    let idx = _m5_find(records, pod_id)
    if idx < 0 {
        return 0
    }
    let prev = records[idx]
    records[idx] = PodRecord {
        id: prev.id,
        provider: prev.provider,
        created_at: prev.created_at,
        rented_by: prev.rented_by,
        ssh_host: prev.ssh_host,
        ssh_port: prev.ssh_port,
        status: status,
        ttl_sec: prev.ttl_sec,
        max_cost_usd: prev.max_cost_usd,
        cumulative_cost_usd: prev.cumulative_cost_usd
    }
    _m5_write_atomic(records)
    return 1
}

// pod_registry_remove — drop a pod from the registry (confirmed teardown).
// Returns 1 on a successful removal, 0 if `pod_id` is absent.
fn pod_registry_remove(pod_id: str) -> int {
    if len(pod_id) == 0 {
        return 0
    }
    let records = pod_registry_load()
    let idx = _m5_find(records, pod_id)
    if idx < 0 {
        return 0
    }
    let mut kept = []
    let mut i = 0
    while i < len(records) {
        if i != idx {
            kept.push(records[i])
        }
        i = i + 1
    }
    _m5_write_atomic(kept)
    return 1
}

// pod_registry_list — return only alive pods (status != "GONE"). External
// readers (`cloud reap`, dashboards) use this to enumerate live billing
// pods after an agent crash.
fn pod_registry_list() -> [PodRecord] {
    let all = pod_registry_load()
    let mut out = []
    let mut i = 0
    while i < len(all) {
        if all[i].status != "GONE" {
            out.push(all[i])
        }
        i = i + 1
    }
    return out
}

// ── M3 cost-cap field writers (additive on the M5 layer) ─────────────

// pod_registry_set_max_cost — persist `max_cost_usd` on `pod_id`.
fn pod_registry_set_max_cost(pod_id: str, max_cost_usd: str) -> int {
    if len(pod_id) == 0 { return 0 }
    let mut records = pod_registry_load()
    let idx = _m5_find(records, pod_id)
    if idx < 0 { return 0 }
    let p = records[idx]
    records[idx] = PodRecord {
        id: p.id, provider: p.provider, created_at: p.created_at,
        rented_by: p.rented_by, ssh_host: p.ssh_host, ssh_port: p.ssh_port,
        status: p.status, ttl_sec: p.ttl_sec,
        max_cost_usd: max_cost_usd, cumulative_cost_usd: p.cumulative_cost_usd
    }
    _m5_write_atomic(records)
    return 1
}

// pod_registry_set_cumulative — persist accrued spend on `pod_id`.
fn pod_registry_set_cumulative(pod_id: str, cumulative_usd: str) -> int {
    if len(pod_id) == 0 { return 0 }
    let mut records = pod_registry_load()
    let idx = _m5_find(records, pod_id)
    if idx < 0 { return 0 }
    let p = records[idx]
    records[idx] = PodRecord {
        id: p.id, provider: p.provider, created_at: p.created_at,
        rented_by: p.rented_by, ssh_host: p.ssh_host, ssh_port: p.ssh_port,
        status: p.status, ttl_sec: p.ttl_sec,
        max_cost_usd: p.max_cost_usd, cumulative_cost_usd: cumulative_usd
    }
    _m5_write_atomic(records)
    return 1
}
