// stdlib/cloud/cloud_cli.hexa — standalone CLI for the cloud dispatch lib.
//
// Run directly:  hexa run stdlib/cloud/cloud_cli.hexa <subcommand> ...
//
// Cycle A ships this as a standalone CLI only; wiring a `hexa cloud`
// subcommand into self/main.hexa (which needs a compiled bin/hexa-cloud)
// is a later deploy-adjacent step — see design.md Decision 5.

use "stdlib/cloud/cloud"
use "stdlib/cloud/pod_registry"
use "stdlib/cloud/preflight"
use "stdlib/cloud/watchdog"
use "stdlib/cloud/vast"
use "stdlib/cloud/runpod"
use "stdlib/cloud/dft_dispatch"
use "stdlib/cloud/pods_local"
use "stdlib/cloud/parallel_audit"
use "stdlib/cloud/providers_catalog"
use "stdlib/sys"

fn _cloud_help() {
    println("hexa cloud — structured-argv remote dispatch (cycle A)")
    println("")
    println("usage:")
    println("  cloud rent <provider> [--gpu T] [--image IMG] [--disk GiB] [--owner TAG] [--project NAME] [--query Q] [--max-wait-sec N] [--no-register]")
    println("                                                         provision a GPU pod (vast|runpod), wait ssh-ready, print host:port + id (alias: up)")
    println("                                                         --project NAME: owning project for the cross-project down-guard (default cwd git-repo basename, else 'unattributed')")
    println("                                                         --no-register: skip the default ./pods.json row write (rent auto-registers a PENDING work row by default — symmetry with nohup/fire --register; a deck-less rent then shows as a leak candidate)")
    println("                                                         --max-wait-sec N (default 180): bounded SSH-readiness gate; on timeout the rent auto-tears the billing pod down + exits 2 with verbatim verdict (M5 sigil: SSH-never-ready leak guard)")
    println("  cloud rm <id> [--provider P] [--force]                 CANONICAL teardown — confirm + destroy + forget (unifies down/destroy/forget). --provider inferred from registry when absent. --force skips confirm prompt. Idempotent: rm of an absent pod exits 0.")
    println("  cloud down <id> [--provider P] [--force]               (legacy alias of `cloud rm`) destroy a pod + forget it from the registry — REFUSES a cross-project kill (pod.project≠cwd project) unless --force")
    println("  cloud reboot <id> [--provider P]                       restart a pod's container (preserve disk) to recover a DARK pod — alive+billing but SSH-dropped; re-runs onstart hook → re-injects key. vast only (runpod console). QE jobs resume from .save")
    println("  cloud list [--provider P]                              list live pods (vast + runpod, or one via --provider)")
    println("  cloud status [--provider P]                            alias of list")
    println("  cloud preflight --params N [--gpu KEY] [opts...]        closed-form GPU mem-budget check (no pod/ssh)")
    println("  cloud preflight --kind dft-phonon --atoms N --nq M [--metallic] [--max-seconds S]  closed-form DFPT walltime sizing")
    println("  cloud run       <host> [conn] [--max-wall S] [--env K=V] [--source P] -- <argv...> run argv, wait, exit with its code")
    println("  cloud exec      <host> [conn] -- <shell-cmd>           run shell command via ssh (DEFAULT SHELL PARSES IT)")
    println("  cloud nohup     <host> <logfile> [conn] [--env K=V] [--source P] [--early-life-check N] [--register [<jid>]] -- <argv...>   background argv, print remote pid")
    println("                                                         --early-life-check N: after launch, sleep N s + poll once; exit 3 if pid already DIED (silent class-1 launch failure)")
    println("                                                         --register [<jid>]: auto-write a row to cwd's ./pods.json on success (bare = auto-jid `auto-<ts>-<host-short>`); replaces the advisory line (ghost-pod L2-auto)")
    println("                                                         on success also prints `__MONITOR_HANDLE__={host,pid,log,tail_cmd}` JSON one-liner (grep '^__MONITOR_HANDLE__=' to extract; Monitor bridge)")
    println("  cloud fire      <host> [--log <path>] [conn] [--env K=V] [--source P] [--early-life-check N] [--register [<jid>]] -- <argv...>   atomic nohup + auto-log + Monitor handle")
    println("                                                         like nohup but logfile is OPTIONAL — defaults to /tmp/cloud-<unix_ts>.log on the remote when --log omitted, so caller does not have to invent + thread the path")
    println("  cloud poll      <host> <pid> [conn]                    exit 0 if remote pid alive, else 1 (DEAD path also flips a PENDING ./pods.json row matching pid → FAIL; ghost-pod teardown auto-verdict)")
    println("  cloud tail      <host> <logfile> [conn] [--grep RE] [--until RE]   live-stream a remote log (Monitor bridge)")
    println("                                                         tail -F | sed -u: print --grep lines, terminal-first classify on default; explicit --until RE = legacy single block; follows forever if --until ''")
    println("                                                         default 3-tier verdict (failure-first): exit 0 = DONE · exit 3 = TIMEOUT-RESUMABLE (Maximum CPU time/max_seconds — RESUME) · exit 4 = CRASHED (non-zero STOP/routine error/segfault/OOM)")
    println("                                                         exit 255 = ssh transport drop · other = log truncated mid-stream (sed/tail pipe failed)")
    println("  cloud watch     <host> <pid> [conn] [--interval N] [--max-wait S] [--then-down <id> [--provider P]]")
    println("                                                         loop poll until pid dies (exit 0) / max-wait (124); optional teardown")
    println("  cloud ssh-port  <id> [--provider P]                    print live ssh host:port of a pod (vast|runpod)")
    println("  cloud resolve   <id> [--provider P]                    alias of ssh-port — pod-id → ssh host:port for run/copy-to")
    println("  cloud copy-to   <host> <local> <remote> [conn] [-r] [--verify-sha]  upload file/dir (scp; -r=tree; sha256 check)")
    println("  cloud copy-from <host> <remote> <local> [conn] [--resume] [--verify-sha]  download (scp; --resume=rsync; sha256 check)")
    println("  cloud orphans   [--hours N]                            list tracked pods, flag stale (>N h, default 6)")
    println("  cloud reconcile                                        cross-ref registry vs provider: ORPHAN/GHOST/OK")
    println("  cloud reap      [--provider P] [--apply]               M6: orphans alive on provider but absent from M5 registry · bare=dry-run · --apply=destroy")
    println("  cloud adopt     <pod_id> [--purpose TEXT] [--project NAME]  track an untracked (ORPHAN) pod (stamps M5 project/purpose for the down-guard)")
    println("  cloud forget    <pod_id|ssh-form|ip|alias>             (legacy — use `cloud rm` instead) mark a tracked (GHOST) pod status=closed")
    println("  cloud watchdog  [--threshold-min N] [--util-cap-pct N] [--kill]  idle-pod autokill sweep (DRY-RUN default)")
    println("                                                         COMPOSITE idle = uptime≥thr(min,def 60) AND util≤cap(%,def 5) AND no-compute-proc AND no-workdir — a slow-but-working pod (compute proc present) is NEVER killed")
    println("                                                         also cross-refs ./pods.json budget.cap: on breach → alert + (with --kill) tear down the lowest-value running pod (g64 honor-cap)")
    println("                                                         bare = DRY-RUN table (pod·age·util·has-proc·has-workdir·idle?·action); --kill enforces (needs RUNPOD_API_KEY / vast key)")
    println("  cloud dft-run   <deck-dir> [--go] [--query Q] [--walltime-h N] [--identity P] [--image I] [--disk G] [--owner T]")
    println("  cloud parallel-audit --physcores N --live-jobs N --ranks-per-job N --queued-decks N  (d_parallel_fire 위반 가드 — VIOLATION→exit1+split 제안)")
    println("                                                         guarded DFT el-ph (QE) dispatch; PREVIEW ($0) unless --go. deck: relax.in·ph.in·scf.in.head·scf.in.tail·pseudo/")
    println("  cloud pods                                              full work table from cwd's ./pods.json (per-project active pod/job manifest)")
    println("  cloud dispatch [tree|active|add|verdict|rm]            manage ./pods.json (update-form): bare = full table")
    println("    add     <job-id> <pod-id> <dir> [--host=H --provider=P --kind=K --stage=S --pid=N --watcher=W --watcher-output=P --verdict=V]")
    println("    verdict <job-id> <status>                            rewrite verdict + verdict_utc only (preserve other fields)")
    println("    rm      <job-id|pod-id>                              delete (refuses pod rm while jobs are still pinned)")
    println("    active                                               only verdict=PENDING jobs")
    println("    tree                                                 pod-grouped ASCII (orphan jobs at tail)")
    println("                                                         (distinct from `cloud orphans` — that scans GLOBAL ~/.hexa-cloud/pods.jsonl billing/orphan registry; `pods`/`dispatch` is the per-project work view)")
    println("  cloud help | version")
    println("")
    println("connection flags [conn] (before `--`):")
    println("  --port <n>      ssh to a non-22 port (RunPod / vast.ai)")
    println("  --insecure      accept a changing/unknown host key (ephemeral pods)")
    println("  --identity <p>  present a specific private key (-i p, IdentitiesOnly);")
    println("                  e.g. ~/.ssh/id_vast_anima for a vast-registered key")
    println("                  (#1155: default ~/.ssh/id_ed25519 is publickey-denied)")
    println("  --max-wall <s>  (run only) cap remote wall-clock at <s> seconds;")
    println("                  on expiry the remote command is killed and run")
    println("                  exits 124 (max-wall exceeded)")
    println("  --env <K=V>     (run/nohup) set a remote env var; repeatable.")
    println("                  K=V stays one argv token, so a value with spaces")
    println("                  survives remote word-splitting.")
    println("  --env-file <p>  (run/nohup) read K=V lines from <p> (blank and")
    println("                  #-comment lines skipped); each line acts as --env.")
    println("  --source <p>    (run/nohup/fire) dot-source remote file <p> BEFORE")
    println("                  the argv (repeatable, in order): wraps as")
    println("                  `bash -c '. <p> && exec <argv>'`. ssh runs a NON-")
    println("                  login shell so ~/.bashrc (conda init / module load)")
    println("                  is NOT sourced — without this, mpirun/toolchain are")
    println("                  off PATH and the job dies instantly (exit 127/243).")
    println("                  e.g. --source ~/miniforge3/etc/profile.d/conda.sh")
    println("                  (point at a script that also `conda activate <env>`).")
    println("  --early-life-check <s>  (nohup only) after the detached launch,")
    println("                  sleep <s> s then poll the remote pid once; exit 3 if")
    println("                  it already DIED (a launcher that execs and exits at")
    println("                  once) so the caller can tear the pod down instead of")
    println("                  burning a watchdog timeout on a job that never ran.")
    println("  --register [<jid>]  (nohup/fire) on a successful dispatch, write a")
    println("                  row to cwd's ./pods.json IN-PROCESS (no shell-out).")
    println("                  Bare form auto-generates jid = auto-<ts>-<host-short>;")
    println("                  explicit <jid> uses it as-is. Replaces the advisory")
    println("                  hint line — ghost-pod L2-auto. cwd = git toplevel")
    println("                  when in a repo, else literal pwd. A later `cloud")
    println("                  poll <host> <pid>` that returns DEAD auto-flips this")
    println("                  row's verdict PENDING→FAIL (conservative — bare poll")
    println("                  cannot see remote exit code; call `cloud dispatch")
    println("                  verdict <jid> PASS` to override).")
    println("  --grep <re>     (tail only) stream only lines matching the awk ERE")
    println("                  <re>; empty / absent = every line.")
    println("  --until <re>    (tail only) terminal behaviour. ABSENT = default")
    println("                  3-tier failure-first taxonomy → exit 0 DONE · 3")
    println("                  TIMEOUT-RESUMABLE · 4 CRASHED. An explicit ERE <re>")
    println("                  = legacy single block (print+quit exit 0 on first")
    println("                  match). Pass '' to follow forever (persistent Monitor).")
    println("  --resume        (copy-from) rsync --partial --append-verify; resume")
    println("                  an interrupted large-file pull (needs rsync >= 3.0).")
    println("  --recursive,-r  (copy-to) copy a directory tree (scp -r).")
    println("  --verify-sha    (copy-to/copy-from) after transfer, compare sha256 of")
    println("                  local vs remote; exit 103 mismatch / 104 if no sha tool.")
    println("")
    println("`run` uses structured argv — every token POSIX-quoted before ssh, so")
    println("no remote shell parsing / glob / /* */ comment mis-parse can corrupt")
    println("the command. Use `run` for program dispatch.")
    println("`exec` joins post-`--` tokens with single spaces and sends the result")
    println("to the remote login shell AS-IS — pipes / globs / redirects / shell")
    println("variables all parse on the remote side. Use `exec` for ad-hoc")
    println("inspection (`cd /work && nvidia-smi | head -5`); caller owns quoting.")
    println("`host` is an ssh destination or ~/.ssh/config alias.")
}

// _mh_json_str — JSON-encode a path-typed string for the __MONITOR_HANDLE__=
// one-liner emitted by `cloud nohup` (and later `cloud fire`). Escapes `"`
// and `\\`; other control chars are vanishingly unlikely in the only inputs
// (ssh host, remote logfile path). Mirrors the existing `__CLOUD_PID__=`
// marker shape — caller extracts with grep '^__MONITOR_HANDLE__='.
fn _mh_json_str(s: str) -> str {
    let mut out = "\""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\"" {
            out = out + "\\\""
        } else if c == "\\" {
            out = out + "\\\\"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out + "\""
}

// _cli_atoi — parse a non-negative decimal string; non-digits ignored.
fn _cli_atoi(s: str) -> int {
    let mut i = 0
    let mut v = 0
    let n = len(s)
    while i < n {
        let cc = char_code(s.substring(i, i + 1))
        if cc >= 48 && cc <= 57 {
            v = v * 10 + (cc - 48)
        }
        i = i + 1
    }
    return v
}

// _need_val — d4-generic value-flag validator. Given the flag KEY at av[i],
// return the value av[i+1] iff it exists AND does not itself look like a flag
// (`--*` / bare `--`). Otherwise emit a clear actionable error and exit(2),
// instead of silently swallowing the next flag as the value (the `--port
// --insecure` -> `Bad port '--insecure'` class of bug). Drives off the call
// site (every value-flag parser calls it) — no per-flag branch lives here.
fn _need_val(av: [str], i: int, key: str) -> str {
    if i + 1 >= len(av) {
        eprintln("[cloud] error: flag " + key + " needs a value, got end-of-args")
        exit(2)
    }
    let nxt = av[i + 1]
    if nxt == "--" || nxt.starts_with("--") {
        eprintln("[cloud] error: flag " + key + " needs a value, got '" + nxt + "'")
        exit(2)
    }
    return nxt
}
// _ttl_to_sec — parse a `--ttl` duration to seconds. Accepts a bare integer
// (seconds) or a `<N>s` / `<N>m` / `<N>h` suffix form. Empty / unparseable →
// -1 (UNSET, no TTL enforcement). M2 deadman uses this.
fn _ttl_to_sec(s: str) -> int {
    let n = len(s)
    if n == 0 {
        return -1
    }
    let last = s.substring(n - 1, n)
    let num = _cli_atoi(s)
    if num <= 0 {
        return -1
    }
    if last == "s" {
        return num
    }
    if last == "m" {
        return num * 60
    }
    if last == "h" {
        return num * 3600
    }
    return num
}

// _ssh_opts_cli — scan av[start..] (up to a "--" separator) for the
// connection flags --port <n> and --insecure, and build the ssh_opts list.
fn _ssh_opts_cli(av: [str], start: int) -> [str] {
    let mut opts = []
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" {
            i = len(av)
        } else if t == "--insecure" {
            opts.push("-o")
            opts.push("StrictHostKeyChecking=no")
            opts.push("-o")
            opts.push("UserKnownHostsFile=/dev/null")
            i = i + 1
        } else if t == "--identity" {
            // #1155: present a SPECIFIC private key (e.g. the vast-registered
            // ~/.ssh/id_vast_anima). Without this, hexa cloud's ssh offered
            // only the Mac default ~/.ssh/id_ed25519 — unregistered on vast →
            // `Permission denied (publickey)` on every direct-IP pod, forcing a
            // raw-ssh workaround OUTSIDE the sanctioned `hexa cloud` path.
            // IdentitiesOnly=yes stops ssh-agent keys from racing ahead of it.
            let idv = _need_val(av, i, "--identity")
            opts.push("-i")
            opts.push(idv)
            opts.push("-o")
            opts.push("IdentitiesOnly=yes")
            i = i + 2
        } else if t == "--port" {
            let pv = _need_val(av, i, "--port")
            opts.push("-p")
            opts.push(pv)
            i = i + 2
        } else if t == "--max-wall" {
            // run-verb wall cap (handled by _max_wall_cli) — skip flag+value
            // here so it never lands in ssh_opts.
            i = i + 2
        } else if t == "--early-life-check" {
            // nohup-verb early-death window (handled by _early_life_cli) —
            // skip flag+value here so it never lands in ssh_opts.
            i = i + 2
        } else if t == "--grep" || t == "--until" {
            // tail-verb filter / terminal regexes (handled by _flag_val) —
            // skip flag+value so a regex value never lands in ssh_opts.
            i = i + 2
        } else {
            i = i + 1
        }
    }
    return opts
}

// _max_wall_cli — scan av[start..] (up to a "--" separator) for the
// `--max-wall <sec>` run-verb flag and return the cap in seconds; 0 means
// no cap was given. Stops at "--" so a `--max-wall` token inside the remote
// argv is never consumed. Mirrors _ssh_opts_cli's pre-separator scan so the
// two coexist in the same [conn] region for the `run` verb.
fn _max_wall_cli(av: [str], start: int) -> int {
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" {
            return 0
        } else if t == "--max-wall" {
            return _cli_atoi(_need_val(av, i, "--max-wall"))
        }
        i = i + 1
    }
    return 0
}

// _early_life_cli — scan av[start..] (up to a "--" separator) for the
// _log_path_cli — scan av[start..] (up to a "--" separator) for `--log <path>`
// and return the path; "" means no --log was given (cloud_fire then
// auto-generates /tmp/cloud-<unix_ts>.log). Mirrors _early_life_cli's
// pre-separator scan.
fn _log_path_cli(av: [str], start: int) -> str {
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" { return "" }
        if t == "--log" {
            if i + 1 < len(av) { return av[i + 1] }
            return ""
        }
        i = i + 1
    }
    return ""
}

// `--early-life-check <sec>` nohup-verb flag and return the window in
// seconds; 0 means it was not given (check disabled). Stops at "--" so an
// `--early-life-check` token inside the remote argv is never consumed.
// Mirrors _max_wall_cli's pre-separator scan.
fn _early_life_cli(av: [str], start: int) -> int {
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" {
            return 0
        } else if t == "--early-life-check" {
            return _cli_atoi(_need_val(av, i, "--early-life-check"))
        }
        i = i + 1
    }
    return 0
}

// _register_cli — scan av[start..] (up to a "--" separator) for the
// `--register [<jid>]` flag. Three returns encoded as a single string:
//   ""                  — flag absent (no auto-register)
//   "__AUTO__"          — bare `--register` (caller auto-generates jid)
//   "<jid>"             — explicit `--register <jid>` (use this jid)
// A token right after --register that starts with "--" is treated as the
// NEXT flag, not the jid, so `--register --early-life-check 5` parses as
// bare register + early-life-check 5. Stops at "--" so `--register` inside
// the remote argv is never consumed.
fn _register_cli(av: [str], start: int) -> str {
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" {
            return ""
        } else if t == "--register" {
            if i + 1 < len(av) {
                let nxt = av[i + 1]
                if nxt == "--" || nxt.starts_with("--") {
                    return "__AUTO__"
                }
                return nxt
            }
            return "__AUTO__"
        }
        i = i + 1
    }
    return ""
}

// _host_short — collapse an ssh destination like "root@1.2.3.4" or
// "vast-anima.tail" into a short stable token suitable for an auto-jid
// suffix. Keeps [A-Za-z0-9-] only; collapses other chars to "-". Caps at
// 16 chars so the resulting jid stays a single readable token.
fn _host_short(host: str) -> str {
    let mut out = ""
    let mut i = 0
    let n = len(host)
    let mut start = 0
    // Skip past a leading "user@" — only the host part matters for the tag.
    let at_i = host.index_of("@")
    if at_i >= 0 { start = at_i + 1 }
    i = start
    let mut emitted = 0
    while i < n && emitted < 16 {
        let c = host.substring(i, i + 1)
        let cc = char_code(c)
        let is_alnum = (cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || (cc >= 97 && cc <= 122) || cc == 45
        if is_alnum {
            out = out + c
            emitted = emitted + 1
        } else if emitted > 0 && (len(out) == 0 || out.substring(len(out) - 1, len(out)) != "-") {
            out = out + "-"
            emitted = emitted + 1
        }
        i = i + 1
    }
    if len(out) == 0 { return "host" }
    return out
}

// _resolve_cwd — git-rooted repo dir when available, else literal `pwd`.
// Matches the advisory line's `"$(pwd)"` shape so a manual + auto-register
// land at the SAME pods.json (no split-ledger).
fn _resolve_cwd() -> str {
    let git_top = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
    if len(git_top) > 0 { return git_top }
    return exec("pwd").trim()
}

// _basename — last path segment of `p` (no trailing-slash handling needed
// for git-toplevel output, which never trails). "" → "".
fn _basename(p: str) -> str {
    let n = len(p)
    if n == 0 {
        return ""
    }
    let mut last = -1
    let mut i = 0
    while i < n {
        if p.substring(i, i + 1) == "/" {
            last = i
        }
        i = i + 1
    }
    return p.substring(last + 1, n)
}

// _resolve_project — the owning project for a pod, used by rent/up/run/nohup/
// adopt to STAMP attribution and by down/destroy to derive the cwd project for
// the cross-project kill-guard. An explicit `--project <name>` flag wins;
// otherwise fall back to the cwd git-repo basename (`git rev-parse
// --show-toplevel` → basename); only "unattributed" when cwd is not a git repo
// (so a pod rented from a non-repo shell is flagged, never silently mis-owned).
fn _resolve_project(av: [str], start: int) -> str {
    let flag = _flag_val(av, start, "--project", "")
    if len(flag) > 0 {
        return flag
    }
    let git_top = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
    if len(git_top) > 0 {
        return _basename(git_top)
    }
    return "unattributed"
}

// _cwd_project — the cwd's owning project (git-repo basename, else
// "unattributed"). The down-guard compares this against the target pod's
// stored project to refuse a cross-project teardown. NO --project override
// here: the guard must compare the REAL cwd, not an asserted one (--force is
// the only bypass).
fn _cwd_project() -> str {
    let git_top = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
    if len(git_top) > 0 {
        return _basename(git_top)
    }
    return "unattributed"
}

// _auto_register — Fix A worker. Build a synthetic argv that mirrors the
// `cloud dispatch add` positional contract (`<jid> <pod-id> <dir>` + named
// flags) and call pods_local_add in-process. Returns the jid actually
// written. Matches the advisory line's slotting: pid as pod-id, host via
// --host. cwd = git-root else pwd. Emits the `registered jid=...` line.
fn _auto_register(reg_token: str, host: str, pid: int) -> str {
    let mut jid = reg_token
    if jid == "__AUTO__" {
        jid = "auto-" + str(timestamp()) + "-" + _host_short(host)
    }
    let cwd = _resolve_cwd()
    let pid_s = str(pid)
    let mut synth = []
    synth.push(jid)
    synth.push(pid_s)
    synth.push(cwd)
    synth.push("--host=" + host)
    synth.push("--stage=running")
    synth.push("--verdict=PENDING")
    synth.push("--pid=" + pid_s)
    let _ = pods_local_add(synth, 0)
    println("[cloud] 📋 registered jid=" + jid + " in " + cwd + "/pods.json")
    return jid
}

// _rent_register_pods_json — Q2 worker. On a successful `cloud rent`, write a
// ./pods.json row IN-PROCESS so a freshly-rented pod can never become an
// untracked ghost (symmetry with nohup/fire `--register`). Reuses the SAME
// pods_local_add gateway as `cloud dispatch add` / `_auto_register` (d4 single
// dispatch — no duplicated writer). job-id = `rent-<ts>-<host-short>`; the
// PROVIDER pod-id is the pod-id; stage=rented, verdict=PENDING (no deck yet —
// that PENDING is exactly the leak signal the watchdog/operator looks for).
// cwd = git-root else pwd, so a manual + auto register land in one file.
fn _rent_register_pods_json(pod_id: str, host: str, provider: str, owner: str) -> str {
    let jid = "rent-" + str(timestamp()) + "-" + _host_short(host)
    let cwd = _resolve_cwd()
    let mut synth = []
    synth.push(jid)
    synth.push(pod_id)
    synth.push(cwd)
    if len(host) > 0 { synth.push("--host=" + host) }
    synth.push("--provider=" + provider)
    synth.push("--kind=rent")
    synth.push("--stage=rented")
    synth.push("--verdict=PENDING")
    let _ = pods_local_add(synth, 0)
    println("[cloud] 📋 registered jid=" + jid + " (pod " + pod_id + ") in " + cwd + "/pods.json — `cloud dispatch verdict " + jid + " PASS` once a deck lands")
    return jid
}

// _teardown_verdict_if_registered — Fix B worker. After `cloud poll`
// detects DEAD, scan ./pods.json's jobs for one whose `pid` matches the
// polled pid. On hit, rewrite verdict=FAIL (we do NOT have the remote
// exit code from a bare poll, so we default conservative — a launcher
// that wants PASS can call `cloud dispatch verdict <jid> PASS` itself).
// On miss, no-op (job was never registered → no advisory churn). Returns
// 1 iff a verdict was written, else 0.
fn _teardown_verdict_if_registered(pid: int) -> int {
    let path = "./pods.json"
    let r = exec_capture("test -e " + path + " && echo y")
    if r[0] != "y\n" { return 0 }
    let raw = read_file(path)
    if len(raw.trim()) == 0 { return 0 }
    let root = json_parse(raw)
    let jobs = json_object_get_object(root, "jobs")
    let job_ids = json_object_keys(jobs)
    let mut i = 0
    while i < len(job_ids) {
        let jid = job_ids[i]
        let j = json_object_get(jobs, jid)
        let jpid = json_object_get_int(j, "pid", 0)
        let verdict = json_object_get_str(j, "verdict", "")
        // Only re-verdict PENDING rows — never overwrite a caller-set
        // PASS/FAIL/DOWN. Matches "no escape hatch but no clobber" (s11).
        if jpid == pid && verdict == "PENDING" {
            let _ = pods_local_verdict(jid, "FAIL")
            println("[cloud] 📋 teardown verdict=FAIL jid=" + jid)
            return 1
        }
        i = i + 1
    }
    return 0
}

// _collect_after — argv elements after the first "--" at or past `start`;
// if there is no "--", every element from `start` onward.
fn _collect_after(av: [str], start: int) -> [str] {
    let mut sepi = -1
    let mut i = start
    while i < len(av) {
        if av[i] == "--" {
            sepi = i
            i = len(av)
        } else {
            i = i + 1
        }
    }
    let mut from = start
    if sepi >= 0 {
        from = sepi + 1
    }
    let mut out = []
    let mut k = from
    while k < len(av) {
        out.push(av[k])
        k = k + 1
    }
    return out
}

// _env_file_kvs — read a KEY=VALUE-per-line env file into a [str] of
// "KEY=VALUE" tokens. Blank lines and `#`-comment lines are skipped; a
// line is kept only if it carries a `=` past column 0. A missing file
// emits one warning and yields no tokens (the dispatch still proceeds).
fn _env_file_kvs(path: str) -> [str] {
    let mut out = []
    if !file_exists(path) {
        println("[cloud] warn: --env-file not found, ignoring: " + path)
        return out
    }
    let lines = read_file(path).split("\n")
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 0 && line.substring(0, 1) != "#" && line.index_of("=") > 0 {
            out.push(line)
        }
        i = i + 1
    }
    return out
}

// _env_args_cli — scan av[start..] (up to a "--" separator) for repeatable
// `--env KEY=VALUE` flags and `--env-file <path>` flags, returning the
// collected "KEY=VALUE" tokens in order. Stops at "--" so an --env token
// inside the remote argv is never consumed. Each KEY=VALUE stays a SINGLE
// argv element end-to-end, so a value with spaces survives remote word-
// splitting — the anima dispatch bug (shell `env K=v` word-split) these
// flags close.
fn _env_args_cli(av: [str], start: int) -> [str] {
    let mut out = []
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" {
            return out
        } else if t == "--env" {
            out.push(_need_val(av, i, "--env"))
            i = i + 2
        } else if t == "--env-file" {
            let fkvs = _env_file_kvs(_need_val(av, i, "--env-file"))
            let mut k = 0
            while k < len(fkvs) {
                out.push(fkvs[k])
                k = k + 1
            }
            i = i + 2
        } else {
            i = i + 1
        }
    }
    return out
}

// _with_env — prepend `env KEY=VALUE ...` to a structured argv so the
// remote command runs under the requested environment. Returns argv
// unchanged when there are no env tokens (the bare command, no `env`
// wrapper). `env` is POSIX-standard and present on every Linux pod image.
fn _with_env(env_kvs: [str], argv: [str]) -> [str] {
    if len(env_kvs) == 0 {
        return argv
    }
    let mut out = []
    out.push("env")
    let mut i = 0
    while i < len(env_kvs) {
        out.push(env_kvs[i])
        i = i + 1
    }
    let mut j = 0
    while j < len(argv) {
        out.push(argv[j])
        j = j + 1
    }
    return out
}

// _shq_src — single-quote-wrap a token for safe embedding in the `bash -c`
// shell string built by _with_source (escapes any internal single quote).
fn _shq_src(s: str) -> str {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            out = out + "'\\''"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out + "'"
}

// _source_args_cli — scan av[start..] (up to "--") for repeatable
// `--source <remote-path>` flags, returning the paths in order (mirror of
// _env_args_cli). A command launched over ssh runs in a NON-interactive,
// NON-login shell, so ~/.bashrc (where `conda init` + module/PATH setup live)
// is NOT sourced — `mpirun`/`ph.x`/toolchain binaries fall off PATH and the
// command dies instantly ("mpirun: command not found", exit 243/127). Setting
// individual vars via --env cannot replay a `conda activate` (a shell function,
// not a var). `--source <file>` dot-sources <file> on the remote BEFORE the
// argv runs, so the caller activates a conda env / loads modules determinist-
// ically. Repeatable; sourced in order.
fn _source_args_cli(av: [str], start: int) -> [str] {
    let mut out = []
    let mut i = start
    while i < len(av) {
        let t = av[i]
        if t == "--" {
            return out
        } else if t == "--source" {
            out.push(_need_val(av, i, "--source"))
            i = i + 2
        } else {
            i = i + 1
        }
    }
    return out
}

// _with_source — wrap a structured argv so the remote runs
// `bash -c '. <f1> && . <f2> && exec <argv>'`. Returns argv unchanged when
// there are no --source files. `exec` keeps the tracked PID identical to the
// final process (so cloud_nohup's `$!` is the real job, not a transient bash).
// Composes AFTER _with_env — the env-prefixed argv (`env K=V <cmd>`) becomes
// the exec target, so --source and --env stack cleanly.
fn _with_source(src: [str], argv: [str]) -> [str] {
    if len(src) == 0 {
        return argv
    }
    let mut sh = ""
    let mut i = 0
    while i < len(src) {
        sh = sh + ". " + _shq_src(src[i]) + " && "
        i = i + 1
    }
    sh = sh + "exec"
    let mut j = 0
    while j < len(argv) {
        sh = sh + " " + _shq_src(argv[j])
        j = j + 1
    }
    let mut out = []
    out.push("bash")
    out.push("-c")
    out.push(sh)
    return out
}

// _checked_host — guard the positional <host> token. Every cloud verb takes
// `<host>` FIRST, then [conn]/flags, then `-- <argv>`. A real ssh destination
// (user@host · alias · IP) NEVER starts with `--`, so a `--`-leading token in
// the host slot means the caller misplaced a flag (or omitted <host>) — the
// CLI used to silently treat it AS the host, ssh to it, and exit 255, which
// reads like a phantom "gateway outage". Reject it loudly instead (INBOX
// 2026-05-28 cloud gap 2, P1). Returns `h` unchanged for any legal host.
fn _checked_host(h: str) -> str {
    if len(h) >= 2 && h.substring(0, 2) == "--" {
        eprintln("[cloud] '" + h + "' looks like a flag, not a host — every verb is positional `<host> [--port N] [--insecure] ... -- <argv>` (flags go AFTER <host>, args AFTER `--`). Misplaced flag, or omitted <host>?")
        exit(2)
    }
    return h
}

// _flag_val — scan av[start..] for `<key> <value>` and return the value;
// `dflt` when the flag is ABSENT. When the key IS present but its value is
// missing or itself looks like a flag (`--*` / bare `--`), error+exit(2) via
// _need_val rather than silently swallowing the next flag (same value-flag
// guard as the positional consumers — driven by the call site, no per-flag
// branch).
fn _flag_val(av: [str], start: int, key: str, dflt: str) -> str {
    let mut i = start
    while i < len(av) {
        if av[i] == key {
            return _need_val(av, i, key)
        }
        i = i + 1
    }
    return dflt
}

// _has_flag — 1 iff `flag` appears anywhere in av[start..], else 0.
fn _has_flag(av: [str], start: int, flag: str) -> int {
    let mut i = start
    while i < len(av) {
        if av[i] == flag {
            return 1
        }
        i = i + 1
    }
    return 0
}

// _copy_from_run — pick the download path: rsync resume (R3) when
// `--resume` was given, else the plain scp+verify path. Branching here
// (not at the call site) keeps a single network op — resume never first
// scp's the whole file and then rsyncs it.
fn _copy_from_run(host: str, ssh_opts: [str], remote_path: str, local_path: str, want_resume: int) -> CloudResult {
    if want_resume == 1 {
        return cloud_copy_from_resume_opts(host, ssh_opts, remote_path, local_path)
    }
    return cloud_copy_from_opts(host, ssh_opts, remote_path, local_path)
}

// _copy_to_run — pick the upload path: `scp -r` directory tree (P5) when
// `--recursive`/`-r` was given, else single-file scp.
fn _copy_to_run(host: str, ssh_opts: [str], local_path: str, remote_path: str, want_recursive: int) -> CloudResult {
    if want_recursive == 1 {
        return cloud_copy_to_recursive_opts(host, ssh_opts, local_path, remote_path)
    }
    return cloud_copy_to_opts(host, ssh_opts, local_path, remote_path)
}

// _print_fail_tail — on a non-zero remote exit, re-surface the last `n`
// lines of captured output under a clear banner (P10) so the failure is
// visible at the bottom of a long log. No-op on success or empty output.
fn _print_fail_tail(out: str, exit_code: int, n: int) {
    if exit_code == 0 {
        return
    }
    if len(out) == 0 {
        return
    }
    let lines = out.split("\n")
    let total = len(lines)
    let mut from = total - n
    if from < 0 {
        from = 0
    }
    println("[cloud] ── exit " + str(exit_code) + " · last " + str(total - from) + " line(s) ──")
    let mut i = from
    while i < total {
        println(lines[i])
        i = i + 1
    }
}

// ── provisioning verbs (rent / down / list) ───────────────────────────
// These WIRE the lifecycle fns already implemented in stdlib/cloud/vast.hexa
// and stdlib/cloud/runpod.hexa into the `hexa cloud` surface (RFC 088/091).
// The CLI layer only parses argv + reads credentials (`secret get …`,
// ~/.ssh/*.pub) and records the result in the pod registry; the provider
// modules own the actual search / create / wait / destroy / list logic.

// _cloud_rent_vast — vast.ai provision path: search-offers → create → wait
// ssh-ready → register. Prints host:port + instance id. Returns the exit
// code (0 ok, 1 failure). The created instance is registered with the
// owner tag BEFORE the ssh wait so a slow boot / crash never leaks an
// untracked billing instance.
fn _cloud_rent_vast(av: [str], start: int) -> int {
    let image = _flag_val(av, start, "--image", "ubuntu:22.04")
    let disk = _cli_atoi(_flag_val(av, start, "--disk", "30"))
    let owner = _flag_val(av, start, "--owner", "(hexa-cloud rent)")
    // Project attribution (down-guard source) — explicit --project, else
    // cwd git-repo basename, else "unattributed". `owner` doubles as purpose.
    let project = _resolve_project(av, start)
    let query = _flag_val(av, start, "--query", "")
    // M1 — bounded SSH-readiness gate. Default 180s; 0/negative = legacy
    // unbounded (opt-in). Caps the rent so a ghost-RUNNING pod whose ssh
    // transport never comes up (exit 255 forever) can't bleed billing.
    let max_wait_sec = _cli_atoi(_flag_val(av, start, "--max-wait-sec", "180"))
    // M2/M3 — opt-in guard limits (stored in registry after READY).
    let ttl_sec = _ttl_to_sec(_flag_val(av, start, "--ttl", ""))
    let max_cost = _flag_val(av, start, "--max-cost-usd", "")
    let mut disk_gb = disk
    if disk_gb <= 0 {
        disk_gb = 30
    }
    // verified_only=1 → vast.hexa applies the campaign-proven default
    // filters (reliability>=0.95 + verified + rentable). An explicit
    // --query opts into the caller's raw predicate string instead.
    let offer = vast_search_offers(query, 1)
    if offer.ok == 0 {
        println("[cloud] rent vast: " + offer.message)
        return 1
    }
    println("[cloud] rent vast: picked offer " + offer.offer_id)
    let inst = vast_create(offer.offer_id, image, disk_gb)
    if inst.ok == 0 {
        // create failed → return the offer claim so a sibling can reuse it.
        vast_offer_release(offer.offer_id)
        println("[cloud] rent vast: " + inst.message)
        return 1
    }
    // Register IMMEDIATELY (before the ssh wait) so a billing instance is
    // never untracked, then release the offer claim (the rent succeeded).
    pod_registry_record(inst.instance_id, owner, "running")
    // M5 — crash-safe registry @ ~/.hx/cloud/active-pods.json (RENTING
    // before ssh-ready; flipped to READY below once ssh handshakes).
    let _ = pod_registry_add(inst.instance_id, "vast", project, owner, "", "", "RENTING")
    vast_offer_release(offer.offer_id)
    println("[cloud] rent vast: created instance " + inst.instance_id + " (owner=" + owner + ", registered)")
    // M1 — bounded SSH-readiness gate. Sleep cadence is 10s (vast boot is
    // not sub-10s anyway); tries = max(1, max_wait_sec / 10). 0 / negative
    // max_wait_sec restores legacy 30 × 20s = 600s.
    let sleep_each = 10
    let mut tries = 30
    let mut bounded = false
    if max_wait_sec > 0 {
        bounded = true
        tries = max_wait_sec / sleep_each
        if tries < 1 {
            tries = 1
        }
    } else {
        tries = 30
    }
    let mut wait_cadence = sleep_each
    if bounded == false {
        wait_cadence = 20
    }
    let ssh = vast_wait_ssh(inst.instance_id, tries, wait_cadence)
    if ssh.ok == 0 {
        if bounded {
            // Auto-teardown — the M1 contract. A billing pod whose ssh
            // never came up is a 100% loss; destroy it rather than leak.
            let v = vast_destroy(inst.instance_id)
            if v.ok == 1 {
                let _ = pod_registry_forget(inst.instance_id)
                println("[cloud] rent: SSH never ready within " + str(max_wait_sec) + "s, pod " + inst.instance_id + " destroyed")
            } else {
                println("[cloud] rent: SSH never ready within " + str(max_wait_sec) + "s, pod " + inst.instance_id + " ALIVE — manual destroy required (vast_destroy: " + v.message + ")")
            }
            return 2
        }
        println("[cloud] rent vast: " + ssh.message)
        println("[cloud] instance " + inst.instance_id + " is created + tracked; ssh not yet ready — re-check with: cloud list / vastai show instance " + inst.instance_id)
        return 1
    }
    println("[cloud] rent vast: READY " + ssh.host + ":" + ssh.port + " (root@" + ssh.host + " -p " + ssh.port + ")")
    let _ = pod_registry_add(inst.instance_id, "vast", project, owner, ssh.host, ssh.port, "READY")
    if ttl_sec >= 0 || len(max_cost) > 0 {
        // Capture the vast offer's hourly rate (dph_total) so the cost-cap can
        // accrue. "" when the offer JSON didn't carry dph (cost-cap inert, TTL ok).
        let _ = pod_registry_set_limits(inst.instance_id, ttl_sec, max_cost, offer.dph)
        println("[cloud] M2/M3 guard: ttl_sec=" + str(ttl_sec) + " max_cost_usd=" + max_cost + " rate=" + offer.dph + "/hr (enforced by `cloud watchdog`)")
    }
    // #1155 zero-flag: write the bare-IP Host block → ~/.ssh/config so a later
    // `cloud run root@<ip>` (or raw ssh) presents the vast key with no
    // --identity. No-op when no vast key is available (graceful).
    let _injected = vast_ssh_config_autoinject(inst.instance_id)
    if len(_injected) > 0 {
        println("[cloud] rent vast: ~/.ssh/config Host " + _injected + " → vast identity (auto · zero-flag ssh; #1155)")
    }
    // Q2 — auto-register a ./pods.json row by default (symmetry with nohup/fire
    // --register); `--no-register` opts out. Off the registry's billing-leak
    // defense (M5 global), this is the per-project work-manifest row so a deck-
    // less rent surfaces as a PENDING job in `cloud pods`.
    if _has_flag(av, start, "--no-register") == 0 {
        let _ = _rent_register_pods_json(inst.instance_id, ssh.host, "vast", owner)
    }
    println("instance_id=" + inst.instance_id)
    println("host=" + ssh.host)
    println("port=" + ssh.port)
    println("owner=" + owner)
    return 0
}

// _cloud_rent_runpod — runpod provision path: create (single GPU type) →
// wait ssh-ready → register. Auto-resolves the key via
// cloud_runpod_must_have_api_key (M7) and a public key at
// ~/.ssh/id_ed25519.pub (same contract as e2e_smoke.hexa). --gpu picks the
// GPU type (RunPod has no offer-search; the type IS the selector).
// Returns 0 ok / 1 failure.
fn _cloud_rent_runpod(av: [str], start: int) -> int {
    let api_key = cloud_runpod_must_have_api_key("rent")
    let pubkey = read_file(env_var("HOME") + "/.ssh/id_ed25519.pub").trim()
    if len(pubkey) == 0 {
        println("[cloud] rent runpod: no ~/.ssh/id_ed25519.pub")
        return 1
    }
    let gpu = _flag_val(av, start, "--gpu", "NVIDIA A100 80GB PCIe")
    let image = _flag_val(av, start, "--image", "runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04")
    let owner = _flag_val(av, start, "--owner", "(hexa-cloud rent)")
    // Project attribution (down-guard source) — explicit --project, else
    // cwd git-repo basename, else "unattributed". `owner` doubles as purpose.
    let project = _resolve_project(av, start)
    // M1 — bounded SSH-readiness gate (default 180s). The 2026-05-28
    // RunPod H100 SXM dump (pod RUNNING + ssh exit 255 forever) is the
    // motivating incident; without a cap a dead-ssh pod bleeds billing.
    let max_wait_sec = _cli_atoi(_flag_val(av, start, "--max-wait-sec", "180"))
    // M2/M3 — opt-in guard limits stored in the M5 registry after READY.
    // ttl: --ttl 30m/90s/3600 → deadman teardown. cost: --max-cost-usd 5.
    let ttl_sec = _ttl_to_sec(_flag_val(av, start, "--ttl", ""))
    let max_cost = _flag_val(av, start, "--max-cost-usd", "")
    let pod = runpod_create(api_key, gpu, image, pubkey, owner)
    if pod.ok == 0 {
        println("[cloud] rent runpod: " + pod.message)
        return 1
    }
    pod_registry_record(pod.pod_id, owner, "running")
    // M5 — crash-safe registry @ ~/.hx/cloud/active-pods.json (RENTING
    // before ssh-ready; flipped to READY below once ssh handshakes).
    let _ = pod_registry_add(pod.pod_id, "runpod", project, owner, "", "", "RENTING")
    println("[cloud] rent runpod: created pod " + pod.pod_id + " (owner=" + owner + ", registered)")
    // M1 — bounded path. sleep_each=10s; tries = max(1, max_wait_sec/10).
    // 0 / negative max_wait_sec restores legacy 40 × 15s = 600s unbounded.
    let sleep_each = 10
    let mut tries = 40
    let mut bounded = false
    let mut wait_cadence = 15
    if max_wait_sec > 0 {
        bounded = true
        tries = max_wait_sec / sleep_each
        if tries < 1 {
            tries = 1
        }
        wait_cadence = sleep_each
    }
    let port = runpod_wait_ssh(api_key, pod.pod_id, tries, wait_cadence)
    if port.ok == 0 {
        if bounded {
            // Auto-teardown — M1 contract. Idempotent: forget the registry
            // row only on a confirmed terminate; print ALIVE hint otherwise.
            let term_ok = runpod_terminate(api_key, pod.pod_id)
            if term_ok == 1 {
                let _ = pod_registry_forget(pod.pod_id)
                println("[cloud] rent: SSH never ready within " + str(max_wait_sec) + "s, pod " + pod.pod_id + " destroyed")
            } else {
                println("[cloud] rent: SSH never ready within " + str(max_wait_sec) + "s, pod " + pod.pod_id + " ALIVE — manual destroy required (runpod_terminate FAILED)")
            }
            return 2
        }
        println("[cloud] rent runpod: " + port.message)
        println("[cloud] pod " + pod.pod_id + " is created + tracked; ssh not yet ready — re-check with: cloud list")
        return 1
    }
    println("[cloud] rent runpod: READY " + port.ip + ":" + port.port + " (root@" + port.ip + " -p " + port.port + ")")
    let _ = pod_registry_add(pod.pod_id, "runpod", project, owner, port.ip, port.port, "READY")
    if ttl_sec >= 0 || len(max_cost) > 0 {
        // Capture the RunPod pod's hourly rate (`costPerHr`) so the M3 cost-cap
        // can accrue. Prefer the value the create response carried; if it was
        // absent (older runpodctl shapes) fall back to a `pod get` lookup. ""
        // when neither surfaces it (cost-cap inert, TTL still enforces).
        let mut rate = pod.cost_per_hr
        if len(rate) == 0 {
            rate = runpod_pod_cost_per_hr(api_key, pod.pod_id)
        }
        let _ = pod_registry_set_limits(pod.pod_id, ttl_sec, max_cost, rate)
        println("[cloud] M2/M3 guard: ttl_sec=" + str(ttl_sec) + " max_cost_usd=" + max_cost + " rate=" + rate + "/hr (enforced by `cloud watchdog`)")
    }
    // Q2 — auto-register a ./pods.json row by default; `--no-register` opts out.
    if _has_flag(av, start, "--no-register") == 0 {
        let _ = _rent_register_pods_json(pod.pod_id, port.ip, "runpod", owner)
    }
    println("pod_id=" + pod.pod_id)
    println("host=" + port.ip)
    println("port=" + port.port)
    println("owner=" + owner)
    return 0
}

// _cloud_down — destroy a pod by id, then forget it from the registry.
// --provider picks the teardown path; defaults to vast (runpod needs an
// api key). The registry forget runs regardless of the provider verdict
// so a confirmed-gone pod never lingers as a GHOST row.
// _down_guard_refuses — cross-project kill-guard (the near-miss fix: anima's
// RTSC pods were almost destroyed from another project's session). Look up the
// target pod's stored `project`, derive the cwd project, and REFUSE the
// teardown when they MISMATCH and the pod is attributed to a REAL project
// (not ""/"unattributed"). `--force` bypasses; same-project or unattributed
// pods behave as before. NO env-var opt-out (sidecar s11). Returns 1 = refuse
// (caller exits non-zero), 0 = allow.
fn _down_guard_refuses(id: str, force: int) -> int {
    if force == 1 {
        return 0
    }
    let records = pod_registry_load()
    let idx = _m5_find(records, id)
    if idx < 0 {
        // Untracked pod (orphan / never-registered) — no attribution to guard.
        return 0
    }
    let owner = records[idx].project
    if len(owner) == 0 || owner == "unattributed" {
        return 0
    }
    let cur = _cwd_project()
    if owner == cur {
        return 0
    }
    println("[cloud] REFUSE: pod " + id + " belongs to project '" + owner
        + "' (cwd='" + cur + "'). Re-run from that repo or pass --force.")
    return 1
}

fn _cloud_down(id: str, provider: str) -> int {
    // M5 — flag the pod STOPPING before issuing teardown, so an
    // agent-crash between here and provider-confirm still leaves an
    // external reader (cloud reap) a hint to retry teardown.
    let _ = pod_registry_update_status(id, "STOPPING")
    let mut ok = 0
    if provider == "runpod" {
        let api_key = cloud_runpod_must_have_api_key("down")
        ok = runpod_terminate(api_key, id)
        if ok == 1 {
            println("[cloud] down runpod: terminated " + id)
        } else {
            println("[cloud] down runpod: terminate FAILED for " + id + " — verify manually")
        }
    } else {
        let v = vast_destroy(id)
        ok = v.ok
        println("[cloud] down vast: " + v.message)
    }
    // Forget the registry row (status=closed) on a confirmed destroy.
    if ok == 1 {
        let _ = pod_registry_forget(id)
        let _ = pod_registry_remove(id)
        println("[cloud] forgot " + id + " (registry status=closed)")
        return 0
    }
    return 1
}

// _cloud_reboot — reboot (restart container of) a pod by id, preserving
// disk. (INBOX #1963) A vast.ai instance can stay alive+billing yet stop
// accepting SSH after a host migration / sshd restart; rebooting restarts
// the container so the image onstart hook re-injects authorized_keys, and
// in-flight QE jobs resume from their .save recovery files. --provider
// picks the path; only vast is wired (vast_reboot) — runpod reboot is not
// yet implemented, so it reports clearly and exits 2 instead of guessing.
fn _cloud_reboot(id: str, provider: str) -> int {
    if provider == "runpod" {
        println("[cloud] reboot: runpod reboot not yet wired — use `cloud rm` + re-rent, or reboot via the runpod console")
        return 2
    }
    let v = vast_reboot(id)
    println("[cloud] reboot vast: " + v.message)
    if v.ok == 1 {
        return 0
    }
    return 1
}

// _rm_lookup_provider — registry-aware provider inference for `cloud rm`.
// Loads ~/.hx/cloud/active-pods.json (M5 SSOT) and returns the provider
// string ("vast" / "runpod" / ...) for the matching pod_id. Empty string
// signals "not in registry" — caller then requires an explicit --provider.
// Registry-load failures (perms / corrupt) degrade to "" so the caller
// surfaces the explicit-provider requirement instead of guessing.
fn _rm_lookup_provider(id: str) -> str {
    if len(id) == 0 {
        return ""
    }
    let records = pod_registry_load()
    let mut i = 0
    while i < len(records) {
        if records[i].id == id {
            return records[i].provider
        }
        i = i + 1
    }
    return ""
}

// _rm_pod_in_registry — 1 iff `id` is tracked in the M5 registry. Used to
// route the idempotent "not found" exit path (registry + provider absent →
// exit 0 with informational verdict).
fn _rm_pod_in_registry(id: str) -> int {
    if len(id) == 0 {
        return 0
    }
    let records = pod_registry_load()
    let mut i = 0
    while i < len(records) {
        if records[i].id == id {
            return 1
        }
        i = i + 1
    }
    return 0
}

// _rm_confirm_yes — 1 iff the answer reads as affirmative ("y" / "yes",
// case-insensitive). Anything else (including empty, "n", "no", garbage)
// rejects — the prompt defaults to N for safety.
fn _rm_confirm_yes(ans: str) -> int {
    let t = ans.trim()
    if len(t) == 0 {
        return 0
    }
    if t == "y" || t == "Y" || t == "yes" || t == "YES" || t == "Yes" {
        return 1
    }
    return 0
}

// _cloud_rm — M4 canonical teardown verb. Unifies the scattered
// down/destroy/forget surfaces behind a single confirm-gated entry:
//   1. infer provider from the M5 registry when --provider is absent
//   2. if the pod is absent from BOTH registry and the caller did not
//      pass --provider, idempotent-exit 0 ("not found")
//   3. otherwise prompt "destroy this pod? [y/N]" unless force == 1
//   4. on confirm: provider-terminate (runpod_terminate / vast_destroy),
//      then pod_registry_remove + pod_registry_forget — registry cleanup
//      runs even on provider failure so a confirmed-gone pod never lingers
//   5. exit 0 on destroyed, 1 on provider-rejected, 2 on cancel
fn _cloud_rm(id: str, provider_in: str, force: int) -> int {
    if len(id) == 0 {
        println("[cloud] rm: empty <id>")
        return 2
    }
    // (1) infer provider from registry when caller did not pass one
    let mut provider = provider_in
    let in_reg = _rm_pod_in_registry(id)
    if len(provider) == 0 {
        provider = _rm_lookup_provider(id)
    }
    // (2) idempotent: not in registry AND no explicit provider → exit 0
    if len(provider) == 0 && in_reg == 0 {
        println("[cloud] rm: " + id + " not found (provider + registry) — nothing to do")
        return 0
    }
    if len(provider) == 0 {
        // Tracked but provider field empty (corrupt row) — require explicit.
        println("[cloud] rm: " + id + " — provider unknown, pass --provider <vast|runpod>")
        return 2
    }
    // (3) confirm gate (skipped on --force)
    if force == 0 {
        println("[cloud] rm " + id + " (provider=" + provider + "): destroy this pod? [y/N]")
        let ans = sys_stdin_read_line()
        if _rm_confirm_yes(ans) == 0 {
            println("[cloud] rm: cancelled (no destroy issued)")
            return 2
        }
    }
    // (4) flag STOPPING + provider teardown + registry cleanup
    let _ = pod_registry_update_status(id, "STOPPING")
    let mut ok = 0
    let mut why = ""
    if provider == "runpod" {
        let api_key = cloud_runpod_must_have_api_key("rm")
        ok = runpod_terminate(api_key, id)
        if ok == 1 {
            why = "runpod terminated"
        } else {
            why = "runpod terminate rejected"
        }
    } else {
        let v = vast_destroy(id)
        ok = v.ok
        why = "vast: " + v.message
    }
    // Registry cleanup runs regardless of provider verdict — a confirmed-
    // gone pod never lingers as a GHOST row. Mirrors _cloud_down semantics.
    let _ = pod_registry_forget(id)
    let _ = pod_registry_remove(id)
    if ok == 1 {
        println("[cloud] rm: destroyed " + id + " (" + why + ")")
        return 0
    }
    println("[cloud] rm: " + id + " destroy FAILED — " + why)
    return 1
}

// _cloud_list_print — print live pods. With --provider it queries one
// provider; bare it queries BOTH (vast + runpod). Read-only ($-free for
// vast: `show instances`; runpod: `runpod_list_pods`). Returns 0 always
// (an empty / failed list is informational, not an error).
fn _cloud_list_print(provider: str) -> int {
    let do_vast = provider == "" || provider == "vast"
    let do_runpod = provider == "" || provider == "runpod"
    if do_vast {
        let vl = vast_list_instances()
        println("[cloud] vast: " + vl.message)
        let mut i = 0
        while i < len(vl.instance_ids) {
            println("  vast   " + vl.instance_ids[i])
            i = i + 1
        }
    }
    if do_runpod {
        let rl = runpod_list_pods()
        println("[cloud] runpod: " + rl.message)
        let mut j = 0
        while j < len(rl.pod_ids) {
            println("  runpod " + rl.pod_ids[j])
            j = j + 1
        }
    }
    // M5 registry view — the crash-safe SSOT (~/.hx/cloud/active-pods.json),
    // which (unlike the provider live-id lists above) carries the project +
    // purpose attribution used by the cross-project down-guard. Empty registry
    // → no section (no clutter).
    let reg = pod_registry_list()
    if len(reg) > 0 {
        println("[cloud] registry (project attribution):")
        println("  ID                       PROVIDER  STATUS    PROJECT          PURPOSE")
        let mut k = 0
        while k < len(reg) {
            let r = reg[k]
            let mut proj = r.project
            if len(proj) == 0 {
                proj = "⚠unattributed"
            }
            println("  " + _reg_pad(r.id, 24) + " " + _reg_pad(r.provider, 9) + " "
                + _reg_pad(r.status, 9) + " " + _reg_pad(proj, 16) + " " + r.purpose)
            k = k + 1
        }
    }
    return 0
}

// _cloud_reap — M6 orphan finder + optional teardown. Enumerate the
// provider(s) live pod set + the M5 registry, then set-diff to find pods
// alive on the provider but absent from registry (billing leaks the M5
// SSOT can't see — an agent crashed mid-rent before registering).
//
// bare (apply=0) = dry-run table + summary line, exit 0.
// --apply (apply=1) = same enumeration + destroy each orphan via the
// existing _cloud_down path. Exit 0 on full success, 1 if any destroy
// failed. (`_cloud_down` already runs pod_registry_forget on the legacy
// JSONL + pod_registry_remove on the M5 SSOT through the rent wire.)
fn _cloud_reap(provider_scope: str, apply: int) -> int {
    let do_runpod = provider_scope == "" || provider_scope == "runpod"
    let do_vast = provider_scope == "" || provider_scope == "vast"
    // Registry ids — the canonical M5 active-pods.json (post-M5 SSOT).
    let reg = pod_registry_list()
    let mut reg_ids = []
    let mut ri = 0
    while ri < len(reg) {
        reg_ids.push(reg[ri].id)
        ri = ri + 1
    }
    // Provider id enumeration (per scope).
    let mut orphans = []
    if do_runpod {
        let rl = runpod_list_pods()
        if rl.ok == 0 {
            println("[cloud] reap: runpod list unavailable (" + rl.message + ") — skipping runpod scope")
        } else {
            let rp = pod_registry_orphans(rl.pod_ids, reg_ids, "runpod")
            let mut i = 0
            while i < len(rp) { orphans.push(rp[i]); i = i + 1 }
        }
    }
    if do_vast {
        let vl = vast_list_instances()
        if vl.ok == 0 {
            println("[cloud] reap: vast list unavailable (" + vl.message + ") — skipping vast scope")
        } else {
            let vp = pod_registry_orphans(vl.instance_ids, reg_ids, "vast")
            let mut j = 0
            while j < len(vp) { orphans.push(vp[j]); j = j + 1 }
        }
    }
    // Table — even when empty so the verb's contract is uniform.
    if len(orphans) == 0 {
        println("[cloud] reap: 0 orphans found · registry covers every alive pod")
        return 0
    }
    println("ID                       PROVIDER  ACTION")
    let mut k = 0
    while k < len(orphans) {
        let o = orphans[k]
        let mut act = "(dry-run)"
        if apply == 1 { act = "DESTROY" }
        println(_reg_pad(o.id, 24) + " " + _reg_pad(o.provider, 9) + " " + act)
        k = k + 1
    }
    if apply == 0 {
        println("[cloud] reap: " + str(len(orphans)) + " orphans found · use --apply to destroy")
        return 0
    }
    // --apply: route each orphan through _cloud_down. The legacy registry
    // forget on success is harmless (orphan is absent there too).
    let mut failed = 0
    let mut m = 0
    while m < len(orphans) {
        let o = orphans[m]
        let rc = _cloud_down(o.id, o.provider)
        if rc != 0 {
            failed = failed + 1
            println("[cloud] reap: FAILED to destroy " + o.id + " (" + o.provider + ")")
        }
        m = m + 1
    }
    println("[cloud] reap: " + str(len(orphans) - failed) + "/" + str(len(orphans))
        + " destroyed · " + str(failed) + " failed")
    if failed > 0 {
        return 1
    }
    return 0
}

// _cloud_ssh_port — print the live ssh endpoint (host + port) of an
// existing pod by id (P4). Wires runpod_get_ssh_port / vast_ssh_endpoint
// (the fns already exist; this only surfaces them as a verb). --provider
// default vast; runpod auto-resolves the key via cloud_runpod_must_have_api_key
// (M7: env-passthrough → Keychain → ~/.runpod/config.toml). Returns 0 when
// the endpoint is mapped, else 1.
fn _cloud_ssh_port(id: str, provider: str) -> int {
    if provider == "runpod" {
        let api_key = cloud_runpod_must_have_api_key("ssh-port")
        let r = runpod_get_ssh_port(api_key, id)
        if r.ok == 1 {
            println("[cloud] ssh-port runpod: " + r.ip + ":" + r.port + " (root@" + r.ip + " -p " + r.port + ")")
            println("host=" + r.ip)
            println("port=" + r.port)
            return 0
        }
        println("[cloud] ssh-port runpod: " + r.message)
        return 1
    }
    let v = vast_ssh_endpoint(id)
    if v.ok == 1 {
        println("[cloud] ssh-port vast: " + v.host + ":" + v.port + " (root@" + v.host + " -p " + v.port + ")")
        println("host=" + v.host)
        println("port=" + v.port)
        return 0
    }
    println("[cloud] ssh-port vast: " + v.message)
    return 1
}

// _cloud_watch — poll a remote pid every `interval` s until it dies (the
// auto-loop substitute for repeatedly calling `poll`, P3). Returns 0 when
// the pid is gone, 124 if `max_wait` s elapse first. `max_wait <= 0` waits
// unboundedly (the default "babysit until the job finishes" mode).
fn _cloud_watch(host: str, ssh_opts: [str], pid: int, interval: int, max_wait: int) -> int {
    let mut step = interval
    if step <= 0 {
        step = 30
    }
    let mut elapsed = 0
    while max_wait <= 0 || elapsed < max_wait {
        let alive = cloud_poll_opts(host, ssh_opts, pid)
        if alive == 0 {
            println("[cloud] watch: pid " + str(pid) + " DEAD after ~" + str(elapsed) + "s")
            return 0
        }
        let _ = exec("sleep " + str(step))
        elapsed = elapsed + step
    }
    println("[cloud] watch: pid " + str(pid) + " still ALIVE after max-wait " + str(max_wait) + "s (exit 124)")
    return 124
}

// _cloud_early_life_check — after a detached nohup launch, sleep `sec` s
// then poll the remote pid ONCE. Returns 0 if the process is still alive
// (it cleared the early-death window), else 3 — the silent class-1 failure
// mode where a launcher execs and dies immediately (bad script path, bad
// argv) while the pod keeps billing. A distinct nonzero return lets the
// caller tear the pod down at once instead of waiting out a watchdog
// timeout on a job that never started (the 158-min idle-burn anima fire).
fn _cloud_early_life_check(host: str, ssh_opts: [str], pid: int, sec: int) -> int {
    if sec <= 0 {
        return 0
    }
    let _ = exec("sleep " + str(sec))
    let alive = cloud_poll_opts(host, ssh_opts, pid)
    if alive == 1 {
        println("[cloud] early-life check OK — pid " + str(pid) + " alive after " + str(sec) + "s")
        return 0
    }
    println("[cloud] early-life check FAILED — pid " + str(pid) + " DIED within " + str(sec) + "s (silent class-1 launch failure; tear the pod down)")
    return 3
}

// Default `cloud tail` terminal mode (INBOX gap 1, 2026-05-28): when
// --until is ABSENT the tail handler routes to cloud_tail_cmd_taxonomy_opts,
// the 3-tier failure-first classifier — DONE (exit 0) / TIMEOUT-RESUMABLE
// (exit 3) / CRASHED (exit 4) — instead of the old "first marker match ==
// exit 0" that mis-read a walltime-timed-out QE job (which prints `Maximum
// CPU time exceeded` then a deceptive `JOB DONE` then `STOP 1`) as SUCCESS.
// The pattern TABLES live in stdlib/cloud/cloud.hexa (g20). An operator who
// wants the old single-block behaviour passes an explicit `--until <ere>`;
// `--until ''` still follows forever.

// _watchdog_budget_guard — Q4 budget cross-ref. Reads the per-project
// ./pods.json budget.cap (USD), compares it against the M5 registry's total
// accrued spend, and on a breach alerts + (when kill==1) tears down the
// LOWEST-VALUE running pod (cheapest accrued — claw spend back under cap with
// the least sunk loss; g64 honor-cap). No budget.cap declared → no-op.
// Returns 1 iff a breach was detected (whether or not a kill fired), else 0.
fn _watchdog_budget_guard(api_key: str, kill: int) -> int {
    let cap_usd = pods_local_budget_cap_usd()
    if len(cap_usd) == 0 {
        return 0
    }
    let cap_c = pod_registry_usd_to_cents(cap_usd)
    if cap_c <= 0 {
        return 0
    }
    let spent_c = pod_registry_total_accrued_cents()
    let cap_d = cap_c / 100
    let spent_d = spent_c / 100
    if spent_c < cap_c {
        println("[cloud] watchdog budget: $" + str(spent_d) + " accrued / $" + cap_usd + " cap — under budget")
        return 0
    }
    println("[cloud] ⚠ watchdog budget BREACH: $" + str(spent_d) + " accrued ≥ $" + cap_usd + " cap (./pods.json)")
    let victim = pod_registry_lowest_value_id()
    if len(victim) == 0 {
        println("[cloud] watchdog budget: no running pod to sacrifice")
        return 1
    }
    let provider = pod_registry_provider_of(victim)
    if kill == 0 {
        println("[cloud] watchdog budget: DRY-RUN — would kill lowest-value pod " + victim + " (" + provider + "); pass --kill to enforce")
        return 1
    }
    println("[cloud] watchdog budget: killing lowest-value pod " + victim + " (" + provider + ") to honor cap")
    let _ = _cloud_down(victim, provider)
    return 1
}

fn main() {
    let av = args()
    let mut si = -1
    let mut sub = ""
    let mut i = 0
    while i < len(av) {
        let t = av[i]
        if si < 0 {
            if t == "rent" || t == "up" || t == "rm" || t == "down" || t == "destroy" || t == "list" || t == "status" || t == "preflight" || t == "watchdog" || t == "run" || t == "exec" || t == "nohup" || t == "fire" || t == "poll" || t == "tail" || t == "watch" || t == "ssh-port" || t == "resolve" || t == "copy-to" || t == "copy-from" || t == "orphans" || t == "reconcile" || t == "reap" || t == "adopt" || t == "forget" || t == "dft-run" || t == "parallel-audit" || t == "pods" || t == "dispatch" || t == "providers" || t == "help" || t == "--help" || t == "-h" || t == "version" || t == "--version" || t == "-v" {
                si = i
                sub = t
            }
        }
        i = i + 1
    }
    if si < 0 {
        _cloud_help()
        return
    }
    if sub == "help" || sub == "--help" || sub == "-h" {
        _cloud_help()
        return
    }
    if sub == "version" || sub == "--version" || sub == "-v" {
        println("hexa cloud 0.5.0 — leak-guard: `rent` auto-registers a ./pods.json row by default (--no-register opts out) · `watchdog` COMPOSITE idle classifier (uptime≥thr AND util≤cap AND no-compute-proc AND no-workdir — slow-but-working pod NEVER killed) + ./pods.json budget.cap cross-ref (breach → kill lowest-value pod) · [0.4.1: rent --max-wait-sec bounded SSH gate · 0.4.0: nohup/fire --register · 0.3.x: resolve/ssh-config/identity/registry-guard/dft-run]")
        return
    }
    if sub == "rent" || sub == "up" {
        // Provision a GPU pod. The first post-verb token is the provider
        // (vast|runpod); flags follow. Wires vast.hexa / runpod.hexa
        // lifecycle fns + pod_registry. $-INCURRING — the only verb that
        // creates a billing instance.
        if si + 1 >= len(av) {
            println("[cloud] rent: missing <provider> — usage: cloud rent <vast|runpod> [--gpu T] [--image IMG] [--disk GiB] [--owner TAG] [--query Q] [--max-wait-sec N]")
            exit(2)
        }
        let provider = av[si + 1]
        if provider == "vast" {
            exit(_cloud_rent_vast(av, si + 2))
        }
        if provider == "runpod" {
            exit(_cloud_rent_runpod(av, si + 2))
        }
        println("[cloud] rent: unknown provider '" + provider + "' — expected vast or runpod")
        exit(2)
    }
    if sub == "rm" {
        // M4 canonical teardown — unifies down/destroy/forget behind a
        // confirm-gated entry. --provider inferred from the M5 registry
        // when absent; --force skips the confirm prompt. Idempotent: rm
        // of an absent pod exits 0. Exit 0 destroyed · 1 provider-rejected
        // · 2 cancel / usage.
        if si + 1 >= len(av) {
            println("[cloud] rm: missing <id> — usage: cloud rm <id> [--provider vast|runpod] [--force]")
            exit(2)
        }
        let id = av[si + 1]
        let provider = _flag_val(av, si + 2, "--provider", "")
        let force = _has_flag(av, si + 2, "--force")
        exit(_cloud_rm(id, provider, force))
    }
    if sub == "down" || sub == "destroy" {
        // (legacy alias of `cloud rm` — kept for back-compat with deployed
        // automation; new callers should prefer `cloud rm`.) Destroy a pod
        // by id + forget it from the registry. --provider selects the
        // teardown path (default vast). Wires vast_destroy /
        // runpod_terminate + pod_registry_forget.
        if si + 1 >= len(av) {
            println("[cloud] down: missing <id> — usage: cloud down <id> [--provider vast|runpod]")
            exit(2)
        }
        let id = av[si + 1]
        let provider = _flag_val(av, si + 2, "--provider", "vast")
        // Cross-project kill-guard — refuse a teardown of a pod owned by a
        // different project unless --force. (The anima RTSC near-miss fix.)
        let force = _has_flag(av, si + 2, "--force")
        if _down_guard_refuses(id, force) == 1 {
            exit(3)
        }
        exit(_cloud_down(id, provider))
    }
    if sub == "reboot" {
        // (INBOX #1963) Restart a pod's container (preserving disk) to
        // recover a dark pod — one that is alive+billing but no longer
        // accepting SSH (host migration / sshd restart dropped its
        // authorized_keys). The reboot re-runs the image onstart hook that
        // re-injects the key; in-flight QE jobs resume from .save recovery
        // files. --provider selects the path (default vast; runpod not yet
        // wired). Exit 0 reboot-confirmed · 1 provider-rejected · 2 usage.
        if si + 1 >= len(av) {
            println("[cloud] reboot: missing <id> — usage: cloud reboot <id> [--provider vast|runpod]")
            exit(2)
        }
        let id = av[si + 1]
        let provider = _flag_val(av, si + 2, "--provider", "vast")
        exit(_cloud_reboot(id, provider))
    }
    if sub == "list" || sub == "status" {
        // List live pods (read-only, $-free). Bare → both providers;
        // --provider <p> narrows. Wires vast_list_instances /
        // runpod_list_pods.
        let provider = _flag_val(av, si + 1, "--provider", "")
        exit(_cloud_list_print(provider))
    }
    if sub == "preflight" {
        // Closed-form GPU memory budget check. No ssh / pod-spinup / LLM —
        // pure arithmetic on the workload spec (preflight.hexa). The post-
        // verb argv (av[si+1..]) is forwarded to preflight_run, which parses
        // --params / --gpu / --optimizer / ... and exits 0 (fits) / 1
        // (invalid args / help) / 2 (budget exceeds cap).
        let rc = preflight_run(av, si + 1)
        exit(rc)
    }
    if sub == "watchdog" {
        // Idle-pod autokill sweep (1 cycle). DRY-RUN by default — only an
        // explicit `--kill` / `--no-dry-run` (post-verb, needs RUNPOD_API_KEY)
        // actually terminates. The post-verb argv (av[si+1..]) is forwarded
        // to watchdog_run, which parses --threshold-min / --util-cap-pct /
        // --kill and exits 0 (clean sweep) / 1 (invalid args / help) / 2
        // (sweep failed: no runpodctl / no pods / list error).
        //
        // M2/M3 — registry limit sweep runs FIRST: tear down pods that opted
        // into `--ttl` (deadman) or `--max-cost-usd` (cost cap) and breached.
        // DRY-RUN unless `--kill`; only --kill resolves the runpod key (so a
        // dry-run with no runpod pods needs no creds). Opt-in invariant: pods
        // with no limit set are never touched.
        let m23_kill = _has_flag(av, si + 1, "--kill")
        // SOFT runpod key (M7 secret-get path, non-exiting): "" when absent
        // so a vast-only sweep doesn't die on a missing runpod key.
        let m23_key = exec("secret get runpod.api_key 2>/dev/null").trim()
        if m23_kill == 1 {
            let n = pod_registry_limit_sweep(m23_key, 0)
            if n > 0 {
                println("[cloud] watchdog: " + str(n) + " pod(s) torn down by M2/M3 limit (ttl/cost)")
            }
        } else {
            let _ = pod_registry_limit_sweep("", 1)
        }
        // Q3 — COMPOSITE idle sweep over the M5 registry (the RTSC leak-guard):
        // idle = uptime≥thr AND util≤cap AND no-compute-proc AND no-workdir.
        // A slow-but-working pod (compute proc present) is NEVER killed. Honors
        // the same --threshold-min / --util-cap-pct flags; DRY-RUN unless --kill.
        let wd_thr = _cli_atoi(_flag_val(av, si + 1, "--threshold-min", "60"))
        let wd_cap = _cli_atoi(_flag_val(av, si + 1, "--util-cap-pct", "5"))
        let mut wd_thr_eff = wd_thr
        if wd_thr_eff < 5 { wd_thr_eff = 60 }
        let wd_dry = 1 - m23_kill
        let _ic = composite_watchdog_sweep(m23_key, wd_thr_eff, wd_cap, wd_dry)
        // Q4 — budget cross-ref: if ./pods.json declares budget.cap and current
        // accrued spend breaches it, alert + (on --kill) tear down the lowest-
        // value running pod (g64 honor-cap — sacrifice the cheapest first).
        let _bg = _watchdog_budget_guard(m23_key, m23_kill)
        // Legacy runpod util sweep (kept for the runpodctl-only path / back-compat).
        let rc = watchdog_run(av, si + 1)
        exit(rc)
    }
    if sub == "parallel-audit" {
        // d_parallel_fire 위반 가드 (T2). pod 의 live state 를 flag 로 받아
        // single-pod-sequential-queue 위반(1 live job + queued decks + spare
        // cores)을 순수 감사하고, VIOLATION → exit 1 + split 제안 · OK → exit 0.
        // 네트워크/pod 접근 없음 — 호출자가 physcores/live/ranks/queued 를 전달.
        let rc = parallel_audit_run(av, si + 1)
        exit(rc)
    }
    if sub == "dft-run" {
        // Guarded DFT el-ph pod dispatch (QE pw.x/ph.x). PREVIEW by default
        // ($0: validate deck + plan + parse a local relax.out); --go rents a
        // billing pod and runs the rent/transport/chain/monitor-guarded chain.
        // Encodes the demiurge RTSC checklist (dft_dispatch.hexa, INBOX #1249).
        let rc = dft_run(av, si + 1)
        exit(rc)
    }
    if sub == "pods" {
        // Per-project active pod/job work manifest at cwd's ./pods.json.
        // Bare form = full table render (operator's "what is running here
        // right now?" view). Distinct from `cloud orphans` / pod_registry
        // (global ~/.hexa-cloud/pods.jsonl — billing/orphan defense).
        exit(pods_local_print_table(false))
    }
    if sub == "dispatch" {
        // Manage the per-project ./pods.json manifest:
        //   bare      → full table (same as `cloud pods`)
        //   tree      → pod-grouped ASCII (orphans at tail)
        //   active    → verdict=PENDING jobs only
        //   add       → add/overwrite a job entry (auto-stubs pod entry)
        //   verdict   → rewrite verdict + verdict_utc (preserve other fields)
        //   rm        → delete a job (then pod, refused if pod has pinned jobs)
        // update-form: each add rewrites the full job entry; verdict touches
        // only the verdict fields; rm deletes. Atomic write + .bak rotation.
        exit(pods_local_dispatch(av, si + 1))
    }
    if sub == "providers" {
        // Read-only compute-provider resource catalog (CLOUD M8/M9) at
        // ~/.hx/cloud/providers.json (decision reference for `cloud rent` —
        // which provider, what cost, what walltime speedup). Subverbs:
        //   bare/list → all tiers · fit → best-fit (fit_score=3) · recommend
        //   → current campaign recommendation. Hand-curated catalog, no write
        //   verb (seed from a PROVIDERS.json). Distinct from `pods`/`dispatch`
        //   (runtime work state) and `orphans`/`reconcile` (billing registry).
        exit(providers_catalog_dispatch(av, si + 1))
    }
    if sub == "run" {
        if si + 1 >= len(av) {
            println("[cloud] run: missing <host> — usage: cloud run <host> [--port N] [--insecure] -- <argv...>")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let ssh_opts = _ssh_opts_cli(av, si + 2)
        let max_wall = _max_wall_cli(av, si + 2)
        let env_kvs = _env_args_cli(av, si + 2)
        let mut argv = _collect_after(av, si + 2)
        if len(argv) == 0 {
            println("[cloud] run: empty argv — usage: cloud run <host> [--port N] [--insecure] [--max-wall S] [--env K=V] [--source P] -- <argv...>")
            exit(2)
        }
        argv = _with_env(env_kvs, argv)
        argv = _with_source(_source_args_cli(av, si + 2), argv)
        let r = cloud_run_wall_opts(host, ssh_opts, argv, max_wall)
        // NOTE (#1229 B): `run` does NOT register the host. The registry holds
        // provider pod-ids (for reconcile vs the provider live set), and `host`
        // is an ssh destination (`root@<ip>`), not a pod-id — recording it
        // poisoned the table with phantom GHOST rows. The pod is tracked at
        // `rent`/`adopt` time by its real id; `run` is a host operation.
        if len(r.stdout_) > 0 {
            println(r.stdout_)
        }
        println("[cloud] " + r.message)
        _print_fail_tail(r.stdout_, r.exit_code, 30)
        exit(r.exit_code)
    }
    if sub == "exec" {
        if si + 1 >= len(av) {
            println("[cloud] exec: missing <host> — usage: cloud exec <host> [--port N] [--insecure] -- <shell-cmd>")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let ssh_opts = _ssh_opts_cli(av, si + 2)
        let tokens = _collect_after(av, si + 2)
        if len(tokens) == 0 {
            println("[cloud] exec: empty shell-cmd — usage: cloud exec <host> [--port N] [--insecure] -- <shell-cmd>")
            exit(2)
        }
        let mut cmd_str = ""
        let mut ei = 0
        while ei < len(tokens) {
            if ei > 0 {
                cmd_str = cmd_str + " "
            }
            cmd_str = cmd_str + tokens[ei]
            ei = ei + 1
        }
        let r = cloud_exec_opts(host, ssh_opts, cmd_str)
        if len(r.stdout_) > 0 {
            println(r.stdout_)
        }
        println("[cloud] " + r.message)
        _print_fail_tail(r.stdout_, r.exit_code, 30)
        exit(r.exit_code)
    }
    if sub == "nohup" {
        if si + 2 >= len(av) {
            println("[cloud] nohup: usage — cloud nohup <host> <logfile> [--port N] [--insecure] [--early-life-check N] [--env K=V] [--source P] [--register [<jid>]] -- <argv...>")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let logfile = av[si + 2]
        let ssh_opts = _ssh_opts_cli(av, si + 3)
        let env_kvs = _env_args_cli(av, si + 3)
        let early_life = _early_life_cli(av, si + 3)
        let reg_token = _register_cli(av, si + 3)
        let mut argv = _collect_after(av, si + 3)
        if len(argv) == 0 {
            println("[cloud] nohup: empty argv — usage: cloud nohup <host> <logfile> [--port N] [--insecure] [--early-life-check N] [--env K=V] [--source P] [--register [<jid>]] -- <argv...>")
            exit(2)
        }
        argv = _with_env(env_kvs, argv)
        argv = _with_source(_source_args_cli(av, si + 3), argv)
        let r = cloud_nohup_opts(host, ssh_opts, argv, logfile)
        // NOTE (#1229 B): `nohup` does NOT register the host (see `run` above) —
        // `host` is an ssh destination, not a provider pod-id. Tracking happens
        // at `rent`/`adopt`; recording the host poisoned reconcile with GHOSTs.
        if len(r.stdout_) > 0 {
            println(r.stdout_)
        }
        println("[cloud] " + r.message)
        // __MONITOR_HANDLE__= : grep-able JSON one-liner so a harness (Monitor
        // attach, micro-exp batch driver, a wrapping skill) can pick up host +
        // pid + logfile + ready-to-run tail_cmd without parsing the human
        // [cloud] message. Mirrors the existing __CLOUD_PID__= marker pattern.
        // Emitted only on a successful dispatch with a known logfile path.
        if r.ok == 1 && len(r.logfile) > 0 {
            println("__MONITOR_HANDLE__={"
                + "\"host\":" + _mh_json_str(host)
                + ",\"pid\":" + str(r.pid)
                + ",\"log\":" + _mh_json_str(r.logfile)
                + ",\"tail_cmd\":" + _mh_json_str("hexa cloud tail " + host + " " + r.logfile)
                + "}")
            // ghost-pod 자동 차단 — `--register` 가 있으면 in-process로 ./pods.json
            // 갱신 (Fix A, PR L2-auto). 없으면 기존 advisory line 유지 (PR #1769 L2-aware).
            if len(reg_token) > 0 {
                let _ = _auto_register(reg_token, host, r.pid)
            } else {
                println("[cloud] 📋 ledger: hexa cloud dispatch add <jid> " + str(r.pid) + " \"$(pwd)\" --host " + host + "  # cwd ./pods.json 에 등록 (commons g57; --register 로 자동화)")
            }
        }
        if r.ok == 1 {
            let rc = _cloud_early_life_check(host, ssh_opts, r.pid, early_life)
            exit(rc)
        }
        exit(1)
    }
    if sub == "fire" {
        // Atomic "fire and Monitor" — like nohup but the logfile is OPTIONAL
        // (auto-generated /tmp/cloud-<unix_ts>.log when --log omitted). Same
        // __MONITOR_HANDLE__= JSON line so a harness picks up host/pid/log/
        // tail_cmd from one verb call. The whole point: the caller no longer
        // has to invent a logfile path AND thread it through to `cloud tail`.
        if si + 1 >= len(av) {
            println("[cloud] fire: usage — cloud fire <host> [--log <path>] [--port N] [--insecure] [--early-life-check N] [--env K=V] [--source P] [--register [<jid>]] -- <argv...>")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let ssh_opts = _ssh_opts_cli(av, si + 2)
        let env_kvs = _env_args_cli(av, si + 2)
        let early_life = _early_life_cli(av, si + 2)
        let log_path = _log_path_cli(av, si + 2)
        let reg_token = _register_cli(av, si + 2)
        let mut argv = _collect_after(av, si + 2)
        if len(argv) == 0 {
            println("[cloud] fire: empty argv — usage: cloud fire <host> [--log <path>] [--port N] [--insecure] [--early-life-check N] [--env K=V] [--source P] [--register [<jid>]] -- <argv...>")
            exit(2)
        }
        argv = _with_env(env_kvs, argv)
        argv = _with_source(_source_args_cli(av, si + 2), argv)
        // Auto-gen canonical /tmp/cloud-<unix_ts>.log when --log omitted, so
        // the caller does not have to invent the path. cloud_nohup_opts then
        // does the actual dispatch (no cloud_fire_opts shim needed in cloud.hexa).
        let mut effective_log = log_path
        if effective_log == "" {
            effective_log = "/tmp/cloud-" + str(timestamp()) + ".log"
        }
        let r = cloud_nohup_opts(host, ssh_opts, argv, effective_log)
        if len(r.stdout_) > 0 {
            println(r.stdout_)
        }
        println("[cloud] " + r.message)
        // Same __MONITOR_HANDLE__= line as cloud nohup (PR1) so callers parse
        // a single shape across both verbs.
        if r.ok == 1 && len(r.logfile) > 0 {
            println("__MONITOR_HANDLE__={"
                + "\"host\":" + _mh_json_str(host)
                + ",\"pid\":" + str(r.pid)
                + ",\"log\":" + _mh_json_str(r.logfile)
                + ",\"tail_cmd\":" + _mh_json_str("hexa cloud tail " + host + " " + r.logfile)
                + "}")
            // ghost-pod 자동 차단 — `--register` 있으면 in-process로 ./pods.json
            // 갱신 (Fix A, PR L2-auto). 없으면 advisory line 유지 (PR #1769 L2-aware).
            if len(reg_token) > 0 {
                let _ = _auto_register(reg_token, host, r.pid)
            } else {
                println("[cloud] 📋 ledger: hexa cloud dispatch add <jid> " + str(r.pid) + " \"$(pwd)\" --host " + host + "  # cwd ./pods.json 에 등록 (commons g57; --register 로 자동화)")
            }
        }
        if r.ok == 1 {
            let rc = _cloud_early_life_check(host, ssh_opts, r.pid, early_life)
            exit(rc)
        }
        exit(1)
    }
    if sub == "poll" {
        if si + 2 >= len(av) {
            println("[cloud] poll: usage — cloud poll <host> <pid> [--port N] [--insecure]")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let pid = _cli_atoi(av[si + 2])
        let ssh_opts = _ssh_opts_cli(av, si + 3)
        let alive = cloud_poll_opts(host, ssh_opts, pid)
        if alive == 1 {
            println("[cloud] pid " + str(pid) + " ALIVE")
            exit(0)
        }
        println("[cloud] pid " + str(pid) + " DEAD")
        // Fix B — teardown auto-verdict. If this pid was registered via Fix A
        // (`--register` on fire/nohup), flip its verdict PENDING→FAIL so the
        // ledger never carries a stale-PENDING row for a DEAD remote job.
        // Conservative default: a launcher that wants PASS calls `cloud
        // dispatch verdict <jid> PASS` itself (poll cannot see exit code).
        let _ = _teardown_verdict_if_registered(pid)
        exit(1)
    }
    if sub == "tail" {
        // Live-stream a remote logfile to stdout so a harness (Monitor) can
        // attach to a remote job's progress with no polling — the canonical
        // bridge for `@D g57` ("attach Monitor to the LOG"). The remote
        // `tail -F | awk` does the grep filter + terminal-exit.
        //
        // We exec_replace() (execvp /bin/sh -c) rather than exec_stream():
        // the hexa process BECOMES the ssh pipeline, inheriting this stdout
        // fd, so each line reaches the local end live with zero buffering and
        // the process simply exits when the pipeline ends (until-match closes
        // the pipe → tail SIGPIPE → ssh returns). exec_stream's callback
        // fn-pointer path segfaults in a `hexa build` standalone binary
        // (upstream gap, logged to INBOX) — exec_replace has no callback and
        // is the same primitive `hexa lsp` uses for clean stream passthrough.
        if si + 2 >= len(av) {
            println("[cloud] tail: usage — cloud tail <host> <logfile> [--port N] [--insecure] [--grep RE] [--until RE]")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let logfile = av[si + 2]
        let ssh_opts = _ssh_opts_cli(av, si + 3)
        let grep_re = _flag_val(av, si + 3, "--grep", "")
        // Terminal mode (INBOX gap 1, 2026-05-28):
        //   - --until ABSENT  → the 3-tier failure-first taxonomy (exit
        //     0 DONE / 3 TIMEOUT-RESUMABLE / 4 CRASHED). This is the default
        //     so a walltime-timed-out QE job is no longer mis-read as success.
        //   - --until <ere>   → legacy single terminal block (exit 0 on first
        //     match). Explicit pattern = opt back into the old behaviour.
        //   - --until ''      → empty ERE = follow forever (no terminal block).
        let mut cmd = ""
        if _has_flag(av, si + 3, "--until") == 1 {
            let until_re = _flag_val(av, si + 3, "--until", "")
            cmd = cloud_tail_cmd_opts(host, ssh_opts, logfile, grep_re, until_re)
        } else {
            cmd = cloud_tail_cmd_taxonomy_opts(host, ssh_opts, logfile, grep_re)
        }
        let _ = exec_replace(cmd)
        // exec_replace only returns on execvp failure (no /bin/sh) — surface it.
        println("[cloud] tail: exec_replace failed — could not spawn ssh pipeline")
        exit(1)
    }
    if sub == "watch" {
        if si + 2 >= len(av) {
            println("[cloud] watch: usage — cloud watch <host> <pid> [--port N] [--insecure] [--interval N] [--max-wait S] [--then-down <id> [--provider P]]")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let pid = _cli_atoi(av[si + 2])
        let ssh_opts = _ssh_opts_cli(av, si + 3)
        let interval = _cli_atoi(_flag_val(av, si + 3, "--interval", "30"))
        let max_wait = _cli_atoi(_flag_val(av, si + 3, "--max-wait", "0"))
        let rc = _cloud_watch(host, ssh_opts, pid, interval, max_wait)
        // On completion (pid gone), optionally tear the pod down — closes the
        // "auto-loop-until-done + teardown" pattern (R2/P3) so the operator
        // need not babysit. Skipped on timeout (rc 124).
        if rc == 0 {
            let down_id = _flag_val(av, si + 3, "--then-down", "")
            if len(down_id) > 0 {
                let provider = _flag_val(av, si + 3, "--provider", "vast")
                exit(_cloud_down(down_id, provider))
            }
        }
        exit(rc)
    }
    if sub == "ssh-port" || sub == "resolve" {
        // `resolve` is a discoverable alias of `ssh-port`: turn a provider
        // pod-id into the live ssh endpoint (host + port) so the result can
        // be fed to `cloud run/exec/copy-to <root@ip> --port <n>`. A live
        // RunPod fire-path agent reached for the name `resolve` and, finding
        // no such verb in a stale 0.1.0 binary, mis-diagnosed a transport
        // deadlock (INBOX 2026-05-27) — the resolver (runpod_get_ssh_port)
        // already existed under `ssh-port`; only the deployed bin was stale.
        if si + 1 >= len(av) {
            println("[cloud] " + sub + ": missing <id> — usage: cloud " + sub + " <id> [--provider vast|runpod]")
            exit(2)
        }
        let id = av[si + 1]
        let provider = _flag_val(av, si + 2, "--provider", "vast")
        exit(_cloud_ssh_port(id, provider))
    }
    if sub == "orphans" {
        // List tracked pods, flagging stale ones (created > N hours ago and
        // not marked closed). Optional `--hours N` overrides the default 6h.
        let mut hours = 6
        let mut oi = si + 1
        while oi < len(av) {
            if av[oi] == "--hours" && oi + 1 < len(av) {
                hours = _cli_atoi(av[oi + 1])
                oi = oi + 2
            } else {
                oi = oi + 1
            }
        }
        if hours <= 0 {
            hours = 6
        }
        let stale = cloud_orphans_print(hours)
        if stale > 0 {
            exit(1)
        }
        exit(0)
    }
    if sub == "reconcile" {
        // Cross-reference the registry (pods.jsonl) against the provider's
        // live pod list (runpod_list_pods) and print the ORPHAN/GHOST/OK
        // table. Exit 1 when registry and provider disagree (any ORPHAN /
        // GHOST), else 0. No ssh / pod-spinup — the only outbound call is the
        // wrapped provider list (runpodctl); absent runpodctl reconciles
        // against an empty provider set (every tracked pod → GHOST).
        let drift = cloud_reconcile_print()
        if drift > 0 {
            exit(1)
        }
        exit(0)
    }
    if sub == "reap" {
        // M6 orphan finder — set-diff alive(provider) − registry(M5) =
        // orphans (alive on provider but the M5 SSOT does not know about
        // them). bare = dry-run table + exit 0; --apply destroys via the
        // existing _cloud_down path. --provider runpod|vast narrows scope.
        let provider = _flag_val(av, si + 1, "--provider", "")
        let mut apply = 0
        let mut ri = si + 1
        while ri < len(av) {
            if av[ri] == "--apply" {
                apply = 1
            }
            ri = ri + 1
        }
        exit(_cloud_reap(provider, apply))
    }
    if sub == "adopt" {
        // Track a previously-untracked (ORPHAN) pod so it regains a
        // poll/pull/lifecycle handle. `--purpose TEXT` sets the registry
        // label; defaults to "(adopted)".
        if si + 1 >= len(av) {
            println("[cloud] adopt: missing <pod_id> — usage: cloud adopt <pod_id> [--purpose TEXT] [--project NAME]")
            exit(2)
        }
        // help-guard (#cloud-adopt-help): `cloud adopt --help`/`-h` 는 usage 를
        // 출력하고 정상(0) 종료 — `--help` 를 pod-id 로 오인해 "adopted --help" 를
        // 찍던 misparse 차단. 일반화: `-` 로 시작하는 pod-id 토큰은 pod-id 가 아니라
        // 놓친 flag 로 보고 거부(exit 2) — _pod_id_looks_valid 의 write-side 거부가
        // registry 오염은 이미 막지만, verb 가 그 전에 거짓 success 를 찍었다.
        let _adopt_first = av[si + 1]
        if _adopt_first == "--help" || _adopt_first == "-h" {
            println("usage: cloud adopt <pod_id> [--purpose TEXT] [--project NAME]")
            println("  track an untracked (ORPHAN) pod — stamps M5 project/purpose for the down-guard.")
            exit(0)
        }
        if len(_adopt_first) >= 1 && _adopt_first.substring(0, 1) == "-" {
            println("[cloud] adopt: '" + _adopt_first + "' is not a pod-id (starts with '-') — did you mean a flag? usage: cloud adopt <pod_id> [--purpose TEXT] [--project NAME]")
            exit(2)
        }
        let pod_id = av[si + 1]
        let mut purpose = "(adopted)"
        let mut ai = si + 2
        while ai < len(av) {
            if av[ai] == "--purpose" && ai + 1 < len(av) {
                purpose = av[ai + 1]
                ai = ai + 2
            } else {
                ai = ai + 1
            }
        }
        // Project attribution for the M5 down-guard — explicit --project, else
        // cwd git-repo basename, else "unattributed".
        let adopt_project = _resolve_project(av, si + 2)
        let ok = pod_registry_adopt(pod_id, purpose)
        // Also stamp the M5 SSOT (active-pods.json) with project/purpose so the
        // adopted pod gains cross-project down-guard attribution. provider ""
        // is preserved/inferred elsewhere; status READY (adopt = it's alive).
        let _m5 = pod_registry_add(pod_id, "", adopt_project, purpose, "", "", "READY")
        if ok == 1 {
            println("[cloud] adopted " + pod_id + " (project=" + adopt_project + ", purpose=" + purpose + ", status=running)")
            // #1155 zero-flag: if this is a vast instance, write its bare-IP
            // Host block → ~/.ssh/config (no-op for runpod / no vast key).
            let _inj = vast_ssh_config_autoinject(pod_id)
            if len(_inj) > 0 {
                println("[cloud] adopt: ~/.ssh/config Host " + _inj + " → vast identity (auto; #1155)")
            }
            exit(0)
        }
        println("[cloud] adopt: empty pod_id")
        exit(2)
    }
    if sub == "forget" {
        // Mark a tracked (GHOST) pod's record status=closed. The record is
        // retained (closed rows are excluded from staleness flagging) so the
        // launch history survives. The arg is matched LITERALLY against the
        // registry `pod_id` field, so any form `cloud reconcile` shows in its
        // GHOST column closes — numeric provider-id, ssh-form (`root@<ip>`),
        // bare IP, alias (`ubu-2`), or a `--help`-as-id edge case (legacy
        // pollution the write-side guard now blocks). This makes the
        // reconcile→forget cleanup loop closed-form (INBOX 2026-05-28).
        if si + 1 >= len(av) {
            println("[cloud] forget: missing <pod_id> — usage: cloud forget <pod_id|ssh-form|ip|alias>")
            exit(2)
        }
        let pod_id = av[si + 1]
        let ok = pod_registry_forget(pod_id)
        if ok == 1 {
            println("[cloud] forgot " + pod_id + " (status=closed)")
            exit(0)
        }
        // Not found — hint the open (non-closed) candidate ids so the caller
        // can copy the exact registry form (it must match LITERALLY).
        println("[cloud] forget: '" + pod_id + "' not found in registry (matched literally against the pod_id field)")
        let rows = pod_registry_rows(0)
        let mut hint = ""
        let mut hn = 0
        let mut hi = 0
        while hi < len(rows) && hn < 12 {
            let r = rows[hi]
            if r.status != "closed" {
                if len(hint) > 0 { hint = hint + ", " }
                hint = hint + r.pod_id
                hn = hn + 1
            }
            hi = hi + 1
        }
        if len(hint) > 0 {
            println("[cloud] forget: open candidates — " + hint)
            println("[cloud] forget: run `cloud reconcile` for the full GHOST list, then forget the exact form shown")
        } else {
            println("[cloud] forget: no open (non-closed) rows tracked — registry is clean")
        }
        exit(1)
    }
    if sub == "copy-to" {
        if si + 3 >= len(av) {
            println("[cloud] copy-to: usage — cloud copy-to <host> <local> <remote> [--port N] [--insecure]")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let local_path = av[si + 2]
        let remote_path = av[si + 3]
        let ssh_opts = _ssh_opts_cli(av, si + 4)
        let mut want_recursive = _has_flag(av, si + 4, "--recursive")
        if _has_flag(av, si + 4, "-r") == 1 {
            want_recursive = 1
        }
        let r = _copy_to_run(host, ssh_opts, local_path, remote_path, want_recursive)
        println("[cloud] " + r.message + " · " + local_path + " -> " + host + ":" + remote_path)
        if r.ok == 1 && _has_flag(av, si + 4, "--verify-sha") == 1 {
            let v = cloud_verify_sha(host, ssh_opts, remote_path, local_path)
            println("[cloud] verify-sha: " + v.message)
            exit(v.exit_code)
        }
        exit(r.exit_code)
    }
    if sub == "copy-from" {
        if si + 3 >= len(av) {
            println("[cloud] copy-from: usage — cloud copy-from <host> <remote> <local> [--port N] [--insecure]")
            exit(2)
        }
        let host = _checked_host(av[si + 1])
        let remote_path = av[si + 2]
        let local_path = av[si + 3]
        let ssh_opts = _ssh_opts_cli(av, si + 4)
        let want_resume = _has_flag(av, si + 4, "--resume")
        let r = _copy_from_run(host, ssh_opts, remote_path, local_path, want_resume)
        println("[cloud] " + r.message + " · " + host + ":" + remote_path + " -> " + local_path)
        if r.ok == 1 && _has_flag(av, si + 4, "--verify-sha") == 1 {
            let v = cloud_verify_sha(host, ssh_opts, remote_path, local_path)
            println("[cloud] verify-sha: " + v.message)
            exit(v.exit_code)
        }
        exit(r.exit_code)
    }
}
