// stdlib/cloud/cloud_tail_test.hexa — falsifiers for the `cloud tail` verb's
// command builder (cloud_tail_cmd_opts).
//
// LLM-free, network-free, **no ssh / no pod**. The streaming itself is
// ssh-bound and exercised by the live e2e smoke; this file pins the PURE
// command-string construction — the part that decides correctness (quoting,
// the tail|sed pipeline shape, the grep/until threading, terminal-first
// ordering) before a single byte goes over the wire.
//
// The remote consumer is `sed -E -un` (NOT awk): the stock pod awk is mawk,
// which block-buffers its stdin behind a following `tail -F` and stalls;
// sed -u is line-buffered. These cases pin that choice.
//
// Run:   hexa run stdlib/cloud/cloud_tail_test.hexa
// PASS:  exits 0, prints "cloud_tail_test PASS — N/N cases".

use "stdlib/cloud/cloud"

fn _fail(case: str, msg: str) {
    println("FAIL " + case + ": " + msg)
    exit(1)
}

fn _has(hay: str, needle: str) -> int {
    if hay.index_of(needle) >= 0 { return 1 }
    return 0
}

fn main() {
    // ── case 1: bare host — ssh prefix + keep-alive + tail -F + sed -E -un ─
    let c1 = cloud_tail_cmd_opts("gpu-1", [], "/workspace/train.log", "", "JOB DONE")
    if _has(c1, "ssh -o BatchMode=yes -o ConnectTimeout=8") != 1 {
        _fail("case1", "missing ssh prefix — " + c1)
    }
    if _has(c1, "ServerAliveInterval=15") != 1 {
        _fail("case1", "missing keep-alive (dead-pod tail must not hang) — " + c1)
    }
    if _has(c1, "tail -F -n +1") != 1 {
        _fail("case1", "missing tail -F replay-then-follow — " + c1)
    }
    if _has(c1, "sed -E -un") != 1 {
        _fail("case1", "consumer must be sed -E -un (line-buffered; mawk stalls) — " + c1)
    }
    println("case1 PASS — ssh+keepalive + tail -F + sed -E -un pipeline present")

    // ── case 2: logfile is POSIX single-quoted (injection-safe) ────────
    let c2 = cloud_tail_cmd_opts("gpu-1", [], "/w/train.log", "", "")
    if _has(c2, "'/w/train.log'") != 1 {
        _fail("case2", "logfile not single-quoted for the remote shell — " + c2)
    }
    println("case2 PASS — logfile POSIX-quoted for the remote shell")

    // ── case 3: empty until → follow forever (no {p;q}), bare `p` filter ─
    // With until_re == "" the sed program has no terminal `/.../{p;q}` block,
    // and with grep_re == "" the filter is a bare `p` (print every line).
    let c3 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "", "")
    if _has(c3, "{p;q}") != 0 {
        _fail("case3", "empty --until must NOT emit a terminal {p;q} block — " + c3)
    }
    if _has(c3, "JOB DONE") != 0 {
        _fail("case3", "empty --until must NOT leak a default terminal marker — " + c3)
    }
    println("case3 PASS — empty --until → no terminal block (follow forever)")

    // ── case 4: until ERE → terminal /until/{p;q} block present ─────────
    let c4 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "", "JOB DONE|Traceback")
    if _has(c4, "/JOB DONE|Traceback/{p;q}") != 1 {
        _fail("case4", "until ERE not in a /…/{p;q} terminal block — " + c4)
    }
    println("case4 PASS — --until ERE → /…/{p;q} terminal block")

    // ── case 5: grep regex → /grep/p filter present ─────────────────────
    let c5 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "step=|loss=", "JOB DONE")
    if _has(c5, "/step=|loss=/p") != 1 {
        _fail("case5", "grep ERE not in a /…/p filter — " + c5)
    }
    println("case5 PASS — --grep ERE → /…/p filter")

    // ── case 6: ssh_opts (port + insecure) thread into the ssh prefix ───
    let opts = ["-p", "41953", "-o", "StrictHostKeyChecking=no"]
    let c6 = cloud_tail_cmd_opts("root@1.2.3.4", opts, "/w/l.log", "", "JOB DONE")
    // each ssh_opt is individually POSIX-quoted (mirrors _ssh_capture_status).
    if _has(c6, "'-p' '41953'") != 1 {
        _fail("case6", "port opt not threaded — " + c6)
    }
    if _has(c6, "StrictHostKeyChecking=no") != 1 {
        _fail("case6", "insecure opt not threaded — " + c6)
    }
    println("case6 PASS — port + insecure ssh_opts threaded into the ssh prefix")

    // ── case 7: terminal-FIRST — the /until/{p;q} block precedes the
    //           filter, so a terminal line surfaces + stops the stream even
    //           when it would fail the grep filter.
    let c7 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "step=", "JOB DONE")
    let ti = c7.index_of("/JOB DONE/{p;q}")
    let fi = c7.index_of("/step=/p")
    if ti < 0 || fi < 0 {
        _fail("case7", "terminal block or filter missing — " + c7)
    }
    if ti > fi {
        _fail("case7", "terminal /until/{p;q} must precede the grep filter — " + c7)
    }
    println("case7 PASS — terminal-first (/until/{p;q} before grep filter)")

    // ── case 8: sed -u (line-buffered) — the property that makes streaming
    //            real-time over a following tail -F (mawk would stall here).
    let c8 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "", "JOB DONE")
    if _has(c8, "sed -E -un") != 1 {
        _fail("case8", "must use sed -u (unbuffered) for real-time streaming — " + c8)
    }
    if _has(c8, "awk") != 0 {
        _fail("case8", "must NOT use awk (mawk block-buffers stdin behind tail -F) — " + c8)
    }
    println("case8 PASS — sed -u line-buffered, no awk (no mawk stdin stall)")

    // ── case 9: cloud_tail_cmd (no-opts wrapper) == _opts with [] ───────
    let c9a = cloud_tail_cmd("gpu-1", "/w/l.log", "", "JOB DONE")
    let c9b = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "", "JOB DONE")
    if c9a != c9b {
        _fail("case9", "cloud_tail_cmd must equal cloud_tail_cmd_opts with [] opts")
    }
    println("case9 PASS — cloud_tail_cmd == cloud_tail_cmd_opts(host, [], ...)")

    // ── 3-tier failure-first terminal taxonomy (INBOX gap 1, 2026-05-28) ──
    // The default `cloud tail` (no --until) routes to the taxonomy variant,
    // which builds a FAILURE-FIRST classifier so a walltime-timed-out QE job
    // (Maximum CPU time exceeded → deceptive JOB DONE → STOP 1) is read as
    // TIMEOUT-RESUMABLE (exit 3) / CRASHED (exit 4), not SUCCESS (exit 0).
    // cloud_tail_cmd_taxonomy_opts selects the classifier (bool flag, not a
    // magic sentinel string — hexa literal collision is a known codegen
    // landmine). Pure string asserts on the generated remote sed program pin
    // the contract (no ssh / no pod).

    // ── case 10: taxonomy emits a CRASH block with q4 ───────────────────
    let c10 = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "")
    if _has(c10, "{p;q4}") != 1 {
        _fail("case10", "taxonomy must emit a CRASHED block quitting q4 — " + c10)
    }
    if _has(c10, "STOP [1-9]") != 1 {
        _fail("case10", "CRASH set must include non-zero Fortran STOP [1-9] — " + c10)
    }
    if _has(c10, "Error in routine") != 1 {
        _fail("case10", "CRASH set must include the QE 'Error in routine' banner — " + c10)
    }
    println("case10 PASS — taxonomy CRASHED block (STOP [1-9]|Error in routine → q4)")

    // ── case 11: taxonomy emits a TIMEOUT block with q3 ─────────────────
    let c11 = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "")
    if _has(c11, "{p;q3}") != 1 {
        _fail("case11", "taxonomy must emit a TIMEOUT-RESUMABLE block quitting q3 — " + c11)
    }
    if _has(c11, "Maximum CPU time exceeded") != 1 {
        _fail("case11", "TIMEOUT set must include QE 'Maximum CPU time exceeded' — " + c11)
    }
    if _has(c11, "max_seconds") != 1 {
        _fail("case11", "TIMEOUT set must include 'max_seconds' — " + c11)
    }
    println("case11 PASS — taxonomy TIMEOUT block (Maximum CPU time/max_seconds → q3)")

    // ── case 12: taxonomy emits a clean DONE block with q0 ──────────────
    let c12 = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "")
    if _has(c12, "{p;q0}") != 1 {
        _fail("case12", "taxonomy must emit a DONE block quitting q0 — " + c12)
    }
    if _has(c12, "JOB DONE") != 1 {
        _fail("case12", "DONE set must include 'JOB DONE' — " + c12)
    }
    println("case12 PASS — taxonomy DONE block (JOB DONE → q0)")

    // ── case 13: FAILURE-FIRST ordering — CRASH before TIMEOUT before
    //            DONE. Load-bearing: in the QE timeout log the failure line
    //            sits AT/BEFORE the deceptive `JOB DONE`, so a sed program
    //            that scanned DONE first would quit q0 (the original bug).
    //            The crash block must precede timeout, which must precede
    //            done, so a failure verdict always wins.
    let c13 = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "")
    let crash_i = c13.index_of("q4")
    let to_i = c13.index_of("q3")
    let done_i = c13.index_of("q0")
    if crash_i < 0 || to_i < 0 || done_i < 0 {
        _fail("case13", "all three taxonomy blocks must be present — " + c13)
    }
    if crash_i > to_i {
        _fail("case13", "CRASH (q4) block must precede TIMEOUT (q3) — " + c13)
    }
    if to_i > done_i {
        _fail("case13", "TIMEOUT (q3) block must precede DONE (q0) — " + c13)
    }
    println("case13 PASS — failure-first ordering (CRASH q4 → TIMEOUT q3 → DONE q0)")

    // ── case 14: STOP 0 (clean stop) is NOT a crash — the CRASH set must
    //            match only STOP [1-9], never `STOP 0`.
    let c14 = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "")
    if _has(c14, "STOP 0") != 0 {
        _fail("case14", "CRASH set must NOT match clean 'STOP 0' — " + c14)
    }
    println("case14 PASS — clean 'STOP 0' excluded from the CRASH set")

    // ── case 15: explicit --until ERE keeps the LEGACY single block (no
    //            taxonomy q3/q4) — back-compat for callers passing a pattern.
    let c15 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "", "JOB DONE|Traceback")
    if _has(c15, "/JOB DONE|Traceback/{p;q}") != 1 {
        _fail("case15", "explicit --until ERE must build the legacy single block — " + c15)
    }
    if _has(c15, "q4") != 0 {
        _fail("case15", "explicit --until ERE must NOT emit the taxonomy q4 — " + c15)
    }
    if _has(c15, "q3") != 0 {
        _fail("case15", "explicit --until ERE must NOT emit the taxonomy q3 — " + c15)
    }
    println("case15 PASS — explicit --until ERE → legacy single block (no taxonomy)")

    // ── case 16: empty --until still follows forever (no terminal block) ─
    //            cloud_tail_cmd_opts with "" until is the follow-forever path
    //            and must emit no terminal block of any kind.
    let c16 = cloud_tail_cmd_opts("gpu-1", [], "/w/l.log", "", "")
    if _has(c16, "q4") != 0 || _has(c16, "q3") != 0 || _has(c16, "{p;q") != 0 {
        _fail("case16", "empty --until must emit NO terminal block (follow forever) — " + c16)
    }
    println("case16 PASS — empty --until → follow forever (no terminal block)")

    // ── case 17: taxonomy threads a --grep filter AFTER the three terminal
    //            blocks (terminal-first preserved), so a verdict line always
    //            surfaces + classifies even when it fails the grep filter.
    let c17 = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "step=")
    if _has(c17, "/step=/p") != 1 {
        _fail("case17", "taxonomy must thread the grep filter (/step=/p) — " + c17)
    }
    let q4i = c17.index_of("q4")
    let gi = c17.index_of("/step=/p")
    if q4i < 0 || gi < 0 || q4i > gi {
        _fail("case17", "terminal blocks must precede the grep filter — " + c17)
    }
    println("case17 PASS — taxonomy threads grep filter after terminal blocks")

    // ── case 18: taxonomy no-opts wrapper == _opts with [] ──────────────
    let c18a = cloud_tail_cmd_taxonomy("gpu-1", "/w/l.log", "")
    let c18b = cloud_tail_cmd_taxonomy_opts("gpu-1", [], "/w/l.log", "")
    if c18a != c18b {
        _fail("case18", "cloud_tail_cmd_taxonomy must equal _opts with [] opts")
    }
    println("case18 PASS — cloud_tail_cmd_taxonomy == _opts(host, [], ...)")

    println("cloud_tail_test PASS — 18/18 cases")
    exit(0)
}
