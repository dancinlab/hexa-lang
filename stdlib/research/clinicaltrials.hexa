// stdlib/research/clinicaltrials.hexa — ClinicalTrials.gov v2 REST client (JSON).
//
// Live endpoints:
//   search:  https://clinicaltrials.gov/api/v2/studies?query.cond=<q>&pageSize=<N>&fields=NCTId
//   by id:   https://clinicaltrials.gov/api/v2/studies/<NCT_ID>?format=json
//
// Public surface:
//   - `ct_fetch`        : single study by NCT id (live HTTP).
//   - `ct_search`       : condition query → [NCT id] (live HTTP).
//   - `ct_parse_study`  : pure-parse a study JSON body → ClinicalTrial.
//   - `ct_parse_search` : pure-parse a search JSON body → [NCT id].
//
// Per @D try-live-or-fallback: callers needing offline determinism feed the
// pure-parse helpers a pre-captured JSON body; live `search`/`fetch` shell
// out to the HTTP builtin.
//
// JSON strategy: hexa's `json_parse` builtin is the primary path — returns a
// nested map mirroring the v2 protocolSection schema. We navigate
// obj["protocolSection"]["identificationModule"]["nctId"] etc. defensively
// (every node guarded by `has_key` + `type_of` since old / deprecated /
// unverified trials omit modules at will). Missing scalar fields collapse
// to "" so the struct is always populated.

struct ClinicalTrial {
    nct_id: string,
    title: string,
    status: string,
    phase: string,                 // joined "PHASE1+PHASE2" when multi-phase
    conditions: [string],
    interventions: [string],       // intervention `name` list
    start_date: string,            // ISO yyyy-mm-dd (or "" when absent)
    completion_date: string,       // ISO yyyy-mm-dd (or "" when absent)
    sponsor: string,               // leadSponsor.name (or "" when absent)
}

let CT_API_BASE   = "https://clinicaltrials.gov/api/v2/studies"
let CT_USER_AGENT = "hexa-lang stdlib/research (github.com/dancinlab/hexa-lang)"

// ── internal: defensive map accessors ───────────────────────────────

// Read `m[k]` as a string, returning "" when missing or wrong-typed.
fn _ct_str(m, k: string) -> string {
    if type_of(m) != "map" { return "" }
    if !has_key(m, k) { return "" }
    let v = m[k]
    if type_of(v) == "string" { return v }
    if type_of(v) == "void" { return "" }
    return to_string(v)
}

// Read `m[k]` as a map; returns an empty map on miss (safe to chain).
fn _ct_map(m, k: string) -> any {
    if type_of(m) != "map" { return json_parse("{}") }
    if !has_key(m, k) { return json_parse("{}") }
    let v = m[k]
    if type_of(v) != "map" { return json_parse("{}") }
    return v
}

// Read `m[k]` as an array; returns [] on miss / wrong-typed.
fn _ct_arr(m, k: string) -> [any] {
    let empty: [any] = []
    if type_of(m) != "map" { return empty }
    if !has_key(m, k) { return empty }
    let v = m[k]
    if type_of(v) != "array" { return empty }
    return v
}

// Pull the `name` field off every element of an interventions array.
fn _ct_intervention_names(arr) -> [string] {
    let mut out: [string] = []
    if type_of(arr) != "array" { return out }
    for it in arr {
        let nm = _ct_str(it, "name")
        if len(nm) > 0 { out.push(nm) }
    }
    return out
}

// Collapse `[string]` from a parsed conditions array.
fn _ct_string_array(arr) -> [string] {
    let mut out: [string] = []
    if type_of(arr) != "array" { return out }
    for it in arr {
        if type_of(it) == "string" { out.push(it) }
    }
    return out
}

// Phase array → "PHASE1+PHASE2" string (joined by `+`). Missing → "".
fn _ct_phase(phases) -> string {
    if type_of(phases) != "array" { return "" }
    let mut out = ""
    let mut first = true
    for p in phases {
        if type_of(p) != "string" { continue }
        if first {
            out = p
            first = false
        } else {
            out = out + "+" + p
        }
    }
    return out
}

// ── public surface ──────────────────────────────────────────────────

// Parse a single-study v2 JSON body into a ClinicalTrial. Safe to call on
// offline fixtures; never touches the network. Missing modules collapse to
// empty scalars / arrays (caller may key off `len(t.nct_id) > 0`).
pub fn ct_parse_study(json_body: string) -> ClinicalTrial {
    let empty = ClinicalTrial{
        nct_id: "", title: "", status: "", phase: "",
        conditions: [], interventions: [],
        start_date: "", completion_date: "", sponsor: "",
    }
    if len(json_body) == 0 { return empty }
    let root = json_parse(json_body)
    if type_of(root) != "map" { return empty }

    let ps   = _ct_map(root, "protocolSection")
    let idm  = _ct_map(ps, "identificationModule")
    let stm  = _ct_map(ps, "statusModule")
    let dm   = _ct_map(ps, "designModule")
    let cm   = _ct_map(ps, "conditionsModule")
    let aim  = _ct_map(ps, "armsInterventionsModule")
    let scm  = _ct_map(ps, "sponsorCollaboratorsModule")

    let nct  = _ct_str(idm, "nctId")
    let ttl  = _ct_str(idm, "briefTitle")
    let stat = _ct_str(stm, "overallStatus")

    let phases = _ct_arr(dm, "phases")
    let phase  = _ct_phase(phases)

    let conds  = _ct_string_array(_ct_arr(cm, "conditions"))
    let interv = _ct_intervention_names(_ct_arr(aim, "interventions"))

    let start_struct = _ct_map(stm, "startDateStruct")
    let comp_struct  = _ct_map(stm, "completionDateStruct")
    let start_date   = _ct_str(start_struct, "date")
    let comp_date    = _ct_str(comp_struct,  "date")

    let lead    = _ct_map(scm, "leadSponsor")
    let sponsor = _ct_str(lead, "name")

    return ClinicalTrial{
        nct_id: nct,
        title: ttl,
        status: stat,
        phase: phase,
        conditions: conds,
        interventions: interv,
        start_date: start_date,
        completion_date: comp_date,
        sponsor: sponsor,
    }
}

// Parse a search v2 JSON body (`/studies?...&fields=NCTId`) into the
// list of NCT ids. The response shape is
//   {"studies":[{"protocolSection":{"identificationModule":{"nctId":"..."}}}, ...], "nextPageToken":"..."}
// — we walk the studies array and pull the nctId off each, skipping any
// entry whose shape drifts.
pub fn ct_parse_search(json_body: string) -> [string] {
    let mut out: [string] = []
    if len(json_body) == 0 { return out }
    let root = json_parse(json_body)
    if type_of(root) != "map" { return out }
    let studies = _ct_arr(root, "studies")
    for s in studies {
        let ps  = _ct_map(s,  "protocolSection")
        let idm = _ct_map(ps, "identificationModule")
        let id  = _ct_str(idm, "nctId")
        if len(id) > 0 { out.push(id) }
    }
    return out
}

// URL-percent-encode the bits of a condition query that
// clinicaltrials.gov's parser is sensitive to. The API is liberal — it
// accepts `+` for space and tolerates `:`, `,`, `(`, `)`. We only swap
// spaces; everything else passes through.
fn _ct_q_encode(q: string) -> string {
    return q.replace(" ", "+")
}

// Live single-study fetch via the v2 REST API. Returns a sentinel
// (empty `nct_id`) on network failure or unknown id.
pub fn ct_fetch(nct_id: string) -> ClinicalTrial {
    let empty = ClinicalTrial{
        nct_id: "", title: "", status: "", phase: "",
        conditions: [], interventions: [],
        start_date: "", completion_date: "", sponsor: "",
    }
    if len(nct_id) == 0 { return empty }
    let url = CT_API_BASE + "/" + nct_id + "?format=json"
    let body = http_get(url)
    if len(body) == 0 { return empty }
    return ct_parse_study(body)
}

// Live search by condition. Returns the NCT id list (≤ `max_results`),
// or [] on network failure. `max_results` is clamped to [1, 1000] per
// the v2 API's `pageSize` cap.
pub fn ct_search(condition: string, max_results: int) -> [string] {
    let empty: [string] = []
    if len(condition) == 0 { return empty }
    let mut n = max_results
    if n < 1 { n = 1 }
    if n > 1000 { n = 1000 }
    let url = CT_API_BASE
        + "?query.cond=" + _ct_q_encode(condition)
        + "&pageSize="   + to_string(n)
        + "&fields=NCTId"
    let body = http_get(url)
    return ct_parse_search(body)
}
