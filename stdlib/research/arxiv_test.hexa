// stdlib/research/arxiv_test.hexa — measured-oracle gate for the arXiv
// stdlib client.
//
// Determinism strategy: parse the captured `compiler/bridges/_cache/
// arxiv.frozen.xml` fixture (2026-05-13 snapshot of a ti:hexagon + number
// theory query — 2 entries) and assert byte-equal field extraction. No
// network. The fixture covers both the modern PDF link layout and the
// pre-2007 `math/0603469v1` id form, so a regression in either path
// trips the gate.

use "stdlib/research/arxiv"

let FIXTURE = "compiler/bridges/_cache/arxiv.frozen.xml"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_eq_i(label: string, want: int, got: int) {
    if want != got { _fail(label, to_string(want), to_string(got)) }
}

fn main() {
    let xml = read_file(FIXTURE)
    if len(xml) == 0 {
        println("FAIL: fixture missing: " + FIXTURE)
        exit(1)
    }

    let papers = arxiv_parse_atom(xml)
    _expect_eq_i("entry count", 2, len(papers))

    // ── entry[0] : pre-2007 id, single author ─────────────────────
    let p0 = papers[0]
    _expect_eq("p0.id",        "math/0603469v1", p0.id)
    _expect_eq("p0.title",     "The Caccetta-Haggkvist conjecture and additive number theory", p0.title)
    _expect_eq("p0.published", "2006-03-20T01:26:20Z", p0.published)
    _expect_eq("p0.pdf_url",   "https://arxiv.org/pdf/math/0603469v1", p0.pdf_url)
    _expect_eq_i("p0.author count", 1, len(p0.authors))
    _expect_eq("p0.authors[0]", "Melvyn B. Nathanson", p0.authors[0])
    _expect_eq_i("p0.category count", 2, len(p0.categories))
    _expect_eq("p0.categories[0]", "math.CO", p0.categories[0])

    // ── entry[1] : modern id, two authors, &amp; entity in abstract ─
    let p1 = papers[1]
    _expect_eq("p1.id",        "1508.06031v2", p1.id)
    _expect_eq("p1.published", "2015-08-25T05:03:25Z", p1.published)
    _expect_eq("p1.pdf_url",   "https://arxiv.org/pdf/1508.06031v2", p1.pdf_url)
    _expect_eq_i("p1.author count", 2, len(p1.authors))
    _expect_eq("p1.authors[0]", "Jay Daigle",       p1.authors[0])
    _expect_eq("p1.authors[1]", "Matthias Flach",   p1.authors[1])

    // ── pdf_url synthesis ────────────────────────────────────────
    _expect_eq("pdf_url(modern)", "https://arxiv.org/pdf/2401.12345",     arxiv_pdf_url("2401.12345"))
    _expect_eq("pdf_url(versioned)", "https://arxiv.org/pdf/2401.12345v2", arxiv_pdf_url("2401.12345v2"))
    _expect_eq("pdf_url(legacy)", "https://arxiv.org/pdf/math/0603469v1",  arxiv_pdf_url("math/0603469v1"))

    // ── empty / error path ───────────────────────────────────────
    let empties = arxiv_parse_atom("")
    _expect_eq_i("empty body → 0 papers", 0, len(empties))
    let no_id = arxiv_fetch("")
    _expect_eq("fetch('') sentinel", "", no_id.id)

    println("PASS: arxiv parse_atom + pdf_url + empty-path oracles (" + to_string(len(papers)) + " entries, 8 fields each)")
}
