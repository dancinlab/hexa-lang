// stdlib/research/clinicaltrials_test.hexa — measured-oracle gate for the
// ClinicalTrials.gov v2 stdlib client.
//
// Determinism strategy: parse `compiler/bridges/_cache/clinicaltrials.frozen.json`
// (2026-05-24 snapshot of NCT00000102 — one of the oldest registered trials,
// a stable closed PHASE1+PHASE2 CAH study) and byte-equal assert each field.
// No network. NCT00000102 was chosen because (a) the entry is permanently
// COMPLETED → never gets re-statused, and (b) it exercises the multi-phase
// array path while having a single-element conditions / interventions list.

use "stdlib/research/clinicaltrials"

let FIXTURE = "compiler/bridges/_cache/clinicaltrials.frozen.json"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_eq_i(label: string, want: int, got: int) {
    if want != got { _fail(label, to_string(want), to_string(got)) }
}

fn main() {
    let body = read_file(FIXTURE)
    if len(body) == 0 {
        println("FAIL: fixture missing: " + FIXTURE)
        exit(1)
    }

    let t = ct_parse_study(body)

    // ── scalar fields (byte-equal vs live curl 2026-05-24) ────────
    _expect_eq("nct_id",          "NCT00000102", t.nct_id)
    _expect_eq("title",
        "Congenital Adrenal Hyperplasia: Calcium Channels as Therapeutic Targets",
        t.title)
    _expect_eq("status",          "COMPLETED",   t.status)
    _expect_eq("phase (multi)",   "PHASE1+PHASE2", t.phase)
    _expect_eq("sponsor",
        "National Center for Research Resources (NCRR)",
        t.sponsor)
    // NCT00000102 predates startDate/completionDate enforcement — modules
    // are absent → defensive accessors should collapse to "" (not panic).
    _expect_eq("start_date (absent)",      "", t.start_date)
    _expect_eq("completion_date (absent)", "", t.completion_date)

    // ── array fields ─────────────────────────────────────────────
    _expect_eq_i("conditions count",    1, len(t.conditions))
    _expect_eq("conditions[0]",
        "Congenital Adrenal Hyperplasia", t.conditions[0])

    _expect_eq_i("interventions count", 1, len(t.interventions))
    _expect_eq("interventions[0]",      "Nifedipine", t.interventions[0])

    // ── search-parse oracle ──────────────────────────────────────
    // Synthetic search body — mirrors the live shape produced by
    //   /api/v2/studies?query.cond=...&pageSize=N&fields=NCTId
    let search_body = "{\"studies\":["
        + "{\"protocolSection\":{\"identificationModule\":{\"nctId\":\"NCT02562313\"}}},"
        + "{\"protocolSection\":{\"identificationModule\":{\"nctId\":\"NCT00904020\"}}},"
        + "{\"protocolSection\":{\"identificationModule\":{\"nctId\":\"NCT03196024\"}}}"
        + "],\"nextPageToken\":\"ZVJj7o\"}"
    let ids = ct_parse_search(search_body)
    _expect_eq_i("search count",   3, len(ids))
    _expect_eq("search ids[0]",    "NCT02562313", ids[0])
    _expect_eq("search ids[1]",    "NCT00904020", ids[1])
    _expect_eq("search ids[2]",    "NCT03196024", ids[2])

    // ── empty / error paths ─────────────────────────────────────
    let empty_study = ct_parse_study("")
    _expect_eq("parse_study('') sentinel",  "", empty_study.nct_id)
    let empty_search = ct_parse_search("")
    _expect_eq_i("parse_search('') count",   0, len(empty_search))
    let no_id = ct_fetch("")
    _expect_eq("fetch('') sentinel",         "", no_id.nct_id)
    let no_q = ct_search("", 5)
    _expect_eq_i("search('') count",         0, len(no_q))

    // ── shape-drift defense — junk JSON / non-map root ──────────
    let drift = ct_parse_study("[]")
    _expect_eq("parse_study('[]') sentinel", "", drift.nct_id)
    let drift_search = ct_parse_search("{\"oops\":1}")
    _expect_eq_i("parse_search drift count", 0, len(drift_search))

    println("PASS: clinicaltrials parse_study + parse_search + drift oracles (9 fields / 4 entries)")
}
