// stdlib/research/pubmed.hexa — NCBI E-utilities PubMed client (esearch + efetch).
//
// Public surface: pubmed_search · pubmed_fetch · pubmed_parse_efetch (pure,
// offline-testable) · pubmed_parse_esearch (pure). XML strategy: lightweight
// `<tag …>…</tag>` slicing that tolerates attributes on the open tag — PMID
// and Author both carry them. No full XML parser dep. Decodes the 5 standard
// XML predefined entities (`&amp; &lt; &gt; &quot; &apos;`).

struct PubmedPaper {
    pmid: string,
    title: string,
    abstract: string,
    authors: [string],   // "LastName, ForeName" each
    journal: string,
    year: string,
    doi: string,
}

let PUBMED_ESEARCH = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi"
let PUBMED_EFETCH  = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi"

// ── string utilities ────────────────────────────────────────────────

fn _idx(hay: string, needle: string, from: int) -> int {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return from }
    if m > n { return -1 }
    let mut i = from
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return i }
        i = i + 1
    }
    return -1
}

fn _trim(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s.substring(a, a + 1)
        if c != " " && c != "\t" && c != "\n" && c != "\r" { break }
        a = a + 1
    }
    let mut b = n
    while b > a {
        let c = s.substring(b - 1, b)
        if c != " " && c != "\t" && c != "\n" && c != "\r" { break }
        b = b - 1
    }
    return s.substring(a, b)
}

fn _xml_decode(s: string) -> string {
    let mut out = s
    out = out.replace("&amp;",  "&")
    out = out.replace("&lt;",   "<")
    out = out.replace("&gt;",   ">")
    out = out.replace("&quot;", "\"")
    out = out.replace("&apos;", "'")
    return out
}

// Slice the inner text of the next `<tag …>…</tag>` from `from`. Tolerates
// attributes on the open tag (PMID, Author, ELocationID, …).
fn _slice_tag_attr(xml: string, tag: string, from: int) -> string {
    let open  = "<" + tag
    let close = "</" + tag + ">"
    let a = _idx(xml, open, from)
    if a < 0 { return "" }
    let gt = _idx(xml, ">", a)
    if gt < 0 { return "" }
    let body_from = gt + 1
    let b = _idx(xml, close, body_from)
    if b < 0 { return "" }
    return xml.substring(body_from, b)
}

// Next `<PubmedArticle …>…</PubmedArticle>` body span as [body_from, after_close].
fn _next_article(xml: string, from: int) -> [int] {
    let a = _idx(xml, "<PubmedArticle", from)
    if a < 0 { return [-1, -1] }
    let gt = _idx(xml, ">", a)
    if gt < 0 { return [-1, -1] }
    let body_from = gt + 1
    let close = "</PubmedArticle>"
    let b = _idx(xml, close, body_from)
    if b < 0 { return [-1, -1] }
    return [body_from, b + len(close)]
}

// Authors as "LastName, ForeName" per <Author>…</Author>; skips entries
// missing a LastName (e.g. <CollectiveName>).
fn _authors(body: string) -> [string] {
    let mut out = []
    let mut i = 0
    let n = len(body)
    while i < n {
        let a = _idx(body, "<Author", i)
        if a < 0 { break }
        let gt = _idx(body, ">", a)
        if gt < 0 { break }
        let b = _idx(body, "</Author>", gt)
        if b < 0 { break }
        let block = body.substring(gt + 1, b)
        let last = _trim(_slice_tag_attr(block, "LastName", 0))
        let fore = _trim(_slice_tag_attr(block, "ForeName", 0))
        if len(last) > 0 {
            if len(fore) > 0 {
                out.push(_xml_decode(last + ", " + fore))
            } else {
                out.push(_xml_decode(last))
            }
        }
        i = b + len("</Author>")
    }
    return out
}

// Scan `<tag …>body</tag>` looking for the open-tag attr substring `marker`;
// return the first body match (decoded as raw text), else "".
fn _attr_tagged(body: string, tag: string, marker: string) -> string {
    let open  = "<"  + tag
    let close = "</" + tag + ">"
    let mut i = 0
    let n = len(body)
    while i < n {
        let a = _idx(body, open, i)
        if a < 0 { return "" }
        let gt = _idx(body, ">", a)
        if gt < 0 { return "" }
        let open_tag = body.substring(a, gt + 1)
        let b = _idx(body, close, gt)
        if b < 0 { return "" }
        if _idx(open_tag, marker, 0) >= 0 {
            return _trim(body.substring(gt + 1, b))
        }
        i = b + len(close)
    }
    return ""
}

// DOI: prefer <ELocationID EIdType="doi">, else <ArticleId IdType="doi">.
fn _doi(body: string) -> string {
    let v = _attr_tagged(body, "ELocationID", "EIdType=\"doi\"")
    if len(v) > 0 { return v }
    return _attr_tagged(body, "ArticleId", "IdType=\"doi\"")
}

// Journal title: <Journal>…<Title>…</Title>…</Journal>.
fn _journal_title(body: string) -> string {
    let j = _idx(body, "<Journal>", 0)
    if j < 0 { return "" }
    let je = _idx(body, "</Journal>", j)
    if je < 0 { return "" }
    return _trim(_slice_tag_attr(body.substring(j, je), "Title", 0))
}

// Pub year: <PubDate><Year>…</Year>.
fn _pub_year(body: string) -> string {
    let j = _idx(body, "<PubDate>", 0)
    if j < 0 { return "" }
    let je = _idx(body, "</PubDate>", j)
    if je < 0 { return "" }
    return _trim(_slice_tag_attr(body.substring(j, je), "Year", 0))
}

// Concatenate every <AbstractText …>…</AbstractText> with single spaces.
// Structured abstracts emit multiple labelled chunks; we flatten.
fn _abstract(body: string) -> string {
    let mut parts = []
    let mut i = 0
    let n = len(body)
    while i < n {
        let a = _idx(body, "<AbstractText", i)
        if a < 0 { break }
        let gt = _idx(body, ">", a)
        if gt < 0 { break }
        let b = _idx(body, "</AbstractText>", gt)
        if b < 0 { break }
        let chunk = _trim(body.substring(gt + 1, b))
        if len(chunk) > 0 { parts.push(chunk) }
        i = b + len("</AbstractText>")
    }
    if len(parts) == 0 { return "" }
    let mut out = parts[0]
    let mut k = 1
    while k < len(parts) {
        out = out + " " + parts[k]
        k = k + 1
    }
    return _xml_decode(out)
}

// ── public surface ──────────────────────────────────────────────────

// Parse a PubMed efetch XML body into PubmedPaper records. Pure, offline-safe.
pub fn pubmed_parse_efetch(xml: string) -> [PubmedPaper] {
    let mut out = []
    if len(xml) == 0 { return out }
    let mut cursor = 0
    while true {
        let span = _next_article(xml, cursor)
        let s = span[0]
        let e = span[1]
        if s < 0 { break }
        let body = xml.substring(s, e - len("</PubmedArticle>"))
        cursor = e

        let paper = PubmedPaper{
            pmid:     _trim(_slice_tag_attr(body, "PMID", 0)),
            title:    _xml_decode(_trim(_slice_tag_attr(body, "ArticleTitle", 0))),
            abstract: _abstract(body),
            authors:  _authors(body),
            journal:  _xml_decode(_journal_title(body)),
            year:     _pub_year(body),
            doi:      _doi(body),
        }
        out.push(paper)
    }
    return out
}

// Parse esearch <IdList><Id>…</Id></IdList> → [PMID]. Pure.
pub fn pubmed_parse_esearch(xml: string) -> [string] {
    let mut out = []
    if len(xml) == 0 { return out }
    let il = _idx(xml, "<IdList>", 0)
    if il < 0 { return out }
    let ile = _idx(xml, "</IdList>", il)
    if ile < 0 { return out }
    let block = xml.substring(il, ile)
    let mut i = 0
    let n = len(block)
    while i < n {
        let a = _idx(block, "<Id>", i)
        if a < 0 { break }
        let b = _idx(block, "</Id>", a)
        if b < 0 { break }
        let id = _trim(block.substring(a + len("<Id>"), b))
        if len(id) > 0 { out.push(id) }
        i = b + len("</Id>")
    }
    return out
}

fn _q_encode(q: string) -> string {
    return q.replace(" ", "+")
}

// Live esearch. Returns PMID list (≤ max_results, clamped to [1,200]), or
// [] on network failure.
pub fn pubmed_search(query: string, max_results: int) -> [string] {
    if len(query) == 0 { return [] }
    let mut n = max_results
    if n < 1 { n = 1 }
    if n > 200 { n = 200 }
    let url = PUBMED_ESEARCH + "?db=pubmed&term=" + _q_encode(query)
        + "&retmax=" + to_string(n)
    return pubmed_parse_esearch(http_get(url))
}

// Live efetch by PMID. Returns an empty placeholder on miss / network failure.
pub fn pubmed_fetch(pmid: string) -> PubmedPaper {
    let empty = PubmedPaper{
        pmid: "", title: "", abstract: "", authors: [],
        journal: "", year: "", doi: "",
    }
    if len(pmid) == 0 { return empty }
    let url = PUBMED_EFETCH + "?db=pubmed&id=" + pmid + "&retmode=xml"
    let papers = pubmed_parse_efetch(http_get(url))
    if len(papers) == 0 { return empty }
    return papers[0]
}
