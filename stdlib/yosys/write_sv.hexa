#!hexa strict
// stdlib/yosys/write_sv.hexa — RTLIL → SystemVerilog netlist backend
//
// @version 0.1.0
// @capabilities [backend, systemverilog, sv, emit, gate-netlist]
// @stability phase-a (FIRMWARE.md G-R2)
// @since 2026-05-20
// @authority FIRMWARE.md §4 G-R2 + RFC 064
//
// SystemVerilog (IEEE Std 1800-2017) dialect emitter. SV is a strict
// superset of Verilog-2005, so every output of stdlib/yosys/write_verilog
// is already valid SV. This module emits the SV-idiomatic variant:
//
//   - module ports declared with `logic` (the 4-state SV scalar type)
//     instead of the Verilog-2005 `wire` / `reg` split;
//   - internal nets declared with `logic`;
//   - file extension convention `.sv` (the caller decides — this module
//     emits text only);
//   - cell instances and concurrent `assign` statements identical to
//     Verilog (SV preserves the syntax).
//
// CLEAN-ROOM PROVENANCE
//   - IEEE Std 1800-2017 (SystemVerilog Unified Hardware Design,
//     Specification, and Verification Language) — Annex A (formal
//     syntax), §6 (data types), §22 (compiler directives)
//   - upstream code     : (none — Yosys' upstream SV backend emits
//                          the same shape; this module re-derives
//                          against the standard, not the upstream)

use "stdlib/yosys/rtlil"

// ─── public types ────────────────────────────────────────────────────────

struct WriteSvResult {
    ok:    int,
    text:  str,
    bytes: int,
}

// ─── helpers ─────────────────────────────────────────────────────────────

fn _wsv_collect_sorted_port_idxs(m: Module) -> [int] {
    let mut idxs: [int] = []
    let mut i = 0
    while i < len(m.wires) {
        if m.wires[i].port_id > 0 { idxs = idxs.push(i) }
        i = i + 1
    }
    let mut sorted: [int] = []
    let mut remaining = idxs
    while len(remaining) > 0 {
        let mut min_pi = 0
        let mut k = 1
        while k < len(remaining) {
            if m.wires[remaining[k]].port_id < m.wires[remaining[min_pi]].port_id {
                min_pi = k
            }
            k = k + 1
        }
        sorted = sorted.push(remaining[min_pi])
        let mut next: [int] = []
        let mut kk = 0
        while kk < len(remaining) {
            if kk != min_pi { next = next.push(remaining[kk]) }
            kk = kk + 1
        }
        remaining = next
    }
    return sorted
}

// SV port direction. Same lexemes as Verilog-2005 for `input`/`output`/`inout`.
fn _wsv_dir(dir_kind: int) -> str {
    if dir_kind == 1 { return "input" }
    if dir_kind == 2 { return "output" }
    if dir_kind == 3 { return "inout" }
    return ""
}

// SV idiomatic port emit: `<dir> logic [W-1:0] <name>` (the `logic` type
// is the SV-2017 4-state scalar — replaces the Verilog wire/reg split).
fn _wsv_emit_port(w: Wire) -> str {
    let dir = _wsv_dir(w.dir_kind)
    let mut typ = "logic"
    if w.width > 1 {
        typ = "logic [" + str(w.width - 1) + ":0]"
    }
    return dir + " " + typ + " " + w.name
}

// SV internal-net declaration: `logic [W-1:0] <name>;`.
fn _wsv_emit_internal(w: Wire) -> str {
    let mut typ = "logic"
    if w.width > 1 {
        typ = "logic [" + str(w.width - 1) + ":0]"
    }
    return "  " + typ + " " + w.name + ";\n"
}

// SV concurrent assign — identical to Verilog.
fn _wsv_emit_connect(lhs: str, rhs: str) -> str {
    return "  assign " + lhs + " = " + rhs + ";\n"
}

// SV cell instance — identical to Verilog (named port association).
fn _wsv_emit_cell(c: Cell, idx: int) -> str {
    let mut out = "  " + c.cell_type + " " + c.name + " ("
    let mut i = 0
    while i < len(c.conns) {
        if i > 0 { out = out + ", " }
        out = out + "." + c.conns[i].pin + "(" + c.conns[i].net + ")"
        i = i + 1
    }
    out = out + ");\n"
    return out
}

// ─── module → text ───────────────────────────────────────────────────────

// SV ANSI-style port declaration: `module name (input logic a, output logic y);`.
// Cleaner than Verilog-2005's port-list + separate-decl style.
fn write_sv_module(m: Module) -> str {
    let sorted = _wsv_collect_sorted_port_idxs(m)
    let mut out = "module " + m.name + " ("
    let mut j = 0
    while j < len(sorted) {
        if j > 0 { out = out + ", " }
        out = out + _wsv_emit_port(m.wires[sorted[j]])
        j = j + 1
    }
    out = out + ");\n"

    // internal nets (dir_kind == 0)
    let mut wj = 0
    while wj < len(m.wires) {
        if m.wires[wj].port_id == 0 {
            out = out + _wsv_emit_internal(m.wires[wj])
        }
        wj = wj + 1
    }
    // top-level concurrent assignments
    let mut ki = 0
    while ki < len(m.connect_lhs) {
        out = out + _wsv_emit_connect(m.connect_lhs[ki], m.connect_rhs[ki])
        ki = ki + 1
    }
    // cell instances
    let mut ci = 0
    while ci < len(m.cells) {
        out = out + _wsv_emit_cell(m.cells[ci], ci)
        ci = ci + 1
    }
    out = out + "endmodule\n"
    return out
}

fn write_sv(d: Design) -> WriteSvResult {
    let mut out = "// Generated by stdlib/yosys/write_sv.hexa (FIRMWARE.md G-R2 + RFC 064)\n"
    out = out + "// source: " + d.source + "\n"
    out = out + "// SystemVerilog IEEE Std 1800-2017\n\n"
    let mut i = 0
    while i < len(d.modules) {
        out = out + write_sv_module(d.modules[i])
        if i + 1 < len(d.modules) { out = out + "\n" }
        i = i + 1
    }
    return WriteSvResult { ok: 1, text: out, bytes: len(out) }
}

fn write_sv_file(d: Design, path: str) -> WriteSvResult {
    let r = write_sv(d)
    write_file(path, r.text)
    return r
}

// ─── self-test ───────────────────────────────────────────────────────────

fn main() {
    let mut fails = 0
    let mut total = 0

    // Same RTLIL fixture as write_verilog selftest.
    let mut m = rtlil_new_module("ab")
    m = rtlil_module_add_wire(m, rtlil_wire("a", 1, 1, 1))
    m = rtlil_module_add_wire(m, rtlil_wire("b", 1, 1, 2))
    m = rtlil_module_add_wire(m, rtlil_wire("y", 1, 2, 3))
    let mut c = rtlil_cell("u_and", "sky130_fd_sc_hd__and2_1", 1)
    c = rtlil_cell_connect(c, "A", "a")
    c = rtlil_cell_connect(c, "B", "b")
    c = rtlil_cell_connect(c, "X", "y")
    m = rtlil_module_add_cell(m, c)
    let mut d = rtlil_new_design("test")
    d = rtlil_design_add(d, m)

    // T1 — ANSI-style port list, `logic` type, all expected fragments.
    total = total + 1
    let r1 = write_sv(d)
    if r1.ok != 1 { println("FAIL T1 ok"); fails = fails + 1 }
    if r1.text.find("module ab (") < 0 {
        println("FAIL T1b module"); fails = fails + 1
    }
    if r1.text.find("input logic a") < 0 {
        println("FAIL T1c input_logic_a"); fails = fails + 1
    }
    if r1.text.find("output logic y") < 0 {
        println("FAIL T1d output_logic_y"); fails = fails + 1
    }
    if r1.text.find("sky130_fd_sc_hd__and2_1 u_and") < 0 {
        println("FAIL T1e cell"); fails = fails + 1
    }
    if r1.text.find(".A(a)") < 0 {
        println("FAIL T1f pin_A"); fails = fails + 1
    }
    if r1.text.find("endmodule") < 0 {
        println("FAIL T1g endmodule"); fails = fails + 1
    }

    // T2 — SV-2017 marker in the header comment.
    total = total + 1
    if r1.text.find("SystemVerilog IEEE Std 1800-2017") < 0 {
        println("FAIL T2 sv_marker"); fails = fails + 1
    }

    // T3 — byte-stable.
    total = total + 1
    let r3a = write_sv(d)
    let r3b = write_sv(d)
    if r3a.text != r3b.text {
        println("FAIL T3 byte_stable"); fails = fails + 1
    }

    // T4 — internal net emitted as `logic <n>;`.
    total = total + 1
    let mut m2 = rtlil_new_module("ii")
    m2 = rtlil_module_add_wire(m2, rtlil_wire("z", 1, 0, 0))
    let mut d2 = rtlil_new_design("test")
    d2 = rtlil_design_add(d2, m2)
    let r4 = write_sv(d2)
    if r4.text.find("logic z;") < 0 {
        println("FAIL T4 internal_logic"); fails = fails + 1
    }

    // T5 — concurrent `assign` preserved.
    total = total + 1
    let mut m3 = rtlil_new_module("c")
    m3 = rtlil_module_add_wire(m3, rtlil_wire("a", 1, 1, 1))
    m3 = rtlil_module_add_wire(m3, rtlil_wire("y", 1, 2, 2))
    m3 = rtlil_module_connect(m3, "y", "a")
    let mut d3 = rtlil_new_design("test")
    d3 = rtlil_design_add(d3, m3)
    let r5 = write_sv(d3)
    if r5.text.find("assign y = a;") < 0 {
        println("FAIL T5 assign"); fails = fails + 1
    }

    // T6 — empty design header.
    total = total + 1
    let r6 = write_sv(rtlil_new_design("test"))
    if r6.bytes <= 0 {
        println("FAIL T6 empty"); fails = fails + 1
    }

    // T7 — multi-module.
    total = total + 1
    let mut d4 = rtlil_new_design("test")
    d4 = rtlil_design_add(d4, rtlil_new_module("m_a"))
    d4 = rtlil_design_add(d4, rtlil_new_module("m_b"))
    let r7 = write_sv(d4)
    if r7.text.find("module m_a (") < 0 {
        println("FAIL T7 multi_a"); fails = fails + 1
    }
    if r7.text.find("module m_b (") < 0 {
        println("FAIL T7b multi_b"); fails = fails + 1
    }

    // T8 — multi-bit `logic [W-1:0]`.
    total = total + 1
    let mut m5 = rtlil_new_module("v")
    m5 = rtlil_module_add_wire(m5, rtlil_wire("bus", 4, 1, 1))
    let mut d5 = rtlil_new_design("test")
    d5 = rtlil_design_add(d5, m5)
    let r8 = write_sv(d5)
    if r8.text.find("input logic [3:0] bus") < 0 {
        println("FAIL T8 multibit"); fails = fails + 1
    }

    if fails > 0 {
        println("write_sv selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("write_sv selftest: " + str(total) + "/" + str(total) + " PASS")
}
