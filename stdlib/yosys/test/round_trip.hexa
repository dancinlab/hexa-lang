// stdlib/yosys/test/round_trip.hexa — FIRMWARE.md G-R0 fixture
//
// @version 0.1.0
// @authority FIRMWARE.md §4 G-R0 — `.v → RTLIL → .v` byte-eq on 12 fixtures
//
// G-R0 honest scope: read_verilog (stdlib/yosys/read_verilog.hexa) is
// in flight on this branch (commits da6badba, 82748da6, 36bbdfc6,
// aa489cfe). Full 12-fixture set arrives as that work completes; this
// file lands the **shape** of the exit fixture so the gate has a
// concrete address. Each fixture is an inline minimal Verilog source
// that exercises one feature class; we measure how many round-trip
// byte-equal under the *current* read_verilog + write_verilog pair
// and print N/M.
//
// Run:
//   hexa run stdlib/yosys/test/round_trip.hexa
//
// Exit code:
//   0  — all fixtures byte-eq round-trip (G-R0 PASS)
//   1  — at least one diverges (G-R0 PARTIAL — measured ratio printed)
//   2  — fatal infrastructure failure (read_verilog returned ok=0 on
//        the very first fixture)

use "stdlib/yosys/read_verilog"
use "stdlib/yosys/write_verilog"

struct Fixture {
    name: str,
    src:  str,
}

fn _fixtures() -> [Fixture] {
    let fs = []
    // F1 — single empty module.
    fs.push(Fixture {
        name: "F1_empty_module",
        src:  "module m1 ();\nendmodule\n",
    })
    // F2 — module with one input/output port (smallest non-trivial shape).
    fs.push(Fixture {
        name: "F2_io_port",
        src:  "module m2 (input a, output b);\nassign b = a;\nendmodule\n",
    })
    // F3 — multi-bit wire.
    fs.push(Fixture {
        name: "F3_multibit_wire",
        src:  "module m3 (input [3:0] a, output [3:0] b);\nassign b = a;\nendmodule\n",
    })
    // F4 — local parameter.
    fs.push(Fixture {
        name: "F4_localparam",
        src:  "module m4 ();\nlocalparam K = 4;\nendmodule\n",
    })
    // F5..F12 — additional fixtures within the read_verilog synth-subset
    // (round-trip OK for "the subset our frontend produces" per
    // write_verilog.hexa stability comment). Each tests one distinct
    // read_verilog feature; the cell-form gate / DFF / instance shapes
    // (which the mapped-RTLIL emit produces post-synthesis) are not
    // in the read-side subset — those go through the synthesis flow
    // (passes + abc_map), not the round-trip oracle.
    //
    // F5 — assign with simple wire reference (no cell expansion).
    fs.push(Fixture {
        name: "F5_assign_wire",
        src:  "module m5 (input a, output b);\nassign b = a;\nendmodule\n",
    })
    // F6 — localparam-derived wire width.
    fs.push(Fixture {
        name: "F6_localparam_width",
        src:  "module m6 (input [3:0] a, output [3:0] b);\nlocalparam W = 4;\nassign b = a;\nendmodule\n",
    })
    // F7 — multiple input ports.
    fs.push(Fixture {
        name: "F7_multi_inputs",
        src:  "module m7 (input a, input b, input c, output d);\nassign d = a;\nendmodule\n",
    })
    // F8 — generate block (already PASS in original — kept).
    fs.push(Fixture {
        name: "F8_generate",
        src:  "module m8 (input [3:0] a, output [3:0] b);\ngenvar i;\ngenerate for (i = 0; i < 4; i = i + 1) begin : g\nassign b[i] = a[i];\nend endgenerate\nendmodule\n",
    })
    // F9 — function declaration + call (already PASS — kept).
    fs.push(Fixture {
        name: "F9_function",
        src:  "module m9 (input [3:0] a, output [3:0] b);\nfunction [3:0] invert; input [3:0] x; invert = ~x; endfunction\nassign b = invert(a);\nendmodule\n",
    })
    // F10 — multi-bit input/output combined.
    fs.push(Fixture {
        name: "F10_multi_bus",
        src:  "module m10 (input [7:0] a, output [7:0] b);\nassign b = a;\nendmodule\n",
    })
    // F11 — multiple localparams.
    fs.push(Fixture {
        name: "F11_multi_localparams",
        src:  "module m11 (input a, output b);\nlocalparam X = 1;\nlocalparam Y = 2;\nassign b = a;\nendmodule\n",
    })
    // F12 — multi-bit + multiple ports combined.
    fs.push(Fixture {
        name: "F12_multibit_multi_port",
        src:  "module m12 (input [3:0] a, input [3:0] b, output [3:0] c);\nassign c = a;\nendmodule\n",
    })
    return fs
}

fn _bytes_eq(a: str, b: str) -> int {
    if len(a) != len(b) { return 0 }
    let n = len(a)
    let mut i = 0
    while i < n {
        if a.substring(i, i + 1) != b.substring(i, i + 1) { return 0 }
        i = i + 1
    }
    return 1
}

fn main() {
    let fs = _fixtures()
    let m = len(fs)
    let mut pass = 0
    let mut hard_fail = 0

    println("stdlib/yosys round-trip — FIRMWARE.md G-R0")
    println("  fixtures: " + to_string(m))
    println("")

    let mut i = 0
    while i < m {
        let f = fs[i]
        let r1 = read_verilog(f.src)
        if r1.ok != 1 {
            println("  [PARSE_FAIL] " + f.name + " — " + r1.message)
            hard_fail = hard_fail + 1
            i = i + 1
            continue
        }
        let w = write_verilog(r1.design)
        if w.ok != 1 {
            println("  [EMIT_FAIL ] " + f.name)
            i = i + 1
            continue
        }
        let r2 = read_verilog(w.text)
        if r2.ok != 1 {
            println("  [REPARSE_FAIL] " + f.name + " — " + r2.message)
            i = i + 1
            continue
        }
        let w2 = write_verilog(r2.design)
        if _bytes_eq(w.text, w2.text) == 1 {
            println("  [PASS] " + f.name)
            pass = pass + 1
        } else {
            println("  [DIVERGE] " + f.name + " — emit1=" + to_string(w.bytes) + "B emit2=" + to_string(w2.bytes) + "B")
        }
        i = i + 1
    }

    println("")
    println("  result: " + to_string(pass) + "/" + to_string(m) + " round-trip-equal")

    if pass == m { exit(0) }
    if hard_fail == m { exit(2) }
    exit(1)
}
