#!hexa strict
// stdlib/yosys/write_sdc.hexa — Synopsys Design Constraints emitter
//
// @version 0.1.0
// @capabilities [backend, sdc, timing, emit]
// @stability phase-a (FIRMWARE.md G-R4)
// @since 2026-05-20
// @authority FIRMWARE.md §4 G-R4 + RFC 064
//
// SDC (Synopsys Design Constraints) — the industry-standard timing
// constraint format consumed by synthesis tools (yosys, Vivado,
// Quartus, Synopsys Design Compiler). This module emits SDC text
// from `@clock` / `@reset` / `@async` metadata threaded through an
// RTLIL Design — see RFC 064 §5 step 3.
//
// G-R4 honest scope: the `@clock` / `@reset` / `@async` annotations
// are codegen-side metadata that the front-end pass (G-R1) propagates
// from hexa source into RTLIL. Until the front-end pass lands, this
// module accepts the metadata as explicit function arguments
// (procedural API) — same minimum-viable shape as the G-R1 counter
// demo. The annotation-driven path slots in once the codegen lane
// is ready.
//
// CLEAN-ROOM PROVENANCE
//   - Synopsys "Using the Synopsys Design Constraints Format Application
//     Note" (2014) — the SDC reference. Public material, no upstream
//     code copied.
//   - IEEE Std 1481-2009 (delay calculation) — informative reference
//     for the timing semantics SDC encodes.

use "stdlib/yosys/rtlil"

// ─── public types ────────────────────────────────────────────────────────

struct ClockSpec {
    name:        str,
    port:        str,      // the wire name on the design's port list
    period_ns:   int,      // SDC accepts float; we round-trip an int-ns
                            // representation for byte-eq determinism.
}

struct IoDelaySpec {
    clock:       str,      // referenced clock name
    delay_ns:    int,
    is_input:    int,      // 1 = set_input_delay, 0 = set_output_delay
    port:        str,      // wire name on the design's port list (or "*"
                            // — caller resolves)
}

struct WriteSdcResult {
    ok:    int,
    text:  str,
    bytes: int,
}

// ─── helpers ─────────────────────────────────────────────────────────────

fn _wsdc_emit_clock(c: ClockSpec) -> str {
    return "create_clock -name " + c.name + " -period " + str(c.period_ns) + ".0 [get_ports " + c.port + "]\n"
}

fn _wsdc_emit_io_delay(io: IoDelaySpec) -> str {
    let mut kw = "set_output_delay"
    if io.is_input == 1 { kw = "set_input_delay" }
    return kw + " -clock " + io.clock + " " + str(io.delay_ns) + ".0 [get_ports " + io.port + "]\n"
}

fn _wsdc_emit_async(reset_port: str) -> str {
    // Async reset doesn't participate in normal STA — break the path
    // with set_false_path.
    return "set_false_path -from [get_ports " + reset_port + "]\n"
}

// ─── public API ──────────────────────────────────────────────────────────

// Build an SDC constraint file given the design, clock spec, optional
// I/O delays, and optional async reset ports. The output is byte-stable
// for fixed inputs.
fn write_sdc(d: Design, clocks: [ClockSpec], ios: [IoDelaySpec], async_resets: [str]) -> WriteSdcResult {
    let mut out = "# Generated by stdlib/yosys/write_sdc.hexa (FIRMWARE.md G-R4 + RFC 064)\n"
    out = out + "# source: " + d.source + "\n"
    out = out + "# format: Synopsys Design Constraints (SDC)\n\n"

    // clocks first — every downstream constraint references one of these
    if len(clocks) > 0 {
        out = out + "# ── clock definitions ──────────────────────────────────────────\n"
        let mut i = 0
        while i < len(clocks) {
            out = out + _wsdc_emit_clock(clocks[i])
            i = i + 1
        }
        out = out + "\n"
    }

    // I/O delays — reference a clock by name
    if len(ios) > 0 {
        out = out + "# ── I/O delay constraints ──────────────────────────────────────\n"
        let mut j = 0
        while j < len(ios) {
            out = out + _wsdc_emit_io_delay(ios[j])
            j = j + 1
        }
        out = out + "\n"
    }

    // async resets — set_false_path breaks STA along these
    if len(async_resets) > 0 {
        out = out + "# ── async reset paths ──────────────────────────────────────────\n"
        let mut k = 0
        while k < len(async_resets) {
            out = out + _wsdc_emit_async(async_resets[k])
            k = k + 1
        }
    }

    return WriteSdcResult { ok: 1, text: out, bytes: len(out) }
}

fn write_sdc_file(d: Design, clocks: [ClockSpec], ios: [IoDelaySpec], async_resets: [str], path: str) -> WriteSdcResult {
    let r = write_sdc(d, clocks, ios, async_resets)
    write_file(path, r.text)
    return r
}

// ─── self-test ───────────────────────────────────────────────────────────

fn main() {
    let mut fails = 0
    let mut total = 0

    // Build a tiny design (counter-like: clk + rst inputs, q output).
    let mut m = rtlil_new_module("counter")
    m = rtlil_module_add_wire(m, rtlil_wire("clk", 1, 1, 1))
    m = rtlil_module_add_wire(m, rtlil_wire("rst", 1, 1, 2))
    m = rtlil_module_add_wire(m, rtlil_wire("q", 4, 2, 3))
    let mut d = rtlil_new_design("test")
    d = rtlil_design_add(d, m)

    // T1 — clock-only SDC.
    total = total + 1
    let clk_only: [ClockSpec] = [
        ClockSpec { name: "clk", port: "clk", period_ns: 10 },
    ]
    let no_ios: [IoDelaySpec] = []
    let no_async: [str] = []
    let r1 = write_sdc(d, clk_only, no_ios, no_async)
    if r1.ok != 1 { println("FAIL T1 ok"); fails = fails + 1 }
    if r1.text.find("create_clock -name clk -period 10.0 [get_ports clk]") < 0 {
        println("FAIL T1b create_clock"); fails = fails + 1
    }
    if r1.text.find("Synopsys Design Constraints") < 0 {
        println("FAIL T1c sdc_marker"); fails = fails + 1
    }

    // T2 — I/O delay section.
    total = total + 1
    let ios: [IoDelaySpec] = [
        IoDelaySpec { clock: "clk", delay_ns: 1, is_input: 1, port: "rst" },
        IoDelaySpec { clock: "clk", delay_ns: 2, is_input: 0, port: "q" },
    ]
    let r2 = write_sdc(d, clk_only, ios, no_async)
    if r2.text.find("set_input_delay -clock clk 1.0 [get_ports rst]") < 0 {
        println("FAIL T2 in_delay"); fails = fails + 1
    }
    if r2.text.find("set_output_delay -clock clk 2.0 [get_ports q]") < 0 {
        println("FAIL T2b out_delay"); fails = fails + 1
    }

    // T3 — async reset → set_false_path.
    total = total + 1
    let async_r: [str] = ["rst_async"]
    let r3 = write_sdc(d, clk_only, no_ios, async_r)
    if r3.text.find("set_false_path -from [get_ports rst_async]") < 0 {
        println("FAIL T3 false_path"); fails = fails + 1
    }

    // T4 — byte-stable.
    total = total + 1
    let r4a = write_sdc(d, clk_only, ios, async_r)
    let r4b = write_sdc(d, clk_only, ios, async_r)
    if r4a.text != r4b.text {
        println("FAIL T4 byte_stable"); fails = fails + 1
    }

    // T5 — multi-clock (system + reference).
    total = total + 1
    let multi: [ClockSpec] = [
        ClockSpec { name: "sys_clk", port: "clk",     period_ns: 10 },
        ClockSpec { name: "ref_clk", port: "ref",     period_ns: 25 },
    ]
    let r5 = write_sdc(d, multi, no_ios, no_async)
    if r5.text.find("create_clock -name sys_clk -period 10.0 [get_ports clk]") < 0 {
        println("FAIL T5 multi_a"); fails = fails + 1
    }
    if r5.text.find("create_clock -name ref_clk -period 25.0 [get_ports ref]") < 0 {
        println("FAIL T5b multi_b"); fails = fails + 1
    }

    // T6 — empty constraints still produces a valid header.
    total = total + 1
    let r6 = write_sdc(d, [], [], [])
    if r6.bytes <= 0 {
        println("FAIL T6 empty_header"); fails = fails + 1
    }
    if r6.text.find("Synopsys Design Constraints") < 0 {
        println("FAIL T6b empty_marker"); fails = fails + 1
    }

    if fails > 0 {
        println("write_sdc selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("write_sdc selftest: " + str(total) + "/" + str(total) + " PASS")
}
