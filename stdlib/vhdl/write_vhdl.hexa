#!hexa strict
// stdlib/vhdl/write_vhdl.hexa — RTLIL → gate-level VHDL-2008 backend
//
// @version 0.1.0
// @capabilities [backend, vhdl, emit, gate-netlist]
// @stability phase-a (FIRMWARE.md G-R3 — mapped-RTLIL → gate VHDL text
//   emitter; deterministic ordering; mirrors stdlib/yosys/write_verilog
//   shape against IEEE Std 1076-2008)
// @since 2026-05-20
// @authority FIRMWARE.md §4 G-R3 + RFC 064
//
// CLEAN-ROOM PROVENANCE
//   - upstream code  : (none — Yosys has no VHDL backend; this module
//                       is authored directly against the IEEE standard)
//   - IEEE ref (norm): IEEE Std 1076-2008 VHDL Language Reference Manual
//                       — entity declaration §4.2, architecture body §4.3,
//                       port clause §6.5.6, signal assignment §10.5,
//                       component instantiation §7.3.3
//   - upstream manual: GHDL user guide (https://ghdl.github.io/ghdl/)
//                       — analyse + elaborate flow as the exit oracle
//   - absorbed substrate (D18): GHDL (G-R3 exit fixture invokes
//                       `ghdl -a` and `ghdl -e` over the emitted .vhd;
//                       see RFC 064 G-R3 falsifier).
//
// Output convention (IEEE 1076-2008):
//   one (entity, architecture) pair per RTLIL Module; gate cells emitted
//   as component instantiations with named port maps. Wires become
//   internal signals; ports declared in the entity's port clause.
//   Deterministic ordering matches stdlib/yosys/write_verilog: modules
//   in user-supplied order; ports in port_id ascending order; internal
//   signals by declaration order; cells by emission order. Byte-stable.

use "stdlib/yosys/rtlil"

// ─── public types ────────────────────────────────────────────────────────

struct WriteVhdlResult {
    ok:    int,
    text:  str,
    bytes: int,
}

// ─── helpers ─────────────────────────────────────────────────────────────

// CLEAN-ROOM: emit ports in port_id ascending order, formatted as a
// VHDL port clause: `port_name : direction std_logic`, separated by
// `;\n    `. Mirrors _wv_emit_port_list shape.
fn _wh_collect_sorted_port_idxs(m: Module) -> [int] {
    let mut idxs: [int] = []
    let mut i = 0
    while i < len(m.wires) {
        if m.wires[i].port_id > 0 { idxs = idxs.push(i) }
        i = i + 1
    }
    let mut sorted: [int] = []
    let mut remaining = idxs
    while len(remaining) > 0 {
        let mut min_pi = 0
        let mut k = 1
        while k < len(remaining) {
            if m.wires[remaining[k]].port_id < m.wires[remaining[min_pi]].port_id {
                min_pi = k
            }
            k = k + 1
        }
        sorted = sorted.push(remaining[min_pi])
        let mut next: [int] = []
        let mut kk = 0
        while kk < len(remaining) {
            if kk != min_pi { next = next.push(remaining[kk]) }
            kk = kk + 1
        }
        remaining = next
    }
    return sorted
}

// CLEAN-ROOM: direction keyword per IEEE 1076-2008 §6.5.6 mode.
fn _wh_dir_of(dir_kind: int) -> str {
    if dir_kind == 1 { return "in" }
    if dir_kind == 2 { return "out" }
    if dir_kind == 3 { return "inout" }
    return ""
}

// CLEAN-ROOM: emit one port declaration line within the port clause.
// `<name> : <dir> std_logic`. Multi-bit widths emit
// `std_logic_vector(W-1 downto 0)`.
fn _wh_emit_port(w: Wire) -> str {
    let dir = _wh_dir_of(w.dir_kind)
    let mut typ = "std_logic"
    if w.width > 1 {
        typ = "std_logic_vector(" + str(w.width - 1) + " downto 0)"
    }
    return w.name + " : " + dir + " " + typ
}

// CLEAN-ROOM: emit an internal signal declaration in the architecture
// declarative region: `signal <name> : std_logic;`. Multi-bit widths
// emit `std_logic_vector(W-1 downto 0)`.
fn _wh_emit_signal(w: Wire) -> str {
    let mut typ = "std_logic"
    if w.width > 1 {
        typ = "std_logic_vector(" + str(w.width - 1) + " downto 0)"
    }
    return "  signal " + w.name + " : " + typ + ";\n"
}

// CLEAN-ROOM: emit a component instantiation in the architecture body:
//   <inst> : <type> port map (.A => a, .Y => y);
// VHDL-2008 named association is `=>` not `=` and uses `port map`.
fn _wh_emit_cell(c: Cell, idx: int) -> str {
    let mut out = "  " + c.name + " : " + c.cell_type + " port map ("
    let mut i = 0
    while i < len(c.conns) {
        if i > 0 { out = out + ", " }
        out = out + c.conns[i].pin + " => " + c.conns[i].net
        i = i + 1
    }
    out = out + ");\n"
    return out
}

// CLEAN-ROOM: emit a concurrent signal assignment (RTLIL ::connect):
// `<lhs> <= <rhs>;`. VHDL uses `<=` for signal assignment, not `=`.
fn _wh_emit_connect(lhs: str, rhs: str) -> str {
    return "  " + lhs + " <= " + rhs + ";\n"
}

// ─── module → text ───────────────────────────────────────────────────────

// CLEAN-ROOM: emit a full (entity, architecture) pair.
// Pattern (IEEE 1076-2008):
//   entity <name> is
//     port (
//       p1 : in std_logic;
//       ...
//     );
//   end entity;
//
//   architecture rtl of <name> is
//     signal s1 : std_logic;
//     ...
//   begin
//     <connects>
//     <cell instances>
//   end architecture;
fn write_vhdl_module(m: Module) -> str {
    let sorted = _wh_collect_sorted_port_idxs(m)

    // entity declaration
    let mut out = "entity " + m.name + " is\n"
    if len(sorted) > 0 {
        out = out + "  port (\n"
        let mut j = 0
        while j < len(sorted) {
            out = out + "    " + _wh_emit_port(m.wires[sorted[j]])
            if j + 1 < len(sorted) { out = out + ";" }
            out = out + "\n"
            j = j + 1
        }
        out = out + "  );\n"
    }
    out = out + "end entity;\n\n"

    // architecture body
    out = out + "architecture rtl of " + m.name + " is\n"
    // internal signals (dir_kind == 0)
    let mut wj = 0
    while wj < len(m.wires) {
        if m.wires[wj].port_id == 0 {
            out = out + _wh_emit_signal(m.wires[wj])
        }
        wj = wj + 1
    }
    out = out + "begin\n"
    // top-level concurrent assignments
    let mut ki = 0
    while ki < len(m.connect_lhs) {
        out = out + _wh_emit_connect(m.connect_lhs[ki], m.connect_rhs[ki])
        ki = ki + 1
    }
    // cell instantiations
    let mut ci = 0
    while ci < len(m.cells) {
        out = out + _wh_emit_cell(m.cells[ci], ci)
        ci = ci + 1
    }
    out = out + "end architecture;\n"
    return out
}

// CLEAN-ROOM: emit a full design as a single VHDL text buffer.
// Modules concatenated in declaration order; header carries the RTLIL
// source provenance for the audit trail. The `library ieee;` +
// `use ieee.std_logic_1164.all;` preamble enables std_logic / vector
// types referenced throughout.
fn write_vhdl(d: Design) -> WriteVhdlResult {
    let mut out = "-- Generated by stdlib/vhdl/write_vhdl.hexa (FIRMWARE.md G-R3 + RFC 064)\n"
    out = out + "-- source: " + d.source + "\n\n"
    out = out + "library ieee;\n"
    out = out + "use ieee.std_logic_1164.all;\n\n"
    let mut i = 0
    while i < len(d.modules) {
        out = out + write_vhdl_module(d.modules[i])
        if i + 1 < len(d.modules) { out = out + "\n" }
        i = i + 1
    }
    return WriteVhdlResult { ok: 1, text: out, bytes: len(out) }
}

// CLEAN-ROOM: write the emitted text to a file path.
fn write_vhdl_file(d: Design, path: str) -> WriteVhdlResult {
    let r = write_vhdl(d)
    write_file(path, r.text)
    return r
}

// ─── self-test ───────────────────────────────────────────────────────────

fn main() {
    let mut fails = 0
    let mut total = 0

    // Build the same fixture as write_verilog's selftest (and-gate cell
    // with two inputs + one output). The expected output shape differs
    // by syntax but the underlying RTLIL is identical — that is the
    // exact mirror property G-R3 tests.
    let mut m = rtlil_new_module("ab")
    m = rtlil_module_add_wire(m, rtlil_wire("a", 1, 1, 1))
    m = rtlil_module_add_wire(m, rtlil_wire("b", 1, 1, 2))
    m = rtlil_module_add_wire(m, rtlil_wire("y", 1, 2, 3))
    let mut c = rtlil_cell("u_and", "sky130_fd_sc_hd__and2_1", 1)
    c = rtlil_cell_connect(c, "A", "a")
    c = rtlil_cell_connect(c, "B", "b")
    c = rtlil_cell_connect(c, "X", "y")
    m = rtlil_module_add_cell(m, c)
    let mut d = rtlil_new_design("test")
    d = rtlil_design_add(d, m)

    // T1 — emit non-empty, contains expected fragments.
    total = total + 1
    let r1 = write_vhdl(d)
    if r1.ok != 1 {
        println("FAIL T1 ok"); fails = fails + 1
    }
    if r1.text.find("entity ab is") < 0 {
        println("FAIL T1b entity"); fails = fails + 1
    }
    if r1.text.find("a : in std_logic") < 0 {
        println("FAIL T1c port_a"); fails = fails + 1
    }
    if r1.text.find("y : out std_logic") < 0 {
        println("FAIL T1d port_y"); fails = fails + 1
    }
    if r1.text.find("architecture rtl of ab is") < 0 {
        println("FAIL T1e arch"); fails = fails + 1
    }
    if r1.text.find("u_and : sky130_fd_sc_hd__and2_1 port map") < 0 {
        println("FAIL T1f inst"); fails = fails + 1
    }
    if r1.text.find("A => a") < 0 {
        println("FAIL T1g pin_A"); fails = fails + 1
    }
    if r1.text.find("end architecture;") < 0 {
        println("FAIL T1h end_arch"); fails = fails + 1
    }

    // T2 — preamble (library + use) emitted once at the top.
    total = total + 1
    if r1.text.find("library ieee;") < 0 {
        println("FAIL T2 library"); fails = fails + 1
    }
    if r1.text.find("use ieee.std_logic_1164.all;") < 0 {
        println("FAIL T2b use"); fails = fails + 1
    }

    // T3 — byte-stable: two emissions identical.
    total = total + 1
    let r3a = write_vhdl(d)
    let r3b = write_vhdl(d)
    if r3a.text != r3b.text {
        println("FAIL T3 byte_stable"); fails = fails + 1
    }

    // T4 — internal signal emitted as `signal <n> : std_logic;`.
    total = total + 1
    let mut m2 = rtlil_new_module("ii")
    m2 = rtlil_module_add_wire(m2, rtlil_wire("z", 1, 0, 0))
    let mut d2 = rtlil_new_design("test")
    d2 = rtlil_design_add(d2, m2)
    let r4 = write_vhdl(d2)
    if r4.text.find("signal z : std_logic;") < 0 {
        println("FAIL T4 internal_signal"); fails = fails + 1
    }

    // T5 — concurrent assign emitted with `<=`.
    total = total + 1
    let mut m3 = rtlil_new_module("c")
    m3 = rtlil_module_add_wire(m3, rtlil_wire("a", 1, 1, 1))
    m3 = rtlil_module_add_wire(m3, rtlil_wire("y", 1, 2, 2))
    m3 = rtlil_module_connect(m3, "y", "a")
    let mut d3 = rtlil_new_design("test")
    d3 = rtlil_design_add(d3, m3)
    let r5 = write_vhdl(d3)
    if r5.text.find("y <= a;") < 0 {
        println("FAIL T5 connect"); fails = fails + 1
    }

    // T6 — empty design still produces a header.
    total = total + 1
    let r6 = write_vhdl(rtlil_new_design("test"))
    if r6.bytes <= 0 {
        println("FAIL T6 empty_design"); fails = fails + 1
    }

    // T7 — multi-module preserved.
    total = total + 1
    let mut d4 = rtlil_new_design("test")
    d4 = rtlil_design_add(d4, rtlil_new_module("m_a"))
    d4 = rtlil_design_add(d4, rtlil_new_module("m_b"))
    let r7 = write_vhdl(d4)
    if r7.text.find("entity m_a is") < 0 {
        println("FAIL T7 multi_a"); fails = fails + 1
    }
    if r7.text.find("entity m_b is") < 0 {
        println("FAIL T7b multi_b"); fails = fails + 1
    }

    // T8 — multi-bit port emits std_logic_vector.
    total = total + 1
    let mut m5 = rtlil_new_module("v")
    m5 = rtlil_module_add_wire(m5, rtlil_wire("bus", 4, 1, 1))
    let mut d5 = rtlil_new_design("test")
    d5 = rtlil_design_add(d5, m5)
    let r8 = write_vhdl(d5)
    if r8.text.find("bus : in std_logic_vector(3 downto 0)") < 0 {
        println("FAIL T8 multibit"); fails = fails + 1
    }

    if fails > 0 {
        println("write_vhdl selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("write_vhdl selftest: " + str(total) + "/" + str(total) + " PASS")
}
