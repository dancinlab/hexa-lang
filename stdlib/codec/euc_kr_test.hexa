// HEXA Standard Library — codec/euc_kr self-test (@ci_gate).
// Golden vectors generated by CPython `euc-kr` codec (authoritative).
// @sentinel(__HEXA_CODEC_EUCKR__ <PASS|FAIL> N/N)

use "stdlib/codec/euc_kr"

let SENT_T = "__HEXA_CODEC_EUCKR__"

fn _hx2b(h: string) -> [int] {
    let hexc = "0123456789abcdef"
    let mut out: [int] = []
    let mut i = 0
    while i < h.len() {
        let hi = hexc.index_of(h.slice(i, i + 1))
        let lo = hexc.index_of(h.slice(i + 1, i + 2))
        out = out + [hi * 16 + lo]
        i = i + 2
    }
    return out
}

fn _eq(a: [int], b: [int]) -> int {
    if len(a) != len(b) { return 0 }
    let mut i = 0
    while i < len(a) { if (a[i] & 0xFF) != (b[i] & 0xFF) { return 0 }; i = i + 1 }
    return 1
}

fn main() {
    let chars = ["가","한","글","안","녕","하","세","요","방","각","훈","민","정","음","ㄱ","ㅎ","ㅏ","①","㈜","€","￦","？","Ａ","나","다","라","마","바","사","아","자","차","카","타","파","조","선","국"]
    let hexes = ["b0a1","c7d1","b1db","bec8","b3e7","c7cf","bcbc","bfe4","b9e6","b0a2","c8c6","b9ce","c1a4","c0bd","a4a1","a4be","a4bf","a8e7","a2df","a2e6","a3dc","a3bf","a3c1","b3aa","b4d9","b6f3","b8b6","b9d9","bbe7","bec6","c0da","c2f7","c4ab","c5b8","c6c4","c1b6","bcb1","b1b9"]

    let mut pass = 0
    let mut total = 0

    // round-trip each golden glyph (encode==bytes AND decode(bytes)==glyph)
    let mut i = 0
    while i < len(chars) {
        total = total + 1
        let exp = _hx2b(hexes[i])
        let enc = euc_kr_encode(chars[i])
        let dec = euc_kr_decode(exp)
        if _eq(enc, exp) == 1 && dec == chars[i] { pass = pass + 1 } else { eprintln("FAIL glyph " + chars[i] + " enc/dec") }
        i = i + 1
    }

    // ASCII passthrough
    total = total + 1
    if _eq(euc_kr_encode("AB9"), [65, 66, 57]) == 1 && euc_kr_decode([65, 66, 57]) == "AB9" { pass = pass + 1 } else { eprintln("FAIL ascii") }

    // mixed ASCII + Hangul round-trip
    total = total + 1
    let mx = "한A글"
    if euc_kr_decode(euc_kr_encode(mx)) == mx { pass = pass + 1 } else { eprintln("FAIL mixed roundtrip") }

    // unsupported syllable outside KS X 1001 (8-byte composition) -> [] (honest scope)
    total = total + 1
    if len(euc_kr_encode("힣")) == 0 { pass = pass + 1 } else { eprintln("FAIL unsupported should be []") }

    // malformed trailing lead byte -> ""
    total = total + 1
    if euc_kr_decode([0xc7]) == "" { pass = pass + 1 } else { eprintln("FAIL malformed") }

    let verdict = if pass == total { "PASS" } else { "FAIL" }
    println(SENT_T + " " + verdict + " " + str(pass) + "/" + str(total))
}
