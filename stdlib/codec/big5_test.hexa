// HEXA Standard Library — codec/big5 self-test (@ci_gate).
// Golden vectors generated by CPython `big5` codec (authoritative).
// @sentinel(__HEXA_CODEC_BIG5__ <PASS|FAIL> N/N)

use "stdlib/codec/big5"

let SENT_T = "__HEXA_CODEC_BIG5__"

fn _hx2b(h: string) -> [int] {
    let hexc = "0123456789abcdef"
    let mut out: [int] = []
    let mut i = 0
    while i < h.len() {
        let hi = hexc.index_of(h.slice(i, i + 1))
        let lo = hexc.index_of(h.slice(i + 1, i + 2))
        out = out + [hi * 16 + lo]
        i = i + 2
    }
    return out
}

fn _eq(a: [int], b: [int]) -> int {
    if len(a) != len(b) { return 0 }
    let mut i = 0
    while i < len(a) { if (a[i] & 0xFF) != (b[i] & 0xFF) { return 0 }; i = i + 1 }
    return 1
}

fn main() {
    let chars = ["繁","體","中","文","漢","字","你","好","國","語","台","灣","水","火","啊","Ａ","，","。","①","※","乙","¢","￣"]
    let hexes = ["c163","c5e9","a4a4","a4e5","ba7e","a672","a741","a66e","b0ea","bb79","a578","c657","a4f4","a4f5","b0da","a2cf","a141","a143","c7e9","a1b0","a441","a246","a1c3"]

    let mut pass = 0
    let mut total = 0

    let mut i = 0
    while i < len(chars) {
        total = total + 1
        let exp = _hx2b(hexes[i])
        let enc = big5_encode(chars[i])
        let dec = big5_decode(exp)
        if _eq(enc, exp) == 1 && dec == chars[i] { pass = pass + 1 } else { eprintln("FAIL glyph " + chars[i]) }
        i = i + 1
    }

    // ASCII passthrough
    total = total + 1
    if _eq(big5_encode("AB9"), [65, 66, 57]) == 1 && big5_decode([65, 66, 57]) == "AB9" { pass = pass + 1 } else { eprintln("FAIL ascii") }

    // mixed ASCII + traditional Chinese round-trip
    total = total + 1
    let mx = "繁A體"
    if big5_decode(big5_encode(mx)) == mx { pass = pass + 1 } else { eprintln("FAIL mixed") }

    // codepoint outside Big5 (astral emoji) -> []
    total = total + 1
    if len(big5_encode("🦀")) == 0 { pass = pass + 1 } else { eprintln("FAIL astral should be []") }

    // malformed trailing lead byte -> ""
    total = total + 1
    if big5_decode([0xa4]) == "" { pass = pass + 1 } else { eprintln("FAIL malformed") }

    let verdict = if pass == total { "PASS" } else { "FAIL" }
    println(SENT_T + " " + verdict + " " + str(pass) + "/" + str(total))
}
