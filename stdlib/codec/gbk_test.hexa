// HEXA Standard Library — codec/gbk self-test (@ci_gate).
// Golden vectors generated by CPython `gbk` codec (authoritative).
// @sentinel(__HEXA_CODEC_GBK__ <PASS|FAIL> N/N)

use "stdlib/codec/gbk"

let SENT_T = "__HEXA_CODEC_GBK__"

fn _hx2b(h: string) -> [int] {
    let hexc = "0123456789abcdef"
    let mut out: [int] = []
    let mut i = 0
    while i < h.len() {
        let hi = hexc.index_of(h.slice(i, i + 1))
        let lo = hexc.index_of(h.slice(i + 1, i + 2))
        out = out + [hi * 16 + lo]
        i = i + 2
    }
    return out
}

fn _eq(a: [int], b: [int]) -> int {
    if len(a) != len(b) { return 0 }
    let mut i = 0
    while i < len(a) { if (a[i] & 0xFF) != (b[i] & 0xFF) { return 0 }; i = i + 1 }
    return 1
}

fn main() {
    let chars = ["中","文","简","体","汉","字","你","好","国","语","北","京","水","火","龥","啊","〇","Ａ","，","。","￥","①","¤"]
    let hexes = ["d6d0","cec4","bcf2","cce5","baba","d7d6","c4e3","bac3","b9fa","d3ef","b1b1","bea9","cbae","bbf0","fd9b","b0a1","a996","a3c1","a3ac","a1a3","a3a4","a2d9","a1e8"]

    let mut pass = 0
    let mut total = 0

    let mut i = 0
    while i < len(chars) {
        total = total + 1
        let exp = _hx2b(hexes[i])
        let enc = gbk_encode(chars[i])
        let dec = gbk_decode(exp)
        if _eq(enc, exp) == 1 && dec == chars[i] { pass = pass + 1 } else { eprintln("FAIL glyph " + chars[i]) }
        i = i + 1
    }

    // ASCII passthrough
    total = total + 1
    if _eq(gbk_encode("AB9"), [65, 66, 57]) == 1 && gbk_decode([65, 66, 57]) == "AB9" { pass = pass + 1 } else { eprintln("FAIL ascii") }

    // mixed ASCII + Chinese round-trip
    total = total + 1
    let mx = "中A文"
    if gbk_decode(gbk_encode(mx)) == mx { pass = pass + 1 } else { eprintln("FAIL mixed") }

    // codepoint outside GBK (astral emoji) -> []
    total = total + 1
    if len(gbk_encode("🦀")) == 0 { pass = pass + 1 } else { eprintln("FAIL astral should be []") }

    // malformed trailing lead byte -> ""
    total = total + 1
    if gbk_decode([0xd6]) == "" { pass = pass + 1 } else { eprintln("FAIL malformed") }

    let verdict = if pass == total { "PASS" } else { "FAIL" }
    println(SENT_T + " " + verdict + " " + str(pass) + "/" + str(total))
}
