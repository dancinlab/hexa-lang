// HEXA Standard Library ‚Äî codec
//
// @version 0.1.0
// @capabilities [pure]
//
// Bytes ‚Üî string codec primitives. Pure hexa (no libc) ‚Äî closes
// RUNTIME.md Phase 2 stdlib primitive {UTF-8, hex, base64} trio.
//
// Modules:
//   base64 ‚Äî RFC 4648 base64 encode/decode
//   hex    ‚Äî base16 (hex) encode/decode (lowercase + uppercase)
//   utf8   ‚Äî UTF-8 validation, codepoint iteration, codepoint‚Üîbytes
//   euc_kr ‚Äî EUC-KR / KS X 1001 (Korean) byte‚Üîstring, 2-byte set
//   cp949  ‚Äî CP949 / UHC (Korean) byte‚Üîstring, full 11172 Hangul
//   shift_jis ‚Äî Shift-JIS (Japanese) byte‚Üîstring, 2-byte + 1-byte katakana
//   gbk    ‚Äî GBK / GB2312 superset (Chinese simplified) byte‚Üîstring, 2-byte
//   big5   ‚Äî Big5 (Chinese traditional) byte‚Üîstring, 2-byte
//   unicode_normalize ‚Äî UAX #15 NFC/NFD/NFKC/NFKD normalization

use "stdlib/codec/base64"
use "stdlib/codec/hex"
use "stdlib/codec/utf8"
use "stdlib/codec/euc_kr"
use "stdlib/codec/cp949"
use "stdlib/codec/shift_jis"
use "stdlib/codec/gbk"
use "stdlib/codec/big5"
use "stdlib/codec/unicode_normalize"
