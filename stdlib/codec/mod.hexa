// HEXA Standard Library — codec
//
// @version 0.1.0
// @capabilities [pure]
//
// Bytes ↔ string codec primitives. Pure hexa (no libc) — closes
// RUNTIME.md Phase 2 stdlib primitive {UTF-8, hex, base64} trio.
//
// Modules:
//   base64 — RFC 4648 base64 encode/decode
//   hex    — base16 (hex) encode/decode (lowercase + uppercase)
//   utf8   — UTF-8 validation, codepoint iteration, codepoint↔bytes
//   euc_kr — EUC-KR / KS X 1001 (Korean) byte↔string, 2-byte set

use "stdlib/codec/base64"
use "stdlib/codec/hex"
use "stdlib/codec/utf8"
use "stdlib/codec/euc_kr"
