// HEXA Standard Library — codec/euc_kr (EUC-KR / KS X 1001)
//
// @version 0.1.0
// @capabilities [pure]
//
// EUC-KR (KS X 1001) byte<->string codec. ASCII (<0x80) is single-byte
// passthrough; the 8226 two-byte KS X 1001 glyphs come from the
// CPython-`euc-kr`-generated table (euc_kr_table.gen.hexa).
//
// Self-contained UTF-8 (string<->codepoint) is inlined here rather than
// importing stdlib/codec/utf8 — utf8_from_codepoints transitively references
// bytes_to_str (defined in stdlib/ckpt/format) without importing it, which
// only resolves in a full-stdlib build, not a standalone codec build.
//
// SCOPE (honest, d6): only the two-byte KS X 1001 set is supported. Hangul
// syllables OUTSIDE the 2350 precomposed set (which CPython encodes via the
// 8-byte 0xA4 Hangul-fill composition) are NOT representable here ->
// euc_kr_encode returns [] for any such input.

use "stdlib/codec/euc_kr_table.gen"

fn _ek_hv(c: int) -> int {
    if c >= 48 && c <= 57 { return c - 48 }      // '0'-'9'
    if c >= 97 && c <= 102 { return c - 87 }     // 'a'-'f'
    return 0
}

// Build the encode map (codepoint -> packed 2 bytes) fresh from the blob.
// NOTE(perf): rebuilt per call — module-level mutable maps do not persist
// across function boundaries in this build; a cached singleton is a follow-up.
fn _ek_build_enc() -> map {
    let mut m: map = {}
    let n = EUCKR_BLOB.len()
    let mut i = 0
    while i + 8 <= n {
        let cp = _ek_hv(EUCKR_BLOB.byte_at(i)) * 4096
            + _ek_hv(EUCKR_BLOB.byte_at(i + 1)) * 256
            + _ek_hv(EUCKR_BLOB.byte_at(i + 2)) * 16
            + _ek_hv(EUCKR_BLOB.byte_at(i + 3))
        let b0 = _ek_hv(EUCKR_BLOB.byte_at(i + 4)) * 16 + _ek_hv(EUCKR_BLOB.byte_at(i + 5))
        let b1 = _ek_hv(EUCKR_BLOB.byte_at(i + 6)) * 16 + _ek_hv(EUCKR_BLOB.byte_at(i + 7))
        m[str(cp)] = b0 * 256 + b1
        i = i + 8
    }
    return m
}

// Build the decode map (packed 2 bytes -> codepoint) fresh from the blob.
fn _ek_build_dec() -> map {
    let mut m: map = {}
    let n = EUCKR_BLOB.len()
    let mut i = 0
    while i + 8 <= n {
        let cp = _ek_hv(EUCKR_BLOB.byte_at(i)) * 4096
            + _ek_hv(EUCKR_BLOB.byte_at(i + 1)) * 256
            + _ek_hv(EUCKR_BLOB.byte_at(i + 2)) * 16
            + _ek_hv(EUCKR_BLOB.byte_at(i + 3))
        let b0 = _ek_hv(EUCKR_BLOB.byte_at(i + 4)) * 16 + _ek_hv(EUCKR_BLOB.byte_at(i + 5))
        let b1 = _ek_hv(EUCKR_BLOB.byte_at(i + 6)) * 16 + _ek_hv(EUCKR_BLOB.byte_at(i + 7))
        m[str(b0 * 256 + b1)] = cp
        i = i + 8
    }
    return m
}

// --- inlined UTF-8 (self-contained, no stdlib/codec/utf8 dependency) ---

// string -> codepoints (decode the input's UTF-8 bytes).
fn _ek_str_cps(s: string) -> [int] {
    let n = s.len()
    let mut cps: [int] = []
    let mut i = 0
    while i < n {
        let b0 = s.byte_at(i) & 0xFF
        if b0 < 0x80 {
            cps = cps + [b0]; i = i + 1
        } else if b0 < 0xE0 {
            cps = cps + [((b0 & 0x1F) * 64) + (s.byte_at(i + 1) & 0x3F)]; i = i + 2
        } else if b0 < 0xF0 {
            cps = cps + [((b0 & 0x0F) * 4096) + ((s.byte_at(i + 1) & 0x3F) * 64) + (s.byte_at(i + 2) & 0x3F)]; i = i + 3
        } else {
            cps = cps + [((b0 & 0x07) * 262144) + ((s.byte_at(i + 1) & 0x3F) * 4096) + ((s.byte_at(i + 2) & 0x3F) * 64) + (s.byte_at(i + 3) & 0x3F)]; i = i + 4
        }
    }
    return cps
}

// codepoints -> UTF-8 bytes -> string (local bytes_to_str via from_char_code).
fn _ek_cps_str(cps: [int]) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(cps) {
        let cp = cps[i]
        i = i + 1
        if cp < 0x80 {
            out = out + to_string(from_char_code(cp & 0xFF))
        } else if cp < 0x800 {
            out = out + to_string(from_char_code((0xC0 + (cp / 64)) & 0xFF))
            out = out + to_string(from_char_code((0x80 + (cp % 64)) & 0xFF))
        } else {
            out = out + to_string(from_char_code((0xE0 + (cp / 4096)) & 0xFF))
            out = out + to_string(from_char_code((0x80 + ((cp / 64) % 64)) & 0xFF))
            out = out + to_string(from_char_code((0x80 + (cp % 64)) & 0xFF))
        }
    }
    return out
}

// --- public codec ---

// Encode a string to EUC-KR bytes. Returns [] if any char is not in the
// two-byte KS X 1001 set (and not ASCII).
pub fn euc_kr_encode(s: string) -> [int] {
    let enc = _ek_build_enc()
    let cps = _ek_str_cps(s)
    let mut out: [int] = []
    let mut i = 0
    while i < len(cps) {
        let cp = cps[i]
        i = i + 1
        if cp < 0x80 {
            out = out + [cp]
        } else {
            let k = str(cp)
            if !enc.has(k) { return [] }
            let packed = enc[k]
            out = out + [(packed / 256) & 0xFF, packed & 0xFF]
        }
    }
    return out
}

// Decode EUC-KR bytes to a string. Returns "" on a malformed lead/trail pair.
pub fn euc_kr_decode(b: [int]) -> string {
    let dec = _ek_build_dec()
    let mut cps: [int] = []
    let mut i = 0
    let n = len(b)
    while i < n {
        let lead = b[i] & 0xFF
        if lead < 0x80 {
            cps = cps + [lead]
            i = i + 1
        } else {
            if i + 1 >= n { return "" }
            let trail = b[i + 1] & 0xFF
            let k = str(lead * 256 + trail)
            if !dec.has(k) { return "" }
            cps = cps + [dec[k]]
            i = i + 2
        }
    }
    return _ek_cps_str(cps)
}
