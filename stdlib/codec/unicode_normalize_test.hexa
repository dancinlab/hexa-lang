// HEXA Standard Library — codec/unicode_normalize self-test (@ci_gate).
// Golden vectors generated by CPython `unicodedata.normalize` (authoritative).
// @sentinel(__HEXA_UNICODE_NORM__ <PASS|FAIL> N/N)

use "stdlib/codec/unicode_normalize"

let SENT_T = "__HEXA_UNICODE_NORM__"

fn _cs(cps: [int]) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(cps) { out = out + to_string(from_char_code(cps[i])); i = i + 1 }
    return out
}

fn main() {
    let ins = [[54620], [44033], [4370, 4449, 4523], [233], [101, 769], [197], [65, 778], [65313], [9312], [12828], [65398], [65418], [113, 775, 803], [97, 98, 99], [54620, 44544], [64257], [65298]]
    let g_nfc = [[54620], [44033], [54620], [233], [233], [197], [197], [65313], [9312], [12828], [65398], [65418], [113, 803, 775], [97, 98, 99], [54620, 44544], [64257], [65298]]
    let g_nfd = [[4370, 4449, 4523], [4352, 4449, 4520], [4370, 4449, 4523], [101, 769], [101, 769], [65, 778], [65, 778], [65313], [9312], [12828], [65398], [65418], [113, 803, 775], [97, 98, 99], [4370, 4449, 4523, 4352, 4467, 4527], [64257], [65298]]
    let g_nfkc = [[54620], [44033], [54620], [233], [233], [197], [197], [65], [49], [40, 51452, 41], [12459], [12495], [113, 803, 775], [97, 98, 99], [54620, 44544], [102, 105], [50]]
    let g_nfkd = [[4370, 4449, 4523], [4352, 4449, 4520], [4370, 4449, 4523], [101, 769], [101, 769], [65, 778], [65, 778], [65], [49], [40, 4364, 4462, 41], [12459], [12495], [113, 803, 775], [97, 98, 99], [4370, 4449, 4523, 4352, 4467, 4527], [102, 105], [50]]

    let mut pass = 0
    let mut total = 0
    let mut i = 0
    while i < len(ins) {
        let s = _cs(ins[i])
        total = total + 4
        if nfc(s) == _cs(g_nfc[i]) { pass = pass + 1 } else { eprintln("FAIL nfc idx " + str(i)) }
        if nfd(s) == _cs(g_nfd[i]) { pass = pass + 1 } else { eprintln("FAIL nfd idx " + str(i)) }
        if nfkc(s) == _cs(g_nfkc[i]) { pass = pass + 1 } else { eprintln("FAIL nfkc idx " + str(i)) }
        if nfkd(s) == _cs(g_nfkd[i]) { pass = pass + 1 } else { eprintln("FAIL nfkd idx " + str(i)) }
        i = i + 1
    }

    let verdict = if pass == total { "PASS" } else { "FAIL" }
    println(SENT_T + " " + verdict + " " + str(pass) + "/" + str(total))
}
