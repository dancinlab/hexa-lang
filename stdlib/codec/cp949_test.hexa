// HEXA Standard Library — codec/cp949 self-test (@ci_gate).
// Golden vectors generated by CPython `cp949` codec (authoritative).
// @sentinel(__HEXA_CODEC_CP949__ <PASS|FAIL> N/N)

use "stdlib/codec/cp949"

let SENT_T = "__HEXA_CODEC_CP949__"

fn _hx2b(h: string) -> [int] {
    let hexc = "0123456789abcdef"
    let mut out: [int] = []
    let mut i = 0
    while i < h.len() {
        let hi = hexc.index_of(h.slice(i, i + 1))
        let lo = hexc.index_of(h.slice(i + 1, i + 2))
        out = out + [hi * 16 + lo]
        i = i + 2
    }
    return out
}

fn _eq(a: [int], b: [int]) -> int {
    if len(a) != len(b) { return 0 }
    let mut i = 0
    while i < len(a) { if (a[i] & 0xFF) != (b[i] & 0xFF) { return 0 }; i = i + 1 }
    return 1
}

fn main() {
    // includes 힣/똠/뷁/곫 — modern Hangul OUTSIDE KS X 1001 that CP949 (UHC) covers.
    let chars = ["가","힣","똠","왕","뷁","곫","한","글","훈","민","정","음","ㄱ","①","￦","？","Ａ","조","선","국","뀀","꽝","뗌","렐","쇽","¡"]
    let hexes = ["b0a1","c652","8c63","bfd5","94ee","81e6","c7d1","b1db","c8c6","b9ce","c1a4","c0bd","a4a1","a8e7","a3dc","a3bf","a3c1","c1b6","bcb1","b1b9","b2eb","b2ce","b6c0","b7bc","bcef","a2ae"]

    let mut pass = 0
    let mut total = 0

    let mut i = 0
    while i < len(chars) {
        total = total + 1
        let exp = _hx2b(hexes[i])
        let enc = cp949_encode(chars[i])
        let dec = cp949_decode(exp)
        if _eq(enc, exp) == 1 && dec == chars[i] { pass = pass + 1 } else { eprintln("FAIL glyph " + chars[i]) }
        i = i + 1
    }

    // ASCII passthrough
    total = total + 1
    if _eq(cp949_encode("AB9"), [65, 66, 57]) == 1 && cp949_decode([65, 66, 57]) == "AB9" { pass = pass + 1 } else { eprintln("FAIL ascii") }

    // mixed ASCII + Hangul round-trip (incl. UHC-only syllable 똠)
    total = total + 1
    let mx = "똠A왕"
    if cp949_decode(cp949_encode(mx)) == mx { pass = pass + 1 } else { eprintln("FAIL mixed") }

    // codepoint outside CP949 (astral emoji) -> []
    total = total + 1
    if len(cp949_encode("🦀")) == 0 { pass = pass + 1 } else { eprintln("FAIL astral should be []") }

    // malformed trailing lead byte -> ""
    total = total + 1
    if cp949_decode([0xc7]) == "" { pass = pass + 1 } else { eprintln("FAIL malformed") }

    let verdict = if pass == total { "PASS" } else { "FAIL" }
    println(SENT_T + " " + verdict + " " + str(pass) + "/" + str(total))
}
