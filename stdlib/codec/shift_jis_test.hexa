// HEXA Standard Library — codec/shift_jis self-test (@ci_gate).
// Golden vectors generated by CPython `shift_jis` codec (authoritative).
// @sentinel(__HEXA_CODEC_SJIS__ <PASS|FAIL> N/N)

use "stdlib/codec/shift_jis"

let SENT_T = "__HEXA_CODEC_SJIS__"

fn _hx2b(h: string) -> [int] {
    let hexc = "0123456789abcdef"
    let mut out: [int] = []
    let mut i = 0
    while i < h.len() {
        let hi = hexc.index_of(h.slice(i, i + 1))
        let lo = hexc.index_of(h.slice(i + 1, i + 2))
        out = out + [hi * 16 + lo]
        i = i + 2
    }
    return out
}

fn _eq(a: [int], b: [int]) -> int {
    if len(a) != len(b) { return 0 }
    let mut i = 0
    while i < len(a) { if (a[i] & 0xFF) != (b[i] & 0xFF) { return 0 }; i = i + 1 }
    return 1
}

fn main() {
    // mix of 2-byte (kanji/kana/symbols) and 1-byte half-width katakana (ﾊ ﾝ ｶ ｷ).
    let chars = ["日","本","語","あ","ア","漢","字","東","京","水","火","ヲ","ァ","ン","ﾊ","ﾝ","ｶ","ｷ","０","Ａ","、","。","¢","￥"]
    let hexes = ["93fa","967b","8cea","82a0","8341","8abf","8e9a","938c","8b9e","9085","89ce","8392","8340","8393","ca","dd","b6","b7","824f","8260","8141","8142","8191","818f"]

    let mut pass = 0
    let mut total = 0

    let mut i = 0
    while i < len(chars) {
        total = total + 1
        let exp = _hx2b(hexes[i])
        let enc = shift_jis_encode(chars[i])
        let dec = shift_jis_decode(exp)
        if _eq(enc, exp) == 1 && dec == chars[i] { pass = pass + 1 } else { eprintln("FAIL glyph " + chars[i]) }
        i = i + 1
    }

    // ASCII passthrough
    total = total + 1
    if _eq(shift_jis_encode("AB9"), [65, 66, 57]) == 1 && shift_jis_decode([65, 66, 57]) == "AB9" { pass = pass + 1 } else { eprintln("FAIL ascii") }

    // mixed ASCII + 2-byte kanji + 1-byte katakana round-trip
    total = total + 1
    let mx = "日Aﾊン"
    if shift_jis_decode(shift_jis_encode(mx)) == mx { pass = pass + 1 } else { eprintln("FAIL mixed") }

    // codepoint outside Shift-JIS (astral emoji) -> []
    total = total + 1
    if len(shift_jis_encode("🦀")) == 0 { pass = pass + 1 } else { eprintln("FAIL astral should be []") }

    // malformed trailing 2-byte lead -> ""
    total = total + 1
    if shift_jis_decode([0x93]) == "" { pass = pass + 1 } else { eprintln("FAIL malformed") }

    let verdict = if pass == total { "PASS" } else { "FAIL" }
    println(SENT_T + " " + verdict + " " + str(pass) + "/" + str(total))
}
