// HEXA Standard Library — codec/shift_jis (Shift-JIS)
//
// @version 0.1.0
// @capabilities [pure]
//
// Shift-JIS byte<->string codec. ASCII (<0x80) is single-byte passthrough;
// half-width katakana (U+FF61..FF9F) are SINGLE bytes 0xA1-0xDF; the kanji /
// kana / symbol set are two bytes. All from the CPython-`shift_jis`-generated
// table (shift_jis_table.gen.hexa).
//
// Self-contained UTF-8 is inlined (no stdlib/codec/utf8 import — utf8 references
// bytes_to_str without importing it, which only resolves in a full-stdlib build).
//
// SCOPE (honest, d6): the Shift-JIS set CPython encodes. Codepoints outside it
// are not representable -> shift_jis_encode returns [] for any such input.

use "stdlib/codec/shift_jis_table.gen"

fn _sj_hv(c: int) -> int {
    if c >= 48 && c <= 57 { return c - 48 }
    if c >= 97 && c <= 102 { return c - 87 }
    return 0
}

fn _sj_rec(i: int) -> [int] {
    let cp = _sj_hv(SJIS_BLOB.byte_at(i)) * 4096
        + _sj_hv(SJIS_BLOB.byte_at(i + 1)) * 256
        + _sj_hv(SJIS_BLOB.byte_at(i + 2)) * 16
        + _sj_hv(SJIS_BLOB.byte_at(i + 3))
    let n = _sj_hv(SJIS_BLOB.byte_at(i + 4)) * 16 + _sj_hv(SJIS_BLOB.byte_at(i + 5))
    let b0 = _sj_hv(SJIS_BLOB.byte_at(i + 6)) * 16 + _sj_hv(SJIS_BLOB.byte_at(i + 7))
    let b1 = _sj_hv(SJIS_BLOB.byte_at(i + 8)) * 16 + _sj_hv(SJIS_BLOB.byte_at(i + 9))
    return [cp, n, b0, b1]
}

// encode map: codepoint -> n*65536 + b0*256 + b1.
fn _sj_build_enc() -> map {
    let mut m: map = {}
    let len_blob = SJIS_BLOB.len()
    let mut i = 0
    while i + 10 <= len_blob {
        let r = _sj_rec(i)
        m[str(r[0])] = r[1] * 65536 + r[2] * 256 + r[3]
        i = i + 10
    }
    return m
}

// decode map: "1_<b0>" or "2_<b0*256+b1>" -> codepoint.
fn _sj_build_dec() -> map {
    let mut m: map = {}
    let len_blob = SJIS_BLOB.len()
    let mut i = 0
    while i + 10 <= len_blob {
        let r = _sj_rec(i)
        if r[1] == 1 {
            m["1_" + str(r[2])] = r[0]
        } else {
            m["2_" + str(r[2] * 256 + r[3])] = r[0]
        }
        i = i + 10
    }
    return m
}

// string -> codepoints (decode input UTF-8 bytes).
fn _sj_str_cps(s: string) -> [int] {
    let n = s.len()
    let mut cps: [int] = []
    let mut i = 0
    while i < n {
        let b0 = s.byte_at(i) & 0xFF
        if b0 < 0x80 {
            cps = cps + [b0]; i = i + 1
        } else if b0 < 0xE0 {
            cps = cps + [((b0 & 0x1F) * 64) + (s.byte_at(i + 1) & 0x3F)]; i = i + 2
        } else if b0 < 0xF0 {
            cps = cps + [((b0 & 0x0F) * 4096) + ((s.byte_at(i + 1) & 0x3F) * 64) + (s.byte_at(i + 2) & 0x3F)]; i = i + 3
        } else {
            cps = cps + [((b0 & 0x07) * 262144) + ((s.byte_at(i + 1) & 0x3F) * 4096) + ((s.byte_at(i + 2) & 0x3F) * 64) + (s.byte_at(i + 3) & 0x3F)]; i = i + 4
        }
    }
    return cps
}

fn _sj_cps_str(cps: [int]) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(cps) {
        out = out + to_string(from_char_code(cps[i]))
        i = i + 1
    }
    return out
}

// Encode a string to Shift-JIS bytes. Returns [] for any char outside Shift-JIS.
pub fn shift_jis_encode(s: string) -> [int] {
    let enc = _sj_build_enc()
    let cps = _sj_str_cps(s)
    let mut out: [int] = []
    let mut i = 0
    while i < len(cps) {
        let cp = cps[i]
        i = i + 1
        if cp < 0x80 {
            out = out + [cp]
        } else {
            let k = str(cp)
            if !enc.has(k) { return [] }
            let packed = enc[k]
            let n = packed / 65536
            let b0 = (packed / 256) & 0xFF
            let b1 = packed & 0xFF
            if n == 1 { out = out + [b0] } else { out = out + [b0, b1] }
        }
    }
    return out
}

// Decode Shift-JIS bytes to a string. Returns "" on a malformed sequence.
pub fn shift_jis_decode(b: [int]) -> string {
    let dec = _sj_build_dec()
    let mut cps: [int] = []
    let mut i = 0
    let n = len(b)
    while i < n {
        let lead = b[i] & 0xFF
        if lead < 0x80 {
            cps = cps + [lead]
            i = i + 1
        } else if dec.has("1_" + str(lead)) {
            cps = cps + [dec["1_" + str(lead)]]
            i = i + 1
        } else {
            if i + 1 >= n { return "" }
            let trail = b[i + 1] & 0xFF
            let k = "2_" + str(lead * 256 + trail)
            if !dec.has(k) { return "" }
            cps = cps + [dec[k]]
            i = i + 2
        }
    }
    return _sj_cps_str(cps)
}
