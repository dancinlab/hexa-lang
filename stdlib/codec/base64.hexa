// HEXA Standard Library — codec/base64
//
// @version 0.1.0
// @capabilities [pure]
//
// RFC 4648 base64 encode/decode — pure hexa, no libc dependency.
// Closes RUNTIME.md Phase 2 stdlib primitive (Bytes ↔ string codec
// subset: base64 of the {UTF-8, hex, base64} trio).
//
// Surface:
//   pub fn base64_encode(bytes: [int]) -> string
//   pub fn base64_decode(s: string) -> [int]
//   pub fn base64_encode_str(s: string) -> string   (convenience: utf-8 bytes → b64)
//   pub fn base64_decode_str(s: string) -> string   (convenience: b64 → bytes-as-string)
//
// Invariants:
//   • Encoder produces canonical RFC 4648 alphabet (A-Z, a-z, 0-9, +, /, =).
//   • Decoder ignores whitespace (\t, \n, \r, ' ') for line-folded inputs.
//   • Invalid byte (non-alphabet, non-whitespace) → returns [] (empty).
//   • Padding ='s are tolerated and required for canonical roundtrip.

let _B64_ALPHA: string = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

// Index of base64 char in alphabet (0-63), or -1 if not in alphabet.
@pure
fn _b64_idx(c: int) -> int {
    if c >= 65 && c <= 90  { return c - 65 }       // A-Z → 0-25
    if c >= 97 && c <= 122 { return c - 97 + 26 }  // a-z → 26-51
    if c >= 48 && c <= 57  { return c - 48 + 52 }  // 0-9 → 52-61
    if c == 43 { return 62 }                       // '+'
    if c == 47 { return 63 }                       // '/'
    return -1
}

@pure
pub fn base64_encode(bytes: [int]) -> string {
    let n = len(bytes)
    if n == 0 { return "" }
    let mut out: [int] = []
    let mut i = 0
    while i + 2 < n {
        let b0 = bytes[i] & 0xFF
        let b1 = bytes[i+1] & 0xFF
        let b2 = bytes[i+2] & 0xFF
        let i0 = b0 / 4
        let i1 = ((b0 % 4) * 16) + (b1 / 16)
        let i2 = ((b1 % 16) * 4) + (b2 / 64)
        let i3 = b2 % 64
        out.push(_B64_ALPHA.byte_at(i0))
        out.push(_B64_ALPHA.byte_at(i1))
        out.push(_B64_ALPHA.byte_at(i2))
        out.push(_B64_ALPHA.byte_at(i3))
        i = i + 3
    }
    let rem = n - i
    if rem == 1 {
        let b0 = bytes[i] & 0xFF
        let i0 = b0 / 4
        let i1 = (b0 % 4) * 16
        out.push(_B64_ALPHA.byte_at(i0))
        out.push(_B64_ALPHA.byte_at(i1))
        out.push(61)   // '='
        out.push(61)
    } else if rem == 2 {
        let b0 = bytes[i] & 0xFF
        let b1 = bytes[i+1] & 0xFF
        let i0 = b0 / 4
        let i1 = ((b0 % 4) * 16) + (b1 / 16)
        let i2 = (b1 % 16) * 4
        out.push(_B64_ALPHA.byte_at(i0))
        out.push(_B64_ALPHA.byte_at(i1))
        out.push(_B64_ALPHA.byte_at(i2))
        out.push(61)
    }
    return bytes_to_str(out)
}

@pure
pub fn base64_decode(s: string) -> [int] {
    let n = byte_len(s)
    if n == 0 { return [] }
    // Filtered input: skip whitespace.
    let mut idxs: [int] = []
    let mut pad = 0
    let mut i = 0
    while i < n {
        let c = s.byte_at(i)
        if c == 9 || c == 10 || c == 13 || c == 32 {
            // whitespace — skip
        } else if c == 61 {
            pad = pad + 1
        } else {
            let v = _b64_idx(c)
            if v < 0 { return [] }
            idxs.push(v)
        }
        i = i + 1
    }
    let m = len(idxs)
    if m % 4 != 0 && (m + pad) % 4 != 0 {
        // Not a canonical 4-multiple input (with padding considered).
        // Soft tolerance: continue, last short group decoded partially.
    }
    let mut out: [int] = []
    let mut j = 0
    while j + 3 < m {
        let v0 = idxs[j]
        let v1 = idxs[j+1]
        let v2 = idxs[j+2]
        let v3 = idxs[j+3]
        let b0 = (v0 * 4) + (v1 / 16)
        let b1 = ((v1 % 16) * 16) + (v2 / 4)
        let b2 = ((v2 % 4) * 64) + v3
        out.push(b0 & 0xFF)
        out.push(b1 & 0xFF)
        out.push(b2 & 0xFF)
        j = j + 4
    }
    // Trim padded bytes.
    let trim = if pad > 2 { 2 } else { pad }
    let final_len = len(out) - trim
    if final_len <= 0 { return [] }
    return out.slice(0, final_len)
}

@pure
pub fn base64_encode_str(s: string) -> string {
    let n = byte_len(s)
    let mut bytes: [int] = []
    let mut i = 0
    while i < n {
        bytes.push(s.byte_at(i))
        i = i + 1
    }
    return base64_encode(bytes)
}

@pure
pub fn base64_decode_str(s: string) -> string {
    return bytes_to_str(base64_decode(s))
}
