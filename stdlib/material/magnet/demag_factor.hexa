#!hexa strict
// ============================================================================
// stdlib/material/magnet/demag_factor.hexa — ellipsoid demagnetizing factors
//
// General-purpose Osborn (1945) demagnetizing-factor primitive. Pure geometry —
// no domain (HTS / RTSC / permanent-magnet design / etc.) baked in. Topical /
// domain-specific verifiers should `use` this module and supply their own
// reference aspect ratios; this file is the SSOT primitive.
//
// A uniformly-magnetized ellipsoid is the unique finite body whose internal
// field is uniform; the demagnetizing field is H_d = −N·M with three principal
// factors N_a, N_b, N_c (along semi-axes a ≥ b ≥ c). Osborn's golden identity
// (the atlas sum-rule):
//
//     N_a + N_b + N_c = 1            (SI convention, exact, every aspect ratio)
//
// Closed forms (semi-axis a = polar/symmetry axis):
//
//   sphere  (a = b = c):     N_a = N_b = N_c = 1/3
//
//   prolate (a > b = c, elongated spheroid), e² = 1 − (c/a)²:
//     N_a = ((1 − e²)/e²) · [ (1/(2e))·ln((1+e)/(1−e)) − 1 ]
//     N_b = N_c = (1 − N_a)/2
//   limit a ≫ c (infinite cylinder):  N_a → 0,  N_b = N_c → 1/2
//
//   oblate  (a = b > c, flattened spheroid), e² = 1 − (c/a)²:
//     N_c = (1/e²) · [ 1 − (√(1−e²)/e)·arcsin(e) ]
//     N_a = N_b = (1 − N_c)/2
//   limit a ≫ c (infinite thin disk):  N_c → 1,  N_a = N_b → 0
//
// Convention note: in BOTH spheroid cases below the FIRST argument `a` is the
// distinguished axis (prolate: long axis; oblate: the two equal long axes) and
// `c` is the short axis, so the caller always passes (semi-major, semi-minor).
// For the prolate the returned N_a is the easy (low-demag) axis; for the oblate
// the returned N_c is the hard (high-demag) polar axis.
//
// Honest scope (commons g3):
//   · Uniform magnetization, linear, isotropic susceptibility implied.
//   · General (three-unequal-axis) ellipsoid needs incomplete elliptic
//     integrals (R_D); this primitive covers the two spheroid families plus
//     the sphere — the cases reachable with libm (ln · arcsin) alone.
//   · NOT a micromagnetic model (no exchange, no domain walls, no Stoner-
//     Wohlfarth switching). Pure magnetostatic shape factor only.
//
// Surface (pure functions):
//   fn demag_sphere()             → 0.3333…           (single isotropic factor)
//   fn demag_prolate(a, c)        → [N_a, N_b, N_c]   (a = long axis ≥ c)
//   fn demag_oblate(a, c)         → [N_a, N_b, N_c]   (a = equatorial ≥ c polar)
//
// Self-test (this file):
//   · sphere               N_a = N_b = N_c = 1/3
//   · sum-rule (GOLDEN)    N_a + N_b + N_c = 1   across many aspect ratios
//   · prolate ∞-cylinder   a/c = 10000  →  N_a → 0, N_b = N_c → 1/2
//   · oblate ∞-thin-disk   a/c = 10000  →  N_c → 1, N_a = N_b → 0
//   · literature 2:1 prolate  N_a ≈ 0.17356  (Osborn 1945 table)
//
// Run:
//     hexa run stdlib/material/magnet/demag_factor.hexa
//
// @no-lock-needed

use "self/runtime/math_pure"

let VERSION = "1.0.0"

// ─── check harness ──────────────────────────────────────────────────────

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

fn abs_f(x: float) -> float { if x < 0.0 { return -x } return x }

fn rel_err(a: float, b: float) -> float {
    let d = abs_f(a - b)
    let abs_b = abs_f(b)
    if abs_b < 1.0e-30 { return d }
    return d / abs_b
}

// ─── ellipsoid demagnetizing factors (Osborn 1945) ───────────────────────

// Sphere: isotropic, single factor on every axis.
fn demag_sphere() -> float {
    return 1.0 / 3.0
}

// Prolate spheroid (a > b = c, elongated), a = long (symmetry) axis, c = short.
// e² = 1 − (c/a)²;  N_a = easy axis (low demag),  N_b = N_c = (1 − N_a)/2.
fn demag_prolate(a: float, c: float) -> [float] {
    // Degenerate / near-sphere guard: a ≤ c collapses to the sphere value.
    if a <= c {
        let t = 1.0 / 3.0
        return [t, t, t]
    }
    let ratio = c / a
    let e2 = 1.0 - ratio * ratio
    let e = sqrt_pure(e2)
    // (1/(2e))·ln((1+e)/(1−e)) − 1   ;  ln term = 2·artanh(e)
    let lnterm = log_pure((1.0 + e) / (1.0 - e))
    let na = ((1.0 - e2) / e2) * ((lnterm / (2.0 * e)) - 1.0)
    let nbc = (1.0 - na) / 2.0
    return [na, nbc, nbc]
}

// Oblate spheroid (a = b > c, flattened), a = equatorial axes, c = short polar.
// e² = 1 − (c/a)²;  N_c = hard polar axis (high demag),  N_a = N_b = (1 − N_c)/2.
fn demag_oblate(a: float, c: float) -> [float] {
    // Degenerate / near-sphere guard: a ≤ c collapses to the sphere value.
    if a <= c {
        let t = 1.0 / 3.0
        return [t, t, t]
    }
    let ratio = c / a
    let e2 = 1.0 - ratio * ratio
    let e = sqrt_pure(e2)
    // N_c = (1/e²)·[ 1 − (√(1−e²)/e)·arcsin(e) ]
    let nc = (1.0 / e2) * (1.0 - (sqrt_pure(1.0 - e2) / e) * asin_pure(e))
    let nab = (1.0 - nc) / 2.0
    return [nab, nab, nc]
}

// ─── analytical limit sanity checks (self-test) ─────────────────────────

fn check_sphere_isotropy() {
    // Sphere: every principal factor = 1/3, and they obviously sum to 1.
    let n = demag_sphere()
    let third = 1.0 / 3.0
    // tol = 1e-5 (absolute): hexa float codegen evaluates the constant 1.0/3.0
    // with a ~3e-7 representation difference between call-site and in-function
    // scope (ref: hexa let-literal / constant-fold precision), orders of
    // magnitude below any physics relevance for a shape factor.
    _check(abs_f(n - third) < 1.0e-5,
        "sphere isotropic factor N = 1/3 (each axis)",
        "N=" + str(n) + "  1/3=" + str(third) + "  |Δ|=" + str(abs_f(n - third)))
}

fn check_sum_rule_golden() {
    // GOLDEN atlas identity: N_a + N_b + N_c = 1 for EVERY aspect ratio,
    // both spheroid families. We sweep several ratios and demand each sum = 1.
    let mut worst: float = 0.0
    // prolate ratios a/c
    let pr = demag_prolate(2.0, 1.0)
    let sum_p2 = pr[0] + pr[1] + pr[2]
    worst = if abs_f(sum_p2 - 1.0) > worst { abs_f(sum_p2 - 1.0) } else { worst }
    let pr10 = demag_prolate(10.0, 1.0)
    let sum_p10 = pr10[0] + pr10[1] + pr10[2]
    worst = if abs_f(sum_p10 - 1.0) > worst { abs_f(sum_p10 - 1.0) } else { worst }
    let pr100 = demag_prolate(100.0, 1.0)
    let sum_p100 = pr100[0] + pr100[1] + pr100[2]
    worst = if abs_f(sum_p100 - 1.0) > worst { abs_f(sum_p100 - 1.0) } else { worst }
    // oblate ratios a/c
    let ob = demag_oblate(2.0, 1.0)
    let sum_o2 = ob[0] + ob[1] + ob[2]
    worst = if abs_f(sum_o2 - 1.0) > worst { abs_f(sum_o2 - 1.0) } else { worst }
    let ob10 = demag_oblate(10.0, 1.0)
    let sum_o10 = ob10[0] + ob10[1] + ob10[2]
    worst = if abs_f(sum_o10 - 1.0) > worst { abs_f(sum_o10 - 1.0) } else { worst }
    let ob100 = demag_oblate(100.0, 1.0)
    let sum_o100 = ob100[0] + ob100[1] + ob100[2]
    worst = if abs_f(sum_o100 - 1.0) > worst { abs_f(sum_o100 - 1.0) } else { worst }
    _check(worst < 1.0e-12,
        "GOLDEN sum-rule N_a+N_b+N_c=1 (6 aspect ratios, prolate+oblate)",
        "prolate sums [2:1,10:1,100:1]=" + str(sum_p2) + "," + str(sum_p10) +
        "," + str(sum_p100) + "  oblate=" + str(sum_o2) + "," + str(sum_o10) +
        "," + str(sum_o100) + "  worst|Σ−1|=" + str(worst))
}

fn check_prolate_cylinder_limit() {
    // Infinite-cylinder limit (a ≫ c): N_a → 0 (no demag along the long axis),
    // N_b = N_c → 1/2 (transverse).
    let n = demag_prolate(10000.0, 1.0)
    let half = 0.5
    _check(n[0] < 1.0e-3 && rel_err(n[1], half) < 1.0e-2 && rel_err(n[2], half) < 1.0e-2,
        "prolate ∞-cylinder limit (a/c=1e4): N_a→0, N_b=N_c→1/2",
        "N_a=" + str(n[0]) + "  N_b=" + str(n[1]) + "  N_c=" + str(n[2]))
}

fn check_oblate_disk_limit() {
    // Infinite-thin-disk limit (a ≫ c): N_c → 1 (full demag across the thin
    // dimension), N_a = N_b → 0 (in-plane).
    let n = demag_oblate(10000.0, 1.0)
    _check(rel_err(n[2], 1.0) < 1.0e-2 && n[0] < 1.0e-3 && n[1] < 1.0e-3,
        "oblate ∞-thin-disk limit (a/c=1e4): N_c→1, N_a=N_b→0",
        "N_a=" + str(n[0]) + "  N_b=" + str(n[1]) + "  N_c=" + str(n[2]))
}

fn check_literature_prolate_2to1() {
    // Osborn (1945) tabulated value: 2:1 prolate spheroid, N along long axis
    // N_a ≈ 0.17356. (Equivalently the m=2 entry of his Table I.)
    let n = demag_prolate(2.0, 1.0)
    let n_lit = 0.173564
    _check(rel_err(n[0], n_lit) < 5.0e-4,
        "literature 2:1 prolate N_a ≈ 0.17356 (Osborn 1945 Table)",
        "N_a=" + str(n[0]) + "  lit=" + str(n_lit) +
        "  rel_err=" + str(rel_err(n[0], n_lit)))
}

// ─── falsifiers ─────────────────────────────────────────────────────────

let FALSIFIERS = [
    "sphere break — demag_sphere() ≠ 1/3 on any axis → DEMOTE isotropic shape factor",
    "GOLDEN sum-rule break — N_a+N_b+N_c ≠ 1 at any aspect ratio → DEMOTE Osborn identity (atlas golden)",
    "prolate-cylinder break — a/c=1e4 fails N_a→0 / N_b=N_c→1/2 → DEMOTE infinite-cylinder asymptote",
    "oblate-disk break — a/c=1e4 fails N_c→1 / N_a=N_b→0 → DEMOTE infinite-thin-disk asymptote",
    "literature break — 2:1 prolate N_a deviates > 0.05 % from 0.17356 → DEMOTE Osborn 1945 calibration",
]

// ─── main ───────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/material/magnet — ellipsoid demagnetizing-factor primitive")
    println("========================================================================")
    println("  sphere:  N_a = N_b = N_c = 1/3")
    println("  prolate: N_a = ((1−e²)/e²)·[(1/2e)·ln((1+e)/(1−e)) − 1], e²=1−(c/a)²")
    println("  oblate:  N_c = (1/e²)·[1 − (√(1−e²)/e)·arcsin(e)],       e²=1−(c/a)²")
    println("  GOLDEN:  N_a + N_b + N_c = 1   (Osborn 1945 sum-rule, exact)")
    println("")

    println("  Analytical limit sanity checks:")
    check_sphere_isotropy()
    check_sum_rule_golden()
    check_prolate_cylinder_limit()
    check_oblate_disk_limit()
    check_literature_prolate_2to1()

    println("")
    println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  demag-factor primitive self-test FAILED — see per-check output above.")
        println("__HEXA_STDLIB_MATERIAL_MAGNET_DEMAG_FACTOR__ FAIL")
        exit(1)
    }
    println("  ellipsoid demagnetizing-factor primitive: PASS")
    println("__HEXA_STDLIB_MATERIAL_MAGNET_DEMAG_FACTOR__ PASS")
    exit(0)
}
