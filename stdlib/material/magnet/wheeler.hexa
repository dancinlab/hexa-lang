#!hexa strict
// ============================================================================
// stdlib/material/magnet/wheeler.hexa — finite-solenoid on-axis B closed-form
//
// General-purpose Wheeler (finite-solenoid on-axis B_z) primitive. Pure
// physics, μ₀ + geometry only — no domain (HTS / RTSC / NMR / etc.) baked in.
// Topical / domain-specific verifiers (e.g. RTSC magnet getdp §4.2.1
// FEM cross-check) should `use` this module and supply their own
// reference values; this file is the SSOT primitive.
//
// Wheeler / finite-solenoid on-axis formula (thin-shell idealization,
// μ_r = 1, axial only):
//
//     B_z(z) = (μ₀·N·I / (2·L)) · [
//                  (z + L/2) / √((z + L/2)² + R²)
//                − (z − L/2) / √((z − L/2)² + R²)
//              ]
//
// where L = axial length, R = (effective) winding radius, N = turns,
// I = per-turn current, μ₀ = 4π·10⁻⁷ H/m.  At z = ±∞ the bracket → 0;
// at L/R → ∞ inside the bore it → (μ₀·N·I/L) (long-solenoid limit).
//
// Honest scope (commons g3):
//   · Linear, μ_r = 1, axial (on-axis) only. Thin-shell idealization at a
//     single effective radius R.
//   · NOT an HTS critical-state model (no Jc(B,T,θ), no quench, no ramp
//     loss, no end-effect refinement beyond the finite-length term itself).
//   · For thick windings, use `wheeler_envelope(...)` to bracket the FEM
//     thick-winding result with {R_in, R_eff, R_outc}.
//
// Surface (pure functions):
//   fn wheeler_bz(n_turns, i_amp, r_m, l_m, z_m)         → B_z (T)
//   fn wheeler_envelope(n_turns, i_amp, r_in, r_outc,
//                       l_m, z_m)                         → [B(R_in), B(R_eff), B(R_outc)]
//
// Self-test (this file):
//   · long-solenoid asymptote L/R = 50  →  B_z(0) ≈ μ₀·n·I (rel < 0.5 %)
//   · far-field decay |z| = 50·L         →  |B_z| < 1 µT
//   · axial symmetry B_z(+z) = B_z(-z)   for centred solenoid
//   · envelope ordering B(R_outc) < B(R_in) (B decreases with R at z=0)
//
// Run:
//     hexa run stdlib/material/magnet/wheeler.hexa
//
// @no-lock-needed

use "self/runtime/math_pure"

let VERSION = "1.0.0"

// ─── check harness ──────────────────────────────────────────────────────

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

fn abs_f(x: float) -> float { if x < 0.0 { return -x } return x }

fn rel_err(a: float, b: float) -> float {
    let d = abs_f(a - b)
    let abs_b = abs_f(b)
    if abs_b < 1.0e-30 { return d }
    return d / abs_b
}

// ─── physical constants ─────────────────────────────────────────────────

let MU0: float = 1.25663706143591729539e-6   // 4π·10⁻⁷ H/m

// ─── Wheeler finite-solenoid on-axis B_z ────────────────────────────────

// Single-radius (thin-shell) closed form.
// (N, I_A, R_m, L_m, z_m) → B_z_T
fn wheeler_bz(n_turns: float, i_amp: float,
              r_m: float, l_m: float, z_m: float) -> float {
    let zp = z_m + 0.5 * l_m
    let zn = z_m - 0.5 * l_m
    let dp = sqrt_pure(zp * zp + r_m * r_m)
    let dn = sqrt_pure(zn * zn + r_m * r_m)
    if dp < 1.0e-30 || dn < 1.0e-30 { return 0.0 }
    let pref = MU0 * n_turns * i_amp / (2.0 * l_m)
    return pref * (zp / dp - zn / dn)
}

// Thick-winding envelope: returns [B(R_in), B(R_eff), B(R_outc)] at z.
// Useful for bracketing FEM thick-winding results against the closed form.
fn wheeler_envelope(n_turns: float, i_amp: float,
                    r_in: float, r_outc: float,
                    l_m: float, z_m: float) -> [float] {
    let r_eff = 0.5 * (r_in + r_outc)
    return [
        wheeler_bz(n_turns, i_amp, r_in,   l_m, z_m),
        wheeler_bz(n_turns, i_amp, r_eff,  l_m, z_m),
        wheeler_bz(n_turns, i_amp, r_outc, l_m, z_m),
    ]
}

// ─── analytical limit sanity checks (self-test) ─────────────────────────

fn check_long_solenoid_limit() {
    // Long-solenoid limit  (L/R → ∞):  B_z(0) → μ₀ · n · I  where n = N/L.
    // We pick L = 50 · R to deeply approach that asymptote.
    let n_turns: float = 1000.0
    let i_amp:   float = 10.0
    let r_m:     float = 0.01
    let l_m:     float = 50.0 * r_m          // 0.5 m
    let bz0 = wheeler_bz(n_turns, i_amp, r_m, l_m, 0.0)
    let asymp = MU0 * (n_turns / l_m) * i_amp
    _check(rel_err(bz0, asymp) < 5.0e-3,
        "L/R = 50 long-solenoid asymptote (B_z(0) → μ₀·n·I within 0.5 %)",
        "B_z(0)=" + str(bz0) + "  μ₀·n·I=" + str(asymp) +
        "  rel_err=" + str(rel_err(bz0, asymp)))
}

fn check_far_field_decay() {
    // Far from the coil (|z| ≫ L, R), B_z must decay (→ 0+).
    // Pick z = 50 · L so that both end terms nearly cancel.
    let n_turns: float = 120.0
    let i_amp:   float = 100.0
    let r_m:     float = 0.0425
    let l_m:     float = 0.200
    let bz_far = wheeler_bz(n_turns, i_amp, r_m, l_m, 50.0 * l_m)
    _check(abs_f(bz_far) < 1.0e-6,
        "far-field |z| = 50·L decays to <= 1 uT",
        "B_z(z=50L)=" + str(bz_far))
}

fn check_symmetry() {
    // The two end terms make B_z(z) an even function of z around the
    // coil centre. B_z(z) = B_z(-z) exactly for the centred solenoid.
    let n_turns: float = 120.0
    let i_amp:   float = 100.0
    let r_m:     float = 0.0425
    let l_m:     float = 0.200
    let z:       float = 0.05
    let bz_p = wheeler_bz(n_turns, i_amp, r_m, l_m,  z)
    let bz_n = wheeler_bz(n_turns, i_amp, r_m, l_m, -z)
    _check(rel_err(bz_p, bz_n) < 1.0e-12,
        "axial symmetry B_z(+z) = B_z(-z) (centred solenoid)",
        "B_z(+z)=" + str(bz_p) + "  B_z(-z)=" + str(bz_n))
}

fn check_envelope_ordering() {
    // For a thick winding at z=0, B_z is monotone-decreasing in R
    // (closer turns → larger contribution). So B(R_in) > B(R_eff) > B(R_outc).
    let env = wheeler_envelope(120.0, 100.0, 0.030, 0.055, 0.200, 0.0)
    _check(env[0] > env[1] && env[1] > env[2],
        "envelope ordering B(R_in) > B(R_eff) > B(R_outc) at z=0",
        "B(R_in)=" + str(env[0]) +
        "  B(R_eff)=" + str(env[1]) +
        "  B(R_outc)=" + str(env[2]))
}

fn check_zero_at_origin_zero_field() {
    // Degenerate: zero current → zero field everywhere.
    let bz = wheeler_bz(120.0, 0.0, 0.0425, 0.200, 0.0)
    _check(abs_f(bz) < 1.0e-30,
        "I = 0  →  B_z = 0 (linearity in current)",
        "B_z=" + str(bz))
}

// ─── falsifiers ─────────────────────────────────────────────────────────

let FALSIFIERS = [
    "long-solenoid limit break — B_z(0; L/R=50) deviates > 0.5 % from μ₀·n·I → DEMOTE Wheeler asymptote",
    "far-field break — |B_z(50·L)| >= 1 uT → DEMOTE finite-extent decay",
    "symmetry break — B_z(+z) ≠ B_z(-z) for centred solenoid → DEMOTE axial-symmetry encoding",
    "envelope ordering break — B(R_in) <= B(R_eff) or B(R_eff) <= B(R_outc) at z=0 → DEMOTE 1/R-monotonicity",
    "linearity break — I = 0 yields nonzero B_z → DEMOTE current-linearity (Biot-Savart)",
]

// ─── main ───────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/material/magnet — Wheeler finite-solenoid on-axis B_z primitive")
    println("========================================================================")
    println("  B_z(z) = (μ₀·N·I / 2L) · [ (z+L/2)/√((z+L/2)²+R²)")
    println("                           − (z−L/2)/√((z−L/2)²+R²) ]")
    println("")

    println("  Analytical limit sanity checks:")
    check_long_solenoid_limit()
    check_far_field_decay()
    check_symmetry()
    check_envelope_ordering()
    check_zero_at_origin_zero_field()

    println("")
    println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  Wheeler primitive self-test FAILED — see per-check output above.")
        println("__HEXA_STDLIB_MATERIAL_MAGNET_WHEELER__ FAIL")
        exit(1)
    }
    println("  Wheeler closed-form primitive: PASS")
    println("__HEXA_STDLIB_MATERIAL_MAGNET_WHEELER__ PASS")
    exit(0)
}
