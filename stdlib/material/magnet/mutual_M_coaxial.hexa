#!hexa strict
// ============================================================================
// stdlib/material/magnet/mutual_M_coaxial.hexa
//   mutual inductance M of two coaxial circular loops — Maxwell elliptic form
//
// 두 동축 원형 filamentary loop (반지름 R₁, R₂, 축 거리 d) 의 상호 인덕턴스
// M 의 닫힌형 — Neumann 적분을 Legendre 형 elliptic K(k), E(k) 로 환원한
// Maxwell-Lyle 공식. wheeler.hexa (단일 솔레노이드 self-L) 의 자매 primitive
// 로, 두 코일 사이의 coupling ground truth.
//
// Maxwell (Legendre) form — modulus k:
//
//   k² = 4·R₁·R₂ / [ (R₁ + R₂)² + d² ]
//   k  = √k²
//
//   M(R₁, R₂, d) = μ₀ · √(R₁·R₂) · [ (2/k − k)·K(k)  −  (2/k)·E(k) ]
//
// 동등한 정리식:
//
//   M = μ₀ · √(R₁·R₂) · [ (2 − k²)·K(k)  −  2·E(k) ] / k
//
// (참고: Maxwell, _A Treatise on Electricity and Magnetism_, vol. II §700;
// Grover, _Inductance Calculations: Working Formulas and Tables_, §17.)
//
// Limits / asymptotes:
//   · d → ∞  (far-field, k → 0)  →  dipole-dipole 어사임토트
//        M ≈ μ₀·π·R₁²·R₂² / (2·d³)
//   · R₁ = R₂ = R, d = 0  (concentric coplanar identical loops, k → 1)
//        K(1) → ∞  ⇒  M → +∞  (filamentary self-coupling singularity;
//                                sentinel 1e300 반환)
//   · R₁ = R₂ = R, d = R  (Maxwell-Lyle anchor)
//        k² = 4·R² / (4·R² + R²) = 4/5,  k = √(0.8) ≈ 0.894427
//        M / (μ₀·R) ≈ 0.393175 (closed-form numeric anchor)
//
// Properties:
//   · Symmetry — M(R₁, R₂, d) = M(R₂, R₁, d)   (R₁ ↔ R₂ swap 동치)
//   · Scale invariance — M(α·R₁, α·R₂, α·d) = α · M(R₁, R₂, d)   (length scaling)
//   · Reciprocity — Neumann 적분 형식 자체가 대칭이므로 위 두 속성은
//     수치 검증의 ground truth.
//
// Honest scope (commons g3):
//   · Filamentary loop pair only (no finite wire radius / proximity effect).
//   · μ_r = 1 (linear vacuum / non-magnetic medium).
//   · Coaxial only — tilted / off-axis pair는 별도 공식 (Neumann 이중적분).
//   · k = 1 (touching loops) returns sentinel 1e300 — filamentary singular.
//
// Surface (pure functions):
//   fn mutual_M_coaxial(r1_m, r2_m, d_m) → M_henry
//
// Self-test (this file):
//   F1: d ≫ R → dipole asymptote  M ≈ μ₀·π·R₁²·R₂² / (2·d³)   (rel < 5e-4)
//   F2: R₁ = R₂, d = 0 → sentinel 1e300 (logarithmic K(1) divergence)
//   F3: R₁ = R₂ = R, d = R → M / (μ₀·R) ≈ 0.393175  (Maxwell anchor; rel < 1e-10)
//   F4: symmetry  M(R₁, R₂, d) = M(R₂, R₁, d)         (rel < 1e-14)
//   F5: scale invariance  M(αR₁, αR₂, αd) = α·M(R₁, R₂, d)  (rel < 1e-12)
//
// Run:
//     hexa run stdlib/material/magnet/mutual_M_coaxial.hexa
//
// @no-lock-needed

use "self/runtime/math_pure"
use "stdlib/math/special/elliptic"

let VERSION = "1.0.0"

// ─── check harness ──────────────────────────────────────────────────────

let mut RUN = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

fn abs_f(x: float) -> float { if x < 0.0 { return -x } return x }

fn rel_err(a: float, b: float) -> float {
    let d = abs_f(a - b)
    let abs_b = abs_f(b)
    if abs_b < 1.0e-30 { return d }
    return d / abs_b
}

// ─── physical constants ─────────────────────────────────────────────────

let MU0:  float = 1.25663706143591729539e-6   // 4π·10⁻⁷ H/m
let PI:   float = 3.14159265358979323846

// +∞ sentinel for k → 1 singular (matches elliptic.hexa K_AT_ONE convention)
let M_INF: float = 1.0e300

// ─── Maxwell mutual M (Legendre / Maxwell elliptic form) ────────────────

// Input:  R1_m, R2_m  — loop radii (m, > 0)
//         d_m         — coaxial separation (m, ≥ 0)
// Output: M_henry     — mutual inductance (H), positive
//
// Edge cases:
//   R1 ≤ 0 or R2 ≤ 0           → 0.0   (degenerate, no loop)
//   d   <  0                   → 0.0   (ill-formed input; geometry must be ≥0)
//   k ≥ 1 − ε  (touching equal-radius coplanar) → M_INF   (filamentary singular)
fn mutual_M_coaxial(r1_m: float, r2_m: float, d_m: float) -> float {
    if r1_m <= 0.0 || r2_m <= 0.0 { return 0.0 }
    if d_m < 0.0 { return 0.0 }

    let sum_r  = r1_m + r2_m
    let denom  = sum_r * sum_r + d_m * d_m
    if denom < 1.0e-300 { return M_INF }

    let ksq    = 4.0 * r1_m * r2_m / denom
    // Coplanar identical-radius limit:  R1=R2=R, d=0  ⇒  ksq = 4R²/(2R)² = 1.
    if ksq >= 1.0 - 1.0e-15 { return M_INF }

    let k      = sqrt_pure(ksq)
    let ke     = elliptic_K_E(k)
    let kk     = ke[0]
    let ee     = ke[1]

    let bracket = (2.0 / k - k) * kk  -  (2.0 / k) * ee
    return MU0 * sqrt_pure(r1_m * r2_m) * bracket
}

// ─── analytical limit sanity checks (self-test) ─────────────────────────

fn check_far_field_dipole_asymptote() {
    // F1 — d ≫ R₁, R₂  →  dipole-dipole asymptote
    //     M ≈ μ₀ · π · R₁² · R₂² / (2 · d³)
    // Pick d/R = 1000 so the asymptote is sharp but k stays large enough to
    // avoid catastrophic cancellation in (2/k − k)·K − (2/k)·E.
    let r1: float = 0.01
    let r2: float = 0.01
    let d:  float = 10.0
    let m_exact   = mutual_M_coaxial(r1, r2, d)
    let m_dipole  = MU0 * PI * r1 * r1 * r2 * r2 / (2.0 * d * d * d)
    _check(rel_err(m_exact, m_dipole) < 5.0e-4,
        "F1 far-field dipole asymptote  M ≈ μ₀·π·R₁²·R₂² / (2·d³)  (d/R=1000)",
        "M_exact=" + str(m_exact) + "  M_dipole=" + str(m_dipole) +
        "  rel_err=" + str(rel_err(m_exact, m_dipole)))
}

fn check_touching_singular_sentinel() {
    // F2 — R₁ = R₂ = R, d = 0  →  k → 1, K(k) → ∞  →  M = M_INF sentinel.
    // Filamentary singular (zero wire radius). Real wires have finite radius
    // and a regularized self-/near-coupling, but the bare Maxwell form is
    // divergent here.
    let r:  float = 0.01
    let m   = mutual_M_coaxial(r, r, 0.0)
    _check(m >= M_INF * 0.5,
        "F2 touching equal loops (R₁=R₂=R, d=0) → +∞ sentinel (k=1 singular)",
        "M=" + str(m) + "  sentinel=" + str(M_INF))
}

fn check_maxwell_lyle_anchor() {
    // F3 — Maxwell-Lyle anchor: R₁ = R₂ = R, d = R.
    //     k² = 4·R² / (4·R² + R²) = 4/5,  k = √(0.8) ≈ 0.894427
    //     K(k) ≈ 2.257205326820854
    //     E(k) ≈ 1.178489924327838
    //     M / (μ₀·R) = (2/k − k)·K(k) − (2/k)·E(k) ≈ 0.39317514837200557
    let r: float = 0.05
    let d: float = 0.05
    let m  = mutual_M_coaxial(r, r, d)
    let target_ratio: float = 0.39317514837200557
    let target_m = MU0 * r * target_ratio
    _check(rel_err(m, target_m) < 1.0e-10,
        "F3 Maxwell-Lyle anchor R₁=R₂=R, d=R  →  M/(μ₀·R) ≈ 0.393175148",
        "M=" + str(m) + "  target=" + str(target_m) +
        "  rel_err=" + str(rel_err(m, target_m)))
}

fn check_symmetry_swap() {
    // F4 — symmetry under R₁ ↔ R₂ swap (Neumann integral 자체 대칭).
    let r1: float = 0.03
    let r2: float = 0.05
    let d:  float = 0.10
    let m_ab = mutual_M_coaxial(r1, r2, d)
    let m_ba = mutual_M_coaxial(r2, r1, d)
    _check(rel_err(m_ab, m_ba) < 1.0e-14,
        "F4 symmetry M(R₁, R₂, d) = M(R₂, R₁, d)  (R₁ ↔ R₂ swap)",
        "M(R₁,R₂,d)=" + str(m_ab) + "  M(R₂,R₁,d)=" + str(m_ba) +
        "  rel_err=" + str(rel_err(m_ab, m_ba)))
}

fn check_scale_invariance() {
    // F5 — length scaling: all dimensions × α  →  M × α
    //   (M has units of H = μ₀ · length, so scales linearly with length.)
    let r1:    float = 0.02
    let r2:    float = 0.04
    let d:     float = 0.03
    let alpha: float = 3.7
    let m_unit   = mutual_M_coaxial(r1, r2, d)
    let m_scaled = mutual_M_coaxial(alpha * r1, alpha * r2, alpha * d)
    _check(rel_err(m_scaled / alpha, m_unit) < 1.0e-12,
        "F5 scale invariance M(αR₁, αR₂, αd) = α·M(R₁, R₂, d)  (α=3.7)",
        "M(unit)=" + str(m_unit) + "  M(scaled)/α=" + str(m_scaled / alpha) +
        "  rel_err=" + str(rel_err(m_scaled / alpha, m_unit)))
}

fn check_degenerate_zero_radius() {
    // Extra — degenerate loop (R = 0)  →  M = 0 (no flux).
    let m = mutual_M_coaxial(0.0, 0.05, 0.10)
    _check(abs_f(m) < 1.0e-30,
        "degenerate R₁ = 0  →  M = 0  (no enclosed flux)",
        "M=" + str(m))
}

// ─── falsifiers ─────────────────────────────────────────────────────────

let FALSIFIERS = [
    "F1 dipole-asymptote break — d/R=1000 limit deviates from μ₀·π·R₁²·R₂²/(2·d³) by > 5e-4 → DEMOTE far-field Legendre→dipole reduction",
    "F2 touching-singular break — mutual_M(R, R, 0) returns finite small value → DEMOTE k=1 sentinel (filamentary divergence)",
    "F3 Maxwell-Lyle anchor break — M(R,R,R)/(μ₀·R) deviates from 0.393175148 by > 1e-10 → DEMOTE Maxwell elliptic K,E formula",
    "F4 symmetry break — M(R₁,R₂,d) ≠ M(R₂,R₁,d) at rel > 1e-14 → DEMOTE R₁↔R₂ Neumann symmetry encoding",
    "F5 scale-invariance break — M(αR₁,αR₂,αd) ≠ α·M(R₁,R₂,d) at rel > 1e-12 → DEMOTE length-scaling (μ₀·length units)",
]

// ─── main ───────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/material/magnet — mutual_M_coaxial (Maxwell elliptic K,E form)")
    println("========================================================================")
    println("  k² = 4·R₁·R₂ / [(R₁+R₂)² + d²]")
    println("  M  = μ₀ · √(R₁·R₂) · [ (2/k − k)·K(k)  −  (2/k)·E(k) ]")
    println("")

    println("  Analytical limit sanity checks (5 falsifiers + 1 extra):")
    check_far_field_dipole_asymptote()
    check_touching_singular_sentinel()
    check_maxwell_lyle_anchor()
    check_symmetry_swap()
    check_scale_invariance()
    check_degenerate_zero_radius()

    println("")
    println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("  mutual_M_coaxial primitive self-test FAILED — see per-check output above.")
        println("__HEXA_STDLIB_MATERIAL_MAGNET_MUTUAL_M_COAXIAL__ FAIL")
        exit(1)
    }
    println("  mutual_M_coaxial (Maxwell elliptic K,E) primitive: PASS")
    println("__HEXA_STDLIB_MATERIAL_MAGNET_MUTUAL_M_COAXIAL__ PASS")
    exit(0)
}
