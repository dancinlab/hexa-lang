// HEXA Standard Library — material/composition
//
// @version 0.1.0
// @capabilities [pure]
//
// RTSC.md §9.9.1 Phase 4 cohort #2 — hexa-native port of the composition
// parser + inorganic/organic domain classifier originally in
// `stdlib/material/askcos_adapter.py`. Ported from
// `_parse_formula_elements` + `_classify_composition_domain`
// (Phase 4 #2, RTSC.md §9.9.1).
//
// Surface (pure functions, no syscall):
//   pub fn parse_formula_elements(formula: string) -> Composition
//   pub fn classify_composition_domain(formula: string) -> Classification
//
// Honest scope: NOT a full IUPAC parser. Handles
//   - Element symbols of the form [A-Z][a-z]?  (1- or 2-char)
//   - Optional integer-or-decimal count immediately after the symbol
//   - SINGLE level of parentheses with an optional integer multiplier
//     after the close-paren (e.g. "(PO4)6" → "P6O24"). Nested parens
//     match Python source behavior (single-level only — anything
//     deeper expands the outermost match once, leaves inner content
//     to the element scan).
//
// Data shape: hexa-lang v0.3 has no native map type, so we use two
// parallel arrays (symbols + counts) — same approach as Phase 4 cohort
// #1 inverse_variance_consensus. `lookup` is O(N) which is fine for
// formulas with ≤ ~10 distinct elements.

import "stdlib/core/string.hexa"

// ── data types ─────────────────────────────────────────────────────────

// Parallel-array element inventory. `symbols[i]` ↔ `counts[i]`.
// Symbols appear in first-encounter order after parenthesis expansion;
// duplicates are merged (counts summed).
pub struct Composition {
    symbols:    [string],
    counts:     [float],
}

// Domain classification result. `label` is one of:
//   "inorganic_sc"        — explicit allow-list hit OR no carbon
//                            OR carbon + heavy-metal + multi-oxygen
//   "organic_molecular"   — carbon present, no oxide signature,
//                            ≤30 heavy atoms (ASKCOS in-distribution)
//   "ambiguous"           — carbon + heavy-atom count > 30,
//                            OR formula parse failure
// `rationale` is a human-readable explanation matching the Python
// reference adapter (askcos_adapter.py:_classify_composition_domain)
// closely enough that downstream consumers can use either source.
pub struct Classification {
    label:      string,
    rationale:  string,
}

// ── helpers ────────────────────────────────────────────────────────────

fn _is_upper(ch: string) -> bool {
    return ch >= "A" && ch <= "Z"
}

fn _is_lower(ch: string) -> bool {
    return ch >= "a" && ch <= "z"
}

fn _is_digit_ch(ch: string) -> bool {
    return ch >= "0" && ch <= "9"
}

// Parse a leading numeric token from `s` starting at index `i`. Accepts
// optional digits, optional '.', optional digits. Returns (count, next_i).
// If no digits/decimal at `i`, returns (1.0, i) — matches Python "" → 1.0.
fn _scan_count(s: string, i: int) -> [float] {
    let n = len(s)
    let mut j = i
    let mut has_digit = false
    let mut int_part = 0
    let mut frac_part = 0
    let mut frac_scale = 1
    let mut saw_dot = false
    while j < n {
        let ch = s.substring(j, j + 1)
        if _is_digit_ch(ch) {
            let d = ord(ch) - 48
            if saw_dot {
                frac_part = frac_part * 10 + d
                frac_scale = frac_scale * 10
            } else {
                int_part = int_part * 10 + d
            }
            has_digit = true
            j = j + 1
        } else {
            if ch == "." && !saw_dot {
                saw_dot = true
                j = j + 1
            } else {
                break
            }
        }
    }
    if !has_digit {
        // Python: `int(mult_str) if mult_str else 1` and
        //         `float(count) if count else 1.0`
        return [1.0, to_float(i)]
    }
    let value = to_float(int_part) + to_float(frac_part) / to_float(frac_scale)
    return [value, to_float(j)]
}

// Append (sym, c) into parallel arrays — merge by summing if `sym`
// already present. Mutates `symbols` / `counts` in place.
fn _accumulate(symbols: [string], counts: [float],
               sym: string, c: float) {
    let n = len(symbols)
    let mut k = 0
    while k < n {
        if symbols[k] == sym {
            counts[k] = counts[k] + c
            return
        }
        k = k + 1
    }
    symbols.push(sym)
    counts.push(c)
}

// Scan an element-list substring `s` (no parens) and accumulate the
// (symbol, count * outer_mult) pairs into the parallel arrays. Used
// both for the outer formula scan (outer_mult = 1.0) and the inner-of-
// parens scan (outer_mult = the multiplier after the close paren).
fn _scan_elements(s: string, outer_mult: float,
                  symbols: [string], counts: [float]) {
    let n = len(s)
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if !_is_upper(ch) {
            // Skip any stray char — Python's regex .findall would just
            // ignore unmatched bytes between matches.
            i = i + 1
        } else {
            // 1- or 2-char element symbol.
            let mut sym = ch
            i = i + 1
            if i < n {
                let ch2 = s.substring(i, i + 1)
                if _is_lower(ch2) {
                    sym = sym + ch2
                    i = i + 1
                }
            }
            let pair = _scan_count(s, i)
            let c = pair[0] * outer_mult
            // pair[1] was stored as float index — back to int.
            i = to_int(pair[1])
            _accumulate(symbols, counts, sym, c)
        }
    }
}

// Find the first `(` ... `)` block in `s` and expand it. Returns the
// rewritten string with that one group inlined as `<sym><count>...`
// repeated by the post-paren integer multiplier (Python parity:
// `re.sub(r"\(([^()]+)\)(\d*)", expand, formula)` runs once across the
// whole string, but each match is independent — we iterate ourselves).
//
// Returns the input unchanged if no balanced single-level group exists.
fn _expand_one_paren_pass(formula: string) -> string {
    let n = len(formula)
    let mut open_at: int = -1
    let mut i = 0
    // find first '('
    while i < n {
        if formula.substring(i, i + 1) == "(" {
            open_at = i
            break
        }
        i = i + 1
    }
    if open_at < 0 { return formula }
    // find matching ')' — single level, no nesting (Python's
    // [^()]+ refuses nested parens).
    let mut close_at: int = -1
    let mut j = open_at + 1
    while j < n {
        let ch = formula.substring(j, j + 1)
        if ch == "(" {
            // nested open — Python regex wouldn't match; bail out.
            return formula
        }
        if ch == ")" {
            close_at = j
            break
        }
        j = j + 1
    }
    if close_at < 0 { return formula }

    let inner = formula.substring(open_at + 1, close_at)
    // scan optional multiplier after ')'
    let after = close_at + 1
    let mult_pair = _scan_count(formula, after)
    let mult = mult_pair[0]
    let after_mult = to_int(mult_pair[1])

    // Expand: scan `inner` and emit "<sym><int(c*mult)>" parts. To stay
    // textual (Python writes `f"{sym}{int(c*mult)}"`), we re-render.
    let inner_symbols: [string] = []
    let inner_counts:  [float]  = []
    _scan_elements(inner, 1.0, inner_symbols, inner_counts)

    let mut expanded = ""
    let m = len(inner_symbols)
    let mut k = 0
    while k < m {
        let c = inner_counts[k] * mult
        // Python: int(c) if c.is_integer() else c. Both branches stringify.
        let c_int = to_int(c)
        if to_float(c_int) == c {
            expanded = expanded + inner_symbols[k] + to_string(c_int)
        } else {
            expanded = expanded + inner_symbols[k] + to_string(c)
        }
        k = k + 1
    }

    let head = formula.substring(0, open_at)
    let tail = formula.substring(after_mult, n)
    return head + expanded + tail
}

// Loop _expand_one_paren_pass until fixpoint. Bounded by len(formula)
// — each pass removes at least one '(' so we cannot infinite-loop.
fn _expand_all_parens(formula: string) -> string {
    let mut cur = formula
    let mut guard = 0
    let max_iters = len(formula) + 2
    while guard < max_iters {
        let next = _expand_one_paren_pass(cur)
        if next == cur { return cur }
        cur = next
        guard = guard + 1
    }
    return cur
}

// ── public surface ─────────────────────────────────────────────────────

// Parse a flat compound formula into a Composition (parallel arrays of
// element symbols + counts). Handles parentheses one level deep, e.g.
// "Pb10Cu(PO4)6O" → {Pb:10, Cu:1, P:6, O:25}. NOT a full IUPAC parser.
//
// Behavior parity with Python `_parse_formula_elements`:
//   - Missing count → 1.0
//   - Decimal counts (e.g. "YBa2Cu3O6.5") supported
//   - Single-level parens expanded; nested parens left as-is (Python's
//     `[^()]+` regex doesn't match nested groups either)
//   - Unmatched chars silently skipped (Python `re.findall` semantics)
//
// Ported from askcos_adapter.py `_parse_formula_elements` (Phase 4 #2,
// RTSC.md §9.9.1).
pub fn parse_formula_elements(formula: string) -> Composition {
    let expanded = _expand_all_parens(formula)
    let symbols: [string] = []
    let counts:  [float]  = []
    _scan_elements(expanded, 1.0, symbols, counts)
    return Composition { symbols: symbols, counts: counts }
}

// O(N) lookup helper — returns count for `sym` in `comp`, or 0.0 if
// missing. Parity with Python `elements.get(sym, 0.0)`.
pub fn composition_get(comp: Composition, sym: string) -> float {
    let n = len(comp.symbols)
    let mut i = 0
    while i < n {
        if comp.symbols[i] == sym { return comp.counts[i] }
        i = i + 1
    }
    return 0.0
}

// Inorganic SC explicit allow-list. Mirrors `_INORGANIC_SC_HINTS` in
// askcos_adapter.py:169-186 verbatim (LK-99 / lead-apatite, YBCO /
// REBCO cuprates, iron-based, intermetallics / borides, hydrides,
// A15 / heavy-fermion). Used as the first short-circuit in
// classify_composition_domain.
pub fn inorganic_sc_hints() -> [string] {
    return [
        // LK-99 / lead-apatite
        "Pb10Cu(PO4)6O", "Pb9Cu(PO4)6O", "Pb10(PO4)6O",
        // YBCO / REBCO cuprates
        "YBa2Cu3O7", "YBa2Cu3O6", "YBa2Cu3O6.5",
        "Bi2Sr2CaCu2O8", "Bi2Sr2Ca2Cu3O10",
        "HgBa2Ca2Cu3O8",
        // Iron-based
        "FeSe", "FeAs", "BaFe2As2", "LaFeAsO",
        // Intermetallics / borides
        "MgB2", "Nb3Sn", "Nb3Ge", "NbTi", "Nb",
        // Hydrides (high-P)
        "H3S", "LaH10", "CaH6", "ScH9", "YH6",
        // A15 / heavy-fermion
        "URu2Si2", "CeCu2Si2", "Sr2RuO4",
    ]
}

// Heavy-metal set used by Rule 4. Mirrors `metals` literal in
// askcos_adapter.py:220-225 verbatim.
fn _heavy_metals() -> [string] {
    return [
        "Pb", "Y", "Ba", "La", "Sr", "Hg", "Fe", "Cu", "Nb", "Mg", "Sc",
        "Ti", "Ca", "Bi", "Tl", "Zr", "Hf", "V", "Ta", "W", "Mo", "Re",
        "Ru", "Os", "Rh", "Ir", "Pd", "Pt", "Ag", "Au", "Cd", "In", "Sn",
        "Sb", "U", "Th", "Ce", "Nd", "Sm", "Gd", "Dy", "Er", "Yb",
    ]
}

fn _list_contains(items: [string], needle: string) -> bool {
    let n = len(items)
    let mut i = 0
    while i < n {
        if items[i] == needle { return true }
        i = i + 1
    }
    return false
}

// Classify a composition string into the (label, rationale) pair
// driving the ASKCOS adapter's `domain-mismatch` gate.
//
// Rules (verbatim from askcos_adapter.py:189-248):
//   1. Explicit allow-list hit → "inorganic_sc"
//   2. No carbon → "inorganic_sc" (oxide / hydride / intermetallic)
//   3. Carbon + heavy-metal + ≥2 oxygen → "inorganic_sc"
//      (organometallic / oxide-coordination compound)
//   4. Carbon present, no oxide pattern, ≤30 heavy atoms →
//      "organic_molecular"
//   5. Otherwise → "ambiguous"
//
// Ported from askcos_adapter.py `_classify_composition_domain` (Phase
// 4 #2, RTSC.md §9.9.1).
pub fn classify_composition_domain(formula: string) -> Classification {
    // Python: f_clean = formula.replace(" ", "")
    let f_clean = formula.replace(" ", "")

    let hints = inorganic_sc_hints()
    if _list_contains(hints, f_clean) {
        return Classification {
            label: "inorganic_sc",
            rationale: "explicit hit on RTSC §8.2 SC family (" + f_clean + ")",
        }
    }

    let comp = parse_formula_elements(f_clean)
    let has_carbon = composition_get(comp, "C") > 0.0
    if !has_carbon {
        return Classification {
            label: "inorganic_sc",
            rationale: "no carbon atoms in '" + f_clean +
                       "'; treated as oxide/hydride/intermetallic — " +
                       "outside ASKCOS (Reaxys-organic) training " +
                       "distribution",
        }
    }

    let metals = _heavy_metals()
    let mut heavy_metal_present = false
    let m = len(metals)
    let mut i = 0
    while i < m {
        if composition_get(comp, metals[i]) > 0.0 {
            heavy_metal_present = true
            break
        }
        i = i + 1
    }
    let oxygen_count = composition_get(comp, "O")
    let has_oxide_pattern = heavy_metal_present && oxygen_count >= 2.0

    if has_oxide_pattern {
        return Classification {
            label: "inorganic_sc",
            rationale: "carbon present in '" + f_clean +
                       "' but heavy-metal + multi-oxygen signature " +
                       "suggests organometallic / oxide coordination " +
                       "compound — outside ASKCOS organic distribution",
        }
    }

    // Total heavy-atom count = Σ counts where sym != "H".
    let n = len(comp.symbols)
    let mut total_heavy: float = 0.0
    let mut j = 0
    while j < n {
        if comp.symbols[j] != "H" {
            total_heavy = total_heavy + comp.counts[j]
        }
        j = j + 1
    }

    if total_heavy <= 30.0 {
        return Classification {
            label: "organic_molecular",
            rationale: "'" + f_clean + "' contains carbon, no oxide " +
                       "pattern, heavy-atom count " +
                       to_string(total_heavy) + " ≤ 30 — likely " +
                       "small-molecule organic (in ASKCOS distribution)",
        }
    }

    return Classification {
        label: "ambiguous",
        rationale: "'" + f_clean + "' contains carbon but heavy-atom " +
                   "count " + to_string(total_heavy) +
                   " > 30; ASKCOS may or may not have signal",
    }
}

// ── self-check entry (smoke) ───────────────────────────────────────────
//
// Run via `hexa run stdlib/material/composition.hexa`.
// Prints the same 10-row table consumed by /tmp/composition_parity_test.py
// (see RTSC.md §9.9.1 Phase 4 cohort #2 verification).

fn _fmt_comp(c: Composition) -> string {
    // Stable rendering: sort symbols alphabetically for the printout.
    let n = len(c.symbols)
    let idx: [int] = []
    let mut i = 0
    while i < n { idx.push(i); i = i + 1 }
    // Simple O(N²) selection sort on idx by symbol.
    let mut a = 0
    while a < n {
        let mut mn = a
        let mut b = a + 1
        while b < n {
            if c.symbols[idx[b]] < c.symbols[idx[mn]] { mn = b }
            b = b + 1
        }
        if mn != a {
            let tmp = idx[a]
            idx[a] = idx[mn]
            idx[mn] = tmp
        }
        a = a + 1
    }
    let mut out = "{"
    let mut k = 0
    while k < n {
        if k > 0 { out = out + ", " }
        out = out + c.symbols[idx[k]] + ":" + to_string(c.counts[idx[k]])
        k = k + 1
    }
    out = out + "}"
    return out
}

fn _emit(formula: string) {
    let comp = parse_formula_elements(formula)
    let cls = classify_composition_domain(formula)
    println("  · " + formula + " → " + _fmt_comp(comp) +
            "  domain=" + cls.label)
}

fn main() {
    println("[material+verify] composition.hexa — RTSC.md §9.9.1 Phase 4 #2")
    _emit("Nb")
    _emit("MgB2")
    _emit("YBa2Cu3O7")
    _emit("Pb10Cu(PO4)6O")
    _emit("Fe3Al2(SiO4)3")
    _emit("C6H6")
    _emit("Si")
    _emit("CO")
    _emit("Na2CO3")
    _emit("MoS2")
    println("[cite] Ported from askcos_adapter.py " +
            "`_parse_formula_elements` + `_classify_composition_domain` " +
            "(Phase 4 #2, RTSC.md §9.9.1).")
    println("[anchor] RTSC.md §9.9.1 Phase 4 (B→A microkernel transition)")
}
