// HEXA Standard Library — material/sim
//
// @version 0.3.0
// @capabilities [pure, io]
//
// RTSC.md §8.7 Tier 1 — Computational synthesis (first-principles 시뮬레이션),
// hexa-native port of `stdlib/material/sim_adapter.py`. Closes the Tier-1
// "hexa-native expansion" roll-out item: the four closed-form Tc/Hc2
// predictors are now a true hexa-lang artifact instead of a Python adapter
// that demiurge spawns over python_ffi. The Python file is kept intact at
// `stdlib/material/sim_adapter.py` for cross-validation (numerically
// identical for the Nb reference panel — see verify steps below).
//
// Surface (pure functions, no syscall):
//   pub fn bcs_weak_tc(theta_d_K: float, lam: float) -> float
//   pub fn mcmillan_tc(omega_log_K: float, lam: float, mu_star: float) -> float
//   pub fn allen_dynes_tc(omega_log_K: float, lam: float, mu_star: float,
//                         omega2_K: float) -> float
//   pub fn whh_hc2_zero(tc_K: float, slope_T_per_K: float) -> float
//   pub fn sigma_from_spread(values: [float], sigma_default: float) -> float
//   pub fn inverse_variance_consensus(values: [float], sigmas: [float])
//                                     -> Consensus
//
// Source formulas (each a closed-form algebraic identity, NOT a solver):
//   - BCS Tc         : Bardeen-Cooper-Schrieffer 1957, PR 108 1175
//                      Tc = 1.13 · Θ_D · exp(-1 / (N(0)·V))
//                      Weak-coupling. Valid only for λ = N(0)V ≲ 0.5.
//   - McMillan Tc    : McMillan 1968, PR 167 331
//                      Tc = (ω_log/1.2) · exp[ -1.04(1+λ) / (λ - μ*(1+0.62λ)) ]
//                      Intermediate-coupling extension.
//   - Allen-Dynes Tc : Allen & Dynes 1975, PRB 12 905
//                      same kernel × f1·f2 strong-coupling correction factors.
//   - Hc2(0) WHH     : Werthamer-Helfand-Hohenberg 1966, PR 147 295
//                      Hc2(0) = -0.69 · Tc · (dHc2/dT)|_Tc  (dirty-limit BCS).
//   - inverse-variance consensus + σ-from-spread (Phase 4 cohort #1, added
//     v0.2.0; see consensus block below for full citation).
//
// g3 (honest scope):
//   absorbed = false FOREVER for this record-kind. Tier 1 is *prediction*,
//   NOT *measurement*. Promotion to absorbed=true requires Tier 3 measurement
//   + Tier 4 falsifier dispatch in a separate cohort (RTSC.md §8.7 / §8.8).
//   The consensus kernel returns numbers ONLY — the caller decides
//   gate_type / absorbed (policy lives in the Python orchestrator, R4
//   invariant carried over per RTSC.md §9.9.1 Phase 4 brief).

// ── helpers ────────────────────────────────────────────────────────────

fn _fabs(x: float) -> float { if x < 0.0 { return -x } return x }

fn _fmax(a: float, b: float) -> float { if a > b { return a } return b }

// ── 1. BCS weak-coupling Tc ────────────────────────────────────────────
//
// Tc = 1.13 · Θ_D · exp(-1 / λ_eff)   where λ_eff = N(0)·V.
//
// Honest scope: weak-coupling only. For λ ≳ 0.5 the exponential blows up
// and Tc becomes unphysically large — that's the published failure mode
// that motivated McMillan (1968) and Allen-Dynes (1975).
pub fn bcs_weak_tc(theta_d_K: float, lam: float) -> float {
    if lam <= 0.0 { return 0.0 }
    return 1.13 * theta_d_K * exp(-1.0 / lam)
}

// ── 2. McMillan Tc ─────────────────────────────────────────────────────
//
// Tc = (ω_log / 1.2) · exp[ -1.04(1+λ) / (λ - μ*(1+0.62λ)) ]
//
// Denominator must be > 0 → λ > μ*(1+0.62λ). Otherwise the formula is
// outside its regime (no SC predicted at this μ*).
pub fn mcmillan_tc(omega_log_K: float, lam: float, mu_star: float) -> float {
    let denom = lam - mu_star * (1.0 + 0.62 * lam)
    if denom <= 0.0 { return 0.0 }
    if lam <= 0.0 { return 0.0 }
    if omega_log_K <= 0.0 { return 0.0 }
    let exponent = -1.04 * (1.0 + lam) / denom
    return (omega_log_K / 1.2) * exp(exponent)
}

// ── 3. Allen-Dynes Tc ──────────────────────────────────────────────────
//
// Tc = f1 · f2 · (ω_log/1.2) · exp[ -1.04(1+λ) / (λ - μ*(1+0.62λ)) ]
//
// f1 = (1 + (λ/Λ1)^(3/2))^(1/3),         Λ1 = 2.46 (1 + 3.8 μ*)
// f2 = 1 + λ²(ω₂/ω_log - 1) / (λ² + Λ2²), Λ2 = 1.82 (1 + 6.3 μ*)(ω₂/ω_log)
//
// First-cut: caller may pass omega2_K = omega_log_K → f2 = 1.
pub fn allen_dynes_tc(omega_log_K: float, lam: float, mu_star: float,
                      omega2_K: float) -> float {
    let base = mcmillan_tc(omega_log_K, lam, mu_star)
    if base <= 0.0 { return 0.0 }
    if omega_log_K <= 0.0 { return 0.0 }

    let r = omega2_K / omega_log_K
    let lambda1 = 2.46 * (1.0 + 3.8 * mu_star)
    let lambda2 = 1.82 * (1.0 + 6.3 * mu_star) * r

    let f1 = pow(1.0 + pow(lam / lambda1, 1.5), 1.0 / 3.0)
    let f2_num = (lam * lam) * (r - 1.0)
    let f2_den = (lam * lam) + (lambda2 * lambda2)
    let f2 = 1.0 + f2_num / f2_den

    return f1 * f2 * base
}

// ── 4. WHH Hc2(0) ──────────────────────────────────────────────────────
//
// Hc2(0) = -0.69 · Tc · (dHc2/dT)|_{T=Tc}    [dirty-limit BCS, WHH 1966]
//
// Convention: the slope dHc2/dT near Tc is *negative* (Hc2 falls from Tc
// upward in T). Callers typically pass the magnitude |slope| (positive
// T/K). We accept either sign and return a positive Hc2(0).
pub fn whh_hc2_zero(tc_K: float, slope_T_per_K: float) -> float {
    let slope_mag = _fabs(slope_T_per_K)
    // slope_signed = -slope_mag → Hc2(0) = -0.69 · Tc · (-slope_mag)
    //                                    = +0.69 · Tc · slope_mag
    return 0.69 * tc_K * slope_mag
}

// ── 4a. Allen-Dynes strong-coupling Tc (full f1·f2 form) ───────────────
//
// @cite Allen & Dynes 1975, PRB 12 905 — Eqs. 33–34 (f1·f2 corrected).
//
// Tc = f1 · f2 · (ω_log/1.2) · exp[ -1.04(1+λ) / (λ - μ*(1+0.62λ)) ]
//
// f1 = (1 + (λ/Λ1)^(3/2))^(1/3),          Λ1 = 2.46 (1 + 3.8 μ*)
// f2 = 1 + λ²(ω̄₂/ω_log - 1) / (λ² + Λ2²),  Λ2 = 1.82 (1 + 6.3 μ*)(ω̄₂/ω_log)
//
// This is the strong-coupling (λ ≳ 1.5) form. f1 lifts the McMillan
// underestimate that plagues high-λ hydrides (CaH₆ λ≈4.4, h3o λ≈2.7);
// f2 is the spectral-shape correction (ω̄₂ = mean-square α²F frequency).
// Differs from `allen_dynes_tc` above ONLY in naming intent — this is the
// canonical 4-arg "full" entry the verify catalog registers (RTSC #1).
// Caller may pass omega2_K = omega_log_K → f2 = 1 (f1-only correction).
pub fn allen_dynes_full(lam: float, omega_log_K: float, omega2_K: float,
                        mu_star: float) -> float {
    let base = mcmillan_tc(omega_log_K, lam, mu_star)
    if base <= 0.0 { return 0.0 }
    if omega_log_K <= 0.0 { return 0.0 }
    // mcmillan_tc uses ω_log/1.45; Allen-Dynes kernel uses ω_log/1.2.
    // Rescale the base prefactor 1.45/1.2 to recover the AD kernel.
    let ad_base = base * (1.45 / 1.2)

    let r = omega2_K / omega_log_K
    let lambda1 = 2.46 * (1.0 + 3.8 * mu_star)
    let lambda2 = 1.82 * (1.0 + 6.3 * mu_star) * r

    let f1 = pow(1.0 + pow(lam / lambda1, 1.5), 1.0 / 3.0)
    let f2_num = (lam * lam) * (r - 1.0)
    let f2_den = (lam * lam) + (lambda2 * lambda2)
    let f2 = 1.0 + f2_num / f2_den

    return f1 * f2 * ad_base
}

// ── 4a-moments. Eliashberg moments from the α²F(ω) spectral function ────
//
// @cite Allen & Dynes 1975, PR B12 905 — moment definitions feeding the
//       f1·f2 Tc form above.  Carbotte 1990, RMP 62 1027 Eq.2.8 (λ).
//
//   λ      = 2 ∫ α²F(ω)/ω dω
//   ω_log  = exp[ (2/λ) ∫ (α²F(ω)/ω) ln ω  dω ]
//   ω̄₂     = sqrt[ (2/λ) ∫ α²F(ω) ω dω ]
//
// Collapses a sampled Eliashberg spectral function α²F(ω) into the three
// scalar moments the Allen-Dynes Tc form consumes — the α²F → (λ, ω_log,
// ω̄₂) → `allen_dynes_full` chain (RTSC #4; the V1 §E5 🟢→🔵 escalation
// prerequisite, replacing the hand-fed scalar moments). `omega` (the grid,
// each > 0 since the integrands carry 1/ω and ln ω) and `a2f` are
// equal-length samples; the integrals use the trapezoid rule over the grid.
// Returns [λ, ω_log, ω̄₂]; [-1, -1, -1] on malformed input (length mismatch,
// < 2 points, or a non-positive frequency); [0, 0, 0] when the spectrum
// integrates to λ ≤ 0 (empty / zero α²F).
pub fn eliashberg_moments_from_a2f(omega: [float], a2f: [float]) -> [float] {
    let n = len(omega)
    if n < 2 || len(a2f) != n {
        return [-1.0, -1.0, -1.0]
    }
    let mut int_lam = 0.0   // ∫ α²F/ω
    let mut int_log = 0.0   // ∫ (α²F/ω) ln ω
    let mut int_w2 = 0.0    // ∫ α²F·ω
    let mut k = 0
    while k < n - 1 {
        let w0 = omega[k]
        let w1 = omega[k + 1]
        if w0 <= 0.0 || w1 <= 0.0 {
            return [-1.0, -1.0, -1.0]
        }
        let dw = w1 - w0
        let g0 = a2f[k] / w0
        let g1 = a2f[k + 1] / w1
        int_lam = int_lam + 0.5 * (g0 + g1) * dw
        int_log = int_log + 0.5 * (g0 * log(w0) + g1 * log(w1)) * dw
        int_w2 = int_w2 + 0.5 * (a2f[k] * w0 + a2f[k + 1] * w1) * dw
        k = k + 1
    }
    let lam = 2.0 * int_lam
    if lam <= 0.0 {
        return [0.0, 0.0, 0.0]
    }
    let omega_log = exp((2.0 / lam) * int_log)
    let omega_bar2 = sqrt((2.0 / lam) * int_w2)
    return [lam, omega_log, omega_bar2]
}

// ── 4b. Morel-Anderson Coulomb pseudopotential μ* ──────────────────────
//
// @cite Morel & Anderson 1962, PR 125 1263 — logarithmic Coulomb
//       renormalisation of the screened repulsion.
//
// μ* = μ / (1 + μ · ln(E_F / ω_ph))
//
// Derives the retarded Coulomb pseudopotential μ* from the bare screened
// Coulomb parameter μ. The log factor is the Tolmachev-Morel-Anderson
// frequency-window renormalisation: phonon-mediated attraction acts only
// up to ω_ph while the Coulomb repulsion extends to E_F, so high-energy
// repulsion is logarithmically suppressed. Returns the canonical 0.10–0.16
// range for s/p/d metals (μ≈0.3, E_F/ω_ph≈100 → μ*≈0.126).
pub fn morel_anderson_mustar(mu_bare: float, e_fermi: float,
                             omega_ph: float) -> float {
    if mu_bare < 0.0 { return 0.0 }
    if e_fermi <= 0.0 { return 0.0 }
    if omega_ph <= 0.0 { return 0.0 }
    return mu_bare / (1.0 + mu_bare * log(e_fermi / omega_ph))
}

// ── 4c. Ginzburg-Landau coherence length from Hc2(0) ───────────────────
//
// @cite Tinkham 1996, "Introduction to Superconductivity" 2nd ed.,
//       Eq. 4.61 — Hc2(0) = Φ₀ / (2π ξ²)  inverted for ξ.
//
// ξ = sqrt( Φ₀ / (2π · Hc2(0)) ),   Φ₀ = h/2e = 2.067833848e-15 Wb
//
// The GL coherence length ξ (in metres) extracted from the measured (or
// WHH-predicted, see `whh_hc2_zero`) zero-temperature upper critical
// field Hc2(0) in tesla. Φ₀ is the superconducting flux quantum (2018
// CODATA). Closes RTSC §8 device-side ξ gap (whh gave only Hc2).
pub fn coherence_length(hc2_zero_T: float) -> float {
    if hc2_zero_T <= 0.0 { return 0.0 }
    let phi0 = 2.067833848e-15        // flux quantum h/2e (Wb), CODATA 2018
    let two_pi = 6.28318530717958647692
    return sqrt(phi0 / (two_pi * hc2_zero_T))
}

// ── 4d. BCS isotope-effect exponent α ──────────────────────────────────
//
// @cite Maxwell 1950, PR 78 477 + Reynolds et al. 1950, PR 78 487
//       (isotope effect); BCS 1957, PR 108 1175 predicts α = 1/2.
//
// α = - ln(Tc₂ / Tc₁) / ln(M₂ / M₁)     (Tc ∝ M^(-α))
//
// Two-point power-law fit of the isotope exponent from a pair of
// (mass, Tc) measurements on isotopically substituted samples. BCS
// weak-coupling predicts α = 0.5 (Tc ∝ ω_D ∝ M^(-1/2)); deviations
// diagnose μ* renormalisation or anharmonicity. Returns the exponent α.
pub fn isotope_exponent(mass1: float, tc1: float,
                        mass2: float, tc2: float) -> float {
    if mass1 <= 0.0 { return 0.0 }
    if mass2 <= 0.0 { return 0.0 }
    if tc1 <= 0.0 { return 0.0 }
    if tc2 <= 0.0 { return 0.0 }
    let dln_m = log(mass2 / mass1)
    if dln_m == 0.0 { return 0.0 }   // equal masses → exponent undefined
    return -(log(tc2 / tc1)) / dln_m
}

// ── 4e. Ginzburg-Landau parameter κ (Type-I/II discriminant) ───────────
//
// @cite Ginzburg & Landau 1950, ZhETF 20 1064; Abrikosov 1957,
//       ZhETF 32 1442 — κ = 1/√2 separates Type-I from Type-II.
//
// κ = λ_L / ξ
//
// The dimensionless GL parameter: ratio of magnetic penetration depth
// λ_L to coherence length ξ (same length units; ratio is unit-invariant).
// κ < 1/√2 ≈ 0.707 → Type-I (positive wall energy, full Meissner);
// κ > 1/√2 → Type-II (negative wall energy, Abrikosov vortex lattice).
pub fn gl_parameter_kappa(lambda_L: float, xi: float) -> float {
    if xi <= 0.0 { return 0.0 }
    if lambda_L < 0.0 { return 0.0 }
    return lambda_L / xi
}

// ── 4f. London magnetic penetration depth from superfluid density ──────
//
// @cite London & London 1935, Proc. R. Soc. A 149 71; Tinkham 1996,
//       "Introduction to Superconductivity" 2nd ed., Eq. 3.10.
//
// λ_L = sqrt( m_e / (μ₀ · n_s · e²) )
//
// The London penetration depth λ_L (metres): the length over which a
// magnetic field decays inside a superconductor (Meissner screening). n_s
// is the superfluid carrier density (m⁻³). Constants are CODATA 2018:
// m_e (electron mass), μ₀ (vacuum permeability), e (elementary charge).
// For a typical metal n_s ≈ 1e28 m⁻³ → λ_L ≈ 53 nm. Pairs with
// `coherence_length` to feed `gl_parameter_kappa` (κ = λ_L/ξ).
pub fn london_penetration_depth(n_s: float) -> float {
    if n_s <= 0.0 { return 0.0 }
    let m_e = 9.1093837015e-31        // electron mass (kg), CODATA 2018
    let mu0 = 1.25663706212e-6        // vacuum permeability (N/A²), CODATA 2018
    let e_q = 1.602176634e-19         // elementary charge (C), CODATA 2018
    return sqrt(m_e / (mu0 * n_s * e_q * e_q))
}

// ── 4g. Thermodynamic critical field Hc(T) — Tuyn parabolic law ────────
//
// @cite Tuyn 1929 (parabolic law); Tinkham 1996, "Introduction to
//       Superconductivity" 2nd ed., Eq. 1.1.
//
// Hc(T) = Hc(0) · (1 - (T/Tc)²)
//
// The thermodynamic critical field at temperature T, from its zero-T value
// Hc(0) and the critical temperature Tc (same temperature units). The
// two-fluid / Tuyn parabolic approximation; exact at T→0 and T→Tc, ~4%
// high mid-range vs the BCS curve. Returns 0 for T ≥ Tc (normal state).
pub fn thermo_critical_field(hc_zero: float, temp_K: float, tc_K: float) -> float {
    if tc_K <= 0.0 { return 0.0 }
    if temp_K >= tc_K { return 0.0 }
    if temp_K < 0.0 { return 0.0 }
    let r = temp_K / tc_K
    return hc_zero * (1.0 - r * r)
}

// ── 4h. Superconducting condensation energy density ────────────────────
//
// @cite Tinkham 1996, "Introduction to Superconductivity" 2nd ed.,
//       Eq. 3.4 — f_n - f_s(0) = Bc²/(2μ₀)  (SI flux-density form).
//
// U = Bc(0)² / (2 · μ₀)
//
// Condensation energy density (J/m³): the free-energy gain per unit volume
// of the superconducting state relative to the normal state, expressed via
// the zero-T thermodynamic critical flux density Bc(0) (tesla). μ₀ is the
// vacuum permeability (CODATA 2018). Bc=1 T → U ≈ 3.98e5 J/m³.
pub fn condensation_energy(bc_zero_T: float) -> float {
    let mu0 = 1.25663706212e-6        // vacuum permeability (N/A²), CODATA 2018
    return bc_zero_T * bc_zero_T / (2.0 * mu0)
}

// ── 4i. BCS zero-temperature energy gap Δ(0) ───────────────────────────
//
// @cite Bardeen, Cooper, Schrieffer 1957, PR 108 1175 — universal
//       weak-coupling gap Δ(0) = (π/e^γ)·k_B·Tc = 1.764·k_B·Tc.
//
// Δ(0) = 1.764 · k_B · Tc
//
// The zero-temperature superconducting energy gap (joules) in the BCS
// weak-coupling limit, where 2Δ(0)/(k_B·Tc) = 3.528 = 2π/e^γ (see
// `bcs_gap_ratio`). k_B is Boltzmann's constant (CODATA 2018). The 1.764
// prefactor is half the universal ratio. Strong-coupling materials exceed
// this (H₃S ≈ 2.4); the deviation diagnoses coupling strength.
pub fn bcs_gap_zero(tc_K: float) -> float {
    if tc_K <= 0.0 { return 0.0 }
    let k_b = 1.380649e-23            // Boltzmann constant (J/K), CODATA 2018
    return 1.764 * k_b * tc_K
}

// ── 4j. Pippard / BCS intrinsic coherence length ξ₀ ────────────────────
//
// @cite Pippard 1953, Proc. R. Soc. A 216 547; BCS 1957, PR 108 1175;
//       Tinkham 1996 Eq. 1.7 — ξ₀ = ħ·v_F / (π·Δ(0)).
//
// ξ₀ = ħ · v_F / (π · Δ(0)),   Δ(0) = 1.764 · k_B · Tc
//
// The intrinsic (clean-limit) coherence length ξ₀ (metres): the spatial
// extent of a Cooper pair, set by the Fermi velocity v_F (m/s) and the
// zero-T gap. Constants are CODATA 2018 (ħ reduced Planck, k_B Boltzmann).
// Distinct from the GL `coherence_length` (Hc2-derived); ξ₀ is the
// microscopic BCS pair size. v_F=1e6 m/s, Tc=10 K → ξ₀ ≈ 138 nm.
pub fn pippard_coherence(v_fermi: float, tc_K: float) -> float {
    if v_fermi <= 0.0 { return 0.0 }
    if tc_K <= 0.0 { return 0.0 }
    let hbar = 1.054571817e-34        // reduced Planck (J·s), CODATA 2018
    let k_b = 1.380649e-23            // Boltzmann constant (J/K), CODATA 2018
    let pi_p = 3.14159265358979323846
    let gap0 = 1.764 * k_b * tc_K
    return hbar * v_fermi / (pi_p * gap0)
}

// ── 4k. Anharmonic λ-suppression ratio (stability↔coupling wall) ───────
//
// NOVEL closed-form quantifier of the binary-hydride stability↔coupling
// trade-off. The McMillan-Hopfield coupling is
//
//   λ = N(Ef)·⟨I²⟩ / (M·⟨ω²⟩) = η / (M·⟨ω²⟩)
//
// where the Hopfield parameter η = N(Ef)⟨I²⟩ is chemistry-fixed and
// UNCHANGED by anharmonic (SSCHA) re-quantisation — only the mean-square
// phonon frequency ⟨ω²⟩ moves. The SAME ⟨ω²⟩ governs BOTH λ (denominator)
// AND dynamical stability (⟨ω²⟩>0 required). A soft harmonic mode
// (⟨ω²⟩_harm→0⁺) inflates λ_harm while ⟨ω²⟩_harm<0 IS the instability.
// SSCHA hardens by a positive curvature Δω²: ⟨ω²⟩_anharm = ⟨ω²⟩_harm+Δω².
// Because η cancels in the ratio,
//
//   S = λ_anharm/λ_harm = ⟨ω²⟩_harm / (⟨ω²⟩_harm + Δω²)   (0 < S ≤ 1)
//
// is the anharmonic λ-suppression ratio. S→1 = no hardening (no
// suppression); S→0 = full hardening (λ enhancement destroyed). Returns
// 0.0 when ⟨ω²⟩_harm ≤ 0 (soft/unstable harmonic mode: λ_harm ill-defined)
// or when the stabilised stiffness stays ≤ 0.
//
// @cite Migdal 1958 JETP 7:996 · McMillan 1968 PR 167:331 · Hopfield 1969
//       PRB 186:443 · Allen-Dynes 1975 PRB 12:905 · Errea-Calandra-Mauri
//       2014 PRL 111:177002 (SSCHA anharmonic hydride).
// Anchor: h3o N5 hydride λ_harm=2.479 (16/16 q imaginary) → λ_anharm≈1.00;
//       ⟨ω²⟩_harm=1.0, Δω²=1.479 → S=0.403388463090, λ_harm·S=1.000.
pub fn lambda_anharm_suppress(omega2_harm: float, delta_omega2: float) -> float {
    if omega2_harm <= 0.0 { return 0.0 }
    let omega2_anharm = omega2_harm + delta_omega2
    if omega2_anharm <= 0.0 { return 0.0 }
    return omega2_harm / omega2_anharm
}

// ── 4l. Stability-coupling margin (cation-clathrate escape discriminant) ─
//
// NOVEL single-number discriminant of whether a phonon-mediated material is
// TRAPPED in the stability↔coupling trade-off (binary hydrides) or ESCAPES
// it (cation-stuffed ternary clathrates, e.g. CaH₆). The anharmonically-
// stabilised stiffness ⟨ω²⟩_anharm (>0 for stability) must also be soft
// enough to deliver the target coupling λ_target = η/(M·⟨ω²⟩). The
// stiffness that yields λ_target is ⟨ω²⟩_λ = η/(M·λ_target). The signed
// fractional headroom is
//
//   m = (⟨ω²⟩_anharm − ⟨ω²⟩_λ) / ⟨ω²⟩_anharm
//
// m > 0 ⇒ the STABLE lattice is already stiffer than the coupling target
// requires → stability and strong-λ are COMPATIBLE (escape; the cation
// chemically pre-compresses the H sublattice, raising ⟨ω²⟩_anharm while
// N(Ef) stays H-derived). m < 0 ⇒ hitting λ_target needs a softer lattice
// than the stable one → TRAPPED. m = 0 = exactly on the wall. Returns 0.0
// on unstable (⟨ω²⟩_anharm ≤ 0) or unphysical (⟨ω²⟩_λ < 0) input.
//
// @cite Hopfield 1969 PRB 186:443 · Wang et al. 2012 PNAS / Ma et al. 2022
//       (CaH₆ clathrate, 215 K) · Errea et al. 2014 PRL 111:177002.
// Anchor: CaH₆ escape ⟨ω²⟩_anharm=1.0, ⟨ω²⟩_λ=0.5 → m=0.5>0; h3o trapped
//       ⟨ω²⟩_anharm=1.0, ⟨ω²⟩_λ=2.479 → m=−1.479<0.
pub fn stability_coupling_margin(omega2_anharm: float, omega2_lambda: float) -> float {
    if omega2_anharm <= 0.0 { return 0.0 }
    if omega2_lambda < 0.0 { return 0.0 }
    return (omega2_anharm - omega2_lambda) / omega2_anharm
}

// ── 5. inverse-variance consensus + σ-from-spread ──────────────────────
//
// Ported from cross_code_dft.py `_compute_consensus` (Phase 4 cohort #1,
// RTSC.md §9.9.1). Pattern matches Nb attestation inverse-variance
// consensus (PAPERS/sample-nb-bcs-absorbed/main.tex §4).
//
// Honest scope (R4 invariant carried over per RTSC.md §9.9.1 Phase 4):
//   This kernel returns NUMBERS only. The Python orchestrator
//   (cross_code_dft.py) decides `absorbed` / `gate_type` / source-name
//   exclusion (e.g. `hexa_rtsc` filter is policy, not math — kept in the
//   Python caller). Port the math; leave the gate_type policy upstream.

struct Consensus {
    mean:                  float,
    combined_sigma:        float,
    n_sources:             int,
    rel_err_max_pairwise:  float,
}

// σ-from-spread helper: when multiple polymorph / poll values are
// available, use their *unbiased sample stdev* (n-1 Bessel correction —
// matches cross_code_dft.py:139-144, 274-279, 338-343 verbatim) but never
// fall below `sigma_default`. Returns `sigma_default` for n < 2 (a single
// value has no spread information).
//
// Formula (cross_code_dft.py:141-142 etc., literal):
//   mean  = Σx / n
//   var   = Σ(x - mean)² / (n - 1)
//   sigma = max(√var, sigma_default)
pub fn sigma_from_spread(values: [float], sigma_default: float) -> float {
    let n = len(values)
    if n < 2 { return sigma_default }
    let nf = to_float(n)
    let mut sum: float = 0.0
    let mut i = 0
    while i < n {
        sum = sum + values[i]
        i = i + 1
    }
    let mean = sum / nf
    let mut sq: float = 0.0
    let mut j = 0
    while j < n {
        let d = values[j] - mean
        sq = sq + d * d
        j = j + 1
    }
    let variance = sq / (nf - 1.0)
    let spread = sqrt(variance)
    return _fmax(spread, sigma_default)
}

// inverse_variance_consensus — main entry, mirrors
// cross_code_dft.py:468-509 verbatim arithmetic.
//
// Inputs:
//   values: parallel list of source readings (floats)
//   sigmas: parallel list of source 1σ uncertainties (floats, > 0
//           expected by the math; the caller is responsible for
//           filtering σ ≤ 0 rows before the call — matches Python R4
//           policy)
//
// Edge cases (mirror Python):
//   n=0 → mean=0, combined_sigma=0, n_sources=0, rel_err_max_pairwise=0
//   n=1 → mean=values[0], combined_sigma=sigmas[0],
//          n_sources=1, rel_err_max_pairwise=0
//   n≥2 → wᵢ = 1/σᵢ², mean = Σwᵢxᵢ/Σwᵢ, combined σ = 1/√Σwᵢ,
//          rel_err_max_pairwise = max over (i,j) of
//          |xᵢ−xⱼ| / max(|xᵢ|, |xⱼ|, 1e-12).
//
// NOTE on n<2: Python `_compute_consensus` returns `None` in this case;
// the hexa-native version returns a sentinel Consensus struct (caller
// can detect via `n_sources < 2`). This is the documented divergence —
// hexa-lang does not have a clean `Option` story in v0.2.0, so we
// surface the count instead. Numeric semantics for n≥2 are identical.
pub fn inverse_variance_consensus(values: [float],
                                  sigmas: [float]) -> Consensus {
    let n = len(values)
    if n == 0 {
        return Consensus { mean: 0.0, combined_sigma: 0.0,
                           n_sources: 0, rel_err_max_pairwise: 0.0 }
    }
    if n == 1 {
        return Consensus { mean: values[0], combined_sigma: sigmas[0],
                           n_sources: 1, rel_err_max_pairwise: 0.0 }
    }
    // n ≥ 2: full inverse-variance combination.
    let mut w_total:  float = 0.0
    let mut wx_total: float = 0.0
    let mut i = 0
    while i < n {
        let s = sigmas[i]
        let w = 1.0 / (s * s)
        w_total  = w_total  + w
        wx_total = wx_total + w * values[i]
        i = i + 1
    }
    let mean   = wx_total / w_total
    let csigma = 1.0 / sqrt(w_total)

    // Pairwise max relative error — matches cross_code_dft.py:496-502.
    // denom = max(|xᵢ|, |xⱼ|, 1e-12)  to keep zero-valued comparisons
    // bounded (avoids div-by-zero on the v=[0.0, 0.0] sample).
    let mut rel_err_max: float = 0.0
    let mut a = 0
    while a < n {
        let mut b = a + 1
        while b < n {
            let denom = _fmax(_fmax(_fabs(values[a]), _fabs(values[b])),
                              1.0e-12)
            let rel = _fabs(values[a] - values[b]) / denom
            if rel > rel_err_max { rel_err_max = rel }
            b = b + 1
        }
        a = a + 1
    }
    return Consensus { mean: mean, combined_sigma: csigma,
                       n_sources: n, rel_err_max_pairwise: rel_err_max }
}

// ── reference-panel runner ─────────────────────────────────────────────
//
// Nb reference panel + claim-only RT-SC negative anchor — mirrors
// sim_adapter.py DEFAULTS table so cross-validation is a textual diff away.
//
// Sources:
//   - Nb λ=0.82, μ*=0.13, ω_log≈262 K, Θ_D=275 K: Allen & Dynes 1975 PRB 12
//     905, Table I (Nb row). dHc2/dT|_Tc ≈ -0.5 T/K is a representative
//     Nb-alloy slope (reference panel for the formula path, NOT a sourced
//     Nb single-crystal sample).
//   - CSH (carbonaceous sulfur hydride) — Snider et al. Nature 586:373
//     (2020), arxiv:2010.07320; **retracted** Nature 610:804 (2022);
//     susceptibility re-analysis Hirsch Physica C 601:1354118 (2022). The
//     canonical failed RT-SC anchor used in this repo (Nature-published,
//     formally retracted → strongest available negative reference). INPUT
//     PARAMS for the claim-only row below are illustrative ranges ONLY;
//     they are NOT a consensus first-principles derivation. Claim-only.

fn _emit_row(family: string, claim_only: bool,
             theta_d: float, w_log: float,
             lam_full: float, lam_bcs: float, mu_star: float,
             slope: float) {
    let bcs = bcs_weak_tc(theta_d, lam_bcs)
    let mcm = mcmillan_tc(w_log, lam_full, mu_star)
    // omega2 ≈ omega_log first-cut → f2 collapses to 1.0
    let ad = allen_dynes_tc(w_log, lam_full, mu_star, w_log)
    let whh = whh_hc2_zero(ad, slope)

    let mut flag = ""
    if claim_only { flag = " [CLAIM-ONLY]" }

    println("  · " + family + flag + ": " +
            "BCS_weak=" + to_string(bcs) + " K  " +
            "McMillan=" + to_string(mcm) + " K  " +
            "AllenDynes=" + to_string(ad) + " K  " +
            "Hc2(0)_WHH=" + to_string(whh) + " T")
}

fn main() {
    println("[material+verify] sim.hexa — RTSC.md §8.7 Tier 1 (hexa-native)")

    // Nb reference panel
    _emit_row("Nb", false,
              275.0,    // Theta_D (K)
              262.0,    // omega_log (K)
              0.82,     // lambda_full  (McMillan / Allen-Dynes input)
              0.32,     // lambda_bcs_weak (BCS-regime reduction)
              0.13,     // mu_star
              0.5)      // |dHc2/dT|_Tc (T/K)

    // claim-only RT-SC row — params NOT measured, illustrative only
    // (CSH, Snider 2020 Nature, retracted 2022 — canonical negative anchor)
    _emit_row("claim-only RT-SC (hypothetical)", true,
              500.0,    // Theta_D (K) — rough Debye estimate
              400.0,    // omega_log (K) — claim-only
              1.50,     // lambda_full — claim-only (huge for RT Tc)
              0.40,     // lambda_bcs_weak — claim-only
              0.13,     // mu_star
              1.0)      // |dHc2/dT|_Tc — claim-only, never measured cleanly

    println("[material+verify] absorbed=false (Tier 1 prediction; " +
            "RTSC.md §8.7 honest 한계 — NEVER promote to absorbed=true " +
            "without Tier 3 measurement + Tier 4 dispatch)")

    // ── Phase 4 cohort #1 — consensus kernel smoke ─────────────────────
    // Nb-style: two equal-valued sources with identical σ → combined σ
    // collapses to σ/√2 (textbook inverse-variance result).
    let v_nb: [float] = [0.0, 0.0]
    let s_nb: [float] = [0.05, 0.05]
    let c_nb = inverse_variance_consensus(v_nb, s_nb)
    println("[consensus] Nb-style n=2 equal: mean=" + to_string(c_nb.mean) +
            " combined_sigma=" + to_string(c_nb.combined_sigma) +
            " n_sources=" + to_string(c_nb.n_sources) +
            " rel_err_max=" + to_string(c_nb.rel_err_max_pairwise))

    // ── scope_caveats (verbatim from sim_adapter.py, s1–s4) ────────────
    println("[scope] (s1) BCS-like effective-coupling assumed throughout " +
            "— NOT a full Eliashberg self-consistent Migdal-Eliashberg " +
            "integral solve. The α²F(ω) spectral function is collapsed to " +
            "scalar moments (λ, ω_log, ω₂) per McMillan / Allen-Dynes; " +
            "off-Fermi-surface vertex corrections and frequency-dependent " +
            "self-energy are absent.")
    println("[scope] (s2) μ* (Coulomb pseudopotential, Morel-Anderson) is " +
            "empirical, NOT first-principles. Standard value 0.10–0.16 is " +
            "fit to the s/p/d metal family it came from; using μ*=0.13 for " +
            "a hypothetical novel lattice (claim-only RT-SC) is itself a " +
            "claim, not a derivation.")
    println("[scope] (s3) Input params for unproven families (claim-only " +
            "RT-SC) are CLAIM-ONLY — the Θ_D / ω_log / λ values have no " +
            "reproduced first-principles consensus and the experimental " +
            "Tc has not been replicated by independent labs. Marked " +
            "claim_only=true. Canonical negative anchor in this repo: " +
            "CSH (Snider 2020 Nature, retracted Nature 610:804 2022).")
    println("[scope] (s4) Tier 1 is *prediction*, NEVER *measurement*. " +
            "absorbed=false is permanent for this record-kind per RTSC.md " +
