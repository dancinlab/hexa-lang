// HEXA Standard Library — mlff (science stack)
//
// hexa-native absorption of the machine-learned force-field family:
// CHGNet (BSD), MACE (MIT), M3GNet / MatGL (BSD), ALIGNN (NIST), SchNet
// (MIT). A unified universal-FF interface — relax a structure, predict
// energy / forces / magnetic moments — for hexa-matter's NOVEL candidate
// deepening pipeline.
//
// Status: STAGE-1 — MlffResult container + constructor + pure-stdlib
// accessors landed. Stage-2 (the actual NNP inference graphs on stdlib
// `grad` with pre-trained weights) still pending; mlff_load / predict /
// relax bodies are inherently Stage-2.
//
// ── Migration plan ──────────────────────────────────────────────────
//   Stage 1 (DONE here): MlffResult struct + mlff_result_new +
//     mlff_e_per_atom + mlff_forces + mlff_magmoms + mlff_relaxed —
//     the result surface hexa-matter `universal_ff_runner.py` and the
//     per-model adapters consume. Inference itself is Stage-2.
//   Stage 2 (dependency hexa-native port): the NNP inference graphs run
//     on stdlib `grad` (autograd + nn); pre-trained weights via
//     `safetensors`; message-passing GNN kernels get hexa-native impls.
//
// ── Public API ──────────────────────────────────────────────────────
//   pub struct MlffResult   — e_per_atom : float, forces : [[float;3]],
//                             magmoms : [float], relaxed : any (Structure)
//   pub fn mlff_result_new(e_per_atom, forces, magmoms, relaxed)
//   pub fn mlff_e_per_atom(r) -> float
//   pub fn mlff_forces(r) -> [[float;3]]
//   pub fn mlff_magmoms(r) -> [float]
//   pub fn mlff_relaxed(r) -> any
//   pub fn mlff_load(model) -> ...        (Stage 2 — NNP weights)
//   pub fn mlff_predict(model, structure) -> MlffResult   (Stage 2)
//   pub fn mlff_relax(model, structure)   -> MlffResult   (Stage 2)
//
// ── Dependencies (hexa stdlib) ──────────────────────────────────────
//   (Stage 1 dependency-free — value container only. grad/ tensor/
//    safetensors/ crystal/ atoms/ enter at Stage 2.)
//
// Absorbs: chgnet, mace, m3gnet/matgl, alignn, schnetpack
// Used by: hexa-matter   Sibling: crystal, atoms, grad
// Honesty: NNP outputs are PREDICTIONS (SIM-NNP), never measurements.
// Cross-link: .roadmap.stdlib (science-stack subdomains)

pub struct MlffResult {
    e_per_atom: any, // float        — predicted energy per atom (eV)
    forces: any,     // [[float;3]]  — per-atom force vectors (eV/Å)
    magmoms: any,    // [float]      — per-atom magnetic moments (μB)
    relaxed: any     // Structure    — relaxed structure (or input)
}

pub fn mlff_result_new(e_per_atom: any, forces: any, magmoms: any, relaxed: any) -> MlffResult {
    return MlffResult { e_per_atom: e_per_atom, forces: forces, magmoms: magmoms, relaxed: relaxed }
}

pub fn mlff_e_per_atom(r: MlffResult) -> float {
    return r.e_per_atom
}

pub fn mlff_forces(r: MlffResult) -> any {
    return r.forces
}

pub fn mlff_magmoms(r: MlffResult) -> any {
    return r.magmoms
}

pub fn mlff_relaxed(r: MlffResult) -> any {
    return r.relaxed
}

pub fn mlff_status() -> str {
    return "STAGE-1 — MlffResult container + mlff_result_new/e_per_atom/forces/magmoms/relaxed (absorbs: chgnet/mace/m3gnet/alignn/schnet; NNP inference Stage-2)"
}
