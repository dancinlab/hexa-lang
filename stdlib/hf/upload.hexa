// HEXA Standard Library — hf/upload
//
// @version 0.1.0
// @capabilities [cli]
//
// Canonical HuggingFace upload wrapper, absorbed into hexa-lang as the
// `hexa hf <flags>` first-class verb (sibling of `hexa dojo`). Validates
// README + repo naming, walks files via shell `find`, computes sha256 via
// the stdlib FIPS 180-4 builtin, and shells out to the `hf` CLI
// (huggingface_hub v1.8.0+: `hf repo create --exist-ok`, `hf upload`,
// `hf repo tag create`) for the network work. Writes an audit log + ledger
// under $HOME/.hexa/hf_upload_audit/. PURE hexa — zero .py.
//
// Origin: ported as-is from anima tool/hf_upload_mk2.hexa v2.2.0 (pure-hexa,
// raw#9 STRICT). The validator logic, token resolution, upload steps, and
// audit payload structure are preserved byte-equivalent; only anima-specific
// hardcoded paths/sentinels were generalized to $HOME-based defaults (with
// env overrides) — zero behavior change to the upload/validation contract.
//
// raw#9 STRICT: network work is done via the `hf` CLI (not a python bridge).
// sha256 via the stdlib builtin, file walk via /usr/bin/find. ZERO .py.
//
// raw#10 honest caveats:
//   - HF rate-limit (HTTP 429) is handled by `hf` CLI internals (not by this
//     wrapper); backoff coordination across concurrent uploads is NOT
//     guaranteed.
//   - The CLI surface is text + exit code, so granular error classes are
//     flattened into the CLI stdout/stderr capture. Audit log captures the
//     full CLI output; programmatic error-class branching is reduced.
//
// Token handling (ps-invisible, file-backed HF_HOME — NOT --token argv,
// NOT an inline HF_TOKEN= prefix; both of those are ps-visible). The token
// value never lands in argv, in the `sh -c` command string, or in `ps`.
//
// Subverbs (flag interface preserved verbatim from mk2):
//   hf --selftest
//   hf --dry-run --repo <org/name> --ckpt <path> --readme <path> [--tag <s>]
//   hf --upload  --repo <org/name> --ckpt <path> --readme <path> [--tag <s>] [--private]
//   hf --validate-readme <path>
//   hf --validate-naming <org/name>
//   hf --help

let VERSION = "0.1.0"
let HOME = exec("echo \"$HOME\"").trim()

// Audit dir / ledger default under $HOME/.hexa (generalized from anima's
// state/hf_upload_audit). Overridable via env for callers that want a
// project-local audit trail (e.g. anima can set HF_UPLOAD_AUDIT_DIR).
fn _audit_dir() -> str {
    let ov = exec("echo \"$HF_UPLOAD_AUDIT_DIR\"").trim()
    if ov.len() > 0 { return ov }
    return HOME + "/.hexa/hf_upload_audit"
}

fn _ledger_path() -> str {
    let ov = exec("echo \"$HF_UPLOAD_LEDGER\"").trim()
    if ov.len() > 0 { return ov }
    return _audit_dir() + "/hf_upload_ledger.jsonl"
}

// `hf` CLI resolution — prefer override, else PATH lookup. v1.8.0+ required
// for `hf repo tag create` coverage. Accepts HF_CLI (general) or
// ANIMA_HF_CLI (back-compat) as the override env.
fn _hf_cli() -> str {
    let override = exec("echo \"$HF_CLI\"").trim()
    if override.len() > 0 { return override }
    let legacy = exec("echo \"$ANIMA_HF_CLI\"").trim()
    if legacy.len() > 0 { return legacy }
    let cli = exec("command -v hf 2>/dev/null").trim()
    if cli.len() > 0 { return cli }
    return "hf"
}

// ─── arg parsing ───────────────────────────────────────────────────────

fn _arg_get(argv: [str], flag: str) -> str {
    let mut i = 0
    while i < argv.len() {
        if argv[i] == flag {
            if i + 1 < argv.len() { return argv[i + 1] }
            return ""
        }
        i = i + 1
    }
    return ""
}

fn _arg_has(argv: [str], flag: str) -> int {
    let mut i = 0
    while i < argv.len() {
        if argv[i] == flag { return 1 }
        i = i + 1
    }
    return 0
}

// ─── README validation ─────────────────────────────────────────────────
// 5 required H2 headings (mk2 spec § README enforcement)

fn _readme_required_headings() -> [str] {
    return ["## Origin", "## Falsifiers", "## Substrate", "## Caveats", "## Composability"]
}

fn _readme_validate(readme_path: str) -> str {
    if !file_exists(readme_path) {
        return "FAIL: README not found at " + readme_path
    }
    let content = read_file(readme_path)
    let required = _readme_required_headings()
    let mut missing = []
    let mut i = 0
    while i < required.len() {
        let h = required[i]
        // Match on a line boundary: heading must appear with newline before+after
        // (or at file start). Approximation: substring contains.
        if !content.contains("\n" + h + "\n") && !content.starts_with(h + "\n") {
            missing = missing.push(h)
        }
        i = i + 1
    }
    if missing.len() > 0 {
        let mut msg = "FAIL: README missing required H2 headings:"
        let mut j = 0
        while j < missing.len() {
            msg = msg + " [" + missing[j] + "]"
            j = j + 1
        }
        msg = msg + " (5 required H2: Origin · Falsifiers · Substrate · Caveats · Composability)"
        return msg
    }
    // Caveats section must have at least 3 bullet items (raw#10 enforcement)
    let cav_idx = content.index_of("## Caveats")
    if cav_idx >= 0 {
        let after = content.substring(cav_idx, content.len())
        let next_h2 = after.index_of("\n## ")
        let block_end = if next_h2 > 0 { cav_idx + next_h2 } else { content.len() }
        let block = content.substring(cav_idx, block_end)
        let mut bullets = 0
        let lines = block.split("\n")
        let mut k = 0
        while k < lines.len() {
            let ln = lines[k].trim()
            if ln.starts_with("- ") || ln.starts_with("* ") { bullets = bullets + 1 }
            k = k + 1
        }
        if bullets < 3 {
            return "FAIL: Caveats section has " + str(bullets) + " bullets (mk2 requires >=3 honest caveats per raw#10)"
        }
    }
    return "OK"
}

// ─── Naming validation (mk2 convention) ────────────────────────────────
// Format: <org>/<family>-<version>-<stage>[-<modifier>]
//   org      = lowercase alnum + dash, 2-32 chars
//   family   = clm | alm | blm | vlm | slm | tlm | nlm | mlm | llm | hexad | composite
//   version  = v1 | v2 | v3 | v4 | v<N>
//   stage    = sft-stage<N> | dpo | merged | base | preview | dev | paradigm-<letter>
//   modifier = optional, lowercase alnum + dash

fn _naming_allowed_families() -> [str] {
    return ["clm", "alm", "blm", "vlm", "slm", "tlm", "nlm", "mlm", "llm", "hexad", "composite"]
}

fn _naming_allowed_stage_prefixes() -> [str] {
    return ["sft-stage", "dpo", "merged", "base", "preview", "dev", "paradigm-"]
}

// §3.7 grace-period fallback: admits the legacy `mk\d+-v\d+` variant form
// until 2026-06-02. Additive — only runs after the strict enum check fails.
fn _grace_period_active() -> int {
    // ISO8601 string compare suffices for date-only comparison.
    let today = exec("date -u +%Y-%m-%d").trim()
    let cutoff = "2026-06-02"
    if today.len() == 10 && today <= cutoff { return 1 }
    return 0
}

fn _is_digit(c: str) -> int {
    if c.len() != 1 { return 0 }
    if c >= "0" && c <= "9" { return 1 }
    return 0
}

fn _matches_legacy_variant(stage_join: str) -> int {
    // §3.7 legacy variant form: `mk\d+-v\d+` (e.g. mk1-v0, mk2-v1, mk3-v12).
    let n = stage_join.len()
    if n < 6 { return 0 }  // minimum "mk0-v0" = 6 chars; no shorter form valid
    let parts = stage_join.split("-")
    if parts.len() != 2 { return 0 }
    let lhs = parts[0]
    let rhs = parts[1]
    // lhs = "mk" + >=1 digits
    if lhs.len() < 3 { return 0 }
    if lhs.substring(0, 2) != "mk" { return 0 }
    let mut i = 2
    while i < lhs.len() {
        if _is_digit(lhs.substring(i, i + 1)) != 1 { return 0 }
        i = i + 1
    }
    // rhs = "v" + >=1 digits
    if rhs.len() < 2 { return 0 }
    if rhs.substring(0, 1) != "v" { return 0 }
    let mut j = 1
    while j < rhs.len() {
        if _is_digit(rhs.substring(j, j + 1)) != 1 { return 0 }
        j = j + 1
    }
    return 1
}

fn _is_lower_alnum_dash(s: str) -> int {
    if s.len() == 0 { return 0 }
    let mut i = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        let ok = (c >= "a" && c <= "z") || (c >= "0" && c <= "9") || c == "-"
        if !ok { return 0 }
        i = i + 1
    }
    return 1
}

fn _naming_validate(repo: str) -> str {
    if !repo.contains("/") {
        return "FAIL: repo must be <org>/<name> form (got: " + repo + ")"
    }
    let parts = repo.split("/")
    if parts.len() != 2 {
        return "FAIL: repo must have exactly one '/' (got: " + repo + ")"
    }
    let org = parts[0]
    let name = parts[1]
    if org.len() < 2 || org.len() > 32 {
        return "FAIL: org must be 2-32 chars (got: '" + org + "' len=" + str(org.len()) + ")"
    }
    if _is_lower_alnum_dash(org) != 1 {
        return "FAIL: org must be lowercase alnum+dash (got: '" + org + "')"
    }
    if _is_lower_alnum_dash(name) != 1 {
        return "FAIL: name must be lowercase alnum+dash (got: '" + name + "')"
    }
    let name_parts = name.split("-")
    if name_parts.len() < 3 {
        return "FAIL: name must be <family>-<version>-<stage>[-<mod>] (got: '" + name + "')"
    }
    let family = name_parts[0]
    let families = _naming_allowed_families()
    let mut fam_ok = 0
    let mut fi = 0
    while fi < families.len() {
        if families[fi] == family { fam_ok = 1 }
        fi = fi + 1
    }
    if fam_ok != 1 {
        let mut fams = ""
        let mut fj = 0
        while fj < families.len() {
            if fj > 0 { fams = fams + "|" }
            fams = fams + families[fj]
            fj = fj + 1
        }
        return "FAIL: family must be one of {" + fams + "} (got: '" + family + "')"
    }
    let version = name_parts[1]
    if !version.starts_with("v") || version.len() < 2 {
        return "FAIL: version must be 'v<N>' (got: '" + version + "')"
    }
    // Stage spans parts[2..N]: stage tokens may contain dashes (e.g., "sft-stage1").
    let mut stage_join = ""
    let mut sp_i = 2
    while sp_i < name_parts.len() {
        if sp_i > 2 { stage_join = stage_join + "-" }
        stage_join = stage_join + name_parts[sp_i]
        sp_i = sp_i + 1
    }
    let stages = _naming_allowed_stage_prefixes()
    let mut st_ok = 0
    let mut si = 0
    while si < stages.len() {
        let sp = stages[si]
        if stage_join == sp || stage_join.starts_with(sp) { st_ok = 1 }
        si = si + 1
    }
    if st_ok != 1 {
        // §3.7 grace-period fallback (additive; strict enum runs first verbatim).
        if _grace_period_active() == 1 && _matches_legacy_variant(stage_join) == 1 {
            println("WARN: §3.7 grace-period: legacy variant '" + stage_join + "' admitted until 2026-06-02")
            return "OK"
        }
        return "FAIL: stage must start with one of {sft-stage|dpo|merged|base|preview|dev|paradigm-} (got: '" + stage_join + "')"
    }
    return "OK"
}

// ─── HF CLI invocation (raw#9 strict, no python bridge) ────────────────

fn _sh_q(s: str) -> str {
    // single-quote escape: ' -> '\''
    let mut out = "'"
    let mut i = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        if c == "'" { out = out + "'\\''" } else { out = out + c }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _hf_cli_check() {
    let cli = _hf_cli()
    let ver = exec(cli + " --version 2>&1 | head -1").trim()
    let probe = exec("test -x '" + cli + "' && echo y || (command -v " + _sh_q(cli) + " >/dev/null 2>&1 && echo y || echo n)").trim()
    let out = json_parse("{}")
    out["cli"] = cli
    out["version"] = ver
    out["available"] = if probe == "y" { 1 } else { 0 }
    return out
}

// Canonical 3-tier token resolution (preserved from mk2 v2.1.0):
//   1) `secret get huggingface.token`     — SSOT (HF official naming)
//   2) ~/.cache/huggingface/token          — HF CLI cache fallback
//   3) HF_TOKEN env                        — explicit override
fn _resolve_token(req_token: str) -> str {
    if req_token.len() > 0 { return req_token }
    // tier 1: canonical secret store
    let s1 = exec("secret get huggingface.token 2>/dev/null").trim()
    if s1.len() > 0 { return s1 }
    // tier 2: HF CLI cache file
    let p2 = HOME + "/.cache/huggingface/token"
    let f2 = exec("test -f " + _sh_q(p2) + " && cat " + _sh_q(p2) + " 2>/dev/null").trim()
    if f2.len() > 0 { return f2 }
    // tier 3: env override
    let env1 = exec("echo \"$HF_TOKEN\"").trim()
    if env1.len() > 0 { return env1 }
    return ""
}

// Pass the token to hf WITHOUT it appearing in any argv/command. huggingface_hub
// resolves its token file as `$HF_HOME/token`. We write the token to a private
// transient dir (umask 077 / chmod 600) and return ONLY the dir path; the dir
// PATH is non-secret, the token VALUE never lands in argv / `sh -c` / `ps`.
// Caller MUST rm -rf the returned dir. Returns "" when token is empty.
fn _hf_token_home_dir(token: str) -> str {
    if token.len() == 0 { return "" }
    let dir = exec("umask 077; d=$(mktemp -d \"${TMPDIR:-/tmp}/_hfup_home.XXXXXX\") && printf '%s' " + _sh_q(token) + " > \"$d/token\" && chmod 600 \"$d/token\" && printf '%s' \"$d\"").trim()
    return dir
}

// Build the `HF_HOME=<dir> ` exec prefix from a token-home dir (empty → "").
fn _hf_token_env_prefix(home_dir: str) -> str {
    if home_dir.len() == 0 { return "" }
    return "HF_HOME=" + _sh_q(home_dir) + " "
}

// A real HF success produced a genuine commit/repo URL. Treat output as
// success ONLY when it points at huggingface.co AND carries no error/auth
// signal — exit-code capture via `echo $?` is unreliable because hexa exec()
// spawns a fresh shell per call.
fn _hf_output_is_error(out: str) -> int {
    if out.contains("Traceback") { return 1 }
    if out.contains("Error") { return 1 }
    if out.contains("401") { return 1 }
    if out.contains("Unauthorized") { return 1 }
    if out.contains("HfHubHTTPError") { return 1 }
    return 0
}

fn _hf_commit_url_ok(commit_url: str) -> int {
    if commit_url.len() == 0 { return 0 }
    if !commit_url.starts_with("https://huggingface.co/") { return 0 }
    if _hf_output_is_error(commit_url) == 1 { return 0 }
    return 1
}

// sha256 of a single file via stdlib FIPS 180-4 builtin.
fn _sha256_file(p: str) -> str {
    return sha256_file(p)
}

// Walk files under root (file or dir). Returns list of absolute paths.
// Skips dot-dirs and dot-files (matches legacy walker semantics).
fn _walk_files(root: str) -> [str] {
    let is_dir = exec("test -d " + _sh_q(root) + " && echo y || echo n").trim()
    if is_dir != "y" {
        let is_file = exec("test -f " + _sh_q(root) + " && echo y || echo n").trim()
        if is_file == "y" { return [root] }
        return []
    }
    // -mindepth 1 to skip root itself; prune any dot-named dir/file.
    let cmd = "/usr/bin/find " + _sh_q(root)
              + " -mindepth 1 \\( -name '.*' -prune \\) -o -type f -print 2>/dev/null"
    let raw = exec(cmd)
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < lines.len() {
        let ln = lines[i].trim()
        if ln.len() > 0 { out = out.push(ln) }
        i = i + 1
    }
    return out
}

fn _file_size(p: str) -> int {
    // BSD stat -f%z, GNU stat -c%s — try both.
    let bsd = exec("stat -f%z " + _sh_q(p) + " 2>/dev/null").trim()
    if bsd.len() > 0 { return to_int(bsd) }
    let gnu = exec("stat -c%s " + _sh_q(p) + " 2>/dev/null").trim()
    if gnu.len() > 0 { return to_int(gnu) }
    let wc = exec("wc -c < " + _sh_q(p) + " 2>/dev/null | awk '{print $1}'").trim()
    if wc.len() > 0 { return to_int(wc) }
    return 0
}

// ─── Audit log helpers ─────────────────────────────────────────────────

fn _ts_utc() -> str {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _audit_write(repo: str, payload) -> str {
    let dir = _audit_dir()
    let _mk = exec("mkdir -p " + _sh_q(dir))
    let ts = exec("date -u +%Y%m%dT%H%M%SZ").trim()
    let safe_repo = repo.replace("/", "__")
    let path = dir + "/" + ts + "_" + safe_repo + ".jsonl"
    let line = json_stringify(payload) + "\n"
    let _w = exec("printf '%s' " + _sh_q(line) + " >> " + _sh_q(path))
    return path
}

// ─── op: selftest ──────────────────────────────────────────────────────
// Verifies the hexa side can find the hf CLI + sha256/walk helpers work.
// Self-contained (walks a fresh temp dir) — no external checkout needed.
// No network call.

fn _do_selftest() {
    let t0 = exec("date +%s").trim()
    let mut checks = []

    // check 1: hf CLI present and version readable
    let cli_info = _hf_cli_check()
    let c1 = json_parse("{}")
    c1["name"] = "hf_cli_present"
    c1["ok"] = cli_info["available"]
    c1["info"] = to_string(cli_info["cli"]) + " | " + to_string(cli_info["version"])
    checks = checks.push(c1)

    // check 2: sha256 helper round-trip
    let tmp = "/tmp/hf_upload_selftest_" + t0 + ".bin"
    write_file(tmp, "hexa_hf_upload_selftest_v1\n")
    let sha = _sha256_file(tmp)
    let _rm = exec("rm -f " + _sh_q(tmp))
    let c2 = json_parse("{}")
    c2["name"] = "sha256_helper"
    c2["ok"] = if sha.len() == 64 { 1 } else { 0 }
    c2["info"] = if sha.len() >= 16 { sha.substring(0, 16) + "..." } else { sha }
    checks = checks.push(c2)

    // check 3: walk_files on a self-built temp dir finds the seeded file.
    let wdir = exec("d=$(mktemp -d \"${TMPDIR:-/tmp}/_hfup_walk.XXXXXX\") && printf '%s' \"$d\"").trim()
    write_file(wdir + "/marker.bin", "walk-probe\n")
    let files = _walk_files(wdir)
    let mut found = 0
    let mut wi = 0
    while wi < files.len() {
        if files[wi].contains("marker.bin") { found = 1 }
        wi = wi + 1
    }
    let _rmw = exec("rm -rf " + _sh_q(wdir))
    let c3 = json_parse("{}")
    c3["name"] = "walk_files"
    c3["ok"] = found
    c3["info"] = to_string(files.len()) + " files"
    checks = checks.push(c3)

    let mut all_ok = 1
    let mut ci = 0
    while ci < checks.len() {
        if to_int(checks[ci]["ok"]) != 1 { all_ok = 0 }
        ci = ci + 1
    }
    let resp = json_parse("{}")
    resp["ok"] = all_ok
    resp["mode"] = "selftest"
    resp["checks"] = checks
    resp["message"] = if all_ok == 1 { "selftest: PASS" } else { "selftest: FAIL" }
    return resp
}

// ─── op: dry_run ───────────────────────────────────────────────────────
// Walk + sha256 every file; no network.

fn _do_dry_run(repo: str, ckpt: str, readme: str, tag: str) {
    let files = _walk_files(ckpt)
    let mut sha_map = json_parse("{}")
    let mut total = 0
    let mut i = 0
    while i < files.len() {
        let abs = files[i]
        // rel path = abs minus ckpt prefix (handle both file + dir cases)
        let mut rel = abs
        if abs.starts_with(ckpt + "/") { rel = abs.substring(ckpt.len() + 1, abs.len()) }
        else if abs == ckpt { rel = exec("basename " + _sh_q(abs)).trim() }
        let sha = _sha256_file(abs)
        sha_map[rel] = if sha.len() > 0 { sha } else { "error:sha256_failed" }
        total = total + _file_size(abs)
        i = i + 1
    }
    let readme_ok = if readme.len() > 0 { exec("test -f " + _sh_q(readme) + " && echo y || echo n").trim() } else { "n" }
    let payload = json_parse("{}")
    payload["ts_utc"] = _ts_utc()
    payload["mode"] = "dry_run"
    payload["repo"] = repo
    payload["tag"] = tag
    payload["file_count"] = files.len()
    payload["total_bytes"] = total
    payload["sha256_map"] = sha_map
    payload["readme_present"] = if readme_ok == "y" { 1 } else { 0 }
    payload["outcome"] = "dry_run_ok"
    let audit_path = _audit_write(repo, payload)

    let resp = json_parse("{}")
    resp["ok"] = 1
    resp["mode"] = "dry_run"
    resp["repo"] = repo
    resp["tag"] = tag
    resp["file_count"] = files.len()
    resp["total_bytes"] = total
    resp["sha256_map"] = sha_map
    resp["audit_path"] = audit_path
    resp["message"] = "dry_run: " + to_string(files.len()) + " files, " + to_string(total) + " bytes, readme=" + (if readme_ok == "y" { "ok" } else { "missing" })
    return resp
}

// ─── op: upload ────────────────────────────────────────────────────────
// Pre-compute sha256 for audit, then shell out to `hf` CLI.

fn _do_upload(repo: str, ckpt: str, readme: str, tag: str, private: int) {
    let cli_info = _hf_cli_check()
    if to_int(cli_info["available"]) != 1 {
        let err = json_parse("{}")
        err["ok"] = 0
        err["mode"] = "upload"
        err["repo"] = repo
        err["error"] = "hf_cli_unavailable"
        err["message"] = "hf CLI not found at " + to_string(cli_info["cli"]) + "; install huggingface_hub>=1.8.0"
        return err
    }
    let token = _resolve_token("")
    if token.len() == 0 {
        let err = json_parse("{}")
        err["ok"] = 0
        err["mode"] = "upload"
        err["repo"] = repo
        err["error"] = "no_token"
        err["message"] = "no HF token (canonical: secret get huggingface.token | ~/.cache/huggingface/token | HF_TOKEN env)"
        return err
    }

    let cli = to_string(cli_info["cli"])

    // Pre-compute sha256 map (audit truth, recorded BEFORE upload).
    let files = _walk_files(ckpt)
    let mut sha_map = json_parse("{}")
    let mut total = 0
    let mut fi = 0
    while fi < files.len() {
        let abs = files[fi]
        let mut rel = abs
        if abs.starts_with(ckpt + "/") { rel = abs.substring(ckpt.len() + 1, abs.len()) }
        else if abs == ckpt { rel = exec("basename " + _sh_q(abs)).trim() }
        let sha = _sha256_file(abs)
        sha_map[rel] = if sha.len() > 0 { sha } else { "error:sha256_failed" }
        total = total + _file_size(abs)
        fi = fi + 1
    }

    let priv_flag = if private == 1 { " --private" } else { "" }
    // token via a private HF_HOME/token file (not --token argv, not an inline
    // HF_TOKEN=<value> — both are ps-visible). Only the dir path is ever on the
    // command line. tok_home is rm -rf'd before this fn returns.
    let tok_home = _hf_token_home_dir(token)
    let tok_env = _hf_token_env_prefix(tok_home)

    // Step 1: create repo (idempotent via --exist-ok). Best-effort / non-fatal:
    // `hf upload` auto-creates the repo, so a create failure does NOT gate
    // success (success is gated on the upload commit URL below). `--repo-type
    // model` (hf 0.36.2 rejects `--type model`).
    let create_cmd = tok_env + cli + " repo create " + _sh_q(repo) + " --repo-type model" + priv_flag + " --exist-ok 2>&1"
    let create_out = exec(create_cmd)

    // Step 2: upload folder (single commit). Returns commit URL on stdout.
    let commit_msg = "hexa hf upload commit"
    let upload_cmd = tok_env + cli + " upload " + _sh_q(repo) + " " + _sh_q(ckpt) + " --commit-message " + _sh_q(commit_msg) + " 2>&1"
    let upload_out = exec(upload_cmd)

    // Heuristic commit_url extraction: look for a real 'https://huggingface.co/'
    // line, skipping lines that carry an error/auth signal.
    let mut commit_url = ""
    let lines = upload_out.split("\n")
    let mut li = 0
    while li < lines.len() {
        let ln = lines[li].trim()
        if ln.starts_with("https://huggingface.co/") && _hf_output_is_error(ln) == 0 {
            commit_url = ln
            li = lines.len()
        } else {
            li = li + 1
        }
    }

    // Step 3: optional README upload if outside ckpt dir.
    let mut readme_msg = ""
    if readme.len() > 0 {
        let readme_exists = exec("test -f " + _sh_q(readme) + " && echo y || echo n").trim()
        if readme_exists == "y" {
            let abs_readme = exec("readlink -f " + _sh_q(readme) + " 2>/dev/null || echo " + _sh_q(readme)).trim()
            let abs_ckpt = exec("readlink -f " + _sh_q(ckpt) + " 2>/dev/null || echo " + _sh_q(ckpt)).trim()
            let inside = if abs_readme.starts_with(abs_ckpt + "/") { 1 } else { 0 }
            if inside == 0 {
                let r_cmd = tok_env + cli + " upload " + _sh_q(repo) + " " + _sh_q(readme) + " README.md --commit-message " + _sh_q("hexa hf upload: README") + " 2>&1"
                let r_out = exec(r_cmd)
                readme_msg = r_out.trim()
            }
        }
    }

    // Step 4: optional tag.
    let mut tag_url = ""
    let mut tag_warn = ""
    if tag.len() > 0 {
        let tag_cmd = tok_env + cli + " repo tag create " + _sh_q(repo) + " " + _sh_q(tag) + " 2>&1"
        let tag_out = exec(tag_cmd)
        // Tagging is non-fatal (does not gate upload success).
        if _hf_output_is_error(tag_out) == 0 {
            tag_url = "https://huggingface.co/" + repo + "/tree/" + tag
        } else {
            tag_warn = "tag_create_warn: " + tag_out.trim()
        }
    }

    // Success is gated on a REAL commit URL, not on `echo $?` (which ran in a
    // fresh shell and reported echo's status, never hf's).
    let upload_ok = _hf_commit_url_ok(commit_url)
    let mut last_err = ""
    if upload_ok != 1 {
        let tail = if upload_out.len() > 512 { upload_out.substring(upload_out.len() - 512, upload_out.len()).trim() } else { upload_out.trim() }
        last_err = "hf_upload_no_commit_url: " + tail
    }

    let payload = json_parse("{}")
    payload["ts_utc"] = _ts_utc()
    payload["mode"] = "upload"
    payload["repo"] = repo
    payload["tag"] = tag
    payload["private"] = private
    payload["file_count"] = files.len()
    payload["total_bytes"] = total
    payload["sha256_map"] = sha_map
    payload["commit_url"] = commit_url
    payload["tag_url"] = tag_url
    payload["tag_warn"] = tag_warn
    payload["readme_msg"] = readme_msg
    payload["create_out"] = create_out.trim()
    payload["upload_out_tail"] = if upload_out.len() > 1024 { upload_out.substring(upload_out.len() - 1024, upload_out.len()) } else { upload_out }
    payload["outcome"] = if upload_ok == 1 { "ok" } else { "fail" }
    payload["error"] = last_err
    let audit_path = _audit_write(repo, payload)

    // shred the transient token-home dir (contains the token file).
    if tok_home.len() > 0 { let _rm = exec("rm -rf " + _sh_q(tok_home)) }

    let resp = json_parse("{}")
    resp["ok"] = upload_ok
    resp["mode"] = "upload"
    resp["repo"] = repo
    resp["tag"] = tag
    resp["file_count"] = files.len()
    resp["total_bytes"] = total
    resp["sha256_map"] = sha_map
    resp["commit_url"] = commit_url
    resp["tag_url"] = tag_url
    resp["audit_path"] = audit_path
    resp["message"] = if upload_ok == 1 {
        "upload: " + to_string(files.len()) + " files, " + to_string(total) + " bytes via hf CLI"
    } else {
        "upload FAILED: " + last_err
    }
    resp["error"] = last_err
    return resp
}

// ─── Ledger append (aggregate audit) ───────────────────────────────────

fn _ledger_append(repo: str, mode: str, resp) {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = json_parse("{}")
    entry["ts_utc"] = ts
    entry["repo"] = repo
    entry["mode"] = mode
    entry["ok"] = if has_key(resp, "ok") { resp["ok"] } else { 0 }
    entry["file_count"] = if has_key(resp, "file_count") { resp["file_count"] } else { 0 }
    entry["total_bytes"] = if has_key(resp, "total_bytes") { resp["total_bytes"] } else { 0 }
    entry["tag"] = if has_key(resp, "tag") { resp["tag"] } else { "" }
    entry["audit_path"] = if has_key(resp, "audit_path") { resp["audit_path"] } else { "" }
    entry["commit_url"] = if has_key(resp, "commit_url") { resp["commit_url"] } else { "" }
    let line = json_stringify(entry) + "\n"
    let _r = exec("mkdir -p " + _sh_q(_audit_dir()) + " && printf '%s' " + _sh_q(line) + " >> " + _sh_q(_ledger_path()))
    return entry
}

// ─── Top-level operations ──────────────────────────────────────────────

fn op_selftest() -> int {
    println("[hexa hf] SELFTEST (raw#9 strict — no python bridge)")
    let cli_info = _hf_cli_check()
    println("  hf cli      = " + to_string(cli_info["cli"]))
    println("  hf version  = " + to_string(cli_info["version"]))
    println("  hf available= " + to_string(cli_info["available"]))

    // 1. README validator unit test (synthesize good + bad README in /tmp)
    let good = "# x\n\n## Origin\nfoo\n\n## Falsifiers\nfoo\n\n## Substrate\nfoo\n\n## Caveats\n- a\n- b\n- c\n\n## Composability\nfoo\n"
    let bad  = "# x\n\n## Origin\nfoo\n\n## Substrate\nfoo\n"
    let g_path = "/tmp/_hf_selftest_good.md"
    let b_path = "/tmp/_hf_selftest_bad.md"
    write_file(g_path, good)
    write_file(b_path, bad)
    let g_res = _readme_validate(g_path)
    let b_res = _readme_validate(b_path)
    let _r1 = exec("rm -f " + _sh_q(g_path) + " " + _sh_q(b_path))
    if g_res != "OK" {
        println("  [F] readme good-case failed: " + g_res)
        println("__HEXA_HF_UPLOAD__ FAIL")
        return 0
    }
    if b_res == "OK" {
        println("  [F] readme bad-case unexpectedly passed")
        println("__HEXA_HF_UPLOAD__ FAIL")
        return 0
    }
    println("  [P] readme validator: good=OK, bad=rejected")

    // 2. naming validator unit test
    let n_good = _naming_validate("dancinlab/clm-v4-sft-stage1")
    let n_bad1 = _naming_validate("BadOrg/clm-v4-sft-stage1")
    let n_bad2 = _naming_validate("dancinlab/zzz-v4-sft-stage1")
    let n_bad3 = _naming_validate("nodash")
    if n_good != "OK" {
        println("  [F] naming good-case failed: " + n_good)
        println("__HEXA_HF_UPLOAD__ FAIL")
        return 0
    }
    if n_bad1 == "OK" || n_bad2 == "OK" || n_bad3 == "OK" {
        println("  [F] naming bad-cases unexpectedly passed: bad1=" + n_bad1 + " bad2=" + n_bad2 + " bad3=" + n_bad3)
        println("__HEXA_HF_UPLOAD__ FAIL")
        return 0
    }
    println("  [P] naming validator: good=OK, bad=rejected")

    // 3. hexa-side selftest: hf CLI presence + sha256 + walk_files (no network).
    let resp = _do_selftest()
    let resp_ok = to_int(resp["ok"])
    let resp_msg = to_string(resp["message"])
    if resp_ok != 1 {
        // Soft-fail: hf CLI may not be installed. Validator units still PASS.
        println("  [W] hexa selftest soft-fail (likely hf CLI not in PATH): " + resp_msg)
        let checks = resp["checks"]
        let mut ci = 0
        while ci < checks.len() {
            let c = checks[ci]
            println("        - " + to_string(c["name"]) + " ok=" + to_string(c["ok"]) + " info=" + to_string(c["info"]))
            ci = ci + 1
        }
        println("  [P] hexa contract intact (validators unit-passed)")
    } else {
        println("  [P] hexa selftest: " + resp_msg)
    }

    println("__HEXA_HF_UPLOAD__ PASS")
    return 1
}

fn op_dry_run(repo: str, ckpt: str, readme: str, tag: str) -> int {
    println("[hexa hf] DRY-RUN (raw#9 strict — hexa-native walk + sha256)")
    println("  repo   = " + repo)
    println("  ckpt   = " + ckpt)
    println("  readme = " + readme)
    println("  tag    = " + tag)

    let n = _naming_validate(repo)
    if n != "OK" { println("  [F] naming: " + n); println("__HEXA_HF_UPLOAD__ FAIL"); return 0 }
    println("  [P] naming OK")

    let r = _readme_validate(readme)
    if r != "OK" { println("  [F] readme: " + r); println("__HEXA_HF_UPLOAD__ FAIL"); return 0 }
    println("  [P] readme OK (5 required H2 + Caveats >=3)")

    let exists = exec("test -d " + _sh_q(ckpt) + " -o -f " + _sh_q(ckpt) + " && echo y || echo n").trim()
    if exists != "y" { println("  [F] ckpt path not found: " + ckpt); println("__HEXA_HF_UPLOAD__ FAIL"); return 0 }

    let resp = _do_dry_run(repo, ckpt, readme, tag)
    if to_int(resp["ok"]) != 1 {
        let m = if has_key(resp, "message") { resp["message"] } else { "unknown" }
        println("  [F] dry-run: " + to_string(m))
        println("__HEXA_HF_UPLOAD__ FAIL")
        return 0
    }
    println("  files       = " + to_string(resp["file_count"]))
    println("  total_bytes = " + to_string(resp["total_bytes"]))
    println("  audit       = " + to_string(resp["audit_path"]))
    let _l = _ledger_append(repo, "dry_run", resp)
    println("__HEXA_HF_UPLOAD__ PASS")
    return 1
}

fn op_upload(repo: str, ckpt: str, readme: str, tag: str, private: int) -> int {
    println("[hexa hf] UPLOAD (raw#9 strict — hf CLI shell-out)")
    println("  repo    = " + repo)
    println("  ckpt    = " + ckpt)
    println("  readme  = " + readme)
    println("  tag     = " + tag)
    println("  private = " + str(private))

    let n = _naming_validate(repo)
    if n != "OK" { println("  [F] naming: " + n); println("__HEXA_HF_UPLOAD__ FAIL"); return 0 }
    let r = _readme_validate(readme)
    if r != "OK" { println("  [F] readme: " + r); println("__HEXA_HF_UPLOAD__ FAIL"); return 0 }

    let resp = _do_upload(repo, ckpt, readme, tag, private)
    if !has_key(resp, "ok") || to_int(resp["ok"]) != 1 {
        let m = if has_key(resp, "message") { resp["message"] } else { "unknown" }
        println("  [F] upload: " + to_string(m))
        let _lf = _ledger_append(repo, "upload", resp)
        println("__HEXA_HF_UPLOAD__ FAIL")
        return 0
    }
    println("  commit_url = " + to_string(resp["commit_url"]))
    println("  tag_url    = " + to_string(resp["tag_url"]))
    println("  audit      = " + to_string(resp["audit_path"]))
    let _l = _ledger_append(repo, "upload", resp)
    println("__HEXA_HF_UPLOAD__ PASS")
    return 1
}

fn print_help() {
    println("hexa hf v" + VERSION + " — HuggingFace upload wrapper (pure hexa · raw#9 strict)")
    println("")
    println("USAGE")
    println("  hexa hf --selftest")
    println("  hexa hf --dry-run --repo <org/name> --ckpt <path> --readme <path> [--tag <step>]")
    println("  hexa hf --upload  --repo <org/name> --ckpt <path> --readme <path> [--tag <step>] [--private]")
    println("  hexa hf --validate-readme <path>")
    println("  hexa hf --validate-naming <org/name>")
    println("")
    println("TOKEN RESOLUTION (canonical 3-tier · ps-invisible via HF_HOME/token file)")
    println("  1) secret get huggingface.token   (canonical SSOT)")
    println("  2) ~/.cache/huggingface/token     (HF CLI cache fallback)")
    println("  3) HF_TOKEN env                   (explicit override)")
    println("")
    println("ENV")
    println("  HF_CLI                hf CLI override (default: `command -v hf`)")
    println("  HF_UPLOAD_AUDIT_DIR   audit dir override (default: $HOME/.hexa/hf_upload_audit)")
    println("  HF_UPLOAD_LEDGER      ledger path override (default: <audit_dir>/hf_upload_ledger.jsonl)")
    println("")
    println("AUDIT")
    println("  per-upload  = <audit_dir>/<ts>_<repo>.jsonl")
    println("  ledger      = <audit_dir>/hf_upload_ledger.jsonl")
}

fn main() {
    // args()[0] is the program path (cf. dojo/cli.hexa) — real args from [1].
    let argv = args()
    let cmd = if argv.len() > 1 { argv[1] } else { "--help" }

    if cmd == "--help" || cmd == "-h" { print_help(); return }

    if cmd == "--selftest" {
        let _r = op_selftest()
        return
    }

    if cmd == "--validate-readme" {
        let path = if argv.len() > 2 { argv[2] } else { "" }
        let res = _readme_validate(path)
        println(res)
        if res == "OK" { println("__HEXA_HF_UPLOAD__ PASS") } else { println("__HEXA_HF_UPLOAD__ FAIL") }
        return
    }

    if cmd == "--validate-naming" {
        let repo = if argv.len() > 2 { argv[2] } else { "" }
        let res = _naming_validate(repo)
        println(res)
        if res == "OK" { println("__HEXA_HF_UPLOAD__ PASS") } else { println("__HEXA_HF_UPLOAD__ FAIL") }
        return
    }

    let repo = _arg_get(argv, "--repo")
    let ckpt = _arg_get(argv, "--ckpt")
    let readme = _arg_get(argv, "--readme")
    let tag = _arg_get(argv, "--tag")
    let priv = _arg_has(argv, "--private")

    if cmd == "--dry-run" {
        if repo.len() == 0 || ckpt.len() == 0 || readme.len() == 0 {
            println("ERROR: --dry-run requires --repo --ckpt --readme")
            print_help()
            return
        }
        let _r = op_dry_run(repo, ckpt, readme, tag)
        return
    }

    if cmd == "--upload" {
        if repo.len() == 0 || ckpt.len() == 0 || readme.len() == 0 {
            println("ERROR: --upload requires --repo --ckpt --readme")
            print_help()
            return
        }
        let _r = op_upload(repo, ckpt, readme, tag, priv)
        return
    }

    println("ERROR: unknown command: " + cmd)
    print_help()
}
