#!hexa strict
// protein-fold verify — Q-score (fraction of native contacts).
fn main() {
    let N_native = 85.0
    let N_total = 100.0
    let Q = N_native / N_total
    println("protein-fold_verify (Q-score · sample native contacts):")
    println("  N_native = " + str(N_native) + " / " + str(N_total))
    println("  Q_score = " + str(Q))
    println("__HEXA_PROTEIN_FOLD_VERIFY__ PASS gate=GATE_OPEN absorbed=false")
}
