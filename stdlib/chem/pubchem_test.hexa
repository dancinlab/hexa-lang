// stdlib/chem/pubchem_test.hexa — measured-oracle gate for pubchem client.
//
// Parses compiler/bridges/_cache/pubchem.frozen.json (live snapshot of
// CID 2244 = Aspirin) and byte-asserts field extraction. No network.
// MolecularWeight / XLogP / TPSA asserted on the *raw JSON token*, not
// float epsilon — any precision drift trips the gate.

use "stdlib/chem/pubchem"

let FIXTURE = "compiler/bridges/_cache/pubchem.frozen.json"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_eq_i(label: string, want: int, got: int) {
    if want != got { _fail(label, to_string(want), to_string(got)) }
}

// Raw token text after `"key":` — bytes-only assert, skip float epsilon.
fn _raw_token(body: string, key: string) -> string {
    let probe = "\"" + key + "\""
    let n = len(body)
    let mut i = 0
    while i + len(probe) <= n {
        if body.substring(i, i + len(probe)) == probe {
            let mut j = i + len(probe)
            // skip ws + colon + ws
            while j < n {
                let c = body.substring(j, j + 1)
                if c == " " || c == "\t" || c == "\n" || c == "\r" || c == ":" {
                    j = j + 1
                    continue
                }
                break
            }
            // capture string OR bare number token
            if j < n && body.substring(j, j + 1) == "\"" {
                let start = j + 1
                let mut k = start
                while k < n && body.substring(k, k + 1) != "\"" { k = k + 1 }
                return body.substring(start, k)
            }
            let start = j
            let mut k = j
            while k < n {
                let c = body.substring(k, k + 1)
                if c == "," || c == "}" || c == "]" || c == "\n" || c == " " { break }
                k = k + 1
            }
            return body.substring(start, k)
        }
        i = i + 1
    }
    return ""
}

fn main() {
    let body = read_file(FIXTURE)
    if len(body) == 0 {
        println("FAIL: fixture missing: " + FIXTURE)
        exit(1)
    }

    let c = pubchem_parse_compound(body)

    // ── identity ─────────────────────────────────────────────────
    _expect_eq_i("c.cid",                 2244,                                  c.cid)
    _expect_eq("c.molecular_formula",     "C9H8O4",                              c.molecular_formula)
    _expect_eq("c.iupac_name",            "2-acetyloxybenzoic acid",             c.iupac_name)

    // SMILES (2025 schema: SMILES = isomeric, ConnectivitySMILES = legacy
    // canonical; aspirin has no stereo so both equal).
    _expect_eq("c.smiles_canonical",      "CC(=O)OC1=CC=CC=C1C(=O)O",            c.smiles_canonical)
    _expect_eq("c.smiles_isomeric",       "CC(=O)OC1=CC=CC=C1C(=O)O",            c.smiles_isomeric)
    _expect_eq("c.inchi_key",             "BSYNRYMUTXBXSQ-UHFFFAOYSA-N",         c.inchi_key)
    _expect_eq("c.inchi",                 "InChI=1S/C9H8O4/c1-6(10)13-8-5-3-2-4-7(8)9(11)12/h2-5H,1H3,(H,11,12)", c.inchi)

    // raw numeric tokens — byte-deterministic, no float epsilon.
    _expect_eq("MolecularWeight raw token", "180.16", _raw_token(body, "MolecularWeight"))
    _expect_eq("XLogP raw token",         "1.2",                                 _raw_token(body, "XLogP"))
    _expect_eq("TPSA raw token",          "63.6",                                _raw_token(body, "TPSA"))

    _expect_eq_i("c.hbond_donors",        1,                                     c.hbond_donors)
    _expect_eq_i("c.hbond_acceptors",     4,                                     c.hbond_acceptors)

    // empty / error path
    let empty = pubchem_parse_compound("")
    _expect_eq_i("empty body → cid 0",    0,                                     empty.cid)
    let no_cid = pubchem_fetch(0)
    _expect_eq_i("fetch(0) sentinel",     0,                                     no_cid.cid)
    println("PASS: pubchem parse_compound + raw-token + empty-path oracles (10 fields, 1 entry)")
}
