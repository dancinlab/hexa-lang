// stdlib/chem/md/verlet.hexa — Velocity-Verlet integrator for MD (TTR M5 cycle 1).
//
// @version 0.1.0
// @capabilities [pure]
//
// References:
//   Verlet, L. (1967). Computer "experiments" on classical fluids.
//     Phys. Rev. 159, 98 (original position-Verlet form).
//   Swope, W.C., Andersen, H.C., Berens, P.H., Wilson, K.R. (1982).
//     J. Chem. Phys. 76, 637 (Velocity-Verlet variant used here).
//
// Pure algorithmic — no I/O, no syscall. Vacuum boundary (no PBC).
//
// DEFERRED (do NOT belong in this PR; follow-up milestones):
//   * Periodic boundary conditions (minimum-image distance)
//   * Long-range electrostatics (Ewald / PME)
//   * Bonded forces (bonds/angles/dihedrals/impropers)
//   * Thermostats (Berendsen, Nosé-Hoover, Langevin)
//   * Barostats (Berendsen, Parrinello-Rahman)
//   * PDB / DCD / XTC trajectory IO
//   * Neighbour lists / cell decomposition
//   * GPU dispatch (CUDA / Metal / SYCL)
//
// Public surface:
//   pub fn verlet_step(particles, dt) -> [MdParticle]
//       Half-kick + drift. Caller recomputes forces between calls,
//       then closes the step with verlet_finish_step.
//   pub fn verlet_finish_step(particles, dt) -> [MdParticle]
//       Second half-kick: v += 0.5 · (F_new/m) · dt.
//   pub fn verlet_run(initial, dt, n_steps, eps, sigma) -> [MdParticle]
//       Convenience: dispatch integrator + LJ-force recompute each step.
//
// The MdParticle struct lives in lennard_jones.hexa (the SSOT layout)
// — imported transitively for callers.

use "stdlib/chem/md/lennard_jones"

// ── Force-field dispatch (LJ for now; future: pluggable) ─────────────
//
// Re-evaluates the force on every particle in-place style. We mutate
// fx/fy/fz on a *fresh* array (the caller's input is conceptually
// immutable from the integrator's perspective).

fn _recompute_lj_forces(particles: array, eps: float, sigma: float) -> array {
    let n = len(particles)
    // Zero out forces on a new array.
    let mut out = []
    let mut i = 0
    while i < n {
        let p = particles[i]
        out.push(MdParticle{
            x: p.x, y: p.y, z: p.z,
            vx: p.vx, vy: p.vy, vz: p.vz,
            mass: p.mass,
            fx: 0.0, fy: 0.0, fz: 0.0,
        })
        i = i + 1
    }
    // Accumulate pair forces with Newton's third law.
    let mut a = 0
    while a < n {
        let mut b = a + 1
        while b < n {
            let f = lj_pair_force(out[a], out[b], eps, sigma)
            let fx = f[0]
            let fy = f[1]
            let fz = f[2]
            let pa = out[a]
            let pb = out[b]
            out[a] = MdParticle{
                x: pa.x, y: pa.y, z: pa.z,
                vx: pa.vx, vy: pa.vy, vz: pa.vz,
                mass: pa.mass,
                fx: pa.fx + fx, fy: pa.fy + fy, fz: pa.fz + fz,
            }
            out[b] = MdParticle{
                x: pb.x, y: pb.y, z: pb.z,
                vx: pb.vx, vy: pb.vy, vz: pb.vz,
                mass: pb.mass,
                fx: pb.fx - fx, fy: pb.fy - fy, fz: pb.fz - fz,
            }
            b = b + 1
        }
        a = a + 1
    }
    return out
}

// ── verlet_step: half-kick + drift ───────────────────────────────────
//
//   v(t + dt/2) = v(t)        + 0.5 · (F(t)/m)     · dt
//   x(t + dt)   = x(t)        + v(t + dt/2)        · dt
//
// Returns a new particle array with positions advanced and velocities
// at t + dt/2. Forces are *not* recomputed here — caller does that,
// then calls verlet_finish_step to close the step.

pub fn verlet_step(particles: array, dt: float) -> array {
    let n = len(particles)
    let half_dt = 0.5 * dt
    let mut out = []
    let mut i = 0
    while i < n {
        let p = particles[i]
        let inv_m = 1.0 / p.mass
        let vx_half = p.vx + half_dt * p.fx * inv_m
        let vy_half = p.vy + half_dt * p.fy * inv_m
        let vz_half = p.vz + half_dt * p.fz * inv_m
        let x_new = p.x + vx_half * dt
        let y_new = p.y + vy_half * dt
        let z_new = p.z + vz_half * dt
        out.push(MdParticle{
            x: x_new, y: y_new, z: z_new,
            vx: vx_half, vy: vy_half, vz: vz_half,
            mass: p.mass,
            fx: p.fx, fy: p.fy, fz: p.fz,
        })
        i = i + 1
    }
    return out
}

// ── verlet_finish_step: second half-kick ─────────────────────────────
//
//   v(t + dt) = v(t + dt/2) + 0.5 · (F(t+dt)/m) · dt
//
// Caller must have refreshed fx/fy/fz to the values at the new
// positions before invoking this.

pub fn verlet_finish_step(particles: array, dt: float) -> array {
    let n = len(particles)
    let half_dt = 0.5 * dt
    let mut out = []
    let mut i = 0
    while i < n {
        let p = particles[i]
        let inv_m = 1.0 / p.mass
        let vx_new = p.vx + half_dt * p.fx * inv_m
        let vy_new = p.vy + half_dt * p.fy * inv_m
        let vz_new = p.vz + half_dt * p.fz * inv_m
        out.push(MdParticle{
            x: p.x, y: p.y, z: p.z,
            vx: vx_new, vy: vy_new, vz: vz_new,
            mass: p.mass,
            fx: p.fx, fy: p.fy, fz: p.fz,
        })
        i = i + 1
    }
    return out
}

// ── verlet_run: full integrator loop with LJ force-field ─────────────
//
// Initialises forces on the input particles (their incoming fx/fy/fz
// are ignored — we re-evaluate at the actual coordinates) and then
// loops n_steps of the canonical Velocity-Verlet sequence:
//
//   1. F(t)        ← LJ at current positions
//   2. half-kick + drift   (verlet_step)
//   3. F(t + dt)   ← LJ at new positions
//   4. second half-kick    (verlet_finish_step)

pub fn verlet_run(initial: array, dt: float, n_steps: int,
                  eps: float, sigma: float) -> array {
    // Seed forces at t=0.
    let mut state = _recompute_lj_forces(initial, eps, sigma)
    if n_steps <= 0 { return state }
    if dt <= 0.0 { return state }

    let mut step = 0
    while step < n_steps {
        // 1. Half-kick + drift.
        let drifted = verlet_step(state, dt)
        // 2. Recompute forces at the new positions.
        let reforced = _recompute_lj_forces(drifted, eps, sigma)
        // 3. Second half-kick to close the step.
        state = verlet_finish_step(reforced, dt)
        step = step + 1
    }
    return state
}
