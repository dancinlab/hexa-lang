// stdlib/chem/md/bonded.hexa — Bonded force-field 항: 결합/각도/이면각.
//
// @version 0.1.0
// @capabilities [pure]
//
// References:
//   Eastman, P. et al. (2017). OpenMM 7: Rapid development of high
//     performance algorithms for molecular dynamics.
//     PLOS Comput Biol 13(7):e1005659.
//   Frenkel, D. & Smit, B. (2002). Understanding Molecular Simulation,
//     2nd ed., Academic. Ch. 4 (interaction terms).
//   Leach, A.R. (2001). Molecular Modelling: Principles and Applications,
//     2nd ed., Prentice Hall. Ch. 4.6.
//
// 순수 알고리즘 — I/O 없음, syscall 없음. 셋 모두 OpenMM 디자인의
// AmberToolkit Harmonic / Periodic 변형:
//
//   1. 결합 신축 (harmonic bond stretch)
//      U_bond  = (1/2) k_b (r − r_0)^2
//   2. 결합각 굽힘 (harmonic angle bend)
//      U_angle = (1/2) k_θ (θ − θ_0)^2
//   3. 이면각 비틀림 (Fourier-series dihedral torsion)
//      U_dih   = Σ_n  k_n [1 + cos(n · φ − δ_n)]
//
// 모든 항은 PBC 가 켜진 경우 pbc.hexa 의 최소-이미지 변위 헬퍼 사용.
// PBC 미사용은 L ≤ 0 으로 호출 → wrap-no-op.
//
// Public surface:
//   pub struct BondTerm     { i, j: int, k_b: float, r0: float }
//   pub struct AngleTerm    { i, j, k: int, k_theta: float, theta0: float }
//   pub struct DihedralTerm { i, j, k, l: int, k_n: float, n: int, delta: float }
//
//   pub fn bond_energy(particles, term, L)        -> float
//   pub fn angle_energy(particles, term, L)       -> float
//   pub fn dihedral_energy(particles, term, L)    -> float
//   pub fn bonded_total_energy(particles, bonds, angles, dihedrals, L) -> float
//
// 힘 (gradient) 은 후속 사이클 — 본 PR 은 energy-only 측정 오라클 7
// 케이스를 닫기 위함. integrator 와 직접 연동은 follow-up.

use "stdlib/chem/md/lennard_jones"
use "stdlib/chem/md/pbc"

// ── 항 구조 ───────────────────────────────────────────────────────────

pub struct BondTerm {
    i: int,        // 입자 인덱스 1
    j: int,        // 입자 인덱스 2
    k_b: float,    // 강성 상수 (force constant)
    r0: float,     // 평형 거리
}

pub struct AngleTerm {
    i: int,        // 끝 입자 1
    j: int,        // 중심 입자
    k: int,        // 끝 입자 2
    k_theta: float,// 강성 상수 (라디안²당)
    theta0: float, // 평형 각 (라디안)
}

pub struct DihedralTerm {
    i: int,        // 입자 1
    j: int,        // 입자 2 (축 시작)
    k: int,        // 입자 3 (축 끝)
    l: int,        // 입자 4
    k_n: float,    // n-차 진폭
    n: int,        // 다중도 (periodicity)
    delta: float,  // 위상 (phase shift, 라디안)
}

// ── 내부 헬퍼 ─────────────────────────────────────────────────────────

fn _disp_xyz(particles: array, i: int, j: int, L: float) -> array {
    // i → j 변위 (PBC-aware). L ≤ 0 이면 raw.
    if L > 0.0 {
        return pbc_min_image_displacement_cubic(particles[i], particles[j], L)
    }
    let pi = particles[i]
    let pj = particles[j]
    return [pj.x - pi.x, pj.y - pi.y, pj.z - pi.z]
}

fn _dot3(a: array, b: array) -> float {
    return a[0] * b[0] + a[1] * b[1] + a[2] * b[2]
}

fn _cross3(a: array, b: array) -> array {
    return [
        a[1] * b[2] - a[2] * b[1],
        a[2] * b[0] - a[0] * b[2],
        a[0] * b[1] - a[1] * b[0],
    ]
}

fn _norm3(a: array) -> float {
    return sqrt(a[0] * a[0] + a[1] * a[1] + a[2] * a[2])
}

// ── 1. 결합 신축 에너지 ────────────────────────────────────────────────
//
// U = (1/2) k_b (r − r_0)²
// PBC: 입자 i → j 변위는 최소-이미지.

pub fn bond_energy(particles: array, term: BondTerm, L: float) -> float {
    let d = _disp_xyz(particles, term.i, term.j, L)
    let r = sqrt(d[0] * d[0] + d[1] * d[1] + d[2] * d[2])
    let dr = r - term.r0
    return 0.5 * term.k_b * dr * dr
}

// ── 2. 결합각 굽힘 에너지 ──────────────────────────────────────────────
//
// θ = angle between (i ← j) 와 (k ← j) — j 는 중심 정점.
// cos θ = ((r_i − r_j) · (r_k − r_j)) / (|r_i − r_j| · |r_k − r_j|)
// 수치 안정화: |cos θ| > 1 클램프.
// U = (1/2) k_θ (θ − θ_0)²

pub fn angle_energy(particles: array, term: AngleTerm, L: float) -> float {
    // j → i 변위, j → k 변위.
    let v_ji = _disp_xyz(particles, term.j, term.i, L)
    let v_jk = _disp_xyz(particles, term.j, term.k, L)
    let nji = _norm3(v_ji)
    let njk = _norm3(v_jk)
    if nji < 1.0e-15 { return 0.0 }
    if njk < 1.0e-15 { return 0.0 }
    let mut c = _dot3(v_ji, v_jk) / (nji * njk)
    if c > 1.0 { c = 1.0 }
    if c < 0.0 - 1.0 { c = 0.0 - 1.0 }
    let theta = acos(c)
    let dt = theta - term.theta0
    return 0.5 * term.k_theta * dt * dt
}

// ── 3. 이면각 비틀림 에너지 ────────────────────────────────────────────
//
// 네 입자 i-j-k-l 사이 이면각 φ:
//   b1 = r_j − r_i,  b2 = r_k − r_j,  b3 = r_l − r_k
//   n1 = b1 × b2,    n2 = b2 × b3
//   cos φ = (n1 · n2) / (|n1| |n2|)
//   sin φ = ((n1 × n2) · b̂_2)            (부호 결정용)
//   φ = atan2(sin φ, cos φ)
// U(φ) = k_n · [1 + cos(n φ − δ)]   (단일 항; OpenMM Periodic 형)
//
// 다중-Fourier 합은 caller 가 같은 i,j,k,l 에 대해 여러 DihedralTerm 누적.

pub fn dihedral_energy(particles: array, term: DihedralTerm, L: float) -> float {
    let b1 = _disp_xyz(particles, term.i, term.j, L)
    let b2 = _disp_xyz(particles, term.j, term.k, L)
    let b3 = _disp_xyz(particles, term.k, term.l, L)

    let n1 = _cross3(b1, b2)
    let n2 = _cross3(b2, b3)
    let nn1 = _norm3(n1)
    let nn2 = _norm3(n2)
    if nn1 < 1.0e-15 { return 0.0 }
    if nn2 < 1.0e-15 { return 0.0 }

    let mut cosphi = _dot3(n1, n2) / (nn1 * nn2)
    if cosphi > 1.0 { cosphi = 1.0 }
    if cosphi < 0.0 - 1.0 { cosphi = 0.0 - 1.0 }

    // 부호 결정: (n1 × n2) · b̂2 의 부호 = sin φ 부호.
    let b2_norm = _norm3(b2)
    if b2_norm < 1.0e-15 { return 0.0 }
    let m = _cross3(n1, n2)
    let sinphi_unsigned = sqrt(1.0 - cosphi * cosphi)
    let sign_dot = _dot3(m, b2) / (b2_norm * nn1 * nn2)
    let mut sinphi = sinphi_unsigned
    if sign_dot < 0.0 { sinphi = 0.0 - sinphi_unsigned }

    let phi = atan2(sinphi, cosphi)
    let arg = to_float(term.n) * phi - term.delta
    return term.k_n * (1.0 + cos(arg))
}

// ── 총합 ──────────────────────────────────────────────────────────────

pub fn bonded_total_energy(particles: array,
                           bonds: array,
                           angles: array,
                           dihedrals: array,
                           L: float) -> float {
    let mut u = 0.0
    let mut i = 0
    while i < len(bonds) {
        u = u + bond_energy(particles, bonds[i], L)
        i = i + 1
    }
    i = 0
    while i < len(angles) {
        u = u + angle_energy(particles, angles[i], L)
        i = i + 1
    }
    i = 0
    while i < len(dihedrals) {
        u = u + dihedral_energy(particles, dihedrals[i], L)
        i = i + 1
    }
    return u
}
