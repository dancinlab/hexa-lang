// stdlib/chem/md/pbc.hexa — 주기경계조건 (Periodic Boundary Conditions)
// 최소-이미지 거리 / 변위 (Minimum-Image Convention) — 입방 + 직교 박스.
//
// @version 0.1.0
// @capabilities [pure]
//
// References:
//   Allen, M.P. & Tildesley, D.J. (2017). Computer Simulation of Liquids,
//     2nd ed., Oxford. Ch. 1.5 (minimum-image convention).
//   Frenkel, D. & Smit, B. (2002). Understanding Molecular Simulation:
//     From Algorithms to Applications, 2nd ed., Academic. Ch. 4.
//
// 순수 알고리즘 — I/O 없음, syscall 없음. 두 형태 박스 지원:
//   1. 입방(cubic):     L_x = L_y = L_z = L  (단일 스칼라)
//   2. 직교(orthorhombic): L_x, L_y, L_z  독립 (배열 [Lx, Ly, Lz])
//
// 비-직교(triclinic / 일반 격자) 박스는 follow-up — Bekker 1997 행렬
// 절단 + tin-foil 보정이 별도 사이클. DEFERRED.
//
// Public surface:
//   pub fn pbc_wrap_scalar(d, L) -> float
//       (-L/2, L/2] 범위로 변위 d 를 wrap (단일 축).
//   pub fn pbc_min_image_distance_cubic(p1, p2, L) -> float
//       두 입자 사이 최소-이미지 거리 (입방 박스).
//   pub fn pbc_min_image_distance_ortho(p1, p2, Lx, Ly, Lz) -> float
//       두 입자 사이 최소-이미지 거리 (직교 박스).
//   pub fn pbc_min_image_displacement_cubic(p1, p2, L) -> [dx, dy, dz]
//       p1 → p2 최소-이미지 변위 벡터 (입방).
//   pub fn pbc_min_image_displacement_ortho(p1, p2, Lx, Ly, Lz) -> [dx, dy, dz]
//       p1 → p2 최소-이미지 변위 벡터 (직교).
//
// 입자 구조는 MdParticle 를 의존하지 않도록 좌표쌍-인터페이스로 받음
// (bonded.hexa / ewald.hexa 모두 MdParticle 의 x/y/z 필드를 직접
//  뽑아서 호출). 이는 lennard_jones.hexa 의존을 끊기 위한 설계.

use "stdlib/chem/md/lennard_jones"

// ── 스칼라 wrap: floor-based ───────────────────────────────────────────
//
// d_wrapped = d − L · round(d / L)
// round 빌트인은 정수반환이라 floor-기반 식으로 대체:
//   round(x) = floor(x + 0.5)
//   d − L · floor(d/L + 0.5) ∈ (-L/2, L/2]

pub fn pbc_wrap_scalar(d: float, L: float) -> float {
    if L <= 0.0 {
        // 보호 — 0 또는 음수 박스는 wrap-no-op (캘러 책임).
        return d
    }
    let q = d / L + 0.5
    // floor 빌트인 사용. floor(q) 는 가장 가까운 정수쪽 내림.
    let k = floor(q)
    return d - L * to_float(k)
}

// ── 두 입자 사이 최소-이미지 거리 — 입방 ───────────────────────────────

pub fn pbc_min_image_distance_cubic(p1: MdParticle, p2: MdParticle, L: float) -> float {
    let dx = pbc_wrap_scalar(p1.x - p2.x, L)
    let dy = pbc_wrap_scalar(p1.y - p2.y, L)
    let dz = pbc_wrap_scalar(p1.z - p2.z, L)
    return sqrt(dx * dx + dy * dy + dz * dz)
}

// ── 두 입자 사이 최소-이미지 거리 — 직교 ───────────────────────────────

pub fn pbc_min_image_distance_ortho(p1: MdParticle, p2: MdParticle,
                                     Lx: float, Ly: float, Lz: float) -> float {
    let dx = pbc_wrap_scalar(p1.x - p2.x, Lx)
    let dy = pbc_wrap_scalar(p1.y - p2.y, Ly)
    let dz = pbc_wrap_scalar(p1.z - p2.z, Lz)
    return sqrt(dx * dx + dy * dy + dz * dz)
}

// ── 두 입자 사이 최소-이미지 변위 벡터 — 입방 ──────────────────────────
//
// 반환: [dx, dy, dz] = (p1 → p2 wrap-aware).

pub fn pbc_min_image_displacement_cubic(p1: MdParticle, p2: MdParticle, L: float) -> array {
    let dx = pbc_wrap_scalar(p2.x - p1.x, L)
    let dy = pbc_wrap_scalar(p2.y - p1.y, L)
    let dz = pbc_wrap_scalar(p2.z - p1.z, L)
    return [dx, dy, dz]
}

// ── 두 입자 사이 최소-이미지 변위 벡터 — 직교 ──────────────────────────

pub fn pbc_min_image_displacement_ortho(p1: MdParticle, p2: MdParticle,
                                         Lx: float, Ly: float, Lz: float) -> array {
    let dx = pbc_wrap_scalar(p2.x - p1.x, Lx)
    let dy = pbc_wrap_scalar(p2.y - p1.y, Ly)
    let dz = pbc_wrap_scalar(p2.z - p1.z, Lz)
    return [dx, dy, dz]
}
