// stdlib/chem/md/md_test.hexa — measured oracles for Velocity-Verlet + LJ.
//
// All four cases are closed-form / point-evaluated; no network, no
// shell-out, no random seeds.
//
//   T1 LJ U(r=σ) = 0 exactly                              tol 1.0e-12
//   T2 LJ U(r=σ·2^(1/6)) = −eps (well depth)              tol 1.0e-10
//   T3 LJ |F(r=σ·2^(1/6))| ≈ 0 (equilibrium)              tol 1.0e-4
//   T4 Verlet energy drift over 1000 steps < 1%           tol 1.0e-2

use "stdlib/chem/md/verlet"
use "stdlib/chem/md/lennard_jones"

let mut pass_count = 0
let mut total = 0
let mut first_fail = ""

fn abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn check(name: string, cond: bool, detail: string) {
    total = total + 1
    if cond {
        pass_count = pass_count + 1
        println("  ok : " + name + " " + detail)
    } else {
        if first_fail == "" { first_fail = name }
        println("  FAIL " + name + " " + detail)
    }
}

// ── Test fixtures ────────────────────────────────────────────────────

let eps = 1.0
let sigma = 3.4
// r_eq = σ · 2^(1/6) — solve dU/dr = 0:
//   2^(1/6) ≈ 1.122462048309373
let r_eq = sigma * 1.122462048309373

fn mk_particle(x: float, y: float, z: float, mass: float) -> MdParticle {
    return MdParticle{
        x: x, y: y, z: z,
        vx: 0.0, vy: 0.0, vz: 0.0,
        mass: mass,
        fx: 0.0, fy: 0.0, fz: 0.0,
    }
}

// ── T1 — U(r = σ) = 0 exactly ────────────────────────────────────────
let pA = mk_particle(0.0, 0.0, 0.0, 1.0)
let pB = mk_particle(sigma, 0.0, 0.0, 1.0)
let u_at_sigma = lj_pair_energy(pA, pB, eps, sigma)
check("T1 lj U(r=σ)=0", abs_f(u_at_sigma) < 1.0e-12,
      "U=" + to_string(u_at_sigma))

// ── T2 — U(r = r_eq) = −eps ───────────────────────────────────────────
let pC = mk_particle(r_eq, 0.0, 0.0, 1.0)
let u_at_req = lj_pair_energy(pA, pC, eps, sigma)
let err2 = abs_f(u_at_req - (0.0 - eps))
check("T2 lj U(r=r_eq)=−eps", err2 < 1.0e-10,
      "U=" + to_string(u_at_req) + " ref=" + to_string(0.0 - eps)
      + " |err|=" + to_string(err2))

// ── T3 — |F(r = r_eq)| ≈ 0 ────────────────────────────────────────────
let f_at_req = lj_pair_force(pA, pC, eps, sigma)
let fx = f_at_req[0]
let fy = f_at_req[1]
let fz = f_at_req[2]
let f_mag2 = fx * fx + fy * fy + fz * fz
let f_mag = sqrt(f_mag2)
check("T3 lj |F(r=r_eq)|≈0", f_mag < 1.0e-4,
      "|F|=" + to_string(f_mag))

// ── T4 — Verlet energy conservation over 1000 steps ──────────────────
//
// Two particles in an LJ well, initial offset from r_eq so the system
// oscillates. Vacuum BC, no thermostat. Velocity-Verlet is symplectic
// so total energy should drift only at O((dt)²) per step — well under
// 1% over 1000 steps at dt = 1e-3.
let p0 = mk_particle(0.0, 0.0, 0.0, 1.0)
let p1 = mk_particle(3.0, 0.0, 0.0, 1.0)
let initial = [p0, p1]

let dt = 1.0e-3
let n_steps = 1000

// Seed forces on the initial state so KE+PE at t=0 reflects the actual
// LJ configuration (mk_particle leaves fx/fy/fz=0 which is fine for
// energy; force values are only used by the integrator).
let init_state = initial
let e0 = total_energy(init_state, eps, sigma)

let final_state = verlet_run(init_state, dt, n_steps, eps, sigma)
let e_final = total_energy(final_state, eps, sigma)

let drift_abs = abs_f(e_final - e0)
let denom = if abs_f(e0) > 1.0e-12 { abs_f(e0) } else { 1.0e-12 }
let drift_rel = drift_abs / denom
check("T4 verlet energy-drift<1% over 1000 steps",
      drift_rel < 1.0e-2,
      "E0=" + to_string(e0)
      + " E_final=" + to_string(e_final)
      + " |ΔE|/|E0|=" + to_string(drift_rel))

// ── Verdict ──────────────────────────────────────────────────────────
println("")
if pass_count == total {
    println("PASS: md " + to_string(pass_count) + "/" + to_string(total))
    exit(0)
} else {
    println("FAIL: md first=" + first_fail
            + " (" + to_string(pass_count) + "/" + to_string(total) + ")")
    exit(1)
}
