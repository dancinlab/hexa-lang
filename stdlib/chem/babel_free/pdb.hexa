// stdlib/chem/babel_free/pdb.hexa — Protein Data Bank (PDB) ATOM/HETATM/CONECT subset.
//
// 사용자 결정 B-2 — open-babel (GPL-2) 회피 + scratch 구현.
// open-babel 소스/알고리즘/자료구조 참조 일절 없음.
// 공개 format 사양만 참조 :
//   - PDB format guide v3.3 (공개)
//     https://www.wwpdb.org/documentation/file-format-content/format33/v3.3.html
//
// 본 모듈이 다루는 record :
//   ATOM   — 단백질 표준 잔기 atom
//   HETATM — 비표준/리간드 atom
//   CONECT — 명시적 결합 정보 (serial + 최대 4 bonded serial)
//
// 그 외 (HEADER · TITLE · REMARK · SEQRES · CRYST1 · TER · END · 등) 무시 (parse-skip).
//
// PDB ATOM/HETATM column layout (1-based, fixed-width) :
//   01-06  record name (`ATOM  ` / `HETATM`)
//   07-11  serial
//   13-16  atom name
//   17     altLoc (subset 무시)
//   18-20  resName
//   22     chain ID
//   23-26  resSeq
//   31-38  x   (8.3f)
//   39-46  y   (8.3f)
//   47-54  z   (8.3f)
//   55-60  occupancy  (6.2f)
//   61-66  tempFactor (b-factor, 6.2f)
//   77-78  element
//   79-80  charge (subset 무시)
//
// CONECT layout :
//   01-06  "CONECT"
//   07-11  serial
//   12-16  bonded_1
//   17-21  bonded_2
//   22-26  bonded_3
//   27-31  bonded_4
//
// 공개 surface :
//   struct PdbAtom    { record_type · serial · name · resname · chain ·
//                       resnum · x · y · z · occupancy · b_factor · element }
//   struct PdbConect  { serial · bonded   ([int]) }
//   struct PdbStructure { atoms · conects }
//   pub fn parse_pdb(text: string)         -> PdbStructure
//   pub fn write_pdb(s: PdbStructure)      -> string

struct PdbAtom {
    record_type: string,   // "ATOM" 또는 "HETATM"
    serial: int,
    name: string,
    resname: string,
    chain: string,
    resnum: int,
    x: float,
    y: float,
    z: float,
    occupancy: float,
    b_factor: float,
    element: string,
}

struct PdbConect {
    serial: int,
    bonded: [int],   // 최대 4 entries
}

struct PdbStructure {
    atoms: [PdbAtom],
    conects: [PdbConect],
}

// ── 로컬 헬퍼 ────────────────────────────────────────────────────────

fn _is_ws_pdb(c: string) -> bool {
    return c == " " || c == "\t" || c == "\r" || c == "\n"
}

fn _trim_pdb(s: string) -> string {
    let n = len(s)
    let mut a = 0
    let mut b = n
    while a < b && _is_ws_pdb(s.substring(a, a + 1)) { a = a + 1 }
    while b > a && _is_ws_pdb(s.substring(b - 1, b)) { b = b - 1 }
    return s.substring(a, b)
}

fn _parse_f_pdb(s: string) -> float {
    let t = _trim_pdb(s)
    if len(t) == 0 { return 0.0 }
    return to_float(t)
}

fn _parse_i_pdb(s: string) -> int {
    let t = _trim_pdb(s)
    if len(t) == 0 { return 0 }
    return to_int(t)
}

fn _split_lines_pdb(text: string) -> [string] {
    let mut out: [string] = []
    let n = len(text)
    let mut i = 0
    let mut start = 0
    while i < n {
        let c = text.substring(i, i + 1)
        if c == "\n" {
            let mut e = i
            if e > start && text.substring(e - 1, e) == "\r" {
                e = e - 1
            }
            out.push(text.substring(start, e))
            start = i + 1
        }
        i = i + 1
    }
    if start < n {
        out.push(text.substring(start, n))
    }
    return out
}

// 한 줄의 [start, end) 슬라이스 — 줄이 짧으면 빈문자.
fn _slice_pdb(line: string, start: int, end: int) -> string {
    let n = len(line)
    if start >= n { return "" }
    let mut e = end
    if e > n { e = n }
    if e <= start { return "" }
    return line.substring(start, e)
}

// fixed-width emit helpers — write_pdb 용.

fn _fmt_iw_pdb(v: int, w: int) -> string {
    let mut s = to_string(v)
    while len(s) < w {
        s = " " + s
    }
    return s
}

// 부동소수 → fixed-width 8.3f
fn _fmt_f8_3(x: float) -> string {
    let mut neg = false
    let mut v = x
    if v < 0.0 {
        neg = true
        v = 0.0 - v
    }
    let scaled = v * 1000.0 + 0.5
    let mut whole_units = to_int(scaled)
    let int_part = whole_units / 1000
    let frac_part = whole_units - int_part * 1000
    let mut frac_str = to_string(frac_part)
    while len(frac_str) < 3 {
        frac_str = "0" + frac_str
    }
    let mut body = to_string(int_part) + "." + frac_str
    if neg {
        body = "-" + body
    }
    while len(body) < 8 {
        body = " " + body
    }
    return body
}

// 부동소수 → fixed-width 6.2f
fn _fmt_f6_2(x: float) -> string {
    let mut neg = false
    let mut v = x
    if v < 0.0 {
        neg = true
        v = 0.0 - v
    }
    let scaled = v * 100.0 + 0.5
    let mut whole_units = to_int(scaled)
    let int_part = whole_units / 100
    let frac_part = whole_units - int_part * 100
    let mut frac_str = to_string(frac_part)
    while len(frac_str) < 2 {
        frac_str = "0" + frac_str
    }
    let mut body = to_string(int_part) + "." + frac_str
    if neg {
        body = "-" + body
    }
    while len(body) < 6 {
        body = " " + body
    }
    return body
}

// width-w left-justified string (atom name, resname, etc.).
fn _fmt_sl_pdb(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w {
        out = out + " "
    }
    if len(out) > w {
        out = out.substring(0, w)
    }
    return out
}

// width-w right-justified string (element 2-char field).
fn _fmt_sr_pdb(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w {
        out = " " + out
    }
    if len(out) > w {
        out = out.substring(0, w)
    }
    return out
}

fn _starts_with(line: string, prefix: string) -> bool {
    let m = len(prefix)
    if len(line) < m { return false }
    return line.substring(0, m) == prefix
}

// ── parse ────────────────────────────────────────────────────────────

pub fn parse_pdb(text: string) -> PdbStructure {
    let lines = _split_lines_pdb(text)
    let nl = len(lines)
    let mut atoms: [PdbAtom] = []
    let mut conects: [PdbConect] = []

    let mut i = 0
    while i < nl {
        let ln = lines[i]
        if _starts_with(ln, "ATOM  ") || _starts_with(ln, "HETATM") {
            let rt = _trim_pdb(_slice_pdb(ln, 0, 6))
            let serial = _parse_i_pdb(_slice_pdb(ln, 6, 11))
            let name = _trim_pdb(_slice_pdb(ln, 12, 16))
            let resname = _trim_pdb(_slice_pdb(ln, 17, 20))
            let chain = _trim_pdb(_slice_pdb(ln, 21, 22))
            let resnum = _parse_i_pdb(_slice_pdb(ln, 22, 26))
            let x = _parse_f_pdb(_slice_pdb(ln, 30, 38))
            let y = _parse_f_pdb(_slice_pdb(ln, 38, 46))
            let z = _parse_f_pdb(_slice_pdb(ln, 46, 54))
            let occ = _parse_f_pdb(_slice_pdb(ln, 54, 60))
            let bf = _parse_f_pdb(_slice_pdb(ln, 60, 66))
            let elem = _trim_pdb(_slice_pdb(ln, 76, 78))
            atoms.push(PdbAtom {
                record_type: rt,
                serial: serial,
                name: name,
                resname: resname,
                chain: chain,
                resnum: resnum,
                x: x, y: y, z: z,
                occupancy: occ, b_factor: bf,
                element: elem,
            })
        } else {
            if _starts_with(ln, "CONECT") {
                let serial = _parse_i_pdb(_slice_pdb(ln, 6, 11))
                let mut bonded: [int] = []
                let b1 = _trim_pdb(_slice_pdb(ln, 11, 16))
                let b2 = _trim_pdb(_slice_pdb(ln, 16, 21))
                let b3 = _trim_pdb(_slice_pdb(ln, 21, 26))
                let b4 = _trim_pdb(_slice_pdb(ln, 26, 31))
                if len(b1) > 0 { bonded.push(to_int(b1)) }
                if len(b2) > 0 { bonded.push(to_int(b2)) }
                if len(b3) > 0 { bonded.push(to_int(b3)) }
                if len(b4) > 0 { bonded.push(to_int(b4)) }
                conects.push(PdbConect {
                    serial: serial, bonded: bonded,
                })
            }
            // 그 외 record (HEADER · TITLE · REMARK · SEQRES · CRYST1 ·
            // ANISOU · TER · END · MASTER · 등) silent skip.
        }
        i = i + 1
    }

    return PdbStructure {
        atoms: atoms, conects: conects,
    }
}

// ── write ────────────────────────────────────────────────────────────
//
// 본 subset 은 ATOM/HETATM + CONECT 만 emit. END 라인은 마지막에 1번.
//
// emit column 정확성 — PDB v3.3 spec 의 column 범위 그대로.

pub fn write_pdb(s: PdbStructure) -> string {
    let mut out = ""
    let na = len(s.atoms)
    let mut i = 0
    while i < na {
        let a = s.atoms[i]
        let mut rec = a.record_type
        // 6-char record name field — 좌측정렬, 부족시 공백 패딩.
        rec = _fmt_sl_pdb(rec, 6)

        let mut line = ""
        line = line + rec                            // 01-06
        line = line + _fmt_iw_pdb(a.serial, 5)       // 07-11
        line = line + " "                            // 12
        line = line + _fmt_sl_pdb(a.name, 4)         // 13-16
        line = line + " "                            // 17 (altLoc)
        line = line + _fmt_sl_pdb(a.resname, 3)      // 18-20
        line = line + " "                            // 21
        let mut ch = a.chain
        if len(ch) == 0 { ch = " " }
        line = line + ch.substring(0, 1)             // 22
        line = line + _fmt_iw_pdb(a.resnum, 4)       // 23-26
        line = line + "    "                         // 27-30 (iCode + 3 space)
        line = line + _fmt_f8_3(a.x)                 // 31-38
        line = line + _fmt_f8_3(a.y)                 // 39-46
        line = line + _fmt_f8_3(a.z)                 // 47-54
        line = line + _fmt_f6_2(a.occupancy)         // 55-60
        line = line + _fmt_f6_2(a.b_factor)          // 61-66
        line = line + "          "                   // 67-76 (10 spaces)
        line = line + _fmt_sr_pdb(a.element, 2)      // 77-78
        line = line + "  "                           // 79-80 (charge)
        out = out + line + "\n"
        i = i + 1
    }

    let nc = len(s.conects)
    let mut k = 0
    while k < nc {
        let c = s.conects[k]
        let mut line = "CONECT"
        line = line + _fmt_iw_pdb(c.serial, 5)
        let nb = len(c.bonded)
        let mut j = 0
        while j < nb && j < 4 {
            line = line + _fmt_iw_pdb(c.bonded[j], 5)
            j = j + 1
        }
        out = out + line + "\n"
        k = k + 1
    }

    out = out + "END\n"
    return out
}
