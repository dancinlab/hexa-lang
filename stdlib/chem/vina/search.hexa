// stdlib/chem/vina/search.hexa — Vina Monte Carlo + Iterated Local Search 검색 드라이버.
//
// @version 0.1.0
// @capabilities [pure, randomness]
//
// Citation: Trott, O. & Olson, A. J. (2010). "AutoDock Vina: Improving the
// speed and accuracy of docking with a new scoring function, efficient
// optimization, and multithreading." J. Comput. Chem. 31(2): 455-461.
// DOI: 10.1002/jcc.21334. §2.5 "Conformational sampling" — Vina 본가는
// (1) BFGS local optimization + (2) Iterated Local Search (ILS) +
// (3) Metropolis acceptance + (4) torsion DOF 를 결합한다. 본 모듈은
// gradient-free Metropolis-Hastings (MC) 만으로 검색을 구동하는 simplified
// 변형 — Vina 의 §2.5 acceptance criterion 과 ILS 구조를 그대로 따른다.
//
// SCOPE — Vina paper §2.5 의 두 축 충실 포팅:
//   1. Metropolis MC: 매 step 마다 리간드 pose 를 perturb → ΔE 계산 →
//      accept 확률 min(1, exp(-ΔE/kT)) 로 채택/기각.
//   2. Iterated Local Search (ILS): N_runs 회 시작점을 새로 뽑아 각자
//      MC 를 N_steps 돌리고, top-K (default K=9) 누적 best-pose 를 반환.
//
// Pose 표현 — Vina 본가의 (translation 3 + quaternion 4 + torsion N)
// 풀어드(full) 모델을 본 cycle 에서는 rigid-body 로 한정:
//
//   pub struct VinaPose {
//       atoms: [VinaAtom],   // 리간드 absolute coordinates (Å)
//       score: float,        // 평가 시점의 grid energy
//   }
//
// 토션 자유도는 deferred — atoms 배열을 직접 perturb 하는 rigid
// translation + small-angle rotation 만 수행한다. (Vina 본가에서
// torsion 가 활성화되는 ligand 는 .pdbqt 의 'BRANCH' 트리; 그 트리 빌더는
// PDBQT IO 와 함께 다음 cycle).
//
// 회전: small-angle rotation quaternion (axis = uniform-on-sphere,
// angle ~ Normal(0, σ_rot)). Pose centroid 기준으로 회전 → 평행이동.
//
// RNG: stdlib/core/math/rng.hexa 의 LCG + Box-Muller. seed → 결정적.
//
// Acceptance: kT 의 1 unit = Vina 본가의 1 kcal/mol·convention. 본
// 모듈 default kT = 1.2 (Vina paper §2.5 와 동일).

use "stdlib/chem/vina/scoring"
use "stdlib/chem/vina/grid"
use "stdlib/core/math/rng"

// ── Types ──────────────────────────────────────────────────────────────

pub struct VinaPose {
    atoms: [VinaAtom],
    score: float,
}

pub struct VinaSearchConfig {
    n_runs: int,        // ILS outer-loop restarts (Vina default 8)
    n_steps: int,       // MC inner-loop steps (Vina default 2500)
    k_top: int,         // top-K poses kept (Vina default 9)
    kT: float,          // Metropolis temperature (kcal/mol; default 1.2)
    sigma_trans: float, // translation step σ (Å; default 0.3)
    sigma_rot: float,   // rotation angle σ (rad; default 0.2 ≈ 11.5°)
    seed: int,          // PRNG seed (deterministic)
    xmin: float,        // search box (inclusive)
    ymin: float,
    zmin: float,
    xmax: float,
    ymax: float,
    zmax: float,
}

// ── Defaults ───────────────────────────────────────────────────────────

pub fn vina_search_config_default(seed: int, xmin: float, ymin: float, zmin: float, xmax: float, ymax: float, zmax: float) -> VinaSearchConfig {
    return VinaSearchConfig {
        n_runs: 8,
        n_steps: 2500,
        k_top: 9,
        kT: 1.2,
        sigma_trans: 0.3,
        sigma_rot: 0.2,
        seed: seed,
        xmin: xmin, ymin: ymin, zmin: zmin,
        xmax: xmax, ymax: ymax, zmax: zmax,
    }
}

// ── RNG helpers ────────────────────────────────────────────────────────

fn _u01(state: int) -> array {
    return lcg_float01(state)
}

fn _normal_1(state: int) -> array {
    // returns [new_state, sample]
    let pack = randn_box_muller(state)
    return [pack[0], pack[1]]
}

// Uniform sample in [lo, hi].
fn _uniform(state: int, lo: float, hi: float) -> array {
    let pack = lcg_float01(state)
    let u = pack[1]
    return [pack[0], lo + (hi - lo) * u]
}

// ── Pose utilities ─────────────────────────────────────────────────────

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _centroid(atoms: [VinaAtom]) -> array {
    let n = len(atoms)
    if n == 0 { return [0.0, 0.0, 0.0] }
    let mut sx = 0.0
    let mut sy = 0.0
    let mut sz = 0.0
    let mut i = 0
    while i < n {
        let a = atoms[i]
        sx = sx + a.x
        sy = sy + a.y
        sz = sz + a.z
        i = i + 1
    }
    let nf = to_float(n)
    return [sx / nf, sy / nf, sz / nf]
}

fn _clone_atoms(src: [VinaAtom]) -> [VinaAtom] {
    let mut out: [VinaAtom] = []
    let n = len(src)
    let mut i = 0
    while i < n {
        let a = src[i]
        out.push(VinaAtom { x: a.x, y: a.y, z: a.z, atype: a.atype })
        i = i + 1
    }
    return out
}

// Translate all atoms by (dx, dy, dz). Returns new array.
fn _translate(atoms: [VinaAtom], dx: float, dy: float, dz: float) -> [VinaAtom] {
    let mut out: [VinaAtom] = []
    let n = len(atoms)
    let mut i = 0
    while i < n {
        let a = atoms[i]
        out.push(VinaAtom { x: a.x + dx, y: a.y + dy, z: a.z + dz, atype: a.atype })
        i = i + 1
    }
    return out
}

// Rotate atoms about centroid via Rodrigues formula on unit axis (ux,uy,uz).
// theta in radians. Returns new array.
fn _rotate_about_centroid(atoms: [VinaAtom], ux: float, uy: float, uz: float, theta: float) -> [VinaAtom] {
    let c = _centroid(atoms)
    let cx = c[0]
    let cy = c[1]
    let cz = c[2]
    let ct = cos(theta)
    let st = sin(theta)
    let one_m_ct = 1.0 - ct

    let mut out: [VinaAtom] = []
    let n = len(atoms)
    let mut i = 0
    while i < n {
        let a = atoms[i]
        let px = a.x - cx
        let py = a.y - cy
        let pz = a.z - cz

        // Rodrigues: R p = p ct + (u × p) st + u (u·p)(1-ct)
        let dot = ux * px + uy * py + uz * pz
        let crx = uy * pz - uz * py
        let cry = uz * px - ux * pz
        let crz = ux * py - uy * px

        let nx = px * ct + crx * st + ux * dot * one_m_ct
        let ny = py * ct + cry * st + uy * dot * one_m_ct
        let nz = pz * ct + crz * st + uz * dot * one_m_ct

        out.push(VinaAtom { x: cx + nx, y: cy + ny, z: cz + nz, atype: a.atype })
        i = i + 1
    }
    return out
}

// Uniform-on-sphere axis (Marsaglia 1972). Returns [state, ux, uy, uz].
fn _random_unit_axis(state: int) -> array {
    let mut s = state
    let mut iters = 0
    while iters < 32 {
        let p1 = _uniform(s, 0.0 - 1.0, 1.0)
        s = p1[0]
        let v1 = p1[1]
        let p2 = _uniform(s, 0.0 - 1.0, 1.0)
        s = p2[0]
        let v2 = p2[1]
        let r2 = v1 * v1 + v2 * v2
        if r2 < 1.0 && r2 > 0.0 {
            let sq = sqrt(1.0 - r2)
            let ux = 2.0 * v1 * sq
            let uy = 2.0 * v2 * sq
            let uz = 1.0 - 2.0 * r2
            return [s, ux, uy, uz]
        }
        iters = iters + 1
    }
    // Fallback (extremely unlikely).
    return [s, 1.0, 0.0, 0.0]
}

// ── Scoring wrapper ────────────────────────────────────────────────────

// Score a pose either via grid lookup (fast) or direct receptor pair-sum
// (slow but exact). If `grids` is non-empty we use vina_grid_eval_ligand;
// otherwise vina_score_complex.
fn _score_pose(grids: [VinaGrid], receptor: [VinaAtom], atoms: [VinaAtom]) -> float {
    if len(grids) > 0 {
        return vina_grid_eval_ligand(grids, receptor, atoms)
    }
    return vina_score_complex(atoms, receptor)
}

// ── MC inner loop ──────────────────────────────────────────────────────

// Single MC run. Returns [final_state, best_pose].
//
// State machine:
//   current = initial; best = current.
//   for step in 1..=n_steps:
//       propose translation N(0, σ_trans) per axis + rotation
//       angle ~ N(0, σ_rot) about uniform-sphere axis.
//       ΔE = E(proposed) - E(current).
//       Metropolis: accept if u01 < exp(-ΔE / kT).
//       update best if E(proposed) < E(best).
fn _mc_run(state: int, cfg: VinaSearchConfig, grids: [VinaGrid], receptor: [VinaAtom], start_atoms: [VinaAtom]) -> array {
    let mut s = state
    let mut cur = _clone_atoms(start_atoms)
    let mut cur_e = _score_pose(grids, receptor, cur)
    let mut best = _clone_atoms(cur)
    let mut best_e = cur_e

    let mut step = 0
    while step < cfg.n_steps {
        // Translation increments (3 independent normals).
        let nz0 = _normal_1(s)
        s = nz0[0]
        let dx = cfg.sigma_trans * nz0[1]
        let nz1 = _normal_1(s)
        s = nz1[0]
        let dy = cfg.sigma_trans * nz1[1]
        let nz2 = _normal_1(s)
        s = nz2[0]
        let dz = cfg.sigma_trans * nz2[1]

        // Rotation: uniform axis + Normal(0, σ_rot) angle.
        let ax = _random_unit_axis(s)
        s = ax[0]
        let ux = ax[1]
        let uy = ax[2]
        let uz = ax[3]
        let na = _normal_1(s)
        s = na[0]
        let theta = cfg.sigma_rot * na[1]

        let rotated = _rotate_about_centroid(cur, ux, uy, uz, theta)
        let proposed = _translate(rotated, dx, dy, dz)
        let prop_e = _score_pose(grids, receptor, proposed)

        let de = prop_e - cur_e
        let mut accept = false
        if de <= 0.0 {
            accept = true
        } else {
            let pu = _u01(s)
            s = pu[0]
            let u = pu[1]
            let p_accept = exp(0.0 - de / cfg.kT)
            if u < p_accept { accept = true }
        }

        if accept {
            cur = proposed
            cur_e = prop_e
            if cur_e < best_e {
                best = _clone_atoms(cur)
                best_e = cur_e
            }
        }

        step = step + 1
    }

    return [s, VinaPose { atoms: best, score: best_e }]
}

// ── Random restart pose ────────────────────────────────────────────────

// Translate the ligand so that its centroid sits at a uniform-random
// point inside the box, with a uniform-random initial rotation.
fn _random_restart(state: int, cfg: VinaSearchConfig, ligand: [VinaAtom]) -> array {
    let c = _centroid(ligand)
    let cx0 = c[0]
    let cy0 = c[1]
    let cz0 = c[2]

    let p1 = _uniform(state, cfg.xmin, cfg.xmax)
    let s1 = p1[0]
    let nx = p1[1]
    let p2 = _uniform(s1, cfg.ymin, cfg.ymax)
    let s2 = p2[0]
    let ny = p2[1]
    let p3 = _uniform(s2, cfg.zmin, cfg.zmax)
    let s3 = p3[0]
    let nz = p3[1]

    let translated = _translate(ligand, nx - cx0, ny - cy0, nz - cz0)

    // Uniform initial rotation: angle in [0, 2π] about random axis.
    let ax = _random_unit_axis(s3)
    let s4 = ax[0]
    let ux = ax[1]
    let uy = ax[2]
    let uz = ax[3]
    let pa = _uniform(s4, 0.0, 6.283185307179586)
    let s5 = pa[0]
    let theta = pa[1]
    let rotated = _rotate_about_centroid(translated, ux, uy, uz, theta)

    return [s5, rotated]
}

// ── Top-K bookkeeping ──────────────────────────────────────────────────

// Insert candidate into a sorted-ascending-by-score [VinaPose] list,
// truncate to length k.
fn _insert_topk(top: [VinaPose], cand: VinaPose, k: int) -> [VinaPose] {
    let mut out: [VinaPose] = []
    let n = len(top)
    let mut inserted = false
    let mut i = 0
    while i < n {
        let t = top[i]
        if !inserted && cand.score < t.score {
            out.push(cand)
            inserted = true
        }
        out.push(t)
        i = i + 1
    }
    if !inserted {
        out.push(cand)
    }
    // Truncate.
    if len(out) > k {
        let mut truncated: [VinaPose] = []
        let mut j = 0
        while j < k {
            truncated.push(out[j])
            j = j + 1
        }
        return truncated
    }
    return out
}

// ── Public driver ──────────────────────────────────────────────────────

// Iterated Local Search: cfg.n_runs MC restarts, each cfg.n_steps long,
// keeping top cfg.k_top poses sorted ascending by score (Vina convention:
// more negative = better binding).
//
// Returns [VinaPose] of length ≤ cfg.k_top.
pub fn vina_search(receptor: [VinaAtom], ligand: [VinaAtom], grids: [VinaGrid], cfg: VinaSearchConfig) -> [VinaPose] {
    let mut s = cfg.seed & 0xFFFFFFFF
    let mut top: [VinaPose] = []
    let mut run = 0
    while run < cfg.n_runs {
        let rr = _random_restart(s, cfg, ligand)
        s = rr[0]
        let start_atoms = rr[1]
        let mc = _mc_run(s, cfg, grids, receptor, start_atoms)
        s = mc[0]
        let best = mc[1]
        top = _insert_topk(top, best, cfg.k_top)
        run = run + 1
    }
    return top
}

// Convenience: single-run wrapper that exposes the inner MC loop with
// caller-supplied starting pose (no random restart). Useful for tests that
// need deterministic convergence from a fixed start.
pub fn vina_mc_single(receptor: [VinaAtom], ligand: [VinaAtom], grids: [VinaGrid], cfg: VinaSearchConfig) -> VinaPose {
    let s = cfg.seed & 0xFFFFFFFF
    let mc = _mc_run(s, cfg, grids, receptor, ligand)
    return mc[1]
}
