// stdlib/chem/vina/scoring_test.hexa — analytic oracle for Vina 5-term energy.
//
// Each case compares vina_pair_energy / vina_score_complex against a
// closed-form analytic sum the test computes on the fly from the Vina
// paper's term formulas (Trott & Olson 2010, §2). No network, no python
// shellout. Tolerance ±1e-4 (floating-point arithmetic).
//
//   T1 C–C    surface r=+0.1  hydrophobic active, no h-bond
//   T2 C–C    surface r=+2.6  hydrophobic off (>1.5), no h-bond
//   T3 cutoff d=12 Å score_complex returns 0  (beyond 8 Å)
//   T4 N_HD–OA r=-0.7  h_bond term fully active (== w5)
//   T5 score_complex 3×3  == manual sum of 9 pair energies

import "scoring.hexa"

let mut pass_count = 0
let mut total = 0
let mut first_fail = ""

fn abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn check(name: string, cond: bool, detail: string) {
    total = total + 1
    if cond {
        pass_count = pass_count + 1
        println("  ok : " + name + " " + detail)
    } else {
        if first_fail == "" { first_fail = name }
        println("  FAIL " + name + " " + detail)
    }
}

// Canonical Vina weights — duplicated locally to keep the test
// independent of the source-file constants (analytic oracle SSOT).
let W1 = 0.0 - 0.0356
let W2 = 0.0 - 0.00516
let W3 = 0.840
let W4 = 0.0 - 0.0351
let W5 = 0.0 - 0.587

// ── T1 — two C atoms at distance 3.5 Å (surface r = +0.1) ────────────
let c1a = VinaAtom { x: 0.0, y: 0.0, z: 0.0, atype: "C" }
let c1b = VinaAtom { x: 3.5, y: 0.0, z: 0.0, atype: "C" }
let r1  = 3.5 - 1.7 - 1.7                  // = 0.1
let g1_1 = exp(0.0 - (r1 / 0.5) * (r1 / 0.5))
let g2_1 = exp(0.0 - ((r1 - 3.0) / 2.0) * ((r1 - 3.0) / 2.0))
let rep_1 = 0.0                            // r > 0
let hp_1 = 1.0                             // r ≤ 0.5 → fully on (hydrophobic both)
let hb_1 = 0.0                             // C-C is not donor-acceptor
let e1_ref = W1 * g1_1 + W2 * g2_1 + W3 * rep_1 + W4 * hp_1 + W5 * hb_1
let e1_num = vina_pair_energy(c1a, c1b)
let err1   = abs_f(e1_num - e1_ref)
check("T1 C–C r=+0.1",
      err1 <= 1.0e-4,
      "num=" + to_string(e1_num) + " ref=" + to_string(e1_ref)
      + " |err|=" + to_string(err1))

// ── T2 — two C atoms at distance 6.0 Å (surface r = +2.6) ────────────
let c2a = VinaAtom { x: 0.0, y: 0.0, z: 0.0, atype: "C" }
let c2b = VinaAtom { x: 6.0, y: 0.0, z: 0.0, atype: "C" }
let r2  = 6.0 - 1.7 - 1.7                  // = 2.6
let g1_2 = exp(0.0 - (r2 / 0.5) * (r2 / 0.5))
let g2_2 = exp(0.0 - ((r2 - 3.0) / 2.0) * ((r2 - 3.0) / 2.0))
let rep_2 = 0.0                            // r > 0
let hp_2 = 0.0                             // r ≥ 1.5 → off
let hb_2 = 0.0
let e2_ref = W1 * g1_2 + W2 * g2_2 + W3 * rep_2 + W4 * hp_2 + W5 * hb_2
let e2_num = vina_pair_energy(c2a, c2b)
let err2   = abs_f(e2_num - e2_ref)
check("T2 C–C r=+2.6",
      err2 <= 1.0e-4,
      "num=" + to_string(e2_num) + " ref=" + to_string(e2_ref)
      + " |err|=" + to_string(err2))

// ── T3 — score_complex cutoff at d > 8 Å (single pair at d=12) ───────
let c3a = VinaAtom { x:  0.0, y: 0.0, z: 0.0, atype: "C" }
let c3b = VinaAtom { x: 12.0, y: 0.0, z: 0.0, atype: "C" }
let mut as3: [VinaAtom] = []
let mut bs3: [VinaAtom] = []
as3.push(c3a)
bs3.push(c3b)
let e3_num = vina_score_complex(as3, bs3)
check("T3 score_complex cutoff d=12",
      abs_f(e3_num) <= 1.0e-12,
      "num=" + to_string(e3_num))

// ── T4 — donor–acceptor N_HD/OA at d = 2.8 Å (surface r = -0.7) ──────
//   _h_bond_ramp(-0.7) == 1.0, so the h_bond term contributes exactly w5.
let c4a = VinaAtom { x: 0.0, y: 0.0, z: 0.0, atype: "N_HD" }
let c4b = VinaAtom { x: 2.8, y: 0.0, z: 0.0, atype: "OA" }
let r4  = 2.8 - 1.8 - 1.7                  // = -0.7
let g1_4 = exp(0.0 - (r4 / 0.5) * (r4 / 0.5))
let g2_4 = exp(0.0 - ((r4 - 3.0) / 2.0) * ((r4 - 3.0) / 2.0))
let rep_4 = r4 * r4                        // r < 0 → r²
let hp_4 = 0.0                             // N/O not hydrophobic
let hb_4 = 1.0                             // r ≤ -0.7 → fully on
let e4_ref = W1 * g1_4 + W2 * g2_4 + W3 * rep_4 + W4 * hp_4 + W5 * hb_4
let e4_num = vina_pair_energy(c4a, c4b)
let err4   = abs_f(e4_num - e4_ref)
check("T4 N_HD–OA r=-0.7 (h_bond on)",
      err4 <= 1.0e-4,
      "num=" + to_string(e4_num) + " ref=" + to_string(e4_ref)
      + " |err|=" + to_string(err4))

// T4b — also verify the h_bond TERM contributes exactly W5 by computing
// the analytic energy WITHOUT the h_bond addend and asserting the
// numeric minus W5 matches.
let e4_no_hb_ref = W1 * g1_4 + W2 * g2_4 + W3 * rep_4 + W4 * hp_4
let err4b = abs_f((e4_num - W5) - e4_no_hb_ref)
check("T4b h_bond addend == W5",
      err4b <= 1.0e-4,
      "delta=" + to_string(e4_num - W5)
      + " no_hb_ref=" + to_string(e4_no_hb_ref)
      + " |err|=" + to_string(err4b))

// ── T5 — score_complex 3 × 3 vs manual sum of 9 pair energies ────────
//   Place set A along x, set B along y; ranges chosen so all 9 pairs
//   are within the 8 Å cutoff (max d ≈ √(2²+2²) ≈ 2.83).
let mut sa: [VinaAtom] = []
let mut sb: [VinaAtom] = []
sa.push(VinaAtom { x: 0.0, y: 0.0, z: 0.0, atype: "C" })
sa.push(VinaAtom { x: 1.5, y: 0.0, z: 0.0, atype: "N" })
sa.push(VinaAtom { x: 3.0, y: 0.0, z: 0.0, atype: "O" })
sb.push(VinaAtom { x: 0.0, y: 1.0, z: 0.0, atype: "C" })
sb.push(VinaAtom { x: 0.0, y: 2.5, z: 0.0, atype: "OA" })
sb.push(VinaAtom { x: 0.0, y: 4.0, z: 0.0, atype: "N_HD" })

let mut manual_sum = 0.0
let mut mi = 0
while mi < 3 {
    let mut mj = 0
    while mj < 3 {
        manual_sum = manual_sum + vina_pair_energy(sa[mi], sb[mj])
        mj = mj + 1
    }
    mi = mi + 1
}
let e5_num = vina_score_complex(sa, sb)
let err5   = abs_f(e5_num - manual_sum)
check("T5 score_complex 3×3 == manual sum",
      err5 <= 1.0e-4,
      "score=" + to_string(e5_num)
      + " manual=" + to_string(manual_sum)
      + " |err|=" + to_string(err5))

// ── Verdict ──────────────────────────────────────────────────────────
println("")
if pass_count == total {
    println("PASS: vina " + to_string(pass_count) + "/" + to_string(total))
    exit(0)
} else {
    println("FAIL: vina first=" + first_fail
            + " (" + to_string(pass_count) + "/" + to_string(total) + ")")
    exit(1)
}
