// stdlib/chem/rdkit_subset/rdkit_subset_test.hexa — measured-oracle gate.
//
// 7 published SMILES with known molecular weight + Hill formula. MW
// tolerance ±0.05 (NIST 2018 atomic-weight revisions drift in the 2nd-3rd
// decimal vs older PubChem tables — see atomic_weights.hexa header).
//
// Deferred features (logP, HBA, HBD, TPSA) are NOT tested here — they
// land in follow-up milestones.

use "stdlib/chem/rdkit_subset/smiles"
use "stdlib/chem/rdkit_subset/molecule"

let MW_TOL = 0.05

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _close(a: float, b: float, tol: float) -> bool {
    return _abs_f(a - b) <= tol
}

let mut fail_count = 0
let mut pass_count = 0

fn _fmt_f(x: float) -> string {
    // float-to-string: round to 2 decimals via integer trick.
    let scaled = x * 100.0
    let mut ipart = to_int(scaled)
    // round half-away-from-zero
    let frac = scaled - to_float(ipart)
    if frac >= 0.5  { ipart = ipart + 1 }
    if frac <= 0.0 - 0.5 { ipart = ipart - 1 }
    let whole = ipart / 100
    let mut rem = ipart - whole * 100
    if rem < 0 { rem = 0 - rem }
    let mut rs = to_string(rem)
    if rem < 10 { rs = "0" + rs }
    return to_string(whole) + "." + rs
}

fn _check_case(label: string, smi: string, want_formula: string, want_mw: float) {
    let mol = parse_smiles(smi)
    let got_formula = molecular_formula(mol)
    let got_mw = molecular_weight(mol)
    let formula_ok = got_formula == want_formula
    let mw_ok = _close(got_mw, want_mw, MW_TOL)
    if formula_ok && mw_ok {
        pass_count = pass_count + 1
        println("  OK  " + label + "  smi=" + smi
            + "  formula=" + got_formula
            + "  mw=" + _fmt_f(got_mw)
            + "  (want mw=" + _fmt_f(want_mw) + " ±" + _fmt_f(MW_TOL) + ")")
    } else {
        fail_count = fail_count + 1
        println("FAIL  " + label + "  smi=" + smi)
        println("        want_formula=" + want_formula + "  got_formula=" + got_formula)
        println("        want_mw=" + _fmt_f(want_mw) + "  got_mw=" + _fmt_f(got_mw)
            + "  tol=" + _fmt_f(MW_TOL))
    }
}

fn main() {
    println("rdkit_subset measured-oracle gate (tol=±0.05 MW; logP/TPSA/HBA/HBD deferred)")
    _check_case("methane",         "C",                          "CH4",   16.04)
    _check_case("ethane",          "CC",                         "C2H6",  30.07)
    _check_case("ethanol",         "CCO",                        "C2H6O", 46.07)
    _check_case("acetic_acid",     "CC(=O)O",                    "C2H4O2", 60.05)
    _check_case("benzene",         "c1ccccc1",                   "C6H6",  78.11)
    _check_case("aspirin",         "CC(=O)Oc1ccccc1C(=O)O",      "C9H8O4", 180.16)
    _check_case("nitromethane",    "C[N+](=O)[O-]",              "CH3NO2", 61.04)

    if fail_count > 0 {
        println("FAIL: rdkit_subset oracle " + to_string(pass_count) + "/"
            + to_string(pass_count + fail_count))
        exit(1)
    }
    println("PASS: rdkit_subset SMILES parser + MW + formula oracle ("
        + to_string(pass_count) + " cases, tol=±0.05 MW; logP/TPSA/HBA/HBD deferred)")
}
