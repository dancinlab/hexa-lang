// stdlib/chem/rdkit_subset/atomic_weights.hexa — NIST 2018 standard
// atomic weights for the organic-subset element set.
//
// Values are the IUPAC "conventional" atomic weights (NIST 2018 table,
// Pure Appl. Chem. 88(3), 265-291, last updated 2021). Where IUPAC
// publishes an interval (e.g. H = [1.00784, 1.00811]) we use the
// conventional midpoint commonly cited by RDKit/PubChem.
//
//   H = 1.008      C = 12.011     N = 14.007    O = 15.999
//   F = 18.998     P = 30.974     S = 32.06
//   Cl= 35.45      Br= 79.904     I = 126.90
//   B = 10.81      Si= 28.085
//
// Tolerance: callers should allow ±0.05 on per-molecule MW because
// (a) NIST 2018 vs older PubChem tables drift in the 2nd-3rd decimal
// (C: 12.0107 → 12.011) and (b) implicit-H counts here are valence-
// completion-based, not SMILES-canonical.
//
// Deferred (NOT in this PR):
//   - isotope-resolved monoisotopic masses (TPSA cycle).
//   - the full periodic table beyond the organic subset (covers <99% of
//     drug-like molecules — enough for TTR M3 docking input prep).

pub fn atomic_weight(symbol: string) -> float {
    if symbol == "H"  { return 1.008    }
    if symbol == "C"  { return 12.011   }
    if symbol == "N"  { return 14.007   }
    if symbol == "O"  { return 15.999   }
    if symbol == "F"  { return 18.998   }
    if symbol == "P"  { return 30.974   }
    if symbol == "S"  { return 32.06    }
    if symbol == "Cl" { return 35.45    }
    if symbol == "Br" { return 79.904   }
    if symbol == "I"  { return 126.90   }
    if symbol == "B"  { return 10.81    }
    if symbol == "Si" { return 28.085   }
    // Defensive fallback — caller treats 0.0 as "unknown element". A
    // visible warning helps debug oracle drift without aborting.
    println("[atomic_weights] WARN: unknown element symbol '" + symbol + "' — using 0.0")
    return 0.0
}

// Default valence used for implicit-H count when an atom is not bracketed
// (i.e. `C`, `N`, `O`, etc. with no `[…]`). Aromatic lowercase atoms
// inherit the same defaults — aromaticity is handled by the parser.
//
//   C → 4   N → 3   O → 2   S → 2   P → 3
//   F/Cl/Br/I → 1   B → 3   default → 0 (no implicit H)
pub fn default_valence(symbol: string) -> int {
    if symbol == "C"  { return 4 }
    if symbol == "N"  { return 3 }
    if symbol == "O"  { return 2 }
    if symbol == "S"  { return 2 }
    if symbol == "P"  { return 3 }
    if symbol == "F"  { return 1 }
    if symbol == "Cl" { return 1 }
    if symbol == "Br" { return 1 }
    if symbol == "I"  { return 1 }
    if symbol == "B"  { return 3 }
    return 0
}
