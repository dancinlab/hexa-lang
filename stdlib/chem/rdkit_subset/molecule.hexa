// stdlib/chem/rdkit_subset/molecule.hexa — Molecule analytics.
//
// Public surface:
//   pub fn molecular_weight(mol: Molecule) -> float
//   pub fn molecular_formula(mol: Molecule) -> string
//
// Both consume the typed Molecule struct produced by parse_smiles().
//
// Deferred (NOT in this PR):
//   - logP (Crippen)
//   - HBA / HBD counts (SMARTS-based)
//   - TPSA (topological polar surface area)
//   - 2D / 3D coordinates
//   - canonical SMILES output

use "stdlib/chem/rdkit_subset/smiles"
use "stdlib/chem/rdkit_subset/atomic_weights"

// Sum of (atomic weight × count) over all heavy atoms, PLUS hydrogen
// contribution from each atom's hcount field.
//
// Implicit-H counts already include explH brackets (parse_smiles merges
// them onto the same field), so the caller doesn't need separate accounting.
pub fn molecular_weight(mol: Molecule) -> float {
    let mut total = 0.0
    let h_w = atomic_weight("H")
    let mut i = 0
    while i < len(mol.atoms) {
        let a = mol.atoms[i]
        let w = atomic_weight(a.symbol)
        total = total + w
        total = total + h_w * to_float(a.hcount)
        i = i + 1
    }
    return total
}

// Canonical Hill-formula string ("C9H8O4" for aspirin). Atoms ordering:
//   C first, H next, then alphabetical.
//
// The formula is also pre-built at parse time into mol.formula — this
// wrapper exists for the documented public surface (matches the RFC's
// intent that downstream callers don't need to know about the cached
// field).
pub fn molecular_formula(mol: Molecule) -> string {
    return mol.formula
}
