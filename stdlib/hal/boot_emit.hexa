#!hexa strict
// stdlib/hal/boot_emit.hexa — F5 RFC 063/064 Component 3-lite + 5 composer.
//
// Pure-hexa `.s`-text full-boot composer. Combines:
//   - stdlib/hal/vector_table_emit.hexa  (Component 2-lite, vector table)
//   - stdlib/hal/reset_prologue_emit.hexa (Component 3-lite, reset prologue)
//
// Output: a single `.s` file string that, when fed to
// `arm-none-eabi-as`, assembles to a byte-identical ELF object to the
// hand-written `boot_<mcu>.s`. This is the surface the build recipe
// (`Makefile.rp2040`) calls to drop the `.s` file from git.
//
// Phase: foundation (PR2 of F5 re-open per RUNTIME.floor.md §F5).
// Replaces the hand-written stdlib/hal/t3/boot_rp2040.s on byte-diff
// PASS (oracle: stdlib/hal/t3/boot_byte_diff_rp2040.hexa).

use "stdlib/hal/vector_table_emit"
use "stdlib/hal/reset_prologue_emit"

let MODULE_NAME = "boot_emit"

// ─── primary API ────────────────────────────────────────────────────
//
// emit_full_boot_s: emits the complete boot `.s` text (banner +
// prelude + vector table + reset prologue). One file → one `as`
// invocation → byte-identical to hand-written boot.
//
// Note: this avoids emitting `.syntax/.thumb/.cpu` twice; the vector-
// table emitter's prelude is reused for the whole file, and the
// reset-prologue body (no prelude) is appended after the vector table.

fn emit_full_boot_s(
    header_banner: str,
    cpu: str,
    section_name: str,
    section_flags: str,
    table_label: str,
    slot_symbols: [str],
    slot_thumb: [bool],
    slot_comments: [str],
    pad_words: int,
    entry_fn: str,
    stack_sym: str,
    data_src: str,
    data_dst_s: str,
    data_dst_e: str,
    bss_s: str,
    bss_e: str
) -> str {
    // Vector-table emitter emits banner + prelude + vector table.
    let vt = vt_emit_section(
        header_banner,
        cpu,
        section_name,
        section_flags,
        table_label,
        slot_symbols,
        slot_thumb,
        slot_comments,
        pad_words
    )
    // Reset-prologue body (no prelude — reused from vt above).
    let pl = rp_emit_prologue_body(
        entry_fn, stack_sym, data_src, data_dst_s, data_dst_e, bss_s, bss_e
    )
    return vt + "\n" + pl
}

// ─── canned shape (rp2040 boot_rp2040.s mirror) ────────────────────

fn rp2040_emit_full_boot_s() -> str {
    let banner = "/* AUTO-GENERATED by stdlib/hal/boot_emit.hexa\n" +
                 " * RP2040 ARMv6-M (Cortex-M0+) full boot (vector + prologue).\n" +
                 " * Composes vector_table_emit + reset_prologue_emit.\n" +
                 " * Byte-identity oracle: stdlib/hal/t3/boot_byte_diff_rp2040.hexa\n" +
                 " * Do not hand-edit — regenerate via the emit fn. */"
    return emit_full_boot_s(
        banner,
        "cortex-m0plus",
        ".vector_table",
        "\"a\", %progbits",
        "_vector_table",
        rp2040_vt_symbols(),
        rp2040_vt_thumb(),
        rp2040_vt_comments(),
        rp2040_vt_pad_words(),
        "harness_main",
        "_stack_top",
        "_etext",
        "_sdata",
        "_edata",
        "_sbss",
        "_ebss"
    )
}
