#!hexa strict
// stdlib/hal/numerics_gpgpu_dispatch.hexa — F-GPGPU-4 T2 numerical.
//
// Closes the T2 (numerical / fixture) tier of falsifier F-GPGPU-4
// (J₂′ = σ · τ = 48 dispatch-state combinations; falsifier_gpgpu_check
// .hexa registry).
//
// T1 (compute.hexa internal asserts: compute_invariant_J2_prime() = 48)
// closes the algebraic identity:
//
//   J₂′ = σ_gpgpu · τ_gpgpu = 12 · 4 = 48
//
// T2 (this script) cross-checks the combinatorial state-space NUMERICALLY
// by enumerating (vendor, stage) tuples on disk + cross-checking that
// compute.hexa declares the matching invariant accessor:
//
//   1. σ · τ = 12 · 4 = 48 algebraic re-assert.
//   2. compute.hexa declares fn compute_invariant_J2_prime() returning 48.
//   3. Per-vendor stage coverage: 6 vendors × 4 stages = 24 (vendor, stage)
//      cells. The aggregate "filled" count (cell has a matching surface
//      fn) must clear floor 6·3 = 18 (every vendor has ≥ 3-of-4 stages,
//      same floor as F-GPGPU-2).
//   4. (vendor, IR) edge map (from F-GPGPU-3) sums to ≥ 6 — cross-check
//      that φ-axis projection is consistent.
//   5. Combined dispatch state-space exposed: |vendors × stages × IRs|
//      ≥ floor 6 · 3 · 1 = 18 (every vendor has ≥1 IR, ≥3 stages → at
//      least 18 reachable states, well below the canonical J₂′=48
//      ceiling but above the 18-floor regression gate).
//   6. No (vendor, stage, IR) combination claims a NATIVE-only IR
//      outside {ptx, spirv} as PRIMARY without ALSO declaring a
//      canonical IR fallback — guards the dichotomy projection.
//
// PASS = all 6 numerical identities hold against on-disk backend table.
// FAIL = any identity drifts.
//
// Run:
//   hexa run stdlib/hal/numerics_gpgpu_dispatch.hexa
//
// Cost: $0 (file-reads + grep; no compilation).
//
// Phase G iter 9+5+4; F-GPGPU-4 closure 33% → 67% (T1+T2 ✓; T3 deferred).
// Pattern: numerics_handle_dispatch.hexa (sister F-HAL-4 T2 fixture —
// it scores J₂/n=4 handle-pool; this scores J₂′=48 dispatch-state
// space).

// ─── n=6 lattice constants ────────────────────────────────────────────

let TAU_GPGPU         = 4
let GPGPU_VENDORS_N   = 6
let GPGPU_IRS_N       = 2
let SIGMA_GPGPU       = GPGPU_VENDORS_N * GPGPU_IRS_N      // = 12
let J2_PRIME          = SIGMA_GPGPU * TAU_GPGPU            // = 48

// Aggregate floor: each vendor has ≥3-of-4 stages → Σ ≥ 6·3 = 18.
let STAGE_AGGREGATE_FLOOR = GPGPU_VENDORS_N * (TAU_GPGPU - 1)   // = 18

// (vendor × stage × IR) reachable-state floor: vendors · 3 · 1 = 18.
let TUPLE_AGGREGATE_FLOOR = GPGPU_VENDORS_N * (TAU_GPGPU - 1) * 1   // = 18

// ─── vendor + IR rosters ──────────────────────────────────────────────

let VENDORS = [
    "cuda", "hip", "sycl", "opencl", "metal", "webgpu"
]
let CANONICAL_IRS = ["ptx", "spirv"]

// ─── τ=4 stage archetypal fn-suffixes (mirror F-GPGPU-2) ──────────────

fn _compile_suffixes() -> [str] { return ["_kernel_compile"] }
fn _enqueue_suffixes() -> [str] { return ["_buffer_h2d", "_buffer_alloc"] }
fn _dispatch_suffixes() -> [str] { return ["_dispatch"] }
fn _retire_suffixes() -> [str] { return ["_event_wait", "_event_release"] }

// ─── check harness ───────────────────────────────────────────────────

let mut RUN  = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ─── helpers ─────────────────────────────────────────────────────────

fn _root() -> str {
    let env_root = env("HEXA_HAL_ROOT")
    if env_root.len() > 0 { return env_root }
    return exec("pwd").trim()
}

fn _exists(p: str) -> bool {
    let r = exec("[ -f \"" + p + "\" ] && echo y || echo n").trim()
    return r == "y"
}

fn _stage_present(src: str, vendor: str, suffixes: [str]) -> bool {
    for sfx in suffixes {
        let pat = "fn " + vendor + sfx + "("
        if src.contains(pat) { return true }
    }
    return false
}

fn _score_stages(src: str, vendor: str) -> int {
    let mut s = 0
    if _stage_present(src, vendor, _compile_suffixes())  { s = s + 1 }
    if _stage_present(src, vendor, _enqueue_suffixes())  { s = s + 1 }
    if _stage_present(src, vendor, _dispatch_suffixes()) { s = s + 1 }
    if _stage_present(src, vendor, _retire_suffixes())   { s = s + 1 }
    return s
}

fn _vendor_consumes_ir(src: str, ir: str) -> bool {
    let lit_primary = "let IR_PRIMARY"
    let lit_fall    = "let IR_FALLBACK"
    let needle = "\"" + ir + "\""
    if src.contains(lit_primary) {
        let i = src.index_of(lit_primary)
        let line_end = src.index_of_from("\n", i)
        let bound = if line_end > 0 { line_end } else { src.len() }
        let line = src.slice(i, bound)
        if line.contains(needle) { return true }
    }
    if src.contains(lit_fall) {
        let i = src.index_of(lit_fall)
        let line_end = src.index_of_from("\n", i)
        let bound = if line_end > 0 { line_end } else { src.len() }
        let line = src.slice(i, bound)
        if line.contains(needle) { return true }
    }
    return false
}

fn _count_canonical_irs(src: str) -> int {
    let mut n = 0
    for ir in CANONICAL_IRS {
        if _vendor_consumes_ir(src, ir) { n = n + 1 }
    }
    return n
}

// Native (non-canonical) IR detection for check 6.
fn _has_native_ir_primary_only(src: str) -> bool {
    // returns true if IR_PRIMARY string is NOT one of {ptx, spirv}.
    let lit_primary = "let IR_PRIMARY"
    if !src.contains(lit_primary) { return false }
    let i = src.index_of(lit_primary)
    let line_end = src.index_of_from("\n", i)
    let bound = if line_end > 0 { line_end } else { src.len() }
    let line = src.slice(i, bound)
    let primary_canonical = line.contains("\"ptx\"") || line.contains("\"spirv\"")
    return !primary_canonical
}

// ─── checks ──────────────────────────────────────────────────────────

fn check_J2_prime_eq_48() {
    let lhs = SIGMA_GPGPU * TAU_GPGPU
    _check(lhs == 48 && J2_PRIME == 48,
           "J₂′ = σ·τ = " + str(SIGMA_GPGPU) + "·" + str(TAU_GPGPU) + " = 48",
           "got " + str(lhs))
}

fn check_invariant_accessor_present(root: str) {
    let p = root + "/stdlib/hal/compute.hexa"
    if !_exists(p) {
        _check(false, "compute.hexa declares fn compute_invariant_J2_prime", "compute.hexa missing")
        return
    }
    let src = read_file(p)
    let pat = "fn compute_invariant_J2_prime"
    let ok = src.contains(pat)
    _check(ok,
           "compute.hexa declares fn compute_invariant_J2_prime() returning 48",
           if ok { "found" } else { "missing accessor" })
}

fn check_per_vendor_stage_floor(root: str) {
    let mut sum = 0
    let mut bad = ""
    let mut detail = ""
    for v in VENDORS {
        let p = root + "/stdlib/hal/backend/" + v + "/compute.hexa"
        if !_exists(p) { bad = bad + v + "(missing) "; continue }
        let src = read_file(p)
        let s = _score_stages(src, v)
        sum = sum + s
        detail = detail + v + "=" + str(s) + " "
        if s < 3 { bad = bad + v + "(score=" + str(s) + ") " }
    }
    _check(sum >= STAGE_AGGREGATE_FLOOR && bad.len() == 0,
           "Σ stage_count over 6 vendors ≥ " + str(STAGE_AGGREGATE_FLOOR) + " (every vendor ≥ 3-of-4)",
           "got Σ=" + str(sum) + " " + (if bad.len() > 0 { "issues:" + bad } else { detail }))
}

fn check_ir_edge_floor(root: str) {
    let mut sum = 0
    let mut detail = ""
    for v in VENDORS {
        let p = root + "/stdlib/hal/backend/" + v + "/compute.hexa"
        if !_exists(p) { continue }
        let src = read_file(p)
        let n = _count_canonical_irs(src)
        sum = sum + n
        detail = detail + v + "=" + str(n) + " "
    }
    _check(sum >= GPGPU_VENDORS_N,
           "Σ (vendor, canonical-IR) edges ≥ " + str(GPGPU_VENDORS_N) + " (φ-axis projection)",
           "got " + str(sum) + " (" + detail + ")")
}

fn check_tuple_state_floor(root: str) {
    // Reachable (vendor, stage, IR) tuples: per vendor, score×ir_count.
    let mut sum = 0
    let mut detail = ""
    for v in VENDORS {
        let p = root + "/stdlib/hal/backend/" + v + "/compute.hexa"
        if !_exists(p) { continue }
        let src = read_file(p)
        let s = _score_stages(src, v)
        let n_ir = _count_canonical_irs(src)
        let cell = s * n_ir
        sum = sum + cell
        detail = detail + v + "=" + str(s) + "·" + str(n_ir) + "=" + str(cell) + " "
    }
    _check(sum >= TUPLE_AGGREGATE_FLOOR,
           "Σ (vendor·stage·IR) reachable states ≥ " + str(TUPLE_AGGREGATE_FLOOR) + " (state-space floor; ceiling J₂′=48)",
           "got " + str(sum) + " (" + detail + ")")
}

fn check_native_ir_has_canonical_fallback(root: str) {
    // Vendors that declare a NATIVE IR_PRIMARY (e.g., amdgcn / msl_air /
    // wgsl) must ALSO declare a canonical IR_FALLBACK in {ptx, spirv}.
    let mut bad = ""
    let mut detail = ""
    for v in VENDORS {
        let p = root + "/stdlib/hal/backend/" + v + "/compute.hexa"
        if !_exists(p) { continue }
        let src = read_file(p)
        if _has_native_ir_primary_only(src) {
            // Has native PRIMARY — must have canonical FALLBACK
            let n = _count_canonical_irs(src)
            if n == 0 { bad = bad + v + "(native-only) " }
            else { detail = detail + v + "(native+canonical) " }
        }
    }
    let mut report = ""
    if bad.len() > 0 {
        report = "issues: " + bad
    } else if detail.len() == 0 {
        report = "no native-IR vendors"
    } else {
        report = detail
    }
    _check(bad.len() == 0,
           "every vendor with native IR_PRIMARY also has canonical IR_FALLBACK",
           report)
}

// ─── main ────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/hal — numerics_gpgpu_dispatch: F-GPGPU-4 T2 numerical")
    println("========================================================================")
    println("  vendors: " + str(VENDORS) + "  IRs: " + str(CANONICAL_IRS))
    println("  σ_gpgpu=" + str(SIGMA_GPGPU) + " · τ_gpgpu=" + str(TAU_GPGPU) + " · J₂′=" + str(J2_PRIME))
    println("  stage aggregate floor: " + str(STAGE_AGGREGATE_FLOOR) + "    tuple state-space floor: " + str(TUPLE_AGGREGATE_FLOOR))
    println("")

    let root = _root()

    check_J2_prime_eq_48()
    check_invariant_accessor_present(root)
    check_per_vendor_stage_floor(root)
    check_ir_edge_floor(root)
    check_tuple_state_floor(root)
    check_native_ir_has_canonical_fallback(root)

    println("")
    println("  FALSIFIER:")
    println("    ✗ F-GPGPU-4: J₂′ = σ·τ = 48 dispatch-state combinations (cross-checked numerically)")

    let pass_n = RUN - FAIL
    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_LANG_HAL_NUMERICS_GPGPU_DISPATCH__ FAIL")
        exit(1)
    }
    println("__HEXA_LANG_HAL_NUMERICS_GPGPU_DISPATCH__ PASS")
    exit(0)
}

main()
