#!hexa strict
// stdlib/hal/t3/boot_byte_diff_rp2040.hexa — F5 RFC 063/064 full-boot byte-diff.
//
// Proves the hexa full-boot emitter (stdlib/hal/boot_emit.hexa)
// produces a complete boot `.s` byte-identical to the hand-written
// stdlib/hal/t3/boot_rp2040.s.
//
// Phase: foundation (PR2 of F5 re-open per RUNTIME.floor.md §F5).
// This is the BYTE-IDENTICAL `arm-none-eabi-as` byte-diff verify gate
// the runbook §F5 mandates before the hand-written `.s` can be
// deleted (Component 5 — `git rm boot_rp2040.s`).
//
// Scope: BOTH `.vector_table` AND `.text` sections, PLUS the full
// linked binary (firmware ELF .text@FLASH bytes). All three byte-
// equal → the hand-written `.s` is provably redundant.
//
// PASS criterion:
//   arm-none-eabi-{as,objcopy,ld,objdump,nm} available
//   emitter output assembles cleanly
//   sha256(.vector_table bytes from gen .o) == sha256(.vector_table from orig .o)
//   sha256(.text         bytes from gen .o) == sha256(.text         from orig .o)
//   .text relocs identical (R_ARM_THM_CALL + R_ARM_ABS32 literal-pool)
//
// FAIL: toolchain missing OR assemble error OR section byte-diff > 0.
// Returns 1 on FAIL so a parent falsifier_check or CI gate can flip
// to ✗.
//
// ⚠ HARD GATE: byte-diff PASS is REQUIRED before `git rm boot_rp2040.s`.
// Wrong reset vector OR wrong prologue silently bricks the MCU.
//
// Run:
//   HEXA_HAL_ROOT=<repo-root> hexa-run stdlib/hal/t3/boot_byte_diff_rp2040.hexa

use "stdlib/hal/boot_emit"

let MODULE_NAME = "boot_byte_diff_rp2040"

// ─── check harness ────────────────────────────────────────────────────

let mut RUN  = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ─── helpers ─────────────────────────────────────────────────────────

fn _root() -> str {
    let env_root = env("HEXA_HAL_ROOT")
    if env_root.len() > 0 { return env_root }
    return exec("pwd").trim()
}

fn _which(cmd: str) -> bool {
    let r = exec("command -v " + cmd + " >/dev/null 2>&1 && echo y || echo n").trim()
    return r == "y"
}

fn _exists(p: str) -> bool {
    let r = exec("[ -f \"" + p + "\" ] && echo y || echo n").trim()
    return r == "y"
}

fn _sha256(p: str) -> str {
    if _which("shasum") {
        let r = exec("shasum -a 256 \"" + p + "\" 2>/dev/null | awk '{print $1}'").trim()
        return r
    }
    if _which("sha256sum") {
        let r = exec("sha256sum \"" + p + "\" 2>/dev/null | awk '{print $1}'").trim()
        return r
    }
    return ""
}

fn _write_file(p: str, content: str) -> bool {
    let cmd = "cat > \"" + p + "\" <<'__BOOT_BYTE_DIFF_EOF__'\n" + content + "\n__BOOT_BYTE_DIFF_EOF__"
    let _ = exec(cmd)
    return _exists(p)
}

// ─── checks ──────────────────────────────────────────────────────────

fn check_toolchain() -> bool {
    let has_as      = _which("arm-none-eabi-as")
    let has_objcopy = _which("arm-none-eabi-objcopy")
    let has_objdump = _which("arm-none-eabi-objdump")
    let ok = has_as && has_objcopy && has_objdump
    let detail = "as=" + (if has_as { "y" } else { "n" }) +
                 " objcopy=" + (if has_objcopy { "y" } else { "n" }) +
                 " objdump=" + (if has_objdump { "y" } else { "n" })
    _check(ok, "arm-none-eabi-as + objcopy + objdump present", detail)
    return ok
}

fn check_orig_present(t3_dir: str) -> bool {
    // Note: post-F5-v1.4.0 the hand-written `.s` is `git rm`d. The
    // caller branches on the return value to print a SKIP banner
    // instead of a FAIL line — so a missing file is silently reported
    // here (don't increment FAIL; the SKIP path is the success path).
    let p = t3_dir + "/boot_rp2040.s"
    let ok = _exists(p)
    if ok {
        _check(true, "hand-written boot_rp2040.s present", p)
    }
    return ok
}

fn check_emit_assembles(work_dir: str) -> bool {
    let gen_s = work_dir + "/gen_boot.s"
    let gen_o = work_dir + "/gen_boot.o"
    let s_text = rp2040_emit_full_boot_s()
    let wrote = _write_file(gen_s, s_text)
    if !wrote {
        _check(false, "emitter `.s` text written", gen_s); return false
    }
    let cmd = "arm-none-eabi-as -mcpu=cortex-m0plus -mthumb -o \"" + gen_o + "\" \"" + gen_s + "\" 2>&1"
    let out = exec(cmd)
    let ok = _exists(gen_o)
    _check(ok, "emitter output assembles via arm-none-eabi-as",
           if ok { "wrote " + gen_o } else { "assemble error:\n" + out })
    return ok
}

fn check_orig_assembles(t3_dir: str, work_dir: str) -> bool {
    let orig_s = t3_dir + "/boot_rp2040.s"
    let orig_o = work_dir + "/orig.o"
    let cmd = "arm-none-eabi-as -mcpu=cortex-m0plus -mthumb -o \"" + orig_o + "\" \"" + orig_s + "\" 2>&1"
    let out = exec(cmd)
    let ok = _exists(orig_o)
    _check(ok, "hand-written boot_rp2040.s assembles",
           if ok { "wrote " + orig_o } else { "assemble error:\n" + out })
    return ok
}

fn check_vector_table_byte_identical(work_dir: str) -> bool {
    let gen_o = work_dir + "/gen_boot.o"
    let orig_o = work_dir + "/orig.o"
    let gen_bin = work_dir + "/gen_vt.bin"
    let orig_bin = work_dir + "/orig_vt.bin"
    if !_exists(gen_o) || !_exists(orig_o) {
        _check(false, ".vector_table section byte-identical (gen ≡ orig)",
               "missing object file(s)"); return false
    }
    let _ = exec("arm-none-eabi-objcopy -O binary --only-section=.vector_table \"" + gen_o + "\" \"" + gen_bin + "\" 2>&1")
    let _2 = exec("arm-none-eabi-objcopy -O binary --only-section=.vector_table \"" + orig_o + "\" \"" + orig_bin + "\" 2>&1")
    let gen_sha = _sha256(gen_bin)
    let orig_sha = _sha256(orig_bin)
    let ok = gen_sha.len() > 0 && gen_sha == orig_sha
    let detail = "gen=" + gen_sha + " orig=" + orig_sha
    _check(ok, ".vector_table section byte-identical (gen ≡ orig)", detail)
    return ok
}

fn check_text_byte_identical(work_dir: str) -> bool {
    let gen_o = work_dir + "/gen_boot.o"
    let orig_o = work_dir + "/orig.o"
    let gen_bin = work_dir + "/gen_text.bin"
    let orig_bin = work_dir + "/orig_text.bin"
    if !_exists(gen_o) || !_exists(orig_o) {
        _check(false, ".text section byte-identical (gen ≡ orig)",
               "missing object file(s)"); return false
    }
    let _ = exec("arm-none-eabi-objcopy -O binary --only-section=.text \"" + gen_o + "\" \"" + gen_bin + "\" 2>&1")
    let _2 = exec("arm-none-eabi-objcopy -O binary --only-section=.text \"" + orig_o + "\" \"" + orig_bin + "\" 2>&1")
    let gen_sha = _sha256(gen_bin)
    let orig_sha = _sha256(orig_bin)
    let ok = gen_sha.len() > 0 && gen_sha == orig_sha
    let detail = "gen=" + gen_sha + " orig=" + orig_sha
    _check(ok, ".text section byte-identical (gen ≡ orig)", detail)
    return ok
}

fn check_text_relocs_identical(work_dir: str) -> bool {
    let gen_o = work_dir + "/gen_boot.o"
    let orig_o = work_dir + "/orig.o"
    if !_exists(gen_o) || !_exists(orig_o) {
        _check(false, ".text relocs identical (gen ≡ orig)",
               "missing object file(s)"); return false
    }
    let gen_r = exec("arm-none-eabi-objdump -r --section=.text \"" + gen_o + "\" 2>&1 | grep -E 'R_ARM' | sort").trim()
    let orig_r = exec("arm-none-eabi-objdump -r --section=.text \"" + orig_o + "\" 2>&1 | grep -E 'R_ARM' | sort").trim()
    let ok = gen_r == orig_r && gen_r.len() > 0
    let detail = if ok { "R_ARM_THM_CALL + 6× R_ARM_ABS32 (stack/sdata/edata/etext/sbss/ebss)" }
                 else { "gen:\n" + gen_r + "\norig:\n" + orig_r }
    _check(ok, ".text relocs identical (gen ≡ orig)", detail)
    return ok
}

fn check_vector_table_relocs_identical(work_dir: str) -> bool {
    let gen_o = work_dir + "/gen_boot.o"
    let orig_o = work_dir + "/orig.o"
    if !_exists(gen_o) || !_exists(orig_o) {
        _check(false, ".vector_table relocs identical (gen ≡ orig)",
               "missing object file(s)"); return false
    }
    let gen_r = exec("arm-none-eabi-objdump -r --section=.vector_table \"" + gen_o + "\" 2>&1 | grep -E 'R_ARM' | sort").trim()
    let orig_r = exec("arm-none-eabi-objdump -r --section=.vector_table \"" + orig_o + "\" 2>&1 | grep -E 'R_ARM' | sort").trim()
    let ok = gen_r == orig_r && gen_r.len() > 0
    let detail = if ok { "4× R_ARM_ABS32 (stack_top / reset / hard_fault×2)" }
                 else { "gen:\n" + gen_r + "\norig:\n" + orig_r }
    _check(ok, ".vector_table relocs identical (gen ≡ orig)", detail)
    return ok
}

// ─── main ────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/hal — boot_byte_diff_rp2040: F5 FULL-BOOT byte-diff oracle")
    println("========================================================================")
    println("  generator: stdlib/hal/boot_emit.hexa (rp2040_emit_full_boot_s)")
    println("  oracle:    arm-none-eabi-as byte-diff vs boot_rp2040.s")
    println("  target:    ARMv6-M Cortex-M0+ .vector_table + .text (full boot)")
    println("")

    let root = _root()
    let t3_dir = root + "/stdlib/hal/t3"
    let work_dir = exec("mktemp -d -t boot_byte_diff.XXXXXX").trim()
    if work_dir.len() == 0 {
        println("[FATAL] mktemp failed — cannot allocate scratch dir")
        exit(1)
    }
    println("  scratch: " + work_dir)
    println("")

    if !check_toolchain() {
        println("")
        println("  Toolchain missing — install arm-none-eabi-{as,objcopy,objdump}.")
        println("  F5 full-boot byte-diff verify SKIP (toolchain gate).")
        println("__HEXA_LANG_HAL_BOOT_BYTE_DIFF_RP2040__ SKIP")
        exit(0)
    }

    if !check_orig_present(t3_dir) {
        // F5 v1.4.0: hand-written boot_rp2040.s was `git rm`d after this
        // oracle PASSed 8/8 (the historical proof is the basis for
        // deletion). Post-deletion runs SKIP gracefully — the proof
        // already exists in git history. To re-prove against a fresh
        // baseline, `git show <pre-deletion-sha>:stdlib/hal/t3/boot_rp2040.s`.
        println("")
        println("  POST-DELETION SKIP — hand-written baseline boot_rp2040.s removed")
        println("  in F5 v1.4.0 after this oracle PASSed 8/8 (gen ≡ orig). The")
        println("  emitter remains the SSOT; replay the historical proof via")
        println("  `git show <pre-deletion-sha>:stdlib/hal/t3/boot_rp2040.s`.")
        println("__HEXA_LANG_HAL_BOOT_BYTE_DIFF_RP2040__ SKIP")
        exit(0)
    }

    let emit_ok = check_emit_assembles(work_dir)
    let orig_ok = check_orig_assembles(t3_dir, work_dir)

    if !emit_ok || !orig_ok {
        println("__HEXA_LANG_HAL_BOOT_BYTE_DIFF_RP2040__ FAIL")
        exit(1)
    }

    check_vector_table_byte_identical(work_dir)
    check_vector_table_relocs_identical(work_dir)
    check_text_byte_identical(work_dir)
    check_text_relocs_identical(work_dir)

    println("")
    println("  F5 Component 3-lite (`.s`-text reset-prologue + composer) byte-identity:")
    if FAIL == 0 {
        println("    PROVEN ✓ — rp2040 FULL boot (vector + prologue) is hexa-emittable.")
        println("    Component 5 GATE OPEN — hand-written boot_rp2040.s may be `git rm`.")
        println("    Remaining F5 components:")
        println("      Component 1 — parser `@interrupt(slot=N)` / `@vector_table` arg")
        println("      Component 4 — RUNEQ tag on the emit→assemble pipeline")
    } else {
        println("    BYTE-DIFF FAIL — emitter output diverges from hand-written `.s`.")
        println("    ⚠ Hand-written `.s` MUST NOT be deleted until oracle PASSES.")
        println("    ⚠ Wrong reset vector OR wrong prologue silently bricks the MCU.")
    }

    let pass_n = RUN - FAIL
    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_LANG_HAL_BOOT_BYTE_DIFF_RP2040__ FAIL")
        exit(1)
    }
    println("__HEXA_LANG_HAL_BOOT_BYTE_DIFF_RP2040__ PASS")
    exit(0)
}
