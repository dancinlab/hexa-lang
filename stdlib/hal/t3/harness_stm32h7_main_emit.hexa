#!hexa strict
// stdlib/hal/t3/harness_stm32h7_main_emit.hexa
//   B9.C-6 (.c-leg small batch · #1850 pattern) — harness_stm32h7_main.c source emitter.
//
// Mirrors stdlib/hal/t3/harness_main_emit.hexa one-to-one (parallel
// rp2040 vs stm32h7 split). Emits the STM32H7 T3 harness main verbatim.
// Makefile.stm32h7 is rewired to consume the `_gen.c` produced here in
// place of the hand-written `harness_stm32h7_main.c`.
//
// Invocation (from Makefile.stm32h7 regen rule):
//   hexa-run stdlib/hal/t3/harness_stm32h7_main_emit.hexa <output-path>
//
// Default output path (if argv missing): "harness_stm32h7_main.c" in cwd.
//
// Phase: B9.C-6 batch (arm-none-eabi cross-compile target, Cortex-M7+FPU).

let MODULE_NAME = "harness_stm32h7_main_emit"

fn emit_harness_stm32h7_main_c() -> str {
    // Verbatim content of hand-written stdlib/hal/t3/harness_stm32h7_main.c
    let s = "/*\n" +
            " * stdlib/hal/t3/harness_stm32h7_main.c — STM32H7 T3 harness main.\n" +
            " *\n" +
            " * Phase: scaffold + compile-tier (live). T3b2 deferred until Renode\n" +
            " * STM32H7 platform spec lands.\n" +
            " *\n" +
            " * Goal: minimally exercise the stm32h7 HW backend stubs documented in\n" +
            " * stdlib/hal/backend/stm32h7/{gpio,uart,timer}.hexa, log a sentinel\n" +
            " * line via USART3 (the Nucleo-H743 default ST-LINK virtual COM), and\n" +
            " * halt. Future T3b2 numerics will assert the sentinel landed in a\n" +
            " * Renode-captured UART log.\n" +
            " *\n" +
            " * Sentinel pattern: \"__T3_STM32H7__ PASS gpio_toggle_5x_observed\\n\"\n" +
            " *\n" +
            " * This file mirrors backend/rp2040/harness_main.c structurally; the\n" +
            " * target-specific bits are the register addresses (STM32H7 GPIO at\n" +
            " * 0x58020000, USART3 at 0x40004800) and the FPU register access path\n" +
            " * (Cortex-M7 has hardware FPU enabled by boot.s before this runs).\n" +
            " */\n" +
            "\n" +
            "/* Manual integer typedefs — same approach as rp2040 harness; avoids\n" +
            " * libc dependency for fully -nostdlib bare-metal cross-compile. */\n" +
            "typedef unsigned char       uint8_t;\n" +
            "typedef unsigned short      uint16_t;\n" +
            "typedef unsigned int        uint32_t;\n" +
            "typedef unsigned long long  uint64_t;\n" +
            "\n" +
            "/* STM32H7 GPIO + RCC + USART register sketch. */\n" +
            "\n" +
            "#define RCC_BASE              0x58024400U\n" +
            "#define RCC_AHB4ENR           (*(volatile uint32_t *)(RCC_BASE + 0x0E0))\n" +
            "#define RCC_AHB4ENR_GPIOBEN   (1U << 1)\n" +
            "#define RCC_APB1LENR          (*(volatile uint32_t *)(RCC_BASE + 0x0E8))\n" +
            "#define RCC_APB1LENR_USART3EN (1U << 18)\n" +
            "\n" +
            "#define GPIOB_BASE            0x58020400U\n" +
            "#define GPIOB_MODER           (*(volatile uint32_t *)(GPIOB_BASE + 0x000))\n" +
            "#define GPIOB_BSRR            (*(volatile uint32_t *)(GPIOB_BASE + 0x018))\n" +
            "\n" +
            "/* Pin: PB0 (Nucleo-H743 user LD1 green LED). */\n" +
            "#define LED_PIN               0\n" +
            "#define MODER_OUTPUT          1U  /* 2-bit field: 01 = general-purpose output */\n" +
            "\n" +
            "#define USART3_BASE           0x40004800U\n" +
            "#define USART3_BRR            (*(volatile uint32_t *)(USART3_BASE + 0x00C))\n" +
            "#define USART3_CR1            (*(volatile uint32_t *)(USART3_BASE + 0x000))\n" +
            "#define USART3_TDR            (*(volatile uint32_t *)(USART3_BASE + 0x028))\n" +
            "#define USART3_ISR            (*(volatile uint32_t *)(USART3_BASE + 0x01C))\n" +
            "#define USART_CR1_UE          (1U << 0)\n" +
            "#define USART_CR1_TE          (1U << 3)\n" +
            "#define USART_ISR_TXE         (1U << 7)\n" +
            "\n" +
            "static void delay_loop(uint32_t n) {\n" +
            "    while (n--) { __asm__ volatile(\"nop\"); }\n" +
            "}\n" +
            "\n" +
            "static void uart_write_str(const char *s) {\n" +
            "    while (*s) {\n" +
            "        while (!(USART3_ISR & USART_ISR_TXE)) { /* spin until TX empty */ }\n" +
            "        USART3_TDR = (uint32_t)(*s++);\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "void harness_main(void) {\n" +
            "    /* 1. Enable GPIOB clock + USART3 clock. */\n" +
            "    RCC_AHB4ENR  |= RCC_AHB4ENR_GPIOBEN;\n" +
            "    RCC_APB1LENR |= RCC_APB1LENR_USART3EN;\n" +
            "\n" +
            "    /* 2. Configure PB0 as output (MODER bits [1:0] = 01). */\n" +
            "    uint32_t moder = GPIOB_MODER;\n" +
            "    moder &= ~(0x3U << (LED_PIN * 2));\n" +
            "    moder |= (MODER_OUTPUT << (LED_PIN * 2));\n" +
            "    GPIOB_MODER = moder;\n" +
            "\n" +
            "    /* 3. Configure USART3 for 115200 8N1 (assume APB1=120 MHz default;\n" +
            "     *    BRR = 120e6 / 115200 ≈ 1042 = 0x412). Real impl computes from\n" +
            "     *    HCLK/PCLK; this stub uses Nucleo defaults. */\n" +
            "    USART3_BRR = 1042;\n" +
            "    USART3_CR1 = USART_CR1_UE | USART_CR1_TE;\n" +
            "\n" +
            "    uart_write_str(\"[t3_stm32h7 START] harness booted\\r\\n\");\n" +
            "\n" +
            "    /* 4. Toggle LED 5 times via BSRR atomic set/reset (MMIO-correct;\n" +
            "     *    no read-modify-write race). */\n" +
            "    for (int i = 0; i < 5; i++) {\n" +
            "        GPIOB_BSRR = (1U << LED_PIN);              /* set bit n   = on */\n" +
            "        delay_loop(100000);\n" +
            "        GPIOB_BSRR = (1U << (LED_PIN + 16));       /* reset bit n = off */\n" +
            "        delay_loop(100000);\n" +
            "    }\n" +
            "\n" +
            "    /* 5. Emit T3 PASS sentinel. */\n" +
            "    uart_write_str(\"__T3_STM32H7__ PASS gpio_toggle_5x_observed\\r\\n\");\n" +
            "\n" +
            "    /* 6. Spin forever. */\n" +
            "    for (;;) { __asm__ volatile(\"nop\"); }\n" +
            "}\n" +
            "\n" +
            "/* End of harness_stm32h7_main.c — minimal STM32H7 GPIO + UART exerciser. */\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "harness_stm32h7_main.c" }
    let c_text = emit_harness_stm32h7_main_c()
    let cmd = "cat > \"" + out_path + "\" <<'__HARNESS_STM32H7_MAIN_EMIT_EOF__'\n" +
              c_text + "__HARNESS_STM32H7_MAIN_EMIT_EOF__"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[harness_stm32h7_main_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[harness_stm32h7_main_emit] wrote " + out_path)
    exit(0)
}
