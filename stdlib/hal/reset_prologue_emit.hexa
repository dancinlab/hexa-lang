#!hexa strict
// stdlib/hal/reset_prologue_emit.hexa — F5 RFC 063/064 Component 3-lite.
//
// Pure-hexa `.s`-text reset-prologue emitter for ARMv6-M / ARMv7-M /
// ARMv7E-M Cortex-M cores. Produces a `.text`-section `.s` fragment
// that, when fed to `arm-none-eabi-as`, assembles to a byte-identical
// `.text` section to the hand-written `_reset_handler` + `_hang` +
// `_hard_fault` sequence in `boot_<mcu>.s`.
//
// Phase: foundation (PR2 of F5 re-open per RUNTIME.floor.md §F5).
// Scope: text-section reset prologue ONLY. The vector table (data
// section) is emitted by `stdlib/hal/vector_table_emit.hexa`
// (Component 2-lite, landed in PR #1843).
//
// `as` does the heavy lifting (Thumb-1 instruction encoding, literal-
// pool layout, R_ARM_ABS32 / R_ARM_THM_CALL reloc emission). This
// module is a string-builder, not an ARM-asm encoder — hence
// "Component 3-LITE", consistent with Component 2-lite's `.s`-text
// approach. Full ELF-native emitter (Component 3 proper, with a
// hexa M0+ codegen target) is deferred.
//
// Byte-identity oracle: stdlib/hal/t3/boot_byte_diff_rp2040.hexa
// (RFC 063 §5 — BYTE-IDENTICAL `arm-none-eabi-as` byte-diff verify
// against the full boot_rp2040.s).
//
// Reset-prologue shape (ARMv6-M Cortex-M0+, mirrors boot_rp2040.s):
//   1. Load _stack_top → msr msp
//   2. Copy .data: src=_etext, dst=_sdata..edata, 4-byte word loop
//   3. Zero  .bss : _sbss..ebss, 4-byte word loop
//   4. bl harness_main
//   5. _hang: b _hang
//   6. _hard_fault: b _hard_fault

let MODULE_NAME = "reset_prologue_emit"

// ─── helpers ────────────────────────────────────────────────────────

fn _pl_indent() -> str { return "    " }

// ─── primary API ────────────────────────────────────────────────────
//
// rp_emit_section: emits the full reset-prologue + hang + hard-fault
// `.s` text. Caller writes it to a file and feeds it to
// `arm-none-eabi-as`.
//
// Args:
//   cpu        — e.g. "cortex-m0plus" / "cortex-m7" (sets `.cpu`).
//   entry_fn   — the function `bl` jumps to (e.g. "harness_main").
//   stack_sym  — initial-SP symbol name (e.g. "_stack_top").
//   data_src   — source symbol for `.data` copy (e.g. "_etext").
//   data_dst_s — start symbol for `.data` (e.g. "_sdata").
//   data_dst_e — end   symbol for `.data` (e.g. "_edata").
//   bss_s      — start symbol for `.bss` (e.g. "_sbss").
//   bss_e      — end   symbol for `.bss` (e.g. "_ebss").
//
// Returns: `.s` text WITHOUT a leading `.syntax/.thumb/.cpu` prelude
// (those are emitted by the vector-table emitter and shared across
// the combined file). Used when composing one full .s via
// `rp_emit_full_boot`.

fn rp_emit_prologue_body(
    entry_fn: str,
    stack_sym: str,
    data_src: str,
    data_dst_s: str,
    data_dst_e: str,
    bss_s: str,
    bss_e: str
) -> str {
    return rp_emit_prologue_body_ext(
        entry_fn, stack_sym, data_src, data_dst_s, data_dst_e, bss_s, bss_e,
        false  // enable_fpu: ARMv6-M (Cortex-M0+) has no FPU
    )
}

// rp_emit_prologue_body_ext: same as rp_emit_prologue_body + optional
// FPU enable block (ARMv7-M / ARMv7E-M Cortex-M4F / M7 / M33 with FPU).
//
// When `enable_fpu == true`, inserts a 6-instruction block between the
// stack-pointer setup (step 1) and the .data copy (step 2) that grants
// full access to CP10 + CP11 in SCB_CPACR (0xE000ED88), followed by
// `dsb` + `isb` barriers. This mirrors the hand-written FPU enable
// sequence in boot_stm32h7.s (Cortex-M7 + FPv5-D16).
//
// The orr literal `#(0xF << 20)` (== 0xF00000) is a Thumb-2 wide-
// encoded immediate that `as` assembles into a 4-byte ORR.W; this is
// ARMv7-M-only and must NOT be emitted for ARMv6-M targets (caller
// guarantees this via the bool flag).

fn rp_emit_prologue_body_ext(
    entry_fn: str,
    stack_sym: str,
    data_src: str,
    data_dst_s: str,
    data_dst_e: str,
    bss_s: str,
    bss_e: str,
    enable_fpu: bool
) -> str {
    let mut out = ""

    // .text section + _reset_handler label
    out = out + _pl_indent() + ".text\n"
    out = out + _pl_indent() + ".global _reset_handler\n"
    out = out + _pl_indent() + ".thumb_func\n"
    out = out + "_reset_handler:\n"

    // 1. set up stack pointer (defensive — already loaded at reset)
    out = out + _pl_indent() + "ldr  r0, =" + stack_sym + "\n"
    out = out + _pl_indent() + "msr  msp, r0\n"
    out = out + "\n"

    // 1.5 (ARMv7-M only): enable FPU (CP10 + CP11 full access in CPACR).
    // Mirrors boot_stm32h7.s FPU-enable block. ARMv6-M skips this.
    if enable_fpu {
        out = out + _pl_indent() + "ldr  r0, =0xE000ED88\n"
        out = out + _pl_indent() + "ldr  r1, [r0]\n"
        out = out + _pl_indent() + "orr  r1, r1, #(0xF << 20)\n"
        out = out + _pl_indent() + "str  r1, [r0]\n"
        out = out + _pl_indent() + "dsb\n"
        out = out + _pl_indent() + "isb\n"
        out = out + "\n"
    }

    // 2. copy .data from FLASH to RAM
    out = out + _pl_indent() + "ldr  r0, =" + data_dst_s + "\n"
    out = out + _pl_indent() + "ldr  r1, =" + data_dst_e + "\n"
    out = out + _pl_indent() + "ldr  r2, =" + data_src + "\n"
    out = out + "1:  cmp  r0, r1\n"
    out = out + _pl_indent() + "bcs  2f\n"
    out = out + _pl_indent() + "ldr  r3, [r2]\n"
    out = out + _pl_indent() + "str  r3, [r0]\n"
    out = out + _pl_indent() + "adds r0, #4\n"
    out = out + _pl_indent() + "adds r2, #4\n"
    out = out + _pl_indent() + "b    1b\n"
    out = out + "\n"

    // 3. zero .bss
    out = out + "2:  ldr  r0, =" + bss_s + "\n"
    out = out + _pl_indent() + "ldr  r1, =" + bss_e + "\n"
    out = out + _pl_indent() + "movs r2, #0\n"
    out = out + "3:  cmp  r0, r1\n"
    out = out + _pl_indent() + "bcs  4f\n"
    out = out + _pl_indent() + "str  r2, [r0]\n"
    out = out + _pl_indent() + "adds r0, #4\n"
    out = out + _pl_indent() + "b    3b\n"
    out = out + "\n"

    // 4. call entry fn (typically harness_main)
    out = out + "4:  bl   " + entry_fn + "\n"
    out = out + "\n"

    // 5. _hang spin (if entry returns)
    out = out + "_hang:\n"
    out = out + _pl_indent() + "b    _hang\n"
    out = out + "\n"

    // 6. _hard_fault spin
    out = out + _pl_indent() + ".global _hard_fault\n"
    out = out + _pl_indent() + ".thumb_func\n"
    out = out + "_hard_fault:\n"
    out = out + _pl_indent() + "b    _hard_fault\n"

    return out
}

// rp_emit_section: emits a self-contained `.s` file (with
// `.syntax/.thumb/.cpu` prelude). Useful when assembling the prologue
// as a STANDALONE `.s` (separate from the vector table) — e.g. for the
// split-and-link verification path from #1843's recon.

fn rp_emit_section(
    header_banner: str,
    cpu: str,
    entry_fn: str,
    stack_sym: str,
    data_src: str,
    data_dst_s: str,
    data_dst_e: str,
    bss_s: str,
    bss_e: str
) -> str {
    let mut out = ""

    if header_banner.len() > 0 {
        out = out + header_banner
        out = out + "\n\n"
    }

    out = out + _pl_indent() + ".syntax unified\n"
    out = out + _pl_indent() + ".thumb\n"
    out = out + _pl_indent() + ".cpu " + cpu + "\n"
    out = out + "\n"

    out = out + rp_emit_prologue_body(
        entry_fn, stack_sym, data_src, data_dst_s, data_dst_e, bss_s, bss_e
    )

    return out
}

// ─── CMSIS-style emitter (PR #1846 — stm32f429 leg) ─────────────────
//
// CMSIS startup `.s` files use a different reset-prologue shape from
// the minimal `boot_<mcu>.s` files:
//   - section is per-handler: `.section .text.Reset_Handler` (no
//     flags) and `.section .text.Default_Handler,"ax",%progbits`.
//   - `.weak` + `.type ... %function` annotations on the handler
//     symbols (linker overrides Reset_Handler weakly).
//   - SP setup uses `mov sp, r0` (ARMv7-M Thumb-2) instead of
//     `msr msp, r0` (architecturally identical, encoding shorter).
//   - data copy uses INDEXED loads: `ldr r4, [r2, r3]` / `str r4,
//     [r0, r3]` with a single index register `r3` that increments by
//     4 each iteration (clears 1 instruction off the inner loop vs
//     the rp2040 dual-pointer form).
//   - branch labels are explicitly named (`.copy_data`, `.zero_bss`,
//     `.bss_loop`, `.start_main`, `.hang`) instead of `1:`/`2:`/etc.
//   - calls `main` (not `harness_main`) — production entry point.
//   - includes a Default_Handler at the end (own labelled section).
//
// The `cmsis` emitter takes these as explicit parameters so the same
// emit surface works for any CMSIS startup (stm32f4, stm32f7, stm32g4,
// nrf52, etc. — they all share this prologue shape with only symbol-
// name and section-name variation).

fn rp_emit_prologue_body_cmsis(
    reset_section: str,
    default_section: str,
    entry_fn: str,
    stack_sym: str,
    data_src: str,
    data_dst_s: str,
    data_dst_e: str,
    bss_s: str,
    bss_e: str
) -> str {
    let mut out = ""

    // ── Reset_Handler section ────────────────────────────────────
    out = out + "/* ---- Reset_Handler --------------------------------------------------- */\n"
    out = out + _pl_indent() + ".section " + reset_section + "\n"
    out = out + _pl_indent() + ".weak Reset_Handler\n"
    out = out + _pl_indent() + ".type Reset_Handler, %function\n"
    out = out + "Reset_Handler:\n"

    // 1. set up stack pointer
    out = out + _pl_indent() + "ldr r0, =" + stack_sym + "\n"
    out = out + _pl_indent() + "mov sp, r0\n"
    out = out + "\n"

    // 2. copy .data from FLASH to RAM (CMSIS indexed-load form)
    out = out + _pl_indent() + "/* Copy .data from flash to RAM */\n"
    out = out + _pl_indent() + "ldr r0, =" + data_dst_s + "\n"
    out = out + _pl_indent() + "ldr r1, =" + data_dst_e + "\n"
    out = out + _pl_indent() + "ldr r2, =" + data_src + "\n"
    out = out + _pl_indent() + "movs r3, #0\n"
    out = out + ".copy_data:\n"
    out = out + _pl_indent() + "cmp r0, r1\n"
    out = out + _pl_indent() + "bge .zero_bss\n"
    out = out + _pl_indent() + "ldr r4, [r2, r3]\n"
    out = out + _pl_indent() + "str r4, [r0, r3]\n"
    out = out + _pl_indent() + "adds r3, r3, #4\n"
    out = out + _pl_indent() + "adds r0, r0, #4\n"
    out = out + _pl_indent() + "b   .copy_data\n"
    out = out + "\n"

    // 3. zero .bss
    out = out + ".zero_bss:\n"
    out = out + _pl_indent() + "ldr r0, =" + bss_s + "\n"
    out = out + _pl_indent() + "ldr r1, =" + bss_e + "\n"
    out = out + _pl_indent() + "movs r2, #0\n"
    out = out + ".bss_loop:\n"
    out = out + _pl_indent() + "cmp r0, r1\n"
    out = out + _pl_indent() + "bge .start_main\n"
    out = out + _pl_indent() + "str r2, [r0]\n"
    out = out + _pl_indent() + "adds r0, r0, #4\n"
    out = out + _pl_indent() + "b   .bss_loop\n"
    out = out + "\n"

    // 4. call entry fn + spin
    out = out + ".start_main:\n"
    out = out + _pl_indent() + "bl " + entry_fn + "\n"
    out = out + ".hang:\n"
    out = out + _pl_indent() + "b .hang\n"
    out = out + "\n"

    // ── Default_Handler section ─────────────────────────────────
    out = out + "/* ---- Default_Handler ------------------------------------------------- */\n"
    out = out + _pl_indent() + ".section " + default_section + "\n"
    out = out + _pl_indent() + ".weak Default_Handler\n"
    out = out + _pl_indent() + ".type Default_Handler, %function\n"
    out = out + "Default_Handler:\n"
    out = out + _pl_indent() + "b Default_Handler\n"

    return out
}

// ─── canned shape (rp2040 boot_rp2040.s mirror) ────────────────────

fn rp2040_emit_reset_prologue_s() -> str {
    let banner = "/* AUTO-GENERATED by stdlib/hal/reset_prologue_emit.hexa\n" +
                 " * RP2040 ARMv6-M (Cortex-M0+) reset prologue (.text section).\n" +
                 " * Byte-identity oracle: stdlib/hal/t3/boot_byte_diff_rp2040.hexa\n" +
                 " * Do not hand-edit — regenerate via the emit fn. */"
    return rp_emit_section(
        banner,
        "cortex-m0plus",
        "harness_main",
        "_stack_top",
        "_etext",
        "_sdata",
        "_edata",
        "_sbss",
        "_ebss"
    )
}
