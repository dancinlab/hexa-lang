#!hexa strict
// stdlib/hal/vector_table_emit.hexa — F5 RFC 063/064 Component 2-lite.
//
// Pure-hexa `.s`-text vector-table emitter. Takes a slot→handler map
// (data) + section name + cpu + padding count and produces ARM/Thumb
// `.s` text that, when passed to `arm-none-eabi-as`, produces a byte-
// identical `.vector_table` section to the hand-written boot_<mcu>.s.
//
// Phase: foundation (PR1 of F5 re-open per RUNTIME.floor.md §F5).
// Scope: vector-table data section ONLY. Reset prologue is OUT (kept
// as a separate `.s` fragment per the runbook's minimal-effort path).
//
// `as` does the heavy lifting (R_ARM_ABS32 reloc emission for each
// `.word <symbol>+1` entry, literal-pool, section flags). This module
// is a string-builder, not an ARM-asm encoder — hence "Component 2-
// LITE". Full ELF-native emitter (Component 2 proper) is deferred to
// a later PR (RUNTIME.floor.md §F5 5-component breakdown).
//
// Byte-identity oracle: stdlib/hal/t3/vt_byte_diff_rp2040.hexa
// (RFC 063 §5 — BYTE-IDENTICAL `arm-none-eabi-as` byte-diff verify).

let MODULE_NAME = "vector_table_emit"

// ─── slot table data structure ─────────────────────────────────────
//
// A vector-table slot is a (index, symbol_or_zero, thumb_bit) triple.
// Zero entries (padding / unused IRQ vectors) → `.word 0` (no reloc).
// Symbol entries → `.word <symbol>` (no Thumb bit, e.g. initial SP)
// OR `.word <symbol> + 1` (Thumb bit set, all handlers on ARMv6-M /
// ARMv7-M / ARMv8-M targets; CPU treats the LSB as "interworking to
// Thumb" and clears it when loading PC).
//
// Encoded as a parallel-array tuple to keep the API stable under the
// hexa-lang struct-array aliasing gotcha
// (feedback_hexa_struct_pack_aliasing.md). Caller passes 3 arrays of
// equal length; index `i` is one slot.

// ─── helpers ────────────────────────────────────────────────────────

fn _vt_indent() -> str { return "    " }

fn _vt_word_line(symbol: str, thumb_bit: bool, comment: str) -> str {
    let mut out = _vt_indent() + ".word "
    if symbol.len() == 0 {
        out = out + "0"
    } else {
        out = out + symbol
        if thumb_bit { out = out + " + 1" }
    }
    if comment.len() > 0 {
        out = out + "              /* " + comment + " */"
    }
    return out + "\n"
}

// ─── primary API ────────────────────────────────────────────────────
//
// vt_emit_section: emits a complete `.s` file string for a vector-
// table data section.
//
// Args:
//   header_banner  — `.s` top-of-file banner (multiline OK, no trailing \n).
//   cpu            — e.g. "cortex-m0plus" / "cortex-m7".
//   section_name   — e.g. ".vector_table" (rp2040) or ".isr_vector"
//                    (stm32 startup convention).
//   section_flags  — e.g. "\"a\", %progbits" (mirrors hand-written).
//   table_label    — exported symbol, e.g. "_vector_table".
//   slot_symbols   — parallel array of slot symbol names ("" = zero).
//   slot_thumb     — parallel array of bools (Thumb-bit on/off).
//   slot_comments  — parallel array of slot comment strings.
//   pad_words      — number of trailing `.word 0` entries (rolled
//                    into a `.rept <N> .word 0 .endr` block for
//                    byte-identity with the hand-written boot files).
//
// Returns: the full `.s` text. Caller writes it to a file and feeds
// it to `arm-none-eabi-as`.

fn vt_emit_section(
    header_banner: str,
    cpu: str,
    section_name: str,
    section_flags: str,
    table_label: str,
    slot_symbols: [str],
    slot_thumb: [bool],
    slot_comments: [str],
    pad_words: int
) -> str {
    return vt_emit_section_ext(
        header_banner, cpu, "",  // fpu: "" = omit `.fpu` directive (M0+)
        section_name, section_flags, table_label,
        slot_symbols, slot_thumb, slot_comments, pad_words
    )
}

// vt_emit_section_ext: same as vt_emit_section + optional `.fpu`
// directive in the architectural prelude.
//
// When `fpu != ""`, emits `.fpu <fpu>` (e.g. "fpv5-d16" for Cortex-M7 +
// FPv5-D16 double-precision FPU on STM32H7). Mirrors the hand-written
// `.fpu fpv5-d16` line in boot_stm32h7.s.

fn vt_emit_section_ext(
    header_banner: str,
    cpu: str,
    fpu: str,
    section_name: str,
    section_flags: str,
    table_label: str,
    slot_symbols: [str],
    slot_thumb: [bool],
    slot_comments: [str],
    pad_words: int
) -> str {
    let mut out = ""

    // banner (caller supplies — preserves whatever comment style the
    // hand-written `.s` used; byte-identity is at the assembled-object
    // level, not the source-text level, so comments are irrelevant to
    // the byte-diff oracle).
    if header_banner.len() > 0 {
        out = out + header_banner
        out = out + "\n\n"
    }

    // architectural prelude
    out = out + _vt_indent() + ".syntax unified\n"
    out = out + _vt_indent() + ".thumb\n"
    out = out + _vt_indent() + ".cpu " + cpu + "\n"
    if fpu.len() > 0 {
        out = out + _vt_indent() + ".fpu " + fpu + "\n"
    }
    out = out + "\n"

    // section + label
    out = out + _vt_indent() + ".section " + section_name + ", " + section_flags + "\n"
    out = out + _vt_indent() + ".global " + table_label + "\n"
    out = out + table_label + ":\n"

    // slot entries
    let n = slot_symbols.len()
    if slot_thumb.len() != n {
        println("[vector_table_emit] FATAL: slot_thumb len " + str(slot_thumb.len()) + " != slot_symbols len " + str(n))
        exit(1)
    }
    if slot_comments.len() != n {
        println("[vector_table_emit] FATAL: slot_comments len " + str(slot_comments.len()) + " != slot_symbols len " + str(n))
        exit(1)
    }
    let mut i = 0
    while i < n {
        out = out + _vt_word_line(slot_symbols[i], slot_thumb[i], slot_comments[i])
        i = i + 1
    }

    // padding (rolled .rept block matches hand-written form for
    // source-readability; the assembled bytes are identical either
    // way since `.rept N .word 0 .endr` ≡ N copies of `.word 0`).
    if pad_words > 0 {
        out = out + _vt_indent() + "/* padding to fill vector table */\n"
        out = out + _vt_indent() + ".rept " + str(pad_words) + "\n"
        out = out + _vt_indent() + ".word 0\n"
        out = out + _vt_indent() + ".endr\n"
    }

    return out
}

// ─── canned slot tables (boot_<mcu>.s shapes) ──────────────────────
//
// rp2040_vt_slots: returns the 4-entry symbol/thumb/comment trio
// matching boot_rp2040.s lines 25-32 (initial-SP + reset + NMI +
// HardFault, then 28 padding words to fill the 32-word ARMv6-M
// system-vector area = 0x80 bytes).
//
// These canned tables are the "data" surface that a future Component
// 1 parser change would populate FROM `@interrupt(slot=N)` /
// `@vector_table(...)` annotations. For this foundation PR, they
// are hand-curated to prove the emit surface is byte-correct.

fn rp2040_vt_symbols() -> [str] {
    return ["_stack_top", "_reset_handler", "_hard_fault", "_hard_fault"]
}

fn rp2040_vt_thumb() -> [bool] {
    return [false, true, true, true]
}

fn rp2040_vt_comments() -> [str] {
    return [
        "0x00: initial SP",
        "0x04: reset (Thumb mode bit set)",
        "0x08: NMI",
        "0x0C: HardFault"
    ]
}

fn rp2040_vt_pad_words() -> int { return 28 }

// rp2040_emit_full: convenience wrapper — emits the complete vector-
// table `.s` for boot_rp2040.s style. Output assembles to a 0x80-byte
// `.vector_table` section with 4 R_ARM_ABS32 relocs.

fn rp2040_emit_vector_table_s() -> str {
    let banner = "/* AUTO-GENERATED by stdlib/hal/vector_table_emit.hexa\n" +
                 " * RP2040 ARMv6-M (Cortex-M0+) vector table (data section).\n" +
                 " * Byte-identity oracle: stdlib/hal/t3/vt_byte_diff_rp2040.hexa\n" +
                 " * Do not hand-edit — regenerate via the emit fn. */"
    return vt_emit_section(
        banner,
        "cortex-m0plus",
        ".vector_table",
        "\"a\", %progbits",
        "_vector_table",
        rp2040_vt_symbols(),
        rp2040_vt_thumb(),
        rp2040_vt_comments(),
        rp2040_vt_pad_words()
    )
}

// ─── canned slot tables (boot_stm32h7.s shape) ─────────────────────
//
// stm32h7_vt_slots: returns the 16-entry ARMv7-M system-vector trio
// matching boot_stm32h7.s lines 22-37 (SP + Reset + NMI + HardFault +
// MemManage + BusFault + UsageFault + 4 reserved + SVCall + DebugMon +
// 1 reserved + PendSV + SysTick), then 240 padding words to fill the
// 256-word ARMv7-M vector page (16 system + 240 IRQs = 256 entries =
// 0x400 bytes).
//
// All 11 active exception handlers share `_hard_fault` (T3 harness is
// not interrupt-driven; any exception spins). The 5 reserved slots
// (positions 7-10 + 13) emit `.word 0` (no reloc).

fn stm32h7_vt_symbols() -> [str] {
    return [
        "_stack_top",      // 0x00: initial SP
        "_reset_handler",  // 0x04: reset
        "_hard_fault",     // 0x08: NMI
        "_hard_fault",     // 0x0C: HardFault
        "_hard_fault",     // 0x10: MemManage
        "_hard_fault",     // 0x14: BusFault
        "_hard_fault",     // 0x18: UsageFault
        "",                // 0x1C: reserved
        "",                // 0x20: reserved
        "",                // 0x24: reserved
        "",                // 0x28: reserved
        "_hard_fault",     // 0x2C: SVCall
        "_hard_fault",     // 0x30: DebugMonitor
        "",                // 0x34: reserved
        "_hard_fault",     // 0x38: PendSV
        "_hard_fault"      // 0x3C: SysTick
    ]
}

fn stm32h7_vt_thumb() -> [bool] {
    return [
        false,  // SP: no Thumb bit
        true,   // reset
        true,   // NMI
        true,   // HardFault
        true,   // MemManage
        true,   // BusFault
        true,   // UsageFault
        false,  // reserved
        false,  // reserved
        false,  // reserved
        false,  // reserved
        true,   // SVCall
        true,   // DebugMonitor
        false,  // reserved
        true,   // PendSV
        true    // SysTick
    ]
}

fn stm32h7_vt_comments() -> [str] {
    return [
        "0x00: initial SP",
        "0x04: reset (Thumb mode bit set)",
        "0x08: NMI",
        "0x0C: HardFault",
        "0x10: MemManage",
        "0x14: BusFault",
        "0x18: UsageFault",
        "0x1C: reserved",
        "0x20: reserved",
        "0x24: reserved",
        "0x28: reserved",
        "0x2C: SVCall",
        "0x30: DebugMonitor",
        "0x34: reserved",
        "0x38: PendSV",
        "0x3C: SysTick"
    ]
}

fn stm32h7_vt_pad_words() -> int { return 240 }

fn stm32h7_emit_vector_table_s() -> str {
    let banner = "/* AUTO-GENERATED by stdlib/hal/vector_table_emit.hexa\n" +
                 " * STM32H7 ARMv7-M (Cortex-M7 + FPv5-D16) vector table (data section).\n" +
                 " * Byte-identity oracle: stdlib/hal/t3/boot_byte_diff_stm32h7.hexa\n" +
                 " * Do not hand-edit — regenerate via the emit fn. */"
    return vt_emit_section_ext(
        banner,
        "cortex-m7",
        "fpv5-d16",
        ".vector_table",
        "\"a\", %progbits",
        "_vector_table",
        stm32h7_vt_symbols(),
        stm32h7_vt_thumb(),
        stm32h7_vt_comments(),
        stm32h7_vt_pad_words()
    )
}

// ─── CMSIS-style emitter (PR #1846 — stm32f429 leg) ─────────────────
//
// CMSIS startup `.s` files diverge from the minimal `boot_<mcu>.s`
// shape in these ways:
//   - section name `.isr_vector` (not `.vector_table`).
//   - external label `g_pfnVectors` with `.type ... %object` + `.size`
//     directive (linker-script-visible object symbol).
//   - `.extern` declarations for every external symbol the vector
//     table references (named IRQ handlers + linker-defined symbols).
//   - NAMED IRQ vectors interleaved with `.rept <N> .word <default>
//     .endr` blocks of identical default handlers (per-peripheral IRQ
//     layout where most slots map to `Default_Handler` but a few are
//     named C handlers).
//   - vector words drop the explicit Thumb-bit suffix (`Reset_Handler`
//     not `Reset_Handler + 1`) — the linker auto-sets bit 0 from the
//     `.type ... %function` annotation on each handler symbol.
//
// We model a CMSIS vector table as alternating "named" + "padding"
// runs: each chunk is either a single named-handler entry or a `.rept
// N .word <default> .endr` block. Parallel arrays of chunk kind +
// label/count keep the API compatible with the parallel-array idiom
// the rp2040/stm32h7 paths use (no struct-array aliasing risk).
//
// chunk_kind[i] == "named" → slot_label[i] is one symbol name; the
//                  emitter writes `.word <label>` + comment, with no
//                  Thumb-bit suffix.
// chunk_kind[i] == "pad"   → slot_label[i] is the default-handler
//                  symbol name; slot_count[i] is the .rept count.
// chunk_kind[i] == "zero"  → slot_label[i] ignored; slot_count[i]
//                  reserved `.word 0,0,...,0` words (CMSIS reserved
//                  slots between system vectors).
//
// system_label / system_comment: the first 16 ARMv7-M system-vector
// entries (SP + Reset + 14 exception slots), emitted with the
// hand-written shape (initial-SP word, Reset_Handler word, then named
// or `.word 0` for reserved slots). Encoded as parallel arrays just
// like the existing `vt_emit_section_ext` slot trios but the emit
// shape DROPS the Thumb-bit suffix to match CMSIS source style.

fn _vt_word_line_no_thumb(symbol: str, comment: str) -> str {
    let mut out = _vt_indent() + ".word "
    if symbol.len() == 0 {
        out = out + "0"
    } else {
        out = out + symbol
    }
    if comment.len() > 0 {
        out = out + "          /* " + comment + " */"
    }
    return out + "\n"
}

fn vt_emit_section_cmsis(
    header_banner: str,
    cpu: str,
    fpu: str,
    section_name: str,
    section_flags: str,
    table_label: str,
    extern_syms: [str],
    global_syms: [str],
    system_labels: [str],
    system_comments: [str],
    chunk_kinds: [str],
    chunk_labels: [str],
    chunk_counts: [int],
    chunk_comments: [str]
) -> str {
    let mut out = ""

    if header_banner.len() > 0 {
        out = out + header_banner
        out = out + "\n\n"
    }

    // architectural prelude (CMSIS order: syntax, cpu, fpu, thumb).
    // Mirrors the hand-written startup_stm32f429.s prelude verbatim.
    out = out + _vt_indent() + ".syntax unified\n"
    out = out + _vt_indent() + ".cpu " + cpu + "\n"
    if fpu.len() > 0 {
        out = out + _vt_indent() + ".fpu " + fpu + "\n"
    }
    out = out + _vt_indent() + ".thumb\n"
    out = out + "\n"

    // `.global` declarations (vector-table label + handler aliases).
    let ng = global_syms.len()
    let mut gi = 0
    while gi < ng {
        out = out + _vt_indent() + ".global " + global_syms[gi] + "\n"
        gi = gi + 1
    }
    out = out + "\n"

    // `.extern` declarations (every symbol that must resolve at link
    // time — linker-defined SP/heap symbols + named IRQ handlers).
    let ne = extern_syms.len()
    let mut ei = 0
    while ei < ne {
        out = out + _vt_indent() + ".extern " + extern_syms[ei] + "\n"
        ei = ei + 1
    }
    out = out + "\n"

    // `.isr_vector` section header (CMSIS shape: `.type ... %object`
    // + `.size ... , . - <label>` BEFORE the label — yes, evaluating
    // the size to 0 at this directive position is the canonical CMSIS
    // form; `as` accepts it and produces a 0-sized symbol entry that
    // the linker still resolves to the table start address).
    out = out + "/* ---- Vector table ---------------------------------------------------- */\n"
    out = out + _vt_indent() + ".section " + section_name + "," + section_flags + "\n"
    out = out + _vt_indent() + ".type " + table_label + ", %object\n"
    out = out + _vt_indent() + ".size " + table_label + ", . - " + table_label + "\n"
    out = out + table_label + ":\n"

    // 16-entry ARMv7-M system-vector area (SP + Reset + 14 exception
    // slots). Drop Thumb-bit suffix — CMSIS source convention.
    let ns = system_labels.len()
    if system_comments.len() != ns {
        println("[vector_table_emit] FATAL: system_comments len " + str(system_comments.len()) + " != system_labels len " + str(ns))
        exit(1)
    }
    let mut si = 0
    while si < ns {
        out = out + _vt_word_line_no_thumb(system_labels[si], system_comments[si])
        si = si + 1
    }

    // Special-case the "0,0,0,0" reserved-slot chunk: CMSIS uses
    // `.word 0,0,0,0` on a single line at offsets 7..10 (between
    // UsageFault and SVC). We handle this via a `kind=zero4` chunk
    // that emits exactly that compact line — byte-identical to the
    // hand-written form.

    let nc = chunk_kinds.len()
    if chunk_labels.len() != nc {
        println("[vector_table_emit] FATAL: chunk_labels len " + str(chunk_labels.len()) + " != chunk_kinds len " + str(nc))
        exit(1)
    }
    if chunk_counts.len() != nc {
        println("[vector_table_emit] FATAL: chunk_counts len " + str(chunk_counts.len()) + " != chunk_kinds len " + str(nc))
        exit(1)
    }
    if chunk_comments.len() != nc {
        println("[vector_table_emit] FATAL: chunk_comments len " + str(chunk_comments.len()) + " != chunk_kinds len " + str(nc))
        exit(1)
    }

    let mut ci = 0
    while ci < nc {
        let kind = chunk_kinds[ci]
        let label = chunk_labels[ci]
        let count = chunk_counts[ci]
        let comment = chunk_comments[ci]
        if kind == "named" {
            out = out + _vt_word_line_no_thumb(label, comment)
        } else if kind == "pad" {
            if comment.len() > 0 {
                out = out + _vt_indent() + "/* " + comment + " */\n"
            }
            out = out + _vt_indent() + ".rept " + str(count) + "\n"
            out = out + _vt_indent() + _vt_indent() + ".word " + label + "\n"
            out = out + _vt_indent() + ".endr\n"
        } else if kind == "zero4" {
            // CMSIS reserved 4-slot block: `.word 0,0,0,0` single line.
            out = out + _vt_indent() + ".word 0,0,0,0" + "                  /* " + comment + " */\n"
        } else if kind == "zero1" {
            // CMSIS reserved single-slot: `.word 0` line w/o comment.
            out = out + _vt_indent() + ".word 0\n"
        } else {
            println("[vector_table_emit] FATAL: unknown chunk kind '" + kind + "'")
            exit(1)
        }
        ci = ci + 1
    }

    return out
}
