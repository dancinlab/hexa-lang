#!hexa strict
// stdlib/hal/numerics_ai_native_lattice.hexa — F-AI-NATIVE-1 T2 numerical.
//
// Closes the T2 (numerical / fixture) tier of falsifier F-AI-NATIVE-1
// (J₂ = σ·φ = 24 native MAC slots × provenance kinds per tile;
// falsifier_ai_native_check.hexa registry).
//
// T1 (ai.hexa internal asserts: SIGMA=12, PHI=2, J2=24, MACS_PER_TILE=24,
// MACS_PER_ARRAY=288) closes the algebraic identity:
//
//   J₂ = σ · φ = 12 · 2 = 24    (per-tile MAC slots)
//   MACS_PER_ARRAY = σ² · φ = 144 · 2 = 288    (chip-level peak)
//
// T2 (this script) cross-checks the lattice constants NUMERICALLY by
// reading them out of the on-disk ai.hexa source — the numeric values
// must be EXACT, the algebraic identity must hold against the declared
// values, and the invariant accessors must be present.
//
// Identities checked (numerically — read from source):
//
//   1. ai.hexa exists at stdlib/hal/ai.hexa.
//   2. ai.hexa declares SIGMA = 12.
//   3. ai.hexa declares PHI = 2.
//   4. ai.hexa declares J2 = 24.
//   5. SIGMA · PHI = J2 (algebraic identity from on-disk values).
//   6. ai.hexa declares MACS_PER_TILE = 24 (= J₂).
//   7. ai.hexa declares MACS_PER_ARRAY = 288 (= σ²·φ).
//   8. ai.hexa declares fn ai_invariant_macs_per_tile() (accessor).
//   9. ai.hexa declares fn ai_invariant_macs_per_array() (accessor).
//
// PASS = every identity holds against on-disk ai.hexa.
// FAIL = any constant missing OR algebraic identity drift OR accessor
//        missing.
//
// Run:
//   hexa run stdlib/hal/numerics_ai_native_lattice.hexa
//
// Cost: $0 (1 file-read + grep; no compilation).
//
// Phase G iter 9+5+8; F-AI-NATIVE-1 closure 33% → 67% (T1+T2 ✓; T3
// deferred per canon §7.5 — silicon RTL bench is downstream).
// Pattern: numerics_gpgpu_lattice.hexa (sister F-GPGPU-1 T2 fixture).

// ─── n=6 lattice constants (numerical references) ────────────────────

let EXPECTED_SIGMA           = 12
let EXPECTED_PHI             = 2
let EXPECTED_J2              = 24       // σ · φ
let EXPECTED_MACS_PER_TILE   = 24       // = J₂
let EXPECTED_MACS_PER_ARRAY  = 288      // σ² · φ

// ─── check harness ───────────────────────────────────────────────────

let mut RUN  = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ─── helpers ─────────────────────────────────────────────────────────

fn _root() -> str {
    let env_root = env("HEXA_HAL_ROOT")
    if env_root.len() > 0 { return env_root }
    return exec("pwd").trim()
}

fn _exists(p: str) -> bool {
    let r = exec("[ -f \"" + p + "\" ] && echo y || echo n").trim()
    return r == "y"
}

// Extract numeric value of `let <name> = <int>` from source.
fn _extract_let_int(src: str, name: str) -> int {
    let pat = "let " + name
    let idx = src.index_of(pat)
    if idx < 0 { return -1 }
    let mut i = idx + pat.len()
    while i < src.len() && src.char_at(i) != "=" { i = i + 1 }
    if i >= src.len() { return -1 }
    i = i + 1
    while i < src.len() && (src.char_at(i) == " " || src.char_at(i) == "\t") { i = i + 1 }
    let mut digits = ""
    while i < src.len() {
        let ch = src.char_at(i)
        if ch >= "0" && ch <= "9" { digits = digits + ch } else { break }
        i = i + 1
    }
    if digits.len() == 0 { return -1 }
    return int(digits)
}

// ─── checks ──────────────────────────────────────────────────────────

fn check_ai_hexa_present(root: str) -> bool {
    let p = root + "/stdlib/hal/ai.hexa"
    let ok = _exists(p)
    _check(ok,
           "ai.hexa present at stdlib/hal/ai.hexa",
           if ok { "found" } else { "MISSING" })
    return ok
}

fn check_const(src: str, name: str, expected: int) -> int {
    let v = _extract_let_int(src, name)
    let ok = v == expected
    _check(ok,
           "ai.hexa declares " + name + " = " + str(expected),
           "got " + str(v))
    return v
}

fn check_algebraic_identity(sigma: int, phi: int, j2: int) {
    let lhs = sigma * phi
    let ok = lhs == j2
    _check(ok,
           "σ · φ = J₂ (algebraic identity from on-disk values)",
           str(sigma) + "·" + str(phi) + "=" + str(lhs) + " want " + str(j2))
}

fn check_array_identity(sigma: int, phi: int, macs_array: int) {
    let lhs = sigma * sigma * phi
    let ok = lhs == macs_array
    _check(ok,
           "σ² · φ = MACS_PER_ARRAY (chip-level peak)",
           str(sigma) + "²·" + str(phi) + "=" + str(lhs) + " want " + str(macs_array))
}

fn check_accessor_present(src: str, name: str) {
    let pat = "fn " + name
    let ok = src.contains(pat)
    _check(ok,
           "ai.hexa declares fn " + name + "()",
           if ok { "found" } else { "missing accessor" })
}

// ─── main ────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/hal — numerics_ai_native_lattice: F-AI-NATIVE-1 T2 numerical")
    println("========================================================================")
    println("  expected: σ=" + str(EXPECTED_SIGMA) + " φ=" + str(EXPECTED_PHI) +
            " J₂=" + str(EXPECTED_J2) + " MACS_PER_TILE=" + str(EXPECTED_MACS_PER_TILE) +
            " MACS_PER_ARRAY=" + str(EXPECTED_MACS_PER_ARRAY))
    println("")

    let root = _root()

    if !check_ai_hexa_present(root) {
        println("__HEXA_LANG_HAL_NUMERICS_AI_NATIVE_LATTICE__ FAIL")
        exit(1)
    }

    let p = root + "/stdlib/hal/ai.hexa"
    let src = read_file(p)

    let sigma          = check_const(src, "SIGMA",          EXPECTED_SIGMA)
    let phi            = check_const(src, "PHI",            EXPECTED_PHI)
    let j2             = check_const(src, "J2",             EXPECTED_J2)
    let macs_per_tile  = check_const(src, "MACS_PER_TILE",  EXPECTED_MACS_PER_TILE)
    let macs_per_array = check_const(src, "MACS_PER_ARRAY", EXPECTED_MACS_PER_ARRAY)

    check_algebraic_identity(sigma, phi, j2)
    check_array_identity(sigma, phi, macs_per_array)

    check_accessor_present(src, "ai_invariant_macs_per_tile")
    check_accessor_present(src, "ai_invariant_macs_per_array")

    println("")
    println("  FALSIFIER:")
    println("    ✗ F-AI-NATIVE-1: J₂ = σ·φ = 24 native MAC slots × prov per tile (cross-checked numerically)")

    let pass_n = RUN - FAIL
    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_LANG_HAL_NUMERICS_AI_NATIVE_LATTICE__ FAIL")
        exit(1)
    }
    println("__HEXA_LANG_HAL_NUMERICS_AI_NATIVE_LATTICE__ PASS")
    exit(0)
}

main()
