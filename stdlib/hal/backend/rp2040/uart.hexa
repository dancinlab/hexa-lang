#!hexa strict
// stdlib/hal/backend/rp2040/uart.hexa — RP2040 UART backend — paper skeleton.
//
// Phase: skeleton / stub. Sim-first invariant preserved.
//
// Target:    RP2040 dual Cortex-M0+ @ 133 MHz.
// Chip ref:  RP2040 Datasheet §4.2 UART / PrimeCell PL011 UART.
// Surface:   rp2040_uart_{configure,write_byte,read_byte,close}(...)
// Dispatch:  uart.hexa selects this via cfg-flag.
//
// MMIO layout (PL011 UART IP):
//
//   UART0:  base = 0x40034000
//   UART1:  base = 0x40038000
//
//   UARTDR                        0x000   data register (rx/tx + error flags)
//   UARTRSR                       0x004   receive status / error
//   UARTFR                        0x018   flag register (TXFE/RXFE/TXFF/RXFF/BUSY)
//   UARTILPR                      0x020   IrDA low-power counter
//   UARTIBRD                      0x024   integer baud-rate divisor (16-bit)
//   UARTFBRD                      0x028   fractional baud-rate divisor (6-bit)
//   UARTLCR_H                     0x02C   line control:
//                                          BRK bit 0
//                                          PEN bit 1 (parity enable)
//                                          EPS bit 2 (even parity select)
//                                          STP2 bit 3 (2 stop bits)
//                                          FEN bit 4 (FIFO enable)
//                                          WLEN bits 6:5 (5..8 bit word length)
//   UARTCR                        0x030   control:
//                                          UARTEN bit 0 (enable)
//                                          TXE bit 8
//                                          RXE bit 9
//   UARTIFLS                      0x034   interrupt FIFO level select
//   UARTIMSC                      0x038   interrupt mask
//   UARTRIS                       0x03C   raw interrupt status
//   UARTMIS                       0x040   masked interrupt status
//   UARTDMACR                     0x048   DMA control
//
// Baud rate calculation (peri_clk = 125 MHz default):
//   divisor = peri_clk / (16 * baud)
//   IBRD = floor(divisor)
//   FBRD = round((divisor - IBRD) * 64)
//
//   e.g. 115200 baud: divisor = 125e6 / (16 * 115200) = 67.817
//        IBRD = 67, FBRD = round(0.817 * 64) = 52
//        actual baud = 125e6 / (16 * (67 + 52/64)) = 115226 (0.02% error)
//
// Word length: 5..8 bits (UARTLCR_H.WLEN = 1..3 maps to 6..9 bits with
// the convention bit 0 = +1 over 5).
//
// TODO:
//   1. cfg-flag dispatch from stdlib/hal/uart.hexa.
//   2. baud divisor IBRD/FBRD calc.
//   3. polling tx/rx with FIFO threshold.
//   4. dma path (UARTDMACR) for higher throughput.
//   5. break detection + framing/parity error reporting.

let MODULE_NAME = "rp2040_uart"
let SIGMA_SLOT  = 4
let PHI_KIND    = "digital"

let UART0_BASE = 0x40034000
let UART1_BASE = 0x40038000

// PL011 register offsets.
let UARTDR    = 0x000
let UARTFR    = 0x018
let UARTIBRD  = 0x024
let UARTFBRD  = 0x028
let UARTLCR_H = 0x02C
let UARTCR    = 0x030

// FR (flag) bit positions.
let FR_TXFE = 7   // tx FIFO empty
let FR_RXFF = 6   // rx FIFO full
let FR_TXFF = 5   // tx FIFO full
let FR_RXFE = 4   // rx FIFO empty
let FR_BUSY = 3   // BUSY

// LCR_H WLEN values: 5/6/7/8 bits.
let WLEN_8 = 3
let WLEN_7 = 2
let WLEN_6 = 1
let WLEN_5 = 0

// Standard baud rates.
let BAUD_9600   = 9600
let BAUD_115200 = 115200

// ── stub handlers ─────────────────────────────────────────────────────

fn rp2040_uart_configure(unit: int, baud: int, word_bits: int) -> int {
    if unit < 0 || unit > 1 { return -1 }
    if baud < 110 || baud > 7372800 { return -2 }
    if word_bits < 5 || word_bits > 8 { return -3 }
    // STUB: real impl would
    //   1. release reset on uart<unit> (RESETS bit 22/23)
    //   2. set UARTIBRD + UARTFBRD from baud divisor
    //   3. set UARTLCR_H: WLEN, FEN=1 (FIFO enabled), no parity
    //   4. set UARTCR: UARTEN=1, TXE=1, RXE=1
    return unit
}

fn rp2040_uart_write_byte(unit: int, byte: int) -> int {
    if unit < 0 || unit > 1 { return -1 }
    if byte < 0 || byte > 255 { return -2 }
    // STUB: spin until UARTFR.TXFF=0, then write UARTDR = byte
    return 0
}

fn rp2040_uart_read_byte(unit: int) -> int {
    if unit < 0 || unit > 1 { return -1 }
    // STUB: spin until UARTFR.RXFE=0, then read UARTDR & 0xFF
    return 0
}

fn rp2040_uart_close(unit: int) -> int {
    if unit < 0 || unit > 1 { return -1 }
    // STUB: clear UARTCR.UARTEN, hold reset on uart<unit>
    return 0
}

fn rp2040_uart_report(unit: int) -> str {
    return "[rp2040_uart sim] unit=" + str(unit) + " (skeleton stub — TODO MMIO)"
}

fn rp2040_uart_module_meta() -> [str] {
    return [MODULE_NAME, str(SIGMA_SLOT), PHI_KIND, "4"]
}

fn main() {
    println("[rp2040_uart sim] STUB skeleton — sim-first; HW MMIO TODO")
    println("  UART0=" + str(UART0_BASE) + " UART1=" + str(UART1_BASE))
    println("  default 115200 8N1 (peri_clk=125 MHz; IBRD=67, FBRD=52)")
}
