#!hexa strict
// stdlib/fusion/mhd_stability.hexa — ①b ideal-MHD β-limit adapter
// (demiurge design.md D72 2-layer STDLIB restructure · FUSION.md F4 gate (d)).
//
// THIN adapter over the domain-agnostic ①a ideal-MHD kernel
// `stdlib/kernels/mhd_stability/beta_limit.hexa`. The kernel owns the
// Troyon β-limit + the cylindrical q* + the external-kink q95 threshold;
// this adapter owns ONLY the fusion-domain operating point (an ITER-class
// reference) and the honesty caveat that those inputs are NOT a device
// measurement and that the model is LINEAR IDEAL-MHD only.
//
// @version 0.1.0
// @capabilities [pure]
// @stability stage-2 substrate. Verification anchor = the textbook Troyon
//   scaling + the cylindrical q* identity, exercised by the `--expr` atoms
//   registered in tool/verify_cli.hexa.
// @since 2026-05-25
//
// 2-layer (ABSORPTION.md ①):
//   ①a kernel  — `stdlib/kernels/mhd_stability/beta_limit.hexa`.
//                Domain-independent Troyon + cylindrical q* + kink.
//   ①b adapter — THIS FILE. Owns the fusion operating point.
//
// ══ HONESTY (g3 — non-negotiable · FUSION governance) ════════════════════
//   • The Troyon β-limit and the cylindrical q* ARE mathematical facts of
//     the published scaling / identity — exact given the inputs.
//   • BUT this is the LINEAR IDEAL-MHD limit ONLY. It is NOT turbulence,
//     NOT disruption dynamics, NOT resistive / neoclassical tearing, NOT a
//     2-D Grad-Shafranov equilibrium (gate (c)). The cylindrical q* omits
//     elongation / shaping (UNDER-estimates a shaped q95).
//   • The *input* operating point (β_N=2.8, I_p≈15 MA, a≈2 m, B≈5.3 T,
//     R≈6.2 m — ITER-class) is TEXTBOOK, NOT a real-device shot. Any
//     consumer keeps gate=GATE_OPEN / absorbed=false unless the operating
//     point comes from a measured tokamak shot. The JET measured-oracle
//     (`stdlib/fusion/jet_plasma_measured_oracle.py`, absorbed=true) is the
//     ONLY absorbed=true fusion path.
//   • A `beta < beta_Troyon` (or `q95 > 2`) PASS here is a STABILITY
//     PREDICTION of the linear ideal-MHD model — NEVER "stable device",
//     and never "Q>1".

use "stdlib/kernels/mhd_stability/beta_limit"

// ── ITER-class reference operating point (textbook · NOT a device shot) ───
//
// A representative ITER-class magnetic-confinement design point — NOT a
// measured shot:
//   β_N = 2.8       (ideal-MHD Troyon limit coefficient)
//   I_p = 15.0 MA   (ITER design plasma current)
//   a   = 2.0 m     (ITER minor radius)
//   B   = 5.3 T     (ITER on-axis toroidal field)
//   R   = 6.2 m     (ITER major radius)
// — g3: these are design reference numbers, NOT a measurement.
pub fn iter_ref_beta_n() -> float { return 2.8 }
pub fn iter_ref_ip_ma() -> float  { return 15.0 }
pub fn iter_ref_a_m() -> float    { return 2.0 }
pub fn iter_ref_b_t() -> float    { return 5.3 }
pub fn iter_ref_r_m() -> float    { return 6.2 }

/// Troyon β-limit [%] at the ITER-class reference operating point.
/// Value is a math fact of the Troyon scaling, but the chosen operating
/// point is textbook (absorbed=false). ≈ 3.962 % for the reference.
pub fn iter_ref_beta_max_pct() -> float {
    return beta_max_pct(iter_ref_beta_n(), iter_ref_ip_ma(),
                        iter_ref_a_m(), iter_ref_b_t())
}

/// Cylindrical edge safety factor q* at the ITER-class reference point.
/// HONEST: cylindrical q* OMITS elongation/shaping → UNDER-estimates the
/// shaped q95 (gate (c) Grad-Shafranov is needed for the true q95). For
/// the reference this is ≈ 1.14 — the cylindrical (circular) lower bound.
pub fn iter_ref_q_star() -> float {
    return q_star(iter_ref_a_m(), iter_ref_b_t(),
                  iter_ref_r_m(), iter_ref_ip_ma())
}

/// Troyon stability PREDICTION at the reference point for an operating β[%].
/// DESIGN-FEASIBILITY ONLY (g3 · absorbed=false): true ⇔ the linear ideal-
/// MHD model predicts no ideal-β instability at this textbook point, NEVER
/// "stable device" and never "Q>1".
pub fn iter_ref_beta_stable(operating_beta_pct: float) -> bool {
    return beta_troyon_stable(operating_beta_pct, iter_ref_beta_n(),
                              iter_ref_ip_ma(), iter_ref_a_m(),
                              iter_ref_b_t())
}

/// External-kink stability PREDICTION for a given q95. DESIGN statement
/// (g3 · absorbed=false): true ⇔ q95 > 2 (textbook external-kink boundary),
/// NOT a guarantee the device is kink-free (resistive wall modes / error
/// fields out of scope).
pub fn iter_ref_kink_stable(q95: float) -> bool {
    return kink_stable(q95)
}
