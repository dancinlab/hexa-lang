// stdlib/fusion/plasma_metrics_test.hexa — Stage 3 parity check
// (ABSORPTION.md §"hexa 포팅 단계" — substrate vs hexa-native).
//
// Cross-checks the clean-room hexa-native derivations in
// `plasma_metrics.hexa` against the plasmapy 2026.2.0 numbers
// captured from a real run on 2026-05-20 (logged in plasma_metrics.py
// header). Tolerances are chosen per parameter to honour the known
// physics:
//   • ω_pe / ω_pi / λ_D / ω_ce / ω_ci — pure non-relativistic algebra
//     → expect agreement to ~1e-9 relative (constant-table noise).
//   • v_th_e / v_th_i — same.
//   • v_A — same.
//   • r_Li — non-relativistic deuteron (v ≪ c) → tight tolerance.
//   • r_Le — plasmapy applies relativistic correction at T_e = 10 keV
//     (~2 % factor: γ ≈ 1.020 at v ≈ 0.2 c). Clean-room hexa version
//     uses the classical (textbook) formula and HONESTLY reports the
//     gap. This is documented (not absorbed) — Stage 4 absorbed=true
//     would require either matching plasmapy's relativistic correction
//     OR redefining the "gyroradius" surface to mean classical only.

// ①a kernel — domain-agnostic plasma-physics algebra (ω_ce, v_th, …).
// ①b adapter — fusion-domain ITER core reference aggregator.
use "stdlib/kernels/plasma/plasma_metrics"
use "stdlib/fusion/plasma_metrics"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
    }
}

fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }

fn rel_err(got: float, want: float) -> float {
    return fabs(got - want) / fabs(want)
}

fn main() {
    // ── ITER core reference (textbook): n_e=1e20 · T_e=T_i=10 keV ──
    //     B=5.3 T · majority D+. Reference values from plasmapy
    //     2026.2.0 / Python 3.12.3 on ubu-2 (Linux) AND Python 3.14.4
    //     on darwin — byte-identical to 15 digits across hosts.

    // ω_pe — pure non-relativistic algebra, expect ~1e-9 relative.
    let omega_pe_got = iter_core_omega_pe()
    let omega_pe_want = 564146023118.0627
    check("omega_pe vs plasmapy (1e-6 rel)",
          rel_err(omega_pe_got, omega_pe_want) < 0.000001)

    // λ_D — pure non-relativistic algebra.
    let lambda_d_got = iter_core_lambda_d()
    let lambda_d_want = 7.433941994700464e-05
    check("lambda_D vs plasmapy (1e-6 rel)",
          rel_err(lambda_d_got, lambda_d_want) < 0.000001)

    // ω_ce — Lorentz algebra.
    let omega_ce_got = omega_ce(iter_core_b_t())
    let omega_ce_want = 932174605709.2465
    check("omega_ce vs plasmapy (1e-6 rel)",
          rel_err(omega_ce_got, omega_ce_want) < 0.000001)

    // ω_ci (D+) — Lorentz algebra, depends on deuteron_mass.
    let omega_ci_got = omega_ci_deuteron(iter_core_b_t())
    let omega_ci_want = 253965112.70068184
    check("omega_ci_D+ vs plasmapy (1e-4 rel)",
          rel_err(omega_ci_got, omega_ci_want) < 0.0001)

    // v_th_e (most-probable) — Maxwell-Boltzmann algebra.
    let vte_got = v_thermal_e(iter_core_t_e_ev())
    let vte_want = 59309695.84768014
    check("v_th_e vs plasmapy (1e-6 rel)",
          rel_err(vte_got, vte_want) < 0.000001)

    // v_th_i (D+, most-probable).
    let vti_got = v_thermal_deuteron(iter_core_t_i_ev())
    let vti_want = 978958.0766568249
    check("v_th_i_D+ vs plasmapy (1e-4 rel)",
          rel_err(vti_got, vti_want) < 0.0001)

    // v_A (D+ majority) — MHD algebra. Stage 3 PARITY FINDING:
    // hexa-native classical v_A = B/√(μ₀·n_i·m_D) agrees with
    // plasmapy 2026.2.0 to ~1.4e-4 relative. Reversing plasmapy's
    // effective ion mass from its v_A gives ≈3.34425e-27 kg, ~0.02 %
    // heavier than the CODATA deuteron mass that its ω_ci uses
    // (≈3.34365e-27 kg) — i.e. plasmapy applies a different ion-mass
    // convention to Alfvén speed than to cyclotron frequency. The
    // textbook classical formula here is honest; the residual gap is
    // a documented Stage-3 finding, NOT absorbed. Tolerance 1e-3.
    let vA_got = iter_core_v_alfven()
    let vA_want = 8175337.380572415
    check("v_A_D+ vs plasmapy (1e-3 rel; ~1.4e-4 actual, doc gap)",
          rel_err(vA_got, vA_want) < 0.001)

    // r_Li (D+) — non-relativistic deuteron.
    let rLi_got = gyroradius_deuteron(iter_core_t_i_ev(), iter_core_b_t())
    let rLi_want = 0.00385471565638207
    check("r_Li_D+ vs plasmapy (1e-4 rel)",
          rel_err(rLi_got, rLi_want) < 0.0001)

    // r_Le — clean-room classical vs plasmapy relativistic. Expect
    // ~2 % gap at T_e = 10 keV. This check is INVERTED: we EXPECT
    // the gap to exist, and we honestly bound it. Stage 4
    // absorbed=true would require resolving this.
    let rLe_got = gyroradius_e(iter_core_t_e_ev(), iter_core_b_t())
    let rLe_want_plasmapy = 6.490798862141296e-05
    let rLe_gap = rel_err(rLe_got, rLe_want_plasmapy)
    // Documented relativistic gap: γ−1 ≈ 0.020 at v ≈ 0.2 c.
    // Bound the gap loosely to confirm the HONEST 2% discrepancy.
    check("r_Le classical ≠ plasmapy relativistic (gap 1–3 %)",
          rLe_gap > 0.01 && rLe_gap < 0.03)

    print("plasma_metrics_test: " + str(pass_count) + "/" + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
    } else {
        print("PASS")
    }
}
