#!hexa strict
// fusion analyze — Lawson triple product target for D-T at T=10 keV.
fn main() {
    let n_e = 1.0e20          // m^-3
    let T_keV = 10.0
    let tau_E_s = 3.0         // s (ITER target)
    let triple = n_e * T_keV * tau_E_s  // m^-3 · keV · s
    let ignition_target = 3.0e21        // D-T ignition criterion
    println("fusion_analyze (Lawson triple product · D-T 10 keV):")
    println("  n_e_T_tau = " + str(triple) + " (m^-3 keV s)")
    println("  ignition_target = " + str(ignition_target))
    println("__HEXA_FUSION_ANALYZE__ PASS gate=GATE_OPEN absorbed=false")
}
