// stdlib/fusion/_plasma_lambda_d_batch.hexa — κ-70 G37 batch wrapper
// for hexa-native Debye-length (λ_D) closed-form evaluation.
//
// Sibling pattern to `stdlib/aura/_dft_alpha_band_batch.hexa` (κ-69
// G33) and `stdlib/energy/_solar_position_batch.hexa` (G31 G29-β):
// one subprocess invocation processes N stationary timesteps of
// (n_e, T_e) plasma measurements and returns one λ_D per timestep.
//
// The producer side (`jet_plasma_measured_oracle.py` for κ-70 G37)
// fetches a JET (or JET-like synthetic) mid-Ohmic pulse profile,
// writes (n_e_m3, T_e_eV) pairs to a sidecar, then invokes THIS
// wrapper once with the sidecar path + n_steps. Output is `n_steps`
// floats on stdout, one per line, in timestep order (no header).
//
// CLI shape:
//   hexa run stdlib/fusion/_plasma_lambda_d_batch.hexa \
//     <profile_path> <n_steps>
//
// <profile_path>   ASCII file, one `n_e_m3 T_e_eV` pair per line,
//                  whitespace-separated. n_steps non-blank rows
//                  required. Comments (`#`) and blank lines skipped.
// <n_steps>        Expected number of stationary timesteps.
//
// Output: <n_steps> lines on stdout, one λ_D [m] per line.
//         λ_D = sqrt(ε₀ · T_e_eV / (n_e · e)) using the kernel-side
//         `plasma_metrics_kernel::lambda_d` (NRL Formulary p.34 +
//         Krall & Trivelpiece ch.1 textbook closed-form · 41/41
//         PASS @ rel_err = 0.0 IEEE-754 bit-exact vs hand-mirrored
//         Python `math` reference).
//
// Exit: 0 on success, 2 on usage error, 3 on file-read / parse error.
//
// HONESTY (g3 — non-negotiable):
//   * The λ_D is the textbook closed-form (Krall & Trivelpiece ch.1
//     + NRL Formulary p.34) — `plasma_metrics_kernel.hexa` carries
//     the clean-room provenance. 41/41 PASS @ rel_err = 0.0
//     vs hand-mirrored Python `math` reference on 8 sample points
//     spanning 19 orders of magnitude in n_e.
//   * NO physics model on the *inputs* — this kernel evaluates the
//     formula on whatever (n_e, T_e) pairs the producer supplies.
//     The honest claim is that the formula evaluation is bit-exact
//     vs the trusted-bridge `plasmapy`-or-textbook-Python reference,
//     measured on a JET (or JET-like) mid-Ohmic stationary profile.
//   * NO ITER / JET / NSTX operating-point assumption baked in —
//     the kernel is domain-agnostic per its ①a layer (kernel-only,
//     no adapter). The mid-Ohmic stationary regime claim lives in
//     the producer + the dataset_caveats of the emitted record.

use "stdlib/kernels/plasma/plasma_metrics_kernel"

fn main() {
    let argv = args()
    let n = len(argv)
    if n < 3 {
        println(
            "usage: hexa run _plasma_lambda_d_batch.hexa "
            + "<profile_path> <n_steps>")
        exit(2)
    }

    let profile_path = argv[1]
    let n_steps = argv[2].to_int()

    let text = read_file(profile_path)
    let lines = text.split("\n")

    let mut emitted = 0
    let mut idx = 0
    while idx < len(lines) {
        let ln = lines[idx].trim()
        if len(ln) > 0 {
            if !ln.starts_with("#") {
                // Split on whitespace — accept any run of spaces / tabs.
                // The hexa `split` is single-delimiter, so we collapse
                // tabs to spaces, then drop empty tokens after a single-
                // space split.
                let normalised = ln.replace("\t", " ")
                let tokens_raw = normalised.split(" ")
                let mut tokens: [str] = []
                let mut ti = 0
                while ti < len(tokens_raw) {
                    let tok = tokens_raw[ti].trim()
                    if len(tok) > 0 {
                        tokens = tokens.push(tok)
                    }
                    ti = ti + 1
                }
                if len(tokens) >= 2 {
                    let n_e = tokens[0].to_float()
                    let t_e = tokens[1].to_float()
                    let lam_d = lambda_d(t_e, n_e)
                    println(str(lam_d))
                    emitted = emitted + 1
                    if emitted >= n_steps {
                        return
                    }
                }
            }
        }
        idx = idx + 1
    }

    if emitted < n_steps {
        println(
            "FATAL _plasma_lambda_d_batch: profile provided "
            + str(emitted) + " (n_e, T_e) pairs, expected "
            + str(n_steps))
        exit(3)
    }
}
