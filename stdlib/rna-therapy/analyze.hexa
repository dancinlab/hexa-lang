#!hexa strict
// rna-therapy analyze — duplex ΔG (rough NN sum, kcal/mol).
fn main() {
    let n_GC = 10.0
    let n_AU = 11.0
    let dG_kcalmol = 0.0 - 3.0 * n_GC - 2.0 * n_AU
    println("rna-therapy_analyze (21-mer duplex · rough NN):")
    println("  n_GC = " + str(n_GC) + "  n_AU = " + str(n_AU))
    println("  dG_kcal_per_mol = " + str(dG_kcalmol))
    println("__HEXA_RNA_THERAPY_ANALYZE__ PASS gate=GATE_OPEN absorbed=false")
}
