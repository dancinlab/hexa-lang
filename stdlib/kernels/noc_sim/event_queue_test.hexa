// stdlib/kernels/noc_sim/event_queue_test.hexa
// D80 g_hexa_only pilot — parity test for event_queue.hexa.
//
// Three tiers:
//   (1) BASIC heap discipline — push N events, pop them all, verify
//       monotone-nondecreasing time.
//   (2) FIFO-AT-EQUAL-TIMES — two events at exactly t=1.0 must pop
//       in insertion order (the `seq` tiebreaker).
//   (3) PYTHON-COMPANION parity — fixed insert script (5 events with
//       a tie) produces the same pop sequence as
//       `event_queue.py::_smoke()` (recorded 2026-05-20). The
//       expected sequence is:
//         (0.5, 104, seq=4) → (1.0, 101, seq=1) → (1.0, 103, seq=3)
//         → (2.0, 100, seq=0) → (3.0, 102, seq=2)

use "stdlib/kernels/noc_sim/event_queue"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
        print("FAIL " + name)
    }
}

fn fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

fn main() {
    // ────────────────────────────────────────────────────────────────
    // Case 1: empty-queue behavior — peek and pop return the sentinel
    //   without aborting.
    // ────────────────────────────────────────────────────────────────
    let q0 = eq_new()
    check("c1 empty size = 0", eq_size(q0) == 0)
    check("c1 empty() = true", eq_empty(q0))
    let p0 = eq_peek(q0)
    check("c1 empty peek sentinel id == -1", p0.id == -1)
    check("c1 empty peek sentinel time == -1.0",
          fabs(p0.time - (0.0 - 1.0)) < 1e-12)
    let r0 = eq_pop(q0)
    check("c1 empty pop ok=false", r0.ok == false)
    check("c1 empty pop sentinel id == -1", r0.ev.id == -1)

    // ────────────────────────────────────────────────────────────────
    // Case 2: basic heap discipline — push 8 events at random times,
    //   pop all, verify monotone-nondecreasing time.
    // ────────────────────────────────────────────────────────────────
    let mut q1 = eq_new()
    let times = [4.7, 1.2, 8.0, 0.5, 3.3, 9.1, 2.0, 6.4]
    let mut i = 0
    while i < 8 {
        q1 = eq_push(q1, times[i], i, 0)
        i = i + 1
    }
    check("c2 size after 8 pushes == 8", eq_size(q1) == 8)
    check("c2 not empty", eq_empty(q1) == false)

    let mut prev_t = 0.0 - 1.0
    let mut monotone = true
    let mut n_popped = 0
    let mut qcur = q1
    while eq_empty(qcur) == false {
        let r = eq_pop(qcur)
        qcur = r.q
        if r.ev.time < prev_t { monotone = false }
        prev_t = r.ev.time
        n_popped = n_popped + 1
    }
    check("c2 popped exactly 8", n_popped == 8)
    check("c2 monotone-nondecreasing times", monotone)
    check("c2 queue drained", eq_empty(qcur))

    // ────────────────────────────────────────────────────────────────
    // Case 3: FIFO at equal times — two pushes at t=1.0, then one at
    //   t=2.0, then one more at t=1.0. Expect pop order: (1.0, seq=0)
    //   → (1.0, seq=1) → (1.0, seq=3) → (2.0, seq=2).
    // ────────────────────────────────────────────────────────────────
    let mut q2 = eq_new()
    q2 = eq_push(q2, 1.0, 50, 0)   // seq=0
    q2 = eq_push(q2, 1.0, 51, 0)   // seq=1
    q2 = eq_push(q2, 2.0, 52, 0)   // seq=2
    q2 = eq_push(q2, 1.0, 53, 0)   // seq=3

    let p1 = eq_pop(q2)
    q2 = p1.q
    check("c3 first pop id==50 (FIFO at t=1)", p1.ev.id == 50)
    check("c3 first pop seq==0", p1.ev.seq == 0)

    let p2 = eq_pop(q2)
    q2 = p2.q
    check("c3 second pop id==51 (FIFO at t=1)", p2.ev.id == 51)
    check("c3 second pop seq==1", p2.ev.seq == 1)

    let p3 = eq_pop(q2)
    q2 = p3.q
    check("c3 third pop id==53 (third t=1 insertion)", p3.ev.id == 53)
    check("c3 third pop seq==3", p3.ev.seq == 3)

    let p4 = eq_pop(q2)
    q2 = p4.q
    check("c3 fourth pop id==52 (t=2 came after)", p4.ev.id == 52)
    check("c3 fourth pop time==2.0", fabs(p4.ev.time - 2.0) < 1e-12)
    check("c3 drained", eq_empty(q2))

    // ────────────────────────────────────────────────────────────────
    // Case 4: Python-companion parity (see `event_queue.py::_smoke()`).
    //   Insert: (2.0,100), (1.0,101), (3.0,102), (1.0,103), (0.5,104).
    //   Expected pop sequence:
    //     (0.5,  104, seq=4)
    //     (1.0,  101, seq=1)
    //     (1.0,  103, seq=3)
    //     (2.0,  100, seq=0)
    //     (3.0,  102, seq=2)
    // ────────────────────────────────────────────────────────────────
    let mut q3 = eq_new()
    q3 = eq_push(q3, 2.0, 100, 0)
    q3 = eq_push(q3, 1.0, 101, 0)
    q3 = eq_push(q3, 3.0, 102, 0)
    q3 = eq_push(q3, 1.0, 103, 0)
    q3 = eq_push(q3, 0.5, 104, 0)

    let r1 = eq_pop(q3); q3 = r1.q
    let r2 = eq_pop(q3); q3 = r2.q
    let r3 = eq_pop(q3); q3 = r3.q
    let r4 = eq_pop(q3); q3 = r4.q
    let r5 = eq_pop(q3); q3 = r5.q

    check("c4.1 pop id==104", r1.ev.id == 104)
    check("c4.1 pop time==0.5", fabs(r1.ev.time - 0.5) < 1e-12)
    check("c4.1 pop seq==4", r1.ev.seq == 4)

    check("c4.2 pop id==101", r2.ev.id == 101)
    check("c4.2 pop time==1.0", fabs(r2.ev.time - 1.0) < 1e-12)
    check("c4.2 pop seq==1", r2.ev.seq == 1)

    check("c4.3 pop id==103", r3.ev.id == 103)
    check("c4.3 pop seq==3", r3.ev.seq == 3)

    check("c4.4 pop id==100", r4.ev.id == 100)
    check("c4.4 pop time==2.0", fabs(r4.ev.time - 2.0) < 1e-12)

    check("c4.5 pop id==102", r5.ev.id == 102)
    check("c4.5 pop time==3.0", fabs(r5.ev.time - 3.0) < 1e-12)

    check("c4 drained", eq_empty(q3))

    // ────────────────────────────────────────────────────────────────
    // Case 5: stress — push 32 events at random times (with full
    //   in-flight retention), drain in one pass, verify monotone-
    //   nondecreasing pop times. (Interleaved push/pop with a
    //   late-arriving smaller time is a CALLER bug — the kernel
    //   correctly returns the smallest currently-queued time, which
    //   in that case is a step backward; that scenario is exercised
    //   in case 3 via the seq tiebreaker and is not retested here.)
    // ────────────────────────────────────────────────────────────────
    let mut q4 = eq_new()
    let mut step = 0
    while step < 32 {
        // pseudo-random scatter — (step * 7 mod 19) + 0.1·step is
        // not monotone but covers a wide spread of times.
        let t = to_float((step * 7) % 19) + 0.1 * to_float(step)
        q4 = eq_push(q4, t, step, 0)
        step = step + 1
    }
    check("c5 size after 32 pushes == 32", eq_size(q4) == 32)

    let mut prev = 0.0 - 1.0
    let mut ok5 = true
    let mut pops5 = 0
    while eq_empty(q4) == false {
        let r = eq_pop(q4)
        q4 = r.q
        if r.ev.time < prev { ok5 = false }
        prev = r.ev.time
        pops5 = pops5 + 1
    }
    check("c5 stress monotone pop times", ok5)
    check("c5 stress all 32 popped", pops5 == 32)

    print("event_queue_test: " + str(pass_count) + "/" + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
        exit(1)
    } else {
        print("PASS")
    }
}
