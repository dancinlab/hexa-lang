// stdlib/kernels/solar/solar_kernel.hexa — D80 g_hexa_only pilot
// (demiurge AGENTS.tape @D g_hexa_only — ultimate form).
//
// First sample of the hexa-native parity port pattern. Clean-room
// hexa-native solar position + Haurwitz clear-sky GHI kernel,
// mirroring the textbook trig algebra that pvlib's
// `solarposition.ephemeris` (Grover Hughes / Sandia 1985) and
// `clearsky.haurwitz` (1945) implement. Substrate parity vs pvlib
// 0.13.0 lives in `solar_kernel_test.hexa`.
//
// Layer (ABSORPTION.md ① / demiurge design.md D72):
//   ①a kernel — THIS FILE. Domain-agnostic. No Phoenix site, no CEC
//                module, no 2024 calendar. Pure "lat/lon + UTC time
//                -> solar position", "zenith -> GHI". A solar-domain
//                ①b adapter (e.g. `stdlib/energy/solar_clearsky.hexa`,
//                future) would supply the site + caveats.
//   ①b adapter — current adapter `stdlib/energy/pvlib_clearsky.py`
//                still calls the heavy `pvlib_kernel.py` ModelChain.
//                Re-pointing the adapter at this kernel is a
//                follow-on once the SAPM PV-system layer (DC peak,
//                AC inverter) also ports to hexa-native.
//
// @version 0.1.0
// @capabilities [pure]
// @stability stage-2 substrate (clean-room re-derivation, no pvlib
//   call). Substrate parity against pvlib 0.13.0 verified by
//   `solar_kernel_test.hexa` for 6 timestamps over Phoenix AZ to
//   <1e-9 relative on zenith / azimuth, <1e-9 relative on Haurwitz
//   GHI (well inside the 0.1 % D80 tolerance).
// @since 2026-05-20
//
// CLEAN-ROOM PROVENANCE
//   This module carries NO pvlib code — it implements the Grover
//   Hughes / Sandia 1985 ephemeris formulae directly from textbook
//   spherical-astronomy algebra (Meeus "Astronomical Algorithms"
//   1998 ch.22, 25) and the Haurwitz 1945 closed-form clear-sky
//   relation. Both algorithms are mathematical-fact open-form
//   expressions; no proprietary or copyrighted source.
//
//   - upstream code   : none (clean-room re-derivation)
//   - upstream spec   : F.Haurwitz, "Insolation in Relation to
//                       Cloudiness and Surface Temperature", J.Met.
//                       2(3) 1945, eq.(1).
//                       G.Hughes, "Engineering Astronomy" course
//                       notes, Sandia National Laboratories, 1985
//                       (PVLIB_MATLAB origin, public domain).
//   - parity baseline : pvlib 0.13.0 `solarposition.ephemeris` +
//                       `clearsky.haurwitz` on darwin-arm64,
//                       Python 3.x.
//
// HONESTY (g3 — non-negotiable, inherited by every caller):
//   * Computed GHI IS the algorithm output — both `ephemeris` and
//     `haurwitz` are deterministic closed-form expressions; given
//     identical (year, doy, utc_hour, lat, lon, pressure, temp_C)
//     they MUST produce identical numbers to last-bit-of-double
//     across hosts. The parity test asserts <1e-9 relative.
//   * BUT clear-sky GHI is the CLEAR-SKY upper bound, not measured
//     irradiance — there is no satellite/pyranometer feed here. Any
//     ①b adapter that consumes this kernel keeps gate=GATE_OPEN and
//     `absorbed=false` at the record layer until a measured oracle
//     is wired in.
//   * The Grover Hughes ephemeris itself is documented as "accuracy
//     not guaranteed" in pvlib — for sub-arcmin work use SPA. This
//     kernel deliberately ports the SIMPLER algorithm to keep the
//     first hexa-native port reviewable. A future SPA port can
//     coexist (`solar_kernel_spa.hexa`).
//   * Substrate parity (`solar_kernel_test.hexa`) only proves the
//     PORT PATTERN — D80's record-layer `absorbed=true` flip needs
//     the demiurge HexaNativeParityRef schema + a measured GHI
//     oracle (out of scope here per g3).
//
// Surface (all inputs UTC; outputs SI degrees / W·m⁻²):
//   pub fn solar_zenith(year, doy, utc_hour, lat_deg, lon_deg) -> deg
//   pub fn solar_azimuth(year, doy, utc_hour, lat_deg, lon_deg) -> deg
//   pub fn solar_elevation(year, doy, utc_hour, lat_deg, lon_deg) -> deg
//   pub fn apparent_zenith(year, doy, utc_hour, lat_deg, lon_deg,
//                          pressure_pa, temp_c) -> deg
//   pub fn refraction_correction(elev_deg, pressure_pa, temp_c) -> deg
//   pub fn haurwitz_ghi(apparent_zenith_deg) -> W·m⁻²
//   pub fn kasten_airmass_relative(apparent_zenith_deg) -> unitless
//   pub fn kasten_airmass_absolute(apparent_zenith_deg, pressure_pa) -> unitless
//   pub fn alt2pres(altitude_m) -> Pa
//   pub fn ineichen_ghi(apparent_zenith_deg, airmass_absolute,
//                       linke_turbidity, altitude_m, dni_extra) -> W·m⁻²

use "stdlib/core/math/float"

// ── helpers ──────────────────────────────────────────────────────────

/// Float modulo: pvlib uses np.mod which floors. Implemented via
/// `x − floor(x/y)·y` since the hexa codegen does not lower `%` on
/// floats (only on ints).
fn fmod_floor(x: float, y: float) -> float {
    return x - floor(x / y) * y
}

/// Degrees → radians.
fn radians(d: float) -> float {
    return d * pi() / 180.0
}

/// Radians → degrees.
fn degrees(r: float) -> float {
    return r * 180.0 / pi()
}

// ── ephemeris (Grover Hughes / Sandia 1985, pvlib parity) ────────────

/// Clean-room hexa-native port of pvlib.solarposition.ephemeris.
/// Returns 5 doubles packed into a tuple-like fixed array:
///   [elevation_deg, azimuth_deg, zenith_deg, hour_angle_deg, solar_time_h]
/// Solar time in [0, 24); azimuth in [0, 360); zenith = 90 − elevation.
///
/// Inputs:
///   year       — Gregorian year (e.g. 2024)
///   doy        — day-of-year, 1-based (Jan 1 = 1)
///   utc_hour   — decimal UTC hour, [0, 24)
///   lat_deg    — latitude north +, south − (decimal degrees)
///   lon_deg    — longitude east +, west − (decimal degrees, modern
///                ISO convention; algorithm internally negates to the
///                1985 PVLIB_MATLAB convention)
///
/// Returns floats packed in a 5-element array.
pub fn ephemeris(year: int, doy: int, utc_hour: float,
                 lat_deg: float, lon_deg: float) -> [float] {
    // The 1985 PVLIB_MATLAB code treated west-positive longitude;
    // pvlib-python keeps that internal convention. We negate so the
    // public API uses modern east-positive.
    let lon_west = -1.0 * lon_deg
    let abber = 20.0 / 3600.0
    let lat_r = radians(lat_deg)

    // ── Yr / YrBegin (J1900.0 base, pvlib eq.) ───────────────────────
    let yr = to_float(year - 1900)
    let yr_begin = 365.0 * yr + floor((yr - 1.0) / 4.0) - 0.5

    // Days since 1900-01-01.5 to midnight UTC of (year, doy).
    let ezero = yr_begin + to_float(doy)
    let t = ezero / 36525.0

    // ── Greenwich mean sidereal time (deg) ───────────────────────────
    let gmst0 = 6.0 / 24.0 + 38.0 / 1440.0 +
        (45.836 + 8640184.542 * t + 0.0929 * t * t) / 86400.0
    let gmst0d = 360.0 * (gmst0 - floor(gmst0))
    let gmsti = fmod_floor(gmst0d + 360.0 * (1.0027379093 * utc_hour / 24.0),
                           360.0)

    // ── Local apparent sidereal time ─────────────────────────────────
    let loc_ast = fmod_floor(360.0 + gmsti - lon_west, 360.0)

    // ── Orbital elements at epoch ────────────────────────────────────
    let epoch_date = ezero + utc_hour / 24.0
    let t1 = epoch_date / 36525.0
    let obliquity_r = radians(23.452294 - 0.0130125 * t1
        - 1.64e-06 * t1 * t1 + 5.03e-07 * t1 * t1 * t1)
    let ml_perigee = 281.22083 + 4.70684e-05 * epoch_date
        + 0.000453 * t1 * t1 + 3e-06 * t1 * t1 * t1
    let mean_anom = fmod_floor(358.47583 + 0.985600267 * epoch_date
        - 0.00015 * t1 * t1 - 3e-06 * t1 * t1 * t1, 360.0)
    let eccen = 0.01675104 - 4.18e-05 * t1 - 1.26e-07 * t1 * t1

    // ── Kepler iteration (Newton-ish; pvlib uses the simple
    // ── eccentricity series E_{n+1} = M + e·sin(E_n) ─────────────────
    let mut eccen_anom = mean_anom
    let mut e_prev = 0.0
    let mut diff = eccen_anom - e_prev
    if diff < 0.0 { diff = -diff }
    let mut iter = 0
    while diff > 0.0001 && iter < 50 {
        e_prev = eccen_anom
        eccen_anom = mean_anom + degrees(eccen) * sin(radians(e_prev))
        diff = eccen_anom - e_prev
        if diff < 0.0 { diff = -diff }
        iter = iter + 1
    }

    // ── True anomaly (pvlib formula — note np.mod and degrees) ───────
    let half_eccen_r = radians(eccen_anom) / 2.0
    let factor = sqrt((1.0 + eccen) / (1.0 - eccen))
    let true_anom = 2.0 * fmod_floor(
        degrees(atan2(factor * tan(half_eccen_r), 1.0)), 360.0)

    // ── Ecliptic longitude → declination & right ascension ───────────
    let ec_lon = fmod_floor(ml_perigee + true_anom, 360.0) - abber
    let ec_lon_r = radians(ec_lon)
    let dec_r = asin(sin(obliquity_r) * sin(ec_lon_r))
    let rt_ascen = degrees(atan2(cos(obliquity_r) * sin(ec_lon_r),
                                  cos(ec_lon_r)))

    // ── Hour angle (deg, signed) ─────────────────────────────────────
    let mut hr_angle = loc_ast - rt_ascen
    let hr_angle_r = radians(hr_angle)
    // pvlib: HrAngle = HrAngle - (360 * (abs(HrAngle) > 180))
    let mut ah = hr_angle
    if ah < 0.0 { ah = -ah }
    if ah > 180.0 {
        hr_angle = hr_angle - 360.0
    }

    // ── Azimuth (deg East of North) ──────────────────────────────────
    let mut sun_az = degrees(atan2(-sin(hr_angle_r),
        cos(lat_r) * tan(dec_r) - sin(lat_r) * cos(hr_angle_r)))
    if sun_az < 0.0 { sun_az = sun_az + 360.0 }

    // ── Elevation (deg) ──────────────────────────────────────────────
    let sun_el = degrees(asin(
        cos(lat_r) * cos(dec_r) * cos(hr_angle_r)
        + sin(lat_r) * sin(dec_r)))

    let solar_time = (180.0 + hr_angle) / 15.0
    let zenith = 90.0 - sun_el

    return [sun_el, sun_az, zenith, hr_angle, solar_time]
}

/// Solar elevation (deg) — geometric, no refraction.
pub fn solar_elevation(year: int, doy: int, utc_hour: float,
                       lat_deg: float, lon_deg: float) -> float {
    let r = ephemeris(year, doy, utc_hour, lat_deg, lon_deg)
    return r[0]
}

/// Solar azimuth (deg East of North, [0, 360)).
pub fn solar_azimuth(year: int, doy: int, utc_hour: float,
                     lat_deg: float, lon_deg: float) -> float {
    let r = ephemeris(year, doy, utc_hour, lat_deg, lon_deg)
    return r[1]
}

/// Solar zenith (deg) — geometric, no refraction.
pub fn solar_zenith(year: int, doy: int, utc_hour: float,
                    lat_deg: float, lon_deg: float) -> float {
    let r = ephemeris(year, doy, utc_hour, lat_deg, lon_deg)
    return r[2]
}

// ── refraction (pvlib piecewise, deg → deg) ──────────────────────────

/// Atmospheric refraction correction (deg) given geometric elevation
/// (deg), surface pressure (Pa), and surface temperature (°C).
///
/// Piecewise model from PVLIB_MATLAB Sandia 1985:
///   • elev ∈ ( 5°, 85°]:   58.1/tan(E) − 0.07/tan³(E) + 8.6e-5/tan⁵(E)
///   • elev ∈ (−0.575°, 5°]: cubic polynomial in elevation
///   • elev ∈ (−1°,   −0.575°]: −20.774/tan(E)
///   • otherwise: 0
/// All in arc-seconds before the (283/(273+T)·(P/101325)/3600) scale.
pub fn refraction_correction(elev_deg: float, pressure_pa: float,
                             temp_c: float) -> float {
    let mut refract_arcsec = 0.0
    let tan_el = tan(radians(elev_deg))

    let tan2 = tan_el * tan_el
    let tan3 = tan2 * tan_el
    let tan5 = tan3 * tan2

    if elev_deg > 5.0 && elev_deg <= 85.0 {
        // pvlib: 58.1/tan(E) − 0.07/tan³(E) + 8.6e-5/tan⁵(E) [arcsec]
        let t1 = 58.1 / tan_el
        let t2 = 0.07 / tan3
        let t3 = 8.6e-05 / tan5
        refract_arcsec = t1 - t2 + t3
    } else if elev_deg > -0.575 && elev_deg <= 5.0 {
        // Horner-form cubic from PVLIB_MATLAB (arcsec).
        let c1 = -12.79 + elev_deg * 0.711
        let c2 = 103.4 + elev_deg * c1
        let c3 = -518.2 + elev_deg * c2
        refract_arcsec = elev_deg * c3 + 1735.0
    } else if elev_deg > -1.0 && elev_deg <= -0.575 {
        refract_arcsec = -20.774 / tan_el
    }

    let scale = (283.0 / (273.0 + temp_c)) * (pressure_pa / 101325.0) / 3600.0
    return refract_arcsec * scale
}

/// Apparent zenith (deg) = 90 − (geometric_elevation + refraction).
/// Pressure default 101325 Pa, temp default 12 °C — pvlib defaults.
pub fn apparent_zenith(year: int, doy: int, utc_hour: float,
                       lat_deg: float, lon_deg: float,
                       pressure_pa: float, temp_c: float) -> float {
    let elev = solar_elevation(year, doy, utc_hour, lat_deg, lon_deg)
    let refract = refraction_correction(elev, pressure_pa, temp_c)
    return 90.0 - (elev + refract)
}

// ── Haurwitz 1945 clear-sky GHI ──────────────────────────────────────

/// Haurwitz 1945 closed-form clear-sky global horizontal irradiance
/// (W·m⁻²) from apparent zenith (deg).
///   GHI = 1098 · cos(z) · exp(−0.059 / cos(z))     for z < 90°
///   GHI = 0                                         otherwise
/// pvlib reference: `pvlib.clearsky.haurwitz`.
pub fn haurwitz_ghi(apparent_zenith_deg: float) -> float {
    if apparent_zenith_deg >= 90.0 { return 0.0 }
    let cos_z = cos(radians(apparent_zenith_deg))
    if cos_z <= 0.0 { return 0.0 }
    return 1098.0 * cos_z * exp(-0.059 / cos_z)
}

// G31β — Kasten-Young 1989 airmass + Ineichen-Perez 2002 clearsky.
//
// Second clean-room hexa-native port closing the pvlib runtime
// dependency on the modeled side of the Energy/solar measured-oracle
// producer. The Kasten-Young 1989 relative airmass and the
// Ineichen-Perez 2002 clearsky GHI are both closed-form mathematical
// expressions with empirical constants from the cited publications;
// no proprietary upstream code is reused.
//
// References:
//   F. Kasten and A. T. Young, "Revised optical air mass tables and
//     approximation formula", Applied Optics 28(22) 1989 pp.4735-4738.
//   P. Ineichen and R. Perez, "A new airmass independent formulation
//     for the Linke turbidity coefficient", Solar Energy 73(3) 2002
//     pp.151-157.
//
// Parity baseline: pvlib 0.13.x
//   `atmosphere.get_relative_airmass(z, model='kastenyoung1989')`
//   `atmosphere.get_absolute_airmass(am_r, pressure)`
//   `atmosphere.alt2pres(altitude)`
//   `clearsky.ineichen(..., perez_enhancement=False)` (default)
//
// HONESTY:
//   * `ineichen_ghi` here ports the DEFAULT pvlib path
//     (perez_enhancement=False — see pvlib/issues/435 for why the
//     enhancement is off by default; producer also does not enable
//     it). The optional Perez airmass-enhancement factor
//     `exp(0.01 * am^1.8)` is NOT applied.
//   * Linke turbidity climatology (the monthly 5-min lat/lon lookup
//     grid bundled with pvlib as `LinkeTurbidities.h5`) is OUT OF
//     SCOPE for this kernel. Callers must supply `linke_turbidity`
//     directly; the demiurge producer continues to obtain it from
//     `pvlib.clearsky.lookup_linke_turbidity`. That's a NetCDF
//     climatology axis separate from the closed-form math here.
//   * Returns 0 for zenith ≥ 90° (sun below horizon) — matches the
//     `np.maximum(cosd(zen), 0)` clamp in the pvlib implementation.

/// Standard sea-level barometric pressure (Pa). Matches pvlib's
/// `P0 = 101325.` reference for absolute-airmass scaling.
pub fn sea_level_pressure_pa() -> float { return 101325.0 }

/// Site pressure (Pa) from altitude (m), per pvlib `alt2pres`:
///   P = 100 · ((44331.514 − altitude) / 11880.516) ^ (1/0.1902632)
///
/// Assumes ISA-like atmosphere (base 101325 Pa, T₀=288.15 K, lapse
/// −6.5e-3 K/m, g=9.80665 m/s², R=287.053 J/(kg·K), RH=0).
pub fn alt2pres(altitude_m: float) -> float {
    return 100.0 * pow((44331.514 - altitude_m) / 11880.516,
                       1.0 / 0.1902632)
}

/// Kasten-Young 1989 relative airmass (sea-level, apparent-zenith).
///   am_r = 1 / ( cos(z) + 0.50572 · (6.07995 + (90 − z))^(−1.6364) )
/// Returns +∞-equivalent (a very large finite value) when the sun is
/// at or below the horizon (z ≥ 90°); callers should gate on the
/// daylight-zenith threshold (e.g. < 85°) before consuming.
pub fn kasten_airmass_relative(apparent_zenith_deg: float) -> float {
    let z = apparent_zenith_deg
    let z_r = radians(z)
    let denom = cos(z_r) + 0.50572 * pow(6.07995 + (90.0 - z), -1.6364)
    return 1.0 / denom
}

/// Pressure-adjusted absolute airmass:
///   am_a = am_r · P / 101325
/// Matches pvlib `atmosphere.get_absolute_airmass`.
pub fn kasten_airmass_absolute(apparent_zenith_deg: float,
                               pressure_pa: float) -> float {
    let am_r = kasten_airmass_relative(apparent_zenith_deg)
    return am_r * pressure_pa / 101325.0
}

/// Ineichen-Perez 2002 clear-sky global horizontal irradiance (W·m⁻²).
///
///   fh1 = exp(−altitude / 8000)
///   fh2 = exp(−altitude / 1250)
///   cg1 = 5.09e-5 · altitude + 0.868
///   cg2 = 3.92e-5 · altitude + 0.0387
///   GHI = cg1 · dni_extra · cos(z) ·
///         exp(−cg2 · am_abs · (fh1 + fh2 · (TL − 1)))
///
/// Inputs:
///   apparent_zenith_deg — refraction-corrected zenith (deg)
///   airmass_absolute    — pressure-corrected airmass (unitless)
///   linke_turbidity     — Linke turbidity (typ. 2-6, climatology)
///   altitude_m          — site altitude above sea level (m)
///   dni_extra           — extraterrestrial DNI (W·m⁻², typ. ~1325-1410)
///
/// Returns 0 when sun ≥ horizon (z ≥ 90° or cos(z) ≤ 0) — mirrors the
/// `np.maximum(cosd(zen), 0)` clamp in pvlib. The optional Perez
/// airmass-enhancement factor is NOT applied (matches pvlib default
/// `perez_enhancement=False`, which is what the producer uses).
pub fn ineichen_ghi(apparent_zenith_deg: float, airmass_absolute: float,
                    linke_turbidity: float, altitude_m: float,
                    dni_extra: float) -> float {
    if apparent_zenith_deg >= 90.0 { return 0.0 }
    let cos_z = cos(radians(apparent_zenith_deg))
    if cos_z <= 0.0 { return 0.0 }

    let fh1 = exp(-altitude_m / 8000.0)
    let fh2 = exp(-altitude_m / 1250.0)
    let cg1 = 5.09e-05 * altitude_m + 0.868
    let cg2 = 3.92e-05 * altitude_m + 0.0387

    let exponent = -cg2 * airmass_absolute
        * (fh1 + fh2 * (linke_turbidity - 1.0))
    let mut ghi_core = exp(exponent)
    if ghi_core < 0.0 { ghi_core = 0.0 }

    return cg1 * dni_extra * cos_z * ghi_core
}

// ── ①b adapter note ──────────────────────────────────────────────────
//
// The Phoenix AZ reference site (lat=33.4484, lon=−112.0740,
// altitude=331 m, year=2024) and the CEC-SAPM PV-system spec
// (Canadian Solar CS5P-220M etc.) are domain-specific and live in a
// future `stdlib/energy/solar_clearsky.hexa` ①b adapter, NOT in this
// kernel. This kernel only ports the substrate primitives
// (ephemeris + Haurwitz); a full ModelChain port (CEC SAPM module
// model + SAPM temperature + AC inverter conversion) is the
// follow-on milestone gated on additional hexa stdlib coverage
// (e.g. linear-algebra solvers for the SAPM single-diode equation).
