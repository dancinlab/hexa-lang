// stdlib/kernels/mc_transport/transport_kinematics_kernel_test.hexa
// D80 g_hexa_only pilot #8 Stage-3 parity check.
//
// Cross-checks the clean-room hexa-native PDG-Bethe-Bloch kernel in
// `transport_kinematics_kernel.hexa` against Python `math` (libm)
// reference numbers captured 2026-05-20 on darwin-arm64 from a
// line-by-line transliteration using the SAME constants + SAME
// operation order. Both sides evaluate the PDG closed forms (eq. 34.4
// T_max, eq. 34.5 Bethe-Bloch) and a 256-step trapezoidal CSDA range.
//
// Reference setup:
//   • Projectile: antiproton — m_p = 938.27208816 MeV/c², |z| = 1
//     (PDG 2024; sign drops in z² of dE/dx)
//   • Electron : m_e = 0.51099895 MeV/c² (PDG 2024)
//   • Materials (Z, A, I_eV) from PDG Table 34.1:
//       Al = (13, 26.9815, 166.0)
//       Cu = (29, 63.5460, 322.0)
//       W  = (74, 183.840, 727.0)
//       Pb = (82, 207.200, 823.0)
//   • Kinetic-energy points: 1, 10, 30, 100, 1000 MeV — ELENA injection
//     scale to fixed-target scale; spans low-β to mildly-relativistic.
//
// Tolerances:
//   • D80 spec ceiling: 1e-10 relative.
//   • Observed: <1e-13 across all 25+ assertions, including the
//     trapezoidal-integral CSDA range — both implementations sum in
//     the same order, so the IEEE-754 result is bit-stable.
//   • Where the reference value is exactly 0 (n/a for this kernel —
//     every quantity is bounded away from 0 in the test envelope),
//     no absolute fallback is needed.

use "stdlib/kernels/mc_transport/transport_kinematics_kernel"
use "stdlib/core/math/float"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
    }
}

fn fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

fn rel_err(got: float, want: float) -> float {
    if fabs(want) < 1e-12 { return fabs(got - want) }
    return fabs(got - want) / fabs(want)
}

fn check_close(name: str, got: float, want: float, tol: float) {
    let r = rel_err(got, want)
    check(name, r < tol)
}

fn main() {
    let m_p = 938.27208816
    let m_e = 0.51099895
    let tol = 0.0000000001          // 1e-10 — D80 ceiling

    // ── kinematics — KE = 1 MeV (low-β regime) ────────────────────────
    let k1 = relativistic_kinematics(1.0, m_p)
    check_close("KE=1   gamma",      k1[0], 1.0010657889247894, tol)
    check_close("KE=1   beta2",      k1[1], 0.0021281749675831074, tol)
    check_close("KE=1   beta",       k1[2], 0.04613214679139816, tol)
    check_close("KE=1   beta_gamma", k1[3], 0.04618131392252519, tol)
    check_close("KE=1   p_MeV",      k1[4], 43.330637848060185, tol)
    check_close("KE=1   E_tot",      k1[5], 939.27208816, tol)

    // ── kinematics — KE = 10 MeV ──────────────────────────────────────
    let k10 = relativistic_kinematics(10.0, m_p)
    check_close("KE=10  gamma",      k10[0], 1.0106578892478946, tol)
    check_close("KE=10  beta2",      k10[1], 0.020979785531242467, tol)
    check_close("KE=10  beta",       k10[2], 0.14484400412596465, tol)
    check_close("KE=10  beta_gamma", k10[3], 0.14638773548016076, tol)
    check_close("KE=10  p_MeV",      k10[4], 137.35152624998415, tol)
    check_close("KE=10  E_tot",      k10[5], 948.27208816, tol)

    // ── kinematics — KE = 100 MeV (mildly relativistic) ───────────────
    let k100 = relativistic_kinematics(100.0, m_p)
    check_close("KE=100 gamma",      k100[0], 1.1065788924789453, tol)
    check_close("KE=100 beta2",      k100[1], 0.18335137335624296, tol)
    check_close("KE=100 beta",       k100[2], 0.42819548497881543, tol)
    check_close("KE=100 beta_gamma", k100[3], 0.4738320855323424, tol)

    // ── kinematics — KE = 1000 MeV (γ ≈ 2) ────────────────────────────
    let k1000 = relativistic_kinematics(1000.0, m_p)
    check_close("KE=1G  gamma",      k1000[0], 2.0657889247894516, tol)
    check_close("KE=1G  beta2",      k1000[1], 0.7656698823705349, tol)
    check_close("KE=1G  beta",       k1000[2], 0.8750256466930183, tol)
    check_close("KE=1G  beta_gamma", k1000[3], 1.807618289845165, tol)

    // ── T_max ────────────────────────────────────────────────────────
    check_close("Tmax@1MeV",   max_energy_transfer_mev(1.0,    m_p, m_e),
                0.0021772542667169627, tol)
    check_close("Tmax@10MeV",  max_energy_transfer_mev(10.0,   m_p, m_e),
                0.021876680938111022, tol)
    check_close("Tmax@100MeV", max_energy_transfer_mev(100.0,  m_p, m_e),
                0.22917944107099075, tol)
    check_close("Tmax@1GeV",   max_energy_transfer_mev(1000.0, m_p, m_e),
                3.3318635589810155, tol)

    // ── Bethe-Bloch dE/dx — 4 materials × representative KE ──────────
    // (Aluminium — Z=13, A=26.9815, I=166 eV)
    let al1 = bethe_bloch_dedx(1.0,    m_p, 1, 13, 26.9815, 166.0, m_e)
    check_close("Al@1MeV    dedx", al1[4], 178.82465201402573, tol)
    let al10 = bethe_bloch_dedx(10.0,  m_p, 1, 13, 26.9815, 166.0, m_e)
    check_close("Al@10MeV   dedx", al10[4], 34.27873521444443, tol)
    let al100 = bethe_bloch_dedx(100.0, m_p, 1, 13, 26.9815, 166.0, m_e)
    check_close("Al@100MeV  dedx", al100[4], 5.686880593645214, tol)
    let al1000 = bethe_bloch_dedx(1000.0, m_p, 1, 13, 26.9815, 166.0, m_e)
    check_close("Al@1GeV    dedx", al1000[4], 1.7666297365222143, tol)

    // (Copper — Z=29, A=63.546, I=322 eV)
    let cu10 = bethe_bloch_dedx(10.0, m_p, 1, 29, 63.5460, 322.0, m_e)
    check_close("Cu@10MeV   dedx", cu10[4], 28.04244347783238, tol)

    // (Tungsten — Z=74, A=183.84, I=727 eV)
    let w30 = bethe_bloch_dedx(30.0, m_p, 1, 74, 183.840, 727.0, m_e)
    check_close("W@30MeV    dedx", w30[4], 9.022144145696117, tol)

    // (Lead — Z=82, A=207.20, I=823 eV)
    let pb100 = bethe_bloch_dedx(100.0, m_p, 1, 82, 207.200, 823.0, m_e)
    check_close("Pb@100MeV  dedx", pb100[4], 3.6099926916530345, tol)
    let pb1000 = bethe_bloch_dedx(1000.0, m_p, 1, 82, 207.200, 823.0, m_e)
    check_close("Pb@1GeV    dedx", pb1000[4], 1.1969804235133183, tol)

    // ── CSDA stopping range — 256-step trapezoidal, ke_floor = 1 MeV ──
    // The trapezoidal sums are bit-stable when both sides accumulate
    // in the same order (the kernel and the Python reference both go
    // i=1..n-1 with endpoints half-weighted), so the rel_err is
    // dominated by the per-step dedx libm spread (≲ 1e-15 per call,
    // accumulated to ≲ 1e-13 over 256 steps).
    check_close("R Al@10MeV ",
        stopping_range_csda(10.0,   m_p, 1, 13, 26.9815, 166.0, m_e, 256, 1.0),
        0.16277150264014525, tol)
    check_close("R Al@100MeV",
        stopping_range_csda(100.0,  m_p, 1, 13, 26.9815, 166.0, m_e, 256, 1.0),
        9.969203913613605, tol)
    check_close("R Al@1GeV  ",
        stopping_range_csda(1000.0, m_p, 1, 13, 26.9815, 166.0, m_e, 256, 1.0),
        410.10963817174115, tol)
    check_close("R Cu@10MeV ",
        stopping_range_csda(10.0,   m_p, 1, 29, 63.5460, 322.0, m_e, 256, 1.0),
        0.20352977137081105, tol)
    check_close("R W@30MeV  ",
        stopping_range_csda(30.0,   m_p, 1, 74, 183.840, 727.0, m_e, 256, 1.0),
        1.9334535371848958, tol)
    check_close("R Pb@100MeV",
        stopping_range_csda(100.0,  m_p, 1, 82, 207.200, 823.0, m_e, 256, 1.0),
        16.144457105729597, tol)
    check_close("R Pb@1GeV  ",
        stopping_range_csda(1000.0, m_p, 1, 82, 207.200, 823.0, m_e, 256, 1.0),
        616.0534458373311, tol)

    // ── invariants (self-consistency, no Python reference needed) ────
    // (i)  E_tot − KE = m  (rest-mass conservation in special relativity)
    let inv1 = relativistic_kinematics(42.5, m_p)
    check_close("inv: E_tot − KE == m_p", inv1[5] - 42.5, m_p, 0.000000000001)

    // (ii) β·γ·m == p   (momentum identity)
    check_close("inv: p == β·γ·m at KE=42.5", inv1[4], inv1[3] * m_p, 0.000000000001)

    print("transport_kinematics_kernel_test: " + str(pass_count) + "/" + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
    } else {
        print("PASS")
    }
}
