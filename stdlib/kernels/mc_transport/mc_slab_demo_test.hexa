// stdlib/kernels/mc_transport/mc_slab_demo_test.hexa
// D80 g_hexa_only pilot — parity test for mc_slab_demo.hexa.
//
// Two checks:
//   (1) ANALYTIC parity — pure-absorber beam source, T_mc should
//       match T_analytic = exp(-Σ_t·L) to within ~3% relative at
//       N=100_000 (statistical √N envelope; tighter than the 5%
//       D80 ceiling — see the inbox pattern note for why).
//   (2) PYTHON-COMPANION parity — same (seed, N, L, Σ, source)
//       inputs into mc_slab_demo.py give bit-identical counts.
//       The companion-side comparison lives in the README's parity
//       table (captured 2026-05-20 against this test's hash).
//
// We intentionally run at N=100_000 not N=10^6 here so the test
// completes in seconds under `hexa run`. The pattern note records
// a N=1e6 reference run on the Python side (where the bigger
// sample size is cheap) for the canonical parity table.

use "stdlib/kernels/mc_transport/mc_slab_demo"
use "stdlib/core/math/float"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
    }
}

fn fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

fn rel_err(got: float, want: float) -> float {
    if fabs(want) < 1e-12 { return fabs(got - want) }
    return fabs(got - want) / fabs(want)
}

fn main() {
    // ────────────────────────────────────────────────────────────────
    // Case 1: pure absorber, beam source, L=1.0 cm, Σ_t=1.0 cm⁻¹
    //   T_analytic = exp(-1) = 0.3678794411714423
    //   N=100_000 -> statistical σ_T ≈ sqrt(T(1-T)/N) ≈ 0.00153
    //   -> relative σ ≈ 0.42 %
    //   D80 tolerance ceiling is 5 %, so 1 % is the honest tight bound.
    // ────────────────────────────────────────────────────────────────
    let r1 = run_slab(1.0, 1.0, 0.0, 1.0, 100000, 12345, 1)
    let t1 = r1[0]
    let t_anal = analytic_transmission_beam_pure_absorber(1.0, 1.0)
    print("case1 pure-absorber beam, L=1.0, Σ_t=1.0, N=100000")
    print("  T_mc       = " + str(t1))
    print("  T_analytic = " + str(t_anal))
    print("  rel_err    = " + str(rel_err(t1, t_anal)))
    check("case1 T parity vs analytic (1 % rel)",
          rel_err(t1, t_anal) < 0.01)
    // Pure absorber: A = 1 - T, R = 0, mean collisions = A (each
    // absorbed neutron has exactly 1 collision).
    check("case1 R == 0 (pure absorber, beam source)",
          fabs(r1[2]) < 1e-12)
    check("case1 A + T == 1 (closure)",
          fabs((r1[0] + r1[1]) - 1.0) < 1e-12)
    check("case1 mean_collisions == A (pure absorber)",
          fabs(r1[3] - r1[1]) < 1e-12)

    // ────────────────────────────────────────────────────────────────
    // Case 2: pure absorber, beam source, thicker slab.
    //   L=2.0, Σ_t=1.0  ->  T_analytic = exp(-2) ≈ 0.1353
    //   N=100_000 -> rel σ ≈ 0.81 % -> 3 % tolerance is honest
    // ────────────────────────────────────────────────────────────────
    let r2 = run_slab(2.0, 1.0, 0.0, 1.0, 100000, 54321, 1)
    let t2 = r2[0]
    let t2_anal = analytic_transmission_beam_pure_absorber(2.0, 1.0)
    print("case2 pure-absorber beam, L=2.0, Σ_t=1.0, N=100000")
    print("  T_mc       = " + str(t2))
    print("  T_analytic = " + str(t2_anal))
    print("  rel_err    = " + str(rel_err(t2, t2_anal)))
    check("case2 T parity vs analytic (3 % rel)",
          rel_err(t2, t2_anal) < 0.03)

    // ────────────────────────────────────────────────────────────────
    // Case 3: scattering medium (no analytic in closed form here).
    //   Σ_t = 1.0, Σ_s = 0.5, Σ_a = 0.5, L=1.0, beam, N=100_000.
    //   Expect: T_mc + A + R = 1 (closure), mean_coll > A
    //   (scattering bumps the collision count above 1 per absorption).
    // ────────────────────────────────────────────────────────────────
    let r3 = run_slab(1.0, 1.0, 0.5, 0.5, 100000, 98765, 1)
    let closure = r3[0] + r3[1] + r3[2]
    print("case3 scattering Σ_s=0.5 Σ_a=0.5, L=1.0, N=100000")
    print("  T = " + str(r3[0]) + "  A = " + str(r3[1])
          + "  R = " + str(r3[2]) + "  mean_coll = " + str(r3[3]))
    check("case3 closure T+A+R==1", fabs(closure - 1.0) < 1e-12)
    check("case3 mean_coll > A (scattering adds collisions)",
          r3[3] > r3[1])
    check("case3 R > 0 (scattering causes backscatter)", r3[2] > 0.0)

    print("mc_slab_demo_test: " + str(pass_count) + "/" + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
    } else {
        print("PASS")
    }
}
