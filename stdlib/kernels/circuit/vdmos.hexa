#!hexa strict
// stdlib/kernels/circuit/vdmos.hexa — hexa-native VDMOS Level-1 DC device model
//                          + Newton operating-point solvers
//
// @version 0.1.0
// @capabilities [device_model, dc_solve]
// @stability bodies landed (κ-41 — hexa-native datasheet parity GREEN,
//            no external simulator spawned)
// @since 2026-05-20
//
// CLEAN-ROOM PROVENANCE (demiurge/design.md D1 + D67)
//   This is a from-scratch hexa-native re-derivation of the textbook
//   Level-1 (Shichman-Hodges square-law) MOSFET DC model — the public
//   device-physics equations every SPICE implements. NO ngspice source
//   is re-derived; the equations are the canonical ones (Sedra/Smith
//   "Microelectronic Circuits"; Shichman & Hodges, IEEE JSSC 1968).
//
// ── WHY this is the absorbed=true path (g3) ─────────────────────────────
//   `ngspice.hexa` / `wolfspeed_parity.hexa` SPAWN ngspice — the engine
//   is an external C solver, so they stay `absorbed=false` (substrate).
//   THIS module computes the C3M0021120K data sheet's DC specs —
//   R_DS(on) and V_GS(th) — with **pure hexa-native arithmetic, zero
//   subprocess**. If the hexa-native numbers land on the data sheet,
//   that satisfies the absorbed=true criterion (ABSORPTION.md ⑤ /
//   D17 matter pattern: "hexa-lang 이 *자체* 측정해 동일 결과를 낼 때").
//
//   SCOPE BOUND (honest): absorbed=true here is for the **DC device
//   model** only — the two static data sheet specs are DC operating
//   points. Full transient circuit simulation (MNA matrix + sparse LU
//   + trapezoidal L/C integration, multi-device) is NOT in this module
//   and remains a separate future effort. But the data sheet parity
//   the measurement gate asked for IS these DC specs, and they are now
//   reproduced hexa-natively.
//
// ── Model equations (Level-1, with series RS/RD) ────────────────────────
//   internal gate overdrive: Vov = (Vgs - Id*RS) - VTO
//   triode      (Vds_i < Vov):  Id = KP*(Vov*Vds_i - Vds_i^2/2)*(1+L*Vds_i)
//   saturation  (Vds_i >= Vov): Id = (KP/2)*Vov^2*(1+L*Vds_i)
//   external Vds = Vds_i + Id*(RS+RD)
//
// ── Public API ──────────────────────────────────────────────────────────
//   pub fn vdmos_solve_vgsth(vto, kp, lam, id_target) -> float
//   pub fn vdmos_solve_rdson(vto, kp, lam, rs, rd, vgs, id) -> float
//   pub fn vdmos_id_sat(vov, vds, kp, lam) -> float

// ─── core device equations ───────────────────────────────────────────────

// Saturation-region drain current (Level-1 square law + channel-length
// modulation). vov = Vgs-VTO overdrive, vds the drain-source voltage.
pub fn vdmos_id_sat(vov: float, vds: float, kp: float, lam: float) -> float {
    if vov <= 0.0 { return 0.0 }
    return 0.5 * kp * vov * vov * (1.0 + lam * vds)
}

// Triode-region drain current.
fn _id_triode(vov: float, vds: float, kp: float, lam: float) -> float {
    if vov <= 0.0 { return 0.0 }
    return kp * (vov * vds - 0.5 * vds * vds) * (1.0 + lam * vds)
}

// ─── solver 1: V_GS(th) ──────────────────────────────────────────────────

// Solve the gate voltage at which a diode-connected device (Vds=Vgs,
// hence always saturation since Vds=Vgs > Vgs-VTO) carries id_target.
// Series RS/RD drops at the data sheet's 17.7 mA test current are
// sub-millivolt and ignored (id*0.0145 ohm ~ 0.26 mV << 2.5 V).
// 1-D Newton-Raphson on:
//   f(v)  = (KP/2)*(v-VTO)^2*(1+L*v) - id_target
//   f'(v) = KP*(v-VTO)*(1+L*v) + (KP/2)*(v-VTO)^2*L
pub fn vdmos_solve_vgsth(vto: float, kp: float, lam: float, id_target: float) -> float {
    let mut v = vto + 0.1
    let mut it = 0
    while it < 60 {
        let ov = v - vto
        let f  = 0.5 * kp * ov * ov * (1.0 + lam * v) - id_target
        let fp = kp * ov * (1.0 + lam * v) + 0.5 * kp * ov * ov * lam
        if fp == 0.0 { return v }
        let step = f / fp
        v = v - step
        if step < 0.0 {
            if -step < 0.0000000001 { return v }
        } else {
            if step < 0.0000000001 { return v }
        }
        it = it + 1
    }
    return v
}

// ─── solver 2: R_DS(on) ──────────────────────────────────────────────────

// Compute the on-resistance at a forced operating point: gate held at
// `vgs`, current `id` forced through the drain. With id fixed, the
// internal gate overdrive Vov = (vgs - id*rs) - VTO is a constant, so
// the only unknown is the internal Vds_i — found by 1-D Newton on the
// triode equation. R_DS(on) = (Vds_i + id*(rs+rd)) / id.
pub fn vdmos_solve_rdson(vto: float, kp: float, lam: float, rs: float, rd: float, vgs: float, id: float) -> float {
    let vgs_int = vgs - id * rs
    let vov = vgs_int - vto
    if vov <= 0.0 { return -1.0 }
    // linear first guess: id ~ kp*vov*vds  ->  vds ~ id/(kp*vov)
    let mut vds = id / (kp * vov)
    let mut it = 0
    while it < 80 {
        let g  = _id_triode(vov, vds, kp, lam) - id
        // g'(vds) = kp*(vov - vds)*(1+L*vds) + kp*(vov*vds - vds^2/2)*L
        let gp = kp * (vov - vds) * (1.0 + lam * vds) + kp * (vov * vds - 0.5 * vds * vds) * lam
        if gp == 0.0 { return -1.0 }
        let step = g / gp
        vds = vds - step
        let mut astep = step
        if astep < 0.0 { astep = -astep }
        if astep < 0.0000000001 {
            let vds_ext = vds + id * (rs + rd)
            return vds_ext / id
        }
        it = it + 1
    }
    let vds_ext = vds + id * (rs + rd)
    return vds_ext / id
}
