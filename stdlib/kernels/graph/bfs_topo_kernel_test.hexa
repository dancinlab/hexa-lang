// stdlib/kernels/graph/bfs_topo_kernel_test.hexa — D80 g_hexa_only pilot #3
// Stage 3 parity check (ABSORPTION.md §"hexa 포팅 단계").
//
// Cross-checks the clean-room hexa-native BFS + topological-sort
// kernels in `bfs_topo_kernel.hexa` against networkx 3.2.1 numbers
// captured on 2026-05-20 from a real Python 3 run on darwin-arm64.
// Reference cases span three graph topologies:
//   • G1 linear chain (5-node undirected path) — BFS from 2 sources
//   • G2 branching tree (7-node undirected) — BFS from 2 sources
//   • G3 disconnected (5-node, 2 components) — unreachable = -1
//   • G4 6-node DAG (3-level diamond) — topological sort
//   • G5 5-node linear-chain DAG — topological sort
//   • G6 5-node two-root branching DAG — topological sort
//
// Tolerance: EXACT integer equality on every element of the
// distance vector and every position of the topological order.
// BFS hop-count and Kahn-order are pure combinatorial outputs —
// no float roundoff, no statistical envelope. The D80 0.1 % spec
// collapses to bit-identical for integer outputs (and we exceed
// the spec by infinity, not a finite ratio, because there is no
// floating-point to round).
//
// Stability convention: Kahn's algorithm with the in-degree-0
// queue seeded in ascending node-id order yields a unique
// topological order for any DAG. networkx's `topological_sort`
// happens to coincide with this order for the test cases we
// chose — verified element-by-element by the reference values
// captured from the Python run. (For DAGs where networkx and
// ascending-id Kahn diverge, the test would need a custom oracle;
// none of our test cases exercise that.)

use "stdlib/kernels/graph/bfs_topo_kernel"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
    }
}

fn arrays_eq(a: [int], b: [int]) -> bool {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn main() {
    // ════════════════════════════════════════════════════════════
    // G1 — Linear chain 0-1-2-3-4 (undirected)
    //   edges: (0,1),(1,2),(2,3),(3,4)
    //   Each undirected edge added BOTH ways for BFS.
    // ════════════════════════════════════════════════════════════
    let mut g1: [[int]] = [[1],[0,2],[1,3],[2,4],[3]]

    // BFS from 0 — networkx 3.2.1 reference: [0,1,2,3,4]
    let d1a = bfs_distance(g1, 5, 0)
    check("G1 BFS from 0 = [0,1,2,3,4]", arrays_eq(d1a, [0,1,2,3,4]))

    // BFS from 2 — reference: [2,1,0,1,2]
    let d1b = bfs_distance(g1, 5, 2)
    check("G1 BFS from 2 = [2,1,0,1,2]", arrays_eq(d1b, [2,1,0,1,2]))

    // ════════════════════════════════════════════════════════════
    // G2 — Branching tree, 7 nodes (undirected)
    //   edges: (0,1),(0,2),(0,3),(1,4),(1,5),(2,6)
    // ════════════════════════════════════════════════════════════
    let mut g2: [[int]] = [
        [1,2,3],   // 0
        [0,4,5],   // 1
        [0,6],     // 2
        [0],       // 3
        [1],       // 4
        [1],       // 5
        [2]        // 6
    ]

    // BFS from 0 — reference: [0,1,1,1,2,2,2]
    let d2a = bfs_distance(g2, 7, 0)
    check("G2 BFS from 0 = [0,1,1,1,2,2,2]",
          arrays_eq(d2a, [0,1,1,1,2,2,2]))

    // BFS from 4 — reference: [2,1,3,3,0,2,4]
    let d2b = bfs_distance(g2, 7, 4)
    check("G2 BFS from 4 = [2,1,3,3,0,2,4]",
          arrays_eq(d2b, [2,1,3,3,0,2,4]))

    // ════════════════════════════════════════════════════════════
    // G3 — Disconnected, 5 nodes, two components
    //   component A: 0-1-2  ; component B: 3-4
    // ════════════════════════════════════════════════════════════
    let mut g3: [[int]] = [
        [1],     // 0
        [0,2],   // 1
        [1],     // 2
        [4],     // 3
        [3]      // 4
    ]

    // BFS from 0 — reference: [0,1,2,-1,-1] (3 and 4 unreachable)
    let d3 = bfs_distance(g3, 5, 0)
    check("G3 BFS from 0 = [0,1,2,-1,-1]",
          arrays_eq(d3, [0,1,2,-1,-1]))

    // Reachable set from 0 (helper)
    let r3 = bfs_reachable(g3, 5, 0)
    check("G3 reachable from 0 = [0,1,2]", arrays_eq(r3, [0,1,2]))

    // ════════════════════════════════════════════════════════════
    // G4 — 6-node DAG (diamond), directed edges
    //   0 -> 1, 2
    //   1 -> 3
    //   2 -> 3, 4
    //   3 -> 5
    //   4 -> 5
    // ════════════════════════════════════════════════════════════
    let mut g4: [[int]] = [
        [1,2],   // 0 -> 1, 2
        [3],     // 1 -> 3
        [3,4],   // 2 -> 3, 4
        [5],     // 3 -> 5
        [5],     // 4 -> 5
        []       // 5 (sink)
    ]

    // Topo — networkx reference: [0,1,2,3,4,5]
    // Kahn ascending-id trace:
    //   indeg = [0,1,1,2,1,2]; queue starts [0]
    //   pop 0 -> indeg=[0,0,0,2,1,2], queue=[1,2]; out=[0]
    //   pop 1 -> indeg[3]=1, queue=[2]; out=[0,1]
    //   pop 2 -> indeg[3]=0, indeg[4]=0, queue=[3,4]; out=[0,1,2]
    //   pop 3 -> indeg[5]=1, queue=[4]; out=[0,1,2,3]
    //   pop 4 -> indeg[5]=0, queue=[5]; out=[0,1,2,3,4]
    //   pop 5 -> sink; out=[0,1,2,3,4,5]
    let t4 = topological_order(g4, 6)
    check("G4 topo = [0,1,2,3,4,5]",
          arrays_eq(t4, [0,1,2,3,4,5]))

    // ════════════════════════════════════════════════════════════
    // G5 — Linear-chain DAG  0 -> 1 -> 2 -> 3 -> 4
    // ════════════════════════════════════════════════════════════
    let mut g5: [[int]] = [
        [1],     // 0 -> 1
        [2],     // 1 -> 2
        [3],     // 2 -> 3
        [4],     // 3 -> 4
        []       // 4
    ]

    // Topo — networkx reference: [0,1,2,3,4]
    let t5 = topological_order(g5, 5)
    check("G5 topo = [0,1,2,3,4]",
          arrays_eq(t5, [0,1,2,3,4]))

    // ════════════════════════════════════════════════════════════
    // G6 — Two-root branching DAG, 5 nodes
    //   0 -> 2
    //   1 -> 2
    //   2 -> 3
    //   2 -> 4
    // ════════════════════════════════════════════════════════════
    let mut g6: [[int]] = [
        [2],     // 0 -> 2
        [2],     // 1 -> 2
        [3,4],   // 2 -> 3, 4
        [],      // 3
        []       // 4
    ]

    // Topo — networkx reference: [0,1,2,3,4]
    let t6 = topological_order(g6, 5)
    check("G6 topo = [0,1,2,3,4]",
          arrays_eq(t6, [0,1,2,3,4]))

    // ════════════════════════════════════════════════════════════
    // G7 — Cyclic graph (negative test): a 3-cycle should leave
    //      every node out of the topo order. Caller detects cycle
    //      via len(out) < n.
    //   0 -> 1 -> 2 -> 0
    // ════════════════════════════════════════════════════════════
    let mut g7: [[int]] = [
        [1],   // 0 -> 1
        [2],   // 1 -> 2
        [0]    // 2 -> 0  (cycle)
    ]
    let t7 = topological_order(g7, 3)
    check("G7 cyclic -> empty topo (len 0)", len(t7) == 0)

    print("bfs_topo_kernel_test: " + str(pass_count) + "/"
          + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
    } else {
        print("PASS")
    }
}
