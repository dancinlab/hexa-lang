// stdlib/kernels/fem/bar1d_kernel_test.hexa
// D80 g_hexa_only pilot #10 Stage-3 parity check.
//
// Cross-checks the clean-room hexa-native 1-D bar FEM kernel in
// `bar1d_kernel.hexa` against (a) Python `math` (libm) reference numbers
// captured 2026-05-20 on darwin-arm64 from a line-by-line transliteration
// in `bar1d_oracle.py`, and (b) the closed-form mechanics-of-materials
// answer u(x) = P · x / (E · A) for the fixed-free uniform-mesh case
// (this analytic oracle is INDEPENDENT of the FEM discretisation —
// the 1-D linear bar element is EXACT for uniform axial loading
// because the analytic solution u(x) = P·x/(EA) is a piecewise linear
// trial function).
//
// Reference setup — four meshes:
//
//   S1 — Uniform N=4 mesh on [0, 1], steel-like (E=200 GPa, A=1e-4 m²,
//        P_tip=1 kN). Tests the canonical uniform-mesh path; analytic
//        u_tip = P L / (E A) = 1000·1 / (2e11·1e-4) = 5e-5 m = 50 µm.
//
//   S2 — NON-uniform N=4 mesh on [0, 1] with nodes [0, 0.1, 0.3, 0.6,
//        1.0], aluminum-like (E=70 GPa, A=2.5e-4 m², P_tip=500 N).
//        Tests the non-uniform-mesh path (different element lengths
//        L_e exercise the per-element c = EA/L₁ ≠ EA/L₂ in the Thomas
//        sweep). analytic u_tip = 500·1 / (7e10·2.5e-4) = 2.857e-5 m.
//
//   S3 — Single-element N=2 mesh on [0, 1] with E=A=P=1.0. Tests the
//        m=1 reduced-system edge case (Thomas sweep degenerates to
//        b[0]/d[0]). analytic u_tip = 1 (exact).
//
//   S4 — Uniform N=8 mesh on [0, 1], same steel/load as S1. Tests
//        Thomas sweep over a longer reduced system (m=8); analytic
//        u(x) values still match within Thomas roundoff (~1e-15 rel).
//
// Tolerances:
//   • D80 spec ceiling: 1e-10 relative.
//   • For the bit-exact hexa ↔ Python oracle comparison: observed
//     rel_err = 0.0 (both sides execute the same Thomas sweep in the
//     same operation order with the same libm).
//   • For the analytic-oracle comparison: Thomas roundoff is ≤ 1e-13
//     relative on the uniform meshes (S1 = 5.92e-17, S4 = ~1e-15);
//     non-uniform S2 also at ≤ 1e-13. All assertions pass at 1e-10.

use "stdlib/kernels/fem/bar1d_kernel"
use "stdlib/core/math/float"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
    }
}

fn fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

fn rel_err(got: float, want: float) -> float {
    if fabs(want) < 1e-15 { return fabs(got - want) }
    return fabs(got - want) / fabs(want)
}

fn check_close(name: str, got: float, want: float, tol: float) {
    let r = rel_err(got, want)
    check(name, r < tol)
}

// Strict bit-exact equality (for hexa ↔ Python oracle parity).
fn check_bit_exact(name: str, got: float, want: float) {
    check(name, got == want)
}

fn main() {
    let tol_analytic = 0.0000000001          // 1e-10 — D80 ceiling
    let tol_loose    = 0.000000000001        // 1e-12 — Thomas roundoff

    // ─── primitive: element stiffness ────────────────────────────────
    let k_unit = bar1d_element_stiffness(1.0, 1.0, 1.0)
    check_bit_exact("k_unit[0][0] = 1",       k_unit[0][0],  1.0)
    check_bit_exact("k_unit[0][1] = -1",      k_unit[0][1], 0.0 - 1.0)
    check_bit_exact("k_unit[1][0] = -1",      k_unit[1][0], 0.0 - 1.0)
    check_bit_exact("k_unit[1][1] = 1",       k_unit[1][1],  1.0)

    let k_steel = bar1d_element_stiffness(200000000000.0, 0.0001, 0.25)
    check_bit_exact("k_steel[0][0] = 8e7",    k_steel[0][0],  80000000.0)
    check_bit_exact("k_steel[0][1] = -8e7",   k_steel[0][1], 0.0 - 80000000.0)
    check_bit_exact("k_steel[1][1] = 8e7",    k_steel[1][1],  80000000.0)

    // ─── S1 — Uniform N=4, steel, P_tip=1000 N ───────────────────────
    let nodes_S1 = [0.0, 0.25, 0.5, 0.75, 1.0]
    let E_S1 = 200000000000.0
    let A_S1 = 0.0001
    let P_S1 = 1000.0
    let u_S1 = bar1d_solve_fixed_free(nodes_S1, E_S1, A_S1, P_S1)

    // bit-exact vs Python oracle (line-by-line transliteration)
    check_bit_exact("S1 u[0] (BC)",     u_S1[0], 0.0)
    check_bit_exact("S1 u[1] vs py",    u_S1[1], 0.0000125)
    check_bit_exact("S1 u[2] vs py",    u_S1[2], 0.000025)
    check_bit_exact("S1 u[3] vs py",    u_S1[3], 0.0000375000000000000033)
    check_bit_exact("S1 u[4] vs py",    u_S1[4], 0.00005)

    // analytic oracle u(x) = P·x/(E·A) — INDEPENDENT of discretisation
    let EA_S1 = E_S1 * A_S1
    let mut k = 0
    while k < 5 {
        let u_analytic = P_S1 * nodes_S1[k] / EA_S1
        check_close("S1 u[" + str(k) + "] vs analytic",
                    u_S1[k], u_analytic, tol_analytic)
        k = k + 1
    }

    // ─── S2 — NON-uniform N=4, aluminum, P_tip=500 N ─────────────────
    let nodes_S2 = [0.0, 0.10, 0.30, 0.60, 1.00]
    let E_S2 = 70000000000.0
    let A_S2 = 0.00025
    let P_S2 = 500.0
    let u_S2 = bar1d_solve_fixed_free(nodes_S2, E_S2, A_S2, P_S2)

    // bit-exact vs Python oracle
    check_bit_exact("S2 u[0] (BC)",     u_S2[0], 0.0)
    check_bit_exact("S2 u[1] vs py",    u_S2[1], 0.0000028571428571428547)
    check_bit_exact("S2 u[2] vs py",    u_S2[2], 0.000008571428571428564)
    check_bit_exact("S2 u[3] vs py",    u_S2[3], 0.00001714285714285713)
    check_bit_exact("S2 u[4] vs py",    u_S2[4], 0.00002857142857142856)

    // analytic oracle
    let EA_S2 = E_S2 * A_S2
    let mut k2 = 0
    while k2 < 5 {
        let u_analytic = P_S2 * nodes_S2[k2] / EA_S2
        check_close("S2 u[" + str(k2) + "] vs analytic",
                    u_S2[k2], u_analytic, tol_analytic)
        k2 = k2 + 1
    }

    // ─── S3 — Single-element edge case (m=1 reduced system) ──────────
    let nodes_S3 = [0.0, 1.0]
    let u_S3 = bar1d_solve_fixed_free(nodes_S3, 1.0, 1.0, 1.0)
    check_bit_exact("S3 u[0] (BC)",     u_S3[0], 0.0)
    check_bit_exact("S3 u[1] = 1",      u_S3[1], 1.0)

    // ─── S4 — Uniform N=8 mesh, longer Thomas sweep ─────────────────
    let nodes_S4 = [0.0, 0.125, 0.25, 0.375, 0.5, 0.625, 0.75, 0.875, 1.0]
    let E_S4 = 200000000000.0
    let A_S4 = 0.0001
    let P_S4 = 1000.0
    let u_S4 = bar1d_solve_fixed_free(nodes_S4, E_S4, A_S4, P_S4)

    // bit-exact vs Python oracle
    check_bit_exact("S4 u[0] (BC)",  u_S4[0], 0.0)
    check_bit_exact("S4 u[1] vs py", u_S4[1], 0.000006250000000000011)
    check_bit_exact("S4 u[2] vs py", u_S4[2], 0.000012500000000000023)
    check_bit_exact("S4 u[3] vs py", u_S4[3], 0.000018750000000000036)
    check_bit_exact("S4 u[4] vs py", u_S4[4], 0.000025000000000000045)
    check_bit_exact("S4 u[5] vs py", u_S4[5], 0.000031250000000000055)
    check_bit_exact("S4 u[6] vs py", u_S4[6], 0.000037500000000000064)
    check_bit_exact("S4 u[7] vs py", u_S4[7], 0.000043750000000000074)
    check_bit_exact("S4 u[8] vs py", u_S4[8], 0.00005000000000000008)

    // analytic oracle (FEM is exact for uniform mesh + tip load —
    // residual is pure Thomas roundoff)
    let EA_S4 = E_S4 * A_S4
    let mut k4 = 0
    while k4 < 9 {
        let u_analytic = P_S4 * nodes_S4[k4] / EA_S4
        check_close("S4 u[" + str(k4) + "] vs analytic",
                    u_S4[k4], u_analytic, tol_loose)
        k4 = k4 + 1
    }

    // ─── invariants ──────────────────────────────────────────────────
    // (i) global K is symmetric (K[i][j] == K[j][i]) on N=4 uniform.
    let K_S1 = bar1d_assemble_K(nodes_S1, E_S1, A_S1)
    let mut sym_ok = true
    let mut i = 0
    while i < 5 {
        let mut j = 0
        while j < 5 {
            if K_S1[i][j] != K_S1[j][i] {
                sym_ok = false
            }
            j = j + 1
        }
        i = i + 1
    }
    check("inv: K is symmetric (N=4 uniform)", sym_ok)

    // (ii) row sums of K are zero — free-free bar has rigid-body mode
    // (no displacement BC yet at assembly time). Σ_j K[i][j] = 0 ∀i.
    let mut zero_rowsum_ok = true
    let mut ii = 0
    while ii < 5 {
        let mut rowsum = 0.0
        let mut jj = 0
        while jj < 5 {
            rowsum = rowsum + K_S1[ii][jj]
            jj = jj + 1
        }
        if fabs(rowsum) > 1e-6 {
            zero_rowsum_ok = false
        }
        ii = ii + 1
    }
    check("inv: row sums of K = 0 (rigid-body mode)", zero_rowsum_ok)

    // (iii) BC enforcement: u[0] = 0 exactly across all 4 samples.
    check_bit_exact("inv: S1 u[0] BC exact", u_S1[0], 0.0)
    check_bit_exact("inv: S2 u[0] BC exact", u_S2[0], 0.0)
    check_bit_exact("inv: S3 u[0] BC exact", u_S3[0], 0.0)
    check_bit_exact("inv: S4 u[0] BC exact", u_S4[0], 0.0)

    print("bar1d_kernel_test: " + str(pass_count)
          + "/" + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
    } else {
        print("PASS")
    }
}
