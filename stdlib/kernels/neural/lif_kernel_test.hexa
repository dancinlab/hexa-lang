// stdlib/kernels/neural/lif_kernel_test.hexa — D80 g_hexa_only port
// Stage 3 parity check (ABSORPTION.md §"hexa 포팅 단계").
//
// Cross-checks the clean-room hexa-native LIF derivations in
// `lif_kernel.hexa` against numpy 2.x / brian2-2.6.0 method='exact'
// numbers captured 2026-05-20 from a real Python 3 run on darwin-arm64.
// Reference samples span:
//   • S1 — brain adapter parameters (tau=10ms, I=2.0 super-thr, dt=0.1ms,
//          sim=1s) — analytic ISI period + 1000-step spike count.
//   • S2 — sub-threshold (tau=10ms, I=0.5, no spike), 5 closed-form
//          V(t) checkpoints across 100 ms.
//   • S3 — general SI form (V_rest=-65 mV, R=10 MΩ, I=2 nA, tau=10 ms),
//          5 closed-form V(t) checkpoints (patch-clamp-shaped).
//   • S4 — sub-threshold long run (10000 steps), v approaches I = 0.5.
//   • S5 — short tau / strong drive (tau=5ms, I=1.5, dt=10us, 100ms).
//   • S6 — at-threshold drive (I = v_thr = 1.0) → never spikes.
//
// Tolerances:
//   • Closed-form ISI period / V(t) checkpoints — both sides apply the
//     SAME exact analytic update in double precision; expect agreement
//     to machine epsilon (≤1e-12 relative).
//   • Time-stepped simulate() spike counts — exact integer match; ISI
//     mean to ≤1e-12 relative.
//
// D80 spec calls for ±1e-6 relative parity; we exceed that by ~6 orders
// of magnitude because the LIF integrator's per-step update IS the
// closed-form ODE solution — there is no numerical integration error.
// Reporting the tighter actual gap is more honest than gating on the
// spec ceiling (same stance as the solar_kernel pilot pattern note).
//
// Numpy/Brian2 reference numbers were captured by:
//   /usr/bin/python3 -c "
//     import math
//     tau=0.010; vthr=1.0; vrst=0.0; I=2.0; dt=1e-4; sim=1.0
//     decay = math.exp(-dt/tau); v = 0.0; spikes = []
//     for i in range(int(sim/dt)):
//         v = I + (v - I)*decay
//         if v >= vthr: spikes.append((i+1)*dt); v = vrst
//     print(len(spikes), spikes[0], spikes[-1], -tau*math.log((vthr-I)/(vrst-I)))
//   "
// → 142 0.007 0.994 0.00693147180559945

use "stdlib/kernels/neural/lif_kernel"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: str, cond: bool) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed == "" { failed = name }
    }
}

fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }

fn rel_err(got: float, want: float) -> float {
    if fabs(want) < 1e-12 { return fabs(got - want) }
    return fabs(got - want) / fabs(want)
}

fn check_close(name: str, got: float, want: float, tol: float) {
    let e = rel_err(got, want)
    check(name, e < tol)
}

fn main() {
    // ── S1: brain adapter parameters (Dayan & Abbott §5.4) ────────────
    //     tau=10ms, v_thr=1, v_reset=0, I=2.0, dt=0.1ms, sim=1s.

    let tau1 = 0.010
    let vthr1 = 1.0
    let vrst1 = 0.0
    let I1 = 2.0
    let dt1 = 0.0001
    let sim1 = 1.0

    // S1a — analytic ISI period vs closed-form ground truth.
    //   T = -tau · ln((v_thr - I)/(v_reset - I))
    //     = -0.010 · ln((1-2)/(0-2)) = -0.010 · ln(0.5) = 0.006931471805599453
    let isi_got = isi_period(I1, vthr1, vrst1, tau1)
    check_close("S1a isi_period analytic (1e-12 rel)",
                isi_got, 0.00693147180559945, 1.0e-12)

    // S1b — tonic firing rate = 1/ISI = 144.269504088896 Hz.
    let rate_got = firing_rate(I1, vthr1, vrst1, tau1)
    check_close("S1b firing_rate analytic (1e-12 rel)",
                rate_got, 144.269504088896, 1.0e-12)

    // S1c — full simulate() — spike count + first/last spike times.
    //   numpy reference: n_spikes=142, first=0.007, last=0.994.
    //   Both kernels use dt=1e-4, so spike-detection grid is identical.
    let r1 = simulate(tau1, vthr1, vrst1, I1, sim1, dt1)
    check("S1c simulate spike count == 142", r1[0] == 142.0)
    check_close("S1c first_spike_s (1e-12 rel)", r1[1], 0.007, 1.0e-12)
    check_close("S1c last_spike_s (1e-12 rel)",  r1[2], 0.994, 1.0e-12)

    // ── S2: sub-threshold (tau=10ms, I=0.5, no spike) ─────────────────
    //     V(t) closed form: V(t) = I · (1 - exp(-t/tau))
    //     5 checkpoints from numpy reference.
    let decay2 = decay_factor(dt1, tau1)
    let I2 = 0.5
    let mut v2 = 0.0

    // Iterate forward to t=1ms (step 10), t=5ms (step 50), t=10ms
    // (step 100), t=50ms (step 500), t=100ms (step 1000).
    let mut step = 0
    while step < 1000 {
        v2 = v_step(v2, I2, decay2)
        step = step + 1
        if step == 10 {
            check_close("S2 V(1ms) closed-form (1e-12 rel)",
                        v2, 0.0475812909820202, 1.0e-12)
        } else if step == 50 {
            check_close("S2 V(5ms) closed-form (1e-12 rel)",
                        v2, 0.196734670143683, 1.0e-12)
        } else if step == 100 {
            check_close("S2 V(10ms) closed-form (1e-12 rel)",
                        v2, 0.316060279414279, 1.0e-12)
        } else if step == 500 {
            check_close("S2 V(50ms) closed-form (1e-12 rel)",
                        v2, 0.496631026500457, 1.0e-12)
        } else if step == 1000 {
            check_close("S2 V(100ms) closed-form (1e-12 rel)",
                        v2, 0.499977300035119, 1.0e-12)
        }
    }

    // ── S3: general SI form (V_rest=-65mV, R=10MΩ, I=2nA, tau=10ms) ────
    //     V(t) = V_rest + R·I · (1 - exp(-t/tau)),  V(0) = V_rest.
    //     R·I = 10e6 · 2e-9 = 20 mV → V∞ = -65 + 20 = -45 mV.
    let v_rest3 = -0.065
    let r_ohm = 10000000.0       // 10 MΩ
    let i_amp = 2.0e-9           // 2 nA
    let tau3 = 0.010
    let decay3 = decay_factor(dt1, tau3)

    let mut v3 = v_rest3
    let mut step3 = 0
    while step3 < 1000 {
        v3 = v_step_general(v3, v_rest3, r_ohm, i_amp, decay3)
        step3 = step3 + 1
        if step3 == 10 {
            check_close("S3 V_si(1ms) general-form (1e-12 rel)",
                        v3, -0.0630967483607192, 1.0e-12)
        } else if step3 == 50 {
            check_close("S3 V_si(5ms) general-form (1e-12 rel)",
                        v3, -0.0571306131942527, 1.0e-12)
        } else if step3 == 100 {
            check_close("S3 V_si(10ms) general-form (1e-12 rel)",
                        v3, -0.0523575888234288, 1.0e-12)
        } else if step3 == 300 {
            check_close("S3 V_si(30ms) general-form (1e-12 rel)",
                        v3, -0.0459957413673573, 1.0e-12)
        } else if step3 == 1000 {
            check_close("S3 V_si(100ms) general-form (1e-12 rel)",
                        v3, -0.0450009079985953, 1.0e-12)
        }
    }

    // ── S4: sub-threshold long run — no spikes, V → I = 0.5 ────────────
    let r4 = simulate(tau1, vthr1, vrst1, 0.5, sim1, dt1)
    check("S4 sub-threshold n_spikes == 0", r4[0] == 0.0)
    check_close("S4 v_final approaches I=0.5 (1e-12 rel)",
                r4[4], 0.5, 1.0e-12)

    // ── S5: short tau / strong drive (tau=5ms, I=1.5, dt=10us, 100ms) ──
    //     T_isi = -0.005 · ln((1-1.5)/(0-1.5)) = -0.005 · ln(1/3)
    //           = 0.0054930614433405484 s
    //     Spikes start at t ≈ 5.5 ms (next dt-multiple ≥ T_isi).
    let tau5 = 0.005
    let i5 = 1.5
    let dt5 = 0.00001
    let r5 = simulate(tau5, vthr1, vrst1, i5, 0.1, dt5)
    check_close("S5 isi_period analytic (1e-12 rel)",
                isi_period(i5, vthr1, vrst1, tau5),
                0.00549306144334055, 1.0e-12)
    check("S5 spike count == 18", r5[0] == 18.0)
    check_close("S5 first_spike near 5.5ms (1e-9 rel)",
                r5[1], 0.0055, 1.0e-9)

    // ── S6: at-threshold drive (I == v_thr) → never spikes ─────────────
    //     isi_period must return the +inf sentinel (≥ 1e300).
    let isi6 = isi_period(1.0, vthr1, vrst1, tau1)
    check("S6 isi_period at-threshold returns +inf sentinel",
          isi6 > 1.0e300)
    let r6 = simulate(tau1, vthr1, vrst1, 1.0, sim1, dt1)
    check("S6 at-threshold n_spikes == 0", r6[0] == 0.0)
    check_close("S6 v_final approaches I=1.0 (1e-12 rel)",
                r6[4], 1.0, 1.0e-12)

    print("lif_kernel_test: " + str(pass_count) + "/" + str(total_count))
    if failed != "" {
        print("FAILED: " + failed)
    } else {
        print("PASS")
    }
}
