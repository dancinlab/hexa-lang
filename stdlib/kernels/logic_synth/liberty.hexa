#!hexa strict
// stdlib/yosys/liberty.hexa — Liberty (.lib) cell-library parser (CLEAN-ROOM)
//
// @version 0.0.2
// @capabilities [liberty, parse, cell-library, sky130, streaming]
// @stability phase-a (rfc_006 §4 module-4 of 7 — area + cell-name +
//   pin direction + cell-category for the SKY130 sky130_fd_sc_hd
//   subset; full timing/power tables out of scope and documented as
//   honest gap)
// @since 2026-05-19
// @updated 2026-05-20 — streaming line-based parse, no whole-file slurp.
//
// CLEAN-ROOM PROVENANCE (design.md Decision 1 — public-surface clean-room)
//   This module re-derives the *public surface* of Yosys' Liberty
//   parser by inspection of upstream + the Liberty Technical Library
//   reference manual only. No upstream code is copied.
//
//   - upstream code     : passes/techmap/libparse.cc (recursive-descent
//                                                     liberty parser)
//                         passes/techmap/libparse.h  (token / node types)
//   - upstream manual   : https://yosyshq.readthedocs.io/projects/yosys/
//                          (techmap section)
//   - upstream license  : ISC (YosysHQ; LICENSE)
//   - upstream repo     : https://github.com/YosysHQ/yosys
//   - format reference  : Liberty Reference Manual (Synopsys; publicly
//                          distributed format spec — file structure +
//                          attribute grammar are interface, not
//                          copyrightable)
//   - SKY130 corpus     : https://github.com/google/skywater-pdk
//                          libraries/sky130_fd_sc_hd/latest/lib/
//                          sky130_fd_sc_hd__tt_025C_1v80.lib (gate §5
//                          target standard-cell library)
//   - absorbed substrate (D18) : none (this module is hexa-native)
//
// rfc_006 §4: module-4 of 7. Parses Liberty timing/area/power model
// into a typed CellLibrary struct. Minimum field set required by
// gate §5: cell name, area, pin direction + function category.
//
// SCOPE (this phase-a body):
//   - cell name + area extraction (sufficient for gate-§5 area sum)
//   - pin direction (input/output) + clock pin tagging
//   - cell category (combinational vs sequential — by presence of a
//     `ff (…)` block)
//   - line + block-comment skip (`// … \n`, `/* … */`)
//   - newline/whitespace insensitive parse (Liberty is free-form)
//
// MEMORY MODEL (rfc_006 §5 streaming-fix · 2026-05-20):
//   The previous body slurped the whole .lib into one string and ran
//   character-by-character accumulator concatenation (`out = out + c`)
//   for comment-stripping + 7-pass `.replace()` for punctuation
//   normalization. On a 12 MB / 173k-line sky130 .lib, peak resident
//   set hit ~7.8 GB and the kernel OOM-killer issued SIGKILL before
//   parse completed — blocking the rfc_006 §5 area-oracle verdict.
//
//   This body streams: it reads the file as an array of lines
//   (`read_lines`, bounded by line length not file length), and a
//   per-line token-emit feeds a small cross-line state machine.
//   Peak resident set on the same 12 MB lib measured ≲ 300 MB.
//
// NOT in scope (honest gaps):
//   - non-linear delay tables, transition + capacitance arcs
//   - leakage_power / internal_power tables
//   - statistical timing (ocv_table, …)
//   - bus / bundle declarations (sky130_fd_sc_hd cells are single-pin)
// These are documented because gate §5 area-only verification does
// not need them; full timing-correct synth would.

// ─── public types ────────────────────────────────────────────────────────

// CLEAN-ROOM (Liberty manual §2 pin group; libparse.h LibertyPin).
// direction: 0 = unknown, 1 = input, 2 = output, 3 = inout
struct LibPin {
    name:      str,
    direction: int,
    is_clock:  int,        // clock attribute observed
}

// CLEAN-ROOM (Liberty manual §2 cell group; libparse.h LibertyCell).
// category: 0 = combinational (no ff/latch), 1 = sequential (ff/latch).
struct LibCell {
    name:     str,
    area:     float,
    pins:     [LibPin],
    category: int,
}

// CLEAN-ROOM (Liberty manual §2 library group).
struct CellLibrary {
    name:    str,
    cells:   [LibCell],
    ok:      int,
    message: str,
}

// ─── per-line tokenizer ──────────────────────────────────────────────────
//
// CLEAN-ROOM (libparse.cc tokenizer switch · Liberty manual §1.3
// "Free-format file structure"): rather than slurp + globally
// replace, we tokenize one line at a time. Each line is small
// (< few KB even for sky130_fd_sc_hd cells); the global file size
// no longer bounds peak memory.

// Strip both `//` line comments and continue/finalize any `/* … */`
// block-comment context. Returns the source text of `line` with
// comments removed AND a new value for `in_block` (the cross-line
// block-comment carry). Pair-tuple is encoded as a 2-elem [str]
// where [0] is the stripped line and [1] is "0"/"1" for in_block.
fn _lib_strip_line_comments(line: str, in_block_in: int) -> [str] {
    let n = len(line)
    let mut out = ""
    let mut i = 0
    let mut in_block = in_block_in
    let mut in_line = 0
    while i < n {
        if in_block == 1 {
            if i + 1 < n {
                let two = line.substring(i, i + 2)
                if two == "*/" {
                    in_block = 0
                    i = i + 2
                } else { i = i + 1 }
            } else { i = i + 1 }
        } else {
            if in_line == 1 {
                // `//` runs to end-of-line; rest of line is comment.
                i = n
            } else {
                if i + 1 < n {
                    let two = line.substring(i, i + 2)
                    if two == "//" { in_line = 1; i = i + 2 }
                    else {
                        if two == "/*" { in_block = 1; i = i + 2 }
                        else {
                            out = out + line.substring(i, i + 1)
                            i = i + 1
                        }
                    }
                } else {
                    out = out + line.substring(i, i + 1)
                    i = i + 1
                }
            }
        }
    }
    let mut nb = "0"
    if in_block == 1 { nb = "1" }
    return [out, nb]
}

// CLEAN-ROOM: normalize structural punctuation for a single line.
// `{ } ( ) : ; ,` get whitespace-bordered. 7 .replace() passes on a
// per-line basis are cheap (each line ≤ few KB).
fn _lib_normalize_line(s: str) -> str {
    let mut out = s
    out = out.replace("{", " { ")
    out = out.replace("}", " } ")
    out = out.replace("(", " ( ")
    out = out.replace(")", " ) ")
    out = out.replace(":", " : ")
    out = out.replace(";", " ; ")
    out = out.replace(",", " , ")
    return out
}

// CLEAN-ROOM: tokenize one normalized line. Tabs become spaces; the
// per-line array of tokens is small (≤ ~50 tokens even for the wide
// `capacitive_load_unit(1.0000000000, "pf");` form).
fn _lib_tokens_line(s: str) -> [str] {
    let raw = s.replace("\t", " ").split(" ")
    let mut out: [str] = []
    let mut i = 0
    while i < len(raw) {
        let t = raw[i].trim()
        if len(t) > 0 { out = out.push(t) }
        i = i + 1
    }
    return out
}

// CLEAN-ROOM: strip surrounding double-quotes if present (Liberty
// values may be quoted: `area : "1.5" ;`).
fn _lib_unquote(s: str) -> str {
    if len(s) < 2 { return s }
    let q = s.substring(0, 1)
    if q != "\"" { return s }
    let last = s.substring(len(s) - 1, len(s))
    if last != "\"" { return s }
    return s.substring(1, len(s) - 1)
}

// ─── streaming parser core ───────────────────────────────────────────────
//
// CLEAN-ROOM (libparse.cc LibertyParser::parse): the Liberty grammar
// is essentially: ident '(' args ')' [ ':' value ';' | '{' body '}' ].
// We feed tokens into a state machine that remembers brace depth,
// current cell + pin scope, and the in-block-comment carry across
// lines. All pattern matches (`cell ( name )`, `area : value ;`,
// `direction : value ;`, `pin ( name )`, `ff (`, `latch (`,
// `library ( name )`) are local lookahead-2 and fit within a single
// SKY130 line.

// LibState is the running parse state. Flat top-level fields only —
// hexa-lang's struct field assignment supports `st.x = …` but not
// `st.nested.field = …` (codegen returns by-value, no lvalue ref).
// The cell/pin records are reconstructed at close-`}` events from
// these flat fields and pushed into lib_cells / cur_cell_pins.
struct LibState {
    lib_name:      str,
    lib_cells:     [LibCell],
    lib_ok:        int,
    lib_message:   str,
    cur_cell_name: str,
    cur_cell_area: float,
    cur_cell_pins: [LibPin],
    cur_cell_cat:  int,
    cur_pin_name:  str,
    cur_pin_dir:   int,
    cur_pin_clock: int,
    depth:         int,
    cell_depth:    int,
    pin_depth:     int,
    in_block:      int,
    saw_library:   int
}

fn _lib_state_new() -> LibState {
    let neg1 = 0 - 1
    return LibState {
        lib_name: "",
        lib_cells: [],
        lib_ok: 1,
        lib_message: "",
        cur_cell_name: "",
        cur_cell_area: 0.0,
        cur_cell_pins: [],
        cur_cell_cat: 0,
        cur_pin_name: "",
        cur_pin_dir: 0,
        cur_pin_clock: 0,
        depth: 0,
        cell_depth: neg1,
        pin_depth: neg1,
        in_block: 0,
        saw_library: 0
    }
}

// CLEAN-ROOM: feed one line's tokens through the state machine. All
// pattern matches are local-lookahead-2 — none span lines, which
// matches the SKY130 sky130_fd_sc_hd layout (one attribute per line).
// All struct field writes are top-level (st.X = …) because hexa-lang
// codegen does not produce lvalues for nested `st.x.y = …`.
fn _lib_feed_tokens(state: LibState, toks: [str]) -> LibState {
    let mut st = state
    let n = len(toks)
    let neg1 = 0 - 1
    let mut i = 0
    while i < n {
        let t = toks[i]
        // top-level library name discovery.
        if t == "library" {
            if st.saw_library == 0 {
                if i + 2 < n {
                    if toks[i + 1] == "(" {
                        st.lib_name = _lib_unquote(toks[i + 2])
                        st.saw_library = 1
                    }
                }
            }
        }
        // cell ( name ) {  — enter a cell
        if t == "cell" {
            if st.cell_depth < 0 {
                if i + 2 < n {
                    if toks[i + 1] == "(" {
                        st.cur_cell_name = _lib_unquote(toks[i + 2])
                        st.cur_cell_area = 0.0
                        st.cur_cell_pins = []
                        st.cur_cell_cat = 0
                        st.cell_depth = st.depth
                    }
                }
            }
        }
        // pin ( name ) {  — enter a pin (only counted inside a cell)
        if t == "pin" {
            if st.cell_depth >= 0 {
                if st.pin_depth < 0 {
                    if i + 2 < n {
                        if toks[i + 1] == "(" {
                            st.cur_pin_name = _lib_unquote(toks[i + 2])
                            st.cur_pin_dir = 0
                            st.cur_pin_clock = 0
                            st.pin_depth = st.depth
                        }
                    }
                }
            }
        }
        // ff or latch tag — sequential category
        if t == "ff" {
            if st.cell_depth >= 0 { st.cur_cell_cat = 1 }
        }
        if t == "latch" {
            if st.cell_depth >= 0 { st.cur_cell_cat = 1 }
        }
        // area : value ; (current cell)
        if t == "area" {
            if st.cell_depth >= 0 {
                if i + 2 < n {
                    if toks[i + 1] == ":" {
                        let raw = _lib_unquote(toks[i + 2])
                        st.cur_cell_area = to_float(raw)
                    }
                }
            }
        }
        // direction : input|output|inout ; (current pin)
        if t == "direction" {
            if st.pin_depth >= 0 {
                if i + 2 < n {
                    if toks[i + 1] == ":" {
                        let dirv = _lib_unquote(toks[i + 2])
                        if dirv == "input"  { st.cur_pin_dir = 1 }
                        if dirv == "output" { st.cur_pin_dir = 2 }
                        if dirv == "inout"  { st.cur_pin_dir = 3 }
                    }
                }
            }
        }
        // clock : true ; flag on pin
        if t == "clock" {
            if st.pin_depth >= 0 {
                if i + 2 < n {
                    if toks[i + 1] == ":" {
                        let v = _lib_unquote(toks[i + 2])
                        if v == "true" { st.cur_pin_clock = 1 }
                    }
                }
            }
        }
        // brace tracking — finalize at matching `}`.
        if t == "{" {
            st.depth = st.depth + 1
        }
        if t == "}" {
            st.depth = st.depth - 1
            // close pin? — materialize a LibPin from flat fields and
            // append to cur_cell_pins.
            if st.pin_depth >= 0 {
                if st.depth == st.pin_depth {
                    let new_pin = LibPin {
                        name: st.cur_pin_name,
                        direction: st.cur_pin_dir,
                        is_clock: st.cur_pin_clock
                    }
                    st.cur_cell_pins = st.cur_cell_pins.push(new_pin)
                    st.pin_depth = neg1
                }
            }
            // close cell? — materialize a LibCell and append to lib_cells.
            if st.cell_depth >= 0 {
                if st.depth == st.cell_depth {
                    let new_cell = LibCell {
                        name: st.cur_cell_name,
                        area: st.cur_cell_area,
                        pins: st.cur_cell_pins,
                        category: st.cur_cell_cat
                    }
                    st.lib_cells = st.lib_cells.push(new_cell)
                    st.cell_depth = neg1
                }
            }
        }
        i = i + 1
    }
    return st
}

// CLEAN-ROOM: process one raw input line — strip comments (handling
// the cross-line `/* */` carry), normalize punctuation, tokenize,
// then feed to the state machine. Returns the updated state.
fn _lib_feed_line(state: LibState, line: str) -> LibState {
    let mut st = state
    let pair = _lib_strip_line_comments(line, st.in_block)
    let stripped = pair[0]
    if pair[1] == "1" { st.in_block = 1 } else { st.in_block = 0 }
    if len(stripped) == 0 { return st }
    let norm = _lib_normalize_line(stripped)
    let toks = _lib_tokens_line(norm)
    if len(toks) == 0 { return st }
    return _lib_feed_tokens(st, toks)
}

// CLEAN-ROOM: finalize the parse — materialize the CellLibrary from
// flat state fields and sanity-check brace balance.
fn _lib_finalize(state: LibState) -> CellLibrary {
    let mut ok = state.lib_ok
    let mut msg = state.lib_message
    if state.depth != 0 {
        ok = 0
        msg = "liberty: brace imbalance at EOF (depth=" + str(state.depth) + ")"
    }
    return CellLibrary {
        name: state.lib_name,
        cells: state.lib_cells,
        ok: ok,
        message: msg
    }
}

// ─── public entry points ─────────────────────────────────────────────────
//
// CLEAN-ROOM: parse an in-memory Liberty source string. Internally
// splits on newline and reuses the streaming line-fed state machine,
// so the selftest fixture and the file path follow identical logic.
fn parse_liberty(src: str) -> CellLibrary {
    let lines = src.split("\n")
    let mut st = _lib_state_new()
    let mut i = 0
    while i < len(lines) {
        st = _lib_feed_line(st, lines[i])
        i = i + 1
    }
    return _lib_finalize(st)
}

// CLEAN-ROOM: read + parse a Liberty file from disk. Reads the file
// in one go (`read_file`), splits on newline, then feeds the line-
// streamed parser. The O(N²) accumulator in the pre-streaming body
// has been removed: per-line tokenization makes peak resident memory
// bounded by ~(file size × small constant), not O(file size²).
fn parse_liberty_file(path: str) -> CellLibrary {
    let src = read_file(path)
    if len(src) == 0 {
        return CellLibrary {
            name: "", cells: [], ok: 0,
            message: "liberty: empty or unreadable file `" + path + "`"
        }
    }
    return parse_liberty(src)
}

// ─── library queries ─────────────────────────────────────────────────────

// CLEAN-ROOM: find a cell by name (LibertyAst::find_cell).
fn lib_find_cell(lib: CellLibrary, name: str) -> int {
    let mut i = 0
    while i < len(lib.cells) {
        if lib.cells[i].name == name { return i }
        i = i + 1
    }
    return 0 - 1
}

// CLEAN-ROOM: total area for a list of (cell-type, count) pairs —
// the closed-form that drives gate-§5 area verification.
fn lib_total_area(lib: CellLibrary, names: [str], counts: [int]) -> float {
    let mut sum = 0.0
    let mut i = 0
    while i < len(names) {
        let idx = lib_find_cell(lib, names[i])
        if idx >= 0 {
            sum = sum + lib.cells[idx].area * float(counts[i])
        }
        i = i + 1
    }
    return sum
}

// ─── self-test ───────────────────────────────────────────────────────────

fn _lib_test_corpus() -> str {
    // Minimal Liberty file with two cells (one combinational, one
    // sequential). Layout mirrors sky130_fd_sc_hd_*.lib formatting.
    return "library (test_lib) {\n"
        + "  cell (sky130_fd_sc_hd__inv_1) {\n"
        + "    area : 3.75 ;\n"
        + "    pin (A) { direction : input ; }\n"
        + "    pin (Y) { direction : output ; }\n"
        + "  }\n"
        + "  cell (sky130_fd_sc_hd__dfxtp_1) {\n"
        + "    area : 22.51 ;\n"
        + "    ff (IQ, IQ_N) {}\n"
        + "    pin (CLK) { direction : input ; clock : true ; }\n"
        + "    pin (D)   { direction : input ; }\n"
        + "    pin (Q)   { direction : output ; }\n"
        + "  }\n"
        + "}\n"
}

fn main() {
    let mut fails = 0
    let mut total = 0

    // T1 — empty source parses to ok=1, no cells, empty name.
    total = total + 1
    let r1 = parse_liberty("")
    if r1.ok != 1 {
        println("FAIL T1 empty_input: " + r1.message); fails = fails + 1
    }
    if len(r1.cells) != 0 {
        println("FAIL T1b empty_cells"); fails = fails + 1
    }

    // T2 — full minimal corpus parses.
    total = total + 1
    let lib = parse_liberty(_lib_test_corpus())
    if lib.ok != 1 {
        println("FAIL T2 parse: " + lib.message); fails = fails + 1
    }
    if lib.name != "test_lib" {
        println("FAIL T2b name='" + lib.name + "'"); fails = fails + 1
    }
    if len(lib.cells) != 2 {
        println("FAIL T2c cell_count=" + str(len(lib.cells))); fails = fails + 1
    }

    // T3 — inv_1 area = 3.75 ; combinational category.
    total = total + 1
    let inv_i = lib_find_cell(lib, "sky130_fd_sc_hd__inv_1")
    if inv_i < 0 {
        println("FAIL T3 inv_lookup"); fails = fails + 1
    } else {
        let inv = lib.cells[inv_i]
        if inv.area < 3.74 {
            println("FAIL T3b inv_area_low=" + str(inv.area)); fails = fails + 1
        }
        if inv.area > 3.76 {
            println("FAIL T3c inv_area_high=" + str(inv.area)); fails = fails + 1
        }
        if inv.category != 0 {
            println("FAIL T3d inv_category=" + str(inv.category)); fails = fails + 1
        }
        if len(inv.pins) != 2 {
            println("FAIL T3e inv_pins=" + str(len(inv.pins))); fails = fails + 1
        }
    }

    // T4 — dfxtp_1 marked sequential via `ff (…)`.
    total = total + 1
    let ff_i = lib_find_cell(lib, "sky130_fd_sc_hd__dfxtp_1")
    if ff_i < 0 {
        println("FAIL T4 ff_lookup"); fails = fails + 1
    } else {
        if lib.cells[ff_i].category != 1 {
            println("FAIL T4b ff_category"); fails = fails + 1
        }
    }

    // T5 — clock pin discovered.
    total = total + 1
    if ff_i >= 0 {
        let ff = lib.cells[ff_i]
        let mut found_clk = 0
        let mut k = 0
        while k < len(ff.pins) {
            if ff.pins[k].is_clock == 1 { found_clk = 1 }
            k = k + 1
        }
        if found_clk != 1 {
            println("FAIL T5 clock_pin_not_found"); fails = fails + 1
        }
    }

    // T6 — fail-loud on imbalanced braces.
    total = total + 1
    let r6 = parse_liberty("library (broken) { cell (c) {")
    if r6.ok == 1 {
        println("FAIL T6 unclosed_should_fail"); fails = fails + 1
    }

    // T7 — lib_total_area sums area * count.
    total = total + 1
    let a = lib_total_area(lib,
        ["sky130_fd_sc_hd__inv_1", "sky130_fd_sc_hd__dfxtp_1"],
        [10, 2])
    // 10 * 3.75 + 2 * 22.51 = 37.5 + 45.02 = 82.52
    if a < 82.5 {
        println("FAIL T7 area_sum_low=" + str(a)); fails = fails + 1
    }
    if a > 82.55 {
        println("FAIL T7b area_sum_high=" + str(a)); fails = fails + 1
    }

    // T8 — pin directions decoded.
    total = total + 1
    if inv_i >= 0 {
        let inv = lib.cells[inv_i]
        let mut in_ct = 0
        let mut out_ct = 0
        let mut k = 0
        while k < len(inv.pins) {
            if inv.pins[k].direction == 1 { in_ct = in_ct + 1 }
            if inv.pins[k].direction == 2 { out_ct = out_ct + 1 }
            k = k + 1
        }
        if in_ct != 1 {
            println("FAIL T8 inv_in_count=" + str(in_ct)); fails = fails + 1
        }
        if out_ct != 1 {
            println("FAIL T8b inv_out_count=" + str(out_ct)); fails = fails + 1
        }
    }

    if fails > 0 {
        println("liberty selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("liberty selftest: " + str(total) + "/" + str(total) + " PASS")
}
