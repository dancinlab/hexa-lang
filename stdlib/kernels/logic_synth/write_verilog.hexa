#!hexa strict
// stdlib/yosys/write_verilog.hexa — RTLIL → gate-level Verilog backend (CLEAN-ROOM)
//
// @version 0.0.1
// @capabilities [backend, verilog, emit, gate-netlist]
// @stability phase-a (rfc_006 §4 module-6 of 7 — mapped-RTLIL → gate
//   Verilog text emitter; deterministic ordering; round-trip with
//   read_verilog OK for the subset our frontend produces)
// @since 2026-05-19
//
// CLEAN-ROOM PROVENANCE (design.md Decision 1 — public-surface clean-room)
//   This module re-derives the *public surface* of Yosys' Verilog
//   backend (mapped/gate-netlist emission only) by inspection of
//   upstream + manual + IEEE 1364-2005 standard wording. No upstream
//   code is copied.
//
//   - upstream code     : backends/verilog/verilog_backend.cc
//                          (RTLIL → Verilog text emitter; mapped + RTL
//                           variants — this module covers the *mapped*
//                           variant only for gate §5 scope)
//   - upstream manual   : https://yosyshq.readthedocs.io/projects/yosys/
//                          en/latest/cmd/write_verilog.html
//   - upstream license  : ISC (YosysHQ; LICENSE)
//   - upstream repo     : https://github.com/YosysHQ/yosys
//   - IEEE ref (norm)   : IEEE Std 1364-2005 §3-12 (lexical + grammar
//                          for the output language)
//   - absorbed substrate (D18) : none
//
// rfc_006 §4: module-6 of 7. Consumes the mapped-RTLIL design produced
// by abc_map (after passes + liberty + abc_map) and emits a gate-level
// Verilog netlist.
//
// Output convention (rfc_006 §4 + IEEE 1364-2005):
//   one `module` block per RTLIL Module; gate cells emitted as instance
//   bindings with named ports (.A(...), .Y(...)); wire declarations
//   explicit; no `defparam`, no behavioral constructs. Deterministic
//   ordering: modules in user-supplied order; within a module, port
//   declarations in port_id order, then internal wires by emission
//   order, then cells by emission order; byte-stable output.

use "stdlib/kernels/logic_synth/rtlil"

// ─── public types ────────────────────────────────────────────────────────

struct WriteVerilogResult {
    ok:    int,
    text:  str,
    bytes: int,
}

// ─── helpers ─────────────────────────────────────────────────────────────

// CLEAN-ROOM: emit ports in port_id ascending order (the Yosys
// backend sorts on the user-declared order, recorded as port_id).
fn _wv_emit_port_list(m: Module) -> str {
    // Collect port wires; sort by port_id via repeated min-scan
    // (O(n²) but n is small, and we avoid a generic sort dependency).
    let mut idxs: [int] = []
    let mut ports: [int] = []
    let mut i = 0
    while i < len(m.wires) {
        if m.wires[i].port_id > 0 { idxs = idxs.push(i) }
        i = i + 1
    }
    // selection sort by port_id
    let mut sorted: [int] = []
    let mut remaining = idxs
    while len(remaining) > 0 {
        let mut min_pi = 0
        let mut k = 1
        while k < len(remaining) {
            if m.wires[remaining[k]].port_id < m.wires[remaining[min_pi]].port_id {
                min_pi = k
            }
            k = k + 1
        }
        sorted = sorted.push(remaining[min_pi])
        let mut next: [int] = []
        let mut kk = 0
        while kk < len(remaining) {
            if kk != min_pi { next = next.push(remaining[kk]) }
            kk = kk + 1
        }
        remaining = next
    }
    let mut out = ""
    let mut j = 0
    while j < len(sorted) {
        if j > 0 { out = out + ", " }
        out = out + _wv_emit_name(m.wires[sorted[j]].name)
        j = j + 1
    }
    return out
}

// CLEAN-ROOM: emit one `wire` / `input` / `output` declaration.
// CLEAN-ROOM: check if a wire name is a plain Verilog identifier
// (letter/_ start + letter/digit/_ tail). RTLIL allows arbitrary
// names (e.g. `name[idx]`, `$rvexpr$N$c`) that require IEEE 1364
// §3.7.1 escaped-identifier syntax (`\name<whitespace>`) for
// substrate yosys round-trip. Returns 1 if plain, 0 if escape needed.
fn _wv_is_plain_ident(n: str) -> int {
    if len(n) == 0 { return 0 }
    let first = n.substring(0, 1)
    let mut ok_first = 0
    if first >= "a" && first <= "z" { ok_first = 1 }
    if first >= "A" && first <= "Z" { ok_first = 1 }
    if first == "_" { ok_first = 1 }
    if ok_first == 0 { return 0 }
    let mut i = 1
    while i < len(n) {
        let ch = n.substring(i, i + 1)
        let mut ok = 0
        if ch >= "a" && ch <= "z" { ok = 1 }
        if ch >= "A" && ch <= "Z" { ok = 1 }
        if ch >= "0" && ch <= "9" { ok = 1 }
        if ch == "_" { ok = 1 }
        if ok == 0 { return 0 }
        i = i + 1
    }
    return 1
}

// CLEAN-ROOM: emit a wire name. Plain identifiers verbatim; non-plain
// names use Verilog escaped-identifier syntax (`\<name><space>`).
fn _wv_emit_name(n: str) -> str {
    if _wv_is_plain_ident(n) == 1 { return n }
    return "\\" + n + " "
}

fn _wv_emit_decl(w: Wire) -> str {
    let mut kind = "wire"
    if w.dir_kind == 1 { kind = "input" }
    if w.dir_kind == 2 { kind = "output" }
    if w.dir_kind == 3 { kind = "inout" }
    let mut width_prefix = ""
    if w.width > 1 { width_prefix = "[" + str(w.width - 1) + ":0] " }
    return "  " + kind + " " + width_prefix + _wv_emit_name(w.name) + ";\n"
}

// CLEAN-ROOM: emit a cell instance: `<type> <name> (.A(a), .Y(y));`.
fn _wv_emit_cell(c: Cell, idx: int) -> str {
    let mut out = "  " + c.cell_type + " " + c.name + " ("
    let mut i = 0
    while i < len(c.conns) {
        if i > 0 { out = out + ", " }
        out = out + "." + c.conns[i].pin + "(" + _wv_emit_name(c.conns[i].net) + ")"
        i = i + 1
    }
    out = out + ");\n"
    return out
}

// CLEAN-ROOM: emit a top-level `assign` (RTLIL ::connect).
fn _wv_emit_connect(lhs: str, rhs: str) -> str {
    return "  assign " + _wv_emit_name(lhs) + " = " + _wv_emit_name(rhs) + ";\n"
}

// ─── module → text ───────────────────────────────────────────────────────

// CLEAN-ROOM: emit a full `module name (ports); … endmodule`.
fn write_verilog_module(m: Module) -> str {
    let ports = _wv_emit_port_list(m)
    let mut out = "module " + m.name + "(" + ports + ");\n"
    // declarations: ports first (port_id ascending), then internal
    // wires (dir_kind == 0).
    let mut wi = 0
    // Pass 1 — ports
    while wi < len(m.wires) {
        if m.wires[wi].port_id > 0 {
            out = out + _wv_emit_decl(m.wires[wi])
        }
        wi = wi + 1
    }
    // Pass 2 — internal wires
    let mut wj = 0
    while wj < len(m.wires) {
        if m.wires[wj].port_id == 0 {
            out = out + _wv_emit_decl(m.wires[wj])
        }
        wj = wj + 1
    }
    // top-level connects
    let mut ki = 0
    while ki < len(m.connect_lhs) {
        out = out + _wv_emit_connect(m.connect_lhs[ki], m.connect_rhs[ki])
        ki = ki + 1
    }
    // cell instances
    let mut ci = 0
    while ci < len(m.cells) {
        out = out + _wv_emit_cell(m.cells[ci], ci)
        ci = ci + 1
    }
    out = out + "endmodule\n"
    return out
}

// CLEAN-ROOM: emit a full design as a single Verilog text buffer
// (modules concatenated in declaration order; header block carries
// the RTLIL source provenance for the audit trail).
fn write_verilog(d: Design) -> WriteVerilogResult {
    let mut out = "// Generated by stdlib/yosys/write_verilog.hexa (rfc_006 §4 module-6)\n"
    out = out + "// source: " + d.source + "\n\n"
    let mut i = 0
    while i < len(d.modules) {
        out = out + write_verilog_module(d.modules[i])
        if i + 1 < len(d.modules) { out = out + "\n" }
        i = i + 1
    }
    return WriteVerilogResult { ok: 1, text: out, bytes: len(out) }
}

// CLEAN-ROOM: write to a file path.
fn write_verilog_file(d: Design, path: str) -> WriteVerilogResult {
    let r = write_verilog(d)
    write_file(path, r.text)
    return r
}

// ─── self-test ───────────────────────────────────────────────────────────

fn main() {
    let mut fails = 0
    let mut total = 0

    // Build a small fixture by hand.
    let mut m = rtlil_new_module("ab")
    m = rtlil_module_add_wire(m, rtlil_wire("a", 1, 1, 1))
    m = rtlil_module_add_wire(m, rtlil_wire("b", 1, 1, 2))
    m = rtlil_module_add_wire(m, rtlil_wire("y", 1, 2, 3))
    let mut c = rtlil_cell("u_and", "sky130_fd_sc_hd__and2_1", 1)
    c = rtlil_cell_connect(c, "A", "a")
    c = rtlil_cell_connect(c, "B", "b")
    c = rtlil_cell_connect(c, "X", "y")
    m = rtlil_module_add_cell(m, c)
    let mut d = rtlil_new_design("test")
    d = rtlil_design_add(d, m)

    // T1 — emit non-empty, contains all expected fragments.
    total = total + 1
    let r1 = write_verilog(d)
    if r1.ok != 1 {
        println("FAIL T1 ok"); fails = fails + 1
    }
    if r1.text.find("module ab(") < 0 {
        println("FAIL T1b module_decl"); fails = fails + 1
    }
    if r1.text.find("input a;") < 0 {
        println("FAIL T1c input_a"); fails = fails + 1
    }
    if r1.text.find("output y;") < 0 {
        println("FAIL T1d output_y"); fails = fails + 1
    }
    if r1.text.find("sky130_fd_sc_hd__and2_1 u_and") < 0 {
        println("FAIL T1e cell_inst"); fails = fails + 1
    }
    if r1.text.find(".A(a)") < 0 {
        println("FAIL T1f pin_A"); fails = fails + 1
    }
    if r1.text.find("endmodule") < 0 {
        println("FAIL T1g endmodule"); fails = fails + 1
    }

    // T2 — port-list ordering by port_id (a, b, y).
    total = total + 1
    let pos_a = r1.text.find("a, b, y")
    if pos_a < 0 {
        println("FAIL T2 port_order"); fails = fails + 1
    }

    // T3 — byte-stable: two emissions identical.
    total = total + 1
    let r3a = write_verilog(d)
    let r3b = write_verilog(d)
    if r3a.text != r3b.text {
        println("FAIL T3 byte_stable"); fails = fails + 1
    }

    // T4 — internal wires emitted as plain `wire`.
    total = total + 1
    let mut m2 = rtlil_new_module("ii")
    m2 = rtlil_module_add_wire(m2, rtlil_wire("z", 1, 0, 0))
    let mut d2 = rtlil_new_design("test")
    d2 = rtlil_design_add(d2, m2)
    let r4 = write_verilog(d2)
    if r4.text.find("wire z;") < 0 {
        println("FAIL T4 internal_wire"); fails = fails + 1
    }

    // T5 — `assign` connects emitted.
    total = total + 1
    let mut m3 = rtlil_new_module("c")
    m3 = rtlil_module_add_wire(m3, rtlil_wire("a", 1, 1, 1))
    m3 = rtlil_module_add_wire(m3, rtlil_wire("y", 1, 2, 2))
    m3 = rtlil_module_connect(m3, "y", "a")
    let mut d3 = rtlil_new_design("test")
    d3 = rtlil_design_add(d3, m3)
    let r5 = write_verilog(d3)
    if r5.text.find("assign y = a;") < 0 {
        println("FAIL T5 assign"); fails = fails + 1
    }

    // T6 — empty design still produces a header.
    total = total + 1
    let r6 = write_verilog(rtlil_new_design("test"))
    if r6.bytes <= 0 {
        println("FAIL T6 empty_design"); fails = fails + 1
    }

    // T7 — multi-module preserved.
    total = total + 1
    let mut d4 = rtlil_new_design("test")
    d4 = rtlil_design_add(d4, rtlil_new_module("m_a"))
    d4 = rtlil_design_add(d4, rtlil_new_module("m_b"))
    let r7 = write_verilog(d4)
    if r7.text.find("module m_a(") < 0 {
        println("FAIL T7 multi_a"); fails = fails + 1
    }
    if r7.text.find("module m_b(") < 0 {
        println("FAIL T7b multi_b"); fails = fails + 1
    }

    // T8 — multi-bit wire emits with `[W-1:0]` width-prefix
    //   (rfc_006 §5 substrate handoff: yosys requires explicit
    //    width on multi-bit declarations).
    total = total + 1
    let mut m8 = rtlil_new_module("mW")
    m8 = rtlil_module_add_wire(m8, rtlil_wire("aW", 8, 0, 0))
    let mut d8 = rtlil_new_design("test")
    d8 = rtlil_design_add(d8, m8)
    let r8 = write_verilog(d8)
    if r8.text.find("[7:0] aW") < 0 {
        println("FAIL T8 width_prefix"); fails = fails + 1
    }

    // T9 — escaped-identifier emit for names with non-ident chars
    //   (RTLIL allows `name[idx]` / `$internal$N` — yosys requires
    //    `\name[idx] ` IEEE 1364-2005 §3.7.1 escaped form on read).
    total = total + 1
    let mut m9 = rtlil_new_module("mE")
    m9 = rtlil_module_add_wire(m9, rtlil_wire("name[3]", 1, 0, 0))
    let mut d9 = rtlil_new_design("test")
    d9 = rtlil_design_add(d9, m9)
    let r9 = write_verilog(d9)
    if r9.text.find("\\name[3] ;") < 0 {
        println("FAIL T9 escaped_ident"); fails = fails + 1
    }

    if fails > 0 {
        println("write_verilog selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("write_verilog selftest: " + str(total) + "/" + str(total) + " PASS")
}
