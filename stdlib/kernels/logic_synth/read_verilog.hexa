    // `route_xy`: reg decl, begin/end wrap, blocking assign substitutes
    // the call-site arg into the cascaded-if's branch expressions, then
    // ternary lowers each level to a $mux. After inline at the assign
    // site, `r = f(h)` should reach the ternary collapse + emit the
    // $mux + $gt cells (no "name not found" fallback).
    total = total + 1
    let _v50 = "module rg ( input wire [ 3 : 0 ] h , output wire [ 1 : 0 ] r ) ; function automatic [ 1 : 0 ] f ( input [ 3 : 0 ] x ) ; reg [ 3 : 0 ] dx ; begin dx = x ; if ( dx > 0 ) f = 1 ; else f = 0 ; end endfunction assign r = f ( h ) ; endmodule"
    let _r50 = read_verilog(_v50)
    if _r50.ok != 1 {
        println("FAIL T50 func_inline_with_prefix: " + _r50.message); fails = fails + 1
    } else {
        let _m50 = _r50.design.modules[0]
        let _gt = rtlil_count_cells_of_type(_m50, "$gt")
        let _mux = rtlil_count_cells_of_type(_m50, "$mux")
        if _gt != 1 {
            println("FAIL T50a gt_count got " + str(_gt) + " (expected 1)"); fails = fails + 1
        }
        if _mux != 1 {
            println("FAIL T50b mux_count got " + str(_mux) + " (expected 1)"); fails = fails + 1
        }
    }

    // ─── RFC 073 Phase 3c — for-loop iteration-guard end-to-end gate ─────
    //
    // T64..T66 verify the full pipeline:
    //
    //   read_verilog  →  pass_proc_mux  →  pass_clean_multidriver
    //
    // for the canonical for-loop guarded-write shape (T58 already locks
    // down the read_verilog half — that 3 cond-tagged rows are produced
    // with iteration-substituted guards `sel[0]`, `sel[1]`, `sel[2]`).
    // T65 asserts the new `pass_clean_multidriver` cond-aware skip
    // (group with ≥1 cond-tagged row is left untouched, deferred to
    // proc_mux). T66 asserts `pass_proc_mux` folds the 3 cond-tagged
    // rows into a 2-level left-deep `$mux` chain ending in one
    // unconditional connect to the LHS.
    //
    // @cite IEEE 1364-2005 §10.3.5 (for-loop unroll) + §10.4.2
    // (procedural assignment — last-write-wins reduces to one-hot mux
    // when guards are mutually exclusive) + Yosys passes/proc/proc_mux.cc
    // (clean-room behavioural reference, no source copy).

    // T64 — read_verilog half (T58 mirror with `sel` LHS-array, narrower
    // assertion: 3 connect_cond rows on `y` with conds `sel[0..2]`).
    total = total + 1
    let _v64 = "module fg64 ( input wire [ 2 : 0 ] sel , output reg [ 7 : 0 ] y ) ; integer i ; always @ ( * ) begin for ( i = 0 ; i < 3 ; i = i + 1 ) if ( sel [ i ] ) y = i ; end endmodule"
    let _r64 = read_verilog(_v64)
    if _r64.ok != 1 {
        println("FAIL T64 for_guarded_y: " + _r64.message); fails = fails + 1
    } else {
        let _m64 = _r64.design.modules[0]
        let mut _t64_rows = 0
        let mut _t64_g0 = 0
        let mut _t64_g1 = 0
        let mut _t64_g2 = 0
        let mut _k64 = 0
        while _k64 < len(_m64.connect_lhs) {
            if _m64.connect_lhs[_k64] == "y" {
                let _c64 = _m64.connect_cond[_k64]
                if len(_c64) > 0 {
                    _t64_rows = _t64_rows + 1
                    if _c64 == "sel[0]" { _t64_g0 = 1 }
                    if _c64 == "sel[1]" { _t64_g1 = 1 }
                    if _c64 == "sel[2]" { _t64_g2 = 1 }
                }
            }
            _k64 = _k64 + 1
        }
        if _t64_rows != 3 {
            println("FAIL T64a row_cnt got " + str(_t64_rows) + " (expected 3)"); fails = fails + 1
        }
        if _t64_g0 != 1 { println("FAIL T64b missing cond=sel[0]"); fails = fails + 1 }
        if _t64_g1 != 1 { println("FAIL T64c missing cond=sel[1]"); fails = fails + 1 }
        if _t64_g2 != 1 { println("FAIL T64d missing cond=sel[2]"); fails = fails + 1 }
    }

    // T65 — pass_clean_multidriver MUST NOT collapse cond-tagged groups.
    //
    // Feed the T64 design directly into `pass_clean_multidriver`. The 3
    // cond-tagged rows on `y` must survive untouched (Phase 3c skip
    // rule). Other LHS-groups (purely unconditional) collapse as before.
    total = total + 1
    let _r65 = read_verilog(_v64)
    if _r65.ok != 1 {
        println("FAIL T65 setup: " + _r65.message); fails = fails + 1
    } else {
        let _r65b = pass_clean_multidriver(_r65.design)
        if _r65b.ok != 1 {
            println("FAIL T65 clean_multidriver: " + _r65b.message); fails = fails + 1
        } else {
            let _m65 = _r65b.design.modules[0]
            // Count cond-tagged rows on y after clean_multidriver — must
            // STILL be 3 (group deferred to proc_mux per Phase 3c).
            let mut _t65_rows = 0
            let mut _t65_g0 = 0
            let mut _t65_g1 = 0
            let mut _t65_g2 = 0
            let mut _k65 = 0
            while _k65 < len(_m65.connect_lhs) {
                if _m65.connect_lhs[_k65] == "y" {
                    let _c65 = _m65.connect_cond[_k65]
                    if len(_c65) > 0 {
                        _t65_rows = _t65_rows + 1
                        if _c65 == "sel[0]" { _t65_g0 = 1 }
                        if _c65 == "sel[1]" { _t65_g1 = 1 }
                        if _c65 == "sel[2]" { _t65_g2 = 1 }
                    }
                }
                _k65 = _k65 + 1
            }
