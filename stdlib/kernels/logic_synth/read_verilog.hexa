                    + " (expected 3 — clean_multidriver must defer cond-tagged groups)")
                fails = fails + 1
            }
            if _t65_g0 != 1 { println("FAIL T65b lost cond=sel[0]"); fails = fails + 1 }
            if _t65_g1 != 1 { println("FAIL T65c lost cond=sel[1]"); fails = fails + 1 }
            if _t65_g2 != 1 { println("FAIL T65d lost cond=sel[2]"); fails = fails + 1 }
        }
    }

    // T66 — pass_proc_mux folds the 3 cond-tagged rows into a left-deep
    // `$mux` chain (3 muxes total — one per cond level) and emits a
    // single unconditional connect to `y` on the chain's output.
    //
    // Chain shape (per `_passes_proc_mux_emit_chain` left-deep build):
    //   inner_0 = base (LHS feedback `y` — no untagged default in T64)
    //   k=2: $mux(S=sel[2], A=y,       B=2, Y=$procmux_y$y$2)
    //   k=1: $mux(S=sel[1], A=$pm.y.2, B=1, Y=$procmux_y$y$1)
    //   k=0: $mux(S=sel[0], A=$pm.y.1, B=0, Y=$procmux_y$y$0)
    //   final: connect(y, $procmux_y$y$0)
    //
    // After proc_mux: 0 cond-tagged rows on y, 1 unconditional connect
    // (y ← $procmux_y$y$0), +3 new $mux cells added to module.
    total = total + 1
    let _r66 = read_verilog(_v64)
    if _r66.ok != 1 {
        println("FAIL T66 setup: " + _r66.message); fails = fails + 1
    } else {
        let _mux_before = rtlil_count_cells_of_type(_r66.design.modules[0], "$mux")
        let _r66b = pass_proc_mux(_r66.design)
        if _r66b.ok != 1 {
            println("FAIL T66 proc_mux: " + _r66b.message); fails = fails + 1
        } else {
            let _m66 = _r66b.design.modules[0]
            // 1. No cond-tagged rows on y survive.
            let mut _t66_cond_rows = 0
            let mut _t66_uncond_y = 0
            let mut _k66 = 0
            while _k66 < len(_m66.connect_lhs) {
                if _m66.connect_lhs[_k66] == "y" {
                    if len(_m66.connect_cond[_k66]) > 0 {
                        _t66_cond_rows = _t66_cond_rows + 1
                    } else {
                        _t66_uncond_y = _t66_uncond_y + 1
                    }
                }
                _k66 = _k66 + 1
            }
            if _t66_cond_rows != 0 {
                println("FAIL T66a cond_rows after proc_mux got "
                    + str(_t66_cond_rows) + " (expected 0)")
                fails = fails + 1
            }
            if _t66_uncond_y < 1 {
                println("FAIL T66b unconditional connect on y missing")
                fails = fails + 1
            }
            // 2. proc_mux added 3 new $mux cells (one per cond level).
            let _mux_after = rtlil_count_cells_of_type(_m66, "$mux")
            let _mux_delta = _mux_after - _mux_before
            if _mux_delta != 3 {
                println("FAIL T66c mux_delta got " + str(_mux_delta)
                    + " (expected 3 = 1 per cond row)")
                fails = fails + 1
            }
        }
    }

    // T67 — RFC 073 Phase 3d (F-RFC-RV-DYN-LHS-CLOCKED, bare path).
    //   Bare dyn-LHS clocked write: `always @(posedge clk) mem [ k ] <=
    //   a ;` with `reg mem [ 0 : 2 ]` (P=3) and `k` a runtime wire.
    //   Expected lowering: per-element ($eq + $mux + $dff) chain × 3 →
    //   3 $eq + 3 $mux + 3 $dff (no $and because the demux isn't gated
    //   by an outer `if`; the bare path is the demux complement of the
    //   single-statement #4d path at read_verilog.hexa:2933 and of the
    //   multi-LHS #4h-b path at L3001 — both of which sit inside an
    //   outer cond guard). Pre-fix: the eval-fail branch silently set
    //   `q = q_base` and emitted one `$dff(Q=mem)` losing all per-cycle
    //   writes.  @cite IEEE 1364-2005 §9.5 + §10.4.2 + Yosys proc_mux.
    total = total + 1
    let _v67 = "module dlc ( input clk , input k , input a , output reg mem [ 0 : 2 ] ) ; always @ ( posedge clk ) mem [ k ] <= a ; endmodule"
    let _r67 = read_verilog(_v67)
    if _r67.ok != 1 {
        println("FAIL T67 dyn_lhs_clocked: " + _r67.message); fails = fails + 1
    } else {
        let _m67 = _r67.design.modules[0]
        let _t67_eq = rtlil_count_cells_of_type(_m67, "$eq")
        let _t67_mux = rtlil_count_cells_of_type(_m67, "$mux")
        let _t67_dff = rtlil_count_cells_of_type(_m67, "$dff")
        if _t67_eq != 3 {
            println("FAIL T67a eq_count got " + str(_t67_eq) + " (expected 3)")
            fails = fails + 1
        }
        if _t67_mux != 3 {
            println("FAIL T67b mux_count got " + str(_t67_mux) + " (expected 3)")
            fails = fails + 1
        }
        if _t67_dff != 3 {
            println("FAIL T67c dff_count got " + str(_t67_dff) + " (expected 3)")
            fails = fails + 1
        }
        // Each $dff must drive a distinct mem[i] slot.
        let mut _t67_q0 = 0
        let mut _t67_q1 = 0
        let mut _t67_q2 = 0
        let mut _t67_ci = 0
        while _t67_ci < len(_m67.cells) {
            let _t67_c = _m67.cells[_t67_ci]
            if _t67_c.cell_type == "$dff" {
                let mut _t67_pi = 0
                while _t67_pi < len(_t67_c.conns) {
                    let _t67_p = _t67_c.conns[_t67_pi]
                    if _t67_p.pin == "Q" {
                        if _t67_p.net == "mem[0]" { _t67_q0 = 1 }
                        if _t67_p.net == "mem[1]" { _t67_q1 = 1 }
                        if _t67_p.net == "mem[2]" { _t67_q2 = 1 }
                    }
                    _t67_pi = _t67_pi + 1
                }
            }
            _t67_ci = _t67_ci + 1
        }
        if _t67_q0 != 1 { println("FAIL T67d missing $dff Q=mem[0]"); fails = fails + 1 }
        if _t67_q1 != 1 { println("FAIL T67e missing $dff Q=mem[1]"); fails = fails + 1 }
        if _t67_q2 != 1 { println("FAIL T67f missing $dff Q=mem[2]"); fails = fails + 1 }
    }

    // T68 — RFC 073 Phase 3d (F-RFC-RV-DYN-LHS-CLOCKED, begin/end).
    //   Same shape as T67 but wrapped in `begin … end` to exercise the
    //   has_begin==1 path through the bare dyn-LHS demux emit. Also
    //   bumps the array bound to P=4 so the chain emits 4 of each cell.
    //   Identity: $eq=4, $mux=4, $dff=4. Without the begin/end loop
    //   continuation the bare path would short-circuit after one
    //   statement.
    total = total + 1
    let _v68 = "module dlcb ( input clk , input k , input a , output reg mem [ 0 : 3 ] ) ; always @ ( posedge clk ) begin mem [ k ] <= a ; end endmodule"
    let _r68 = read_verilog(_v68)
    if _r68.ok != 1 {
        println("FAIL T68 dyn_lhs_clocked_begin: " + _r68.message); fails = fails + 1
    } else {
        let _m68 = _r68.design.modules[0]
        if rtlil_count_cells_of_type(_m68, "$eq") != 4 {
            println("FAIL T68a eq_count got "
                + str(rtlil_count_cells_of_type(_m68, "$eq")) + " (expected 4)")
            fails = fails + 1
        }
        if rtlil_count_cells_of_type(_m68, "$mux") != 4 {
            println("FAIL T68b mux_count got "
                + str(rtlil_count_cells_of_type(_m68, "$mux")) + " (expected 4)")
            fails = fails + 1
        }
        if rtlil_count_cells_of_type(_m68, "$dff") != 4 {
            println("FAIL T68c dff_count got "
                + str(rtlil_count_cells_of_type(_m68, "$dff")) + " (expected 4)")
            fails = fails + 1
        }
    }

    // T69 — RFC 073 Phase 3d (F-RFC-RV-DYN-LHS-MULTI-LHS-IF).
    //   Multi-LHS no-else cond-mux body with dyn-idx LHS — matches the
    //   router_d4 `if (any_grant) begin out_data[grant_out] <= …;
    //   out_valid[grant_out] <= … end` shape. Per IEEE 1364-2005 §9.5 +
    //   §10.4.2 the lowering is per-element ($eq + $and + $mux + $dff)
    //   chain × P per statement: with two statements at P=3 we expect
    //   $eq=6, $and=6, $mux=6, $dff=6. Without the multi-LHS dyn-idx
    //   extension (which landed inline in `7575a79d`) the handler bailed
    //   out silently on every dyn-idx LHS statement, dropping the writes
    //   entirely. T52 already verifies P=4; T69 cross-verifies P=3.
    total = total + 1
    let _v69 = "module sm69 ( input clk , input en , input k , input a , input b , output reg y [ 0 : 2 ] , output reg z [ 0 : 2 ] ) ; always @ ( posedge clk ) if ( en ) begin y [ k ] <= a ; z [ k ] <= b ; end endmodule"
    let _r69 = read_verilog(_v69)
    if _r69.ok != 1 {
        println("FAIL T69 multi_lhs_dyn_idx: " + _r69.message); fails = fails + 1
    } else {
        let _m69 = _r69.design.modules[0]
        if rtlil_count_cells_of_type(_m69, "$eq") != 6 {
            println("FAIL T69a eq_count got "
                + str(rtlil_count_cells_of_type(_m69, "$eq")) + " (expected 6)")
            fails = fails + 1
        }
        if rtlil_count_cells_of_type(_m69, "$and") != 6 {
            println("FAIL T69b and_count got "
                + str(rtlil_count_cells_of_type(_m69, "$and")) + " (expected 6)")
            fails = fails + 1
        }
        if rtlil_count_cells_of_type(_m69, "$mux") != 6 {
            println("FAIL T69c mux_count got "
                + str(rtlil_count_cells_of_type(_m69, "$mux")) + " (expected 6)")
            fails = fails + 1
        }
        if rtlil_count_cells_of_type(_m69, "$dff") != 6 {
            println("FAIL T69d dff_count got "
                + str(rtlil_count_cells_of_type(_m69, "$dff")) + " (expected 6)")
            fails = fails + 1
        }
    }

    // T70 — RFC 073 Phase 3e (F-RFC-RV-CLOCKED-FOR-INDEXED-LHS).
    //   Unrolled clocked for-loop with static-idx LHS:
    //     `always @(posedge clk) for (i = 0; i < 3; i = i + 1)
    //         name[i] <= rhs(i)`
    //   The for-body handler unrolls i ∈ {0,1,2} and emits one $dff per
    //   iteration with Q = name[<const>] (no $mux feedback — unguarded
    //   write inside posedge-always). Expected: 3 $dff with Q=name[0],
    //   name[1], name[2]. @cite IEEE 1364-2005 §10.3.5 (for-loop) +
    //   §10.4.2 (procedural assign).
    total = total + 1
    let _v70 = "module fil ( input clk , input a , input b , input c , output reg name [ 0 : 2 ] ) ; integer i ; always @ ( posedge clk ) for ( i = 0 ; i < 3 ; i = i + 1 ) name [ i ] <= a ; endmodule"
    let _r70 = read_verilog(_v70)
    if _r70.ok != 1 {
        println("FAIL T70 for_indexed_lhs: " + _r70.message); fails = fails + 1
    } else {
        let _m70 = _r70.design.modules[0]
        if rtlil_count_cells_of_type(_m70, "$dff") != 3 {
            println("FAIL T70a dff_count got "
                + str(rtlil_count_cells_of_type(_m70, "$dff")) + " (expected 3)")
            fails = fails + 1
        }
        // Each $dff must drive a distinct name[i] slot.
        let mut _t70_q0 = 0
        let mut _t70_q1 = 0
        let mut _t70_q2 = 0
        let mut _t70_ci = 0
        while _t70_ci < len(_m70.cells) {
            let _t70_c = _m70.cells[_t70_ci]
            if _t70_c.cell_type == "$dff" {
                let mut _t70_pi = 0
                while _t70_pi < len(_t70_c.conns) {
                    let _t70_p = _t70_c.conns[_t70_pi]
                    if _t70_p.pin == "Q" {
                        if _t70_p.net == "name[0]" { _t70_q0 = 1 }
                        if _t70_p.net == "name[1]" { _t70_q1 = 1 }
                        if _t70_p.net == "name[2]" { _t70_q2 = 1 }
                    }
                    _t70_pi = _t70_pi + 1
                }
            }
            _t70_ci = _t70_ci + 1
        }
        if _t70_q0 != 1 { println("FAIL T70b missing $dff Q=name[0]"); fails = fails + 1 }
        if _t70_q1 != 1 { println("FAIL T70c missing $dff Q=name[1]"); fails = fails + 1 }
        if _t70_q2 != 1 { println("FAIL T70d missing $dff Q=name[2]"); fails = fails + 1 }
    }

    // T71 — RFC 073 Phase 3e (F-RFC-RV-WITH-ELSE-NONMATCHING-BODIES).
    //   With-else where THEN-arm is a single simple-LHS write and ELSE-
    //   arm is a TWO-statement block (mismatched arm shapes — THEN has
    //   1 stmt, ELSE has 2). Pre-Phase-3e the positional multi-LHS
    //   with-else handler bailed silently because `len(t_stmts) !=
    //   len(e_stmts)`. Post-Phase-3e the `_rv_emit_body_v2` fallback
    //   recurses into each arm with the cond / !cond guard, emitting
    //   per-LHS cond-tagged `connect_cond(<lhs>__d, rhs, guard)` rows
    //   PLUS one $dff per tracked LHS (with D=<lhs>__d, Q=<lhs>) and an
    //   unconditional `connect(<lhs>__d, <lhs>)` feedback default.
    //   `pass_proc_mux` later folds the cond-tagged rows into a $mux
    //   chain feeding each $dff. Single $dff per LHS = no multi-driver.
    //   Expected post-read_verilog (BEFORE pass_proc_mux):
    //     $dff = 2 (one per LHS y, z — single-driver invariant)
    //     $logic_not ≥ 1 (NOT(cond) for ELSE-arm guard)
    //     connect_cond rows ≥ 3 (THEN y, ELSE y, ELSE z) + 2 feedback
    //   @cite IEEE 1364-2005 §9.4 (control) + §10.4.2 (procedural
    //   assign) + Yosys passes/proc/proc_mux.cc (priority-mux fold).
    total = total + 1
    let _v71 = "module sm71 ( input clk , input c , input a , input b , output reg y , output reg z ) ; always @ ( posedge clk ) if ( c ) y <= a ; else begin y <= b ; z <= c ; end endmodule"
    let _r71 = read_verilog(_v71)
    if _r71.ok != 1 {
        println("FAIL T71 with_else_nonmatching: " + _r71.message); fails = fails + 1
    } else {
        let _m71 = _r71.design.modules[0]
        let _t71_dff = rtlil_count_cells_of_type(_m71, "$dff")
        let _t71_not = rtlil_count_cells_of_type(_m71, "$logic_not")
        if _t71_dff != 2 {
            println("FAIL T71a dff_count got " + str(_t71_dff) + " (expected 2 — one per LHS)")
            fails = fails + 1
        }
        if _t71_not < 1 {
            println("FAIL T71b logic_not_count got " + str(_t71_not) + " (expected ≥1)")
            fails = fails + 1
        }
        // Each $dff must drive a distinct Q (y, z).
        let mut _t71_qy = 0
        let mut _t71_qz = 0
        let mut _t71_ci = 0
        while _t71_ci < len(_m71.cells) {
            let _t71_c = _m71.cells[_t71_ci]
            if _t71_c.cell_type == "$dff" {
                let mut _t71_pi = 0
                while _t71_pi < len(_t71_c.conns) {
                    let _t71_p = _t71_c.conns[_t71_pi]
                    if _t71_p.pin == "Q" {
                        if _t71_p.net == "y" { _t71_qy = 1 }
                        if _t71_p.net == "z" { _t71_qz = 1 }
                    }
                    _t71_pi = _t71_pi + 1
                }
            }
            _t71_ci = _t71_ci + 1
        }
        if _t71_qy != 1 { println("FAIL T71c missing $dff Q=y"); fails = fails + 1 }
        if _t71_qz != 1 { println("FAIL T71d missing $dff Q=z"); fails = fails + 1 }
        // Per-LHS D-wires (y__d, z__d) must exist + drive each $dff's D.
        if rtlil_find_wire(_m71, "y__d") < 0 {
            println("FAIL T71e missing y__d D-wire"); fails = fails + 1
        }
        if rtlil_find_wire(_m71, "z__d") < 0 {
            println("FAIL T71f missing z__d D-wire"); fails = fails + 1
        }
    }

    // T72 — RFC 073 Phase 3e (F-RFC-RV-NESTED-IF-INSIDE-ELSE-BODY).
    //   Nested if/else chain where the else-body is itself an `if (c2)`
    //   (i.e. `else if`). The else-arm shape forces the Phase 3e v2
    //   helper recursion to fire on a body that contains a nested `if`.
    //   Pre-Phase-3e: the cascaded else-if path at L2636 handled this
    //   only when both arms were simple `LHS <= RHS ;`; with-else mode
    //   was untouched and the inner nesting was dropped. Post-Phase-3e:
    //   the v2 helper recurses through the else-body's `if (c2)`,
    //   composing `!c1 AND c2` as the inner-write guard, producing
    //   ≥2 $logic_not (one per else-arm at each level) and ≥2 $and
    //   (composed-guard wires). @cite IEEE 1364-2005 §9.4.
    total = total + 1
    let _v72 = "module sm72 ( input clk , input c1 , input c2 , input a , input b , output reg y ) ; always @ ( posedge clk ) if ( c1 ) y <= a ; else if ( c2 ) y <= b ; endmodule"
    let _r72 = read_verilog(_v72)
    if _r72.ok != 1 {
        println("FAIL T72 nested_if_else_body: " + _r72.message); fails = fails + 1
    } else {
        let _m72 = _r72.design.modules[0]
        let _t72_mux = rtlil_count_cells_of_type(_m72, "$mux")
        let _t72_dff = rtlil_count_cells_of_type(_m72, "$dff")
        // Either the nested-chain handler (cascaded-mux tree) OR the
        // Phase 3e v2 helper fires here. Both produce ≥2 $mux + ≥1 $dff
        // for Q=y. The pre-Phase-3e handler at L2636+ already covers
        // this shape via the cascaded `else if` chain detector
        // (nested_chain_ok==1 path), so T72 anchors that path's continued
        // operation — it MUST not regress when v2 fallback is wired.
        if _t72_mux < 2 {
            println("FAIL T72a mux_count got " + str(_t72_mux) + " (expected ≥2)")
            fails = fails + 1
        }
        if _t72_dff < 1 {
            println("FAIL T72b dff_count got " + str(_t72_dff) + " (expected ≥1)")
            fails = fails + 1
        }
        // The single $dff must drive Q=y.
        let mut _t72_qy = 0
        let mut _t72_ci = 0
        while _t72_ci < len(_m72.cells) {
            let _t72_c = _m72.cells[_t72_ci]
            if _t72_c.cell_type == "$dff" {
                let mut _t72_pi = 0
                while _t72_pi < len(_t72_c.conns) {
                    let _t72_p = _t72_c.conns[_t72_pi]
                    if _t72_p.pin == "Q" {
                        if _t72_p.net == "y" { _t72_qy = 1 }
                    }
                    _t72_pi = _t72_pi + 1
                }
            }
            _t72_ci = _t72_ci + 1
        }
        if _t72_qy != 1 { println("FAIL T72c missing $dff Q=y"); fails = fails + 1 }
    }

    // T73 — RFC 006 §5 ABC combinational-loop SSA fix
    //   (F-RFC-RV-COMB-LOOP-SSA-ARBITER).
    //
    //   Pattern: combinational `always @*` with a `for` loop whose body
    //   reads-then-writes the same `reg` (priority-arbiter pattern from
    //   router_d4 `always @*` block at lines 80-94 of
    //   comb/rtl/router_d4.v):
    //
    //     always @* begin
    //       pick = 1'b0;
    //       for (i = 0; i < P; i = i + 1) begin
    //         if (!pick && r[i]) pick = 1'b1;        // read-then-write
    //       end
    //     end
    //
    //   Pre-fix: every iter's read of `pick` references the same single
    //   net as every iter's write. After flat unroll the net depends on
    //   itself → ABC reports "Network contains combinational loop" and
    //   emits 0 sequential cells (rfc_006 §5 area=0.0 µm²).
    //
    //   Post-fix: per-iteration SSA renaming. Each tracked blocking-
    //   assigned reg `s` is versioned `s__ssa0` (loop entry value),
    //   `s__ssa1` (after iter 0), …, `s__ssaP` (after iter P-1, the
    //   final loop-exit value). Reads inside iter k substitute
    //   `s` → `s__ssa<k>`; writes go to `s__ssa<k+1>` (cond-tagged) with
    //   an unconditional `s__ssa<k+1> <= s__ssa<k>` hold-default. After
    //   the loop, `connect(s, s__ssa<P>)` publishes the final value to
    //   outer scope. Inter-iter anti-dependency is now explicit in the
    //   netlist DAG; ABC sees no cycle.
    //
    //   Falsifier: P=4 priority arbiter over 4-bit `r`. Expect:
    //     - wires `pick__ssa0` .. `pick__ssa4` all present (5 versions)
    //     - wire `pick__ssa4` drives outer `pick` (final publish)
    //     - same versioning for `g` (the indexed grant register)
    //
    //   @cite IEEE 1364-2005 §10.4.2 (procedural assign within
    //   sequential block — blocking assignment ordering) + Yosys
    //   passes/proc/proc_arst.cc (SigChunk inter-statement chain).
    total = total + 1
    let _v73 = "module sm73 ( input [ 3 : 0 ] r , output reg [ 1 : 0 ] g ) ; reg pick ; integer i ; always @ ( * ) begin pick = 1'b0 ; g = 2'd0 ; for ( i = 0 ; i < 4 ; i = i + 1 ) begin if ( ! pick && r [ i ] ) begin g = i [ 1 : 0 ] ; pick = 1'b1 ; end end end endmodule"
    let _r73 = read_verilog(_v73)
    if _r73.ok != 1 {
        println("FAIL T73 comb_loop_ssa: " + _r73.message); fails = fails + 1
    } else {
        let _m73 = _r73.design.modules[0]
        // SSA versioned wires for `pick` — pre-fix these don't exist.
        let mut _t73_ssa_missing = 0
        let mut _t73_k = 0
        while _t73_k <= 4 {
            if rtlil_find_wire(_m73, "pick__ssa" + str(_t73_k)) < 0 {
                _t73_ssa_missing = _t73_ssa_missing + 1
            }
            _t73_k = _t73_k + 1
        }
        if _t73_ssa_missing > 0 {
            println("FAIL T73a pick__ssa<k> missing count = "
                + str(_t73_ssa_missing) + " (expected 0 — 5 versions ssa0..ssa4)")
            fails = fails + 1
        }
        // Final publish: connect(pick, pick__ssa4) — Module uses
        // parallel arrays connect_lhs/connect_rhs/connect_cond.
        let mut _t73_publish = 0
        let mut _t73_ci = 0
        while _t73_ci < len(_m73.connect_lhs) {
            if _m73.connect_lhs[_t73_ci] == "pick"
                && _m73.connect_rhs[_t73_ci] == "pick__ssa4"
                && len(_m73.connect_cond[_t73_ci]) == 0 {
                _t73_publish = 1
            }
            _t73_ci = _t73_ci + 1
        }
        if _t73_publish != 1 {
            println("FAIL T73b missing final publish connect(pick, pick__ssa4)")
            fails = fails + 1
        }
    }

    if fails > 0 {
        println("read_verilog selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("read_verilog selftest: " + str(total) + "/" + str(total) + " PASS")
}
