#!hexa strict
// stdlib/yosys/read_verilog.hexa — Verilog-2005 → RTLIL frontend (CLEAN-ROOM)
//
// @version 0.0.1
// @capabilities [frontend, verilog, parse, rtlil-emit]
// @stability phase-a (rfc_006 §4 module-2 of 7 — minimum synthesizable
//   subset for gate §5 router_d{4,6}.v body; behavioral always-blocks
//   and generate-for are honest gaps documented below)
// @since 2026-05-19
//
// CLEAN-ROOM PROVENANCE (design.md Decision 1 — public-surface clean-room)
//   This module re-derives the *public surface* of Yosys' Verilog
//   frontend (synthesizable subset only) by inspection of upstream +
//   IEEE 1364-2005 / 1800-2017 standard wording. No upstream code is
//   copied.
//
//   - upstream code     : frontends/verilog/verilog_lexer.l
//                         frontends/verilog/verilog_parser.y
//                         frontends/verilog/preproc.cc
//                         frontends/verilog/genrtlil.cc
//   - upstream manual   : https://yosyshq.readthedocs.io/projects/yosys/
//                          en/latest/yosys_internals/extending_yosys/
//                          extensions.html
//   - upstream license  : ISC (YosysHQ; LICENSE)
//   - upstream repo     : https://github.com/YosysHQ/yosys
//   - IEEE refs (norm)  : IEEE Std 1364-2005 §3-13 (lexical + grammar;
//                          used only as standardized language reference)
//   - absorbed substrate (D18) : none
//
// rfc_006 §4: module-2 of 7. Consumes Verilog text, emits an rtlil.Design.
//
// SCOPE (this phase-a body — honest):
//   - module … endmodule with input/output port declarations
//   - wire declarations (1-bit; widths recorded but treated as 1)
//   - simple `assign lhs = rhs;` continuous assignments (single-op only:
//     a & b, a | b, ~a, a ^ b, or bare wire reference / 1'b0 / 1'b1)
//   - line comments (//) and block comments (/* */)
//
// NOT in scope (honest, documented gaps — gate §5 router_d{4,6}.v
// requires more than this; this phase-a body deliberately stops at a
// reviewable subset and reports unsupported constructs fail-loud):
//   - always @(*) / always @(posedge clk) blocks
//   - case/casez/casex statements
//   - generate-for loops
//   - parameters / `define preprocessing
//   - multi-bit literals (16'h1234), arithmetic operators, $signed
//   - instance bindings (m_inst u (.a(a), .b(b)))
//
// Gate-§5 path: enlarge the subset under the same idiom (each new
// construct = one new fn, one new self-test, fail-loud on unsupported).
//
// RFC 073 — read_verilog procedural-mux scope expansion (Shape-B,
// OPENER landed 2026-05-20 — see inbox/rfc_drafts_2026_05_20/
// rfc_073_read_verilog_proc_mux.md). Three-phase plan for §5
// absorption-gate closure: phase-1 `pass_proc_mux` skeleton for
// if/else cond-mux + nested chains; phase-1.5 `case` statement
// lowering; phase-2 array-indexed runtime-K assignment; phase-3
// router_d{4,6} re-target + ±5% area-oracle measurement (or honest
// mismatch report). This opener cycle ships SCAFFOLD ONLY — zero
// behaviour change. See SCAFFOLD markers in `_rv_parse_always` and
// `_rv_parse_assign`, plus the no-op `pass_proc_mux` stub.

use "stdlib/kernels/logic_synth/rtlil"
use "stdlib/kernels/logic_synth/passes"

// ─── parse result ────────────────────────────────────────────────────────

struct ReadVerilogResult {
    ok:      int,      // 1 = parsed; 0 = error
    design:  Design,
    message: str,
}

// ─── private tokenization ────────────────────────────────────────────────

// CLEAN-ROOM: strip // line comments and /* */ block comments
// (re-derived from IEEE 1364-2005 §3.4 white-space / comments).
fn _rv_strip_comments(src: str) -> str {
    let n = len(src)
    let mut out = ""
    let mut i = 0
    let mut in_block = 0
    let mut in_line = 0
    while i < n {
        let c = src.substring(i, i + 1)
        if in_block == 1 {
            if i + 1 < n {
                let two = src.substring(i, i + 2)
                if two == "*/" {
                    in_block = 0
                    i = i + 2
                } else {
                    i = i + 1
                }
            } else {
                i = i + 1
            }
        } else {
            if in_line == 1 {
                if c == "\n" {
                    in_line = 0
                    out = out + "\n"
                }
                i = i + 1
            } else {
                if i + 1 < n {
                    let two = src.substring(i, i + 2)
                    if two == "//" {
                        in_line = 1
                        i = i + 2
                    } else {
                        if two == "/*" {
                            in_block = 1
                            i = i + 2
                        } else {
                            out = out + c
                            i = i + 1
                        }
                    }
                } else {
                    out = out + c
                    i = i + 1
                }
            }
        }
    }
    return out
}

// CLEAN-ROOM: replace punctuation/symbol chars with spaces so a simple
// whitespace split yields token stream (IEEE 1364-2005 §3.5).
fn _rv_normalize_punct(s: str) -> str {
    let punct = [";", ",", "(", ")", "[", "]", "{", "}", "=", "&", "|", "~", "^", "<", ">", "!", "+", "-", "*", "/", "%", ":", "@"]
    let mut out = s
    let mut i = 0
    while i < len(punct) {
        out = out.replace(punct[i], " " + punct[i] + " ")
        i = i + 1
    }
    return out
}

// CLEAN-ROOM: merge adjacent single-char tokens back into 2-char
// Verilog operators (== != <= >= && || << >>) that _rv_normalize_punct
// split apart (IEEE 1364-2005 §5.1 — these are single lexical tokens).
fn _rv_merge_ops(toks: [str]) -> [str] {
    let n = len(toks)
    let mut out: [str] = []
    let mut i = 0
    while i < n {
        if i + 1 < n {
            let two = toks[i] + toks[i + 1]
            if two == "==" || two == "!=" || two == "<=" || two == ">="
               || two == "&&" || two == "||" || two == "<<" || two == ">>"
               || two == "-:" || two == "+:" {
                out = out.push(two)
                i = i + 2
                continue
            }
        }
        out = out.push(toks[i])
        i = i + 1
    }
    return out
}

// CLEAN-ROOM: whitespace tokeniser + 2-char operator merge.
fn _rv_tokens(s: str) -> [str] {
    let raw = s.replace("\n", " ").replace("\t", " ").split(" ")
    let mut out: [str] = []
    let mut i = 0
    while i < len(raw) {
        let t = raw[i].trim()
        if len(t) > 0 { out = out.push(t) }
        i = i + 1
    }
    return _rv_merge_ops(out)
}

// ─── constant-expression evaluator (rfc_006 §4 module-2 scope, D68) ──────
//
// CLEAN-ROOM: Verilog-2005 §5 constant expressions — the integer-valued
// subset needed to elaborate parameter/localparam, [hi:lo] wire ranges,
// generate-for bounds, and replication counts. Re-derived from IEEE
// 1364-2005 §5.1 operator precedence; no upstream code copied.
//
// Scope: integer arithmetic only (parameters/widths are integers). The
// evaluator does NOT model bit-width or X/Z — those belong to RTLIL
// elaboration, not constant folding.

// Parameter/localparam symbol table — parallel name/value arrays
// (booksim stdlib idiom; no map type in this stdlib layer).
struct SymTab {
    names:  [str],
    values: [int],
}

fn symtab_new() -> SymTab {
    return SymTab { names: [], values: [] }
}

fn symtab_put(s: SymTab, name: str, value: int) -> SymTab {
    // update in place if `name` is already present (genvar update in
    // generate-for unroll); otherwise append.
    let mut i = 0
    while i < len(s.names) {
        if s.names[i] == name {
            let mut newvals: [int] = []
            let mut k = 0
            while k < len(s.values) {
                if k == i {
                    newvals = newvals.push(value)
                } else {
                    newvals = newvals.push(s.values[k])
                }
                k = k + 1
            }
            return SymTab { names: s.names, values: newvals }
        }
        i = i + 1
    }
    return SymTab { names: s.names.push(name), values: s.values.push(value) }
}

fn symtab_has(s: SymTab, name: str) -> int {
    let mut i = 0
    while i < len(s.names) {
        if s.names[i] == name { return 1 }
        i = i + 1
    }
    return 0
}

fn symtab_get(s: SymTab, name: str) -> int {
    let mut i = 0
    while i < len(s.names) {
        if s.names[i] == name { return s.values[i] }
        i = i + 1
    }
    return 0
}

// Result of evaluating a constant (sub)expression: the integer value,
// the token index just past what was consumed, and an error string
// (empty = ok). No tuples in this toolchain — struct return.
struct ConstEval {
    value: int,
    pos:   int,
    err:   str,
}

// CLEAN-ROOM: single hex/dec digit → value, or -1 if not a digit.
fn _rv_digit(c: str, base: int) -> int {
    let mut v = 0 - 1
    if c == "0" { v = 0 }
    if c == "1" { v = 1 }
    if c == "2" { v = 2 }
    if c == "3" { v = 3 }
    if c == "4" { v = 4 }
    if c == "5" { v = 5 }
    if c == "6" { v = 6 }
    if c == "7" { v = 7 }
    if c == "8" { v = 8 }
    if c == "9" { v = 9 }
    if base == 16 {
        if c == "a" { v = 10 }
        if c == "b" { v = 11 }
        if c == "c" { v = 12 }
        if c == "d" { v = 13 }
        if c == "e" { v = 14 }
        if c == "f" { v = 15 }
        if c == "A" { v = 10 }
        if c == "B" { v = 11 }
        if c == "C" { v = 12 }
        if c == "D" { v = 13 }
        if c == "E" { v = 14 }
        if c == "F" { v = 15 }
    }
    if v >= base { return 0 - 1 }
    return v
}

// CLEAN-ROOM: parse a digit run `s[from:]` in `base`, ignoring `_`
// (Verilog 1364-2005 §3.5.1 allows underscores in numbers). Returns
// the accumulated value; stops at the first non-digit.
fn _rv_parse_digits(s: str, from: int, base: int) -> int {
    let n = len(s)
    let mut acc = 0
    let mut i = from
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "_" { i = i + 1; continue }
        let d = _rv_digit(c, base)
        if d < 0 { return acc }
        acc = acc * base + d
        i = i + 1
    }
    return acc
}

// CLEAN-ROOM: integer value of a single Verilog number token.
//   `64`        → 64           (unsized decimal)
//   `3'd2`      → 2            (sized decimal — size ignored for folding)
//   `8'hff`     → 255          (sized hex)
//   `4'b1010`   → 10           (sized binary)
//   `1'b0`      → 0
// Returns -1 on a token that is not a number literal.
fn _rv_literal_value(tok: str) -> int {
    let n = len(tok)
    if n == 0 { return 0 - 1 }
    // find a `'` (sized literal marker)
    let mut tick = 0 - 1
    let mut i = 0
    while i < n {
        if tok.substring(i, i + 1) == "'" { tick = i }
        i = i + 1
    }
    if tick < 0 {
        // unsized decimal — must be all digits
        if _rv_digit(tok.substring(0, 1), 10) < 0 { return 0 - 1 }
        return _rv_parse_digits(tok, 0, 10)
    }
    // sized: <size>'<base><digits> ; base char follows the tick
    if tick + 1 >= n { return 0 - 1 }
    let basec = tok.substring(tick + 1, tick + 2)
    let mut base = 10
    let mut dstart = tick + 2
    if basec == "d" { base = 10 }
    if basec == "h" { base = 16 }
    if basec == "b" { base = 2 }
    if basec == "o" { base = 8 }
    if basec == "D" { base = 10 }
    if basec == "H" { base = 16 }
    if basec == "B" { base = 2 }
    if basec == "O" { base = 8 }
    return _rv_parse_digits(tok, dstart, base)
}

// CLEAN-ROOM: binary-operator precedence (IEEE 1364-2005 §5.1.2).
// Higher number = binds tighter. 0 = not a binary operator.
fn _rv_binop_prec(op: str) -> int {
    if op == "||" { return 1 }
    if op == "&&" { return 2 }
    if op == "|"  { return 3 }
    if op == "^"  { return 4 }
    if op == "&"  { return 5 }
    if op == "==" { return 6 }
    if op == "!=" { return 6 }
    if op == "<"  { return 7 }
    if op == ">"  { return 7 }
    if op == "<=" { return 7 }
    if op == ">=" { return 7 }
    if op == "<<" { return 8 }
    if op == ">>" { return 8 }
    if op == "+"  { return 9 }
    if op == "-"  { return 9 }
    if op == "*"  { return 10 }
    if op == "/"  { return 10 }
    if op == "%"  { return 10 }
    return 0
}

// CLEAN-ROOM: apply a binary operator to two folded integer operands.
fn _rv_apply_binop(op: str, a: int, b: int) -> int {
    if op == "||" { if a != 0 { return 1 } if b != 0 { return 1 } return 0 }
    if op == "&&" { if a != 0 { if b != 0 { return 1 } } return 0 }
    if op == "|"  { return a | b }
    if op == "^"  { return a ^ b }
    if op == "&"  { return a & b }
    if op == "==" { if a == b { return 1 } return 0 }
    if op == "!=" { if a != b { return 1 } return 0 }
    if op == "<"  { if a < b  { return 1 } return 0 }
    if op == ">"  { if a > b  { return 1 } return 0 }
    if op == "<=" { if a <= b { return 1 } return 0 }
    if op == ">=" { if a >= b { return 1 } return 0 }
    if op == "<<" { return a << b }
    if op == ">>" { return a >> b }
    if op == "+"  { return a + b }
    if op == "-"  { return a - b }
    if op == "*"  { return a * b }
    if op == "/"  { if b == 0 { return 0 } return a / b }
    if op == "%"  { if b == 0 { return 0 } return a % b }
    return 0
}

// CLEAN-ROOM: evaluate a primary — literal, identifier (looked up in
// `tab`), parenthesised expression, or unary `-` / `~` / `!`.
fn _rv_eval_primary(toks: [str], pos: int, tab: SymTab) -> ConstEval {
    let n = len(toks)
    if pos >= n {
        return ConstEval { value: 0, pos: pos, err: "const-expr: unexpected end" }
    }
    let t = toks[pos]
    // unary operators
    if t == "-" {
        let inner = _rv_eval_primary(toks, pos + 1, tab)
        if len(inner.err) > 0 { return inner }
        return ConstEval { value: 0 - inner.value, pos: inner.pos, err: "" }
    }
    if t == "~" {
        let inner = _rv_eval_primary(toks, pos + 1, tab)
        if len(inner.err) > 0 { return inner }
        return ConstEval { value: 0 - inner.value - 1, pos: inner.pos, err: "" }
    }
    if t == "!" {
        let inner = _rv_eval_primary(toks, pos + 1, tab)
        if len(inner.err) > 0 { return inner }
        let mut v = 1
        if inner.value != 0 { v = 0 }
        return ConstEval { value: v, pos: inner.pos, err: "" }
    }
    // parenthesised
    if t == "(" {
        let inner = _rv_eval_expr(toks, pos + 1, tab, 1)
        if len(inner.err) > 0 { return inner }
        if inner.pos >= n {
            return ConstEval { value: 0, pos: inner.pos, err: "const-expr: missing `)`" }
        }
        if toks[inner.pos] != ")" {
            return ConstEval { value: 0, pos: inner.pos,
                err: "const-expr: expected `)` got `" + toks[inner.pos] + "`" }
        }
        return ConstEval { value: inner.value, pos: inner.pos + 1, err: "" }
    }
    // numeric literal
    let lit = _rv_literal_value(t)
    if lit >= 0 {
        return ConstEval { value: lit, pos: pos + 1, err: "" }
    }
    // identifier — must resolve in the symbol table
    if symtab_has(tab, t) == 1 {
        return ConstEval { value: symtab_get(tab, t), pos: pos + 1, err: "" }
    }
    return ConstEval { value: 0, pos: pos,
        err: "const-expr: unresolved `" + t + "` (not a literal or known parameter)" }
}

// CLEAN-ROOM: precedence-climbing constant-expression evaluator.
// Evaluates from `pos` while the next binary operator's precedence is
// >= `min_prec`; returns the folded value + the index just past the
// last consumed token. (IEEE 1364-2005 §5.1.2 — left-associative.)
fn _rv_eval_expr(toks: [str], pos: int, tab: SymTab, min_prec: int) -> ConstEval {
    let lhs = _rv_eval_primary(toks, pos, tab)
    if len(lhs.err) > 0 { return lhs }
    let mut acc = lhs.value
    let mut i = lhs.pos
    let n = len(toks)
    while i < n {
        let op = toks[i]
        let prec = _rv_binop_prec(op)
        if prec == 0 { return ConstEval { value: acc, pos: i, err: "" } }
        if prec < min_prec { return ConstEval { value: acc, pos: i, err: "" } }
        let rhs = _rv_eval_expr(toks, i + 1, tab, prec + 1)
        if len(rhs.err) > 0 { return rhs }
        acc = _rv_apply_binop(op, acc, rhs.value)
        i = rhs.pos
    }
    return ConstEval { value: acc, pos: i, err: "" }
}

// ─── private parsers ─────────────────────────────────────────────────────

// Track parse cursor in a struct (no tuples).
struct PState {
    toks: [str],
    pos:  int,
    err:  str,
}

fn _ps_peek(st: PState) -> str {
    if st.pos < len(st.toks) { return st.toks[st.pos] }
    return ""
}

fn _ps_take(st: PState) -> PState {
    return PState { toks: st.toks, pos: st.pos + 1, err: st.err }
}

fn _ps_fail(st: PState, msg: str) -> PState {
    return PState { toks: st.toks, pos: st.pos, err: msg }
}

// CLEAN-ROOM: top-level driver — parse one or more `module … endmodule`
// blocks. (IEEE 1364-2005 §12 module declarations.)
fn read_verilog(src: str) -> ReadVerilogResult {
    let cleaned = _rv_strip_comments(src)
    let normalized = _rv_normalize_punct(cleaned)
    let toks = _rv_tokens(normalized)
    let mut st = PState { toks: toks, pos: 0, err: "" }
    let mut d = rtlil_new_design("read_verilog")
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == "module" {
            st = _ps_take(st)
            // expect identifier
            let name = _ps_peek(st)
            if name == "" {
                return ReadVerilogResult {
                    ok: 0, design: d,
                    message: "read_verilog: EOF after `module`"
                }
            }
            st = _ps_take(st)
            let mut m = rtlil_new_module(name)
            let mut tab = symtab_new()
            let mut funcs: [VFunc] = []
            let mut inlined = 0
            // optional `#( parameter NAME = EXPR , … )` header
            if _ps_peek(st) == "#" {
                let ph = _rv_parse_param_header(st, tab)
                st = ph.st; tab = ph.tab
                if len(st.err) > 0 {
                    return ReadVerilogResult { ok: 0, design: d, message: st.err }
                }
            }
            // ANSI-style port list — `(` immediately followed by a
            // direction keyword. Parse it; non-ANSI falls through to the
            // skip-until-`;` path (ports re-declared in the body).
            if _ps_peek(st) == "(" {
                let mut is_ansi = 0
                if st.pos + 1 < len(st.toks) {
                    let n1 = st.toks[st.pos + 1]
                    if n1 == "input"  { is_ansi = 1 }
                    if n1 == "output" { is_ansi = 1 }
                    if n1 == "inout"  { is_ansi = 1 }
                }
                if is_ansi == 1 {
                    let pr = _rv_parse_ansi_ports(st, m, tab)
                    st = pr.st; m = pr.m
                    if len(st.err) > 0 {
                        return ReadVerilogResult { ok: 0, design: d, message: st.err }
                    }
                }
            }
            // optional (port-list); skip until ; or endmodule
            // consume until ';' to finish the module header
            while st.pos < len(st.toks) {
                if _ps_peek(st) == ";" {
                    st = _ps_take(st); break
                }
                if _ps_peek(st) == "endmodule" { break }
                st = _ps_take(st)
            }
            // module body
            while st.pos < len(st.toks) {
                let bt = _ps_peek(st)
                if bt == "endmodule" {
                    st = _ps_take(st); break
                }
                // proc-pass core sub-step #4c (multi-day work, partial):
                // once at least one function is collected and we're past
                // the function decl region, rewrite the remaining tokens
                // by inlining single-stmt return-expr function calls.
                if inlined == 0 && len(funcs) > 0 && bt != "function" {
                    let mut rest: [str] = []
                    let mut ri = st.pos
                    while ri < len(st.toks) {
                        rest = rest.push(st.toks[ri])
                        ri = ri + 1
                    }
                    let pp = _rv_inline_func_calls(rest, funcs)
                    st = PState { toks: pp, pos: 0, err: st.err }
                    inlined = 1
                    continue
                }
                // wire / input / output / inout declarations
                if bt == "input" {
                    let r1 = _rv_parse_port_decl(st, m, 1, tab)
                    st = r1.st; m = r1.m
                } else {
                    if bt == "output" {
                        let r2 = _rv_parse_port_decl(st, m, 2, tab)
                        st = r2.st; m = r2.m
                    } else {
                        if bt == "inout" {
                            let r3 = _rv_parse_port_decl(st, m, 3, tab)
                            st = r3.st; m = r3.m
                        } else {
                            if bt == "wire" || bt == "reg" || bt == "integer" {
                                let r4 = _rv_parse_port_decl(st, m, 0, tab)
                                st = r4.st; m = r4.m
                            } else {
                                if bt == "assign" {
                                    let r5 = _rv_parse_assign(st, m, tab)
                                    st = r5.st; m = r5.m
                                    if len(st.err) > 0 {
                                        return ReadVerilogResult {
                                            ok: 0, design: d, message: st.err
                                        }
                                    }
                                } else {
                                    if bt == "localparam" || bt == "parameter" {
                                        let rl = _rv_parse_localparam(st, tab)
                                        st = rl.st; tab = rl.tab
                                        if len(st.err) > 0 {
                                            return ReadVerilogResult {
                                                ok: 0, design: d, message: st.err
                                            }
                                        }
                                    } else {
                                        if bt == "function" {
                                            let rf = _rv_parse_function(st)
                                            st = rf.st
                                            if len(rf.err) > 0 {
                                                return ReadVerilogResult {
                                                    ok: 0, design: d, message: rf.err
                                                }
                                            }
                                            funcs = funcs.push(rf.func)
                                        } else {
                                            if bt == "generate" {
                                                let rg = _rv_parse_generate(st, m, tab)
                                                st = rg.st
                                                m = rg.m
                                                tab = rg.tab
                                                if len(st.err) > 0 {
                                                    return ReadVerilogResult {
                                                        ok: 0, design: d, message: st.err
                                                    }
                                                }
                                            } else {
                                                if bt == "always" {
                                                    let ra = _rv_parse_always(st, m, tab)
                                                    st = ra.st
                                                    m = ra.m
                                                    if len(st.err) > 0 {
                                                        return ReadVerilogResult {
                                                            ok: 0, design: d, message: st.err
                                                        }
                                                    }
                                                } else {
                                                    if bt == "genvar" || bt == "initial" {
                                                    // `genvar NAME ;` — declaration only, value
                                                    // is set inside the generate-for init.
                                                    while st.pos < len(st.toks) {
                                                        if _ps_peek(st) == ";" {
                                                            st = _ps_take(st); break
                                                        }
                                                        st = _ps_take(st)
                                                    }
                                                } else {
                                                    return ReadVerilogResult {
                                                        ok: 0, design: d,
                                                        message: "read_verilog: unsupported construct `"
                                                            + bt + "` (synth-subset only — see rfc_006 §4 module-2 scope)"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            }
            d = rtlil_design_add(d, m)
        } else {
            st = _ps_take(st)
        }
    }
    return ReadVerilogResult { ok: 1, design: d, message: "" }
}

// Helper result struct so parse-step fns can return both st + m.
struct RvStep {
    st: PState,
    m:  Module,
}

// CLEAN-ROOM: parse `(input|output|inout|wire) name1, name2 … ;`
// dir_kind: 0=internal-wire · 1=input · 2=output · 3=inout
fn _rv_parse_port_decl(st_in: PState, m_in: Module, dir_kind: int, tab: SymTab) -> RvStep {
    let mut st = _ps_take(st_in)            // consume the keyword
    let mut m = m_in
    // optional net-type / signedness tail of an ANSI body declaration
    // (`input wire`, `output reg`, `input signed [hi:lo]` …) — skip.
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == "wire" || t == "reg" || t == "logic" || t == "signed" {
            st = _ps_take(st); continue
        }
        break
    }
    // optional packed bit-range `[hi:lo]` → width, folded against `tab`.
    let mut width = 1
    if _ps_peek(st) == "[" {
        let rg = _rv_parse_range(st, tab)
        if len(rg.err) > 0 { return RvStep { st: _ps_fail(st, rg.err), m: m } }
        width = rg.width
        st = rg.st
    }
    // name list — each may carry an optional 1-D unpacked range that
    // expands to one wire per index (`q [ 0 : 3 ]` → q[0]..q[3]).
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ";" { st = _ps_take(st); break }
        if t == "," { st = _ps_take(st); continue }
        // identifier
        let nm = t
        st = _ps_take(st)
        if _ps_peek(st) == "[" {
            let ur = _rv_parse_range(st, tab)
            if len(ur.err) > 0 { return RvStep { st: _ps_fail(st, ur.err), m: m } }
            st = ur.st
            let mut k = 0
            while k < ur.width {
                let wn = nm + "[" + str(k) + "]"
                let mut pid = 0
                if dir_kind > 0 { pid = len(m.wires) + 1 }
                m = rtlil_module_add_wire(m, rtlil_wire(wn, width, dir_kind, pid))
                k = k + 1
            }
        } else {
            let mut pid = 0
            if dir_kind > 0 { pid = len(m.wires) + 1 }
            m = rtlil_module_add_wire(m, rtlil_wire(nm, width, dir_kind, pid))
        }
    }
    return RvStep { st: st, m: m }
}

// CLEAN-ROOM: parse `assign lhs = rhs;` with a single binary/unary op.
//   `assign y = a & b ;`  →  $and cell
//   `assign y = a | b ;`  →  $or cell
//   `assign y = a ^ b ;`  →  $xor cell
//   `assign y = ~ a ;`    →  $not cell
//   `assign y = a ;`      →  RTLIL ::connect (wire-to-wire)
//   `assign y = 1'b0 ;`   →  RTLIL ::connect to a constant (treated as
//                             a tie to a special wire "$const_0"/"$const_1"
//                             which the passes pipeline will lift)
// ─── expression elaboration → RTLIL cell tree (rfc_006 §4 m2, D68) ───────
//
// CLEAN-ROOM: lower a Verilog expression to a tree of RTLIL cells (IEEE
// 1364-2005 §5 / Yosys genrtlil.cc public surface). Each binary operator
// becomes one generic RTLIL cell ($add/$and/$eq/…) whose Y output is a
// fresh internal wire; the wire carrying the whole expression's result
// is returned. Wire widths are recorded as 1 here — a follow-up pass
// elaborates real widths; the generic cells are width-tolerant.

struct ElabResult {
    wire: str,
    m:    Module,
    pos:  int,
    err:  str,
}

// CLEAN-ROOM: binary operator → RTLIL generic cell type (empty = none).
fn _rv_binop_cell(op: str) -> str {
    if op == "+"  { return "$add" }
    if op == "-"  { return "$sub" }
    if op == "*"  { return "$mul" }
    if op == "/"  { return "$div" }
    if op == "%"  { return "$mod" }
    if op == "&"  { return "$and" }
    if op == "|"  { return "$or" }
    if op == "^"  { return "$xor" }
    if op == "==" { return "$eq" }
    if op == "!=" { return "$ne" }
    if op == "<"  { return "$lt" }
    if op == ">"  { return "$gt" }
    if op == "<=" { return "$le" }
    if op == ">=" { return "$ge" }
    if op == "<<" { return "$shl" }
    if op == ">>" { return "$shr" }
    if op == "&&" { return "$logic_and" }
    if op == "||" { return "$logic_or" }
    return ""
}

// CLEAN-ROOM: a fresh internal result-wire name, unique per cell count.
fn _rv_fresh_wire(m: Module) -> str {
    return "$rvexpr$" + str(len(m.cells))
}

// CLEAN-ROOM: elaborate a primary — wire reference, 1'b0/1'b1 constant,
// parenthesised expression, or unary `~` / `!`.
fn _rv_elab_primary(toks: [str], pos: int, m_in: Module, tab: SymTab) -> ElabResult {
    let n = len(toks)
    let mut m = m_in
    if pos >= n {
        return ElabResult {
            wire: "", m: m, pos: pos, err: "read_verilog: expr: unexpected end"
        }
    }
    let t = toks[pos]
    if t == "~" || t == "!" || t == "-" {
        let inner = _rv_elab_primary(toks, pos + 1, m, tab)
        if len(inner.err) > 0 { return inner }
        m = inner.m
        let wn = _rv_fresh_wire(m)
        m = rtlil_module_add_wire(m, rtlil_wire(wn, 1, 0, 0))
        let mut cty = "$not"
        if t == "!" { cty = "$logic_not" }
        if t == "-" { cty = "$neg" }
        let mut c = rtlil_cell(wn + "$c", cty, 0)
        c = rtlil_cell_connect(c, "A", inner.wire)
        c = rtlil_cell_connect(c, "Y", wn)
        m = rtlil_module_add_cell(m, c)
        return ElabResult { wire: wn, m: m, pos: inner.pos, err: "" }
    }
    if t == "(" {
        let inner = _rv_elab_expr(toks, pos + 1, m, 1, tab)
        if len(inner.err) > 0 { return inner }
        m = inner.m
        if inner.pos >= n {
            return ElabResult {
                wire: "", m: m, pos: inner.pos, err: "read_verilog: expr: missing `)`"
            }
        }
        if toks[inner.pos] != ")" {
            return ElabResult {
                wire: "", m: m, pos: inner.pos,
                err: "read_verilog: expr: expected `)` got `" + toks[inner.pos] + "`"
            }
        }
        return ElabResult { wire: inner.wire, m: m, pos: inner.pos + 1, err: "" }
    }
    if t == "1'b0" { return ElabResult { wire: "$const_0", m: m, pos: pos + 1, err: "" } }
    if t == "1'b1" { return ElabResult { wire: "$const_1", m: m, pos: pos + 1, err: "" } }
    // RFC 073 Phase 3e — generic sized-literal handling. Any Verilog
    // `<size>'<base><digits>` (e.g. `3'd0`, `8'hFF`, `4'b1010`) folds
    // to `$const_<value>`. Without this, untyped literals fell through
    // to the bare-wire path, leaving raw Verilog tokens like `3'd0`
    // in the BLIF as wire names — which ABC then rejected. The
    // `_rv_literal_value` helper handles all four bases (d/h/b/o,
    // upper + lower case) per IEEE 1364-2005 §3.5.1. @cite IEEE
    // 1364-2005 §3.5.1 (integer numbers).
    if t.find("'") >= 0 {
        let lv = _rv_literal_value(t)
        if lv >= 0 {
            let cn = "$const_" + str(lv)
            if rtlil_find_wire(m, cn) < 0 {
                m = rtlil_module_add_wire(m, rtlil_wire(cn, 1, 0, 0))
            }
            return ElabResult { wire: cn, m: m, pos: pos + 1, err: "" }
        }
    }
    // Fold a bare localparam/parameter identifier into a synthesized
    // `$const_<N>` wire (IEEE 1364-2005 §5.1.1 — a parameter reference
    // in an expression is replaced by its constant value). Required so
    // downstream lowerings (`passes::lower_mod`, future $add/$sub
    // const-foldings) see an integer divisor on a B-pin instead of the
    // localparam *name*. rfc_006 §5 absorption iter 8: closes the
    // case-C→case-B transition for the lowering reported at
    // passes.hexa:1181 ("variable / unfoldable divisor B=`P`"). Scope:
    // non-negative values only — `$const_<N>` (passes.hexa:1098-1099)
    // accepts only decimal digits; negative parameter values keep the
    // wire-name fallback (honest gap, still case C). The substitution
    // happens only when the token is not followed by `[` — a parameter
    // name as an array index has already been folded into the wire
    // name by the index-eval branch below; here we handle the operand
    // position. (@cite IEEE 1364-2005 §5.1 constant-expression
    // operands.)
    if ((pos + 1 >= n) || (toks[pos + 1] != "[")) && (symtab_has(tab, t) == 1) {
        let pv = symtab_get(tab, t)
        if pv >= 0 {
            let cn = "$const_" + str(pv)
            // dedupe: only add the wire if not already present in the
            // module (multiple operands referencing the same value
            // share the wire — naming convention match).
            if rtlil_find_wire(m, cn) < 0 {
                m = rtlil_module_add_wire(m, rtlil_wire(cn, 1, 0, 0))
            }
            return ElabResult { wire: cn, m: m, pos: pos + 1, err: "" }
        }
    }
    // bare token = wire reference, optionally followed by one or more
    // `[ ... ]` index groups (unpacked-array element after generate-
    // unrolling, packed part-select, or chained 2-D access like
    // `mem[p][q]`). A foldable constant index appends `[<val>]` to the
    // wire name; range / non-foldable index is an honest gap — the
    // bracket group is consumed but the wire name is left unchanged
    // (rest of the expression still parses).
    let mut wn = t
    let mut cur = pos + 1
    while cur < n && toks[cur] == "[" {
        let mut idxtoks: [str] = []
        let mut np = cur + 1
        let mut depth = 1
        while np < n {
            let it = toks[np]
            if it == "[" {
                depth = depth + 1
                idxtoks = idxtoks.push(it)
                np = np + 1
                continue
            }
            if it == "]" {
                depth = depth - 1
                if depth == 0 { break }
                idxtoks = idxtoks.push(it)
                np = np + 1
                continue
            }
            idxtoks = idxtoks.push(it)
            np = np + 1
        }
        let mut isrange = 0
        let mut k = 0
        while k < len(idxtoks) {
            let tk = idxtoks[k]
            if tk == ":" || tk == "-:" || tk == "+:" { isrange = 1 }
            k = k + 1
        }
        if isrange == 0 {
            let ev = _rv_eval_expr(idxtoks, 0, tab, 1)
            if len(ev.err) == 0 {
                wn = wn + "[" + str(ev.value) + "]"
            }
        }
        cur = np + 1                        // past `]`
    }
    return ElabResult { wire: wn, m: m, pos: cur, err: "" }
}

// CLEAN-ROOM: precedence-climbing expression elaborator (left-assoc,
// IEEE 1364-2005 §5.1.2). Reuses _rv_binop_prec from the constant
// evaluator. Emits one RTLIL cell per binary operator.
fn _rv_elab_expr(toks: [str], pos: int, m_in: Module, min_prec: int, tab: SymTab) -> ElabResult {
    let lhs = _rv_elab_primary(toks, pos, m_in, tab)
    if len(lhs.err) > 0 { return lhs }
    let mut m = lhs.m
    let mut cur = lhs.wire
    let mut i = lhs.pos
    let n = len(toks)
    while i < n {
        let op = toks[i]
        let prec = _rv_binop_prec(op)
        if prec == 0 { break }
        if prec < min_prec { break }
        let cty = _rv_binop_cell(op)
        if cty == "" {
            return ElabResult {
                wire: cur, m: m, pos: i,
                err: "read_verilog: expr: operator `" + op + "` not in subset"
            }
        }
        let rhs = _rv_elab_expr(toks, i + 1, m, prec + 1, tab)
        if len(rhs.err) > 0 { return rhs }
        m = rhs.m
        let wn = _rv_fresh_wire(m)
        m = rtlil_module_add_wire(m, rtlil_wire(wn, 1, 0, 0))
        let mut c = rtlil_cell(wn + "$c", cty, 0)
        c = rtlil_cell_connect(c, "A", cur)
        c = rtlil_cell_connect(c, "B", rhs.wire)
        c = rtlil_cell_connect(c, "Y", wn)
        m = rtlil_module_add_cell(m, c)
        cur = wn
        i = rhs.pos
    }
    // CLEAN-ROOM: ternary `? :` (IEEE 1364-2005 §5.1.4, right-assoc,
    // lowest non-assignment precedence). Lowered to `\$mux(S=cond,
    // A=else, B=then, Y=mux_y)` — matches yosys-internal ternary
    // emission. Only fires at the lowest precedence call (min_prec<=1)
    // so it does not interfere with cell-tree ops above.
    if min_prec <= 1 && i < n {
        if toks[i] == "?" {
            let then_res = _rv_elab_expr(toks, i + 1, m, 1, tab)
            if len(then_res.err) > 0 { return then_res }
            m = then_res.m
            let cp = then_res.pos
            if cp >= n || toks[cp] != ":" {
                return ElabResult {
                    wire: cur, m: m, pos: cp,
                    err: "read_verilog: ternary: expected `:`"
                }
            }
            let else_res = _rv_elab_expr(toks, cp + 1, m, 1, tab)
            if len(else_res.err) > 0 { return else_res }
            m = else_res.m
            let mux_y = _rv_fresh_wire(m)
            m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
            let mut tc = rtlil_cell(mux_y + "$tc", "$mux", 0)
            tc = rtlil_cell_connect(tc, "A", else_res.wire)
            tc = rtlil_cell_connect(tc, "B", then_res.wire)
            tc = rtlil_cell_connect(tc, "S", cur)
            tc = rtlil_cell_connect(tc, "Y", mux_y)
            m = rtlil_module_add_cell(m, tc)
            cur = mux_y
            i = else_res.pos
        }
    }
    return ElabResult { wire: cur, m: m, pos: i, err: "" }
}

// CLEAN-ROOM: parse `assign LHS = EXPR ;`. EXPR is lowered to an RTLIL
// cell tree via _rv_elab_expr and its result wire connected to LHS.
fn _rv_parse_assign(st_in: PState, m_in: Module, tab: SymTab) -> RvStep {
    let mut st = _ps_take(st_in)            // consume "assign"
    let mut m = m_in
    if st.pos >= len(st.toks) {
        return RvStep { st: _ps_fail(st, "read_verilog: EOF after `assign`"), m: m }
    }
    let lhs_base = _ps_peek(st)
    st = _ps_take(st)
    let mut lhs = lhs_base
    // RFC 073 SCAFFOLD: array-indexed assign — phase-2 extends the
    // const-foldable `[<const>]` LHS form below to runtime-K (e.g.
    // `grant[i] = …` inside a `for (i=0; i<N; …)` loop) by emitting
    // a per-index `$eq`/`$mux` selector chain (N×$eq + N×$mux per
    // write site). Const-K stays on the existing single-`connect`
    // path (zero regression). No behaviour change this cycle.
    // optional `[ <const> ]` index on the LHS (unpacked array element
    // after generate-unrolling or pre-elaborated indexed wire).
    if _ps_peek(st) == "[" {
        st = _ps_take(st)
        let mut idxtoks: [str] = []
        let mut depth = 1
        while st.pos < len(st.toks) {
            let it = _ps_peek(st)
            if it == "[" {
                depth = depth + 1
                idxtoks = idxtoks.push(it)
                st = _ps_take(st)
                continue
            }
            if it == "]" {
                depth = depth - 1
                if depth == 0 { st = _ps_take(st); break }
                idxtoks = idxtoks.push(it)
                st = _ps_take(st)
                continue
            }
            idxtoks = idxtoks.push(it)
            st = _ps_take(st)
        }
        let ev = _rv_eval_expr(idxtoks, 0, tab, 1)
        if len(ev.err) == 0 {
            lhs = lhs_base + "[" + str(ev.value) + "]"
        }
    }
    if _ps_peek(st) != "=" {
        return RvStep {
            st: _ps_fail(st, "read_verilog: assign missing `=` (got `" + _ps_peek(st) + "`)"),
            m: m
        }
    }
    st = _ps_take(st)
    // collect RHS tokens up to `;`
    let mut rhs: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ";" { st = _ps_take(st); break }
        rhs = rhs.push(t)
        st = _ps_take(st)
    }
    let er = _rv_elab_expr(rhs, 0, m, 1, tab)
    if len(er.err) > 0 {
        return RvStep { st: _ps_fail(st, er.err), m: m }
    }
    m = er.m
    m = rtlil_module_connect(m, lhs, er.wire)
    return RvStep { st: st, m: m }
}

// ─── parameter / localparam declaration parsing (rfc_006 §4 m2, D68) ─────

// Parse-step result carrying the cursor + the updated symbol table.
struct RvParamStep {
    st:  PState,
    tab: SymTab,
}

// CLEAN-ROOM: skip optional declaration type keywords / range before a
// parameter or localparam name — `integer`, `signed`, `[hi:lo]`
// (IEEE 1364-2005 §4.10 — type is irrelevant to integer constant folding).
fn _rv_skip_decl_type(st_in: PState) -> PState {
    let mut st = st_in
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == "integer" { st = _ps_take(st); continue }
        if t == "signed"  { st = _ps_take(st); continue }
        if t == "[" {
            while st.pos < len(st.toks) {
                if _ps_peek(st) == "]" { st = _ps_take(st); break }
                st = _ps_take(st)
            }
            continue
        }
        break
    }
    return st
}

// CLEAN-ROOM: parse a module-header parameter list `#( parameter NAME =
// EXPR , … )` (ANSI-style, IEEE 1364-2005 §12.1). `st` points at `#`.
// Each EXPR is folded against `tab` (so a later parameter can reference
// an earlier one) and the result is added to the table.
fn _rv_parse_param_header(st_in: PState, tab_in: SymTab) -> RvParamStep {
    let mut st = st_in
    let mut tab = tab_in
    st = _ps_take(st)                       // consume "#"
    if _ps_peek(st) != "(" {
        return RvParamStep {
            st: _ps_fail(st, "read_verilog: param header: expected `(` after `#`"),
            tab: tab
        }
    }
    st = _ps_take(st)                       // consume "("
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ")" { st = _ps_take(st); break }
        if t == "," { st = _ps_take(st); continue }
        if t == "parameter" { st = _ps_take(st); continue }
        st = _rv_skip_decl_type(st)
        let name = _ps_peek(st)
        if name == "" || name == ")" {
            return RvParamStep {
                st: _ps_fail(st, "read_verilog: param header: expected parameter name"),
                tab: tab
            }
        }
        st = _ps_take(st)
        if _ps_peek(st) != "=" {
            return RvParamStep {
                st: _ps_fail(st, "read_verilog: param `" + name + "`: expected `=`"),
                tab: tab
            }
        }
        st = _ps_take(st)
        // collect expression tokens until `,` or `)`
        let mut exprtoks: [str] = []
        while st.pos < len(st.toks) {
            let tk = _ps_peek(st)
            if tk == "," { break }
            if tk == ")" { break }
            exprtoks = exprtoks.push(tk)
            st = _ps_take(st)
        }
        let ev = _rv_eval_expr(exprtoks, 0, tab, 1)
        if len(ev.err) > 0 {
            return RvParamStep {
                st: _ps_fail(st, "read_verilog: param `" + name + "`: " + ev.err),
                tab: tab
            }
        }
        tab = symtab_put(tab, name, ev.value)
    }
    return RvParamStep { st: st, tab: tab }
}

// CLEAN-ROOM: parse a body `localparam NAME = EXPR ;` (IEEE 1364-2005
// §4.10.1). `st` points at `localparam`. EXPR is folded against `tab`.
fn _rv_parse_localparam(st_in: PState, tab_in: SymTab) -> RvParamStep {
    let mut st = _ps_take(st_in)            // consume "localparam"
    let mut tab = tab_in
    st = _rv_skip_decl_type(st)
    let name = _ps_peek(st)
    if name == "" {
        return RvParamStep {
            st: _ps_fail(st, "read_verilog: localparam: expected name"),
            tab: tab
        }
    }
    st = _ps_take(st)
    if _ps_peek(st) != "=" {
        return RvParamStep {
            st: _ps_fail(st, "read_verilog: localparam `" + name + "`: expected `=`"),
            tab: tab
        }
    }
    st = _ps_take(st)
    let mut exprtoks: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ";" { st = _ps_take(st); break }
        exprtoks = exprtoks.push(t)
        st = _ps_take(st)
    }
    let ev = _rv_eval_expr(exprtoks, 0, tab, 1)
    if len(ev.err) > 0 {
        return RvParamStep {
            st: _ps_fail(st, "read_verilog: localparam `" + name + "`: " + ev.err),
            tab: tab
        }
    }
    tab = symtab_put(tab, name, ev.value)
    return RvParamStep { st: st, tab: tab }
}

// ─── width elaboration + ANSI-style port parsing (rfc_006 §4 m2, D68) ────

// Result of parsing a `[ HI : LO ]` range — the elaborated extent plus
// the cursor just past `]`.
struct RangeEval {
    width: int,         // HI - LO + 1 (always positive)
    st:    PState,
    err:   str,
}

// CLEAN-ROOM: parse a bracketed range `[ HI : LO ]`, folding HI and LO
// against `tab`. Used for both packed bit-ranges (width) and unpacked
// 1-D array ranges (element count). `[ N ]` single-index → extent 1.
// `st` points at `[`. (IEEE 1364-2005 §3.3 / §4.8.)
fn _rv_parse_range(st_in: PState, tab: SymTab) -> RangeEval {
    let mut st = _ps_take(st_in)            // consume "["
    let mut hitoks: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ":" { break }
        if t == "]" { break }
        hitoks = hitoks.push(t)
        st = _ps_take(st)
    }
    if _ps_peek(st) == "]" {
        // single-index `[N]` → extent 1
        st = _ps_take(st)
        return RangeEval { width: 1, st: st, err: "" }
    }
    if _ps_peek(st) != ":" {
        return RangeEval {
            width: 1, st: st,
            err: "read_verilog: range: expected `:` got `" + _ps_peek(st) + "`"
        }
    }
    st = _ps_take(st)                       // consume ":"
    let mut lotoks: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == "]" { break }
        lotoks = lotoks.push(t)
        st = _ps_take(st)
    }
    if _ps_peek(st) != "]" {
        return RangeEval { width: 1, st: st, err: "read_verilog: range: missing `]`" }
    }
    st = _ps_take(st)                       // consume "]"
    let hi = _rv_eval_expr(hitoks, 0, tab, 1)
    if len(hi.err) > 0 { return RangeEval { width: 1, st: st, err: hi.err } }
    let lo = _rv_eval_expr(lotoks, 0, tab, 1)
    if len(lo.err) > 0 { return RangeEval { width: 1, st: st, err: lo.err } }
    // width is |HI - LO| + 1 — packed [msb:lsb] and unpacked [lo:hi]
    // both yield a positive extent.
    let mut w = hi.value - lo.value + 1
    if w < 1 { w = lo.value - hi.value + 1 }
    return RangeEval { width: w, st: st, err: "" }
}

// CLEAN-ROOM: parse an ANSI-style port list `( DIR NETTYPE [signed]
// [packed-range] NAME [unpacked-range] , … )` (IEEE 1364-2005 §12.3.3).
// `st` points at `(`. Direction is sticky — a port without an explicit
// direction inherits the previous one. An unpacked 1-D array expands to
// one RTLIL wire per index (`NAME[0]` … `NAME[n-1]`), each `width` bits.
fn _rv_parse_ansi_ports(st_in: PState, m_in: Module, tab: SymTab) -> RvStep {
    let mut st = _ps_take(st_in)            // consume "("
    let mut m = m_in
    let mut cur_dir = 1                     // first port defaults to input
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ")" { st = _ps_take(st); break }
        if t == "," { st = _ps_take(st); continue }
        // direction keyword (sticky)
        if t == "input"  { cur_dir = 1; st = _ps_take(st); continue }
        if t == "output" { cur_dir = 2; st = _ps_take(st); continue }
        if t == "inout"  { cur_dir = 3; st = _ps_take(st); continue }
        // net type / signedness — irrelevant to RTLIL wire shape
        if t == "wire"  { st = _ps_take(st); continue }
        if t == "reg"   { st = _ps_take(st); continue }
        if t == "logic" { st = _ps_take(st); continue }
        if t == "signed" { st = _ps_take(st); continue }
        // packed bit-range → width
        let mut width = 1
        if t == "[" {
            let rg = _rv_parse_range(st, tab)
            if len(rg.err) > 0 { return RvStep { st: _ps_fail(st, rg.err), m: m } }
            width = rg.width
            st = rg.st
        }
        // port name
        let pname = _ps_peek(st)
        if pname == "" || pname == ")" || pname == "," {
            return RvStep {
                st: _ps_fail(st, "read_verilog: ANSI port: expected name"), m: m
            }
        }
        st = _ps_take(st)
        // optional unpacked 1-D array range → one wire per index
        if _ps_peek(st) == "[" {
            let ur = _rv_parse_range(st, tab)
            if len(ur.err) > 0 { return RvStep { st: _ps_fail(st, ur.err), m: m } }
            st = ur.st
            let mut k = 0
            while k < ur.width {
                let wn = pname + "[" + str(k) + "]"
                let pid = len(m.wires) + 1
                m = rtlil_module_add_wire(m, rtlil_wire(wn, width, cur_dir, pid))
                k = k + 1
            }
        } else {
            let pid = len(m.wires) + 1
            m = rtlil_module_add_wire(m, rtlil_wire(pname, width, cur_dir, pid))
        }
    }
    return RvStep { st: st, m: m }
}

// ─── function automatic declaration parsing (rfc_006 §4 m2, D68) ────────

// CLEAN-ROOM: a parsed Verilog `function` — its name, ordered argument
// names, and body token stream (between `;` and `endfunction`). The
// body is kept as tokens for later inline expansion at call sites
// (IEEE 1364-2005 §10.3 — a function call is semantically an inline
// substitution of the body with arguments bound).
struct VFunc {
    name: str,
    args: [str],
    body: [str],
}

// Parse-step result for a function declaration.
struct RvFuncStep {
    st:   PState,
    func: VFunc,
    err:  str,
}

// CLEAN-ROOM: parse `function [automatic] [signed] [range] NAME (
// [input [range]] ARG , … ) ; BODY endfunction` (IEEE 1364-2005
// §10.3.1). `st` points at `function`. The return type / ranges are
// skipped — integer-level inlining does not need them; argument names
// and the body token stream are retained.
fn _rv_parse_function(st_in: PState) -> RvFuncStep {
    let mut st = _ps_take(st_in)            // consume "function"
    // skip `automatic` / `signed` / return `[range]`
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == "automatic" { st = _ps_take(st); continue }
        if t == "signed"    { st = _ps_take(st); continue }
        if t == "integer"   { st = _ps_take(st); continue }
        if t == "[" {
            while st.pos < len(st.toks) {
                if _ps_peek(st) == "]" { st = _ps_take(st); break }
                st = _ps_take(st)
            }
            continue
        }
        break
    }
    let fname = _ps_peek(st)
    if fname == "" {
        return RvFuncStep {
            st: st, func: VFunc { name: "", args: [], body: [] },
            err: "read_verilog: function: expected name"
        }
    }
    st = _ps_take(st)
    // optional ANSI argument list `( input [range] ARG , … )`
    let mut argnames: [str] = []
    if _ps_peek(st) == "(" {
        st = _ps_take(st)
        while st.pos < len(st.toks) {
            let t = _ps_peek(st)
            if t == ")" { st = _ps_take(st); break }
            if t == "," { st = _ps_take(st); continue }
            if t == "input"  { st = _ps_take(st); continue }
            if t == "signed" { st = _ps_take(st); continue }
            if t == "[" {
                while st.pos < len(st.toks) {
                    if _ps_peek(st) == "]" { st = _ps_take(st); break }
                    st = _ps_take(st)
                }
                continue
            }
            argnames = argnames.push(t)
            st = _ps_take(st)
        }
    }
    // header terminator `;`
    if _ps_peek(st) == ";" { st = _ps_take(st) }
    // body tokens until `endfunction`
    let mut body: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == "endfunction" { st = _ps_take(st); break }
        body = body.push(t)
        st = _ps_take(st)
    }
    return RvFuncStep {
        st: st,
        func: VFunc { name: fname, args: argnames, body: body },
        err: ""
    }
}

// CLEAN-ROOM: collapse a cascaded-if function body into a single
// return-expr statement using nested ternary (sub-step #4f). The
// recognised shape is
//   if ( c1 ) fname = e1 ; else if ( c2 ) fname = e2 ; …
//                                       else fname = eN ;
// which collapses to
//   fname = ( c1 ) ? ( e1 ) : ( ( c2 ) ? ( e2 ) : … ( eN ) ) ;
// Any deviation (no terminal else, missing fname assignments, no `if`
// at the head) returns an empty list — caller falls back to the
// original body. Pre-`if` statements (e.g. local `reg` decls or
// blocking assignments to local vars) are NOT handled — those need
// proper function-body proc-pass, separate sub-step.
// CLEAN-ROOM: extension of _rv_collapse_cascaded_if_body that also
// handles a preceding prefix of local declarations + blocking
// assignments, optionally wrapped in `begin … end`. router_d4's
// route_xy has the shape:
//
//   function automatic [2:0] route_xy(input [W-1:0] pkt);
//       reg signed [...] dx, dy;       ← decl(s) — skipped
//       begin                          ← optional block-wrap — skipped
//           dx = dst_x_of(pkt) - my_x; ← blocking assign — substituted
//           dy = dst_y_of(pkt) - my_y; ← blocking assign — substituted
//           if (dx > 0) route_xy = 3'd2;  …
//           else if (dy > 0) route_xy = 3'd0;
//           …
//           else route_xy = 3'd4;
//       end                            ← matched `end`
//   endfunction
//
// The recognised cascaded-if tail is collapsed via the existing
// `_rv_collapse_cascaded_if_body`. Then every `<name>` that appeared
// as a blocking-assign LHS is substituted token-wise with `( <rhs> )`
// (SSA-style; works for the route_xy shape where each local is
// assigned exactly once and only consumed downstream). Returns the
// `fname = ( ternary ) ;` token form on success, or `[]` for any
// shape mismatch — caller falls back to plain _rv_collapse, then
// to vf.body unchanged.
fn _rv_collapse_func_body_with_prefix(body: [str], fname: str) -> [str] {
    let mut subst_names: [str] = []
    let mut subst_exprs: [[str]] = []
    let mut i = 0
    let n = len(body)
    let mut has_begin = 0
    while i < n {
        let t = body[i]
        if t == "reg" || t == "integer" || t == "wire" {
            // skip a single declaration up to `;` (range / signed / list)
            while i < n && body[i] != ";" { i = i + 1 }
            if i < n { i = i + 1 }
            continue
        }
        if t == "begin" {
            has_begin = 1
            i = i + 1
            continue
        }
        if t == "if" { break }
        // blocking-assign: `<name> = <expr> ;` (name is not a keyword)
        if i + 1 < n && body[i + 1] == "=" {
            let lhs = t
            i = i + 2
            let mut expr: [str] = []
            while i < n && body[i] != ";" {
                expr = expr.push(body[i])
                i = i + 1
            }
            if i >= n { return [] }
            i = i + 1
            subst_names = subst_names.push(lhs)
            subst_exprs = subst_exprs.push(expr)
            continue
        }
        // anything else → shape mismatch
        return []
    }
    // tail = body[i..(n - optional `end`)]. Build a slice for the
    // existing cascaded-if collapser.
    let mut tail_end = n
    if has_begin == 1 && n > 0 && body[n - 1] == "end" { tail_end = n - 1 }
    let mut tail: [str] = []
    let mut j = i
    while j < tail_end {
        tail = tail.push(body[j])
        j = j + 1
    }
    if len(tail) == 0 { return [] }
    let collapsed = _rv_collapse_cascaded_if_body(tail, fname)
    if len(collapsed) == 0 { return [] }
    // Substitute each subst name with `( <expr> )` token-wise across
    // the collapsed token stream.
    if len(subst_names) == 0 { return collapsed }
    let mut out: [str] = []
    let mut ci = 0
    while ci < len(collapsed) {
        let ct = collapsed[ci]
        let mut idx = 0 - 1
        let mut sk = 0
        while sk < len(subst_names) {
            if subst_names[sk] == ct { idx = sk; sk = len(subst_names) }
            sk = sk + 1
        }
        if idx >= 0 {
            out = out.push("(")
            let mut ei = 0
            while ei < len(subst_exprs[idx]) {
                out = out.push(subst_exprs[idx][ei])
                ei = ei + 1
            }
            out = out.push(")")
        } else {
            out = out.push(ct)
        }
        ci = ci + 1
    }
    return out
}

fn _rv_collapse_cascaded_if_body(body: [str], fname: str) -> [str] {
    let mut conds: [[str]] = []
    let mut exprs: [[str]] = []
    let mut else_expr: [str] = []
    let mut i = 0
    let n = len(body)
    let mut ok = 1
    let mut done = 0
    while i < n && ok == 1 && done == 0 {
        if body[i] != "if" { ok = 0; break }
        i = i + 1
        if i >= n || body[i] != "(" { ok = 0; break }
        i = i + 1
        let mut cond: [str] = []
        let mut depth = 1
        while i < n && depth > 0 {
            if body[i] == "(" {
                depth = depth + 1
                cond = cond.push(body[i])
                i = i + 1
                continue
            }
            if body[i] == ")" {
                depth = depth - 1
                if depth == 0 { i = i + 1; break }
                cond = cond.push(body[i])
                i = i + 1
                continue
            }
            cond = cond.push(body[i])
            i = i + 1
        }
        if depth != 0 { ok = 0; break }
        if i >= n || body[i] != fname { ok = 0; break }
        i = i + 1
        if i >= n || body[i] != "=" { ok = 0; break }
        i = i + 1
        let mut expr: [str] = []
        while i < n && body[i] != ";" {
            expr = expr.push(body[i])
            i = i + 1
        }
        if i >= n { ok = 0; break }
        i = i + 1
        conds = conds.push(cond)
        exprs = exprs.push(expr)
        if i >= n || body[i] != "else" { ok = 0; break }
        i = i + 1
        if i < n && body[i] == "if" {
            continue
        }
        if i >= n || body[i] != fname { ok = 0; break }
        i = i + 1
        if i >= n || body[i] != "=" { ok = 0; break }
        i = i + 1
        while i < n && body[i] != ";" {
            else_expr = else_expr.push(body[i])
            i = i + 1
        }
        if i >= n { ok = 0; break }
        i = i + 1
        done = 1
    }
    if ok == 0 || done == 0 { return [] }
    if i < n { return [] }
    let mut result: [str] = else_expr
    let mut k = len(conds) - 1
    while k >= 0 {
        let mut nr: [str] = []
        nr = nr.push("(")
        let mut ci = 0
        while ci < len(conds[k]) {
            nr = nr.push(conds[k][ci])
            ci = ci + 1
        }
        nr = nr.push(")")
        nr = nr.push("?")
        nr = nr.push("(")
        let mut xi = 0
        while xi < len(exprs[k]) {
            nr = nr.push(exprs[k][xi])
            xi = xi + 1
        }
        nr = nr.push(")")
        nr = nr.push(":")
        nr = nr.push("(")
        let mut ri = 0
        while ri < len(result) {
            nr = nr.push(result[ri])
            ri = ri + 1
        }
        nr = nr.push(")")
        result = nr
        k = k - 1
    }
    let mut out: [str] = []
    out = out.push(fname)
    out = out.push("=")
    let mut oi = 0
    while oi < len(result) {
        out = out.push(result[oi])
        oi = oi + 1
    }
    out = out.push(";")
    return out
}

// CLEAN-ROOM: token-level inlining of function calls inside the
// remaining module body. Handles the minimal shape:
//   call site:  `func_name ( arg1_toks , arg2_toks , … )`
//   func body:  `func_name = expr_toks ;`        (single return-expr)
// Anything outside that shape (multi-stmt bodies, nested calls,
// args using `(`/`)` deeper than the call's own parens, mismatched
// arity) is left untouched so the parser still sees the original
// token stream and either parses correctly or fails loudly.
fn _rv_inline_func_calls(toks_in: [str], funcs: [VFunc]) -> [str] {
    let mut out: [str] = []
    let mut i = 0
    while i < len(toks_in) {
        let nm = toks_in[i]
        let mut fidx = 0 - 1
        let mut k = 0
        while k < len(funcs) {
            if funcs[k].name == nm { fidx = k; k = len(funcs) }
            k = k + 1
        }
        if fidx >= 0 && i + 1 < len(toks_in) && toks_in[i + 1] == "(" {
            // collect args, depth-balanced on `(`/`)`, split on `,`
            let mut args: [[str]] = []
            let mut cur: [str] = []
            let mut p = i + 2
            let mut depth = 1
            let mut ok = 1
            while p < len(toks_in) && depth > 0 {
                let t = toks_in[p]
                if t == "(" {
                    depth = depth + 1
                    cur = cur.push(t)
                    p = p + 1
                    continue
                }
                if t == ")" {
                    depth = depth - 1
                    if depth == 0 {
                        if len(cur) > 0 { args = args.push(cur) }
                        cur = []
                        p = p + 1
                        break
                    }
                    cur = cur.push(t)
                    p = p + 1
                    continue
                }
                if t == "," && depth == 1 {
                    if len(cur) > 0 { args = args.push(cur) }
                    cur = []
                    p = p + 1
                    continue
                }
                cur = cur.push(t)
                p = p + 1
            }
            if depth != 0 { ok = 0 }
            let vf = funcs[fidx]
            // Sub-step #4g: try function body with preceding-stmt
            // prefix first (decls + blocking-assigns + cascaded-if,
            // router_d4 route_xy shape). Falls back to bare cascaded-
            // if collapse (#4f), then to vf.body unchanged.
            let collapsed_g = _rv_collapse_func_body_with_prefix(vf.body, vf.name)
            let mut body_use: [str] = []
            if len(collapsed_g) > 0 {
                body_use = collapsed_g
            } else {
                let collapsed = _rv_collapse_cascaded_if_body(vf.body, vf.name)
                if len(collapsed) > 0 {
                    body_use = collapsed
                } else {
                    body_use = vf.body
                }
            }
            if ok == 1 && len(args) == len(vf.args) && len(body_use) >= 4 {
                if body_use[0] != vf.name { ok = 0 }
                if ok == 1 && body_use[1] != "=" { ok = 0 }
                if ok == 1 && body_use[len(body_use) - 1] != ";" { ok = 0 }
            } else {
                ok = 0
            }
            if ok == 1 {
                let mut expr_toks: [str] = []
                let mut ei = 2
                while ei < len(body_use) - 1 {
                    let et = body_use[ei]
                    let mut sub = 0 - 1
                    let mut sk = 0
                    while sk < len(vf.args) {
                        if vf.args[sk] == et { sub = sk; sk = len(vf.args) }
                        sk = sk + 1
                    }
                    if sub >= 0 {
                        let av = args[sub]
                        // wrap the substituted arg tokens in `(` / `)`
                        // so operator precedence at the call site is
                        // preserved (e.g. `~(a^b)` doesn't bind tighter
                        // than the substituted expression's own ops).
                        expr_toks = expr_toks.push("(")
                        let mut av_i = 0
                        while av_i < len(av) {
                            expr_toks = expr_toks.push(av[av_i])
                            av_i = av_i + 1
                        }
                        expr_toks = expr_toks.push(")")
                    } else {
                        expr_toks = expr_toks.push(et)
                    }
                    ei = ei + 1
                }
                // wrap the whole inlined body in `(` / `)` too — the
                // call site might be inside a larger expression.
                out = out.push("(")
                let mut xi = 0
                while xi < len(expr_toks) {
                    out = out.push(expr_toks[xi])
                    xi = xi + 1
                }
                out = out.push(")")
                i = p
                continue
            }
        }
        out = out.push(toks_in[i])
        i = i + 1
    }
    return out
}

// CLEAN-ROOM: count the elements of an unpacked-array reg by scanning
// the module's wires for the `base[k]` pattern. Used by the dynamic-
// indexing cond-mux lowering (proc-pass sub-step #4d) to size the
// per-element $eq/$mux/$dff chain. Returns 0 if no elements found
// (caller should fall back to no-emit).
//
// Assumes contiguous indices 0..P-1 (router_d{4,6}'s array decls
// follow this convention).
fn _rv_array_bound(m: Module, base: str) -> int {
    let mut count = 0
    let prefix = base + "["
    let pl = len(prefix)
    let mut i = 0
    while i < len(m.wires) {
        let wn = m.wires[i].name
        if len(wn) > pl {
            if wn.substring(0, pl) == prefix {
                if wn.substring(len(wn) - 1, len(wn)) == "]" {
                    count = count + 1
                }
            }
        }
        i = i + 1
    }
    return count
}

// CLEAN-ROOM: linear lookup of a function by name; -1 if absent.
fn _rv_find_function(funcs: [VFunc], name: str) -> int {
    let mut i = 0
    while i < len(funcs) {
        if funcs[i].name == name { return i }
        i = i + 1
    }
    return 0 - 1
}

// ─── generate-for static unroll (rfc_006 §4 m2, D68) ─────────────────────

// Parse-step result for a `generate` block — cursor + module + tab.
struct RvGenStep {
    st:  PState,
    m:   Module,
    tab: SymTab,
}

// CLEAN-ROOM: parse and unroll a `generate for ( GV = INIT ; COND ; GV
// = STEP ) begin [: label] BODY end endgenerate` block (IEEE 1364-2005
// §12.4.1). On each iteration the genvar is bound in `tab` and the
// body is re-parsed; supported body statements are `assign` and
// `localparam` (router_d{4,6}.v synth-subset). Nested begin/end are
// depth-balanced; an iteration cap guards runaway loops.
fn _rv_parse_generate(st_in: PState, m_in: Module, tab_in: SymTab) -> RvGenStep {
    let mut st = _ps_take(st_in)            // consume "generate"
    let mut m = m_in
    let mut tab = tab_in
    if _ps_peek(st) != "for" {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate: expected `for`"),
            m: m, tab: tab
        }
    }
    st = _ps_take(st)
    if _ps_peek(st) != "(" {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate for: expected `(`"),
            m: m, tab: tab
        }
    }
    st = _ps_take(st)

    // init: GV = INIT ;
    let gv = _ps_peek(st)
    st = _ps_take(st)
    if _ps_peek(st) != "=" {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate for init: expected `=`"),
            m: m, tab: tab
        }
    }
    st = _ps_take(st)
    let mut initoks: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ";" { st = _ps_take(st); break }
        initoks = initoks.push(t)
        st = _ps_take(st)
    }
    let init_ev = _rv_eval_expr(initoks, 0, tab, 1)
    if len(init_ev.err) > 0 {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate for init: " + init_ev.err),
            m: m, tab: tab
        }
    }
    tab = symtab_put(tab, gv, init_ev.value)

    // cond expr until ";"
    let mut condtoks: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ";" { st = _ps_take(st); break }
        condtoks = condtoks.push(t)
        st = _ps_take(st)
    }

    // step: GV = STEP ) — skip name + "=", collect step expr until ")"
    st = _ps_take(st)                       // step gv name
    if _ps_peek(st) != "=" {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate for step: expected `=`"),
            m: m, tab: tab
        }
    }
    st = _ps_take(st)
    let mut steptoks: [str] = []
    while st.pos < len(st.toks) {
        let t = _ps_peek(st)
        if t == ")" { st = _ps_take(st); break }
        steptoks = steptoks.push(t)
        st = _ps_take(st)
    }

    // expect "begin" [: label]
    if _ps_peek(st) != "begin" {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate for: expected `begin`"),
            m: m, tab: tab
        }
    }
    st = _ps_take(st)
    if _ps_peek(st) == ":" {
        st = _ps_take(st)
        st = _ps_take(st)                   // label name
    }

    // record body span [body_start, body_end), depth-balancing begin/end.
    let body_start = st.pos
    let mut depth = 1
    let mut body_end = body_start
    while body_end < len(st.toks) {
        let t = st.toks[body_end]
        if t == "begin" { depth = depth + 1 }
        if t == "end" {
            depth = depth - 1
            if depth == 0 { break }
        }
        body_end = body_end + 1
    }

    // unroll: re-parse the body each iteration while COND folds to non-zero.
    let mut iter = 0
    while iter < 1024 {
        let cond_ev = _rv_eval_expr(condtoks, 0, tab, 1)
        if len(cond_ev.err) > 0 {
            return RvGenStep {
                st: _ps_fail(st, "read_verilog: generate for cond: " + cond_ev.err),
                m: m, tab: tab
            }
        }
        if cond_ev.value == 0 { break }

        let mut bst = PState { toks: st.toks, pos: body_start, err: "" }
        while bst.pos < body_end {
            let bt = _ps_peek(bst)
            if bt == "assign" {
                let r = _rv_parse_assign(bst, m, tab)
                bst = r.st
                m = r.m
                if len(bst.err) > 0 {
                    return RvGenStep { st: bst, m: m, tab: tab }
                }
            } else {
                if bt == "localparam" || bt == "parameter" {
                    let r2 = _rv_parse_localparam(bst, tab)
                    bst = r2.st
                    tab = r2.tab
                    if len(bst.err) > 0 {
                        return RvGenStep { st: bst, m: m, tab: tab }
                    }
                } else {
                    bst = _ps_take(bst)
                }
            }
        }

        let step_ev = _rv_eval_expr(steptoks, 0, tab, 1)
        if len(step_ev.err) > 0 {
            return RvGenStep {
                st: _ps_fail(st, "read_verilog: generate for step: " + step_ev.err),
                m: m, tab: tab
            }
        }
        tab = symtab_put(tab, gv, step_ev.value)
        iter = iter + 1
    }

    // jump past body + the closing `end`
    st = PState { toks: st.toks, pos: body_end + 1, err: "" }
    if _ps_peek(st) != "endgenerate" {
        return RvGenStep {
            st: _ps_fail(st, "read_verilog: generate: expected `endgenerate`"),
            m: m, tab: tab
        }
    }
    st = _ps_take(st)
    return RvGenStep { st: st, m: m, tab: tab }
}

// ─── always-block inference (rfc_006 §4 m2, D68) ─────────────────────────

// RFC 073 Phase 3a — nested-if inside for-body if. The for-body if-handler
// (in `_rv_parse_always`) splits the if's THEN/ELSE body into statements
// and emits one `connect_cond` row (combinational) or `$mux + $dff` pair
// (clocked) per LHS, carrying the outer if's COND wire as the guard. When
// a body statement is itself another `if (innercond) … [else …]`, this
// helper composes the guard with `cond AND inner` (then-arm) or
// `cond AND NOT inner` (else-arm) — emitting `$and` / `$logic_not` cells
// inline — and recurses on the inner body with the composed guard. Per
// IEEE 1364-2005 §9.4 (nested conditional statements) + Yosys
// passes/proc/proc_mux.cc (clean-room).
struct RvEmitRes {
    m: Module,
    ok: int,                                // 1 = all stmts emitted, 0 = honest-gap (drop)
}

fn _rv_emit_for_if_stmts(
    body_toks: [str],
    cond_wire: str,
    m_in: Module,
    tab: SymTab,
    is_clocked: int,
    clk_wire: str
) -> RvEmitRes {
    let mut m = m_in
    let mut bp = 0
    let n = len(body_toks)
    while bp < n {
        let t0 = body_toks[bp]
        // skip stray separators (defensive; the splitter below produces
        // `;`-terminated runs, but recursion may re-enter with begin/end
        // wrappers stripped).
        if t0 == ";" { bp = bp + 1; continue }
        if t0 == "begin" {
            // begin/end wrapper inside a body — strip and process inner
            // tokens recursively at the same guard.
            bp = bp + 1
            let mut sd = 1
            let mut inner_toks: [str] = []
            while bp < n && sd > 0 {
                let tt = body_toks[bp]
                if tt == "begin" { sd = sd + 1 }
                if tt == "end" {
                    sd = sd - 1
                    if sd == 0 { bp = bp + 1; break }
                }
                inner_toks = inner_toks.push(tt)
                bp = bp + 1
            }
            let sub = _rv_emit_for_if_stmts(inner_toks, cond_wire, m, tab, is_clocked, clk_wire)
            if sub.ok == 0 { return RvEmitRes { m: m_in, ok: 0 } }
            m = sub.m
            continue
        }
        if t0 == "if" {
            // nested if — consume `( COND ) THEN [else ELSE]`
            bp = bp + 1
            let mut inner_cond: [str] = []
            if bp < n && body_toks[bp] == "(" {
                bp = bp + 1
                let mut pd = 1
                while bp < n {
                    let pt = body_toks[bp]
                    if pt == "(" { pd = pd + 1; inner_cond = inner_cond.push(pt); bp = bp + 1; continue }
                    if pt == ")" {
                        pd = pd - 1
                        if pd == 0 { bp = bp + 1; break }
                        inner_cond = inner_cond.push(pt); bp = bp + 1; continue
                    }
                    inner_cond = inner_cond.push(pt); bp = bp + 1
                }
            } else {
                return RvEmitRes { m: m_in, ok: 0 }
            }
            // collect THEN-body
            let mut then_toks: [str] = []
            if bp < n && body_toks[bp] == "begin" {
                bp = bp + 1
                let mut sd = 1
                while bp < n {
                    let tt = body_toks[bp]
                    if tt == "begin" { sd = sd + 1; then_toks = then_toks.push(tt); bp = bp + 1; continue }
                    if tt == "end" {
                        sd = sd - 1
                        if sd == 0 { bp = bp + 1; break }
                        then_toks = then_toks.push(tt); bp = bp + 1; continue
                    }
                    then_toks = then_toks.push(tt); bp = bp + 1
                }
            } else {
                // single statement (could itself be a nested-if — collect
                // up to ; OR up to a matched if-tail). Simplest: collect
                // tokens up to `;` (terminator). Nested-if-without-begin
                // inside is then a single `if (…) … ;` run, which the
                // recursive call splits again.
                while bp < n {
                    let tt = body_toks[bp]
                    if tt == ";" { then_toks = then_toks.push(tt); bp = bp + 1; break }
                    then_toks = then_toks.push(tt); bp = bp + 1
                }
            }
            // optional ELSE
            let mut has_else = 0
            let mut else_toks: [str] = []
            if bp < n && body_toks[bp] == "else" {
                has_else = 1
                bp = bp + 1
                if bp < n && body_toks[bp] == "begin" {
                    bp = bp + 1
                    let mut sd = 1
                    while bp < n {
                        let tt = body_toks[bp]
                        if tt == "begin" { sd = sd + 1; else_toks = else_toks.push(tt); bp = bp + 1; continue }
                        if tt == "end" {
                            sd = sd - 1
                            if sd == 0 { bp = bp + 1; break }
                            else_toks = else_toks.push(tt); bp = bp + 1; continue
                        }
                        else_toks = else_toks.push(tt); bp = bp + 1
                    }
                } else {
                    while bp < n {
                        let tt = body_toks[bp]
                        if tt == ";" { else_toks = else_toks.push(tt); bp = bp + 1; break }
                        else_toks = else_toks.push(tt); bp = bp + 1
                    }
                }
            }
            // Elaborate inner cond → inner_wire. On failure, honest gap.
            let ier = _rv_elab_expr(inner_cond, 0, m, 1, tab)
            if len(ier.err) > 0 { return RvEmitRes { m: m_in, ok: 0 } }
            m = ier.m
            // Compose THEN guard = cond_wire AND ier.wire — emit $and cell
            // unless cond_wire is empty (top-level: guard collapses to the
            // inner cond itself; matches Phase 2 single-level behaviour).
            let mut then_guard = ier.wire
            if len(cond_wire) > 0 {
                let andw = _rv_fresh_wire(m)
                m = rtlil_module_add_wire(m, rtlil_wire(andw, 1, 0, 0))
                let mut andc = rtlil_cell(andw + "$and", "$and", 0)
                andc = rtlil_cell_connect(andc, "A", cond_wire)
                andc = rtlil_cell_connect(andc, "B", ier.wire)
                andc = rtlil_cell_connect(andc, "Y", andw)
                m = rtlil_module_add_cell(m, andc)
                then_guard = andw
            }
            // Recurse on THEN body with composed guard.
            let then_sub = _rv_emit_for_if_stmts(then_toks, then_guard, m, tab, is_clocked, clk_wire)
            if then_sub.ok == 0 { return RvEmitRes { m: m_in, ok: 0 } }
            m = then_sub.m
            // ELSE arm — guard = cond_wire AND NOT(ier.wire); when no outer
            // guard, guard collapses to just NOT(ier.wire).
            if has_else == 1 {
                let notw = _rv_fresh_wire(m)
                m = rtlil_module_add_wire(m, rtlil_wire(notw, 1, 0, 0))
                let mut notc = rtlil_cell(notw + "$c", "$logic_not", 0)
                notc = rtlil_cell_connect(notc, "A", ier.wire)
                notc = rtlil_cell_connect(notc, "Y", notw)
                m = rtlil_module_add_cell(m, notc)
                let mut else_guard = notw
                if len(cond_wire) > 0 {
                    let andw2 = _rv_fresh_wire(m)
                    m = rtlil_module_add_wire(m, rtlil_wire(andw2, 1, 0, 0))
                    let mut andc2 = rtlil_cell(andw2 + "$and", "$and", 0)
                    andc2 = rtlil_cell_connect(andc2, "A", cond_wire)
                    andc2 = rtlil_cell_connect(andc2, "B", notw)
                    andc2 = rtlil_cell_connect(andc2, "Y", andw2)
                    m = rtlil_module_add_cell(m, andc2)
                    else_guard = andw2
                }
                let else_sub = _rv_emit_for_if_stmts(else_toks, else_guard, m, tab, is_clocked, clk_wire)
                if else_sub.ok == 0 { return RvEmitRes { m: m_in, ok: 0 } }
                m = else_sub.m
            }
            continue
        }
        // Otherwise: must be a regular `LHS op RHS ;` statement.
        // Collect until next `;` (matching the original splitter).
        let mut stmt: [str] = []
        while bp < n {
            let tt = body_toks[bp]
            stmt = stmt.push(tt)
            bp = bp + 1
            if tt == ";" { break }
        }
        if len(stmt) < 4 { return RvEmitRes { m: m_in, ok: 0 } }
        if stmt[len(stmt) - 1] != ";" { return RvEmitRes { m: m_in, ok: 0 } }
        let op = stmt[1]
        if op != "<=" && op != "=" { return RvEmitRes { m: m_in, ok: 0 } }
        if op == "<=" && is_clocked == 0 { return RvEmitRes { m: m_in, ok: 0 } }
        if op == "="  && is_clocked == 1 { return RvEmitRes { m: m_in, ok: 0 } }
        let lhs = stmt[0]
        let mut rhs: [str] = []
        let mut ri = 2
        while ri < len(stmt) - 1 {
            rhs = rhs.push(stmt[ri])
            ri = ri + 1
        }
        let rer = _rv_elab_expr(rhs, 0, m, 1, tab)
        if len(rer.err) > 0 { return RvEmitRes { m: m_in, ok: 0 } }
        m = rer.m
        if is_clocked == 1 {
            // Clocked guarded write: $mux feedback-hold + $dff sink.
            // @cite IEEE 1364-2005 §9.2 (non-blocking) + §9.4 (nested
            // conditional) + Yosys proc_mux $mux-feedback shape.
            let mux_y = _rv_fresh_wire(m)
            m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
            let mux_n = "$rvmux$" + str(len(m.cells))
            let mut mc = rtlil_cell(mux_n, "$mux", 0)
            mc = rtlil_cell_connect(mc, "A", lhs)
            mc = rtlil_cell_connect(mc, "B", rer.wire)
            mc = rtlil_cell_connect(mc, "S", cond_wire)
            mc = rtlil_cell_connect(mc, "Y", mux_y)
            m = rtlil_module_add_cell(m, mc)
            let dn = "$rvff$" + str(len(m.cells))
            let mut dc = rtlil_cell(dn, "$dff", 0)
            dc = rtlil_cell_connect(dc, "CLK", clk_wire)
            dc = rtlil_cell_connect(dc, "D", mux_y)
            dc = rtlil_cell_connect(dc, "Q", lhs)
            m = rtlil_module_add_cell(m, dc)
        } else {
            // Combinational guarded write — emit a connect_cond row.
            // pass_proc_mux folds multiple cond-tagged rows on the same
            // LHS into a left-deep $mux chain. @cite IEEE 1364-2005 §9.2
            // + §9.4 + RFC 073 §4 Phase 3a (F-RFC-RV-NESTED-IF).
            m = rtlil_module_connect_cond(m, lhs, rer.wire, cond_wire)
        }
    }
    return RvEmitRes { m: m, ok: 1 }
}

// ─── RFC 073 Phase 3e — shared single-arm cond-mux helper ────────────────
// `_rv_emit_body_v2` is the SUPER-set of `_rv_emit_for_if_stmts`. It
// recursively walks a body-token stream and emits per-LHS cond-tagged
// connect_cond rows for the D-input of each tracked LHS. Constructs:
//   - `begin … end` blocks (strip, recurse with same guard)
//   - `if (cond) THEN [else ELSE]` — recurse with composed guards
//     (`cond AND outer` / `NOT cond AND outer`); inline $and /
//     $logic_not cells per IEEE 1364-2005 §9.4.
//   - `for (gv = init; cond; gv = step) body` — static-unroll while
//     `cond` const-folds non-zero (≤1024 iters); per-iteration body
//     recurse with iter-substituted symtab + same outer guard.
//   - `LHS [<=|=] RHS ;`         — guarded write
//   - `LHS [ const ] [<=|=] RHS` — guarded indexed write (static idx)
//   - `LHS [ wire ] [<=|=] RHS`  — guarded indexed write (dyn idx) —
//     emits a per-element ($eq + $and) chain composing the guard with
//     the per-slot select; one (wire-D, rhs, slot_guard) row per slot.
//   - `LHS [ idx1 ] [ idx2 ]`    — 2-D indexed: graceful-skip (NOT on
//     §5 critical path).
//
// Emission model — instead of emitting `$mux+$dff` per leaf (which
// produces multi-driver $dff cells when an LHS is written from
// multiple arms), the helper emits:
//   (a) `connect_cond(<lhs>__d, rhs_wire, guard_wire)` per leaf write,
//   (b) `tracked_lhs[]` accumulator listing every unique LHS seen.
// The CALLER (the always-handler) is responsible for emitting one
// `$dff(D=<lhs>__d, Q=<lhs>)` per tracked LHS PLUS one unconditional
// feedback default `connect(<lhs>__d, <lhs>)` so `pass_proc_mux` sees
// the cond-tagged rows + default and folds them into a single $mux
// chain driving each $dff. Result: every clocked LHS has exactly ONE
// $dff (no multi-driver), and the chain expresses the priority-mux
// composition per IEEE 1364-2005 §10.4.2 + Yosys
// passes/proc/proc_mux.cc.
//
// For combinational `=` writes the rows go to `connect_cond` directly
// without the `<lhs>__d` indirection (no $dff needed).
//
// Returns ok=1 always (honest-gap statements skip-with-no-emit; an
// arm must still emit the writes it CAN emit lest §5 gate sees 0 area).
struct RvEmitV2Res {
    m: Module,
    tracked_lhs: [str],
    ok: int,
}

// CLEAN-ROOM helper: append `lhs` to `tracked` if not already there.
fn _rv_v2_track(tracked: [str], lhs: str) -> [str] {
    let mut i = 0
    while i < len(tracked) {
        if tracked[i] == lhs { return tracked }
        i = i + 1
    }
    return tracked.push(lhs)
}

// CLEAN-ROOM helper: per-LHS D-wire naming. Stable string so multiple
// recursion paths writing to the same LHS share the same D-wire.
fn _rv_v2_dwire(lhs: str) -> str {
    return lhs + "__d"
}

// RFC 006 §5 ABC combinational-loop SSA fix —
// `_rv_signal_is_read_in_body` returns 1 iff `name` appears as a RHS
// (read) reference somewhere in `toks` (any position that is NOT a
// blocking-LHS-base immediately preceding a `=`). Used to filter the
// SSA-renaming target set down to signals that need it: only signals
// that are BOTH written-then-read in the loop body create the inter-
// iter anti-dependency that ABC mistakes for a combinational loop.
// Write-only signals (e.g. T58 `idx = i;` in a for-body where `idx`
// is not read) keep the legacy `pass_proc_mux` path — no SSA renaming.
fn _rv_signal_is_read_in_body(toks: [str], name: str) -> int {
    let n = len(toks)
    let mut k = 0
    while k < n {
        if toks[k] == name {
            // Walk past optional `[...]` indexing groups.
            let mut p = k + 1
            while p < n && toks[p] == "[" {
                let mut bd = 1
                p = p + 1
                while p < n && bd > 0 {
                    if toks[p] == "[" { bd = bd + 1 }
                    if toks[p] == "]" { bd = bd - 1 }
                    p = p + 1
                }
            }
            // If immediately followed by `=` (and NOT `==`), it's an LHS.
            let mut is_lhs = 0
            if p < n && toks[p] == "=" {
                let mut is_assign = 1
                if p + 1 < n && toks[p + 1] == "=" { is_assign = 0 }
                if is_assign == 1 { is_lhs = 1 }
            }
            if is_lhs == 0 { return 1 }
        }
        k = k + 1
    }
    return 0
}

// RFC 006 §5 ABC combinational-loop SSA fix —
// `_rv_collect_blocking_lhs` walks a for-body token sequence and
// returns the set of LHS-base names that are *blocking-assigned* (`=`,
// NOT `<=`) somewhere inside. These are the signals whose `read in
// iter k` should see `write in iter k-1` — i.e. they need per-iter
// SSA versioning.
//
// Detection rule: a `=` token at paren-depth 0 marks an assignment.
// The LHS-base is the most-recent identifier before that `=`, skipping
// balanced `[...]` indexing groups (which may be packed-part-select
// `[hi:lo]`, integer-fold `[const]`, or runtime `[wire]`).
//
// Skipped: `<=` (sequential), `==` / `!=` / `<=` (comparison — although
// `<=` is itself ambiguous in Verilog; here `=` immediately preceded by
// `<` is treated as non-blocking and skipped via the `out[k-1] == "<"`
// guard). The tokenizer is presumed to emit `<=`, `==`, `!=`, `<=`,
// `>=` as either single tokens or as adjacent `<`+`=`/`=`+`=` pairs;
// both cases are handled.
fn _rv_collect_blocking_lhs(toks: [str]) -> [str] {
    let mut result: [str] = []
    let n = len(toks)
    let mut paren_depth = 0
    let mut k = 0
    while k < n {
        let t = toks[k]
        if t == "(" { paren_depth = paren_depth + 1; k = k + 1; continue }
        if t == ")" { paren_depth = paren_depth - 1; k = k + 1; continue }
        if t == "=" && paren_depth == 0 {
            let mut is_blocking = 1
            if k > 0 && toks[k - 1] == "<" { is_blocking = 0 }
            if k > 0 && toks[k - 1] == ">" { is_blocking = 0 }
            if k > 0 && toks[k - 1] == "!" { is_blocking = 0 }
            if k > 0 && toks[k - 1] == "=" { is_blocking = 0 }
            if k + 1 < n && toks[k + 1] == "=" { is_blocking = 0 }
            if is_blocking == 1 {
                let mut j = k - 1
                while j >= 0 && toks[j] == "]" {
                    let mut bd = 1
                    j = j - 1
                    while j >= 0 && bd > 0 {
                        if toks[j] == "]" { bd = bd + 1 }
                        if toks[j] == "[" { bd = bd - 1 }
                        j = j - 1
                    }
                }
                if j >= 0 {
                    let lhs = toks[j]
                    let mut found = 0
                    let mut i = 0
                    while i < len(result) {
                        if result[i] == lhs { found = 1 }
                        i = i + 1
                    }
                    if found == 0 { result = result.push(lhs) }
                }
            }
        }
        k = k + 1
    }
    return result
}

// RFC 006 §5 ABC combinational-loop SSA fix —
// `_rv_ssa_rename_toks` produces a per-iter rewritten token sequence:
//   - All occurrences of any name in `tracked` are substituted with
//     `<name>__ssa<k_read>` (read version).
//   - Then every LHS-base position (detected on the ORIGINAL token
//     stream, same algorithm as `_rv_collect_blocking_lhs`) whose base
//     is in `tracked` is re-substituted to `<name>__ssa<k_write>` —
//     the write version that the conditional connect_cond emit will
//     target.
// The caller is responsible for pre-loop alias (`connect(s__ssa0, s)`),
// per-iter default-hold (`connect(s__ssa<k+1>, s__ssa<k>)` unconditional),
// and post-loop publish (`connect(s, s__ssa<P>)`).
fn _rv_ssa_rename_toks(toks: [str], tracked: [str], k_read: int, k_write: int) -> [str] {
    let n = len(toks)
    // Pass 1: blanket read-substitution.
    let mut out: [str] = []
    let mut i = 0
    while i < n {
        let t = toks[i]
        let mut found = 0
        let mut j = 0
        while j < len(tracked) {
            if tracked[j] == t { found = 1 }
            j = j + 1
        }
        if found == 1 {
            out = out.push(t + "__ssa" + str(k_read))
        } else {
            out = out.push(t)
        }
        i = i + 1
    }
    // Pass 2: LHS-position write-redirect (LHS detection on ORIGINAL
    // toks so positions align 1:1 with `out`).
    let mut paren_depth = 0
    let mut k = 0
    while k < n {
        let t = toks[k]
        if t == "(" { paren_depth = paren_depth + 1; k = k + 1; continue }
        if t == ")" { paren_depth = paren_depth - 1; k = k + 1; continue }
        if t == "=" && paren_depth == 0 {
            let mut is_blocking = 1
            if k > 0 && toks[k - 1] == "<" { is_blocking = 0 }
            if k > 0 && toks[k - 1] == ">" { is_blocking = 0 }
            if k > 0 && toks[k - 1] == "!" { is_blocking = 0 }
            if k > 0 && toks[k - 1] == "=" { is_blocking = 0 }
            if k + 1 < n && toks[k + 1] == "=" { is_blocking = 0 }
            if is_blocking == 1 {
                let mut jp = k - 1
                while jp >= 0 && toks[jp] == "]" {
                    let mut bd = 1
                    jp = jp - 1
                    while jp >= 0 && bd > 0 {
                        if toks[jp] == "]" { bd = bd + 1 }
                        if toks[jp] == "[" { bd = bd - 1 }
                        jp = jp - 1
                    }
                }
                if jp >= 0 {
                    let lhs_orig = toks[jp]
                    let mut is_tracked = 0
                    let mut ti = 0
                    while ti < len(tracked) {
                        if tracked[ti] == lhs_orig { is_tracked = 1 }
                        ti = ti + 1
                    }
                    if is_tracked == 1 {
                        let new_tok = lhs_orig + "__ssa" + str(k_write)
                        let mut rebuilt: [str] = []
                        let mut z = 0
                        let nm = len(out)
                        while z < nm {
                            if z == jp {
                                rebuilt = rebuilt.push(new_tok)
                            } else {
                                rebuilt = rebuilt.push(out[z])
                            }
                            z = z + 1
                        }
                        out = rebuilt
                    }
                }
            }
        }
        k = k + 1
    }
    return out
}

fn _rv_emit_body_v2(
    body_toks: [str],
    cond_wire: str,
    m_in: Module,
    tab_in: SymTab,
    is_clocked: int,
    clk_wire: str,
    tracked_in: [str]
) -> RvEmitV2Res {
    let mut m = m_in
    let mut tab = tab_in
    let mut tracked = tracked_in
    let mut bp = 0
    let n = len(body_toks)
    while bp < n {
        let t0 = body_toks[bp]
        if t0 == ";" { bp = bp + 1; continue }
        // ── `begin … end` wrapper — strip & recurse with same guard.
        if t0 == "begin" {
            bp = bp + 1
            let mut sd = 1
            let mut inner: [str] = []
            while bp < n && sd > 0 {
                let tt = body_toks[bp]
                if tt == "begin" { sd = sd + 1 }
                if tt == "end" {
                    sd = sd - 1
                    if sd == 0 { bp = bp + 1; break }
                }
                inner = inner.push(tt)
                bp = bp + 1
            }
            let sub = _rv_emit_body_v2(inner, cond_wire, m, tab, is_clocked, clk_wire, tracked)
            m = sub.m
            tracked = sub.tracked_lhs
            continue
        }
        // ── `if (cond) THEN [else ELSE]` — recurse with composed guard.
        if t0 == "if" {
            bp = bp + 1
            // collect ( cond )
            let mut inner_cond: [str] = []
            if bp < n && body_toks[bp] == "(" {
                bp = bp + 1
                let mut pd = 1
                while bp < n {
                    let pt = body_toks[bp]
                    if pt == "(" { pd = pd + 1; inner_cond = inner_cond.push(pt); bp = bp + 1; continue }
                    if pt == ")" {
                        pd = pd - 1
                        if pd == 0 { bp = bp + 1; break }
                        inner_cond = inner_cond.push(pt); bp = bp + 1; continue
                    }
                    inner_cond = inner_cond.push(pt); bp = bp + 1
                }
            }
            // collect THEN body (begin/end OR single stmt to `;`)
            let mut then_toks: [str] = []
            if bp < n && body_toks[bp] == "begin" {
                bp = bp + 1
                let mut sd = 1
                while bp < n {
                    let tt = body_toks[bp]
                    if tt == "begin" { sd = sd + 1; then_toks = then_toks.push(tt); bp = bp + 1; continue }
                    if tt == "end" {
                        sd = sd - 1
                        if sd == 0 { bp = bp + 1; break }
                        then_toks = then_toks.push(tt); bp = bp + 1; continue
                    }
                    then_toks = then_toks.push(tt); bp = bp + 1
                }
            } else {
                // single statement (may be nested-if or for) — collect with
                // structural-balance tracking like the for-body walker.
                let mut pdepth = 0
                let mut bdepth = 0
                while bp < n {
                    let tt = body_toks[bp]
                    if tt == "(" || tt == "[" { pdepth = pdepth + 1 }
                    if tt == ")" || tt == "]" { pdepth = pdepth - 1 }
                    if tt == "begin" { bdepth = bdepth + 1; then_toks = then_toks.push(tt); bp = bp + 1; continue }
                    if tt == "end" {
                        bdepth = bdepth - 1
                        then_toks = then_toks.push(tt); bp = bp + 1
                        if pdepth == 0 && bdepth == 0 {
                            if bp < n && body_toks[bp] == "else" { continue }
                            break
                        }
                        continue
                    }
                    if tt == ";" && pdepth == 0 && bdepth == 0 {
                        then_toks = then_toks.push(tt); bp = bp + 1
                        if bp < n && body_toks[bp] == "else" { continue }
                        break
                    }
                    then_toks = then_toks.push(tt); bp = bp + 1
                }
            }
            // optional ELSE
            let mut has_else = 0
            let mut else_toks: [str] = []
            if bp < n && body_toks[bp] == "else" {
                has_else = 1
                bp = bp + 1
                if bp < n && body_toks[bp] == "begin" {
                    bp = bp + 1
                    let mut sd = 1
                    while bp < n {
                        let tt = body_toks[bp]
                        if tt == "begin" { sd = sd + 1; else_toks = else_toks.push(tt); bp = bp + 1; continue }
                        if tt == "end" {
                            sd = sd - 1
                            if sd == 0 { bp = bp + 1; break }
                            else_toks = else_toks.push(tt); bp = bp + 1; continue
                        }
                        else_toks = else_toks.push(tt); bp = bp + 1
                    }
                } else {
                    let mut pdepth = 0
                    let mut bdepth = 0
                    while bp < n {
                        let tt = body_toks[bp]
                        if tt == "(" || tt == "[" { pdepth = pdepth + 1 }
                        if tt == ")" || tt == "]" { pdepth = pdepth - 1 }
                        if tt == "begin" { bdepth = bdepth + 1; else_toks = else_toks.push(tt); bp = bp + 1; continue }
                        if tt == "end" {
                            bdepth = bdepth - 1
                            else_toks = else_toks.push(tt); bp = bp + 1
                            if pdepth == 0 && bdepth == 0 { break }
                            continue
                        }
                        if tt == ";" && pdepth == 0 && bdepth == 0 {
                            else_toks = else_toks.push(tt); bp = bp + 1; break
                        }
                        else_toks = else_toks.push(tt); bp = bp + 1
                    }
                }
            }
            // elaborate inner cond → cond-wire
            let ier = _rv_elab_expr(inner_cond, 0, m, 1, tab)
            if len(ier.err) > 0 { continue }
            m = ier.m
            // THEN guard = outer AND inner
            let mut then_guard = ier.wire
            if len(cond_wire) > 0 {
                let andw = _rv_fresh_wire(m)
                m = rtlil_module_add_wire(m, rtlil_wire(andw, 1, 0, 0))
                let mut andc = rtlil_cell(andw + "$and", "$and", 0)
                andc = rtlil_cell_connect(andc, "A", cond_wire)
                andc = rtlil_cell_connect(andc, "B", ier.wire)
                andc = rtlil_cell_connect(andc, "Y", andw)
                m = rtlil_module_add_cell(m, andc)
                then_guard = andw
            }
            let then_sub = _rv_emit_body_v2(then_toks, then_guard, m, tab, is_clocked, clk_wire, tracked)
            m = then_sub.m
            tracked = then_sub.tracked_lhs
            // ELSE guard = outer AND NOT(inner)
            if has_else == 1 {
                let notw = _rv_fresh_wire(m)
                m = rtlil_module_add_wire(m, rtlil_wire(notw, 1, 0, 0))
                let mut notc = rtlil_cell(notw + "$c", "$logic_not", 0)
                notc = rtlil_cell_connect(notc, "A", ier.wire)
                notc = rtlil_cell_connect(notc, "Y", notw)
                m = rtlil_module_add_cell(m, notc)
                let mut else_guard = notw
                if len(cond_wire) > 0 {
                    let andw2 = _rv_fresh_wire(m)
                    m = rtlil_module_add_wire(m, rtlil_wire(andw2, 1, 0, 0))
                    let mut andc2 = rtlil_cell(andw2 + "$and", "$and", 0)
                    andc2 = rtlil_cell_connect(andc2, "A", cond_wire)
                    andc2 = rtlil_cell_connect(andc2, "B", notw)
                    andc2 = rtlil_cell_connect(andc2, "Y", andw2)
                    m = rtlil_module_add_cell(m, andc2)
                    else_guard = andw2
                }
                let else_sub = _rv_emit_body_v2(else_toks, else_guard, m, tab, is_clocked, clk_wire, tracked)
                m = else_sub.m
                tracked = else_sub.tracked_lhs
            }
            continue
        }
        // ── `for (gv = init; cond; gv = step) body` — static unroll.
        if t0 == "for" {
            bp = bp + 1
            if bp >= n || body_toks[bp] != "(" { continue }
            bp = bp + 1
            if bp >= n { continue }
            let fgv = body_toks[bp]
            bp = bp + 1
            if bp >= n || body_toks[bp] != "=" { continue }
            bp = bp + 1
            let mut finit: [str] = []
            while bp < n {
                let tt = body_toks[bp]
                if tt == ";" { bp = bp + 1; break }
                finit = finit.push(tt); bp = bp + 1
            }
            let f_init_ev = _rv_eval_expr(finit, 0, tab, 1)
            if len(f_init_ev.err) > 0 { continue }
            tab = symtab_put(tab, fgv, f_init_ev.value)
            let mut fcond: [str] = []
            while bp < n {
                let tt = body_toks[bp]
                if tt == ";" { bp = bp + 1; break }
                fcond = fcond.push(tt); bp = bp + 1
            }
            if bp < n { bp = bp + 1 }     // skip gv name in step
            if bp < n && body_toks[bp] == "=" { bp = bp + 1 }
            let mut fstep: [str] = []
            while bp < n {
                let tt = body_toks[bp]
                if tt == ")" { bp = bp + 1; break }
                fstep = fstep.push(tt); bp = bp + 1
            }
            // body: begin/end or single statement (track depth to find end)
            let mut for_body: [str] = []
            if bp < n && body_toks[bp] == "begin" {
                bp = bp + 1
                let mut sd = 1
                while bp < n {
                    let tt = body_toks[bp]
                    if tt == "begin" { sd = sd + 1; for_body = for_body.push(tt); bp = bp + 1; continue }
                    if tt == "end" {
                        sd = sd - 1
                        if sd == 0 { bp = bp + 1; break }
                        for_body = for_body.push(tt); bp = bp + 1; continue
                    }
                    for_body = for_body.push(tt); bp = bp + 1
                }
            } else {
                let mut pdepth = 0
                let mut bdepth = 0
                while bp < n {
                    let tt = body_toks[bp]
                    if tt == "(" || tt == "[" { pdepth = pdepth + 1 }
                    if tt == ")" || tt == "]" { pdepth = pdepth - 1 }
                    if tt == "begin" { bdepth = bdepth + 1; for_body = for_body.push(tt); bp = bp + 1; continue }
                    if tt == "end" {
                        bdepth = bdepth - 1
                        for_body = for_body.push(tt); bp = bp + 1
                        if pdepth == 0 && bdepth == 0 { break }
                        continue
                    }
                    if tt == ";" && pdepth == 0 && bdepth == 0 {
                        for_body = for_body.push(tt); bp = bp + 1; break
                    }
                    for_body = for_body.push(tt); bp = bp + 1
                }
            }
            // unroll. (RFC 006 §5 SSA fix does NOT fire here: v2 helper
            // is invoked only from the sequential with-else fallback
            // path (L4094) — the combinational fire site is in the
            // top-level `_rv_parse_always` for-handler at L4124, where
            // the per-iter SSA rename + pre/post alias emit lives.)
            let mut fiter = 0
            while fiter < 1024 {
                let fcv = _rv_eval_expr(fcond, 0, tab, 1)
                if len(fcv.err) > 0 { break }
                if fcv.value == 0 { break }
                let iter_sub = _rv_emit_body_v2(for_body, cond_wire, m, tab, is_clocked, clk_wire, tracked)
                m = iter_sub.m
                tracked = iter_sub.tracked_lhs
                let f_step_ev = _rv_eval_expr(fstep, 0, tab, 1)
                if len(f_step_ev.err) > 0 { break }
                tab = symtab_put(tab, fgv, f_step_ev.value)
                fiter = fiter + 1
            }
            continue
        }
        // ── leaf statement: `LHS [op] RHS ;` (with optional [idx] [idx2]).
        // Collect until `;` at depth 0.
        let mut stmt: [str] = []
        let mut pd = 0
        let mut bd = 0
        while bp < n {
            let tt = body_toks[bp]
            if tt == "(" || tt == "[" { pd = pd + 1 }
            if tt == ")" || tt == "]" { pd = pd - 1 }
            if tt == "begin" { bd = bd + 1 }
            if tt == "end" { bd = bd - 1 }
            stmt = stmt.push(tt); bp = bp + 1
            if tt == ";" && pd == 0 && bd == 0 { break }
        }
        if len(stmt) < 4 { continue }
        if stmt[len(stmt) - 1] != ";" { continue }
        // Find the LHS extent and operator. LHS may be:
        //   (a) simple-name  →  op at stmt[1]
        //   (b) name [ idx ] →  op at stmt[idx_close + 1]
        //   (c) name [ idx1 ] [ idx2 ] → 2-D (graceful skip)
        let lhs_base = stmt[0]
        let mut op_pos = 0 - 1
        let mut idx1_toks: [str] = []
        let mut has_idx1 = 0
        let mut has_idx2 = 0
        if stmt[1] == "<=" || stmt[1] == "=" {
            op_pos = 1
        } else if stmt[1] == "[" {
            has_idx1 = 1
            let mut depth = 1
            let mut p = 2
            while p < len(stmt) && depth > 0 {
                if stmt[p] == "[" { depth = depth + 1; idx1_toks = idx1_toks.push(stmt[p]); p = p + 1; continue }
                if stmt[p] == "]" {
                    depth = depth - 1
                    if depth == 0 { p = p + 1; break }
                    idx1_toks = idx1_toks.push(stmt[p]); p = p + 1; continue
                }
                idx1_toks = idx1_toks.push(stmt[p]); p = p + 1
            }
            // optional second [ idx2 ] — 2-D, graceful skip
            if p < len(stmt) && stmt[p] == "[" {
                has_idx2 = 1
                let mut d2 = 1
                p = p + 1
                while p < len(stmt) && d2 > 0 {
                    if stmt[p] == "[" { d2 = d2 + 1 }
                    if stmt[p] == "]" {
                        d2 = d2 - 1
                        if d2 == 0 { p = p + 1; break }
                    }
                    p = p + 1
                }
            }
            if p < len(stmt) && (stmt[p] == "<=" || stmt[p] == "=") { op_pos = p }
        }
        if has_idx2 == 1 { continue }              // 2-D — honest skip
        if op_pos <= 0 { continue }
        let op = stmt[op_pos]
        if op == "<=" && is_clocked == 0 { continue }
        if op == "="  && is_clocked == 1 { continue }
        // Collect RHS tokens (between op_pos+1 and trailing `;`)
        let mut rhs: [str] = []
        let mut ri = op_pos + 1
        while ri < len(stmt) - 1 { rhs = rhs.push(stmt[ri]); ri = ri + 1 }
        let rer = _rv_elab_expr(rhs, 0, m, 1, tab)
        if len(rer.err) > 0 { continue }
        m = rer.m
        // ── leaf emission (Phase 3e per-LHS D-wire model) ──
        // For clocked writes: emit `connect_cond(<lhs>__d, rhs, guard)`
        //   and track <lhs> for $dff stitching at the always-handler
        //   level. The <lhs>__d wire is the shared per-LHS D-input that
        //   `pass_proc_mux` folds via the cond-tagged rows.
        // For combinational writes: emit `connect_cond(<lhs>, rhs, guard)`
        //   directly (no $dff needed). pass_proc_mux still folds.
        // Resolve LHS wire name(s).
        if has_idx1 == 0 {
            // simple LHS
            let lhs = lhs_base
            if is_clocked == 1 {
                let dw = _rv_v2_dwire(lhs)
                if rtlil_find_wire(m, dw) < 0 {
                    m = rtlil_module_add_wire(m, rtlil_wire(dw, 1, 0, 0))
                }
                m = rtlil_module_connect_cond(m, dw, rer.wire, cond_wire)
                tracked = _rv_v2_track(tracked, lhs)
            } else {
                m = rtlil_module_connect_cond(m, lhs, rer.wire, cond_wire)
            }
            continue
        }
        // indexed LHS: try const-fold first
        let ev = _rv_eval_expr(idx1_toks, 0, tab, 1)
        if len(ev.err) == 0 {
            // static idx — name[const] is a wire
            let lhs = lhs_base + "[" + str(ev.value) + "]"
            if is_clocked == 1 {
                let dw = _rv_v2_dwire(lhs)
                if rtlil_find_wire(m, dw) < 0 {
                    m = rtlil_module_add_wire(m, rtlil_wire(dw, 1, 0, 0))
                }
                m = rtlil_module_connect_cond(m, dw, rer.wire, cond_wire)
                tracked = _rv_v2_track(tracked, lhs)
            } else {
                m = rtlil_module_connect_cond(m, lhs, rer.wire, cond_wire)
            }
            continue
        }
        // dyn idx — per-element ($eq + $and) chain composes a per-slot
        // guard; each slot emits one cond-tagged row (lhs[i]__d <= rhs
        // when index==i AND outer_guard).
        let bound = _rv_array_bound(m, lhs_base)
        if bound <= 0 { continue }
        let ier2 = _rv_elab_expr(idx1_toks, 0, m, 1, tab)
        if len(ier2.err) > 0 { continue }
        m = ier2.m
        let mut dk = 0
        while dk < bound {
            let elem = lhs_base + "[" + str(dk) + "]"
            // const wire for dk
            let cdk = "$const_" + str(dk)
            if rtlil_find_wire(m, cdk) < 0 {
                m = rtlil_module_add_wire(m, rtlil_wire(cdk, 1, 0, 0))
            }
            let eq_y = _rv_fresh_wire(m)
            m = rtlil_module_add_wire(m, rtlil_wire(eq_y, 1, 0, 0))
            let mut eqc = rtlil_cell(eq_y + "$eq", "$eq", 0)
            eqc = rtlil_cell_connect(eqc, "A", ier2.wire)
            eqc = rtlil_cell_connect(eqc, "B", cdk)
            eqc = rtlil_cell_connect(eqc, "Y", eq_y)
            m = rtlil_module_add_cell(m, eqc)
            let mut sel_w = eq_y
            if len(cond_wire) > 0 {
                let en_y = _rv_fresh_wire(m)
                m = rtlil_module_add_wire(m, rtlil_wire(en_y, 1, 0, 0))
                let mut andc = rtlil_cell(en_y + "$and", "$and", 0)
                andc = rtlil_cell_connect(andc, "A", cond_wire)
                andc = rtlil_cell_connect(andc, "B", eq_y)
                andc = rtlil_cell_connect(andc, "Y", en_y)
                m = rtlil_module_add_cell(m, andc)
                sel_w = en_y
            }
            if is_clocked == 1 {
                let dw = _rv_v2_dwire(elem)
                if rtlil_find_wire(m, dw) < 0 {
                    m = rtlil_module_add_wire(m, rtlil_wire(dw, 1, 0, 0))
                }
                m = rtlil_module_connect_cond(m, dw, rer.wire, sel_w)
                tracked = _rv_v2_track(tracked, elem)
            } else {
                m = rtlil_module_connect_cond(m, elem, rer.wire, sel_w)
            }
            dk = dk + 1
        }
    }
    return RvEmitV2Res { m: m, tracked_lhs: tracked, ok: 1 }
}

// CLEAN-ROOM helper: emit $dff cells per tracked LHS plus an
// unconditional feedback-default connect (lhs__d <= lhs) so that
// pass_proc_mux folds the cond-tagged rows into a $mux chain feeding
// each $dff. Run AFTER all `_rv_emit_body_v2` calls for an always.
fn _rv_emit_dff_for_tracked(
    m_in: Module,
    tracked: [str],
    clk_wire: str
) -> Module {
    let mut m = m_in
    let mut i = 0
    while i < len(tracked) {
        let lhs = tracked[i]
        let dw = _rv_v2_dwire(lhs)
        // feedback default — no cond tag, becomes pass_proc_mux's default
        m = rtlil_module_connect(m, dw, lhs)
        // $dff with D=<lhs>__d, Q=<lhs>
        let dn = "$rvff$" + str(len(m.cells))
        let mut dc = rtlil_cell(dn, "$dff", 0)
        dc = rtlil_cell_connect(dc, "CLK", clk_wire)
        dc = rtlil_cell_connect(dc, "D", dw)
        dc = rtlil_cell_connect(dc, "Q", lhs)
        m = rtlil_module_add_cell(m, dc)
        i = i + 1
    }
    return m
}

// CLEAN-ROOM: parse a Verilog `always @( SENS ) [begin] BODY [end]`
// block and lower it to an RTLIL register/combinational cell tree.
// SCOPE — this body landing covers the basic case yosys's `proc` pass
// emits for routinely-written RTL:
//   - @( posedge | negedge CLK )  →  $dff cell per nonblocking assign
//   - @( * ) or @*               →  $-tree of muxes (single assign:
//                                    direct connect; if/else and for
//                                    are honest gaps for this commit)
//   - body may be `begin ... end` or a single statement
//   - single nonblocking `VAR <= EXPR ;` or blocking `VAR = EXPR ;`
//
// Honest gaps (rfc_003 idiom: fail-loud, not silent): nested if/else,
// case, for-loops, multi-statement bodies require the full `proc` pass
// — those land in a follow-up commit with the SigSpec/Process model.
fn _rv_parse_always(st_in: PState, m_in: Module, tab: SymTab) -> RvStep {
    let mut st = _ps_take(st_in)            // consume "always"
    let mut m = m_in
    if _ps_peek(st) != "@" {
        return RvStep {
            st: _ps_fail(st, "read_verilog: always: expected `@`"),
            m: m
        }
    }
    st = _ps_take(st)                       // consume "@"
    // sensitivity list: @* or @( ... )
    let mut is_clocked = 0
    let mut clk_wire = ""
    let mut clk_edge = 0                    // 1 = posedge, 2 = negedge
    if _ps_peek(st) == "*" {
        st = _ps_take(st)
    } else {
        if _ps_peek(st) != "(" {
            return RvStep {
                st: _ps_fail(st, "read_verilog: always: expected `(` or `*`"),
                m: m
            }
        }
        st = _ps_take(st)
        let first = _ps_peek(st)
        if first == "*" {
            st = _ps_take(st)
        } else {
            if first == "posedge" || first == "negedge" {
                is_clocked = 1
                if first == "posedge" {
                    clk_edge = 1
                } else {
                    clk_edge = 2
                }
                st = _ps_take(st)
                clk_wire = _ps_peek(st)
                st = _ps_take(st)
            } else {
                return RvStep {
                    st: _ps_fail(st, "read_verilog: always sensitivity `"
                        + first + "` not in subset (need `*`, `posedge`, `negedge`)"),
                    m: m
                }
            }
        }
        if _ps_peek(st) != ")" {
            return RvStep {
                st: _ps_fail(st, "read_verilog: always: expected `)`"),
                m: m
            }
        }
        st = _ps_take(st)
    }

    // body: optional begin / end
    let mut has_begin = 0
    if _ps_peek(st) == "begin" {
        has_begin = 1
        st = _ps_take(st)
    }

    // Parse one or more statements. With `begin`, loop until `end`;
    // otherwise a single statement. Supported per-statement shape:
    //   VAR [ <const> ]  (`<=` | `=`)  EXPR ;
    // If / for / case / function-call inside the body are honest gaps
    // (those need the full yosys `proc` pass — separate commit).
    let mut keep_going = 1
    while keep_going == 1 {
        if has_begin == 1 && _ps_peek(st) == "end" {
            st = _ps_take(st)
            break
        }
        // RFC 073 SCAFFOLD: pass_proc_mux site — phase-1 expands the
        // single-statement if/else cond-mux below to multi-statement
        // bodies + nested if/else chains + case statements (IEEE
        // 1364-2005 §9.5; Yosys proc_mux behavioural reference). The
        // current narrow shape already emits `$mux` correctly; phase-1
        // generalises the detection so multi-driver condition-guarded
        // writes flow here BEFORE pass_clean_multidriver collapses them.
        // No behaviour change this cycle — marker + RFC link only.
        // `if (...) [begin] body [end] [else [begin] body [end]]` inside
        // always — proc-pass core sub-step #1: cond-mux emission for the
        // narrow shape `if (COND) LHS <= TRHS ; else LHS <= ERHS ;` with
        // the same simple-name LHS in a posedge-clocked always. Tokens of
        // cond / then-body / else-body are collected first; on a shape
        // match the cond-mux is emitted as `$mux(A=else_rhs, B=then_rhs,
        // S=cond, Y=mux_y)` wired to `$dff(CLK, D=mux_y, Q=lhs)`. Any
        // other shape (multi-statement body, mixed-LHS, blocking, no-else,
        // combinational always, nested if, indexed LHS) falls back to
        // skip-with-no-emit — same effective behaviour as the prior
        // if-skip commit, so router_d4 still parses end-to-end while
        // scope grows incrementally.
        if _ps_peek(st) == "if" {
            st = _ps_take(st)
            let mut cond_toks: [str] = []
            if _ps_peek(st) == "(" {
                st = _ps_take(st)
                let mut pdepth = 1
                while st.pos < len(st.toks) {
                    let pt = _ps_peek(st)
                    if pt == "(" {
                        pdepth = pdepth + 1
                        cond_toks = cond_toks.push(pt)
                        st = _ps_take(st)
                        continue
                    }
                    if pt == ")" {
                        pdepth = pdepth - 1
                        if pdepth == 0 { st = _ps_take(st); break }
                        cond_toks = cond_toks.push(pt)
                        st = _ps_take(st)
                        continue
                    }
                    cond_toks = cond_toks.push(pt)
                    st = _ps_take(st)
                }
            }
            let mut then_toks: [str] = []
            if _ps_peek(st) == "begin" {
                st = _ps_take(st)
                let mut sdepth = 1
                while st.pos < len(st.toks) {
                    let st_ = _ps_peek(st)
                    if st_ == "begin" {
                        sdepth = sdepth + 1
                        then_toks = then_toks.push(st_)
                        st = _ps_take(st)
                        continue
                    }
                    if st_ == "end" {
                        sdepth = sdepth - 1
                        if sdepth == 0 { st = _ps_take(st); break }
                        then_toks = then_toks.push(st_)
                        st = _ps_take(st)
                        continue
                    }
                    then_toks = then_toks.push(st_)
                    st = _ps_take(st)
                }
            } else {
                while st.pos < len(st.toks) {
                    let pt = _ps_peek(st)
                    if pt == ";" {
                        then_toks = then_toks.push(pt)
                        st = _ps_take(st)
                        break
                    }
                    then_toks = then_toks.push(pt)
                    st = _ps_take(st)
                }
            }
            let mut has_else = 0
            let mut else_toks: [str] = []
            if _ps_peek(st) == "else" {
                has_else = 1
                st = _ps_take(st)
                if _ps_peek(st) == "begin" {
                    st = _ps_take(st)
                    let mut sd2 = 1
                    while st.pos < len(st.toks) {
                        let et = _ps_peek(st)
                        if et == "begin" {
                            sd2 = sd2 + 1
                            else_toks = else_toks.push(et)
                            st = _ps_take(st)
                            continue
                        }
                        if et == "end" {
                            sd2 = sd2 - 1
                            if sd2 == 0 { st = _ps_take(st); break }
                            else_toks = else_toks.push(et)
                            st = _ps_take(st)
                            continue
                        }
                        else_toks = else_toks.push(et)
                        st = _ps_take(st)
                    }
                } else {
                    // RFC 073 Phase 1 — nested else-if chain: the else-body
                    // may itself be a complete `if ( cond ) body [else REST]`
                    // statement (or chain thereof). Walk forward absorbing
                    // each `if` + cond-parens + body-stmt (or begin/end) +
                    // optional `else`-tail, repeating while the `else` tail
                    // is another `if`. The legacy collector below the
                    // `if`-special-case keeps the bare-else terminator
                    // semantics (single `;`).
                    if _ps_peek(st) == "if" {
                        let mut chain_more = 1
                        while chain_more == 1 && st.pos < len(st.toks) {
                            chain_more = 0
                            // consume "if"
                            else_toks = else_toks.push(_ps_peek(st))
                            st = _ps_take(st)
                            // consume `( … )`
                            if _ps_peek(st) == "(" {
                                else_toks = else_toks.push(_ps_peek(st))
                                st = _ps_take(st)
                                let mut pdepth = 1
                                while st.pos < len(st.toks) && pdepth > 0 {
                                    let pt = _ps_peek(st)
                                    if pt == "(" { pdepth = pdepth + 1 }
                                    if pt == ")" { pdepth = pdepth - 1 }
                                    else_toks = else_toks.push(pt)
                                    st = _ps_take(st)
                                }
                            }
                            // body — single statement (`LHS [op] RHS ;`) OR
                            // `begin … end` block (track begin/end depth).
                            if _ps_peek(st) == "begin" {
                                else_toks = else_toks.push(_ps_peek(st))
                                st = _ps_take(st)
                                let mut bd = 1
                                while st.pos < len(st.toks) && bd > 0 {
                                    let bt = _ps_peek(st)
                                    if bt == "begin" { bd = bd + 1 }
                                    if bt == "end" { bd = bd - 1 }
                                    else_toks = else_toks.push(bt)
                                    st = _ps_take(st)
                                }
                            } else {
                                while st.pos < len(st.toks) {
                                    let bt = _ps_peek(st)
                                    if bt == ";" {
                                        else_toks = else_toks.push(bt)
                                        st = _ps_take(st)
                                        break
                                    }
                                    else_toks = else_toks.push(bt)
                                    st = _ps_take(st)
                                }
                            }
                            // optional `else` tail: if another `if` follows,
                            // keep looping to absorb the chain; otherwise
                            // absorb the bare-else statement (single ; or
                            // begin/end) and stop.
                            if _ps_peek(st) == "else" {
                                else_toks = else_toks.push(_ps_peek(st))
                                st = _ps_take(st)
                                if _ps_peek(st) == "if" {
                                    chain_more = 1
                                } else {
                                    // bare-else default
                                    if _ps_peek(st) == "begin" {
                                        else_toks = else_toks.push(_ps_peek(st))
                                        st = _ps_take(st)
                                        let mut bd2 = 1
                                        while st.pos < len(st.toks) && bd2 > 0 {
                                            let bt2 = _ps_peek(st)
                                            if bt2 == "begin" { bd2 = bd2 + 1 }
                                            if bt2 == "end" { bd2 = bd2 - 1 }
                                            else_toks = else_toks.push(bt2)
                                            st = _ps_take(st)
                                        }
                                    } else {
                                        while st.pos < len(st.toks) {
                                            let bt2 = _ps_peek(st)
                                            if bt2 == ";" {
                                                else_toks = else_toks.push(bt2)
                                                st = _ps_take(st)
                                                break
                                            }
                                            else_toks = else_toks.push(bt2)
                                            st = _ps_take(st)
                                        }
                                    }
                                }
                            }
                        }
                    } else {
                        while st.pos < len(st.toks) {
                            let et = _ps_peek(st)
                            if et == ";" {
                                else_toks = else_toks.push(et)
                                st = _ps_take(st)
                                break
                            }
                            else_toks = else_toks.push(et)
                            st = _ps_take(st)
                        }
                    }
                }
            }
            // ── cond-mux shape detection: both bodies = single
            //    `LHS <= RHS ;` (or `=`). LHS may be simple-name
            //    (then_toks[0]) OR indexed with a const-foldable index
            //    (then_toks[0] `[` const_expr `]`) — yielding the
            //    canonical `name[idx_value]` SigSpec string. ──
            let mut t_ok = 0
            let mut t_lhs = ""
            let mut t_rhs: [str] = []
            let mut t_op_str = ""
            let mut t_dyn_base = ""
            let mut t_dyn_idx_toks: [str] = []
            let mut t_dyn_op_str = ""
            let mut t_dyn_rhs: [str] = []
            let mut t_dyn_ok = 0
            if len(then_toks) >= 4 {
                let mut op_pos = 0 - 1
                let mut lhs_str = ""
                if then_toks[1] == "<=" || then_toks[1] == "=" {
                    lhs_str = then_toks[0]
                    op_pos = 1
                }
                if then_toks[1] == "[" {
                    let mut bd = 1
                    let mut p = 2
                    let mut idx_toks: [str] = []
                    while p < len(then_toks) {
                        if then_toks[p] == "[" { bd = bd + 1 }
                        if then_toks[p] == "]" {
                            bd = bd - 1
                            if bd == 0 { break }
                        }
                        idx_toks = idx_toks.push(then_toks[p])
                        p = p + 1
                    }
                    if p < len(then_toks) && then_toks[p] == "]" {
                        if p + 1 < len(then_toks) {
                            if then_toks[p + 1] == "<=" || then_toks[p + 1] == "=" {
                                let ev = _rv_eval_expr(idx_toks, 0, tab, 1)
                                if len(ev.err) == 0 {
                                    lhs_str = then_toks[0] + "[" + str(ev.value) + "]"
                                    op_pos = p + 1
                                }
                            }
                        }
                    }
                }
                // sub-step #4d dynamic-index detection — indexed LHS
                // whose index expression does NOT const-fold. We still
                // capture the (base, idx_toks) so the emit path can
                // build a P-way $eq+$and+$mux+$dff chain via
                // _rv_array_bound. Only fires when the simple/static
                // paths above failed to capture op_pos.
                if op_pos <= 0 && then_toks[1] == "[" {
                    let mut bd2 = 1
                    let mut p2 = 2
                    let mut idx2_toks: [str] = []
                    while p2 < len(then_toks) {
                        if then_toks[p2] == "[" { bd2 = bd2 + 1 }
                        if then_toks[p2] == "]" {
                            bd2 = bd2 - 1
                            if bd2 == 0 { break }
                        }
                        idx2_toks = idx2_toks.push(then_toks[p2])
                        p2 = p2 + 1
                    }
                    if p2 < len(then_toks) && then_toks[p2] == "]" {
                        if p2 + 1 < len(then_toks) {
                            if then_toks[p2 + 1] == "<=" || then_toks[p2 + 1] == "=" {
                                let mut last_s3 = 0 - 1
                                let mut sc3 = 0
                                let mut tj = 0
                                while tj < len(then_toks) {
                                    if then_toks[tj] == ";" {
                                        last_s3 = tj
                                        sc3 = sc3 + 1
                                    }
                                    tj = tj + 1
                                }
                                if sc3 == 1 && last_s3 == len(then_toks) - 1 {
                                    t_dyn_ok = 1
                                    t_dyn_base = then_toks[0]
                                    t_dyn_idx_toks = idx2_toks
                                    t_dyn_op_str = then_toks[p2 + 1]
                                    let mut tj2 = p2 + 2
                                    while tj2 < len(then_toks) - 1 {
                                        t_dyn_rhs = t_dyn_rhs.push(then_toks[tj2])
                                        tj2 = tj2 + 1
                                    }
                                }
                            }
                        }
                    }
                }
                if op_pos > 0 {
                    let mut last_semi = 0 - 1
                    let mut semi_count = 0
                    let mut ti = 0
                    while ti < len(then_toks) {
                        if then_toks[ti] == ";" {
                            last_semi = ti
                            semi_count = semi_count + 1
                        }
                        ti = ti + 1
                    }
                    if semi_count == 1 && last_semi == len(then_toks) - 1 {
                        t_ok = 1
                        t_lhs = lhs_str
                        t_op_str = then_toks[op_pos]
                        let mut ti2 = op_pos + 1
                        while ti2 < len(then_toks) - 1 {
                            t_rhs = t_rhs.push(then_toks[ti2])
                            ti2 = ti2 + 1
                        }
                    }
                }
            }
            let mut e_ok = 0
            let mut e_lhs = ""
            let mut e_rhs: [str] = []
            let mut e_op_str = ""
            if has_else == 1 {
                if len(else_toks) >= 4 {
                    let mut e_op_pos = 0 - 1
                    let mut e_lhs_str = ""
                    if else_toks[1] == "<=" || else_toks[1] == "=" {
                        e_lhs_str = else_toks[0]
                        e_op_pos = 1
                    }
                    if else_toks[1] == "[" {
                        let mut ebd = 1
                        let mut ep = 2
                        let mut e_idx_toks: [str] = []
                        while ep < len(else_toks) {
                            if else_toks[ep] == "[" { ebd = ebd + 1 }
                            if else_toks[ep] == "]" {
                                ebd = ebd - 1
                                if ebd == 0 { break }
                            }
                            e_idx_toks = e_idx_toks.push(else_toks[ep])
                            ep = ep + 1
                        }
                        if ep < len(else_toks) && else_toks[ep] == "]" {
                            if ep + 1 < len(else_toks) {
                                if else_toks[ep + 1] == "<=" || else_toks[ep + 1] == "=" {
                                    let eev = _rv_eval_expr(e_idx_toks, 0, tab, 1)
                                    if len(eev.err) == 0 {
                                        e_lhs_str = else_toks[0] + "[" + str(eev.value) + "]"
                                        e_op_pos = ep + 1
                                    }
                                }
                            }
                        }
                    }
                    if e_op_pos > 0 {
                        let mut last_s2 = 0 - 1
                        let mut sc2 = 0
                        let mut ei = 0
                        while ei < len(else_toks) {
                            if else_toks[ei] == ";" {
                                last_s2 = ei
                                sc2 = sc2 + 1
                            }
                            ei = ei + 1
                        }
                        if sc2 == 1 && last_s2 == len(else_toks) - 1 {
                            e_ok = 1
                            e_lhs = e_lhs_str
                            e_op_str = else_toks[e_op_pos]
                            let mut ei2 = e_op_pos + 1
                            while ei2 < len(else_toks) - 1 {
                                e_rhs = e_rhs.push(else_toks[ei2])
                                ei2 = ei2 + 1
                            }
                        }
                    }
                }
            }
            // RFC 073 Phase 1 — NESTED else-if chain detection
            //   `if (c1) lhs <= a ; else if (c2) lhs <= b ; … else lhs <= d ;`
            // lowers to a left-deep `$mux` tree: the deepest else binds first,
            // then each outer cond wraps the previous result. We iteratively
            // peel `else if` levels off `else_toks`, building parallel arrays
            // of (cond_expr, rhs_expr) pairs for the cascade arms plus a
            // final default `rhs`. The leftmost `if` (already in `cond_toks`
            // + `then_toks`) is arm-0, and is parsed identically to the 2-arm
            // base case by the existing single-arm shape detector (t_ok above).
            // @cite IEEE 1364-2005 §9.4 (control statements) + Yosys
            // passes/proc/proc_mux.cc behaviour (left-deep cascade); clean-room.
            let mut nested_chain_ok = 0
            let mut nested_chain_lhs = ""
            let mut nested_chain_op  = ""
            let mut nested_conds: [[str]]  = []
            let mut nested_rhss:  [[str]]  = []
            let mut nested_default: [str]  = []
            if t_ok == 1 && has_else == 1 && len(else_toks) >= 1 && else_toks[0] == "if" {
                // arm-0 = the original (cond_toks, t_rhs); seed the chain.
                nested_chain_lhs = t_lhs
                nested_chain_op  = t_op_str
                nested_conds = nested_conds.push(cond_toks)
                nested_rhss  = nested_rhss.push(t_rhs)
                // Iterate over the `else_toks` list, peeling `if ( c ) body
                // [ else REST ]` levels. `body` here is the same narrow
                // shape `LHS [op] RHS ;` used by t_ok above; LHS must match
                // nested_chain_lhs, op must match nested_chain_op.
                let mut work: [str] = else_toks
                let mut walk_ok = 1
                let mut have_default = 0
                while len(work) > 0 && walk_ok == 1 && have_default == 0 {
                    if work[0] != "if" {
                        // bare-else default arm: body shape `LHS [op] RHS ;`.
                        if len(work) < 4 {
                            walk_ok = 0
                        } else {
                            if work[0] == nested_chain_lhs
                               && work[1] == nested_chain_op {
                                // last token must be `;`, exactly one `;`.
                                let mut last_s = 0 - 1
                                let mut sc = 0
                                let mut ti = 0
                                while ti < len(work) {
                                    if work[ti] == ";" {
                                        last_s = ti
                                        sc = sc + 1
                                    }
                                    ti = ti + 1
                                }
                                if sc == 1 && last_s == len(work) - 1 {
                                    let mut def_rhs: [str] = []
                                    let mut ti2 = 2
                                    while ti2 < len(work) - 1 {
                                        def_rhs = def_rhs.push(work[ti2])
                                        ti2 = ti2 + 1
                                    }
                                    nested_default = def_rhs
                                    have_default = 1
                                } else {
                                    walk_ok = 0
                                }
                            } else {
                                walk_ok = 0
                            }
                        }
                    } else {
                        // peel `if ( c ) body [ else REST ]`
                        // consume "if"
                        let mut p = 1
                        if p >= len(work) || work[p] != "(" { walk_ok = 0 }
                        let mut arm_cond: [str] = []
                        if walk_ok == 1 {
                            p = p + 1   // past "("
                            let mut pdepth = 1
                            while p < len(work) && pdepth > 0 {
                                let tt = work[p]
                                if tt == "(" {
                                    pdepth = pdepth + 1
                                    arm_cond = arm_cond.push(tt)
                                    p = p + 1
                                    continue
                                }
                                if tt == ")" {
                                    pdepth = pdepth - 1
                                    if pdepth == 0 {
                                        p = p + 1
                                        break
                                    }
                                    arm_cond = arm_cond.push(tt)
                                    p = p + 1
                                    continue
                                }
                                arm_cond = arm_cond.push(tt)
                                p = p + 1
                            }
                            if pdepth != 0 { walk_ok = 0 }
                        }
                        // body = `LHS [op] RHS ;` — collect through next ";".
                        let mut arm_body: [str] = []
                        if walk_ok == 1 {
                            while p < len(work) {
                                let tt = work[p]
                                if tt == ";" {
                                    arm_body = arm_body.push(tt)
                                    p = p + 1
                                    break
                                }
                                arm_body = arm_body.push(tt)
                                p = p + 1
                            }
                            if len(arm_body) < 4 {
                                walk_ok = 0
                            } else {
                                if arm_body[0] != nested_chain_lhs
                                   || arm_body[1] != nested_chain_op {
                                    walk_ok = 0
                                }
                            }
                        }
                        if walk_ok == 1 {
                            let mut arm_rhs: [str] = []
                            let mut bi = 2
                            while bi < len(arm_body) - 1 {
                                arm_rhs = arm_rhs.push(arm_body[bi])
                                bi = bi + 1
                            }
                            nested_conds = nested_conds.push(arm_cond)
                            nested_rhss  = nested_rhss.push(arm_rhs)
                            // optional `else REST` — REST is the next work[]
                            if p < len(work) && work[p] == "else" {
                                let mut rest: [str] = []
                                p = p + 1
                                while p < len(work) {
                                    rest = rest.push(work[p])
                                    p = p + 1
                                }
                                work = rest
                            } else {
                                // chain terminated without explicit default;
                                // for combinational that's a latch (no-emit);
                                // for clocked the implicit default is the
                                // feedback `lhs` itself (hold).
                                work = []
                                if is_clocked == 1 {
                                    nested_default = [nested_chain_lhs]
                                    have_default = 1
                                } else {
                                    walk_ok = 0
                                }
                            }
                        }
                    }
                }
                if walk_ok == 1 && have_default == 1
                   && len(nested_conds) == len(nested_rhss)
                   && len(nested_conds) >= 2 {
                    // operator gating per is_clocked, same as 2-arm case
                    let mut op_ok = 0
                    if nested_chain_op == "<=" && is_clocked == 1 { op_ok = 1 }
                    if nested_chain_op == "="  && is_clocked == 0 { op_ok = 1 }
                    if op_ok == 1 { nested_chain_ok = 1 }
                }
            }
            if nested_chain_ok == 1 {
                // Emit left-deep mux tree. Build from the deepest arm:
                //   inner_0 = default
                //   for k = (N-1) down to 0:
                //     mux_k = $mux(S=cond_k, A=inner_{k}, B=rhs_k, Y=fresh)
                //     inner_{k+1} = mux_k
                // Final inner = sink (Q of $dff for clocked, direct connect
                // for comb). N = len(nested_conds).
                let der = _rv_elab_expr(nested_default, 0, m, 1, tab)
                if len(der.err) == 0 {
                    m = der.m
                    let mut inner_w = der.wire
                    let mut emit_ok = 1
                    let mut idx_k = len(nested_conds) - 1
                    while idx_k >= 0 && emit_ok == 1 {
                        let cer = _rv_elab_expr(nested_conds[idx_k], 0, m, 1, tab)
                        if len(cer.err) > 0 { emit_ok = 0 }
                        if emit_ok == 1 {
                            m = cer.m
                            let rer = _rv_elab_expr(nested_rhss[idx_k], 0, m, 1, tab)
                            if len(rer.err) > 0 { emit_ok = 0 }
                            if emit_ok == 1 {
                                m = rer.m
                                let mux_y = _rv_fresh_wire(m)
                                m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
                                let mux_n = "$rvmux$" + str(len(m.cells))
                                let mut mc = rtlil_cell(mux_n, "$mux", 0)
                                mc = rtlil_cell_connect(mc, "A", inner_w)
                                mc = rtlil_cell_connect(mc, "B", rer.wire)
                                mc = rtlil_cell_connect(mc, "S", cer.wire)
                                mc = rtlil_cell_connect(mc, "Y", mux_y)
                                m = rtlil_module_add_cell(m, mc)
                                inner_w = mux_y
                            }
                        }
                        idx_k = idx_k - 1
                    }
                    if emit_ok == 1 {
                        if is_clocked == 1 {
                            let dn = "$rvff$" + str(len(m.cells))
                            let mut dc = rtlil_cell(dn, "$dff", 0)
                            dc = rtlil_cell_connect(dc, "CLK", clk_wire)
                            dc = rtlil_cell_connect(dc, "D", inner_w)
                            dc = rtlil_cell_connect(dc, "Q", nested_chain_lhs)
                            m = rtlil_module_add_cell(m, dc)
                            let _eg = clk_edge
                        } else {
                            m = rtlil_module_connect(m, nested_chain_lhs, inner_w)
                        }
                    }
                }
            }
            // Operator must match across both branches; non-blocking
            // `<=` belongs to posedge-clocked always (→ $dff sink),
            // blocking `=` belongs to combinational always (→ direct
            // connect sink). Any mismatch → fall back to skip-no-emit.
            let mut op_match = 0
            if t_ok == 1 && e_ok == 1 {
                if t_op_str == e_op_str {
                    let topr = t_op_str
                    if topr == "<=" && is_clocked == 1 { op_match = 1 }
                    if topr == "=" && is_clocked == 0 { op_match = 1 }
                }
            }
            if nested_chain_ok == 0 && t_ok == 1 && e_ok == 1 && t_lhs == e_lhs && op_match == 1 {
                let cer = _rv_elab_expr(cond_toks, 0, m, 1, tab)
                if len(cer.err) == 0 {
                    m = cer.m
                    let ter = _rv_elab_expr(t_rhs, 0, m, 1, tab)
                    if len(ter.err) == 0 {
                        m = ter.m
                        let eer = _rv_elab_expr(e_rhs, 0, m, 1, tab)
                        if len(eer.err) == 0 {
                            m = eer.m
                            let mux_y = _rv_fresh_wire(m)
                            m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
                            let mux_n = "$rvmux$" + str(len(m.cells))
                            let mut mc = rtlil_cell(mux_n, "$mux", 0)
                            mc = rtlil_cell_connect(mc, "A", eer.wire)
                            mc = rtlil_cell_connect(mc, "B", ter.wire)
                            mc = rtlil_cell_connect(mc, "S", cer.wire)
                            mc = rtlil_cell_connect(mc, "Y", mux_y)
                            m = rtlil_module_add_cell(m, mc)
                            if is_clocked == 1 {
                                let dn = "$rvff$" + str(len(m.cells))
                                let mut dc = rtlil_cell(dn, "$dff", 0)
                                dc = rtlil_cell_connect(dc, "CLK", clk_wire)
                                dc = rtlil_cell_connect(dc, "D", mux_y)
                                dc = rtlil_cell_connect(dc, "Q", t_lhs)
                                m = rtlil_module_add_cell(m, dc)
                                let _eg = clk_edge
                            } else {
                                m = rtlil_module_connect(m, t_lhs, mux_y)
                            }
                        }
                    }
                }
            }
            // ── no-else sequential cond-mux (proc-pass sub-step #2b) ──
            //   `if (en) lhs <= d ;` posedge always → $mux(S=en,
            //   A=lhs[feedback], B=d, Y=mux_y) + $dff(D=mux_y, Q=lhs).
            //   Combinational no-else is intentionally NOT covered
            //   (would infer a latch — emit nothing → fallback skip).
            if t_ok == 1 && has_else == 0 && is_clocked == 1 && t_op_str == "<=" {
                let cer = _rv_elab_expr(cond_toks, 0, m, 1, tab)
                if len(cer.err) == 0 {
                    m = cer.m
                    let ter = _rv_elab_expr(t_rhs, 0, m, 1, tab)
                    if len(ter.err) == 0 {
                        m = ter.m
                        let mux_y = _rv_fresh_wire(m)
                        m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
                        let mux_n = "$rvmux$" + str(len(m.cells))
                        let mut mc = rtlil_cell(mux_n, "$mux", 0)
                        mc = rtlil_cell_connect(mc, "A", t_lhs)
                        mc = rtlil_cell_connect(mc, "B", ter.wire)
                        mc = rtlil_cell_connect(mc, "S", cer.wire)
                        mc = rtlil_cell_connect(mc, "Y", mux_y)
                        m = rtlil_module_add_cell(m, mc)
                        let dn = "$rvff$" + str(len(m.cells))
                        let mut dc = rtlil_cell(dn, "$dff", 0)
                        dc = rtlil_cell_connect(dc, "CLK", clk_wire)
                        dc = rtlil_cell_connect(dc, "D", mux_y)
                        dc = rtlil_cell_connect(dc, "Q", t_lhs)
                        m = rtlil_module_add_cell(m, dc)
                        let _eg = clk_edge
                    }
                }
            }
            // ── dynamic-index no-else cond-mux (proc-pass sub-step #4d
            //    emit-chain). `if (en) name [ wire_idx ] <= rhs ;`
            //    posedge always → per-element ($eq + $and + $mux +
            //    $dff) chain × P. Requires _rv_array_bound(m, base)>0;
            //    if 0 (unknown array size) we fall back to skip-no-emit.
            if t_dyn_ok == 1 && has_else == 0 && is_clocked == 1 && t_dyn_op_str == "<=" {
                let bound = _rv_array_bound(m, t_dyn_base)
                if bound > 0 {
                    let cer = _rv_elab_expr(cond_toks, 0, m, 1, tab)
                    if len(cer.err) == 0 {
                        m = cer.m
                        let ier = _rv_elab_expr(t_dyn_idx_toks, 0, m, 1, tab)
                        if len(ier.err) == 0 {
                            m = ier.m
                            let ter = _rv_elab_expr(t_dyn_rhs, 0, m, 1, tab)
                            if len(ter.err) == 0 {
                                m = ter.m
                                let mut dk = 0
                                while dk < bound {
                                    let elem = t_dyn_base + "[" + str(dk) + "]"
                                    let eq_y = _rv_fresh_wire(m)
                                    m = rtlil_module_add_wire(m, rtlil_wire(eq_y, 1, 0, 0))
                                    let mut eqc = rtlil_cell(eq_y + "$eq", "$eq", 0)
                                    eqc = rtlil_cell_connect(eqc, "A", ier.wire)
                                    eqc = rtlil_cell_connect(eqc, "B", str(dk))
                                    eqc = rtlil_cell_connect(eqc, "Y", eq_y)
                                    m = rtlil_module_add_cell(m, eqc)
                                    let en_y = _rv_fresh_wire(m)
                                    m = rtlil_module_add_wire(m, rtlil_wire(en_y, 1, 0, 0))
                                    let mut andc = rtlil_cell(en_y + "$and", "$and", 0)
                                    andc = rtlil_cell_connect(andc, "A", cer.wire)
                                    andc = rtlil_cell_connect(andc, "B", eq_y)
                                    andc = rtlil_cell_connect(andc, "Y", en_y)
                                    m = rtlil_module_add_cell(m, andc)
                                    let mux_y = _rv_fresh_wire(m)
                                    m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
                                    let mut muxc = rtlil_cell(mux_y + "$mux", "$mux", 0)
                                    muxc = rtlil_cell_connect(muxc, "A", elem)
                                    muxc = rtlil_cell_connect(muxc, "B", ter.wire)
                                    muxc = rtlil_cell_connect(muxc, "S", en_y)
                                    muxc = rtlil_cell_connect(muxc, "Y", mux_y)
                                    m = rtlil_module_add_cell(m, muxc)
                                    let dn = "$rvff$" + str(len(m.cells))
                                    let mut dc = rtlil_cell(dn, "$dff", 0)
                                    dc = rtlil_cell_connect(dc, "CLK", clk_wire)
                                    dc = rtlil_cell_connect(dc, "D", mux_y)
                                    dc = rtlil_cell_connect(dc, "Q", elem)
                                    m = rtlil_module_add_cell(m, dc)
                                    let _eg = clk_edge
                                    dk = dk + 1
                                }
                            }
                        }
                    }
                }
            }
            // ── multi-LHS no-else cond-mux (proc-pass sub-step #2c + #4h-a) ──
            //   `if (en) begin lhs1 <= a ; lhs2 <= b ; … end` posedge
            //   always → per-statement $mux(S=en, A=lhs_i[feedback],
            //   B=rhs_i, Y=mux_y_i) + $dff(D=mux_y_i, Q=lhs_i).
            //
            //   #2c: simple-name LHS  — `name <= rhs ;`
            //   #4h-a: static-idx LHS — `name [ <const-expr> ] <= rhs ;`
            //          (router_d4 reset cascade L101-105 unrolled form
            //           after for-in-always landing). The const-fold
            //           value becomes part of the LHS wire name
            //           (`base[N]`) so existing generate-for-unrolled
            //           wire decls are matched.
            //   Dyn-idx LHS (wire-indexed) remains a separate scope
            //   (sub-step #4h-b).
            //   Single-statement covered by #2b above (t_ok==1 path),
            //   so this only fires when t_ok==0 and the collected
            //   then-body splits into ≥2 valid statements.
            if t_ok == 0 && has_else == 0 && is_clocked == 1 && len(then_toks) > 0 {
                let mut stmts: [[str]] = []
                let mut cur: [str] = []
                let mut si = 0
                while si < len(then_toks) {
                    if then_toks[si] == ";" {
                        cur = cur.push(then_toks[si])
                        stmts = stmts.push(cur)
                        cur = []
                        si = si + 1
                        continue
                    }
                    cur = cur.push(then_toks[si])
                    si = si + 1
                }
                let mut all_ok = 1
                if len(stmts) < 2 { all_ok = 0 }
                let mut sj = 0
                while sj < len(stmts) && all_ok == 1 {
                    let s = stmts[sj]
                    if len(s) < 4 { all_ok = 0 }
                    if all_ok == 1 {
                        // #4h-a: detect indexed-LHS prefix `name [ … ]`
                        // and locate the operator (`<=`). For simple-
                        // name LHS the operator is at index 1 as before.
                        let mut lhs_end = 1
                        if s[1] == "[" {
                            let mut depth = 1
                            let mut q = 2
                            while q < len(s) && depth > 0 {
                                if s[q] == "[" { depth = depth + 1 }
                                if s[q] == "]" {
                                    depth = depth - 1
                                    if depth == 0 { q = q + 1; break }
                                }
                                q = q + 1
                            }
                            if depth != 0 { all_ok = 0 }
                            lhs_end = q
                        }
                        if all_ok == 1 && lhs_end >= len(s) { all_ok = 0 }
                        if all_ok == 1 && s[lhs_end] != "<=" { all_ok = 0 }
                        if all_ok == 1 && s[len(s) - 1] != ";" { all_ok = 0 }
                    }
                    sj = sj + 1
                }
                if all_ok == 1 {
                    let cer = _rv_elab_expr(cond_toks, 0, m, 1, tab)
                    if len(cer.err) == 0 {
                        m = cer.m
                        let mut emit_ok = 1
                        let mut sk = 0
                        while sk < len(stmts) && emit_ok == 1 {
                            let s = stmts[sk]
                            // #4h-a: compute slhs (indexed form) + RHS start.
                            let mut slhs = s[0]
                            let mut ri_start = 2
                            if s[1] == "[" {
                                let mut depth = 1
                                let mut q = 2
                                let mut idx_toks: [str] = []
                                while q < len(s) && depth > 0 {
                                    if s[q] == "[" {
                                        depth = depth + 1
                                        idx_toks = idx_toks.push(s[q])
                                        q = q + 1
                                        continue
                                    }
                                    if s[q] == "]" {
                                        depth = depth - 1
                                        if depth == 0 { q = q + 1; break }
                                        idx_toks = idx_toks.push(s[q])
                                        q = q + 1
                                        continue
                                    }
                                    idx_toks = idx_toks.push(s[q])
                                    q = q + 1
                                }
                                let ev = _rv_eval_expr(idx_toks, 0, tab, 1)
                                if len(ev.err) > 0 {
                                    // #4h-b: dyn-idx LHS (wire-indexed) —
                                    // per-element ($eq + $and + $mux + $dff)
                                    // chain × `bound`. Mirrors the single-
                                    // stmt dyn-idx emit (PR #174) but in
                                    // the multi-LHS no-else context.
                                    let bound = _rv_array_bound(m, s[0])
                                    if bound <= 0 {
                                        emit_ok = 0
                                    } else {
                                        let ier = _rv_elab_expr(idx_toks, 0, m, 1, tab)
                                        if len(ier.err) > 0 {
                                            emit_ok = 0
                                        } else {
                                            m = ier.m
                                            let mut srhs_d: [str] = []
                                            let mut ri_d = q + 1
                                            while ri_d < len(s) - 1 {
                                                srhs_d = srhs_d.push(s[ri_d])
                                                ri_d = ri_d + 1
                                            }
                                            let ser_d = _rv_elab_expr(srhs_d, 0, m, 1, tab)
                                            if len(ser_d.err) > 0 {
                                                emit_ok = 0
                                            } else {
                                                m = ser_d.m
                                                let mut dk = 0
                                                while dk < bound {
                                                    let elem = s[0] + "[" + str(dk) + "]"
                                                    let eq_y = _rv_fresh_wire(m)
                                                    m = rtlil_module_add_wire(m, rtlil_wire(eq_y, 1, 0, 0))
                                                    let mut eqc = rtlil_cell(eq_y + "$eq", "$eq", 0)
                                                    eqc = rtlil_cell_connect(eqc, "A", ier.wire)
                                                    eqc = rtlil_cell_connect(eqc, "B", str(dk))
                                                    eqc = rtlil_cell_connect(eqc, "Y", eq_y)
                                                    m = rtlil_module_add_cell(m, eqc)
                                                    let en_y = _rv_fresh_wire(m)
                                                    m = rtlil_module_add_wire(m, rtlil_wire(en_y, 1, 0, 0))
                                                    let mut andc = rtlil_cell(en_y + "$and", "$and", 0)
                                                    andc = rtlil_cell_connect(andc, "A", cer.wire)
                                                    andc = rtlil_cell_connect(andc, "B", eq_y)
                                                    andc = rtlil_cell_connect(andc, "Y", en_y)
                                                    m = rtlil_module_add_cell(m, andc)
                                                    let mux_yd = _rv_fresh_wire(m)
                                                    m = rtlil_module_add_wire(m, rtlil_wire(mux_yd, 1, 0, 0))
                                                    let mut muxc = rtlil_cell(mux_yd + "$mux", "$mux", 0)
                                                    muxc = rtlil_cell_connect(muxc, "A", elem)
                                                    muxc = rtlil_cell_connect(muxc, "B", ser_d.wire)
                                                    muxc = rtlil_cell_connect(muxc, "S", en_y)
                                                    muxc = rtlil_cell_connect(muxc, "Y", mux_yd)
                                                    m = rtlil_module_add_cell(m, muxc)
                                                    let dn2 = "$rvff$" + str(len(m.cells))
                                                    let mut dc2 = rtlil_cell(dn2, "$dff", 0)
                                                    dc2 = rtlil_cell_connect(dc2, "CLK", clk_wire)
                                                    dc2 = rtlil_cell_connect(dc2, "D", mux_yd)
                                                    dc2 = rtlil_cell_connect(dc2, "Q", elem)
                                                    m = rtlil_module_add_cell(m, dc2)
                                                    let _eg2 = clk_edge
                                                    dk = dk + 1
                                                }
                                                // Skip the regular emit path for this stmt
                                                ri_start = -1
                                            }
                                        }
                                    }
                                } else {
                                    slhs = s[0] + "[" + str(ev.value) + "]"
                                    ri_start = q + 1
                                }
                            }
                            if emit_ok == 1 && ri_start >= 0 {
                                let mut srhs: [str] = []
                                let mut ri = ri_start
                                while ri < len(s) - 1 {
                                    srhs = srhs.push(s[ri])
                                    ri = ri + 1
                                }
                                let ser = _rv_elab_expr(srhs, 0, m, 1, tab)
                                if len(ser.err) > 0 {
                                    emit_ok = 0
                                } else {
                                    m = ser.m
                                    let mux_y = _rv_fresh_wire(m)
                                    m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
                                    let mux_n = "$rvmux$" + str(len(m.cells))
                                    let mut mc = rtlil_cell(mux_n, "$mux", 0)
                                    mc = rtlil_cell_connect(mc, "A", slhs)
                                    mc = rtlil_cell_connect(mc, "B", ser.wire)
                                    mc = rtlil_cell_connect(mc, "S", cer.wire)
                                    mc = rtlil_cell_connect(mc, "Y", mux_y)
                                    m = rtlil_module_add_cell(m, mc)
                                    let dn = "$rvff$" + str(len(m.cells))
                                    let mut dc = rtlil_cell(dn, "$dff", 0)
                                    dc = rtlil_cell_connect(dc, "CLK", clk_wire)
                                    dc = rtlil_cell_connect(dc, "D", mux_y)
                                    dc = rtlil_cell_connect(dc, "Q", slhs)
                                    m = rtlil_module_add_cell(m, dc)
                                    let _eg = clk_edge
                                }
                            }
                            sk = sk + 1
                        }
                    }
                }
            }
            // ── multi-LHS with-else cond-mux (proc-pass sub-step #3b) ──
            //   `if (cond) begin lhs1 <= a1 ; lhs2 <= a2 ; … end
            //    else       begin lhs1 <= b1 ; lhs2 <= b2 ; … end`
            //   posedge always → per-statement $mux(S=cond, A=else_rhs_i,
            //   B=then_rhs_i, Y=mux_y_i) + $dff(D=mux_y_i, Q=lhs_i).
            //   Requires same simple-name LHS sequence in both branches;
            //   any mismatch falls back to RFC 073 Phase 3e v2 helper below.
            // RFC 073 Phase 3e — track whether the legacy with-else
            // handler emitted ANY $dff; if not (all_ok==0), the v2
            // helper fallback (L3780+) runs the recursive cond-mux
            // decomposition on each arm. Without this guard, the legacy
            // handler silently dropped mismatched arms (the §5 router's
            // `if (rst) <for> else <for; for; if>` shape).
            let mut _3e_legacy_emitted = 0
            if t_ok == 0 && has_else == 1 && is_clocked == 1 {
                let mut t_stmts: [[str]] = []
                let mut tcur: [str] = []
                let mut tsi = 0
                while tsi < len(then_toks) {
                    if then_toks[tsi] == ";" {
                        tcur = tcur.push(then_toks[tsi])
                        t_stmts = t_stmts.push(tcur)
                        tcur = []
                        tsi = tsi + 1
                        continue
                    }
                    tcur = tcur.push(then_toks[tsi])
                    tsi = tsi + 1
                }
                let mut e_stmts: [[str]] = []
                let mut ecur: [str] = []
                let mut esi = 0
                while esi < len(else_toks) {
                    if else_toks[esi] == ";" {
                        ecur = ecur.push(else_toks[esi])
                        e_stmts = e_stmts.push(ecur)
                        ecur = []
                        esi = esi + 1
                        continue
                    }
                    ecur = ecur.push(else_toks[esi])
                    esi = esi + 1
                }
                let mut all_ok = 1
                if len(t_stmts) != len(e_stmts) { all_ok = 0 }
                if all_ok == 1 && len(t_stmts) < 2 { all_ok = 0 }
                let mut sj = 0
                while sj < len(t_stmts) && all_ok == 1 {
                    let ts = t_stmts[sj]
                    let es = e_stmts[sj]
                    if len(ts) < 4 { all_ok = 0 }
                    if all_ok == 1 && len(es) < 4 { all_ok = 0 }
                    if all_ok == 1 {
                        if ts[1] != "<=" { all_ok = 0 }
                    }
                    if all_ok == 1 {
                        if es[1] != "<=" { all_ok = 0 }
                    }
                    if all_ok == 1 {
                        if ts[0] != es[0] { all_ok = 0 }
                    }
                    if all_ok == 1 {
                        if ts[len(ts) - 1] != ";" { all_ok = 0 }
                    }
                    if all_ok == 1 {
                        if es[len(es) - 1] != ";" { all_ok = 0 }
                    }
                    sj = sj + 1
                }
                if all_ok == 1 {
                    let cer = _rv_elab_expr(cond_toks, 0, m, 1, tab)
                    if len(cer.err) == 0 {
                        m = cer.m
                        let mut emit_ok = 1
                        let mut sk = 0
                        while sk < len(t_stmts) && emit_ok == 1 {
                            let ts = t_stmts[sk]
                            let es = e_stmts[sk]
                            let slhs = ts[0]
                            let mut trhs: [str] = []
                            let mut ri = 2
                            while ri < len(ts) - 1 {
                                trhs = trhs.push(ts[ri])
                                ri = ri + 1
                            }
                            let mut erhs: [str] = []
                            let mut ri2 = 2
                            while ri2 < len(es) - 1 {
                                erhs = erhs.push(es[ri2])
                                ri2 = ri2 + 1
                            }
                            let ter2 = _rv_elab_expr(trhs, 0, m, 1, tab)
                            if len(ter2.err) > 0 { emit_ok = 0 }
                            if emit_ok == 1 {
                                m = ter2.m
                                let eer2 = _rv_elab_expr(erhs, 0, m, 1, tab)
                                if len(eer2.err) > 0 { emit_ok = 0 }
                                if emit_ok == 1 {
                                    m = eer2.m
                                    let mux_y = _rv_fresh_wire(m)
                                    m = rtlil_module_add_wire(m, rtlil_wire(mux_y, 1, 0, 0))
                                    let mux_n = "$rvmux$" + str(len(m.cells))
                                    let mut mc = rtlil_cell(mux_n, "$mux", 0)
                                    mc = rtlil_cell_connect(mc, "A", eer2.wire)
                                    mc = rtlil_cell_connect(mc, "B", ter2.wire)
                                    mc = rtlil_cell_connect(mc, "S", cer.wire)
                                    mc = rtlil_cell_connect(mc, "Y", mux_y)
                                    m = rtlil_module_add_cell(m, mc)
                                    let dn = "$rvff$" + str(len(m.cells))
                                    let mut dc = rtlil_cell(dn, "$dff", 0)
                                    dc = rtlil_cell_connect(dc, "CLK", clk_wire)
                                    dc = rtlil_cell_connect(dc, "D", mux_y)
                                    dc = rtlil_cell_connect(dc, "Q", slhs)
                                    m = rtlil_module_add_cell(m, dc)
                                    let _eg = clk_edge
                                    _3e_legacy_emitted = 1
                                }
                            }
                            sk = sk + 1
                        }
                    }
                }
            }
            // ── RFC 073 Phase 3e — with-else NON-MATCHING bodies fallback. ──
            // When all preceding positional handlers bailed (single-LHS
            // pair, multi-LHS positional pair, nested else-if chain),
            // recurse into each arm via `_rv_emit_body_v2` with the cond /
            // !cond guard. The v2 helper handles for-loop static unroll,
            // nested if/else, indexed-LHS (static + dyn), and graceful skip
            // for 2-D indexed LHS (not on §5 area critical path). Each leaf
            // write emits a guarded $dff which the downstream multi-driver
            // pipeline reconciles. Trigger conditions (fall-through pattern):
            //   (a) `t_ok==0` — t-arm shape not captured by positional
            //       handler. Includes router_d{4,6}'s outer `if (rst)
            //       <for> else <for; for; if>` shape.
            //   (b) `t_ok==1 && e_ok==0` — single-LHS THEN-arm matched but
            //       ELSE-arm has multiple statements (`if (c) y<=a; else
            //       begin y<=b; z<=c; end`); the legacy single-LHS handler
            //       silently drops the ELSE-arm's writes. T71 falsifier.
            // In case (b), the legacy single-LHS path ALREADY emitted a
            // $dff for the t_lhs/e_lhs pair before the fallback fires.
            // Re-emitting via v2 would double-drive — guard via the
            // `_3e_legacy_emitted` flag (also set when nested_chain_ok ==
            // 1 or single-LHS shape emitted). @cite IEEE 1364-2005 §9.4 +
            // §10.4.2 + Yosys passes/proc/proc_mux.cc.
            // Mark legacy-emit for single-LHS path (L2863-2896) + nested-
            // chain path (L2799-2850) by checking their preconditions.
            let mut _3e_single_emitted = 0
