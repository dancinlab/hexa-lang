#!hexa strict
// stdlib/yosys/rtlil.hexa — Yosys RTLIL IR data model (CLEAN-ROOM)
//
// @version 0.0.1
// @capabilities [rtlil, ir, parse, emit]
// @stability phase-a (rfc_006 §4 module-1 of 7 — typed core + invariants)
// @since 2026-05-19
//
// CLEAN-ROOM PROVENANCE (design.md Decision 1 — public-surface clean-room)
//   This module re-derives the *public surface* of Yosys' RTLIL
//   (Register-Transfer-Level Intermediate Language) by inspection of
//   upstream source + manual only. No upstream code is copied.
//
//   - upstream code     : kernel/rtlil.h, kernel/rtlil.cc
//                          (RTLIL::Design / Module / Wire / Cell / Process
//                           / SigBit / SigSpec / Const data model)
//   - upstream manual   : https://yosyshq.readthedocs.io/projects/yosys/
//                          en/latest/yosys_internals/formats/rtlil_rep.html
//   - upstream license  : ISC (YosysHQ; LICENSE)
//   - upstream repo     : https://github.com/YosysHQ/yosys (main branch
//                          as of 2026-05-19 re-derivation pass)
//   - absorbed substrate (D18) : none (this module is hexa-native only)
//
// rfc_006 §4: module-1 of 7. typed in-memory design representation
// shared by read_verilog (§4-2) frontend and write_verilog (§4-6)
// backend, mutated by the passes library (§4-3). All other modules in
// this stdlib consume or produce values of these types.
//
// Toolchain limits (rfc_003): no `match`, no tuples — use int-tagged
// structs + dispatcher fns; enum-equality is supported (codegen_c2
// `_is_enum_name` fix landed in hexa-lang main 8ff19d2a) but we keep
// the int-payload idiom for predictability.

// ─── public types ────────────────────────────────────────────────────────

// CLEAN-ROOM (kernel/rtlil.h ::Wire — port direction + bit width)
// dir_kind: 0=internal · 1=input · 2=output · 3=inout
struct Wire {
    name:     str,
    width:    int,
    dir_kind: int,
    port_id:  int,        // 0 if not a port; otherwise 1-based sort order
}

// CLEAN-ROOM (kernel/rtlil.h ::Cell — instance of a typed cell with
// named pin connections; matches RTLIL::Cell::connections SigMap).
struct CellConn {
    pin:  str,            // port name on the cell type (e.g. "A", "Y")
    net:  str,            // wire name in containing module
}

struct Cell {
    name:     str,        // local instance name (unique within module)
    cell_type: str,       // e.g. "$and" or "sky130_fd_sc_hd__nand2_1"
    conns:    [CellConn],
    is_mapped: int,       // 0 = generic ($and/$or/$dff/...), 1 = tech cell
}

// CLEAN-ROOM (kernel/rtlil.h ::Process — sync/comb assignment block;
// post-`proc` pass these are replaced by Cells, so we keep the
// minimal info needed to round-trip through passes.proc).
struct Process {
    name:    str,
    is_sync: int,
    clk:     str,         // wire name of clock (sync only)
    targets: [str],       // assigned wire names
}

// CLEAN-ROOM (kernel/rtlil.h ::Module — container of wires + cells +
// processes + connect statements).
//
// RFC 073 Phase 1 — `connect_cond` is a third parallel array that
// carries the guarding-condition wire name for condition-guarded
// procedural writes (`if (cond) lhs = rhs;` from `_rv_parse_always`).
// Empty string ("") = unconditional connect (the legacy IR shape).
// `pass_proc_mux` (passes.hexa) groups rows with non-empty `cond`
// by `lhs` and emits a left-deep `$mux` tree before
// `pass_clean_multidriver` collapses last-wins. @cite IEEE Std
// 1364-2005 §9.2 (procedural assignment semantics) + Yosys
// passes/proc/proc_mux.cc behaviour (clean-room).
struct Module {
    name:      str,
    wires:     [Wire],
    cells:     [Cell],
    processes: [Process],
    // top-level `assign` (RTLIL ::connect): pairs of (lhs_wire, rhs_wire)
    connect_lhs:  [str],
    connect_rhs:  [str],
    connect_cond: [str],     // "" = unguarded; else wire-name of guarding cond (RFC 073 Phase 1)
}

// CLEAN-ROOM (kernel/rtlil.h ::Design — the root container).
struct Design {
    modules: [Module],
    // top-level provenance: which RTLIL frontend produced this design
    // (e.g. "read_verilog" / "abc_map") — aids the gate-§5 audit trail.
    source:  str,
}

// ─── constructors ────────────────────────────────────────────────────────

// CLEAN-ROOM: empty design factory (kernel/rtlil.cc Design::Design()).
fn rtlil_new_design(source: str) -> Design {
    return Design { modules: [], source: source }
}

// CLEAN-ROOM: empty module factory (kernel/rtlil.cc Module::Module()).
fn rtlil_new_module(name: str) -> Module {
    return Module {
        name:         name,
        wires:        [],
        cells:        [],
        processes:    [],
        connect_lhs:  [],
        connect_rhs:  [],
        connect_cond: [],
    }
}

// CLEAN-ROOM: wire builder (kernel/rtlil.cc Module::addWire).
fn rtlil_wire(name: str, width: int, dir_kind: int, port_id: int) -> Wire {
    return Wire { name: name, width: width, dir_kind: dir_kind, port_id: port_id }
}

// CLEAN-ROOM: cell builder (kernel/rtlil.cc Module::addCell).
fn rtlil_cell(name: str, cell_type: str, is_mapped: int) -> Cell {
    return Cell {
        name:      name,
        cell_type: cell_type,
        conns:     [],
        is_mapped: is_mapped,
    }
}

// CLEAN-ROOM: pin-binding appender (RTLIL::Cell::setPort).
fn rtlil_cell_connect(c: Cell, pin: str, net: str) -> Cell {
    let mut updated = c.conns
    updated = updated.push(CellConn { pin: pin, net: net })
    return Cell {
        name: c.name, cell_type: c.cell_type,
        conns: updated, is_mapped: c.is_mapped
    }
}

// CLEAN-ROOM: module mutation — append wire (Module::addWire).
fn rtlil_module_add_wire(m: Module, w: Wire) -> Module {
    let mut ws = m.wires
    ws = ws.push(w)
    return Module {
        name: m.name, wires: ws, cells: m.cells, processes: m.processes,
        connect_lhs: m.connect_lhs, connect_rhs: m.connect_rhs,
        connect_cond: m.connect_cond
    }
}

// CLEAN-ROOM: module mutation — append cell (Module::addCell).
fn rtlil_module_add_cell(m: Module, c: Cell) -> Module {
    let mut cs = m.cells
    cs = cs.push(c)
    return Module {
        name: m.name, wires: m.wires, cells: cs, processes: m.processes,
        connect_lhs: m.connect_lhs, connect_rhs: m.connect_rhs,
        connect_cond: m.connect_cond
    }
}

// CLEAN-ROOM: module mutation — append process (Module::addProcess).
fn rtlil_module_add_process(m: Module, p: Process) -> Module {
    let mut ps = m.processes
    ps = ps.push(p)
    return Module {
        name: m.name, wires: m.wires, cells: m.cells, processes: ps,
        connect_lhs: m.connect_lhs, connect_rhs: m.connect_rhs,
        connect_cond: m.connect_cond
    }
}

// CLEAN-ROOM: module mutation — append top-level connect (RTLIL::connect).
// Cond defaults to "" (unconditional) for the legacy two-arg API.
fn rtlil_module_connect(m: Module, lhs: str, rhs: str) -> Module {
    let mut l = m.connect_lhs
    let mut r = m.connect_rhs
    let mut c = m.connect_cond
    l = l.push(lhs)
    r = r.push(rhs)
    c = c.push("")
    return Module {
        name: m.name, wires: m.wires, cells: m.cells, processes: m.processes,
        connect_lhs: l, connect_rhs: r, connect_cond: c
    }
}

// RFC 073 Phase 1: condition-guarded top-level connect. `cond` is the
// wire-name of the guarding boolean (the elaborated `if (cond)`); empty
// string means unconditional and behaves identically to rtlil_module_connect.
// pass_proc_mux (passes.hexa) walks these rows and emits a $mux tree
// when the same `lhs` has ≥2 condition-tagged rows. @cite IEEE Std
// 1364-2005 §9.2 + Yosys passes/proc/proc_mux.cc (clean-room).
fn rtlil_module_connect_cond(m: Module, lhs: str, rhs: str, cond: str) -> Module {
    let mut l = m.connect_lhs
    let mut r = m.connect_rhs
    let mut c = m.connect_cond
    l = l.push(lhs)
    r = r.push(rhs)
    c = c.push(cond)
    return Module {
        name: m.name, wires: m.wires, cells: m.cells, processes: m.processes,
        connect_lhs: l, connect_rhs: r, connect_cond: c
    }
}

// CLEAN-ROOM: design mutation — append module (Design::addModule).
fn rtlil_design_add(d: Design, m: Module) -> Design {
    let mut ms = d.modules
    ms = ms.push(m)
    return Design { modules: ms, source: d.source }
}

// ─── lookup helpers ──────────────────────────────────────────────────────

// CLEAN-ROOM: name-based module lookup (Design::module(IdString)).
// Returns module index or -1 (no module).
fn rtlil_find_module(d: Design, name: str) -> int {
    let mut i = 0
    while i < len(d.modules) {
        if d.modules[i].name == name { return i }
        i = i + 1
    }
    return 0 - 1
}

// CLEAN-ROOM: name-based wire lookup (Module::wire(IdString)).
fn rtlil_find_wire(m: Module, name: str) -> int {
    let mut i = 0
    while i < len(m.wires) {
        if m.wires[i].name == name { return i }
        i = i + 1
    }
    return 0 - 1
}

// ─── invariants (for self-test + gate-§5 audit) ──────────────────────────

// CLEAN-ROOM: every cell pin must reference an existing wire — RTLIL's
// "no dangling SigBit" invariant (kernel/rtlil.cc ::Module::check).
// Returns 0 = OK, >0 = first violating index.
fn rtlil_check_no_dangling(m: Module) -> int {
    let mut ci = 0
    while ci < len(m.cells) {
        let conns = m.cells[ci].conns
        let mut pi = 0
        while pi < len(conns) {
            if rtlil_find_wire(m, conns[pi].net) < 0 {
                return ci + 1
            }
            pi = pi + 1
        }
        ci = ci + 1
    }
    return 0
}

// CLEAN-ROOM: module-name uniqueness (Design::check — no two modules
// share a name in the registry).
fn rtlil_check_unique_modules(d: Design) -> int {
    let mut i = 0
    while i < len(d.modules) {
        let mut j = i + 1
        while j < len(d.modules) {
            if d.modules[i].name == d.modules[j].name { return i + 1 }
            j = j + 1
        }
        i = i + 1
    }
    return 0
}

// CLEAN-ROOM: cell count of a given type — used by passes.hexa to
// audit post-techmap cell mixes.
fn rtlil_count_cells_of_type(m: Module, ty: str) -> int {
    let mut n = 0
    let mut i = 0
    while i < len(m.cells) {
        if m.cells[i].cell_type == ty { n = n + 1 }
        i = i + 1
    }
    return n
}

// ─── self-test (rfc_003 idiom — `hexa run stdlib/yosys/rtlil.hexa`) ──────

fn main() {
    let mut fails = 0
    let mut total = 0

    // T1 — empty design has zero modules.
    total = total + 1
    let d0 = rtlil_new_design("test")
    if len(d0.modules) != 0 {
        println("FAIL T1 empty_design"); fails = fails + 1
    }

    // T2 — module/wire round-trip.
    total = total + 1
    let mut m1 = rtlil_new_module("top")
    m1 = rtlil_module_add_wire(m1, rtlil_wire("a", 1, 1, 1))
    m1 = rtlil_module_add_wire(m1, rtlil_wire("b", 1, 1, 2))
    m1 = rtlil_module_add_wire(m1, rtlil_wire("y", 1, 2, 3))
    if len(m1.wires) != 3 {
        println("FAIL T2 wire_add"); fails = fails + 1
    }

    // T3 — cell with port bindings.
    total = total + 1
    let mut c1 = rtlil_cell("u_and", "$and", 0)
    c1 = rtlil_cell_connect(c1, "A", "a")
    c1 = rtlil_cell_connect(c1, "B", "b")
    c1 = rtlil_cell_connect(c1, "Y", "y")
    m1 = rtlil_module_add_cell(m1, c1)
    if len(m1.cells) != 1 {
        println("FAIL T3 cell_add"); fails = fails + 1
    }
    if len(m1.cells[0].conns) != 3 {
        println("FAIL T3b cell_conns"); fails = fails + 1
    }

    // T4 — no-dangling invariant holds for the built module.
    total = total + 1
    if rtlil_check_no_dangling(m1) != 0 {
        println("FAIL T4 no_dangling_clean"); fails = fails + 1
    }

    // T5 — dangling pin detected.
    total = total + 1
    let mut c_bad = rtlil_cell("u_bad", "$or", 0)
    c_bad = rtlil_cell_connect(c_bad, "A", "ghost")
    let m_bad = rtlil_module_add_cell(m1, c_bad)
    if rtlil_check_no_dangling(m_bad) == 0 {
        println("FAIL T5 dangling_detect"); fails = fails + 1
    }

    // T6 — design with module + lookup.
    total = total + 1
    let mut d1 = rtlil_new_design("read_verilog")
    d1 = rtlil_design_add(d1, m1)
    if rtlil_find_module(d1, "top") < 0 {
        println("FAIL T6 find_module"); fails = fails + 1
    }

    // T7 — module-name uniqueness violation detected.
    total = total + 1
    let mut d_dup = rtlil_design_add(d1, m1)
    if rtlil_check_unique_modules(d_dup) == 0 {
        println("FAIL T7 unique_modules"); fails = fails + 1
    }

    // T8 — process round-trip (sync flop placeholder).
    total = total + 1
    let p1 = Process { name: "p_ff", is_sync: 1, clk: "clk", targets: ["q"] }
    let m_p = rtlil_module_add_process(m1, p1)
    if len(m_p.processes) != 1 {
        println("FAIL T8 process_add"); fails = fails + 1
    }

    // T9 — connect statement (RTLIL ::connect).
    total = total + 1
    let m_c = rtlil_module_connect(m1, "y", "a")
    if len(m_c.connect_lhs) != 1 {
        println("FAIL T9 connect"); fails = fails + 1
    }

    // T10 — cell-of-type counter (used by techmap audit).
    total = total + 1
    if rtlil_count_cells_of_type(m1, "$and") != 1 {
        println("FAIL T10 count_cells_of_type"); fails = fails + 1
    }

    // T11 — RFC 073 Phase 1: condition-guarded connect parallel-array.
    //   Legacy `rtlil_module_connect` records cond="" (unguarded);
    //   `rtlil_module_connect_cond` records the supplied cond wire-name.
    //   The three connect_* arrays must stay parallel (same length).
    total = total + 1
    let mut m_cc = rtlil_new_module("cc")
    m_cc = rtlil_module_add_wire(m_cc, rtlil_wire("a", 1, 1, 1))
    m_cc = rtlil_module_add_wire(m_cc, rtlil_wire("b", 1, 1, 2))
    m_cc = rtlil_module_add_wire(m_cc, rtlil_wire("c", 1, 1, 3))
    m_cc = rtlil_module_add_wire(m_cc, rtlil_wire("y", 1, 2, 4))
    m_cc = rtlil_module_connect(m_cc, "y", "a")
    m_cc = rtlil_module_connect_cond(m_cc, "y", "b", "c")
    if len(m_cc.connect_lhs) != 2 || len(m_cc.connect_rhs) != 2
       || len(m_cc.connect_cond) != 2 {
        println("FAIL T11a connect_cond parallel-array length")
        fails = fails + 1
    }
    if m_cc.connect_cond[0] != "" {
        println("FAIL T11b legacy_connect default-cond not empty: `"
            + m_cc.connect_cond[0] + "`")
        fails = fails + 1
    }
    if m_cc.connect_cond[1] != "c" {
        println("FAIL T11c connect_cond not preserved: `"
            + m_cc.connect_cond[1] + "`")
        fails = fails + 1
    }

    if fails > 0 {
        println("rtlil selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("rtlil selftest: " + str(total) + "/" + str(total) + " PASS")
}
