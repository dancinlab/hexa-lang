// stdlib/signal/core_mel_test.hexa
//
// Self-contained smoke test for stdlib/signal/core_mel.hexa. Single-file
// `hexa build` does not flatten `import "stdlib/..."`, so the module body is
// inlined verbatim below (same pattern as core_pitch_test / voss). When
// cross-import flatten lands, swap the inlined block for
// `import "stdlib/signal/core_mel.hexa"` and the assertions stay valid.

// ─── INLINED FROM stdlib/signal/core_mel.hexa ───
let CM_LOG10 = 2.30258509299404568402

fn hz_to_mel(hz: float) -> float {
    return 2595.0 * log(1.0 + hz / 700.0) / CM_LOG10
}

fn mel_to_hz(mel: float) -> float {
    return 700.0 * (pow(10.0, mel / 2595.0) - 1.0)
}

fn mel_filterbank(n_mels: int, n_fft: int, sr: int) -> [float] {
    let bins = n_fft / 2 + 1
    let fmax = sr / 2

    let mel_low = hz_to_mel(0.0)
    let mel_high = hz_to_mel(fmax * 1.0)
    let n_points = n_mels + 2

    let mut mel_points = []
    let mut hz_points = []
    let mut m = 0
    while m < n_points {
        let mel_val = mel_low + (mel_high - mel_low) * m / (n_points - 1)
        mel_points = mel_points.push(mel_val)
        hz_points = hz_points.push(mel_to_hz(mel_val))
        m = m + 1
    }

    let mut bin_points = []
    let mut bp = 0
    while bp < n_points {
        bin_points = bin_points.push(hz_points[bp] * n_fft / sr)
        bp = bp + 1
    }

    let mut fb = []
    let mut mi = 0
    while mi < n_mels {
        let f_left = bin_points[mi]
        let f_center = bin_points[mi + 1]
        let f_right = bin_points[mi + 2]
        let mut b = 0
        while b < bins {
            let bf = b * 1.0
            let mut val = 0.0
            if bf >= f_left && bf <= f_center && f_center > f_left {
                val = (bf - f_left) / (f_center - f_left)
            } else if bf > f_center && bf <= f_right && f_right > f_center {
                val = (f_right - bf) / (f_right - f_center)
            }
            fb = fb.push(val)
            b = b + 1
        }
        mi = mi + 1
    }
    return fb
}

fn spec_to_mel(spec_mag: [float], filterbank: [float], n_mels: int) -> [float] {
    let bins = len(spec_mag)
    let mut mel_out = []
    let mut m = 0
    while m < n_mels {
        let mut sum = 0.0
        let mut b = 0
        while b < bins {
            sum = sum + spec_mag[b] * filterbank[m * bins + b]
            b = b + 1
        }
        mel_out = mel_out.push(sum)
        m = m + 1
    }
    return mel_out
}
// ─── END INLINE ───

let MEL_TOL = 0.001

fn nearf(a: float, b: float, tol: float) -> bool {
    let mut d = a - b
    if d < 0.0 { d = 0.0 - d }
    return d < tol
}

fn check(name: string, ok: bool, pass: int, fail: int) -> [int] {
    if ok {
        print("PASS  " + name)
        return [pass + 1, fail]
    } else {
        print("FAIL  " + name)
        return [pass, fail + 1]
    }
}

fn main() {
    let mut pass = 0
    let mut fail = 0

    // ── hz ↔ mel basics ──────────────────────────────────────────────────
    // hz_to_mel(0) = 0   (log(1) = 0)
    let r1 = check("hz_to_mel(0)=0", nearf(hz_to_mel(0.0), 0.0, MEL_TOL), pass, fail)
    pass = r1[0]; fail = r1[1]

    // mel_to_hz(0) = 0   (10^0 − 1 = 0)
    let r2 = check("mel_to_hz(0)=0", nearf(mel_to_hz(0.0), 0.0, MEL_TOL), pass, fail)
    pass = r2[0]; fail = r2[1]

    // hz_to_mel(700) = 2595 · log10(2) ≈ 781.1771
    // log10(2) = 0.30102999566...
    let r3 = check("hz_to_mel(700)≈781.18", nearf(hz_to_mel(700.0), 781.1771, 0.01), pass, fail)
    pass = r3[0]; fail = r3[1]

    // Round-trip: mel_to_hz(hz_to_mel(1000)) ≈ 1000
    let rt = mel_to_hz(hz_to_mel(1000.0))
    let r4 = check("mel↔hz round-trip(1000)", nearf(rt, 1000.0, 0.01), pass, fail)
    pass = r4[0]; fail = r4[1]

    // Round-trip: hz_to_mel(mel_to_hz(2000)) ≈ 2000
    let rt2 = hz_to_mel(mel_to_hz(2000.0))
    let r5 = check("hz↔mel round-trip(2000)", nearf(rt2, 2000.0, 0.01), pass, fail)
    pass = r5[0]; fail = r5[1]

    // Monotone: mel is strictly increasing in hz
    let r6 = check("hz_to_mel monotone (100<200)", hz_to_mel(100.0) < hz_to_mel(200.0), pass, fail)
    pass = r6[0]; fail = r6[1]

    // ── filterbank shape sanity ──────────────────────────────────────────
    // n_mels=8, n_fft=64, sr=16000 → bins=33, total length = 8·33 = 264
    let fb = mel_filterbank(8, 64, 16000)
    let r7 = check("filterbank length = n_mels · bins (264)", len(fb) == 264, pass, fail)
    pass = r7[0]; fail = r7[1]

    // All weights non-negative
    let mut all_nonneg = true
    let mut k = 0
    while k < len(fb) {
        if fb[k] < 0.0 { all_nonneg = false }
        k = k + 1
    }
    let r8 = check("filterbank weights ≥ 0", all_nonneg, pass, fail)
    pass = r8[0]; fail = r8[1]

    // Row peak ≤ 1 (triangle apex at the center bin)
    let bins = 33
    let mut row0_max = 0.0
    let mut bb = 0
    while bb < bins {
        if fb[bb] > row0_max { row0_max = fb[bb] }
        bb = bb + 1
    }
    let r9 = check("filterbank row peak ≤ 1.0", row0_max <= 1.0 + 0.0001, pass, fail)
    pass = r9[0]; fail = r9[1]

    // Each row has at least one non-zero bin (triangle exists)
    let mut all_rows_nonzero = true
    let mut mm = 0
    while mm < 8 {
        let mut row_sum = 0.0
        let mut bb2 = 0
        while bb2 < bins {
            row_sum = row_sum + fb[mm * bins + bb2]
            bb2 = bb2 + 1
        }
        if row_sum <= 0.0 { all_rows_nonzero = false }
        mm = mm + 1
    }
    let r10 = check("every mel row has triangle support", all_rows_nonzero, pass, fail)
    pass = r10[0]; fail = r10[1]

    // ── spec_to_mel sanity ───────────────────────────────────────────────
    // Build a unit-magnitude spectrum (all bins = 1); each mel band energy
    // = sum of its triangle weights (= row sum).
    let mut spec = []
    let mut si = 0
    while si < bins {
        spec = spec.push(1.0)
        si = si + 1
    }
    let mel_out = spec_to_mel(spec, fb, 8)
    let r11 = check("spec_to_mel output length = n_mels", len(mel_out) == 8, pass, fail)
    pass = r11[0]; fail = r11[1]

    // First mel band energy = row 0 sum
    let mut row0_sum = 0.0
    let mut bb3 = 0
    while bb3 < bins {
        row0_sum = row0_sum + fb[bb3]
        bb3 = bb3 + 1
    }
    let r12 = check("spec_to_mel[0] = row0 sum (unit spec)",
                    nearf(mel_out[0], row0_sum, MEL_TOL), pass, fail)
    pass = r12[0]; fail = r12[1]

    // Zero spectrum → zero mel
    let mut zspec = []
    let mut zi = 0
    while zi < bins {
        zspec = zspec.push(0.0)
        zi = zi + 1
    }
    let zmel = spec_to_mel(zspec, fb, 8)
    let mut zsum = 0.0
    let mut zk = 0
    while zk < 8 {
        zsum = zsum + zmel[zk]
        zk = zk + 1
    }
    let r13 = check("spec_to_mel(zeros) = zeros", nearf(zsum, 0.0, MEL_TOL), pass, fail)
    pass = r13[0]; fail = r13[1]

    print("")
    print("core_mel: " + to_string(pass) + "/" + to_string(pass + fail) + " passed")
    if fail == 0 {
        print("ALL PASS — stdlib/signal/core_mel")
    } else {
        print("FAILURES present")
        exit(1)
    }
}
