// HEXA Standard Library — signal/pearson_autocorr
//
// @version 0.1.0
// @capabilities [pure]
//
// Mean-centered, variance-normalized autocorrelation (the *Pearson* ACF).
// This is the form anima's substrate engines actually compute at all 9
// autocorrelation sites — every one of them mean-centers the signal and
// normalizes by the variance (NOT by ACF[0]=energy). That makes this a
// genuinely DIFFERENT mathematical object from the biased Wiener-Khinchin
// estimator already shipped in stdlib/signal/autocorrelation.hexa.
//
//   Pearson ACF (this module):
//     ACF[k] = Σ_{i=0}^{n-1-k} (x[i]-μ)(x[i+k]-μ) / Σ_{i=0}^{n-1} (x[i]-μ)²
//
//   Biased Wiener-Khinchin (autocorrelation.hexa):
//     ACF[k] = (1/n) · Σ_{i=0}^{n-1-k} x[i] · x[i+k]      (no mean removal)
//
// The biased form measures correlation of the *raw* (DC-loaded) signal with
// itself; the Pearson form measures correlation of the *fluctuations* about
// the mean, normalized to [-1, 1] like the Pearson correlation coefficient.
// A constant-offset signal has biased ACF ≈ 1 at every lag (DC dominates)
// but Pearson ACF undefined (zero variance) — they answer different
// questions. anima's Φ-engine / tension correlation / EEG-band work all want
// the Pearson form, which is why autocorrelation_normalized() (÷ACF[0], no
// mean removal) could not unblock those sites.
//
// No trig is used here, so the project.tape @D stdlib_trig_libm rule is
// trivially satisfied (pure arithmetic).
//
// Public surface (covers anima's 3 observed patterns):
//   pearson_autocorr(x, n, max_lag)      mean-centered normalized ACF[0..max_lag]
//   pearson_autocorr_abs(x, n, max_lag)  |pearson_autocorr| (Φ-engine variant)
//   pearson_autocorr_lag1(x, n)          single lag-1 Pearson value (convenience)
//
// ZERO-VARIANCE GUARD CONVENTION:
//   A constant signal has Σ(x-μ)² = 0, so ACF[k] is mathematically
//   undefined (0/0). This module returns ACF[0] = 1.0 (self-correlation is
//   1 by definition / continuity) and ACF[k] = 0.0 for k > 0. Rationale:
//   1.0 at lag 0 preserves the universal invariant pearson_autocorr[0]==1.0
//   that callers assert; 0.0 elsewhere is the conservative "no detectable
//   fluctuation-correlation" answer rather than a NaN/sentinel that would
//   propagate. The convenience lag-1 helper returns 0.0 under zero variance.
//
// HONEST LIMITS:
//   - O(n × max_lag) naive direct sum. Fine for anima-scale n ≤ ~10k and
//     small max_lag; an FFT-backed O(n log n) path is deferred (same note as
//     autocorrelation.hexa).
//   - float64 accumulator, no Kahan compensation. On bounded signals
//     (|x| < ~1e3) relative error stays ≤ ~1e-12.
//   - Returns empty array on n <= 0 or max_lag < 0. max_lag is clamped to
//     n-1 (lags ≥ n have zero overlap by definition).

// ── pearson_autocorr(x, n, max_lag) → mean-centered normalized ACF[0..max_lag] ──
//
// Returns an array of length (max_lag + 1). ACF[0] == 1.0 by construction.
// Values in [-1, 1]; near +1 at lag k ⇒ strong in-phase periodicity at
// period k, near -1 ⇒ anti-correlation at that lag.

pub fn pearson_autocorr(x: [float], n: int, max_lag: int) -> [float] {
    if n <= 0 { return [] }
    if max_lag < 0 { return [] }
    let mut lag_cap = max_lag
    if lag_cap > n - 1 { lag_cap = n - 1 }

    // mean μ — computed once.
    let mut mean_sum = 0.0
    let mut mi = 0
    while mi < n {
        mean_sum = mean_sum + x[mi]
        mi = mi + 1
    }
    let mu = mean_sum / n

    // variance denominator Σ(x[i]-μ)² (== Pearson ACF[0] numerator).
    let mut denom = 0.0
    let mut di = 0
    while di < n {
        let d = x[di] - mu
        denom = denom + d * d
        di = di + 1
    }

    let mut out = []

    // zero-variance guard: constant signal ⇒ ACF[0]=1.0, ACF[k>0]=0.0.
    if denom == 0.0 {
        let mut zk = 0
        while zk <= lag_cap {
            if zk == 0 {
                out = out.push(1.0)
            } else {
                out = out.push(0.0)
            }
            zk = zk + 1
        }
        return out
    }

    let inv_denom = 1.0 / denom
    let mut k = 0
    while k <= lag_cap {
        let mut sum = 0.0
        let mut i = 0
        while i < n - k {
            sum = sum + (x[i] - mu) * (x[i + k] - mu)
            i = i + 1
        }
        out = out.push(sum * inv_denom)
        k = k + 1
    }
    return out
}

// ── pearson_autocorr_abs(x, n, max_lag) → |pearson_autocorr| ──
//
// Element-wise absolute value of pearson_autocorr. anima's consciousness
// Φ-engine uses |r| (magnitude of correlation, sign-agnostic) so that
// strong anti-correlation contributes the same "structure" signal as strong
// positive correlation. All entries are ≥ 0; entry 0 is 1.0 (or 1.0 under
// the zero-variance guard, since |1.0| = 1.0).

pub fn pearson_autocorr_abs(x: [float], n: int, max_lag: int) -> [float] {
    let r = pearson_autocorr(x, n, max_lag)
    let r_len = len(r)
    if r_len == 0 { return [] }
    let mut out = []
    let mut k = 0
    while k < r_len {
        let v = r[k]
        if v < 0.0 {
            out = out.push(0.0 - v)
        } else {
            out = out.push(v)
        }
        k = k + 1
    }
    return out
}

// ── pearson_autocorr_lag1(x, n) → single lag-1 Pearson value ──
//
// Convenience wrapper returning just the lag-1 Pearson autocorrelation
// (the most common single-lag query: serial dependence between adjacent
// samples). Equivalent to pearson_autocorr(x, n, 1)[1]. Returns 0.0 on
// degenerate input (n < 2 or zero variance — no fluctuation to correlate).

pub fn pearson_autocorr_lag1(x: [float], n: int) -> float {
    if n < 2 { return 0.0 }
    let r = pearson_autocorr(x, n, 1)
    if len(r) < 2 { return 0.0 }
    return r[1]
}
