// Smoke test — stdlib/signal/core_window (Hann / Hamming / Blackman windows).
//
// Import-based canonical test. NOTE: single-file `hexa build` does NOT flatten
// `import "stdlib/..."` (undefined link symbols) — algorithm correctness is
// verified via a self-contained build (see PR), this file is the importable
// regression harness once cross-import flatten lands (M5-style rebootstrap).

import "stdlib/signal/core_window.hexa"

fn _check_flag(name: string, ok: int) -> int {
    if ok == 1 {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name)
    return 1
}

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _close(a: float, b: float) -> int {
    if _abs_f(a - b) < 1.0e-9 { return 1 }
    return 0
}

fn main() {
    let mut fails = 0

    // ── Hann(4) = [0, 0.75, 0.75, 0] (symmetric, denominator N-1=3) ──
    let h0 = hann_window(0, 4)
    let h1 = hann_window(1, 4)
    let h2 = hann_window(2, 4)
    let h3 = hann_window(3, 4)
    fails = fails + _check_flag("hann4_w0==0",  _close(h0, 0.0))
    fails = fails + _check_flag("hann4_w1==0.75", _close(h1, 0.75))
    fails = fails + _check_flag("hann4_w2==0.75", _close(h2, 0.75))
    fails = fails + _check_flag("hann4_w3==0",  _close(h3, 0.0))

    // ── Hann(16): endpoints ~0, center near peak, symmetry w[i]==w[N-1-i] ──
    let n16 = 16
    let mut ep_ok = 1
    if _abs_f(hann_window(0, n16)) > 1.0e-9 { ep_ok = 0 }
    if _abs_f(hann_window(n16 - 1, n16)) > 1.0e-9 { ep_ok = 0 }
    fails = fails + _check_flag("hann16_endpoints~0", ep_ok)
    let mut sym_ok = 1
    let mut si = 0
    while si < n16 / 2 {
        if _close(hann_window(si, n16), hann_window(n16 - 1 - si, n16)) == 0 { sym_ok = 0 }
        si = si + 1
    }
    fails = fails + _check_flag("hann16_symmetric", sym_ok)

    // ── Hamming(4) = [0.08, 0.77, 0.77, 0.08] (raised endpoints) ──
    fails = fails + _check_flag("hamming4_w0==0.08", _close(hamming_window(0, 4), 0.08))
    fails = fails + _check_flag("hamming4_w1==0.77", _close(hamming_window(1, 4), 0.77))
    fails = fails + _check_flag("hamming4_w3==0.08", _close(hamming_window(3, 4), 0.08))

    // ── Blackman(4) = [~0, 0.63, 0.63, ~0] ──
    fails = fails + _check_flag("blackman4_w0~0", if _abs_f(blackman_window(0, 4)) < 1.0e-9 { 1 } else { 0 })
    fails = fails + _check_flag("blackman4_w1==0.63", _close(blackman_window(1, 4), 0.63))
    fails = fails + _check_flag("blackman4_w3~0", if _abs_f(blackman_window(3, 4)) < 1.0e-9 { 1 } else { 0 })

    // ── N<=1 guards return 1.0 ──
    fails = fails + _check_flag("hann_N1_guard", _close(hann_window(0, 1), 1.0))
    fails = fails + _check_flag("hamming_N0_guard", _close(hamming_window(0, 0), 1.0))
    fails = fails + _check_flag("blackman_N1_guard", _close(blackman_window(0, 1), 1.0))

    // ── full-window generator: hann_window_arr(4) matches per-sample ──
    let arr = hann_window_arr(4)
    let mut arr_ok = 1
    if farr_len(arr) != 4 { arr_ok = 0 }
    let mut ai = 0
    while ai < 4 {
        if _close(farr_get(arr, ai), hann_window(ai, 4)) == 0 { arr_ok = 0 }
        ai = ai + 1
    }
    fails = fails + _check_flag("hann_window_arr_matches", arr_ok)
    let _ = farr_free(arr)

    // ── generator length parity for hamming / blackman ──
    let ham = hamming_window_arr(8)
    let bla = blackman_window_arr(8)
    fails = fails + _check_flag("hamming_arr_len8", if farr_len(ham) == 8 { 1 } else { 0 })
    fails = fails + _check_flag("blackman_arr_len8", if farr_len(bla) == 8 { 1 } else { 0 })
    let _ = farr_free(ham)
    let _ = farr_free(bla)

    // ── Periodic Hann(4): denom=N=4, not N-1=3 ──
    // Periodic(0,4) = 0.5*(1-cos(0))    = 0
    // Periodic(1,4) = 0.5*(1-cos(pi/2)) = 0.5
    // Periodic(2,4) = 0.5*(1-cos(pi))   = 1.0
    // Periodic(3,4) = 0.5*(1-cos(3pi/2))= 0.5
    fails = fails + _check_flag("periodic_hann4_w0==0",   _close(hann_window_periodic(0, 4), 0.0))
    fails = fails + _check_flag("periodic_hann4_w1==0.5", _close(hann_window_periodic(1, 4), 0.5))
    fails = fails + _check_flag("periodic_hann4_w2==1.0", _close(hann_window_periodic(2, 4), 1.0))
    fails = fails + _check_flag("periodic_hann4_w3==0.5", _close(hann_window_periodic(3, 4), 0.5))

    // ── Periodic differs from symmetric: at w(N-1) symmetric=0, periodic≠0 ──
    let n_pdiff = 8
    let sym_last = hann_window(n_pdiff - 1, n_pdiff)
    let per_last = hann_window_periodic(n_pdiff - 1, n_pdiff)
    fails = fails + _check_flag("periodic_neq_symmetric_at_last",
        if _abs_f(sym_last - per_last) > 0.1 { 1 } else { 0 })

    // ── Periodic Hann N<=0 guard ──
    fails = fails + _check_flag("periodic_hann_N0_guard", _close(hann_window_periodic(0, 0), 1.0))

    // ── Periodic full-window generator parity ──
    let parr = hann_window_periodic_arr(4)
    let mut parr_ok = 1
    if farr_len(parr) != 4 { parr_ok = 0 }
    let mut pi_idx = 0
    while pi_idx < 4 {
        if _close(farr_get(parr, pi_idx), hann_window_periodic(pi_idx, 4)) == 0 { parr_ok = 0 }
        pi_idx = pi_idx + 1
    }
    fails = fails + _check_flag("hann_periodic_arr_matches", parr_ok)
    let _ = farr_free(parr)

    // ── Half-Hann taper(4): denom=k-1=3, pi (not 2pi). Ascending 0 → 1 ──
    // Taper(0,4) = 0.5*(1-cos(0))     = 0
    // Taper(1,4) = 0.5*(1-cos(pi/3))  = 0.25
    // Taper(2,4) = 0.5*(1-cos(2pi/3)) = 0.75
    // Taper(3,4) = 0.5*(1-cos(pi))    = 1.0
    fails = fails + _check_flag("half_hann_taper4_i0==0",   _close(half_hann_taper(0, 4), 0.0))
    fails = fails + _check_flag("half_hann_taper4_i1==0.25", _close(half_hann_taper(1, 4), 0.25))
    fails = fails + _check_flag("half_hann_taper4_i2==0.75", _close(half_hann_taper(2, 4), 0.75))
    fails = fails + _check_flag("half_hann_taper4_i3==1.0", _close(half_hann_taper(3, 4), 1.0))

    // ── Taper monotone-ascending on [0, k-1] ──
    let k_mono = 8
    let mut mono_ok = 1
    let mut mi = 1
    while mi < k_mono {
        if half_hann_taper(mi, k_mono) <= half_hann_taper(mi - 1, k_mono) { mono_ok = 0 }
        mi = mi + 1
    }
    fails = fails + _check_flag("half_hann_taper_monotone_ascending", mono_ok)

    // ── Taper k<=1 guard ──
    fails = fails + _check_flag("half_hann_taper_k1_guard", _close(half_hann_taper(0, 1), 1.0))

    // ── Taper-arr parity ──
    let tarr = half_hann_taper_arr(4)
    let mut tarr_ok = 1
    if farr_len(tarr) != 4 { tarr_ok = 0 }
    let mut ti = 0
    while ti < 4 {
        if _close(farr_get(tarr, ti), half_hann_taper(ti, 4)) == 0 { tarr_ok = 0 }
        ti = ti + 1
    }
    fails = fails + _check_flag("half_hann_taper_arr_matches", tarr_ok)
    let _ = farr_free(tarr)

    if fails == 0 {
        println("ALL PASS — stdlib/signal/core_window")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
