// Smoke test — stdlib/signal/spectral_density
//
// SELF-CONTAINED build target. Single-file `hexa build` does not flatten
// `import "stdlib/..."`, so module bodies for stdlib/signal/core_fft,
// stdlib/signal/core_window, and stdlib/signal/spectral_density itself
// are inlined VERBATIM below (same pattern as core_griffin_test which
// chains stft + fft + window). When cross-import flatten lands, swap the
// inlined blocks for the imports.
//
// Checks:
//   T1 power_spectral_density returns N/2 + 1 bins
//   T2 sine wave PSD peaks at the correct FFT bin (frequency localization)
//   T3 DC signal PSD energy concentrates at bin 0
//   T4 Welch with window_size=N (full window, single segment) PSD bin
//      count matches window_size/2 + 1
//   T5 Welch noise variance reduction: variance(welch_psd) <
//      variance(power_spectral_density) on a noisy sine

// ════════════════════════════════════════════════════════════════════
// Inlined: stdlib/signal/core_fft (helper subset — fft_native + deps)
// ════════════════════════════════════════════════════════════════════

let CF_PI = 3.14159265358979323846
let CF_TWO_PI = 6.28318530717958647692

fn _cf_bit_reverse(x: int, bits: int) -> int {
    let mut result = 0
    let mut val = x
    let mut i = 0
    while i < bits {
        result = result * 2 + (val - (val / 2) * 2)
        val = val / 2
        i = i + 1
    }
    return result
}

fn _cf_log2_int(n: int) -> int {
    let mut result = 0
    let mut v = n
    while v > 1 {
        v = v / 2
        result = result + 1
    }
    return result
}

fn fft_native(real: [float], imag: [float], n: int) -> [float] {
    if n <= 0 { return [] }
    let bits = _cf_log2_int(n)

    let mut re = []
    let mut im = []
    let mut i = 0
    while i < n {
        let rev = _cf_bit_reverse(i, bits)
        re = re.push(real[rev])
        im = im.push(imag[rev])
        i = i + 1
    }

    let mut stride = 2
    while stride <= n {
        let half_stride = stride / 2
        let mut group = 0
        while group < n {
            let mut k = 0
            while k < half_stride {
                let tw_re = cos(0.0 - CF_TWO_PI * k / stride)
                let tw_im = sin(0.0 - CF_TWO_PI * k / stride)
                let idx_a = group + k
                let idx_b = group + k + half_stride
                let a_re = re[idx_a]
                let a_im = im[idx_a]
                let b_re = re[idx_b]
                let b_im = im[idx_b]
                let t_re = tw_re * b_re - tw_im * b_im
                let t_im = tw_re * b_im + tw_im * b_re
                re[idx_a] = a_re + t_re
                im[idx_a] = a_im + t_im
                re[idx_b] = a_re - t_re
                im[idx_b] = a_im - t_im
                k = k + 1
            }
            group = group + stride
        }
        stride = stride * 2
    }

    let mut out = []
    let mut p = 0
    while p < n {
        out = out.push(re[p])
        out = out.push(im[p])
        p = p + 1
    }
    return out
}

// ════════════════════════════════════════════════════════════════════
// Inlined: stdlib/signal/core_window (hann_window only — what welch uses)
// ════════════════════════════════════════════════════════════════════

let CW_TWO_PI = 6.28318530717958647692

fn hann_window(n: int, N: int) -> float {
    return 0.5 * (1.0 - cos(CW_TWO_PI * n / (N - 1)))
}

// ════════════════════════════════════════════════════════════════════
// Inlined: stdlib/signal/spectral_density (module under test)
// ════════════════════════════════════════════════════════════════════

fn _sd_onesided(spec_flat: [float], n: int) -> [float] {
    let half = n / 2
    let mut out = []
    let mut k = 0
    while k <= half {
        let re = spec_flat[k * 2]
        let im = spec_flat[k * 2 + 1]
        let mag_sq = re * re + im * im
        let mut bin = mag_sq
        if k > 0 {
            if k < half {
                bin = mag_sq * 2.0
            }
        }
        out = out.push(bin)
        k = k + 1
    }
    return out
}

fn power_spectral_density(x: [float], n: int) -> [float] {
    if n <= 0 { return [] }
    let mut imag = []
    let mut i = 0
    while i < n {
        imag = imag.push(0.0)
        i = i + 1
    }
    let spec = fft_native(x, imag, n)
    let one_sided = _sd_onesided(spec, n)
    let inv_n = 1.0 / n
    let mut out = []
    let mut k = 0
    let half = n / 2
    while k <= half {
        out = out.push(one_sided[k] * inv_n)
        k = k + 1
    }
    return out
}

fn welch_psd(x: [float], n: int, window_size: int, overlap: int) -> [float] {
    if n <= 0 { return [] }
    if window_size <= 0 { return [] }
    if window_size > n { return [] }
    if overlap < 0 { return [] }
    if overlap >= window_size { return [] }

    let stride = window_size - overlap
    if stride <= 0 { return [] }
    let n_segs = (n - window_size) / stride + 1
    if n_segs <= 0 { return [] }

    let mut win = []
    let mut win_pow = 0.0
    let mut wi = 0
    while wi < window_size {
        let w = hann_window(wi, window_size)
        win = win.push(w)
        win_pow = win_pow + w * w
        wi = wi + 1
    }
    if win_pow <= 0.0 { return [] }
    let inv_win_pow = 1.0 / win_pow

    let half = window_size / 2
    let mut acc = []
    let mut a = 0
    while a <= half {
        acc = acc.push(0.0)
        a = a + 1
    }

    let mut seg = 0
    while seg < n_segs {
        let start = seg * stride
        let mut seg_re = []
        let mut seg_im = []
        let mut s = 0
        while s < window_size {
            seg_re = seg_re.push(x[start + s] * win[s])
            seg_im = seg_im.push(0.0)
            s = s + 1
        }
        let spec = fft_native(seg_re, seg_im, window_size)
        let one_sided = _sd_onesided(spec, window_size)
        let mut k = 0
        while k <= half {
            acc[k] = acc[k] + one_sided[k] * inv_win_pow
            k = k + 1
        }
        seg = seg + 1
    }

    let inv_segs = 1.0 / n_segs
    let mut out = []
    let mut k2 = 0
    while k2 <= half {
        out = out.push(acc[k2] * inv_segs)
        k2 = k2 + 1
    }
    return out
}

// ════════════════════════════════════════════════════════════════════
// Test harness
// ════════════════════════════════════════════════════════════════════

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _check_flag(name: string, ok: int) -> int {
    if ok == 1 {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name)
    return 1
}

let SD_TOL = 1.0e-9
let SD_PI = 3.14159265358979323846

// Mean of an array
fn _mean(arr: [float], len_arr: int) -> float {
    if len_arr <= 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < len_arr {
        s = s + arr[i]
        i = i + 1
    }
    return s / len_arr
}

// Variance of an array (population)
fn _variance(arr: [float], len_arr: int) -> float {
    if len_arr <= 0 { return 0.0 }
    let mu = _mean(arr, len_arr)
    let mut s = 0.0
    let mut i = 0
    while i < len_arr {
        let d = arr[i] - mu
        s = s + d * d
        i = i + 1
    }
    return s / len_arr
}

// Argmax over a one-sided PSD (ignoring DC bin 0)
fn _argmax_excluding_dc(arr: [float], len_arr: int) -> int {
    let mut best = 1
    let mut best_v = arr[1]
    let mut i = 2
    while i < len_arr {
        if arr[i] > best_v {
            best_v = arr[i]
            best = i
        }
        i = i + 1
    }
    return best
}

// Simple LCG for deterministic pseudo-random noise (Park-Miller MINSTD)
fn _lcg_next(state_in: int) -> int {
    return (state_in * 48271) - (state_in * 48271 / 2147483647) * 2147483647
}

fn _lcg_uniform(state_in: int) -> float {
    return state_in * 1.0 / 2147483647
}

fn main() {
    let mut fails = 0

    // ── T1: power_spectral_density returns N/2 + 1 bins ──
    let N1 = 8
    let mut x1 = []
    let mut i1 = 0
    while i1 < N1 {
        x1 = x1.push(1.0)
        i1 = i1 + 1
    }
    let psd1 = power_spectral_density(x1, N1)
    let mut t1_ok = 1
    if len(psd1) != N1 / 2 + 1 { t1_ok = 0 }
    fails = fails + _check_flag("T1_psd_returns_half_plus_one_bins", t1_ok)

    // ── T2: sine wave PSD peaks at the correct bin ──
    // x[i] = sin(2π · k_target · i / N), N = 64, k_target = 5.
    // PSD should peak strictly at bin 5 (excluding DC).
    let N2 = 64
    let k_target = 5
    let mut x2 = []
    let mut i2 = 0
    while i2 < N2 {
        x2 = x2.push(sin(2.0 * SD_PI * k_target * i2 / N2))
        i2 = i2 + 1
    }
    let psd2 = power_spectral_density(x2, N2)
    let peak_bin = _argmax_excluding_dc(psd2, N2 / 2 + 1)
    let mut t2_ok = 1
    if peak_bin != k_target { t2_ok = 0 }
    fails = fails + _check_flag("T2_sine_psd_peak_at_target_bin", t2_ok)

    // ── T3: DC signal PSD concentrates at bin 0 ──
    // x = [3, 3, 3, ..., 3], N=8. PSD[0] >> PSD[k] for k > 0.
    let N3 = 8
    let mut x3 = []
    let mut i3 = 0
    while i3 < N3 {
        x3 = x3.push(3.0)
        i3 = i3 + 1
    }
    let psd3 = power_spectral_density(x3, N3)
    let mut t3_ok = 1
    if psd3[0] <= 1.0 { t3_ok = 0 }
    let mut nz_max = 0.0
    let mut z = 1
    while z < N3 / 2 + 1 {
        if psd3[z] > nz_max { nz_max = psd3[z] }
        z = z + 1
    }
    if nz_max > 1.0e-9 { t3_ok = 0 }
    if psd3[0] <= nz_max * 1000.0 {
        // require >= 1000x ratio
        if nz_max > 0.0 { t3_ok = 0 }
    }
    fails = fails + _check_flag("T3_dc_signal_psd_concentrates_at_bin0", t3_ok)

    // ── T4: Welch full-window single-segment bin count ──
    // n = 64, window_size = 16, overlap = 0 → 4 segments;
    // returned PSD length must be 16/2 + 1 = 9.
    let N4 = 64
    let mut x4 = []
    let mut i4 = 0
    while i4 < N4 {
        x4 = x4.push(sin(2.0 * SD_PI * 3.0 * i4 / N4))
        i4 = i4 + 1
    }
    let welch4 = welch_psd(x4, N4, 16, 0)
    let mut t4_ok = 1
    if len(welch4) != 9 { t4_ok = 0 }
    fails = fails + _check_flag("T4_welch_returns_window_half_plus_one", t4_ok)

    // ── T5: Welch noise variance reduction ──
    // Generate a noisy signal (sine + LCG-uniform noise), N = 256.
    // welch_psd variance < power_spectral_density variance.
    // Take variance over the noise-only bins (excluding the sine peak
    // bin to keep the comparison fair).
    let N5 = 256
    let mut x5 = []
    let mut state = 12345
    let k5 = 10  // sine bin
    let mut i5 = 0
    while i5 < N5 {
        state = _lcg_next(state)
        let noise = (_lcg_uniform(state) - 0.5) * 2.0  // [-1, 1]
        let sig = sin(2.0 * SD_PI * k5 * i5 / N5)
        x5 = x5.push(sig + noise)
        i5 = i5 + 1
    }
    let psd5 = power_spectral_density(x5, N5)
    let welch5 = welch_psd(x5, N5, 64, 32)  // 64-wide Hann, 32 overlap
    // Compare variance over interior bins, excluding bin 0 (DC) and the
    // sine peak band. periodogram length = 129, welch length = 33.
    // Build the bins-only-noise comparison by re-binning the periodogram
    // to welch's binwidth via simple block-average (4 periodogram bins per
    // welch bin, since 129 ≈ 4 × 33). Skip welch bin 0 (DC) and
    // welch peak bin (= k5 * 64 / 256 = 2 + neighbors).
    let mut periodogram_rebinned = []
    let n_welch_bins = 33
    let bins_per_w = 4
    let mut bi = 0
    while bi < n_welch_bins {
        let mut s = 0.0
        let mut bb = 0
        while bb < bins_per_w {
            let pi = bi * bins_per_w + bb
            if pi < 129 {
                s = s + psd5[pi]
            }
            bb = bb + 1
        }
        periodogram_rebinned = periodogram_rebinned.push(s / bins_per_w)
        bi = bi + 1
    }

    // Collect noise-only bins (skip DC + peak band [bins 1..4])
    let mut periodogram_noise = []
    let mut welch_noise = []
    let mut nb = 5  // skip 0..4
    while nb < n_welch_bins - 1 {
        periodogram_noise = periodogram_noise.push(periodogram_rebinned[nb])
        welch_noise = welch_noise.push(welch5[nb])
        nb = nb + 1
    }
    let pn_len = len(periodogram_noise)
    let var_periodogram = _variance(periodogram_noise, pn_len)
    let var_welch = _variance(welch_noise, pn_len)
    let mut t5_ok = 1
    if var_welch >= var_periodogram { t5_ok = 0 }
    println("    var(periodogram)=" + to_string(var_periodogram) + "  var(welch)=" + to_string(var_welch))
    fails = fails + _check_flag("T5_welch_reduces_noise_variance", t5_ok)

    if fails == 0 {
        println("ALL PASS — stdlib/signal/spectral_density")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
