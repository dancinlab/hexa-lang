// HEXA Standard Library — signal/core_griffin
//
// @version 0.1.0
// @capabilities [pure]
//
// Griffin–Lim iterative phase reconstruction from a magnitude spectrogram.
// Ported from anima HEXAD/VOICE/anima-voice/dsp_core.hexa (`dsp_griffin_lim`)
// per the STDLIB domain phase3 M1 (signal primitives) — the phase-recon part
// deferred from the merged stdlib/signal/core_pitch (#857). Companion to
// stdlib/signal/core_mel.
//
// Algorithm (Griffin & Lim 1984):
//   Given |X| (magnitude spectrogram only), estimate a complex spectrogram
//   X̂ whose iSTFT, when re-STFT'd, has magnitude as close as possible to |X|.
//
//   1. Initialise complex spec with zero phase:  X̂_re = |X|,  X̂_im = 0.
//   2. Repeat n_iter times:
//        a. y     = iSTFT(X̂)
//        b. X'    = STFT(y)
//        c. φ     = phase(X')                          // arg(X')
//        d. X̂    = |X| · exp(jφ)                       // restore target magnitude
//   3. Return iSTFT(X̂).
//
// Convergence typically takes 30–60 iterations for speech-quality recovery;
// 1–2 iterations suffice as a smoke / shape test (this module's test layer).
//
// Layout:
//   mag_spec — flat one-sided magnitude spectrogram, n_frames · bins floats,
//              frame-major (frame 0 bins 0..bins-1, frame 1 ...).
//   bins      = n_fft / 2 + 1
//   Window     = Hann (win_type = 0), matching the anima baseline (WIN_HANN).
//
// NOTE on the trig path (libm):
//   The phase-restore step uses the native libm `sqrt` builtin (IEEE-correct
//   across the full range — no hand-rolled `sqrt_approx`). The underlying
//   STFT / iSTFT path inherits the libm trig stance via stdlib/signal/core_stft.
//   The framing / magnitude-preservation / overlap-add logic is otherwise a
//   faithful port of dsp_core.hexa::dsp_griffin_lim.
//
// Surface:
//   pub fn griffin_lim(mag_spec: [float], n_fft: int, hop: int, n_iter: int) -> [float]
//       // → reconstructed audio (time domain).

import "stdlib/signal/core_stft.hexa"

let CG_EPS = 0.000001
let CG_WIN_HANN = 0

// ── griffin_lim(mag_spec, n_fft, hop, n_iter) ───────────────────────────────
//
// Iterative phase reconstruction. Returns the reconstructed time-domain
// audio (length = istft_output_len(n_frames, n_fft, hop)).
//
// Byte-equal port of dsp_core.hexa::dsp_griffin_lim, modulo the libm sqrt
// (replacing `sqrt_approx`) and the STFT/iSTFT calls now going through
// stdlib/signal/core_stft.hexa (`stft_native` / `istft_native`).

pub fn griffin_lim(mag_spec: [float], n_fft: int, hop: int, n_iter: int) -> [float] {
    let bins = n_fft / 2 + 1
    let total = len(mag_spec)
    if bins <= 0 { return [] }
    let n_frames = total / bins
    if n_frames <= 0 { return [] }

    // Initialise complex spec with zero phase:
    //   X̂_re = |X| · cos(0) = |X|,   X̂_im = |X| · sin(0) = 0
    let mut cur_re = []
    let mut cur_im = []
    let mut i = 0
    while i < n_frames * bins {
        cur_re = cur_re.push(mag_spec[i])
        cur_im = cur_im.push(0.0)
        i = i + 1
    }

    let mut it = 0
    while it < n_iter {
        // iSTFT of current complex spectrogram → time-domain estimate
        let audio = istft_native(cur_re, cur_im, n_fft, hop, CG_WIN_HANN, n_frames)
        if len(audio) == 0 { return [] }

        // STFT of the estimate (one-sided interleaved [re, im, re, im, ...],
        // length = n_frames · bins · 2)
        let new_spec = stft_native(audio, n_fft, hop, CG_WIN_HANN)
        if len(new_spec) == 0 { return [] }

        // Restore target magnitude, keep new phase:
        //   X̂[j] = |X|[j] · (re/|re+jim|) + j · |X|[j] · (im/|re+jim|)
        let mut new_re = []
        let mut new_im = []
        let mut j = 0
        while j < n_frames * bins {
            let re_val = new_spec[j * 2]
            let im_val = new_spec[j * 2 + 1]
            let new_mag = sqrt(re_val * re_val + im_val * im_val)
            if new_mag > CG_EPS {
                let scale = mag_spec[j] / new_mag
                new_re = new_re.push(re_val * scale)
                new_im = new_im.push(im_val * scale)
            } else {
                // Phase-degenerate bin: fall back to zero-phase + target |X|
                new_re = new_re.push(mag_spec[j])
                new_im = new_im.push(0.0)
            }
            j = j + 1
        }
        cur_re = new_re
        cur_im = new_im
        it = it + 1
    }

    // Final iSTFT — emit the reconstructed time-domain audio
    return istft_native(cur_re, cur_im, n_fft, hop, CG_WIN_HANN, n_frames)
}
