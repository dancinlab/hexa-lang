// Smoke test — stdlib/signal/core_resample (resample / pitch_shift / rms / zcr / dB).
//
// Self-contained: single-file `hexa build` does NOT flatten `import "stdlib/..."`
// (undefined link symbols), so the functions under test are INLINED here verbatim
// from core_resample.hexa. The importable regression-harness form (below `main`,
// commented) becomes the canonical path once cross-import flatten lands. The
// transcendental ops route to the native libm `floor` / `pow` / `sqrt` / `log10`
// builtins (IEEE-correct); expected values are the closed-form analytic results.
//
// import "stdlib/signal/core_resample.hexa"   // ← canonical once flatten lands

let CR_DB_FLOOR = 0.0 - 120.0
let CR_SILENCE  = 0.000001

fn _cr_lerp(s0: float, s1: float, t: float) -> float {
    return s0 * (1.0 - t) + s1 * t
}

fn _cr_floor_idx(p: float) -> int {
    let f = floor(p)
    let mut k = 0
    while (k + 1) * 1.0 <= f {
        k = k + 1
    }
    return k
}

fn resample(x: [float], ratio: float) -> [float] {
    let n_in = len(x)
    if n_in <= 1 { return x }
    if ratio <= 0.0 { return [] }
    let n_out = _cr_floor_idx(n_in * ratio)
    if n_out <= 0 { return [] }
    let inv = 1.0 / ratio
    let mut out = []
    let mut i = 0
    while i < n_out {
        let src_pos = i * inv
        let k = _cr_floor_idx(src_pos)
        if k >= n_in - 1 {
            out = out.push(x[n_in - 1])
        } else {
            let t = src_pos - k * 1.0
            out = out.push(_cr_lerp(x[k], x[k + 1], t))
        }
        i = i + 1
    }
    return out
}

fn pitch_shift(x: [float], semitones: float) -> [float] {
    let n = len(x)
    if n <= 1 { return x }
    let shift = pow(2.0, semitones / 12.0)
    if shift <= 0.0 { return x }
    let mut out = []
    let mut i = 0
    while i < n {
        let src_pos = i * shift
        let k = _cr_floor_idx(src_pos)
        if k >= n - 1 {
            out = out.push(x[n - 1])
        } else {
            let t = src_pos - k * 1.0
            out = out.push(_cr_lerp(x[k], x[k + 1], t))
        }
        i = i + 1
    }
    return out
}

fn rms(x: [float]) -> float {
    let n = len(x)
    if n <= 0 { return 0.0 }
    let mut sum_sq = 0.0
    let mut i = 0
    while i < n {
        sum_sq = sum_sq + x[i] * x[i]
        i = i + 1
    }
    return sqrt(sum_sq / n)
}

fn zcr(x: [float]) -> float {
    let n = len(x)
    if n <= 1 { return 0.0 }
    let mut crossings = 0
    let mut i = 1
    while i < n {
        let prev = x[i - 1]
        let curr = x[i]
        if prev >= 0.0 && curr < 0.0 { crossings = crossings + 1 }
        if prev < 0.0 && curr >= 0.0 { crossings = crossings + 1 }
        i = i + 1
    }
    return crossings * 1.0 / (n - 1)
}

fn lin_to_db(x: float) -> float {
    if x <= CR_SILENCE { return CR_DB_FLOOR }
    return 20.0 * log10(x)
}

fn db_to_lin(db: float) -> float {
    return pow(10.0, db / 20.0)
}

// ── test scaffold ───────────────────────────────────────────────────────────

fn _check_flag(name: string, ok: int) -> int {
    if ok == 1 {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name)
    return 1
}

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _near(a: float, b: float, tol: float) -> int {
    if _abs_f(a - b) <= tol { return 1 }
    return 0
}

fn main() {
    let mut fails = 0
    let tol = 0.000001

    // ── resample 2× of [0,1,2,3] → [0, 0.5, 1, 1.5, 2, 2.5, 3, 3] ──
    // ratio=2 ⇒ n_out=8, p=i/2. Tail (k ≥ n_in−1=3) clamps to x[3]=3.
    let sig = [0.0, 1.0, 2.0, 3.0]
    let up = resample(sig, 2.0)
    fails = fails + _check_flag("resample2x_len8", if len(up) == 8 { 1 } else { 0 })
    fails = fails + _check_flag("resample2x_v0", _near(up[0], 0.0, tol))
    fails = fails + _check_flag("resample2x_v1", _near(up[1], 0.5, tol))
    fails = fails + _check_flag("resample2x_v2", _near(up[2], 1.0, tol))
    fails = fails + _check_flag("resample2x_v3", _near(up[3], 1.5, tol))
    fails = fails + _check_flag("resample2x_v4", _near(up[4], 2.0, tol))
    fails = fails + _check_flag("resample2x_v5", _near(up[5], 2.5, tol))
    fails = fails + _check_flag("resample2x_v6", _near(up[6], 3.0, tol))
    fails = fails + _check_flag("resample2x_v7_tailclamp", _near(up[7], 3.0, tol))

    // ── resample 1× is identity (sr_in == sr_out short-circuit elsewhere) ──
    // ratio=1.0 ⇒ n_out=4, integer positions, exact passthrough.
    let same = resample(sig, 1.0)
    fails = fails + _check_flag("resample1x_len4", if len(same) == 4 { 1 } else { 0 })
    fails = fails + _check_flag("resample1x_v2", _near(same[2], 2.0, tol))

    // ── rms of [3,4] = sqrt((9+16)/2) = sqrt(12.5) ≈ 3.53553391 ──
    let r = rms([3.0, 4.0])
    fails = fails + _check_flag("rms_3_4_sqrt12p5", _near(r, 3.5355339059327378, tol))
    // rms of all-zero buffer = 0.
    fails = fails + _check_flag("rms_zero", _near(rms([0.0, 0.0, 0.0]), 0.0, tol))

    // ── zcr of sign-alternating [1,-1,1,-1,1] (N=5) → 4 flips / 4 = 1.0 ──
    let alt = [1.0, 0.0 - 1.0, 1.0, 0.0 - 1.0, 1.0]
    fails = fails + _check_flag("zcr_alternating_1p0", _near(zcr(alt), 1.0, tol))
    // zcr of a monotone-positive buffer = 0 (no sign changes).
    fails = fails + _check_flag("zcr_no_cross_0", _near(zcr([0.1, 0.2, 0.3, 0.4]), 0.0, tol))
    // zcr of [1,-1,-1,1] → 2 flips / 3 ≈ 0.6666667.
    let two = [1.0, 0.0 - 1.0, 0.0 - 1.0, 1.0]
    fails = fails + _check_flag("zcr_two_of_three", _near(zcr(two), 0.6666666666666666, tol))

    // ── dB round-trip: lin → dB → lin recovers the amplitude ──
    let amp = 0.5
    let db = lin_to_db(amp)            // 20·log10(0.5) ≈ −6.0205999
    let back = db_to_lin(db)           // 10^(db/20) ≈ 0.5
    fails = fails + _check_flag("db_known_minus6", _near(db, 0.0 - 6.020599913279624, tol))
    fails = fails + _check_flag("db_roundtrip_0p5", _near(back, amp, tol))
    // 0 dB == unity amplitude.
    fails = fails + _check_flag("db_0dB_unity", _near(db_to_lin(0.0), 1.0, tol))
    // Silence floor.
    fails = fails + _check_flag("db_silence_floor", _near(lin_to_db(0.0), CR_DB_FLOOR, tol))

    // ── pitch_shift preserves length; 0 semitones is identity ──
    let ps0 = pitch_shift(sig, 0.0)
    fails = fails + _check_flag("pitch_shift_len_preserved", if len(ps0) == 4 { 1 } else { 0 })
    fails = fails + _check_flag("pitch_shift_0st_identity_v1", _near(ps0[1], 1.0, tol))
    // +12 semitones (octave up) ⇒ shift=2: out[i]=x[2i] clamped → [0,2,3,3].
    let ps12 = pitch_shift(sig, 12.0)
    fails = fails + _check_flag("pitch_shift_oct_v0", _near(ps12[0], 0.0, tol))
    fails = fails + _check_flag("pitch_shift_oct_v1", _near(ps12[1], 2.0, tol))
    fails = fails + _check_flag("pitch_shift_oct_v2_tailclamp", _near(ps12[2], 3.0, tol))

    if fails == 0 {
        println("ALL PASS — stdlib/signal/core_resample")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
