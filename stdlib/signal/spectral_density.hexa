// HEXA Standard Library — signal/spectral_density
//
// @version 0.1.0
// @capabilities [pure]
//
// Power spectral density (PSD) estimators for EEG / signal analysis:
//
//   - power_spectral_density(x, n)
//         Single-shot periodogram PSD via |FFT(x)|² / n.
//         Returns one-sided spectrum, bins [0..n/2] (length n/2 + 1).
//   - welch_psd(x, n, window_size, overlap)
//         Welch's method (Bartlett with Hann-windowed segments + average).
//         Reduces periodogram variance at the cost of frequency resolution.
//         Returns one-sided PSD of length (window_size/2 + 1).
//
// Convention: one-sided PSD doubles bins 1..(N/2 - 1) to fold the negative
// frequency energy into the positive half (DC and Nyquist NOT doubled), so
// the returned bins sum (× df) to the total signal power — the standard
// SciPy / MATLAB / Octave convention.
//
// HONEST LIMITS:
//   - window_size MUST be a power of 2 (Cooley-Tukey radix-2 FFT). Caller
//     is responsible; no internal padding. Behavior on non-power-of-2 is
//     undefined (likely producing wrong bin counts).
//   - overlap MUST satisfy 0 <= overlap < window_size; otherwise the
//     segment stride collapses and we return empty.
//   - No detrending / no DC removal. Caller subtracts mean if needed.
//   - Welch normalization uses Hann window's coherent-gain correction
//     (sum_of_window² factor). Bin units are POWER per FFT-bin (not
//     density-per-Hz) — caller multiplies by (1 / sample_rate) to convert
//     to absolute V²/Hz if needed.
//   - Naive periodogram (power_spectral_density) is biased + high-variance;
//     prefer welch_psd for stationary EEG bands.

import "stdlib/signal/core_fft.hexa"
import "stdlib/signal/core_window.hexa"

// ── _sd_onesided(spec_flat, n) → one-sided magnitude² array ──
//
// Converts the flat [re0, im0, re1, im1, ...] FFT output (length 2n) into
// the one-sided power spectrum of length n/2 + 1. DC and Nyquist bins are
// kept single-sided; interior bins are doubled to fold conjugate-pair
// energy.
fn _sd_onesided(spec_flat: [float], n: int) -> [float] {
    let half = n / 2
    let mut out = []
    let mut k = 0
    while k <= half {
        let re = spec_flat[k * 2]
        let im = spec_flat[k * 2 + 1]
        let mag_sq = re * re + im * im
        let mut bin = mag_sq
        if k > 0 {
            if k < half {
                bin = mag_sq * 2.0
            }
        }
        out = out.push(bin)
        k = k + 1
    }
    return out
}

// ── power_spectral_density(x, n) → periodogram PSD ──
//
// Single-shot periodogram: P[k] = |FFT(x)[k]|² / n  (one-sided, doubled).
// Returns array of length n/2 + 1. n MUST be a power of 2.
pub fn power_spectral_density(x: [float], n: int) -> [float] {
    if n <= 0 { return [] }
    // Build complex input with imag = 0
    let mut imag = []
    let mut i = 0
    while i < n {
        imag = imag.push(0.0)
        i = i + 1
    }
    let spec = fft_native(x, imag, n)
    let one_sided = _sd_onesided(spec, n)
    // Normalize by n (periodogram convention)
    let inv_n = 1.0 / n
    let mut out = []
    let mut k = 0
    let half = n / 2
    while k <= half {
        out = out.push(one_sided[k] * inv_n)
        k = k + 1
    }
    return out
}

// ── welch_psd(x, n, window_size, overlap) → averaged PSD ──
//
// Welch's method: split x into overlapping Hann-windowed segments of
// length window_size, compute the periodogram of each, and average.
// Reduces periodogram variance by ~K (K = segment count) at the cost of
// frequency resolution (binwidth grows from 1/n to 1/window_size).
//
// segment stride = window_size - overlap
// K = floor((n - window_size) / stride) + 1   for n >= window_size, else 0
//
// Each segment's periodogram is divided by the window's coherent power
// (sum_of_window² ≈ 0.375 × window_size for Hann), making bin units
// POWER per FFT-bin (caller multiplies by 1/sample_rate for V²/Hz).
pub fn welch_psd(x: [float], n: int, window_size: int, overlap: int) -> [float] {
    if n <= 0 { return [] }
    if window_size <= 0 { return [] }
    if window_size > n { return [] }
    if overlap < 0 { return [] }
    if overlap >= window_size { return [] }

    let stride = window_size - overlap
    if stride <= 0 { return [] }
    let n_segs = (n - window_size) / stride + 1
    if n_segs <= 0 { return [] }

    // Precompute Hann window and its sum-of-squares
    let mut win = []
    let mut win_pow = 0.0
    let mut wi = 0
    while wi < window_size {
        let w = hann_window(wi, window_size)
        win = win.push(w)
        win_pow = win_pow + w * w
        wi = wi + 1
    }
    if win_pow <= 0.0 { return [] }
    let inv_win_pow = 1.0 / win_pow

    let half = window_size / 2
    // Accumulator for one-sided averaged PSD
    let mut acc = []
    let mut a = 0
    while a <= half {
        acc = acc.push(0.0)
        a = a + 1
    }

    let mut seg = 0
    while seg < n_segs {
        let start = seg * stride
        // Build windowed segment + zero imag
        let mut seg_re = []
        let mut seg_im = []
        let mut s = 0
        while s < window_size {
            seg_re = seg_re.push(x[start + s] * win[s])
            seg_im = seg_im.push(0.0)
            s = s + 1
        }
        let spec = fft_native(seg_re, seg_im, window_size)
        let one_sided = _sd_onesided(spec, window_size)
        let mut k = 0
        while k <= half {
            acc[k] = acc[k] + one_sided[k] * inv_win_pow
            k = k + 1
        }
        seg = seg + 1
    }

    // Average over segments
    let inv_segs = 1.0 / n_segs
    let mut out = []
    let mut k2 = 0
    while k2 <= half {
        out = out.push(acc[k2] * inv_segs)
        k2 = k2 + 1
    }
    return out
}
