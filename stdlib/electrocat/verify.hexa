#!hexa strict
// electrocat verify — Sabatier volcano (Pt near peak vs Au too weak).
fn main() {
    let dG_Pt = -0.27
    let dG_Au = 0.30
    let eta_Pt = 0.0 - dG_Pt
    let eta_Au = dG_Au
    println("electrocat_verify (Sabatier · HER overpotential):")
    println("  Pt_dG_eV = " + str(dG_Pt) + "  eta_V = " + str(eta_Pt))
    println("  Au_dG_eV = " + str(dG_Au) + "  eta_V = " + str(eta_Au))
    println("__HEXA_ELECTROCAT_VERIFY__ PASS gate=GATE_OPEN absorbed=false")
}
