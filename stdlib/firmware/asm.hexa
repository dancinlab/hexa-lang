#!hexa strict
// stdlib/firmware/asm.hexa — @asm escape hatch emit + arch validation
//
// @version 0.1.0
// @stability phase-a (FIRMWARE.md G-F4 — library-level capability)
// @authority FIRMWARE.md §4 G-F4 + RFC 063
//
// G-F4 library capability: emit the GCC inline-asm C fragment that
// codegen invokes when it sees `@asm(arch=..., clobbers=...)` on a
// function. Pure string production — no codegen-side glue.
//
// G-F4 anti-balloon discipline (FIRMWARE.md §5): the helpers here do
// NOT increase the cap; they just encode the syntax. The cap is a
// review-time discipline (≤5 sites across stdlib/firmware/).

// CLEAN-ROOM: emit a GCC inline-asm block from the asm body text and
// the clobber list. Conforms to GCC __asm__ volatile (...) syntax per
// GCC manual §6.47.2.
//
// Example output for body="wfi" + clobbers=["memory"]:
//   __asm__ volatile (
//       "wfi"
//       :  /* outputs */
//       :  /* inputs */
//       : "memory"
//   );
fn asm_emit_block(body: str, clobbers: [str]) -> str {
    let mut out = "__asm__ volatile (\n"
    out = out + "    \"" + body + "\"\n"
    out = out + "    :  /* outputs */\n"
    out = out + "    :  /* inputs */\n"
    out = out + "    : "
    let mut i = 0
    while i < len(clobbers) {
        if i > 0 { out = out + ", " }
        out = out + "\"" + clobbers[i] + "\""
        i = i + 1
    }
    out = out + "\n);\n"
    return out
}

fn asm_supported_arch(arch: str) -> int {
    if arch == "armv6-m"  { return 1 }
    if arch == "armv7e-m" { return 1 }
    if arch == "armv8-m.main" { return 1 }
    if arch == "rv32imac" { return 0 }   // pending RFC 063 cortex-M lead
    return 0
}

// CLEAN-ROOM: count @asm sites in a translation unit's source text.
// Used by the G-F4 anti-balloon check (FIRMWARE.md §5).
fn asm_count_sites(source_text: str) -> int {
    let needle = "@asm("
    let n = len(needle)
    let m = len(source_text)
    let mut count = 0
    let mut i = 0
    while i <= m - n {
        if source_text.substring(i, i + n) == needle {
            count = count + 1
            i = i + n
        } else {
            i = i + 1
        }
    }
    return count
}

// CLEAN-ROOM: anti-balloon gate. Returns 1 if the source text passes
// the ≤5 site discipline (FIRMWARE.md §5), 0 if it breaches.
fn asm_balloon_check(source_text: str, threshold: int) -> int {
    if asm_count_sites(source_text) > threshold { return 0 }
    return 1
}

fn main() {
    let mut fails = 0
    let mut total = 0

    total = total + 1
    let wfi = asm_emit_block("wfi", ["memory"])
    if wfi.find("__asm__ volatile") < 0 { println("FAIL T1 asm_volatile"); fails = fails + 1 }
    if wfi.find("\"wfi\"") < 0 { println("FAIL T1b body"); fails = fails + 1 }
    if wfi.find("\"memory\"") < 0 { println("FAIL T1c clobber"); fails = fails + 1 }

    total = total + 1
    let multi = asm_emit_block("dsb", ["memory", "cc"])
    if multi.find("\"memory\", \"cc\"") < 0 {
        println("FAIL T2 multi_clobber"); fails = fails + 1
    }

    total = total + 1
    if asm_supported_arch("armv6-m") != 1 { println("FAIL T3 armv6m"); fails = fails + 1 }
    if asm_supported_arch("armv7e-m") != 1 { println("FAIL T3b armv7em"); fails = fails + 1 }
    if asm_supported_arch("z80") != 0 { println("FAIL T3c unknown"); fails = fails + 1 }

    total = total + 1
    let txt = "fn a() { @asm(arch=\"armv6-m\") { ... } }\nfn b() { @asm(arch=\"armv7e-m\") { ... } }"
    if asm_count_sites(txt) != 2 {
        println("FAIL T4 count"); fails = fails + 1
    }

    total = total + 1
    if asm_count_sites("plain hexa code\n") != 0 {
        println("FAIL T5 zero_sites"); fails = fails + 1
    }

    total = total + 1
    let six_sites = "@asm( @asm( @asm( @asm( @asm( @asm("
    if asm_balloon_check(six_sites, 5) != 0 {
        println("FAIL T6 balloon_breach"); fails = fails + 1
    }
    if asm_balloon_check("@asm(", 5) != 1 {
        println("FAIL T6b balloon_ok"); fails = fails + 1
    }

    total = total + 1
    let w2 = asm_emit_block("wfi", ["memory"])
    let w3 = asm_emit_block("wfi", ["memory"])
    if w2 != w3 { println("FAIL T7 byte_stable"); fails = fails + 1 }

    if fails > 0 {
        println("asm selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("asm selftest: " + str(total) + "/" + str(total) + " PASS")
}
