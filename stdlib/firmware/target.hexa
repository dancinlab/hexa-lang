#!hexa strict
// stdlib/firmware/target.hexa — firmware target descriptors + linker emit
//
// @version 0.1.0
// @stability phase-a (FIRMWARE.md G-F0 — library-level capability)
// @authority FIRMWARE.md §4 G-F0 + RFC 063
//
// G-F0 library capability:
//   - target_describe(arch) — returns the canonical FirmwareTarget for
//     a supported arch string;
//   - target_emit_linker_script(t) — emits a minimal `link.ld`
//     template for the target (sections + addresses);
//   - target_supported_archs() — enumerates the supported set.
//
// What is NOT here: the `@target(firmware, ...)` annotation lowering
// (that is a codegen-side change owned by RFC 063 cycle C). The
// library shape above is the consumer surface that lowering will
// invoke once the codegen lane is ready. Library + lowering split
// keeps the substantive part of the gate (deterministic per-arch
// data) measurable without touching `self/codegen_c2.hexa`.

struct FirmwareTarget {
    arch:        str,     // "cortex-m0" | "cortex-m4" | "riscv32" | ...
    core:        str,     // ISA profile
    word_bits:   int,     // 32 | 64
    endianness:  str,     // "little" | "big"
    float_abi:   str,     // "soft" | "softfp" | "hard"
    freestanding: int,    // 1 (always for firmware)
    // Memory map — addresses for the linker script. Per-arch defaults.
    flash_base:  str,     // hex string (e.g. "0x08000000")
    flash_size:  str,     // hex string (e.g. "0x00080000")
    ram_base:    str,
    ram_size:    str,
    stack_size:  str,     // hex string (e.g. "0x00001000")
}

// CLEAN-ROOM: addresses + ABI per-arch from public datasheets.
//   - Cortex-M0 / nRF51 — Nordic nRF51822 product spec
//   - Cortex-M4 / STM32F4 — ST RM0090 reference manual
//   - RISC-V (rv32imac) — generic vendor-neutral defaults
fn target_describe(arch: str) -> FirmwareTarget {
    if arch == "cortex-m0" {
        return FirmwareTarget {
            arch: "cortex-m0", core: "armv6-m",
            word_bits: 32, endianness: "little", float_abi: "soft",
            freestanding: 1,
            flash_base: "0x00000000", flash_size: "0x00040000",  // 256 KB
            ram_base:   "0x20000000", ram_size:   "0x00004000",  // 16 KB
            stack_size: "0x00000800",                              // 2 KB
        }
    }
    if arch == "cortex-m4" {
        return FirmwareTarget {
            arch: "cortex-m4", core: "armv7e-m",
            word_bits: 32, endianness: "little", float_abi: "softfp",
            freestanding: 1,
            flash_base: "0x08000000", flash_size: "0x00080000",  // 512 KB
            ram_base:   "0x20000000", ram_size:   "0x00020000",  // 128 KB
            stack_size: "0x00001000",                              // 4 KB
        }
    }
    if arch == "cortex-m33" {
        return FirmwareTarget {
            arch: "cortex-m33", core: "armv8-m.main",
            word_bits: 32, endianness: "little", float_abi: "softfp",
            freestanding: 1,
            flash_base: "0x08000000", flash_size: "0x00100000",  // 1 MB
            ram_base:   "0x20000000", ram_size:   "0x00040000",  // 256 KB
            stack_size: "0x00002000",                              // 8 KB
        }
    }
    if arch == "riscv32" {
        return FirmwareTarget {
            arch: "riscv32", core: "rv32imac",
            word_bits: 32, endianness: "little", float_abi: "soft",
            freestanding: 1,
            flash_base: "0x20400000", flash_size: "0x00400000",  // 4 MB
            ram_base:   "0x80000000", ram_size:   "0x00020000",  // 128 KB
            stack_size: "0x00001000",
        }
    }
    // unknown — return a sentinel (caller can check arch == "")
    return FirmwareTarget {
        arch: "", core: "", word_bits: 0, endianness: "", float_abi: "",
        freestanding: 0, flash_base: "0", flash_size: "0",
        ram_base: "0", ram_size: "0", stack_size: "0",
    }
}

fn target_supported_archs() -> [str] {
    return ["cortex-m0", "cortex-m4", "cortex-m33", "riscv32"]
}

// CLEAN-ROOM: GNU `ld` script — per-section layout matching the standard
// embedded toolchain expectation. Section names + ENTRY symbol follow
// the GNU `ld` script grammar (binutils docs §3.6 SECTIONS).
fn target_emit_linker_script(t: FirmwareTarget) -> str {
    if t.arch == "" { return "" }
    let mut out = "/* Generated by stdlib/firmware/target.hexa (G-F0) for " + t.arch + " */\n"
    out = out + "ENTRY(Reset_Handler)\n\n"
    out = out + "MEMORY\n{\n"
    out = out + "  FLASH (rx)  : ORIGIN = " + t.flash_base + ", LENGTH = " + t.flash_size + "\n"
    out = out + "  RAM   (rwx) : ORIGIN = " + t.ram_base   + ", LENGTH = " + t.ram_size   + "\n"
    out = out + "}\n\n"
    out = out + "_stack_size = " + t.stack_size + ";\n"
    out = out + "_estack = ORIGIN(RAM) + LENGTH(RAM);\n\n"
    out = out + "SECTIONS\n{\n"
    out = out + "  .isr_vector : { KEEP(*(.isr_vector)) } > FLASH\n"
    out = out + "  .text       : { *(.text*) *(.rodata*) } > FLASH\n"
    out = out + "  .data       : AT(LOADADDR(.text) + SIZEOF(.text))\n"
    out = out + "              { _sdata = .; *(.data*) _edata = .; } > RAM\n"
    out = out + "  .bss        : { _sbss = .; *(.bss*) *(COMMON) _ebss = .; } > RAM\n"
    out = out + "}\n"
    return out
}

// ─── self-test ───────────────────────────────────────────────────────────

fn main() {
    let mut fails = 0
    let mut total = 0

    // T1 — cortex-m0 metadata.
    total = total + 1
    let m0 = target_describe("cortex-m0")
    if m0.arch != "cortex-m0" { println("FAIL T1 arch"); fails = fails + 1 }
    if m0.core != "armv6-m" { println("FAIL T1b core"); fails = fails + 1 }
    if m0.word_bits != 32 { println("FAIL T1c bits"); fails = fails + 1 }
    if m0.freestanding != 1 { println("FAIL T1d freestanding"); fails = fails + 1 }

    // T2 — cortex-m4 softfp.
    total = total + 1
    let m4 = target_describe("cortex-m4")
    if m4.float_abi != "softfp" { println("FAIL T2 float_abi"); fails = fails + 1 }
    if m4.flash_size != "0x00080000" { println("FAIL T2b flash"); fails = fails + 1 }

    // T3 — riscv32.
    total = total + 1
    let rv = target_describe("riscv32")
    if rv.core != "rv32imac" { println("FAIL T3 rv_core"); fails = fails + 1 }
    if rv.flash_base != "0x20400000" { println("FAIL T3b rv_flash"); fails = fails + 1 }

    // T4 — unknown arch returns sentinel.
    total = total + 1
    let unk = target_describe("z80")
    if unk.arch != "" { println("FAIL T4 unknown_arch"); fails = fails + 1 }

    // T5 — supported archs list.
    total = total + 1
    let archs = target_supported_archs()
    if len(archs) != 4 { println("FAIL T5 archs_count"); fails = fails + 1 }

    // T6 — linker script for cortex-m4 has required sections + entry.
    total = total + 1
    let ld = target_emit_linker_script(m4)
    if ld.find("ENTRY(Reset_Handler)") < 0 {
        println("FAIL T6 entry"); fails = fails + 1
    }
    if ld.find("FLASH (rx)") < 0 {
        println("FAIL T6b flash_region"); fails = fails + 1
    }
    if ld.find("RAM   (rwx)") < 0 {
        println("FAIL T6c ram_region"); fails = fails + 1
    }
    if ld.find(".isr_vector") < 0 {
        println("FAIL T6d isr_section"); fails = fails + 1
    }
    if ld.find("0x08000000") < 0 {
        println("FAIL T6e flash_base"); fails = fails + 1
    }

    // T7 — empty target produces empty linker script.
    total = total + 1
    let empty_ld = target_emit_linker_script(unk)
    if empty_ld != "" {
        println("FAIL T7 empty_ld"); fails = fails + 1
    }

    // T8 — byte-stable.
    total = total + 1
    let ld2 = target_emit_linker_script(m4)
    let ld3 = target_emit_linker_script(m4)
    if ld2 != ld3 {
        println("FAIL T8 byte_stable"); fails = fails + 1
    }

    if fails > 0 {
        println("target selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("target selftest: " + str(total) + "/" + str(total) + " PASS")
}
