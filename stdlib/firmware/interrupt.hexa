#!hexa strict
// stdlib/firmware/interrupt.hexa — interrupt vector table emit
//
// @version 0.1.0
// @stability phase-a (FIRMWARE.md G-F3 — library-level capability)
// @authority FIRMWARE.md §4 G-F3 + RFC 063
//
// G-F3 library capability: emit the C text fragments + vector-table
// slot management that codegen invokes when it sees
// `@interrupt(vector="...", number=N)` on a function. Pure string
// production — no codegen-side glue.

struct InterruptSlot {
    name:    str,    // human-readable, e.g. "SysTick_Handler"
    number:  int,    // IRQn (per-arch)
}

// CLEAN-ROOM: emit a single vector-table slot entry. Codegen invokes
// this for each `@interrupt(...)`-annotated function it sees.
fn interrupt_emit_slot(s: InterruptSlot) -> str {
    return "    " + s.name + ",  /* " + str(s.number) + " */\n"
}

// CLEAN-ROOM: emit the full vector table given a list of registered
// interrupt slots. Output is byte-stable for a given input list.
fn interrupt_emit_vector_table(arch: str, slots: [InterruptSlot]) -> str {
    let mut out = "/* Generated by stdlib/firmware/interrupt.hexa (G-F3) for " + arch + " */\n"
    out = out + "extern unsigned int _estack;\n"
    out = out + "extern void Reset_Handler(void);\n"
    out = out + "__attribute__((weak)) void Default_Handler(void) { for(;;){} }\n"
    let mut i = 0
    while i < len(slots) {
        out = out + "__attribute__((weak, alias(\"Default_Handler\"))) void " + slots[i].name + "(void);\n"
        i = i + 1
    }
    out = out + "\n__attribute__((section(\".isr_vector\"), used))\n"
    out = out + "void (* const g_vectors[])(void) = {\n"
    out = out + "    (void (*)(void))(&_estack),  /* 0: stack top */\n"
    out = out + "    Reset_Handler,               /* 1: reset */\n"
    out = out + "    Default_Handler,             /* 2: NMI */\n"
    out = out + "    Default_Handler,             /* 3: hardfault */\n"
    let mut j = 0
    while j < len(slots) {
        out = out + interrupt_emit_slot(slots[j])
        j = j + 1
    }
    out = out + "};\n"
    return out
}

// CLEAN-ROOM: validate that no two interrupt slots share the same number.
// Returns the first colliding number, or -1 if none.
fn interrupt_find_collision(slots: [InterruptSlot]) -> int {
    let mut i = 0
    while i < len(slots) {
        let mut j = i + 1
        while j < len(slots) {
            if slots[i].number == slots[j].number { return slots[i].number }
            j = j + 1
        }
        i = i + 1
    }
    return -1
}

fn main() {
    let mut fails = 0
    let mut total = 0

    let slots: [InterruptSlot] = [
        InterruptSlot { name: "SysTick_Handler",  number: 15 },
        InterruptSlot { name: "USART1_Handler",   number: 37 },
    ]

    total = total + 1
    let vt = interrupt_emit_vector_table("cortex-m4", slots)
    if vt.find(".isr_vector") < 0 { println("FAIL T1 section"); fails = fails + 1 }
    if vt.find("SysTick_Handler,") < 0 { println("FAIL T1b systick"); fails = fails + 1 }
    if vt.find("USART1_Handler,") < 0 { println("FAIL T1c usart1"); fails = fails + 1 }
    if vt.find("Default_Handler,             /* 2: NMI */") < 0 { println("FAIL T1d nmi"); fails = fails + 1 }

    total = total + 1
    if vt.find("weak, alias(\"Default_Handler\")") < 0 {
        println("FAIL T2 weak_alias"); fails = fails + 1
    }

    total = total + 1
    let no_coll = interrupt_find_collision(slots)
    if no_coll != -1 { println("FAIL T3 no_collision"); fails = fails + 1 }

    total = total + 1
    let coll_slots: [InterruptSlot] = [
        InterruptSlot { name: "A", number: 10 },
        InterruptSlot { name: "B", number: 10 },
    ]
    let coll = interrupt_find_collision(coll_slots)
    if coll != 10 { println("FAIL T4 collision_detect"); fails = fails + 1 }

    total = total + 1
    let vt2 = interrupt_emit_vector_table("cortex-m4", slots)
    let vt3 = interrupt_emit_vector_table("cortex-m4", slots)
    if vt2 != vt3 { println("FAIL T5 byte_stable"); fails = fails + 1 }

    total = total + 1
    let empty = interrupt_emit_vector_table("cortex-m4", [])
    if empty.find("Default_Handler,             /* 3: hardfault */") < 0 {
        println("FAIL T6 empty_core"); fails = fails + 1
    }

    if fails > 0 {
        println("interrupt selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("interrupt selftest: " + str(total) + "/" + str(total) + " PASS")
}
