#!hexa strict
// stdlib/firmware/startup.hexa — startup vector + reset handler text emit
//
// @version 0.1.0
// @stability phase-a (FIRMWARE.md G-F1 — library-level capability)
// @authority FIRMWARE.md §4 G-F1 + RFC 063
//
// Emits the C text for the reset handler + initial vector table that
// hexa AOT codegen will embed into the `build/firmware/<arch>/` output
// per RFC 063 G-F1. Library-level capability: pure string production,
// no codegen-side glue. The codegen lane invokes these helpers when
// it sees a `@target(firmware)` annotation on `fn main()`.
//
// CLEAN-ROOM PROVENANCE
//   - ARMv6-M / ARMv7-M Architecture Reference Manual — vector table
//     layout (stack top, reset, NMI, hardfault at slots 0..3).
//   - GNU `as`/`gcc` documentation for the `__attribute__((interrupt))`
//     emission convention (no upstream code copied).

use "stdlib/firmware/target"

// CLEAN-ROOM: minimal reset handler text — copies .data from flash to
// RAM, zeroes .bss, then jumps to main(). C source string; the AOT
// codegen emits this into `build/firmware/<arch>/startup.c`.
fn startup_emit_reset_handler(arch: str) -> str {
    let t = target_describe(arch)
    if t.arch == "" { return "" }
    let mut out = "/* Generated by stdlib/firmware/startup.hexa (G-F1) for " + t.arch + " */\n"
    out = out + "extern unsigned int _sdata, _edata, _sbss, _ebss;\n"
    out = out + "extern unsigned int _sidata;  /* .data LMA in FLASH */\n"
    out = out + "extern int main(void);\n\n"
    out = out + "__attribute__((naked, noreturn))\n"
    out = out + "void Reset_Handler(void) {\n"
    out = out + "    /* copy .data from FLASH to RAM */\n"
    out = out + "    unsigned int *src = &_sidata;\n"
    out = out + "    unsigned int *dst = &_sdata;\n"
    out = out + "    while (dst < &_edata) { *dst++ = *src++; }\n"
    out = out + "    /* zero .bss */\n"
    out = out + "    dst = &_sbss;\n"
    out = out + "    while (dst < &_ebss) { *dst++ = 0; }\n"
    out = out + "    /* hand off to main */\n"
    out = out + "    (void)main();\n"
    out = out + "    for (;;) {}\n"
    out = out + "}\n"
    return out
}

// CLEAN-ROOM: minimal vector table — slots 0 (stack top), 1 (reset),
// 2 (NMI), 3 (hardfault). Per-arch slot counts vary; we emit the
// universal 4-slot core that every Cortex-M / RISC-V design requires.
fn startup_emit_vector_table(arch: str) -> str {
    let t = target_describe(arch)
    if t.arch == "" { return "" }
    let mut out = "/* Generated by stdlib/firmware/startup.hexa (G-F1) for " + t.arch + " */\n"
    out = out + "extern unsigned int _estack;\n"
    out = out + "extern void Reset_Handler(void);\n"
    out = out + "__attribute__((weak)) void Default_Handler(void) { for(;;){} }\n\n"
    out = out + "__attribute__((section(\".isr_vector\"), used))\n"
    out = out + "void (* const g_vectors[])(void) = {\n"
    out = out + "    (void (*)(void))(&_estack),  /* 0: stack top */\n"
    out = out + "    Reset_Handler,               /* 1: reset */\n"
    out = out + "    Default_Handler,             /* 2: NMI */\n"
    out = out + "    Default_Handler,             /* 3: hardfault */\n"
    out = out + "};\n"
    return out
}

fn main() {
    let mut fails = 0
    let mut total = 0

    total = total + 1
    let rh = startup_emit_reset_handler("cortex-m4")
    if rh.find("Reset_Handler") < 0 { println("FAIL T1 reset"); fails = fails + 1 }
    if rh.find("__attribute__((naked, noreturn))") < 0 { println("FAIL T1b naked"); fails = fails + 1 }
    if rh.find("while (dst < &_edata)") < 0 { println("FAIL T1c data_copy"); fails = fails + 1 }
    if rh.find("while (dst < &_ebss)") < 0 { println("FAIL T1d bss_zero"); fails = fails + 1 }
    if rh.find("(void)main()") < 0 { println("FAIL T1e main_call"); fails = fails + 1 }

    total = total + 1
    let vt = startup_emit_vector_table("cortex-m4")
    if vt.find(".isr_vector") < 0 { println("FAIL T2 isr_section"); fails = fails + 1 }
    if vt.find("(&_estack)") < 0 { println("FAIL T2b stack"); fails = fails + 1 }
    if vt.find("Reset_Handler,") < 0 { println("FAIL T2c reset_slot"); fails = fails + 1 }
    if vt.find("Default_Handler,") < 0 { println("FAIL T2d default"); fails = fails + 1 }

    total = total + 1
    if startup_emit_reset_handler("z80") != "" {
        println("FAIL T3 unknown_arch"); fails = fails + 1
    }

    total = total + 1
    let rh2 = startup_emit_reset_handler("cortex-m4")
    let rh3 = startup_emit_reset_handler("cortex-m4")
    if rh2 != rh3 { println("FAIL T4 byte_stable"); fails = fails + 1 }

    if fails > 0 {
        println("startup selftest: " + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("startup selftest: " + str(total) + "/" + str(total) + " PASS")
}
