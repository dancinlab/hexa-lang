// stdlib/http_sse.hexa — SSE / chunked streaming HTTP client (callback + handle)
//
// @module(slug="stdlib-http-sse", desc="curl --no-buffer streaming GET — Server-Sent Events parser + raw-line generator")
// @usage(import stdlib/http_sse; let n = http_sse_get(url, #{}, on_event, 60))
//
// @version 1.1.0
// @capabilities [http_sse_get, http_sse_get_lines, http_sse_get_buffered, http_sse_post, http_sse_post_buffered, http_sse_open, http_sse_open_post, http_sse_open_method, http_sse_next, http_sse_close, http_sse_parse_event, http_sse_feed, http_sse_available, http_sse_build_curl_cmd, http_sse_build_curl_method_cmd, http_sse_empty_event]
// @stability experimental
// @since 2026-05-08
// @changelog
//   1.1.0 (2026-05-11) — POST-with-body support: http_sse_post / http_sse_open_post
//                        (Anthropic Messages, OpenAI Chat Completions streaming).
//                        Internal _sse_build_curl factored into _method variant;
//                        GET surface unchanged.
//   1.0.0 (2026-05-08) — initial GET-only callback + handle API.
// @maintainer anima-core
// @priority P1
// Versioning policy: docs/hexa_lang_module_versioning_spec_2026_05_03.md
//
// Source: anima chat Phase-2 streaming substrate (llama-server token stream
// + HF Inference Endpoint event-stream). Sister modules stdlib/http and
// stdlib/http2 cover request/response — this one covers long-lived,
// token-by-token streaming.
//
// ── PROBLEM ─────────────────────────────────────────────────────────
//   stdlib/http::http_get_with_headers() and stdlib/http2::http2_get()
//   both use exec(curl ...) which popen-buffers the entire response
//   before returning. anima chat (Phase 2) needs to render LLM tokens
//   as they arrive — buffered exec() makes the user wait N seconds
//   then dump the full reply at once, breaking the streaming-chat UX.
//
//   Two wire protocols, one code path:
//     · text/event-stream (SSE, RFC: WHATWG HTML §9.2, RFC 8895 sketch):
//       lines like `event: foo\n`, `data: payload\n`, blank line ends
//       a logical "event". Used by HF Inference Endpoint / OpenAI /
//       Anthropic / llama-server with --sse.
//     · plain chunked transfer (HTTP/1.1 §4.1 "Transfer-Encoding:
//       chunked"): server emits length-prefixed binary chunks. curl
//       de-chunks transparently — caller sees raw bytes (or in our
//       wrapper, raw lines).
//
// ── FIX (additive, no runtime.c change) ──────────────────────────────
//   Two parallel APIs over the same `exec_stream` runtime primitive:
//
//   (A) Callback form — sync, single-event-loop:
//        http_sse_get(url, headers, on_event, timeout_sec) -> int
//          on_event(event_map) is invoked for each parsed SSE event.
//          event_map = {"event": string, "data": string, "id": string,
//                       "retry": int}; "data" may be multi-line (SSE
//                       spec: multiple `data:` lines concat with "\n").
//          Returns curl exit code (0 = clean EOF).
//
//        http_sse_get_lines(url, headers, on_line, timeout_sec) -> int
//          Lower-level: invokes on_line(string) for every raw stdout
//          line (with trailing "\n" preserved). Use when the wire is
//          chunked-transfer (non-SSE) — caller parses bytes itself.
//
//   (B) Handle form — generator-style, non-blocking poll:
//        http_sse_open(url, headers, timeout_sec) -> int
//          Returns a handle (int >= 0) to a backgrounded curl child;
//          -1 on launch failure.
//        http_sse_next(handle) -> array
//          Drains 0..N newline-terminated lines available right now.
//          Returns the magic ["__HEXA_STREAM_EOF__"] sentinel on EOF.
//        http_sse_close(handle) -> int
//          Reaps the child, returns its exit code. Idempotent.
//
//   Both forms emit the SSE parser as a separate pure-string helper
//   (http_sse_parse_event) so callers in handle-form can feed line
//   buffers directly without re-implementing the spec.
//
// ── BACKWARD COMPAT ─────────────────────────────────────────────────
// Breaking risk: 0. New module, new symbols. stdlib/http and
// stdlib/http2 are untouched — http_get_with_headers / http2_get
// signatures and behavior preserved.
//
// ── HONEST C3 (C3) ──────────────────────────────────────────────
//   1. AOT-only streaming. The runtime exposes `exec_stream` and
//      `exec_stream_async/poll/close` as native builtins, but they are
//      currently registered only on the AOT/codegen lowering path
//      (self/native/hexa_v2). The `hexa run` interpreter does NOT
//      dispatch these symbols (self/hexa_full.hexa has only "exec").
//      Callers using `hexa run` will receive a runtime error
//      "undefined function: exec_stream". The handle-form fallback
//      (http_sse_open via exec_stream_async) has the same limit.
//
//      Workaround for `hexa run` users today: synchronous fallback —
//      this module exposes http_sse_get_buffered(...) which uses the
//      regular exec(curl --max-time N) path, captures the whole
//      transcript, then replays it through the SSE parser. Latency =
//      whole-response (no streaming benefit) but at least the parsed
//      event sequence is identical, so callers can develop against
//      either path and only flip to streaming under AOT.
//
//   2. curl subprocess only — no native HTTP impl. Adding a native
//      streaming HTTP parser would require nontrivial work (chunked-
//      decoder, TLS, redirect, h2). curl is already a hard dep of
//      stdlib/http and stdlib/http2; we follow the same pattern.
//      A future `hexa_http_stream_native` runtime builtin can replace
//      the exec_stream(curl ...) shim without changing this API.
//
//   3. Header-value containing literal newline still produces broken
//      HTTP — same caveat as stdlib/http. Caller must validate.
//
//   4. Handle-form line drain is best-effort: exec_stream_poll uses
//      O_NONBLOCK fgets-like semantics with a 1MB per-slot line cap.
//      Lines longer than 1MB are silently truncated (ack).
//      For SSE this is acceptable — `data: <token>` payloads are
//      tens of bytes for chat tokens, kilobytes for full-message
//      events; a 1MB SSE line indicates a misuse.
//
//   5. timeout_sec on streams = wall clock to first byte AND between
//      bytes (curl --max-time covers total). For an indefinitely
//      open stream pass timeout_sec <= 0 → no --max-time flag (let
//      OS keepalive govern). Default 300s for finite jobs.
//
//   6. HTTP method override: RESOLVED in v1.1 (2026-05-11, faca4134).
//      http_sse_post / http_sse_open_post / http_sse_open_method route
//      the body via `printf %s '...' | curl --data-binary @-` (no temp
//      file, no inline-arg quoting fragility). The GET wire surface is
//      byte-identical. Streaming POST under `hexa run` still falls to
//      the buffered path (http_sse_post_buffered) — same AOT-vs-interp
//      split as item 1.
//
//   7. Binary frame in SSE 'data:' is base64-on-the-wire by spec — we
//      pass through as string (UTF-8 safe per curl). Zero bytes (NUL)
//      truncate the hexa string. Same caveat as stdlib/http.
//
// ── EXAMPLE (callback form, AOT mode) ───────────────────────────────
//
//   use "stdlib/http_sse"
//
//   fn on_event(ev) {
//       println(ev["event"] + ": " + ev["data"])
//   }
//
//   fn main() -> void {
//       let _ = http_sse_get(
//           "https://stream.wikimedia.org/v2/stream/recentchange",
//           #{"Accept": "text/event-stream"},
//           on_event,
//           10
//       )
//   }
//
//   $ hexa build chat.hexa -o chat && ./chat   # AOT — true streaming.
//
// ── EXAMPLE (handle form, AOT mode) ─────────────────────────────────
//
//   let h = http_sse_open(url, headers, 0)         // 0 = no timeout
//   let mut buf = ""
//   while true {
//       let lines = http_sse_next(h)
//       if len(lines) == 0 { continue }            // pace as desired
//       let mut i = 0
//       while i < len(lines) {
//           let line = to_string(lines[i])
//           if line == "__HEXA_STREAM_EOF__" {
//               let rc = http_sse_close(h)
//               return
//           }
//           buf = http_sse_feed(buf, line, on_event)
//           i = i + 1
//       }
//   }
//
// hexa-only-strict: pure hexa wrapper, exec_stream(curl ...)
//   shell-out — identical pattern to stdlib/http and stdlib/http2.

// _sse_shell_escape — single-quote wrap with internal quote escape.
// Duplicated from stdlib/http for resolver simplicity (no cross-
// module dep on a private helper).
fn _sse_shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

// _sse_build_header_flags — emit ` -H 'k: v' ...` from a header map.
// Mirrors _build_header_flags in stdlib/http (kept private here so
// the module imports nothing from http/).
fn _sse_build_header_flags(headers) -> string {
    if type_of(headers) != "map" { return "" }
    let ks = dict_keys(headers)
    let mut out = ""
    let mut i = 0
    while i < len(ks) {
        let k = ks[i]
        let v = to_string(headers[k])
        out = out + " -H " + _sse_shell_escape(k + ": " + v)
        i = i + 1
    }
    return out
}

// _sse_build_curl — assemble the curl streaming command.
//
// Flags:
//   -s         — silent (no progress meter, but errors still surface
//                via 2>&1 → would mix into the stream; we redirect
//                stderr to /dev/null instead, matching stdlib/http).
//   -S         — show error if curl itself fails (NOT mixed into
//                stdout; on macOS curl 7.50+ -sS pair is canonical).
//                Wire to /dev/null in practice — caller diagnoses
//                via the exit code returned from exec_stream.
//   -L         — follow 3xx redirects (CDN-fronted SSE endpoints).
//   -N --no-buffer — disable curl's own libc buffer; flush every
//                read to stdout immediately. Without this, even a
//                streaming server's tokens get coalesced inside curl.
//   --max-time N — total wall-clock budget. Omitted when timeout<=0
//                (long-lived stream).
//   -H 'k: v'  — request headers.
//
// We deliberately do NOT pass --fail (which silently swallows 4xx/5xx
// bodies) — for SSE the body IS the stream and a 4xx with a JSON error
// page is useful diagnostic the caller wants to surface.
//
// _sse_build_curl_method — generalized builder, supports any HTTP verb
// + optional body. Body delivery uses `printf '%s' '<escaped>' | curl
// --data-binary @-` to avoid temp-file lifecycle and inline-arg
// quoting fragility (JSON bodies have lots of `"`). Single-quote
// wrapping of the body is shell-safe (no $ expansion) — _sse_shell_escape
// handles embedded `'`. The pipe ends when curl closes stdin, so body
// lifetime is automatically tied to the curl process.
//
// method == "" or "GET" → no `-X` flag (GET is curl's default), no body.
// body  == ""           → no `--data-binary @-`, no printf prefix.
fn _sse_build_curl_method(url: string, headers, method: string, body: string, timeout_sec: int) -> string {
    let hflags = _sse_build_header_flags(headers)
    let mut prefix = ""
    let mut cmd = "curl -sSL -N --no-buffer"
    if timeout_sec > 0 {
        cmd = cmd + " --max-time " + to_string(timeout_sec)
    }
    cmd = cmd + hflags
    if len(method) > 0 && method != "GET" {
        cmd = cmd + " -X " + method
    }
    if len(body) > 0 {
        prefix = "printf '%s' " + _sse_shell_escape(body) + " | "
        cmd = cmd + " --data-binary @-"
    }
    cmd = cmd + " " + _sse_shell_escape(url)
    cmd = cmd + " 2>/dev/null"
    return prefix + cmd
}

// _sse_build_curl — thin GET-only wrapper, kept for ABI / call-site
// stability. New code can call _sse_build_curl_method directly.
fn _sse_build_curl(url: string, headers, timeout_sec: int) -> string {
    return _sse_build_curl_method(url, headers, "GET", "", timeout_sec)
}

// http_sse_available — probe streaming readiness.
//
// Returns a map: {"curl": bool, "exec_stream": bool, "any": bool}.
// `exec_stream` is best-effort detected — we currently can't probe
// builtin presence from hexa, so we report whether the AOT lowering
// path is presumed (HEXA_AOT=1 env or absent HEXA_INTERP=1). Callers
// in `hexa run` mode should treat any=false as "no streaming, fall
// back to http_sse_get_buffered".
pub fn http_sse_available() {
    let result = #{}
    let curl = to_string(exec("command -v curl >/dev/null 2>&1 && echo y || echo n")).trim()
    result["curl"] = curl == "y"
    // No reliable runtime probe for `exec_stream` symbol — report
    // based on env hint. Callers can override by setting
    // HEXA_HTTP_SSE_ASSUME_AOT=1.
    let assume_aot = env("HEXA_HTTP_SSE_ASSUME_AOT")
    result["exec_stream"] = assume_aot == "1"
    result["any"] = result["curl"] && result["exec_stream"]
    return result
}

// ── SSE event parser (pure string, no I/O) ──────────────────────────
//
// SSE spec (WHATWG HTML §9.2 server-sent events):
//   · Lines are LF or CRLF terminated.
//   · Comment line: starts with ":". Ignored.
//   · Field line: "<field>: <value>" — known fields: event, data, id, retry.
//     Unknown fields are ignored.
//   · `data` accumulates: multiple data: lines in one event are joined
//     with "\n" between them.
//   · Empty line dispatches the buffered event (event_map) to caller.
//   · Field with no colon: whole line is the field name, value = "".
//   · Leading single space after the colon is stripped per spec.

// _sse_strip_eol — drop trailing \r\n / \n / \r.
fn _sse_strip_eol(line: string) -> string {
    let n = len(line)
    if n == 0 { return line }
    let mut end = n
    if end > 0 && line.substring(end - 1, end) == "\n" { end = end - 1 }
    if end > 0 && line.substring(end - 1, end) == "\r" { end = end - 1 }
    if end == n { return line }
    return line.substring(0, end)
}

// _sse_empty_event — fresh event accumulator.
fn _sse_empty_event() {
    let ev = #{}
    ev["event"] = "message"   // SSE spec default when no `event:` field set
    ev["data"] = ""
    ev["id"] = ""
    ev["retry"] = 0
    ev["_has_data"] = false   // internal: distinguishes "no data field"
                              // from "data field with empty value".
    return ev
}

// http_sse_parse_event — feed one raw line into a partial event map.
//
// Returns a map with the same shape as the input event, mutated to
// reflect the line. The caller drives the loop; on a blank line
// (after EOL strip → ""), the caller treats the accumulated event as
// dispatchable and resets it via _sse_empty_event().
//
// Public so handle-form callers can re-use the parser without going
// through http_sse_feed (which couples it to a callback).
pub fn http_sse_parse_event(event, raw_line: string) {
    let line = _sse_strip_eol(raw_line)

    // Comment line (per spec — useful for keep-alive ":\n" pings).
    if len(line) > 0 && line.substring(0, 1) == ":" {
        return event
    }

    // Field split on first ":" — value strips one leading SP per spec.
    let colon = line.index_of(":")
    let mut field = ""
    let mut value = ""
    if colon < 0 {
        // "Field with no colon" rule: whole line is field, value = "".
        field = line
        value = ""
    } else {
        field = line.substring(0, colon)
        value = line.substring(colon + 1, len(line))
        if len(value) > 0 && value.substring(0, 1) == " " {
            value = value.substring(1, len(value))
        }
    }

    if field == "event" {
        event["event"] = value
        return event
    }
    if field == "data" {
        if event["_has_data"] {
            event["data"] = to_string(event["data"]) + "\n" + value
        } else {
            event["data"] = value
            event["_has_data"] = true
        }
        return event
    }
    if field == "id" {
        event["id"] = value
        return event
    }
    if field == "retry" {
        // Spec: retry is integer ms, ignore non-integer.
        let n = to_int(value)
        if n > 0 { event["retry"] = n }
        return event
    }
    // Unknown / empty field — ignore per spec.
    return event
}

// ── Module-scope SSE feed state ─────────────────────────────────────
//
// The runtime's exec_stream() takes a TOP-LEVEL FN IDENT for the
// callback. Closures capturing locals don't survive the codegen
// lowering (see self/main.hexa:1112-1116 — the same trick used by
// __hexa_run_stream_on_line). So the user-facing on_event callback
// is not directly reachable from inside the C-side fgets loop;
// instead we route every line through a module-scope dispatcher
// `_sse_dispatch_line`, which:
//   · maintains a partial-event accumulator
//   · calls the user's registered fn ident (set just before
//     exec_stream) on each blank line.
//
// This mirrors stdlib/http2's behaviour pattern but for streaming.
let mut _sse_user_callback = ""        // unused — see below
let mut _sse_partial_event = #{}        // current accumulator
let mut _sse_partial_initialized = false

// We also keep a "raw line" callback dispatcher for http_sse_get_lines.
let mut _sse_partial_lines_total = 0

// _sse_init_partial — reset the accumulator. Called at the start of
// each http_sse_get / http_sse_get_lines.
fn _sse_init_partial() {
    _sse_partial_event = _sse_empty_event()
    _sse_partial_initialized = true
    _sse_partial_lines_total = 0
}

// http_sse_feed — feed one raw line into a buffered SSE state and
// dispatch a complete event when a blank line is seen. Pure helper;
// the caller passes its OWN event-callback fn ident.
//
// Returns the (possibly updated) `event` map. When an event was
// dispatched, the returned map is a fresh empty event ready for the
// next reception.
//
// Note: `on_event` is a fn-ident — same constraint as exec_stream's
// callback (top-level fn, no closure capture).
pub fn http_sse_feed(event, raw_line: string, on_event) {
    let line = _sse_strip_eol(raw_line)
    if len(line) == 0 {
        // Dispatch — but only if we have any field set (avoid emitting
        // empty events on consecutive blank lines / leading blanks).
        if event["_has_data"] || to_string(event["event"]) != "message" || len(to_string(event["id"])) > 0 {
            on_event(event)
        }
        return _sse_empty_event()
    }
    return http_sse_parse_event(event, raw_line)
}

// ── exec_stream callback bridge ─────────────────────────────────────
//
// The codegen lowering for `exec_stream(cmd, ident)` requires `ident`
// to be a known top-level fn taking exactly one string arg. We expose
// one such bridge per public callback variant (event vs. raw line)
// and route to the user's fn via a module-scope ident registry.
//
// Module globals are the only state available to the bridges (no
// closures across the popen boundary — same constraint as
// __hexa_run_stream_on_line in self/main.hexa).
let mut _sse_event_user_fn = ""    // "name" of the user fn — UNUSED
                                    // (kept for future symbol-table
                                    // dispatch; today we inline-call
                                    // via an indirection table).
// fn-pointer registry: callers stash their fn here BEFORE calling
// http_sse_get(). We pull it out from the bridge.
let mut _sse_event_fn = 0           // hexa fn-value cell (untyped)
let mut _sse_line_fn = 0

fn _sse_event_bridge(line) {
    if !_sse_partial_initialized { _sse_init_partial() }
    _sse_partial_lines_total = _sse_partial_lines_total + 1
    let stripped = _sse_strip_eol(to_string(line))
    if len(stripped) == 0 {
        // Dispatch — only if event has content.
        let ev = _sse_partial_event
        let has_content = ev["_has_data"] || to_string(ev["event"]) != "message" || len(to_string(ev["id"])) > 0
        if has_content {
            let f = _sse_event_fn
            f(ev)
        }
        _sse_partial_event = _sse_empty_event()
    } else {
        _sse_partial_event = http_sse_parse_event(_sse_partial_event, to_string(line))
    }
}

fn _sse_line_bridge(line) {
    let f = _sse_line_fn
    f(to_string(line))
}

// ── Public callback API ─────────────────────────────────────────────

// http_sse_get — stream an SSE endpoint, dispatch events to callback.
//
// `on_event` is invoked with a map: {"event", "data", "id", "retry"}.
// The "_has_data" internal flag is included for callers that want to
// distinguish "no data field" from "empty data". Returns the curl
// child's exit code (0 = clean EOF).
//
// Re-entrancy: NOT thread-safe (uses module globals). Safe to call
// sequentially. Concurrent SSE streams should use http_sse_open()
// per-stream — handle-form has independent per-slot state.
pub fn http_sse_get(url: string, headers, on_event, timeout_sec: int) -> int {
    if len(url) == 0 { return 127 }
    _sse_init_partial()
    _sse_event_fn = on_event
    let cmd = _sse_build_curl(url, headers, timeout_sec)
    let rc = exec_stream(cmd, _sse_event_bridge)
    // Final-event flush: server may close without a trailing blank
    // line. Spec says incomplete events are discarded — we follow.
    _sse_partial_event = _sse_empty_event()
    return rc
}

// http_sse_get_lines — raw-line stream (pre-SSE-parse). Useful when
// the wire is plain chunked-transfer (e.g. `tail -f` semantics, NDJSON
// stream). Caller's on_line(string) gets each line with trailing "\n".
pub fn http_sse_get_lines(url: string, headers, on_line, timeout_sec: int) -> int {
    if len(url) == 0 { return 127 }
    _sse_line_fn = on_line
    let cmd = _sse_build_curl(url, headers, timeout_sec)
    return exec_stream(cmd, _sse_line_bridge)
}

// http_sse_get_buffered — interp-mode FALLBACK (no streaming benefit).
//
// Captures the entire response via exec(curl ...) then feeds each
// line through the SSE parser to `on_event`. Use this when running
// under `hexa run` (interp) where exec_stream is not registered.
// The event sequence delivered is byte-identical to http_sse_get,
// but latency = whole-response (zero streaming benefit).
//
// AOT callers should prefer http_sse_get. This exists for parity
// during development.
pub fn http_sse_get_buffered(url: string, headers, on_event, timeout_sec: int) -> int {
    if len(url) == 0 { return 127 }
    let cmd = _sse_build_curl(url, headers, timeout_sec)
    let raw = to_string(exec(cmd))
    let lines = split(raw, "\n")
    let mut ev = _sse_empty_event()
    let mut i = 0
    while i < len(lines) {
        let line = to_string(lines[i])
        if len(line) == 0 {
            let has_content = ev["_has_data"] || to_string(ev["event"]) != "message" || len(to_string(ev["id"])) > 0
            if has_content {
                on_event(ev)
            }
            ev = _sse_empty_event()
        } else {
            ev = http_sse_parse_event(ev, line)
        }
        i = i + 1
    }
    return 0
}

// ── Public handle API (incl. POST variants v1.1) ────────────────────

// http_sse_open — start a backgrounded curl stream, return a handle.
//
// Handle is the runtime exec_stream_async slot id (>= 0). On launch
// failure (slots exhausted, popen failed) returns -1. Per-slot line
// buffer is dynamic up to 1MB.
//
// Caller drives the consumer loop with http_sse_next(handle), and
// MUST call http_sse_close(handle) when done — slots are scarce
// (default 8 — see HEXA_STREAM_SLOT_COUNT in runtime.c:8869).
pub fn http_sse_open(url: string, headers, timeout_sec: int) -> int {
    if len(url) == 0 { return -1 }
    let cmd = _sse_build_curl(url, headers, timeout_sec)
    return exec_stream_async(cmd)
}

// http_sse_next — poll a handle for available lines.
//
// Returns an array of strings (each line retains trailing "\n").
// On EOF the runtime appends a "__HEXA_STREAM_EOF__" sentinel — caller
// MUST check for it and call http_sse_close(h). On a still-live
// stream with no bytes available, returns []. Non-blocking.
//
// Param name is `h` (not `handle`) because `handle` is a reserved
// keyword in hexa-lang.
pub fn http_sse_next(h: int) {
    return exec_stream_poll(h)
}

// http_sse_close — reap the handle, return curl's exit code.
// Idempotent on stale handles (returns -1 silently).
pub fn http_sse_close(h: int) -> int {
    return exec_stream_close(h)
}

// v1.1 POST callback form — parallel to http_sse_get but routes a
// request body to curl via stdin (--data-binary @-). Use for chat
// completion streaming endpoints (request body = POST'd JSON).
pub fn http_sse_post(url: string, headers, body: string, on_event, timeout_sec: int) -> int {
    if len(url) == 0 { return 127 }
    _sse_init_partial()
    _sse_event_fn = on_event
    let cmd = _sse_build_curl_method(url, headers, "POST", body, timeout_sec)
    let rc = exec_stream(cmd, _sse_event_bridge)
    _sse_partial_event = _sse_empty_event()
    return rc
}

// v1.1 POST interp fallback — parallel to http_sse_get_buffered.
// Latency = full response (zero streaming benefit); event sequence
// byte-identical to http_sse_post. For dev runs under `hexa run`
// (interp) where exec_stream is not registered.
//
// @allow-bare-exec — curl shellout is the documented v0 transport
//                    (mirror of http_sse_get_buffered above).
// @allow-silent-exit — buffered path discards curl rc by design;
//                      AOT path (http_sse_post) is the rc-aware variant.
pub fn http_sse_post_buffered(url: string, headers, body: string, on_event, timeout_sec: int) -> int {
    if len(url) == 0 { return 127 }
    let cmd = _sse_build_curl_method(url, headers, "POST", body, timeout_sec)
    let raw = to_string(exec(cmd))
    let lines = split(raw, "\n")
    let mut ev = _sse_empty_event()
    let mut i = 0
    while i < len(lines) {
        let line = to_string(lines[i])
        if len(line) == 0 {
            let has_content = ev["_has_data"] || to_string(ev["event"]) != "message" || len(to_string(ev["id"])) > 0
            if has_content {
                on_event(ev)
            }
            ev = _sse_empty_event()
        } else {
            ev = http_sse_parse_event(ev, line)
        }
        i = i + 1
    }
    return 0
}

// v1.1 POST handle form — for streaming chat completion endpoints
// that require a request body. Body is piped to curl via stdin.
pub fn http_sse_open_post(url: string, headers, body: string, timeout_sec: int) -> int {
    if len(url) == 0 { return -1 }
    let cmd = _sse_build_curl_method(url, headers, "POST", body, timeout_sec)
    return exec_stream_async(cmd)
}

// v1.1 generalized — any HTTP verb + optional body. method="" or "GET"
// behaves like http_sse_open; body="" omits --data-binary.
pub fn http_sse_open_method(url: string, headers, method: string, body: string, timeout_sec: int) -> int {
    if len(url) == 0 { return -1 }
    let cmd = _sse_build_curl_method(url, headers, method, body, timeout_sec)
    return exec_stream_async(cmd)
}

// ── Test/golden helpers (pure, no I/O) ──────────────────────────────

// http_sse_build_curl_cmd — expose the curl command builder for golden
// fixture tests (deterministic string transform, no exec()).
pub fn http_sse_build_curl_cmd(url: string, headers, timeout_sec: int) -> string {
    return _sse_build_curl(url, headers, timeout_sec)
}

// http_sse_build_curl_method_cmd — v1.1 generalized golden-fixture
// helper. Same deterministic-string contract as build_curl_cmd, but
// exposes the method+body path for POST / PUT / DELETE etc. test cases.
pub fn http_sse_build_curl_method_cmd(url: string, headers, method: string, body: string, timeout_sec: int) -> string {
    return _sse_build_curl_method(url, headers, method, body, timeout_sec)
}

// http_sse_empty_event — public ctor for the partial-event map used
// by handle-form callers driving their own parser loop.
pub fn http_sse_empty_event() {
    return _sse_empty_event()
}
