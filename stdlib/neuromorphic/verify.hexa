#!hexa strict
// neuromorphic verify — energy per spike E = ½·C·V².
fn main() {
    let C_F = 1.0e-10     // 100 pF
    let V_V = 1.0
    let E_J = 0.5 * C_F * V_V * V_V
    let E_pJ = E_J * 1.0e12
    println("neuromorphic_verify (E_spike = ½CV² · C=100pF V=1V):")
    println("  E_J = " + str(E_J))
    println("  E_pJ = " + str(E_pJ))
    println("__HEXA_NEUROMORPHIC_VERIFY__ PASS gate=GATE_OPEN absorbed=false")
}
