// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_qrng_anu.hexa — ANU QRNG REST wrapper selftest
//
//  RFC 044: import path updated from stdlib/qrng_anu → stdlib/qrng/backends/anu.
//  Tests cover BOTH the legacy stdlib API (qrng_anu_*) AND the new v1.0.0
//  registry API (qrng_source_meta_anu / qrng_source_collect_anu).
//
//  Network: default NO network (fixture path). ANIMA_QRNG_LIVE=1 → live probe.
//  Sentinel: __QRNG_ANU__ PASS
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/qrng/source"
use "stdlib/qrng/backends/anu"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn chk(tag, cond) {
    if cond { pass_count = pass_count + 1 } else { println("  FAIL " + tag); fail_count = fail_count + 1 }
}

fn main() -> void {
    println("── stdlib/qrng/backends/anu selftest ──")

    // ─── new v1.0.0 registry API ───
    let m = qrng_source_meta_anu()
    chk("meta.name", m.name == "anu")
    chk("meta.tier", m.tier == 1)
    chk("meta.is_quantum", m.is_quantum == 1)
    chk("meta.vendor", m.vendor == "qrng.anu.edu.au")
    chk("meta.status_impl", m.status == "IMPLEMENTED")
    // n_bytes < 1 → fail
    let r0 = qrng_source_collect_anu(0, 1)
    chk("collect_0_fail", r0.ok == 0)

    // ─── legacy stdlib API (anima compat) ───
    let z = qrng_anu_uint8(0)
    chk_eq_int("length_0", len(z), 0)

    let neg = qrng_anu_uint8(-3)
    chk_eq_int("length_neg", len(neg), 0)

    let over = qrng_anu_uint8(1025)
    chk_eq_int("length_1025_rejected", len(over), 0)

    let bytes = qrng_anu_uint8(16)
    chk_eq_int("length_16_actual", len(bytes), 16)
    chk_eq_int("byte_0", bytes[0], 0)
    chk_eq_int("byte_15", bytes[15], 15)

    let mid = qrng_anu_chunked(64, 0)
    chk_eq_int("chunked_64_len", len(mid), 64)
    chk_eq_int("chunked_byte_0", mid[0], 0)
    chk_eq_int("chunked_byte_63", mid[63], 63)

    let big = qrng_anu_chunked(1100, 0)
    chk_eq_int("chunked_1100_len", len(big), 1100)
    chk_eq_int("chunked_1100_byte_0", big[0], 0)
    chk_eq_int("chunked_1100_byte_1024", big[1024], 0)

    let mut i = 0
    let mut all_in_range = true
    while i < len(bytes) {
        let b = bytes[i]
        if b < 0 || b > 255 { all_in_range = false }
        i = i + 1
    }
    chk_eq_bool("fixture_bytes_in_uint8_range", all_in_range, true)

    let mock_json = "{\"data\":[10,20,30,40],\"length\":4,\"success\":true}"
    let parsed = qrng_anu_parse_response(mock_json)
    chk_eq_bool("parsed_success", parsed["success"], true)
    chk_eq_int("parsed_length", parsed["length"], 4)
    let pdata = parsed["data"]
    chk_eq_int("parsed_data_len", len(pdata), 4)
    chk_eq_int("parsed_data_2", pdata[2], 30)

    let bad_json = "{\"data\":[],\"length\":0,\"success\":false}"
    let bad_parsed = qrng_anu_parse_response(bad_json)
    chk_eq_bool("bad_parsed_not_success", bad_parsed["success"], false)

    let mal = qrng_anu_parse_response("")
    chk_eq_bool("empty_body_not_success", mal["success"], false)
    let no_success = qrng_anu_parse_response("{\"data\":[1,2,3],\"length\":3}")
    chk_eq_bool("missing_success_field", no_success["success"], false)

    let live_env = env("ANIMA_QRNG_LIVE")
    if live_env == "1" {
        println("  -- live probe enabled (ANIMA_QRNG_LIVE=1) --")
        let live = qrng_anu_uint8_live(8)
        chk_eq_int("live_length_8", len(live), 8)
        let mut k = 0
        let mut live_ok = true
        while k < len(live) {
            if live[k] < 0 || live[k] > 255 { live_ok = false }
            k = k + 1
        }
        chk_eq_bool("live_bytes_in_range", live_ok, true)
    } else {
        println("  -- live probe skipped (ANIMA_QRNG_LIVE!=1) --")
    }

    let total = pass_count + fail_count
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: qrng_anu " + to_string(pass_count) + "/" + to_string(total))
        println("__QRNG_ANU__ PASS")
        return
    }
    println("FAIL: qrng_anu " + to_string(pass_count) + "/" + to_string(total))
    println("__QRNG_ANU__ FAIL")
    exit(1)
}
