// stdlib/test/test_dynlink_caps_parse_error.hexa
// ─────────────────────────────────────────────────────────────────────
// E3 audit (commit 10e87cd1) follow-up: verify malformed cap manifest
// payloads surface as kind="parse_error" via dynlink_parse_cap_manifest_strict
// (and propagate through dynlink_full_gate), instead of silently parsing
// as an "empty plugin" that bypasses capability checks.
//
// Sentinel: __DYNLINK_CAPS_PARSE_ERROR__ PASS
//
// @cite RFC 070 §G7-D fail-closed gate · E3 audit 10e87cd1

use "stdlib/dynlink_caps"

let mut pass_count = 0
let mut fail_count = 0

fn chk(tag, cond) {
    if cond { pass_count = pass_count + 1 } else { println("  FAIL " + tag); fail_count = fail_count + 1 }
}

fn main() -> void {
    println("── stdlib/dynlink_caps strict-parse selftest ──")

    // CASE 1: empty payload → parse_error
    let r_empty = dynlink_parse_cap_manifest_strict("")
    chk("empty.ok_0", r_empty.gate.ok == 0)
    chk("empty.kind_parse_error", r_empty.gate.kind == "parse_error")
    chk("empty.manifest_empty", len(r_empty.manifest.capabilities) == 0)

    // CASE 2: non-'H' first cell → parse_error (the bypass scenario:
    // malformed-but-decodable HXC with a forged sentinel).
    let forged = hxc_v2_encode_records([["X", "id-forge", "1", "cc"], ["C", "fs.write"]])
    let r_forge = dynlink_parse_cap_manifest_strict(forged)
    chk("forge.ok_0", r_forge.gate.ok == 0)
    chk("forge.kind_parse_error", r_forge.gate.kind == "parse_error")
    chk("forge.manifest_empty", len(r_forge.manifest.capabilities) == 0)

    // CASE 3: header arity < 4 → parse_error (truncated header).
    let trunc = hxc_v2_encode_records([["H", "id-trunc"], ["C", "net.connect"]])
    let r_trunc = dynlink_parse_cap_manifest_strict(trunc)
    chk("trunc.ok_0", r_trunc.gate.ok == 0)
    chk("trunc.kind_parse_error", r_trunc.gate.kind == "parse_error")

    // CASE 4: well-formed payload → ok, manifest populated.
    let good = dynlink_encode_cap_manifest(CapManifest{
        plugin_id: "plugin.ok",
        capabilities: ["fs.read"],
        rfc_version: 1,
        compiler_id: "cc-1",
    })
    let r_good = dynlink_parse_cap_manifest_strict(good)
    chk("good.ok_1", r_good.gate.ok == 1)
    chk("good.kind_ok", r_good.gate.kind == "ok")
    chk("good.plugin_id", r_good.manifest.plugin_id == "plugin.ok")
    chk("good.caps_len_1", len(r_good.manifest.capabilities) == 1)
    chk("good.cap_value", r_good.manifest.capabilities[0] == "fs.read")

    // CASE 5: dynlink_full_gate must REJECT malformed cap payload even
    // when ABI stamp is valid and grant_table would have permitted an
    // empty manifest. This is the E3 bypass closure proof.
    let abi_good = dynlink_encode_abi_stamp(AbiStamp{
        runtime_version: dynlink_host_runtime_version(),
        nanbox_layout_hash: dynlink_host_nanbox_layout_hash(),
    })
    let full_res = dynlink_full_gate(abi_good, forged, ["fs.write"])
    chk("full_gate.malformed_rejected", full_res.ok == 0)
    chk("full_gate.kind_parse_error", full_res.kind == "parse_error")

    // CASE 6: dynlink_full_gate ACCEPTS a well-formed payload with all
    // capabilities granted (positive control).
    let full_ok = dynlink_full_gate(abi_good, good, ["fs.read"])
    chk("full_gate.good_accepted", full_ok.ok == 1)
    chk("full_gate.good_kind_ok", full_ok.kind == "ok")

    let total = pass_count + fail_count
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: dynlink_caps_parse_error " + to_string(pass_count) + "/" + to_string(total))
        println("__DYNLINK_CAPS_PARSE_ERROR__ PASS")
        return
    }
    println("FAIL: dynlink_caps_parse_error " + to_string(pass_count) + "/" + to_string(total))
}
