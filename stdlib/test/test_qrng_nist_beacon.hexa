// stdlib/test/test_qrng_nist_beacon.hexa — NIST Beacon 2.0 selftest
//
// Sentinel: __QRNG_NIST_BEACON__ PASS

use "stdlib/qrng/source"
use "stdlib/qrng/backends/nist_beacon"

let mut pass_count = 0
let mut fail_count = 0

fn chk(tag, cond) {
    if cond { pass_count = pass_count + 1 } else { println("  FAIL " + tag); fail_count = fail_count + 1 }
}

fn main() -> void {
    println("── stdlib/qrng/backends/nist_beacon selftest ──")

    let m = qrng_source_meta_nist_beacon()
    chk("meta.name", m.name == "nist_beacon")
    chk("meta.tier", m.tier == 1)
    // Honest C3: nist_beacon is MIXED entropy (HSM + RNGs), is_quantum=0
    chk("meta.is_quantum_mixed", m.is_quantum == 0)
    chk("meta.is_local", m.is_local == 0)
    chk("meta.is_free", m.is_free == 1)
    chk("meta.vendor", m.vendor == "nist")
    chk("meta.status", m.status == "IMPLEMENTED")

    let r0 = qrng_source_collect_nist_beacon(0, 1)
    chk("collect_0_fail", r0.ok == 0)
    let r_big = qrng_source_collect_nist_beacon(65, 1)
    chk("collect_65_fail", r_big.ok == 0)
    let r_gated = qrng_source_collect_nist_beacon(8, 1)
    chk("collect_gated_fail", r_gated.ok == 0)

    let total = pass_count + fail_count
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: qrng_nist_beacon " + to_string(pass_count) + "/" + to_string(total))
        println("__QRNG_NIST_BEACON__ PASS")
        return
    }
    println("FAIL: qrng_nist_beacon " + to_string(pass_count) + "/" + to_string(total))
    println("__QRNG_NIST_BEACON__ FAIL")
    exit(1)
}
