// stdlib/test/test_llm.hexa — isolated golden-fixture test for llm.hexa
//
// Self-contained (NO `use` import) so it compiles + runs without the local
// module_loader (multi-use builds link-fail locally; this is the parse-gate +
// isolated-logic-test gate per the stdlib CLI verify recipe). The pure
// request-builders are copied verbatim from llm.hexa; any drift between this
// copy and the module is the test's job to surface.
//
// NO network / NO LLM call / NO keychain read / NO cost. We assert the COMPOSED
// REQUEST (body + headers) the IO function WOULD send, built with a FAKE key:
//   · headers — byte-exact (pure string concat, deterministic)
//   · body    — round-tripped through json_parse and asserted structurally
//               (model id + messages role/content), so the test is robust to
//               json_stringify's exact compact spacing.

fn llm_provider(url: string, model: string, kc_service: string, kc_account: string) {
    let p = #{}
    p["url"] = url
    p["model"] = model
    p["kc_service"] = kc_service
    p["kc_account"] = kc_account
    return p
}

fn llm_message(role: string, content: string) {
    let m = #{}
    m["role"] = role
    m["content"] = content
    return m
}

fn llm_build_messages_body(model: string, messages) -> string {
    let body = #{}
    body["model"] = model
    body["messages"] = messages
    return json_stringify(body)
}

fn llm_build_body(model: string, prompt: string) -> string {
    let messages = []
    messages.push(llm_message("user", prompt))
    return llm_build_messages_body(model, messages)
}

fn llm_build_headers(api_key: string) {
    let h = #{}
    h["Authorization"] = "Bearer " + api_key
    h["Content-Type"] = "application/json"
    return h
}

// ── Anthropic Messages-API builders (copied verbatim from llm.hexa) ──

fn llm_build_body_anthropic(model: string, system: string, messages, max_tokens: int) -> string {
    let body = #{}
    body["model"] = model
    body["max_tokens"] = max_tokens
    if len(system) > 0 {
        body["system"] = system
    }
    body["messages"] = messages
    return json_stringify(body)
}

fn llm_build_headers_anthropic(api_key: string, version: string) {
    let h = #{}
    h["x-api-key"] = api_key
    h["anthropic-version"] = version
    h["Content-Type"] = "application/json"
    return h
}

// ── SSE stream-decode (copied verbatim from llm.hexa) ────────────────

fn _llm_sse_data_payload(raw_line: string) -> string {
    let mut line = raw_line
    let n = len(line)
    let mut end = n
    if end > 0 && line.substring(end - 1, end) == "\n" { end = end - 1 }
    if end > 0 && line.substring(end - 1, end) == "\r" { end = end - 1 }
    if end != n { line = line.substring(0, end) }
    if len(line) < 5 { return "" }
    if line.substring(0, 5) != "data:" { return "" }
    let mut value = line.substring(5, len(line))
    if len(value) > 0 && value.substring(0, 1) == " " {
        value = value.substring(1, len(value))
    }
    return value
}

fn _llm_openai_delta_content(frame) -> string {
    if type_of(frame) != "map" { return "" }
    let choices = frame["choices"]
    if type_of(choices) != "array" { return "" }
    if len(choices) == 0 { return "" }
    let c0 = choices[0]
    if type_of(c0) != "map" { return "" }
    let delta = c0["delta"]
    if type_of(delta) != "map" { return "" }
    let content = delta["content"]
    if type_of(content) != "string" { return "" }
    return to_string(content)
}

fn llm_stream_decode(sse_lines) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(sse_lines) {
        let payload = _llm_sse_data_payload(to_string(sse_lines[i]))
        i = i + 1
        if len(payload) == 0 { continue }
        if payload == "[DONE]" { break }
        let frame = json_parse(payload)
        out = out + _llm_openai_delta_content(frame)
    }
    return out
}

fn expect(name: string, got: string, want: string) -> int {
    if got == want {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name)
    println("  got : " + got)
    println("  want: " + want)
    return 1
}

fn expect_bool(name: string, got: bool, want: bool) -> int {
    if got == want {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    return 1
}

fn main() {
    let mut fails = 0

    // ── headers: byte-exact (pure concat) ─────────────────────────
    let h = llm_build_headers("sk-FAKE-KEY-123")
    fails = fails + expect(
        "headers Authorization bearer",
        to_string(h["Authorization"]),
        "Bearer sk-FAKE-KEY-123"
    )
    fails = fails + expect(
        "headers Content-Type json",
        to_string(h["Content-Type"]),
        "application/json"
    )

    // ── single-prompt body (MVP): round-trip structural assert ────
    let body = llm_build_body("gpt-4o-mini", "Hello, world")
    let parsed = json_parse(body)
    fails = fails + expect(
        "body model id",
        to_string(parsed["model"]),
        "gpt-4o-mini"
    )
    let msgs = parsed["messages"]
    fails = fails + expect_bool("body has 1 message", len(msgs) == 1, true)
    fails = fails + expect(
        "body msg[0] role user",
        to_string(msgs[0]["role"]),
        "user"
    )
    fails = fails + expect(
        "body msg[0] content",
        to_string(msgs[0]["content"]),
        "Hello, world"
    )

    // ── escape safety: a quote + newline in the prompt survives ───
    let tricky = llm_build_body("m", "say \"hi\"\nthen bye")
    let tparsed = json_parse(tricky)
    let tmsgs = tparsed["messages"]
    fails = fails + expect(
        "body escapes quote+newline (round-trip)",
        to_string(tmsgs[0]["content"]),
        "say \"hi\"\nthen bye"
    )

    // ── multi-message body: system + user preserved in order ──────
    let conv = []
    conv.push(llm_message("system", "You are terse."))
    conv.push(llm_message("user", "2+2?"))
    let mbody = llm_build_messages_body("gpt-4o", conv)
    let mparsed = json_parse(mbody)
    let mm = mparsed["messages"]
    fails = fails + expect_bool("multi body has 2 messages", len(mm) == 2, true)
    fails = fails + expect("multi msg[0] system role", to_string(mm[0]["role"]), "system")
    fails = fails + expect("multi msg[1] user content", to_string(mm[1]["content"]), "2+2?")
    fails = fails + expect("multi body model", to_string(mparsed["model"]), "gpt-4o")

    // ── provider config carries the four call-site coordinates ────
    let p = llm_provider("https://api.openai.com/v1/chat/completions", "gpt-4o-mini", "dancinlab.secret", "openai.api_key")
    fails = fails + expect("provider url", to_string(p["url"]), "https://api.openai.com/v1/chat/completions")
    fails = fails + expect("provider model", to_string(p["model"]), "gpt-4o-mini")
    fails = fails + expect("provider kc_service", to_string(p["kc_service"]), "dancinlab.secret")
    fails = fails + expect("provider kc_account", to_string(p["kc_account"]), "openai.api_key")

    // ── Anthropic headers: x-api-key + anthropic-version (NOT bearer) ─
    let ah = llm_build_headers_anthropic("sk-ant-FAKE-999", "2023-06-01")
    fails = fails + expect("anthropic header x-api-key", to_string(ah["x-api-key"]), "sk-ant-FAKE-999")
    fails = fails + expect("anthropic header version", to_string(ah["anthropic-version"]), "2023-06-01")
    fails = fails + expect("anthropic header content-type", to_string(ah["Content-Type"]), "application/json")
    // anthropic must NOT carry a bearer Authorization header
    fails = fails + expect_bool("anthropic header no bearer", type_of(ah["Authorization"]) == "string", false)

    // ── Anthropic body: system top-level + required max_tokens ────────
    let aconv = []
    aconv.push(llm_message("user", "ping"))
    let abody = llm_build_body_anthropic("claude-3-5-sonnet", "You are terse.", aconv, 256)
    let aparsed = json_parse(abody)
    fails = fails + expect("anthropic body model", to_string(aparsed["model"]), "claude-3-5-sonnet")
    // system is a TOP-LEVEL field (not a message role)
    fails = fails + expect("anthropic body system top-level", to_string(aparsed["system"]), "You are terse.")
    // max_tokens is present
    fails = fails + expect("anthropic body max_tokens", to_string(aparsed["max_tokens"]), "256")
    let amsgs = aparsed["messages"]
    fails = fails + expect_bool("anthropic body has 1 message", len(amsgs) == 1, true)
    fails = fails + expect("anthropic body msg[0] role user", to_string(amsgs[0]["role"]), "user")
    // empty system → field omitted
    let abody2 = llm_build_body_anthropic("claude-3-haiku", "", aconv, 64)
    let aparsed2 = json_parse(abody2)
    fails = fails + expect_bool("anthropic body omits empty system", type_of(aparsed2["system"]) == "string", false)

    // ── SSE decode: OpenAI choices[].delta.content deltas → "Hello" ───
    let sse = []
    sse.push("data: {\"choices\":[{\"delta\":{\"content\":\"He\"}}]}")
    sse.push("data: {\"choices\":[{\"delta\":{\"content\":\"llo\"}}]}")
    sse.push("data: [DONE]")
    fails = fails + expect("sse decode concatenates deltas", llm_stream_decode(sse), "Hello")

    // first frame role-only (no content) + keep-alive/blank lines ignored
    let sse2 = []
    sse2.push("data: {\"choices\":[{\"delta\":{\"role\":\"assistant\"}}]}")
    sse2.push(": keep-alive")
    sse2.push("")
    sse2.push("data: {\"choices\":[{\"delta\":{\"content\":\"Hi\"}}]}")
    sse2.push("data: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}]}")
    sse2.push("data: [DONE]")
    fails = fails + expect("sse decode skips role/finish/keepalive", llm_stream_decode(sse2), "Hi")

    if fails == 0 {
        println("ALL PASS (28/28)")
    } else {
        println("FAILURES: " + to_string(fails))
    }
}
