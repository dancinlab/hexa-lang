#!hexa strict
// stdlib/verify/calculators/eliashberg_full.hexa
//
// Allen–Dynes 1975 STRONG-COUPLING Tc with f1·f2 corrections (the "full"
// Allen–Dynes formula beyond the bare McMillan / plain Allen–Dynes):
//
//   T_c = (f1 · f2 · ω_log / 1.20) · exp[ -1.04(1+λ) / (λ − μ*(1+0.62λ)) ]
//
//   f1(λ, μ*)            = [ 1 + (λ / Λ_1(μ*))^(3/2) ]^(1/3)
//   f2(λ, ω2_over_omega) = 1 + ((ω̄₂/ω_log − 1) λ²) / (λ² + Λ_2(μ*)²)
//
//   Λ_1(μ*) = 2.46 · (1 + 3.8 μ*)
//   Λ_2(μ*) = 1.82 · (1 + 6.3 μ*) · (ω̄₂/ω_log)
//
// At λ ≪ 1 (weak coupling) f1·f2 → 1, recovering the plain Allen–Dynes
// formula. At λ ≳ 1.5 (strong coupling — H₃S, MgB₂, hydrides) f1·f2 lifts
// Tc by 10–40 % above plain Allen–Dynes.
//
// Identity references:
//   · Allen & Dynes 1975 — Phys.Rev.B 12 905, eqs. (3.1)–(3.4)
//   · Carbotte 1990 review — Rev.Mod.Phys. 62 1027
//
// PR-hx2 (verify-atlas direct-fold) — first impl in stdlib + assumes meta.

use "self/runtime/math_pure"

// ─── canonical fn ──────────────────────────────────────────────────────

fn eliashberg_full(omega_log: float, omega2: float, lambda: float, mu_star: float) -> float {
    if lambda <= 0.0 { return 0.0 }
    let exp_den = lambda - mu_star * (1.0 + 0.62 * lambda)
    if exp_den <= 0.0 { return 0.0 }

    // f1 — strong-coupling lift
    let lam1 = 2.46 * (1.0 + 3.8 * mu_star)
    let f1_inner = 1.0 + pow_pure(lambda / lam1, 1.5)
    let f1 = pow_pure(f1_inner, 1.0 / 3.0)

    // f2 — spectral-shape correction (ω̄₂ vs ω_log ratio)
    let ratio = omega2 / omega_log
    let lam2 = 1.82 * (1.0 + 6.3 * mu_star) * ratio
    let f2_num = (ratio - 1.0) * lambda * lambda
    let f2_den = lambda * lambda + lam2 * lam2
    let f2 = 1.0 + f2_num / f2_den

    let prefactor = (f1 * f2 * omega_log) / 1.20
    let exp_num = -1.04 * (1.0 + lambda)
    return prefactor * exp_pure(exp_num / exp_den)
}

// ─── @assumes metadata (introspect-able) ───────────────────────────────

fn eliashberg_full_assumes() -> [str] {
    return [
        "BCS-strong-coupling",
        "Migdal-approximation (Omega_ph << E_F)",
        "Eliashberg-isotropic alpha2F(omega)",
        "harmonic-phonons (near-equilibrium)",
        "Morel-Anderson mu_star renormalisation",
        "omega_2 >= omega_log (spectral-moment ordering)",
    ]
}

fn eliashberg_full_provenance() -> str {
    return "Allen-Dynes 1975 Phys.Rev.B 12 905 eqs 3.1-3.4 · Carbotte 1990 review"
}
