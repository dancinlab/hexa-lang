// stdlib/bio/uniprot.hexa — UniProt + AlphaFold DB REST clients (JSON).
//
// Two thin REST adapters used by TTR docking-target intake:
//   · uniprot_fetch(acc)   → https://rest.uniprot.org/uniprotkb/<ACC>.json
//   · alphafold_fetch(acc) → https://alphafold.ebi.ac.uk/api/prediction/<ACC>
//
// ⚠ DEPRECATION — AlphaFold DB public REST sunset 2026-06-25.
//   When the endpoint goes dark, callers should fall back to the UniProt
//   structure cross-reference section (`uniProtKBCrossReferences`
//   `database == "AlphaFoldDB"` rows), or to the EBI replacement endpoint
//   announced on https://alphafold.ebi.ac.uk. The parse helper
//   `alphafold_parse` stays useful: it is pure (no network) and runs
//   against any cached JSON body identical to today's array-of-1 shape.
//
// Per @D try-live-or-fallback: pure parsers `uniprot_parse` /
// `alphafold_parse` are exposed so tests can run offline against the
// captured frozen fixtures (P05067 — Amyloid-β Precursor Protein).
//
// JSON strategy: prefer the builtin `json_parse` map-walk; on the very
// few free-text fields where the runtime decoder is brittle (deeply
// quoted FUNCTION comment body), we fall back to substring slicing
// over the raw body. Same belt-and-suspenders idiom as `stdlib/proc`.

struct UniprotEntry {
    accession: string,        // "P05067"
    name: string,             // recommended full name, e.g. "Amyloid-beta precursor protein"
    gene: string,             // primary gene symbol, e.g. "APP"
    organism: string,         // scientific name, e.g. "Homo sapiens"
    sequence: string,         // single-letter amino acid sequence
    sequence_length: int,     // residue count
    function: string,         // first FUNCTION comment text (may be long)
}

struct AlphafoldPrediction {
    accession: string,        // mirror of UniProt accession the model was built for
    pdb_url: string,          // canonical .pdb file URL
    cif_url: string,          // canonical mmCIF file URL
    plddt_mean: float,        // global pLDDT confidence (`globalMetricValue`)
    model_url: string,        // alias for the model entity id ("AF-<ACC>-F1")
    version: int,             // `latestVersion`
}

let UNIPROT_API_BASE   = "https://rest.uniprot.org/uniprotkb/"
let ALPHAFOLD_API_BASE = "https://alphafold.ebi.ac.uk/api/prediction/"

// ── string utilities (substring fallback path) ──────────────────────

fn _idx(hay: string, needle: string, from: int) -> int {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return from }
    if m > n { return -1 }
    let mut i = from
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return i }
        i = i + 1
    }
    return -1
}

// Slice the value of a JSON string field `"<key>":"<value>"` (no nesting
// awareness — caller must scope the search via `from`).
fn _json_str_field(body: string, key: string, from: int) -> string {
    let needle = "\"" + key + "\":\""
    let a = _idx(body, needle, from)
    if a < 0 { return "" }
    let v_from = a + len(needle)
    // Find closing quote, honouring backslash-escapes.
    let n = len(body)
    let mut i = v_from
    while i < n {
        let c = body.substring(i, i + 1)
        if c == "\\" { i = i + 2; continue }
        if c == "\"" { return body.substring(v_from, i) }
        i = i + 1
    }
    return ""
}

// Slice the value of a JSON numeric/bool field `"<key>":<value>`.
// Returns the raw token (caller converts via to_int / to_float).
fn _json_num_field(body: string, key: string, from: int) -> string {
    let needle = "\"" + key + "\":"
    let a = _idx(body, needle, from)
    if a < 0 { return "" }
    let v_from = a + len(needle)
    let n = len(body)
    let mut i = v_from
    while i < n {
        let c = body.substring(i, i + 1)
        if c == "," || c == "}" || c == "]" || c == " " || c == "\n" { break }
        i = i + 1
    }
    return body.substring(v_from, i)
}

// ── UniProt parse ───────────────────────────────────────────────────

// Pull the first FUNCTION comment from the raw JSON body via substring
// scan — the runtime json_parse can be brittle on the long, embedded-
// quote-heavy free text of UniProt's FUNCTION comments. We anchor on
// `"commentType":"FUNCTION"` then scoop the next `"value":"…"`.
fn _uniprot_function_text(body: string) -> string {
    let a = _idx(body, "\"commentType\":\"FUNCTION\"", 0)
    if a < 0 { return "" }
    return _json_str_field(body, "value", a)
}

// uniprot_parse — pure: decode a UniProtKB JSON body. On a deformed body
// the returned record carries empty strings + zero length (caller checks
// `len(e.accession) > 0` to disambiguate from a real hit).
pub fn uniprot_parse(json_body: string) -> UniprotEntry {
    let empty = UniprotEntry{
        accession: "", name: "", gene: "", organism: "",
        sequence: "", sequence_length: 0, function: "",
    }
    if len(json_body) == 0 { return empty }

    let parsed = json_parse(json_body)
    if type_of(parsed) != "map" {
        // Pure-substring fallback for malformed/partial JSON
        return UniprotEntry{
            accession:       _json_str_field(json_body, "primaryAccession", 0),
            name:            "",
            gene:            "",
            organism:        _json_str_field(json_body, "scientificName", 0),
            sequence:        _json_str_field(json_body, "value", _idx(json_body, "\"sequence\":", 0)),
            sequence_length: 0,
            function:        _uniprot_function_text(json_body),
        }
    }

    let mut accession = ""
    if has_key(parsed, "primaryAccession") { accession = to_string(parsed["primaryAccession"]) }

    let mut name = ""
    if has_key(parsed, "proteinDescription") {
        let pd = parsed["proteinDescription"]
        if type_of(pd) == "map" && has_key(pd, "recommendedName") {
            let rn = pd["recommendedName"]
            if type_of(rn) == "map" && has_key(rn, "fullName") {
                let fn_ = rn["fullName"]
                if type_of(fn_) == "map" && has_key(fn_, "value") {
                    name = to_string(fn_["value"])
                }
            }
        }
    }

    let mut gene = ""
    if has_key(parsed, "genes") {
        let gs = parsed["genes"]
        if type_of(gs) == "array" && len(gs) > 0 {
            let g0 = gs[0]
            if type_of(g0) == "map" && has_key(g0, "geneName") {
                let gn = g0["geneName"]
                if type_of(gn) == "map" && has_key(gn, "value") {
                    gene = to_string(gn["value"])
                }
            }
        }
    }

    let mut organism = ""
    if has_key(parsed, "organism") {
        let o = parsed["organism"]
        if type_of(o) == "map" && has_key(o, "scientificName") {
            organism = to_string(o["scientificName"])
        }
    }

    let mut sequence = ""
    let mut sequence_length = 0
    if has_key(parsed, "sequence") {
        let sq = parsed["sequence"]
        if type_of(sq) == "map" {
            if has_key(sq, "value")  { sequence = to_string(sq["value"]) }
            if has_key(sq, "length") { sequence_length = to_int(to_string(sq["length"])) }
        }
    }

    // FUNCTION text: substring scan is more robust than walking the
    // nested comments[] / texts[] arrays through json_parse on bodies
    // that contain embedded quotes & punctuation.
    let function_text = _uniprot_function_text(json_body)

    return UniprotEntry{
        accession:       accession,
        name:            name,
        gene:            gene,
        organism:        organism,
        sequence:        sequence,
        sequence_length: sequence_length,
        function:        function_text,
    }
}

// uniprot_fetch — live GET `<base>/<ACC>.json`. Returns a sentinel empty
// record on network failure (caller checks `len(e.accession) > 0`).
pub fn uniprot_fetch(accession: string) -> UniprotEntry {
    let empty = UniprotEntry{
        accession: "", name: "", gene: "", organism: "",
        sequence: "", sequence_length: 0, function: "",
    }
    if len(accession) == 0 { return empty }
    let url = UNIPROT_API_BASE + accession + ".json"
    let body = http_get(url)
    return uniprot_parse(body)
}

// ── AlphaFold parse ─────────────────────────────────────────────────

// The AlphaFold DB endpoint returns a JSON array of length 1 (one
// prediction record per UniProt accession). We pull element [0].
//
// ⚠ The endpoint is scheduled for sunset 2026-06-25. After that date,
// callers should query UniProt's `uniProtKBCrossReferences` section for
// AlphaFoldDB rows and synthesize the URL from the model entity id
// directly (canonical pattern below remains stable for cached files).
pub fn alphafold_parse(json_body: string) -> AlphafoldPrediction {
    let empty = AlphafoldPrediction{
        accession: "", pdb_url: "", cif_url: "",
        plddt_mean: 0.0, model_url: "", version: 0,
    }
    if len(json_body) == 0 { return empty }

    let parsed = json_parse(json_body)
    if type_of(parsed) != "array" || len(parsed) == 0 {
        // Substring fallback — the endpoint also occasionally returns a
        // bare object during EBI maintenance windows. Treat the body as
        // a flat key/value soup.
        let plddt_raw = _json_num_field(json_body, "globalMetricValue", 0)
        let ver_raw   = _json_num_field(json_body, "latestVersion", 0)
        return AlphafoldPrediction{
            accession:  _json_str_field(json_body, "uniprotAccession", 0),
            pdb_url:    _json_str_field(json_body, "pdbUrl", 0),
            cif_url:    _json_str_field(json_body, "cifUrl", 0),
            plddt_mean: if len(plddt_raw) > 0 { to_float(plddt_raw) } else { 0.0 },
            model_url:  _json_str_field(json_body, "modelEntityId", 0),
            version:    if len(ver_raw) > 0 { to_int(ver_raw) } else { 0 },
        }
    }

    let r = parsed[0]
    if type_of(r) != "map" { return empty }

    let mut accession = ""
    if has_key(r, "uniprotAccession") { accession = to_string(r["uniprotAccession"]) }

    let mut pdb_url = ""
    if has_key(r, "pdbUrl") { pdb_url = to_string(r["pdbUrl"]) }

    let mut cif_url = ""
    if has_key(r, "cifUrl") { cif_url = to_string(r["cifUrl"]) }

    let mut plddt_mean = 0.0
    if has_key(r, "globalMetricValue") {
        plddt_mean = to_float(to_string(r["globalMetricValue"]))
    }

    let mut model_url = ""
    if has_key(r, "modelEntityId") { model_url = to_string(r["modelEntityId"]) }

    let mut version = 0
    if has_key(r, "latestVersion") { version = to_int(to_string(r["latestVersion"])) }

    return AlphafoldPrediction{
        accession:  accession,
        pdb_url:    pdb_url,
        cif_url:    cif_url,
        plddt_mean: plddt_mean,
        model_url:  model_url,
        version:    version,
    }
}

// alphafold_fetch — live GET. Returns a sentinel empty record on network
// failure or post-sunset 404. Callers should verify `len(p.pdb_url) > 0`.
pub fn alphafold_fetch(accession: string) -> AlphafoldPrediction {
    let empty = AlphafoldPrediction{
        accession: "", pdb_url: "", cif_url: "",
        plddt_mean: 0.0, model_url: "", version: 0,
    }
    if len(accession) == 0 { return empty }
    let url = ALPHAFOLD_API_BASE + accession
    let body = http_get(url)
    return alphafold_parse(body)
}
