// stdlib/bio/mirna/mirbase_subset.hexa — hardcoded miRBase v22 mature-miRNA registry (human canonical subset).
//
// @version 0.1.0
// @capabilities [pure]
//
// PURE static registry of well-known human mature miRNAs sourced from
// miRBase v22 (the canonical release; IDs are stable across v22 → v22.1).
// Sequences are in RNA alphabet (A,C,G,U) — the convention used by
// miRBase and TargetScan publications.
//
// Public surface:
//   pub fn mirbase_lookup(name: string) -> MirnaEntry   // sentinel-empty on miss
//   pub fn mirbase_all() -> [MirnaEntry]                // hardcoded list
//
// All sequences cross-checked against miRBase v22 mature.fa
// (https://www.mirbase.org/download/mature.fa). Sentinel for missing
// lookup is an entry with empty `name` / `mirbase_id` / `sequence`.

struct MirnaEntry {
    name: string,
    mirbase_id: string,
    sequence: string,
    organism: string,
}

// Build the canonical registry. ~20 well-known human miRNAs spanning
// canonical regulators: let-7 family · oncomiRs · tumor suppressor miRs
// · liver-specific miR-122 · neural miR-9 · EMT miR-200c · brown-fat
// miR-378a · macrophage miR-146a · etc.
fn _build_registry() -> array {
    let mut r = []
    r.push(MirnaEntry { name: "hsa-let-7a-5p",  mirbase_id: "MIMAT0000062", sequence: "UGAGGUAGUAGGUUGUAUAGUU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-let-7b-5p",  mirbase_id: "MIMAT0000063", sequence: "UGAGGUAGUAGGUUGUGUGGUU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-21-5p",  mirbase_id: "MIMAT0000076", sequence: "UAGCUUAUCAGACUGAUGUUGA", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-122-5p", mirbase_id: "MIMAT0000421", sequence: "UGGAGUGUGACAAUGGUGUUUG", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-155-5p", mirbase_id: "MIMAT0000646", sequence: "UUAAUGCUAAUUGUGAUAGGGGU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-29a-3p", mirbase_id: "MIMAT0000086", sequence: "UAGCACCAUCUGAAAUCGGUUA", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-34a-5p", mirbase_id: "MIMAT0000255", sequence: "UGGCAGUGUCUUAGCUGGUUGU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-200c-3p", mirbase_id: "MIMAT0000617", sequence: "UAAUACUGCCGGGUAAUGAUGGA", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-9-5p",   mirbase_id: "MIMAT0000441", sequence: "UCUUUGGUUAUCUAGCUGUAUGA", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-146a-5p", mirbase_id: "MIMAT0000449", sequence: "UGAGAACUGAAUUCCAUGGGUU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-17-5p",  mirbase_id: "MIMAT0000070", sequence: "CAAAGUGCUUACAGUGCAGGUAG", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-18a-5p", mirbase_id: "MIMAT0000072", sequence: "UAAGGUGCAUCUAGUGCAGAUAG", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-19a-3p", mirbase_id: "MIMAT0000073", sequence: "UGUGCAAAUCUAUGCAAAACUGA", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-92a-3p", mirbase_id: "MIMAT0000092", sequence: "UAUUGCACUUGUCCCGGCCUGU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-125b-5p", mirbase_id: "MIMAT0000423", sequence: "UCCCUGAGACCCUAACUUGUGA", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-126-3p", mirbase_id: "MIMAT0000445", sequence: "UCGUACCGUGAGUAAUAAUGCG", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-378a-3p", mirbase_id: "MIMAT0000732", sequence: "ACUGGACUUGGAGUCAGAAGGC", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-451a",   mirbase_id: "MIMAT0001631", sequence: "AAACCGUUACCAUUACUGAGUU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-7-5p",   mirbase_id: "MIMAT0000252", sequence: "UGGAAGACUAGUGAUUUUGUUGU", organism: "Homo sapiens" })
    r.push(MirnaEntry { name: "hsa-miR-181a-5p", mirbase_id: "MIMAT0000256", sequence: "AACAUUCAACGCUGUCGGUGAGU", organism: "Homo sapiens" })
    return r
}

pub fn mirbase_all() -> array {
    return _build_registry()
}

pub fn mirbase_lookup(name: string) -> MirnaEntry {
    let all = _build_registry()
    let n = len(all)
    let mut i = 0
    while i < n {
        let e = all[i]
        if e.name == name { return e }
        i = i + 1
    }
    // Sentinel-empty entry on miss.
    return MirnaEntry { name: "", mirbase_id: "", sequence: "", organism: "" }
}
