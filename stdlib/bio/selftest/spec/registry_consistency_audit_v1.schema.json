{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/selftest/spec/registry_consistency_audit_v1.schema.json",
  "title": "Registry-vs-spec consistency audit witness v1",
  "description": "Aggregate witness emitted by selftest/registry_consistency_audit.py. Validates registry rows against spec schemas with const-tagged schema fields. Reference: cycle-26 closure session iter 26.",
  "type": "object",
  "required": [
    "schema",
    "audited_at",
    "audit_kind",
    "n_total_rows",
    "n_covered_by_spec",
    "n_uncovered_by_spec",
    "n_validate_pass",
    "n_validate_fail",
    "overall_pass",
    "witness_ref"
  ],
  "properties": {
    "schema": {"type": "string", "const": "raw_77_registry_consistency_audit_v1"},
    "audited_at": {"type": "string", "format": "date-time"},
    "audit_kind": {"type": "string"},
    "n_total_rows": {"type": "integer", "minimum": 0},
    "n_covered_by_spec": {"type": "integer", "minimum": 0},
    "n_uncovered_by_spec": {"type": "integer", "minimum": 0},
    "n_validate_pass": {"type": "integer", "minimum": 0},
    "n_validate_fail": {"type": "integer", "minimum": 0},
    "uncovered_schema_tags": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 1}
    },
    "fail_details": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "line": {"type": "integer"},
          "schema": {"type": "string"},
          "errors": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "specs_loaded": {
      "type": "array",
      "items": {"type": "string"}
    },
    "overall_pass": {"type": "boolean"},
    "raw_91_c3_disclose": {"type": "string"},
    "raw_77_append_only": {"type": "boolean"},
    "witness_ref": {
      "type": "string",
      "pattern": "^state/discovery_absorption/registry\\.jsonl#raw_77_registry_consistency_audit_v1$"
    }
  }
}
