{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/selftest/spec/regression_audit_v1.schema.json",
  "title": "F-*-REGRESSION runner aggregate witness v1",
  "description": "Aggregate witness emitted by selftest/regression_audit.py. One row per CI hook invocation containing per-falsifier verdicts and baseline essential-fields hashes. Reference: .roadmap.hexa_bio §A.9 + §G GATE-26-6.",
  "type": "object",
  "required": [
    "schema",
    "audited_at",
    "audit_kind",
    "n_regressions",
    "n_pass",
    "n_fail",
    "overall_pass",
    "per_falsifier",
    "witness_ref"
  ],
  "properties": {
    "schema": {"type": "string", "const": "raw_77_regression_audit_v1"},
    "audited_at": {"type": "string", "format": "date-time"},
    "audit_kind": {"type": "string"},
    "n_regressions": {"type": "integer", "minimum": 1},
    "n_pass": {"type": "integer", "minimum": 0},
    "n_fail": {"type": "integer", "minimum": 0},
    "overall_pass": {"type": "boolean"},
    "per_falsifier": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["falsifier", "verdict"],
        "properties": {
          "falsifier": {"type": "string"},
          "script": {"type": "string"},
          "verdict": {"type": "string", "enum": ["PASS", "FAIL"]},
          "exit_code": {"type": "integer"},
          "expect_sentinel": {"type": "string"},
          "sentinel_present": {"type": "boolean"},
          "baseline_witness_schema": {"type": "string"},
          "baseline_essential_hash": {"type": "string"},
          "baseline_present": {"type": "boolean"},
          "stdout_tail": {"type": "string"}
        }
      }
    },
    "raw_91_c3_disclose": {"type": "string"},
    "raw_77_append_only": {"type": "boolean"},
    "witness_ref": {
      "type": "string",
      "pattern": "^state/discovery_absorption/registry\\.jsonl#raw_77_regression_audit_v1$"
    }
  }
}
