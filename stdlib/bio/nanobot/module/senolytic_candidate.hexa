#!hexa strict
//
// nanobot/module/senolytic_candidate.hexa — C2 cell N·δ.
//
// HEXA-NATIVE port of _python_bridge/module/nanobot_senolytic_candidate.py
// (R5 sunset 50/57, 2026-05-07).

use "nanobot/module/actuation_simulation"

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn build_candidate() {
    let c = {}
    c["target_disease_class_label"] = "delta_senolytic"
    c["matrix_cell_label"] = "N_delta"
    c["marker_referenced"] = "senescence-associated surface marker (public catalogued)"
    c["skeleton"] = "truncated_icosahedron"
    c["n_vertices"] = 12

    let dec = {}
    dec["vertex_idx"] = 0
    dec["ligand_module_id"] = "anti_p16_associated_marker_scfv_stub"
    dec["binding_domain_class"] = "anti-senescence-marker scFv (illustrative public AB DB stub)"
    dec["binding_affinity_M_lit"] = 1.0e-9
    dec["source_lit"] = "public antibody database catalogued"
    let decs = []
    decs.push(dec)
    c["vertex_decorations"] = decs

    c["payload_slot"] = "unspecified-placeholder-no-molecule-modeled"
    c["motor_cycle_states"] = 4
    let snames = []
    snames.push("S0_idle"); snames.push("S1_fwd_stroke"); snames.push("S2_back_stroke"); snames.push("S3_reset")
    c["motor_state_names"] = snames
    c["n6_invariant_role"] = "σ(6)=12 vertex; τ(6)=4 motor states; φ(6)=2; J₂=24."
    let anchors = []; anchors.push("senescence-associated surface marker — public open-access aging research literature")
    c["source_literature_anchors"] = anchors
    let handoff = []
    handoff.push("delivery / formulation → out-of-scope")
    handoff.push("in-vivo distribution / safety → wet-lab (out-of-repo, C3+)")
    c["downstream_layer_handoff"] = handoff
    return c
}

fn build_witness(verify_result, candidate) {
    let pe = verify_result["pass_evaluation"]
    let overall_pass = pe["overall_pass"]

    let mut sentinel = "__N_DELTA_SENOLYTIC_C2__ FAIL"
    if overall_pass { sentinel = "__N_DELTA_SENOLYTIC_C2__ PASS" }

    let verification = {}
    verification["simulator"] = "nanobot_actuation_simulation (F-NB-4 PASS, cycle 24 C0b)"
    verification["actuation_pass"] = overall_pass
    verification["n_cycles_run"] = verify_result["n_cycles_run"]
    verification["skeleton"] = verify_result["skeleton"]
    verification["T_kelvin"] = verify_result["T_kelvin"]
    verification["kT_J"] = verify_result["kT_J"]
    verification["work_per_cycle_kT_units"] = verify_result["work_per_cycle_kT_units"]
    verification["work_margin_vs_10kT"] = verify_result["work_margin_vs_10kT"]
    verification["pose_canonicalize_speedup_factor"] = verify_result["pose_canonicalize_speedup_factor"]
    verification["brownian_collapse_detected"] = verify_result["brownian_collapse_detected"]
    verification["pass_count"] = pe["pass_count"]
    verification["total_count"] = pe["total_count"]

    let disclosures = []
    disclosures.push("delta_senolytic is a 16-cell matrix label, NOT a clinical proposal.")
    disclosures.push("Senescence-associated surface marker is a PUBLIC AB DB catalogued construct stub.")
    disclosures.push("Affinity 1e-9 M is illustrative literature value.")
    disclosures.push("PASS verifies mechanical/thermodynamic properties under decoration topology — NOT biological outcome.")
    disclosures.push("Payload slot is unspecified placeholder.")
    disclosures.push("16-cell matrix N·δ at IN-SILICO grade only.")

    let row = {}
    row["schema"] = "raw_77_c2_nanobot_senolytic_v1"
    row["ts"] = utc_iso_now()
    row["cycle"] = 25
    row["phase"] = "c2-n-delta-senolytic-decorated-skeleton-candidate"
    row["domain"] = "hexa-nanobot"
    row["matrix_cell"] = "N_delta"
    row["disease_class_label"] = "delta_senolytic"
    row["candidate"] = candidate
    row["verification"] = verification
    row["n6_invariant"] = verify_result["n6_invariant"]
    row["in_silico_grade_disclose"] = "IN-SILICO numerical-primitive verification ONLY."
    row["raw_91_c3_disclose"] = disclosures
    row["raw_47_cross_repo"] = "Imports nanobot_actuation_simulation (R2 preserved)."
    row["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    row["raw_138_sentinel"] = sentinel
    row["raw_77_append_only"] = true
    return row
}

fn parse_argv_local(av) {
    let r = {}
    r["cycles"] = 10000
    r["T"] = 310.0
    r["skeleton"] = "truncated_icosahedron"
    r["seed"] = 42
    r["no_emit"] = false
    r["quiet"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--cycles" { if i + 1 < len(av) { r["cycles"] = to_int(av[i + 1]); i = i + 1 } }
        else if a == "--T" { if i + 1 < len(av) { r["T"] = to_float(av[i + 1]); i = i + 1 } }
        else if a == "--skeleton" { if i + 1 < len(av) { r["skeleton"] = av[i + 1]; i = i + 1 } }
        else if a == "--seed" { if i + 1 < len(av) { r["seed"] = to_int(av[i + 1]); i = i + 1 } }
        else if a == "--no-emit" { r["no_emit"] = true }
        else if a == "--quiet" { r["quiet"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let cfg = parse_argv_local(args())
    let candidate = build_candidate()
    let result = run_actuation_args(cfg["cycles"], cfg["T"], cfg["skeleton"], cfg["seed"])
    let pe = result["pass_evaluation"]
    let overall_pass = pe["overall_pass"]
    let witness = build_witness(result, candidate)

    if !cfg["no_emit"] {
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(witness) + "\n")
    }
    let mut sentinel = "__N_DELTA_SENOLYTIC_C2__ FAIL"
    if overall_pass { sentinel = "__N_DELTA_SENOLYTIC_C2__ PASS" }
    println(sentinel)
    if overall_pass { exit(0) }
    exit(1)
}
