#!hexa strict
//
// nanobot/module/bayesian_n6_per_axis_stratum.hexa — F-NB-2-c per-axis decomposition.
//
// HEXA-NATIVE port of _python_bridge/module/nanobot_bayesian_n6_per_axis_stratum.py
// (R5 sunset 23/57, 2026-05-07). Decomposes the cycle-25 stratum bias FAIL
// (aggregate delta=3.65) into per-axis match-rate deltas to identify the
// bias-driver axis.

use "nanobot/module/bayesian_audit_n30"

let YEAR_RE = "(^|[^0-9])(19[5-9][0-9]|20[0-3][0-9])([^0-9]|$)"

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn classify(entry) -> string {
    let mut ref = ""
    let r_v = entry["ref"]
    if type_of(r_v) == "string" { ref = r_v }
    let m = regex_search(YEAR_RE, ref)
    if len(m) == 0 { return "unknown" }
    let span = ref.substring(m[0], m[1])
    let mut yr_start = -1
    let mut k = 0
    while k + 4 <= len(span) {
        let c4 = span.substring(k, k + 4)
        let mut all_digits = true
        let mut q = 0
        while q < 4 {
            let ch = c4.substring(q, q + 1)
            if ch < "0" || ch > "9" { all_digits = false }
            q = q + 1
        }
        if all_digits { yr_start = k; break }
        k = k + 1
    }
    if yr_start < 0 { return "unknown" }
    let yr = to_int(span.substring(yr_start, yr_start + 4))
    if yr < 2000 { return "pre_2000" }
    return "post_2000"
}

fn axis_block(applicable: int, matches: int) {
    let r = {}
    r["applicable"] = applicable
    r["matches"] = matches
    if applicable > 0 {
        r["rate"] = to_float(matches) / to_float(applicable)
    } else {
        r["rate"] = void
    }
    return r
}

fn per_axis_match_rates(corpus) {
    let r = {}
    if len(corpus) == 0 {
        r["sigma"] = void
        r["tau"] = void
        r["phi"] = void
        r["J2"] = void
        return r
    }
    let mut s_app = 0
    let mut t_app = 0
    let mut p_app = 0
    let mut j_app = 0
    let mut s_m = 0
    let mut t_m = 0
    let mut p_m = 0
    let mut j_m = 0
    let mut i = 0
    while i < len(corpus) {
        let e = corpus[i]
        let flags = _axis_match_flags_c(e, 12, 4, 2, 24)
        let s_obs = e["sigma_observed"]
        let t_obs = e["tau_observed"]
        let p_obs = e["phi_observed"]
        let j_obs = e["J2_observed"]
        if type_of(s_obs) != "void" && s_obs != void {
            s_app = s_app + 1
            if flags[0] { s_m = s_m + 1 }
        }
        if type_of(t_obs) != "void" && t_obs != void {
            t_app = t_app + 1
            if flags[1] { t_m = t_m + 1 }
        }
        if type_of(p_obs) != "void" && p_obs != void {
            p_app = p_app + 1
            if flags[2] { p_m = p_m + 1 }
        }
        if type_of(j_obs) != "void" && j_obs != void {
            j_app = j_app + 1
            if flags[3] { j_m = j_m + 1 }
        }
        i = i + 1
    }
    r["sigma"] = axis_block(s_app, s_m)
    r["tau"] = axis_block(t_app, t_m)
    r["phi"] = axis_block(p_app, p_m)
    r["J2"] = axis_block(j_app, j_m)
    return r
}

fn parse_argv_local(av) {
    let r = {}
    r["emit"] = false
    r["summary"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--emit" { r["emit"] = true }
        else if a == "--summary" { r["summary"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let cfg = parse_argv_local(args())
    let corpus = build_corpus_n30()
    let pre = []
    let post = []
    let unk = []
    let mut i = 0
    while i < len(corpus) {
        let cls = classify(corpus[i])
        if cls == "pre_2000" { pre.push(corpus[i]) }
        else if cls == "post_2000" { post.push(corpus[i]) }
        else { unk.push(corpus[i]) }
        i = i + 1
    }

    let rates_pre = per_axis_match_rates(pre)
    let rates_post = per_axis_match_rates(post)
    let rates_unk = per_axis_match_rates(unk)

    let axes = ["sigma", "tau", "phi", "J2"]
    let deltas = {}
    let mut a_i = 0
    while a_i < len(axes) {
        let axis = axes[a_i]
        let a_block = rates_pre[axis]
        let b_block = rates_post[axis]
        if type_of(a_block) == "void" || type_of(b_block) == "void" {
            deltas[axis] = void
        } else {
            let a_rate = a_block["rate"]
            let b_rate = b_block["rate"]
            if type_of(a_rate) == "void" || type_of(b_rate) == "void" {
                deltas[axis] = void
            } else {
                deltas[axis] = fabs(to_float(a_rate) - to_float(b_rate))
            }
        }
        a_i = a_i + 1
    }

    let mut bias_axis = void
    let mut bias_delta = 0.0 - 1.0
    let mut k = 0
    while k < len(axes) {
        let axis = axes[k]
        let d = deltas[axis]
        if type_of(d) != "void" {
            let dv = to_float(d)
            if dv > bias_delta {
                bias_axis = axis
                bias_delta = dv
            }
        }
        k = k + 1
    }

    let audited_at = utc_iso_now()
    let w = {}
    w["schema"] = "raw_77_nanobot_bayesian_audit_v2"
    w["audited_at"] = audited_at
    w["audit_kind"] = "n6_per_axis_stratum_decomposition"
    w["stratum_classifier"] = "year_pre_post_2000"
    w["n_pre_2000"] = len(pre)
    w["n_post_2000"] = len(post)
    w["n_unknown"] = len(unk)
    w["rates_pre_2000"] = rates_pre
    w["rates_post_2000"] = rates_post
    w["rates_unknown"] = rates_unk
    w["deltas_per_axis"] = deltas
    w["bias_driver_axis"] = bias_axis
    if type_of(bias_axis) == "void" {
        w["bias_driver_delta"] = void
    } else {
        w["bias_driver_delta"] = bias_delta
    }
    w["raw_91_c3_disclose"] = "F-NB-2-c follow-up: decomposes the cycle-25 stratum bias FAIL (aggregate delta=3.65) into per-axis match-rate deltas to identify the bias-driver axis. Diagnostic, not a gate. Cycle-27 corpus enlargement should target the bias-driver axis specifically (expand experimental entries that DO register that axis)."
    w["raw_77_append_only"] = true
    w["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    w["witness_ref"] = "state/discovery_absorption/registry.jsonl#raw_77_nanobot_bayesian_audit_v2"

    if cfg["emit"] {
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(w) + "\n")
        eprintln("emitted 1 witness row -> " + path)
    }

    if cfg["summary"] {
        println(json_encode(w))
    } else {
        eprintln("pre_2000 (n=" + to_string(len(pre)) + "):")
        let mut q = 0
        while q < len(axes) {
            let axis = axes[q]
            let blk = rates_pre[axis]
            if type_of(blk) != "void" {
                eprintln("  " + axis + ": applicable=" + to_string(blk["applicable"]) + " match=" + to_string(blk["matches"]) + " rate=" + to_string(blk["rate"]))
            }
            q = q + 1
        }
        eprintln("post_2000 (n=" + to_string(len(post)) + "):")
        let mut r = 0
        while r < len(axes) {
            let axis = axes[r]
            let blk = rates_post[axis]
            if type_of(blk) != "void" {
                eprintln("  " + axis + ": applicable=" + to_string(blk["applicable"]) + " match=" + to_string(blk["matches"]) + " rate=" + to_string(blk["rate"]))
            }
            r = r + 1
        }
        eprintln("bias_driver_axis=" + to_string(bias_axis) + " (delta=" + to_string(bias_delta) + ")")
    }
}
