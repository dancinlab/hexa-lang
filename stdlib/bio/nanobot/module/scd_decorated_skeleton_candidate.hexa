#!hexa strict
//
// nanobot/module/scd_decorated_skeleton_candidate.hexa — C2 cell N·β.
// HEXA-NATIVE port (R5 sunset 52/57, 2026-05-07).

use "nanobot/module/actuation_simulation"

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn build_candidate() {
    let c = {}
    c["target_disease_class_label"] = "beta_SCD"
    c["matrix_cell_label"] = "N_beta"
    c["surface_marker_referenced"] = "CD34"
    c["skeleton"] = "truncated_icosahedron"
    c["n_vertices"] = 12
    let dec = {}
    dec["vertex_idx"] = 0
    dec["ligand_module_id"] = "anti_cd34_scfv_stub_public_db"
    dec["binding_domain_class"] = "anti-CD34 single-chain Fv"
    dec["binding_affinity_M_lit"] = 1.0e-9
    dec["source_lit"] = "public antibody database catalogued anti-CD34 scFv"
    let decs = []; decs.push(dec); c["vertex_decorations"] = decs
    c["payload_slot"] = "unspecified-placeholder-no-molecule-modeled"
    c["motor_cycle_states"] = 4
    let snames = []; snames.push("S0_idle"); snames.push("S1_fwd_stroke"); snames.push("S2_back_stroke"); snames.push("S3_reset")
    c["motor_state_names"] = snames
    c["n6_invariant_role"] = "σ(6)=12 vertex count; τ(6)=4 motor states; φ(6)=2 productive vs back-slip; J₂=24 octahedral pose-equivalence quotient."
    let anchors = []
    anchors.push("anti-CD34 single-chain Fv — public antibody database")
    anchors.push("DNA-origami 12-vertex polyhedron — public structural DNA nanotechnology literature")
    c["source_literature_anchors"] = anchors
    let handoff = []
    handoff.push("delivery / formulation / pharmacokinetics → out-of-scope at this primitive")
    handoff.push("ex-vivo cell handling / engraftment / safety → wet-lab (out-of-repo, C3+)")
    c["downstream_layer_handoff"] = handoff
    return c
}

fn build_witness(verify_result, candidate) {
    let pe = verify_result["pass_evaluation"]
    let overall_pass = pe["overall_pass"]
    let mut sentinel = "__N_BETA_SCD_C2__ FAIL"
    if overall_pass { sentinel = "__N_BETA_SCD_C2__ PASS" }
    let v = {}
    v["simulator"] = "nanobot_actuation_simulation (F-NB-4 PASS, cycle 24 C0b)"
    v["actuation_pass"] = overall_pass
    v["n_cycles_run"] = verify_result["n_cycles_run"]
    v["skeleton"] = verify_result["skeleton"]
    v["T_kelvin"] = verify_result["T_kelvin"]
    v["kT_J"] = verify_result["kT_J"]
    v["work_per_cycle_kT_units"] = verify_result["work_per_cycle_kT_units"]
    v["work_margin_vs_10kT"] = verify_result["work_margin_vs_10kT"]
    v["pose_canonicalize_speedup_factor"] = verify_result["pose_canonicalize_speedup_factor"]
    v["brownian_collapse_detected"] = verify_result["brownian_collapse_detected"]
    v["pass_count"] = pe["pass_count"]
    v["total_count"] = pe["total_count"]
    let d = []
    d.push("The disease_class_label 'beta_SCD' is a 16-cell matrix label per .roadmap.hexa_bio §0; NOT clinical.")
    d.push("CD34 is referenced as a PUBLIC AB DB catalogued surface marker stub.")
    d.push("Affinity 1e-9 M is illustrative literature value.")
    d.push("PASS verifies mechanical/thermodynamic properties under decoration topology — NOT biological outcome.")
    d.push("Payload slot is unspecified placeholder.")
    d.push("16-cell matrix N·β at IN-SILICO grade only.")
    let row = {}
    row["schema"] = "raw_77_c2_nanobot_scd_v1"
    row["ts"] = utc_iso_now()
    row["cycle"] = 25
    row["phase"] = "c2-n-beta-scd-decorated-skeleton-candidate"
    row["domain"] = "hexa-nanobot"
    row["matrix_cell"] = "N_beta"
    row["disease_class_label"] = "beta_SCD"
    row["candidate"] = candidate
    row["verification"] = v
    row["n6_invariant"] = verify_result["n6_invariant"]
    row["in_silico_grade_disclose"] = "IN-SILICO numerical-primitive verification ONLY."
    row["raw_91_c3_disclose"] = d
    row["raw_47_cross_repo"] = "Imports nanobot_actuation_simulation (R2 preserved)."
    row["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    row["raw_138_sentinel"] = sentinel
    row["raw_77_append_only"] = true
    return row
}

fn parse_argv_local(av) {
    let r = {}
    r["cycles"] = 10000; r["T"] = 310.0; r["skeleton"] = "truncated_icosahedron"
    r["seed"] = 42; r["no_emit"] = false; r["quiet"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--cycles" { if i + 1 < len(av) { r["cycles"] = to_int(av[i + 1]); i = i + 1 } }
        else if a == "--T" { if i + 1 < len(av) { r["T"] = to_float(av[i + 1]); i = i + 1 } }
        else if a == "--skeleton" { if i + 1 < len(av) { r["skeleton"] = av[i + 1]; i = i + 1 } }
        else if a == "--seed" { if i + 1 < len(av) { r["seed"] = to_int(av[i + 1]); i = i + 1 } }
        else if a == "--no-emit" { r["no_emit"] = true }
        else if a == "--quiet" { r["quiet"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let cfg = parse_argv_local(args())
    let candidate = build_candidate()
    let result = run_actuation_args(cfg["cycles"], cfg["T"], cfg["skeleton"], cfg["seed"])
    let pe = result["pass_evaluation"]
    let overall_pass = pe["overall_pass"]
    let witness = build_witness(result, candidate)
    if !cfg["no_emit"] {
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(witness) + "\n")
    }
    let mut sentinel = "__N_BETA_SCD_C2__ FAIL"
    if overall_pass { sentinel = "__N_BETA_SCD_C2__ PASS" }
    println(sentinel)
    if overall_pass { exit(0) }
    exit(1)
}
