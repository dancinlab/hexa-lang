#!hexa strict
//
// nanobot/module/worst_case_env_audit.hexa — F-NB-3-c worst-case env audit.
//
// HEXA-NATIVE port of _python_bridge/module/nanobot_worst_case_env_audit.py
// (R5 sunset 54/57, 2026-05-07). T_kelvin=320K + gamma+20% perturbation.

use "nanobot/module/actuation_simulation"

let PASS_WORK_KT_RELAXED = 5.0
let PASS_MIN_CYCLES = 2500

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn parse_argv_local(av) {
    let r = {}
    r["cycles"] = 2500
    r["emit"] = false
    r["summary"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--cycles" { if i + 1 < len(av) { r["cycles"] = to_int(av[i + 1]); i = i + 1 } }
        else if a == "--emit" { r["emit"] = true }
        else if a == "--summary" { r["summary"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let cfg = parse_argv_local(args())

    // Hexa note: actuation_simulation eta override would require lib
    // mutability hooks. We approximate by passing T_kelvin=320K only;
    // gamma perturbation is documented in witness but lib uses canonical
    // ETA_WATER. (Functional behavior: relaxed PASS gate at 5.0 kT.)
    let result = run_actuation_args(cfg["cycles"], 320.0, "truncated_icosahedron", 42)

    let work_kT = result["work_per_cycle_kT_units"]
    let n_cycles = result["n_cycles_run"]
    let collapse = result["brownian_collapse_detected"]
    let first_collapse = result["first_collapse_cycle"]

    let work_pass = to_float(work_kT) >= PASS_WORK_KT_RELAXED
    let mut collapse_pass = !collapse
    if collapse && type_of(first_collapse) != "void" && first_collapse != void {
        if to_int(first_collapse) >= PASS_MIN_CYCLES { collapse_pass = true }
    }
    let cycles_pass = n_cycles >= PASS_MIN_CYCLES
    let overall = work_pass && collapse_pass && cycles_pass

    let mut verdict = "FAIL"
    if overall { verdict = "PASS" }

    let crit = {}
    crit["work_per_cycle_kT_ge_5"] = work_pass
    crit["no_collapse_for_ge_2500_cycles"] = collapse_pass
    crit["n_cycles_ge_2500"] = cycles_pass

    let f3c = {}
    f3c["verdict"] = verdict
    f3c["T_kelvin_perturbed"] = 320.0
    f3c["gamma_perturbation_factor"] = 1.2
    f3c["n_cycles_run"] = n_cycles
    f3c["work_per_cycle_kT"] = work_kT
    f3c["brownian_collapse_detected"] = collapse
    f3c["first_collapse_cycle"] = first_collapse
    f3c["criteria"] = crit

    let sub = {}
    sub["f_nb_3_c"] = f3c

    let perturb = {}
    perturb["T_kelvin_canonical"] = 310.0
    perturb["T_kelvin_perturbed"] = 320.0
    perturb["eta_canonical_Pa_s"] = 0.000692
    perturb["eta_perturbed_factor"] = 1.2

    let witness = {}
    witness["schema"] = "raw_77_nanobot_subclause_direct_read_v3"
    witness["audited_at"] = utc_iso_now()
    witness["audit_kind"] = "f_nb_3_c_worst_case_env"
    witness["perturbation"] = perturb
    witness["f_nb_3_subclauses"] = sub
    witness["raw_91_c3_disclose"] = "Worst-case environmental perturbation re-runs nanobot actuation sim with T_kelvin=320K (mild fever) and ETA_WATER scaled by 1.2 (gamma_drag +20%; documented but lib uses canonical eta in this hexa port). Relaxed PASS criterion (work_per_cycle_kT >= 5 kT). Single-seed run."
    witness["raw_77_append_only"] = true
    witness["witness_ref"] = "state/discovery_absorption/registry.jsonl#raw_77_nanobot_subclause_direct_read_v3"

    if cfg["emit"] {
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(witness) + "\n")
        eprintln("emitted 1 witness row -> " + path)
    }

    if cfg["summary"] {
        println(json_encode(witness))
    } else {
        eprintln("T=320K gamma+20%  cycles_run=" + to_string(n_cycles) +
                 "  work_kT=" + to_string(work_kT) +
                 "  collapse=" + to_string(collapse) +
                 "  verdict=" + verdict)
    }

    if overall { exit(0) }
    exit(1)
}
