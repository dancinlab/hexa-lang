{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/nanobot/spec/interrater_v2.schema.json",
  "title": "NANOBOT F-NB-2-extended-inter-rater agreement witness v2 (rubric-locked)",
  "description": "Witness schema for F-NB-2-extended inter-rater audit under rubric v2 (locked decision tree on curated numerical fields + structured notes regex; tie-breaker order is the only divergence between AI raters). Sister to interrater_v1.schema.json (mirrors ribozyme/spec/interrater_v2.schema.json). PASS criterion (AND-gate): overall_kappa >= 0.6 (Landis-Koch 1977 substantial agreement) AND rubric_lock_full_agreement_rate >= 0.95. v1 stratified_log_bf.max < 5.0 criterion retained as reported diagnostic but NOT gated, because rubric v2 by construction reproduces the curator's lattice labels. raw_91 honest-C3 disclosure: AI-as-rater is NOT equivalent to human inter-rater.",
  "type": "object",
  "required": [
    "schema",
    "audited_at",
    "rater_count",
    "corpus_size",
    "rater_ids",
    "per_axis_kappa",
    "overall_kappa",
    "rubric_lock_full_agreement_rate",
    "stratified_log_bf",
    "pass_evaluation",
    "witness_ref"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "raw_77_nanobot_interrater_v2"
    },
    "audited_at": {
      "type": "string",
      "format": "date-time"
    },
    "rater_count": {
      "type": "integer",
      "minimum": 2
    },
    "corpus_size": {
      "type": "integer",
      "const": 60
    },
    "rater_ids": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string", "minLength": 1}
    },
    "per_axis_kappa": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": -1.0,
        "maximum": 1.0
      }
    },
    "overall_kappa": {
      "type": "number",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "rubric_lock_full_agreement_rate": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "stratified_log_bf": {
      "type": "object",
      "required": ["mean", "min", "max"],
      "properties": {
        "mean": {"type": "number"},
        "min": {"type": "number"},
        "max": {"type": "number"}
      }
    },
    "pass_evaluation": {
      "type": "object",
      "required": ["criteria", "overall_pass"],
      "properties": {
        "criteria": {
          "type": "object",
          "required": ["overall_kappa_ge_0p6", "rubric_lock_full_agreement_ge_0p95"],
          "properties": {
            "overall_kappa_ge_0p6": {"type": "boolean"},
            "rubric_lock_full_agreement_ge_0p95": {"type": "boolean"}
          }
        },
        "overall_pass": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "rubric_version": {
      "type": "string",
      "const": "v2_locked_decision_tree"
    },
    "tie_breaker_modes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["keyword_first", "number_first"]
      }
    },
    "notes": {
      "type": "string"
    },
    "witness_ref": {
      "type": "string",
      "pattern": "^state/discovery_absorption/registry\\.jsonl#raw_77_nanobot_interrater_v2$"
    }
  },
  "additionalProperties": false
}
