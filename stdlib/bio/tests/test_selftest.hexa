#!hexa strict
// tests/test_selftest.hexa — full 5-axis selftest harness
//
// Pass criterion: __HEXA_BIO_SELFTEST__ PASS sentinel present (4 bio-axis
// sentinels + 16-cell C2 sweep; the `quantum` axis is advisory-only).
// Cost: $0 (orchestrates the 4 bio-axis modules in default path).

fn main() {
    let root = env("HEXA_BIO_ROOT")
    let mut p = "selftest/module/selftest.hexa"
    if root.len() > 0 { p = root + "/selftest/module/selftest.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("__HEXA_BIO_SELFTEST__ PASS") {
        println("test_selftest: PASS")
        return
    }
    println("test_selftest: FAIL")
    println(raw.trim())
    exit(1)
}
