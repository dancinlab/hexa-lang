// stdlib/bio/seq_align/needleman_wunsch.hexa — global pairwise alignment (DP + traceback).
//
// @version 0.1.0
// @capabilities [pure]
//
// Needleman-Wunsch global alignment with linear gap penalty. Used by
// HERPES + TTR primer design, off-target scans, and motif anchors.
//
// Public surface:
//   pub fn needleman_wunsch(a, b, match_score, mismatch_score, gap_penalty) -> NWAlignment
//
// Algorithm — textbook O(m·n) DP score matrix + corner traceback.
//   - score[0][j] = j * gap_penalty,  score[i][0] = i * gap_penalty
//   - score[i][j] = max( score[i-1][j-1] + (match or mismatch),
//                        score[i-1][j]   + gap_penalty,
//                        score[i][j-1]   + gap_penalty )
//   - traceback from (m, n) reconstructs aligned_a / aligned_b with '-'
//     where a gap was opened against the longer sequence.
//
// MSA (progressive MAFFT-style) is TODO — deferred to a follow-up
// milestone. See sibling smith_waterman.hexa for local alignment.

struct NWAlignment {
    score: int,
    aligned_a: string,
    aligned_b: string,
    gaps: int,
    mismatches: int,
    matches: int,
}

// ── helpers ──────────────────────────────────────────────────────────

fn _max3(a: int, b: int, c: int) -> int {
    let mut m = a
    if b > m { m = b }
    if c > m { m = c }
    return m
}

// 1-char slice — hexa string indexing convention (see arxiv.hexa).
fn _ch(s: string, i: int) -> string {
    return s.substring(i, i + 1)
}

// Reverse a string built tail-first during traceback.
fn _reverse(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = n - 1
    while i >= 0 {
        out = out + s.substring(i, i + 1)
        i = i - 1
    }
    return out
}

// ── public surface ───────────────────────────────────────────────────

pub fn needleman_wunsch(a: string, b: string,
                        match_score: int, mismatch_score: int,
                        gap_penalty: int) -> NWAlignment {
    let m = len(a)
    let n = len(b)

    // Edge case — both empty: trivially aligned.
    if m == 0 && n == 0 {
        return NWAlignment{
            score: 0, aligned_a: "", aligned_b: "",
            gaps: 0, mismatches: 0, matches: 0,
        }
    }

    // Allocate (m+1) × (n+1) score matrix. Arrays in hexa are reference-
    // shared so direct m[i][j] = x writes propagate.
    let mut score = []
    let mut i = 0
    while i <= m {
        let mut row = []
        let mut j = 0
        while j <= n {
            row.push(0)
            j = j + 1
        }
        score.push(row)
        i = i + 1
    }

    // Boundary conditions.
    let mut j0 = 0
    while j0 <= n {
        score[0][j0] = j0 * gap_penalty
        j0 = j0 + 1
    }
    let mut i0 = 0
    while i0 <= m {
        score[i0][0] = i0 * gap_penalty
        i0 = i0 + 1
    }

    // Fill — three-way max recurrence.
    let mut ii = 1
    while ii <= m {
        let mut jj = 1
        while jj <= n {
            let ca = _ch(a, ii - 1)
            let cb = _ch(b, jj - 1)
            let sub = if ca == cb { match_score } else { mismatch_score }
            let diag = score[ii - 1][jj - 1] + sub
            let up   = score[ii - 1][jj]     + gap_penalty
            let left = score[ii][jj - 1]     + gap_penalty
            score[ii][jj] = _max3(diag, up, left)
            jj = jj + 1
        }
        ii = ii + 1
    }

    let final_score = score[m][n]

    // ── traceback ────────────────────────────────────────────────────
    // Walk (m, n) → (0, 0), preferring diag → up → left on ties
    // (canonical convention — reproducible output).
    let mut aa_rev = ""
    let mut bb_rev = ""
    let mut gaps = 0
    let mut mismatches = 0
    let mut matches = 0

    let mut ti = m
    let mut tj = n
    while ti > 0 || tj > 0 {
        if ti > 0 && tj > 0 {
            let ca = _ch(a, ti - 1)
            let cb = _ch(b, tj - 1)
            let sub = if ca == cb { match_score } else { mismatch_score }
            let here = score[ti][tj]
            let diag_src = score[ti - 1][tj - 1] + sub
            if here == diag_src {
                aa_rev = aa_rev + ca
                bb_rev = bb_rev + cb
                if ca == cb { matches = matches + 1 }
                else { mismatches = mismatches + 1 }
                ti = ti - 1
                tj = tj - 1
                continue
            }
            let up_src = score[ti - 1][tj] + gap_penalty
            if here == up_src {
                aa_rev = aa_rev + ca
                bb_rev = bb_rev + "-"
                gaps = gaps + 1
                ti = ti - 1
                continue
            }
            // must be left
            aa_rev = aa_rev + "-"
            bb_rev = bb_rev + cb
            gaps = gaps + 1
            tj = tj - 1
            continue
        }
        if ti > 0 {
            let ca = _ch(a, ti - 1)
            aa_rev = aa_rev + ca
            bb_rev = bb_rev + "-"
            gaps = gaps + 1
            ti = ti - 1
            continue
        }
        // tj > 0
        let cb = _ch(b, tj - 1)
        aa_rev = aa_rev + "-"
        bb_rev = bb_rev + cb
        gaps = gaps + 1
        tj = tj - 1
    }

    return NWAlignment{
        score: final_score,
        aligned_a: _reverse(aa_rev),
        aligned_b: _reverse(bb_rev),
        gaps: gaps,
        mismatches: mismatches,
        matches: matches,
    }
}
