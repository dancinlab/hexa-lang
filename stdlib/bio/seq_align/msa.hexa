// stdlib/bio/seq_align/msa.hexa — progressive multiple sequence alignment.
//
// @version 0.1.0
// @capabilities [pure]
//
// 다중 서열 정렬 (Multiple Sequence Alignment) — ClustalW 스타일의
// progressive 알고리즘. cycle-2 의 Needleman-Wunsch 를 building block
// 으로 사용.
//
// 알고리즘 흐름:
//   1) Pairwise distance matrix
//      모든 (i,j) 쌍에 대해 NW alignment 를 수행.
//      D[i][j] = 1 - identity, identity = matches / aligned_length.
//   2) Neighbor-Joining guide tree (Saitou & Nei 1987)
//      거리행렬 → 루트가 있는 binary tree.
//      각 step 마다 Q 행렬을 계산해 최소 Q 쌍을 합침.
//   3) Progressive alignment (post-order traversal)
//      각 internal node 에서 두 자식의 누적 profile 을 정렬해 합침.
//      Profile-profile DP — column 점수는 sum-of-pairs match/mismatch.
//   4) 입력 순서로 재정렬해 [str] 반환.
//
// References:
//   Thompson JD, Higgins DG, Gibson TJ. CLUSTAL W: improving the
//     sensitivity of progressive multiple sequence alignment through
//     sequence weighting, position-specific gap penalties and weight
//     matrix choice. Nucleic Acids Research 1994;22:4673-4680.
//   Saitou N, Nei M. The neighbor-joining method: a new method for
//     reconstructing phylogenetic trees. Mol Biol Evol 1987;4:406-425.
//
// Public surface:
//   pub fn build_distance_matrix(seqs: [str]) -> [[float]]
//   pub fn build_nj_tree(dist: [[float]]) -> NjTree
//   pub fn progressive_align(seqs: [str], tree: NjTree) -> [str]
//   pub fn msa(seqs: [str]) -> [str]

use "stdlib/bio/seq_align/needleman_wunsch"

// ── tree representation ──────────────────────────────────────────────
//
// Flat node array. Leaf 의 경우 seq_idx 는 입력 sequence index, left/right
// 는 -1. Internal node 의 경우 seq_idx 는 -1, left/right 는 node array
// index.
struct NjNode {
    is_leaf: bool,
    seq_idx: int,
    left: int,
    right: int,
}

struct NjTree {
    nodes: [NjNode],
    root: int,
    n_leaves: int,
}

// ── numeric helpers ──────────────────────────────────────────────────

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _ch(s: string, i: int) -> string {
    return s.substring(i, i + 1)
}

// ── distance matrix ──────────────────────────────────────────────────
//
// D[i][j] = 1 - identity(NW(seq_i, seq_j)), 대칭, D[i][i] = 0.
// Scoring: match=+1, mismatch=-1, gap=-1 (textbook).
pub fn build_distance_matrix(seqs: [str]) -> [[float]] {
    let n = len(seqs)
    let mut mat: [[float]] = []

    // (n x n) 0.0 으로 초기화.
    let mut i0 = 0
    while i0 < n {
        let mut row: [float] = []
        let mut j0 = 0
        while j0 < n {
            row.push(0.0)
            j0 = j0 + 1
        }
        mat.push(row)
        i0 = i0 + 1
    }

    // 상삼각 (i < j) 만 채우고 대칭으로 mirror.
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let al = needleman_wunsch(seqs[i], seqs[j], 1, 0 - 1, 0 - 1)
            let alen = len(al.aligned_a)
            let mut d = 0.0
            if alen > 0 {
                // identity = matches / alen → distance = 1 - identity
                let id = 1.0 * al.matches / alen
                d = 1.0 - id
            }
            mat[i][j] = d
            mat[j][i] = d
            j = j + 1
        }
        i = i + 1
    }
    return mat
}

// ── neighbor-joining guide tree ──────────────────────────────────────
//
// Saitou & Nei 1987 — iterative star-decomposition.
//   1) For an active set of r taxa, compute net divergence r_i = Σ_k D[i][k].
//   2) Q[i][j] = (r - 2) * D[i][j] - r_i - r_j. (Saitou-Nei criterion)
//   3) Join the pair (a, b) minimizing Q → new node u.
//   4) Update distances: D[u][k] = (D[a][k] + D[b][k] - D[a][b]) / 2.
//   5) Repeat until only the root remains.
//
// 입력이 단일 서열이면 단일 leaf 만 가진 trivial tree 반환.
pub fn build_nj_tree(dist: [[float]]) -> NjTree {
    let n = len(dist)
    let mut nodes: [NjNode] = []

    // Boundary — n == 0 (input empty).
    if n == 0 {
        return NjTree{ nodes: nodes, root: 0 - 1, n_leaves: 0 }
    }

    // Leaf 노드를 먼저 등록 (node index == seq index 보장).
    let mut li = 0
    while li < n {
        nodes.push(NjNode{ is_leaf: true, seq_idx: li, left: 0 - 1, right: 0 - 1 })
        li = li + 1
    }

    // Boundary — n == 1: 단일 leaf, root == 0.
    if n == 1 {
        return NjTree{ nodes: nodes, root: 0, n_leaves: 1 }
    }

    // 활성 노드 집합 = 현재 join 의 입력. 처음에는 모든 leaf.
    let mut active: [int] = []
    let mut k0 = 0
    while k0 < n {
        active.push(k0)
        k0 = k0 + 1
    }

    // 작업용 거리행렬 — node index 키 (leaf + internal 모두 포함).
    // 점진적으로 확장되므로 dict 대신 sparse pair lookup 을 위해
    // _get/_set 헬퍼 (flat parallel arrays a/b/val) 사용.
    //
    // 단, n 이 작아 풀 매트릭스 복사가 더 단순함 — 처음 n×n 만 작업하고
    // 새 internal node 가 생기면 한 행/열을 push.
    let mut wdist: [[float]] = []
    let mut wi = 0
    while wi < n {
        let mut wrow: [float] = []
        let mut wj = 0
        while wj < n {
            wrow.push(dist[wi][wj])
            wj = wj + 1
        }
        wdist.push(wrow)
        wi = wi + 1
    }

    // active[k] -> wdist row/col index 매핑. 처음에는 identity.
    // internal node 가 생기면 wdist 에 새 row/col push 하고 active 갱신.
    let mut row_of: [int] = []
    let mut ri = 0
    while ri < n {
        row_of.push(ri)
        ri = ri + 1
    }

    let mut root_idx = 0 - 1

    while len(active) > 1 {
        let r = len(active)

        // r == 2 boundary — 마지막 두 노드를 직접 합침.
        if r == 2 {
            let a_node = active[0]
            let b_node = active[1]
            nodes.push(NjNode{
                is_leaf: false, seq_idx: 0 - 1,
                left: a_node, right: b_node,
            })
            root_idx = len(nodes) - 1
            // active 비움.
            active = []
            continue
        }

        // 1) net divergence r_i.
        let mut div: [float] = []
        let mut ai = 0
        while ai < r {
            let row_i = row_of[ai]
            let mut s = 0.0
            let mut ak = 0
            while ak < r {
                if ak != ai {
                    let row_k = row_of[ak]
                    s = s + wdist[row_i][row_k]
                }
                ak = ak + 1
            }
            div.push(s)
            ai = ai + 1
        }

        // 2) Q[i][j] minimizer.
        let mut best_q = 0.0
        let mut have_best = false
        let mut bi = 0
        let mut bj = 0
        let mut qi = 0
        while qi < r {
            let mut qj = qi + 1
            while qj < r {
                let row_i = row_of[qi]
                let row_j = row_of[qj]
                let q = (1.0 * (r - 2)) * wdist[row_i][row_j] - div[qi] - div[qj]
                if !have_best || q < best_q {
                    best_q = q
                    bi = qi
                    bj = qj
                    have_best = true
                }
                qj = qj + 1
            }
            qi = qi + 1
        }

        // 3) Join active[bi] + active[bj] → new internal node u.
        let a_node = active[bi]
        let b_node = active[bj]
        let row_a = row_of[bi]
        let row_b = row_of[bj]
        let d_ab = wdist[row_a][row_b]

        nodes.push(NjNode{
            is_leaf: false, seq_idx: 0 - 1,
            left: a_node, right: b_node,
        })
        let u_node = len(nodes) - 1

        // 4) 새 행/열 — D[u][k] = (D[a][k] + D[b][k] - D[a][b]) / 2.
        //    wdist 에 새 행/열 push.
        let old_rows = len(wdist)
        let mut new_row: [float] = []
        let mut nr = 0
        while nr < old_rows {
            let v = (wdist[row_a][nr] + wdist[row_b][nr] - d_ab) / 2.0
            new_row.push(v)
            nr = nr + 1
        }
        new_row.push(0.0)  // self-distance
        wdist.push(new_row)

        // 기존 행에 새 column 추가.
        let mut ec = 0
        while ec < old_rows {
            let v = (wdist[row_a][ec] + wdist[row_b][ec] - d_ab) / 2.0
            wdist[ec].push(v)
            ec = ec + 1
        }
        let new_row_idx = old_rows

        // 5) active 갱신 — bi/bj 제거, u_node 추가.
        let mut new_active: [int] = []
        let mut new_row_of: [int] = []
        let mut ka = 0
        while ka < r {
            if ka != bi && ka != bj {
                new_active.push(active[ka])
                new_row_of.push(row_of[ka])
            }
            ka = ka + 1
        }
        new_active.push(u_node)
        new_row_of.push(new_row_idx)
        active = new_active
        row_of = new_row_of
    }

    // r == 1 (단일 leaf 케이스만 도달, 위에서 처리). r >= 2 는 위 loop 에서 root_idx 설정.
    if root_idx < 0 {
        root_idx = 0
    }
    return NjTree{ nodes: nodes, root: root_idx, n_leaves: n }
}

// ── profile-profile alignment ────────────────────────────────────────
//
// Profile = [str] 각 행이 같은 길이의 정렬된 서열 (gap '-' 포함).
// 두 profile A (rows=ra, cols=ca), B (rows=rb, cols=cb) 를 정렬하면
// 새 profile (rows=ra+rb, cols=L) 가 나옴. NW 와 동일한 3-way DP:
//
//   score[i][j] = max( score[i-1][j-1] + col_score(A[..i], B[..j]),
//                      score[i-1][j]   + col_gap(A[..i], rb),    // B 쪽 전체에 '-'
//                      score[i][j-1]   + col_gap(rb=ra, B[..j]) ) // A 쪽 전체에 '-'
//
// col_score: 모든 (a, b) pair 에 대해 match=+1 / mismatch=-1, gap-gap=0,
// gap-residue=-1.

fn _col_score(prof_a: [str], col_a: int, prof_b: [str], col_b: int) -> int {
    let ra = len(prof_a)
    let rb = len(prof_b)
    let mut s = 0
    let mut i = 0
    while i < ra {
        let ca = _ch(prof_a[i], col_a)
        let mut j = 0
        while j < rb {
            let cb = _ch(prof_b[j], col_b)
            if ca == "-" && cb == "-" {
                // 0
            } else if ca == "-" || cb == "-" {
                s = s - 1
            } else if ca == cb {
                s = s + 1
            } else {
                s = s - 1
            }
            j = j + 1
        }
        i = i + 1
    }
    return s
}

// Profile 의 col 컬럼 전체와 "전부 gap" 한 컬럼을 비교한 점수.
// 각 residue 는 - 와 만나면 -1, gap 끼리는 0.
fn _col_gap_score(prof: [str], col: int, other_rows: int) -> int {
    let r = len(prof)
    let mut s = 0
    let mut i = 0
    while i < r {
        let c = _ch(prof[i], col)
        if c == "-" {
            // gap vs gap × other_rows → 0
        } else {
            s = s - other_rows
        }
        i = i + 1
    }
    return s
}

// 한 컬럼의 모든 row 를 stride 로 합쳐 string 생성.
fn _emit_col(prof: [str], col: int) -> [str] {
    let r = len(prof)
    let mut out: [str] = []
    let mut i = 0
    while i < r {
        out.push(_ch(prof[i], col))
        i = i + 1
    }
    return out
}

// rows × 1 의 gap-only column.
fn _emit_gap_col(rows: int) -> [str] {
    let mut out: [str] = []
    let mut i = 0
    while i < rows {
        out.push("-")
        i = i + 1
    }
    return out
}

fn _max3i(a: int, b: int, c: int) -> int {
    let mut m = a
    if b > m { m = b }
    if c > m { m = c }
    return m
}

fn _reverse_str(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = n - 1
    while i >= 0 {
        out = out + s.substring(i, i + 1)
        i = i - 1
    }
    return out
}

fn _align_profiles(prof_a: [str], prof_b: [str]) -> [str] {
    let ra = len(prof_a)
    let rb = len(prof_b)

    // 두 profile 의 column 수 (정렬된 모든 row 는 같은 길이).
    let ca = if ra == 0 { 0 } else { len(prof_a[0]) }
    let cb = if rb == 0 { 0 } else { len(prof_b[0]) }

    // 빈 profile boundary.
    if ra == 0 { return prof_b }
    if rb == 0 { return prof_a }

    // (ca+1) x (cb+1) score matrix.
    let mut sc: [[int]] = []
    let mut i0 = 0
    while i0 <= ca {
        let mut row: [int] = []
        let mut j0 = 0
        while j0 <= cb {
            row.push(0)
            j0 = j0 + 1
        }
        sc.push(row)
        i0 = i0 + 1
    }

    // Gap penalty per residue per row pair = -1.
    // Boundary: sc[i][0] = Σ_{k<i} _col_gap_score(prof_a, k, rb)
    let mut bi = 1
    while bi <= ca {
        sc[bi][0] = sc[bi - 1][0] + _col_gap_score(prof_a, bi - 1, rb)
        bi = bi + 1
    }
    let mut bj = 1
    while bj <= cb {
        sc[0][bj] = sc[0][bj - 1] + _col_gap_score(prof_b, bj - 1, ra)
        bj = bj + 1
    }

    // Fill.
    let mut ii = 1
    while ii <= ca {
        let mut jj = 1
        while jj <= cb {
            let diag = sc[ii - 1][jj - 1] + _col_score(prof_a, ii - 1, prof_b, jj - 1)
            let up   = sc[ii - 1][jj]     + _col_gap_score(prof_a, ii - 1, rb)
            let left = sc[ii][jj - 1]     + _col_gap_score(prof_b, jj - 1, ra)
            sc[ii][jj] = _max3i(diag, up, left)
            jj = jj + 1
        }
        ii = ii + 1
    }

    // ── traceback — 각 row 의 string 을 tail-first 로 누적 ──────────
    let mut row_strs: [str] = []
    let mut k = 0
    while k < ra + rb {
        row_strs.push("")
        k = k + 1
    }

    let mut ti = ca
    let mut tj = cb
    while ti > 0 || tj > 0 {
        if ti > 0 && tj > 0 {
            let here = sc[ti][tj]
            let diag_src = sc[ti - 1][tj - 1] + _col_score(prof_a, ti - 1, prof_b, tj - 1)
            if here == diag_src {
                // diag — col from both profiles
                let mut rk = 0
                while rk < ra {
                    row_strs[rk] = row_strs[rk] + _ch(prof_a[rk], ti - 1)
                    rk = rk + 1
                }
                let mut rl = 0
                while rl < rb {
                    row_strs[ra + rl] = row_strs[ra + rl] + _ch(prof_b[rl], tj - 1)
                    rl = rl + 1
                }
                ti = ti - 1
                tj = tj - 1
                continue
            }
            let up_src = sc[ti - 1][tj] + _col_gap_score(prof_a, ti - 1, rb)
            if here == up_src {
                let mut rk = 0
                while rk < ra {
                    row_strs[rk] = row_strs[rk] + _ch(prof_a[rk], ti - 1)
                    rk = rk + 1
                }
                let mut rl = 0
                while rl < rb {
                    row_strs[ra + rl] = row_strs[ra + rl] + "-"
                    rl = rl + 1
                }
                ti = ti - 1
                continue
            }
            // left
            let mut rk = 0
            while rk < ra {
                row_strs[rk] = row_strs[rk] + "-"
                rk = rk + 1
            }
            let mut rl = 0
            while rl < rb {
                row_strs[ra + rl] = row_strs[ra + rl] + _ch(prof_b[rl], tj - 1)
                rl = rl + 1
            }
            tj = tj - 1
            continue
        }
        if ti > 0 {
            let mut rk = 0
            while rk < ra {
                row_strs[rk] = row_strs[rk] + _ch(prof_a[rk], ti - 1)
                rk = rk + 1
            }
            let mut rl = 0
            while rl < rb {
                row_strs[ra + rl] = row_strs[ra + rl] + "-"
                rl = rl + 1
            }
            ti = ti - 1
            continue
        }
        // tj > 0
        let mut rk = 0
        while rk < ra {
            row_strs[rk] = row_strs[rk] + "-"
            rk = rk + 1
        }
        let mut rl = 0
        while rl < rb {
            row_strs[ra + rl] = row_strs[ra + rl] + _ch(prof_b[rl], tj - 1)
            rl = rl + 1
        }
        tj = tj - 1
    }

    // Reverse all rows.
    let mut out: [str] = []
    let mut rk = 0
    while rk < len(row_strs) {
        out.push(_reverse_str(row_strs[rk]))
        rk = rk + 1
    }
    return out
}

// ── progressive alignment ────────────────────────────────────────────
//
// Tree 를 post-order 로 순회. 각 internal node 에서 두 자식의 누적
// profile 을 align 해 합침. 자식 순서는 tree 의 left/right 그대로.
//
// 각 노드의 출력은:
//   - profile rows (정렬된 sequence 들)
//   - 같은 순서의 seq_idx list (입력순으로 reorder 하기 위함)
//
// 결과는 입력 순서로 재정렬해 [str] 반환.

struct NodeAlignment {
    rows: [str],
    seq_idxs: [int],
}

fn _align_node(tree: NjTree, seqs: [str], node_idx: int) -> NodeAlignment {
    let node = tree.nodes[node_idx]
    if node.is_leaf {
        let mut leaf_rows: [str] = []
        leaf_rows.push(seqs[node.seq_idx])
        let mut leaf_idxs: [int] = []
        leaf_idxs.push(node.seq_idx)
        return NodeAlignment{ rows: leaf_rows, seq_idxs: leaf_idxs }
    }
    let left = _align_node(tree, seqs, node.left)
    let right = _align_node(tree, seqs, node.right)
    let combined = _align_profiles(left.rows, right.rows)
    // seq_idxs 도 left → right 순서로 concat.
    let mut combined_idxs: [int] = []
    let mut li = 0
    while li < len(left.seq_idxs) {
        combined_idxs.push(left.seq_idxs[li])
        li = li + 1
    }
    let mut ri = 0
    while ri < len(right.seq_idxs) {
        combined_idxs.push(right.seq_idxs[ri])
        ri = ri + 1
    }
    return NodeAlignment{ rows: combined, seq_idxs: combined_idxs }
}

pub fn progressive_align(seqs: [str], tree: NjTree) -> [str] {
    let n = len(seqs)
    if n == 0 {
        let empty: [str] = []
        return empty
    }
    if n == 1 {
        let mut single: [str] = []
        single.push(seqs[0])
        return single
    }

    let aln = _align_node(tree, seqs, tree.root)

    // 입력 순서로 reorder.
    let mut out: [str] = []
    let mut k = 0
    while k < n {
        out.push("")
        k = k + 1
    }
    let mut p = 0
    while p < len(aln.seq_idxs) {
        out[aln.seq_idxs[p]] = aln.rows[p]
        p = p + 1
    }
    return out
}

// ── one-shot wrapper ─────────────────────────────────────────────────

pub fn msa(seqs: [str]) -> [str] {
    let n = len(seqs)
    if n == 0 {
        let empty: [str] = []
        return empty
    }
    if n == 1 {
        let mut single: [str] = []
        single.push(seqs[0])
        return single
    }
    let dist = build_distance_matrix(seqs)
    let tree = build_nj_tree(dist)
    return progressive_align(seqs, tree)
}
