// stdlib/bio/seq_align/seq_align_test.hexa — measured textbook oracle for NW + SW.
//
// 7 cases (no network, no fixtures, no shellout). Each compares against
// a closed-form / textbook optimum:
//
//   C1 NW classic   GCATGCU vs GATTACA  (+1/-1/-1)   score == 0
//   C2 NW identity  AAAA    vs AAAA     (+1/-1/-1)   score == 4
//   C3 NW total mismatch AAAA vs TTTT   (+1/-1/-1)   score == -4
//   C4 SW local     ACACACTA vs AGCACACA (+2/-1/-1)  score == 12
//   C5 SW identity  AAAA    vs AAAA     (+2/-1/-1)   score == 8
//   C6 SW no-match  AAAA    vs TTTT     (+2/-1/-1)   score == 0
//   C7 NW gaps      AGCT    vs GCT      (+1/-1/-1)   score == 2

use "stdlib/bio/seq_align/needleman_wunsch"
use "stdlib/bio/seq_align/smith_waterman"

let mut pass_count = 0
let mut total = 0
let mut first_fail = ""

fn check(name: string, cond: bool, detail: string) {
    total = total + 1
    if cond {
        pass_count = pass_count + 1
        println("  ok : " + name + " " + detail)
    } else {
        if first_fail == "" { first_fail = name }
        println("  FAIL " + name + " " + detail)
    }
}

// ── C1 NW classic ───────────────────────────────────────────────────
let r1 = needleman_wunsch("GCATGCU", "GATTACA", 1, 0 - 1, 0 - 1)
check("C1 NW classic GCATGCU vs GATTACA", r1.score == 0,
      "score=" + to_string(r1.score)
      + " a=" + r1.aligned_a
      + " b=" + r1.aligned_b
      + " m=" + to_string(r1.matches)
      + " x=" + to_string(r1.mismatches)
      + " g=" + to_string(r1.gaps))

// ── C2 NW identity ──────────────────────────────────────────────────
let r2 = needleman_wunsch("AAAA", "AAAA", 1, 0 - 1, 0 - 1)
check("C2 NW identity AAAA vs AAAA", r2.score == 4,
      "score=" + to_string(r2.score)
      + " matches=" + to_string(r2.matches))

// ── C3 NW total mismatch ────────────────────────────────────────────
let r3 = needleman_wunsch("AAAA", "TTTT", 1, 0 - 1, 0 - 1)
// Optimal global = match all 4 with mismatches = -4 (better than any
// gap-heavy alternative at gap=-1 since 8 gaps would be -8).
check("C3 NW total mismatch AAAA vs TTTT", r3.score == 0 - 4,
      "score=" + to_string(r3.score)
      + " mismatches=" + to_string(r3.mismatches)
      + " gaps=" + to_string(r3.gaps))

// ── C4 SW local ─────────────────────────────────────────────────────
let r4 = smith_waterman("ACACACTA", "AGCACACA", 2, 0 - 1, 0 - 1)
check("C4 SW local ACACACTA vs AGCACACA", r4.score == 12,
      "score=" + to_string(r4.score)
      + " a[" + to_string(r4.a_start) + ":" + to_string(r4.a_end) + "]"
      + " b[" + to_string(r4.b_start) + ":" + to_string(r4.b_end) + "]"
      + " a=" + r4.aligned_a
      + " b=" + r4.aligned_b)

// ── C5 SW identity ──────────────────────────────────────────────────
let r5 = smith_waterman("AAAA", "AAAA", 2, 0 - 1, 0 - 1)
check("C5 SW identity AAAA vs AAAA", r5.score == 8,
      "score=" + to_string(r5.score))

// ── C6 SW no-match ──────────────────────────────────────────────────
let r6 = smith_waterman("AAAA", "TTTT", 2, 0 - 1, 0 - 1)
check("C6 SW no-match AAAA vs TTTT", r6.score == 0,
      "score=" + to_string(r6.score))

// ── C7 NW gaps ──────────────────────────────────────────────────────
let r7 = needleman_wunsch("AGCT", "GCT", 1, 0 - 1, 0 - 1)
// Optimal: A-GCT / -GCT → 1 gap on each side aligned, 3 matches → -1 + 3 = 2
// (or AGCT / -GCT → 1 gap, 3 matches → 3-1 = 2; same score).
check("C7 NW gaps AGCT vs GCT", r7.score == 2,
      "score=" + to_string(r7.score)
      + " a=" + r7.aligned_a
      + " b=" + r7.aligned_b
      + " gaps=" + to_string(r7.gaps)
      + " matches=" + to_string(r7.matches))

// ── Verdict ─────────────────────────────────────────────────────────
println("")
if pass_count == total {
    println("PASS: seq_align " + to_string(pass_count) + "/" + to_string(total))
    exit(0)
} else {
    println("FAIL: seq_align first=" + first_fail
            + " (" + to_string(pass_count) + "/" + to_string(total) + ")")
    exit(1)
}
