// stdlib/bio/seq_align/msa_test.hexa — measured oracle for progressive MSA.
//
// 7 cases (no network, no fixtures, no shellout). 각 case 는 textbook
// closed-form 결과나 boundary 조건과 직접 비교.
//
//   C1 단일 서열       ["MKVLW"]                       → 1×"MKVLW"
//   C2 3개 동일        3× "MKVLW"                      → 3× "MKVLW", no gaps
//   C3 1 insertion     ["MKVLW","MKVLW","MKVVLW"]      → 모든 row 길이 6, gap 1개
//   C4 4 seq cluster   {A,A,B,B} 동일쌍 두 클러스터    → NJ tree 가 {0,1}/{2,3} 분리
//   C5 distance symm   D[i][j] == D[j][i]              → numerical
//   C6 distance self   D[i][i] == 0                    → numerical
//   C7 ribonuclease 4-seq fragment                     → 모든 row 동일 길이 + 원본 ungap 복원

use "stdlib/bio/seq_align/msa"

let mut pass_count = 0
let mut total = 0
let mut first_fail = ""

fn check(name: string, cond: bool, detail: string) {
    total = total + 1
    if cond {
        pass_count = pass_count + 1
        println("  ok : " + name + " " + detail)
    } else {
        if first_fail == "" { first_fail = name }
        println("  FAIL " + name + " " + detail)
    }
}

// '-' 를 제거해 원본 ungapped sequence 를 복원.
fn ungap(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c != "-" { out = out + c }
        i = i + 1
    }
    return out
}

// 두 string 의 길이만 비교 (rows 간 동일성 체크).
fn all_same_length(rows: [str]) -> bool {
    let n = len(rows)
    if n <= 1 { return true }
    let l0 = len(rows[0])
    let mut i = 1
    while i < n {
        if len(rows[i]) != l0 { return false }
        i = i + 1
    }
    return true
}

fn count_gaps(s: string) -> int {
    let n = len(s)
    let mut c = 0
    let mut i = 0
    while i < n {
        if s.substring(i, i + 1) == "-" { c = c + 1 }
        i = i + 1
    }
    return c
}

// ── C1 단일 서열 ────────────────────────────────────────────────────
let mut s1: [str] = []
s1.push("MKVLW")
let r1 = msa(s1)
check("C1 single seq",
      len(r1) == 1 && r1[0] == "MKVLW",
      "len=" + to_string(len(r1)) + " out=" + (if len(r1) > 0 { r1[0] } else { "<empty>" }))

// ── C2 3개 동일 서열 ────────────────────────────────────────────────
let mut s2: [str] = []
s2.push("MKVLW")
s2.push("MKVLW")
s2.push("MKVLW")
let r2 = msa(s2)
let mut c2_ok = len(r2) == 3 && all_same_length(r2)
if c2_ok {
    let mut k = 0
    while k < 3 {
        if r2[k] != "MKVLW" { c2_ok = false }
        k = k + 1
    }
}
check("C2 three identical seqs",
      c2_ok,
      "rows=" + to_string(len(r2))
      + " r0=" + (if len(r2) > 0 { r2[0] } else { "" })
      + " r1=" + (if len(r2) > 1 { r2[1] } else { "" })
      + " r2=" + (if len(r2) > 2 { r2[2] } else { "" }))

// ── C3 1 insertion ──────────────────────────────────────────────────
// 두 short + 한 long → 모든 row 길이 6, 짧은 두 row 에 정확히 한 gap.
let mut s3: [str] = []
s3.push("MKVLW")
s3.push("MKVLW")
s3.push("MKVVLW")
let r3 = msa(s3)
let mut c3_ok = len(r3) == 3 && all_same_length(r3)
if c3_ok && len(r3) >= 1 { if len(r3[0]) != 6 { c3_ok = false } }
// 짧은 row 두 개는 gap 1 개, 긴 row 는 gap 0 개.
if c3_ok {
    if count_gaps(r3[0]) != 1 { c3_ok = false }
    if count_gaps(r3[1]) != 1 { c3_ok = false }
    if count_gaps(r3[2]) != 0 { c3_ok = false }
}
// ungap 시 원본 복원.
if c3_ok {
    if ungap(r3[0]) != "MKVLW" { c3_ok = false }
    if ungap(r3[1]) != "MKVLW" { c3_ok = false }
    if ungap(r3[2]) != "MKVVLW" { c3_ok = false }
}
check("C3 one insertion across 3 seqs",
      c3_ok,
      "r0=" + (if len(r3) > 0 { r3[0] } else { "" })
      + " r1=" + (if len(r3) > 1 { r3[1] } else { "" })
      + " r2=" + (if len(r3) > 2 { r3[2] } else { "" }))

// ── C4 NJ tree cluster structure ────────────────────────────────────
// {s0,s1}=AAAACCCC pair, {s2,s3}=GGGGTTTT pair → NJ 가 두 명백한 클러스터로 묶어야.
//
// 검증: build_distance_matrix → D[0][1]=0, D[2][3]=0,
//      D[0][2] > 0.9, D[1][3] > 0.9 (완전 mismatch).
// NJ tree root 의 두 child 가 각각 {0,1} sub-tree, {2,3} sub-tree 인지
// post-order leaf 수집해 확인.
let mut s4: [str] = []
s4.push("AAAACCCC")
s4.push("AAAACCCC")
s4.push("GGGGTTTT")
s4.push("GGGGTTTT")
let d4 = build_distance_matrix(s4)
let t4 = build_nj_tree(d4)

// 거리 sanity.
let mut c4_dist_ok = true
if _abs_dist(d4[0][1]) > 0.0001 { c4_dist_ok = false }  // 동일 → 0
if _abs_dist(d4[2][3]) > 0.0001 { c4_dist_ok = false }
if d4[0][2] < 0.9 { c4_dist_ok = false }
if d4[1][3] < 0.9 { c4_dist_ok = false }

// Root 자식들 leaf-set 수집.
let root_node = t4.nodes[t4.root]
let left_leaves = collect_leaves(t4, root_node.left)
let right_leaves = collect_leaves(t4, root_node.right)
// 한쪽이 {0,1}, 다른쪽이 {2,3} 인지 (양쪽 어느 순서든 OK).
let pair_01_left = has_pair(left_leaves, 0, 1) && has_pair(right_leaves, 2, 3)
let pair_01_right = has_pair(right_leaves, 0, 1) && has_pair(left_leaves, 2, 3)
let c4_topo_ok = pair_01_left || pair_01_right

check("C4 NJ cluster {0,1} vs {2,3}",
      c4_dist_ok && c4_topo_ok,
      "d01=" + to_string(d4[0][1])
      + " d23=" + to_string(d4[2][3])
      + " d02=" + to_string(d4[0][2])
      + " topo=" + to_string(c4_topo_ok))

// ── C5 distance matrix symmetry ─────────────────────────────────────
let mut s5: [str] = []
s5.push("ACGTACGT")
s5.push("ACGTTCGT")
s5.push("ACCTACGT")
s5.push("TCGTACGT")
let d5 = build_distance_matrix(s5)
let n5 = len(s5)
let mut c5_ok = true
let mut i5 = 0
while i5 < n5 {
    let mut j5 = i5 + 1
    while j5 < n5 {
        if _abs_dist(d5[i5][j5] - d5[j5][i5]) > 0.00001 { c5_ok = false }
        j5 = j5 + 1
    }
    i5 = i5 + 1
}
check("C5 distance symmetry D[i][j]==D[j][i]",
      c5_ok,
      "n=" + to_string(n5))

// ── C6 distance self == 0 ───────────────────────────────────────────
let mut c6_ok = true
let mut k6 = 0
while k6 < n5 {
    if _abs_dist(d5[k6][k6]) > 0.00001 { c6_ok = false }
    k6 = k6 + 1
}
check("C6 distance D[i][i]==0", c6_ok, "n=" + to_string(n5))

// ── C7 ribonuclease 4-seq fragment ──────────────────────────────────
// 4 짧은 RNase-A 패밀리 단편 (~25-30 residues each).
// 검증: 모든 row 같은 길이 + ungap 시 원본 복원 (loss-less reordering).
let mut s7: [str] = []
s7.push("KESAAAKFERQHMDS")
s7.push("KESAAAKFERQHMDS")
s7.push("KETAAAKFERQHIDT")
s7.push("RESAAEKFERQHMDS")
let r7 = msa(s7)
let mut c7_ok = len(r7) == 4 && all_same_length(r7)
if c7_ok {
    let mut k7 = 0
    while k7 < 4 {
        if ungap(r7[k7]) != s7[k7] { c7_ok = false }
        k7 = k7 + 1
    }
}
// 정렬된 길이는 입력 최대 길이 이상이어야 한다 (gap insertion만 가능).
let max_in_len = len(s7[0])
let mut k7m = 1
while k7m < 4 {
    if len(s7[k7m]) > max_in_len { max_in_len = len(s7[k7m]) }
    k7m = k7m + 1
}
if c7_ok && len(r7) > 0 {
    if len(r7[0]) < max_in_len { c7_ok = false }
}
check("C7 ribonuclease 4-seq fragment",
      c7_ok,
      "rows=" + to_string(len(r7))
      + " L=" + (if len(r7) > 0 { to_string(len(r7[0])) } else { "0" })
      + " r0=" + (if len(r7) > 0 { r7[0] } else { "" }))

// ── helpers (forward-referenced — hexa hoists fn decls) ─────────────

fn _abs_dist(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn collect_leaves(tree: NjTree, node_idx: int) -> [int] {
    let mut out: [int] = []
    let node = tree.nodes[node_idx]
    if node.is_leaf {
        out.push(node.seq_idx)
        return out
    }
    let l = collect_leaves(tree, node.left)
    let r = collect_leaves(tree, node.right)
    let mut i = 0
    while i < len(l) { out.push(l[i]); i = i + 1 }
    let mut j = 0
    while j < len(r) { out.push(r[j]); j = j + 1 }
    return out
}

fn has_pair(leaves: [int], a: int, b: int) -> bool {
    if len(leaves) != 2 { return false }
    let l0 = leaves[0]
    let l1 = leaves[1]
    return (l0 == a && l1 == b) || (l0 == b && l1 == a)
}

// ── Verdict ─────────────────────────────────────────────────────────
println("")
if pass_count == total {
    println("PASS: msa " + to_string(pass_count) + "/" + to_string(total))
    exit(0)
} else {
    println("FAIL: msa first=" + first_fail
            + " (" + to_string(pass_count) + "/" + to_string(total) + ")")
    exit(1)
}
