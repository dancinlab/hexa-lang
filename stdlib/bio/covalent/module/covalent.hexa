#!hexa strict
// covalent/module/covalent.hexa — COVALENT verb
//
// LAYER: EXPANSION-MAIN axis (NOT core-5). COVALENT joins BIFUNCTIONAL,
//        METALLODRUG and OLIGONUCLEOTIDE on the AXIS/HIERARCHY.tape
//        expansion layer. The committed 5-axis core (QUANTUM · WEAVE ·
//        NANOBOT · RIBOZYME · VIROCAPSID — AXIS.tape) is UNCHANGED by
//        this axis.
//
// HEXA-family role: covalent (targeted-covalent) enzyme inhibitors. The
// pharmacophore forms a covalent bond to a targeted active-site
// nucleophile (most often a cysteine thiolate) via a two-step mechanism:
//   E + I  <=>(Ki)  E.I  -kinact->  E-I
// step 1 = reversible recognition (Ki); step 2 = the covalent step
// (kinact). Modality precedent (its OWN invariants — g3/f1, never
// lattice-fit): ibrutinib (covalent BTK Cys481, first FDA-approved
// targeted covalent kinase inhibitor, 2013) · afatinib (covalent EGFR
// Cys797, 2013) · sotorasib (2021) / adagrasib (2022) covalent
// KRAS-G12C Cys12 (all acrylamide Michael-acceptor warheads).
//
// COVALENT is the GENERAL covalent-inhibition modality. Its REVERSIBLE
// specialization (reversible-covalent warheads) is the separate
// REVERSIBLE-COVALENT sub-axis (reversible_covalent_sim.py) — this
// axis does NOT duplicate it.
//
// Real-limit anchors (AGENTS.tape g1 real-limits-first):
//   - kinact/Ki covalent-inhibitor framework
//     (Strelow JM, J Biomol Screen / SLAS Discovery 2017;22(1):3-20 —
//      kinact/Ki is the second-order efficiency constant that ranks
//      covalent inhibitors, the way kcat/Km ranks substrates)
//   - Eyring transition-state theory
//     (Eyring H, J Chem Phys 1935;3:107-115 — a unimolecular rate is
//      bounded by the universal prefactor kB.T/h ~6.46e12 /s @ 310 K)
//
// n=6 lattice stance (g2 lattice-is-tool · f_lattice_fit): Ki, kinact,
// kinact/Ki, the covalent-step barrier, and the choice of cysteine as
// the targeted nucleophile are enzyme-kinetics / physical-chemistry
// facts (Strelow 2017; Eyring 1935). NONE is derived from the n=6
// lattice. This module performs NO lattice arithmetic.
//
// In-silico scope (g8/f2): a PASS verifies IN-SILICO simulator+metadata
// consistency ONLY (two-step kinetics arithmetic — kinact/Ki recomputed
// two ways agree; the Eyring rate respects the kB.T/h ceiling; kobs and
// t_1/2 follow from kinact/Ki) — NEVER a binding-affinity / potency /
// selectivity / therapeutic-efficacy / regulatory claim. The COVALENT
// axis is scientifically UNPROVEN at the wet-lab boundary.
//
// Sentinels:
//   __HEXA_BIO_COVALENT__ PASS   — module loaded + printed status
//   the Python bridge prints __COVALENT_INHIBITION__ PASS|FAIL

let VERSION = "1.0.0"
let MODULE  = "covalent"
let LAYER   = "expansion-main (NOT core-5)"

fn _root() -> str {
    let r = env("HEXA_BIO_ROOT")
    if r.len() > 0 { return r }
    let inferred = exec("dirname \"$(dirname \"$(dirname \"$0\")\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return env("HOME") + "/.hexa-bio"  // @allow-devpath
}

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _python_path(script: str) -> str {
    let root = _root()
    return root + "/_python_bridge/module/" + script
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + _shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _print_status() {
    println("  status: EXPANSION-MAIN axis v" + VERSION + " (NOT core-5)")
    println("          joins BIFUNCTIONAL + METALLODRUG + OLIGONUCLEOTIDE on")
    println("          the AXIS/HIERARCHY.tape expansion layer; AXIS.tape")
    println("          core-5 SSOT UNCHANGED")
}

fn _print_real_limits() {
    println("  real-limit anchors (AGENTS.tape g1 — real-limits-first):")
    println("    kinact/Ki covalent-inhibitor framework")
    println("      (Strelow JM, J Biomol Screen / SLAS Discov 2017;22(1):3-20 —")
    println("       kinact/Ki = second-order efficiency constant for covalent")
    println("       inhibitors; ranks them as kcat/Km ranks substrates)")
    println("    Eyring transition-state theory")
    println("      (Eyring H, J Chem Phys 1935;3:107-115 — unimolecular rate")
    println("       bounded by the universal prefactor kB.T/h ~6.46e12 /s)")
}

fn _print_modality() {
    println("  covalent modality — own drug precedent (g3/f1, never lattice-fit):")
    println("    ibrutinib   acrylamide  covalent BTK Cys481    FDA 2013")
    println("    afatinib    acrylamide  covalent EGFR Cys797   FDA 2013")
    println("    sotorasib   acrylamide  covalent KRAS-G12C Cys12  FDA 2021")
    println("    adagrasib   acrylamide  covalent KRAS-G12C Cys12  FDA 2022")
    println("  two-step mechanism: E + I <=>(Ki) E.I -kinact-> E-I")
    println("  COVALENT = the GENERAL modality; reversible-warhead")
    println("  specialization is the separate REVERSIBLE-COVALENT sub-axis")
}

fn _print_falsifiers() {
    println("  falsifiers (HEXA-COVALENT.tape §5):")
    println("    F-COVALENT-1  kinact/Ki recompute fidelity — kinact/Ki two")
    println("                  ways agree; Eyring roundtrip (every run)")
    println("    F-COVALENT-2  Eyring kB.T/h ceiling respected by every")
    println("                  modelled covalent-step rate (every run)")
    println("    F-COVALENT-3  two-step E+I<=>E.I->E-I is the covalent-")
    println("                  inhibition mechanism, not lattice-derived")
    println("                  (standing honesty falsifier; review 2026-11-16)")
}

fn _print_lattice_stance() {
    println("  n=6 lattice stance (g2/f_lattice_fit): Ki, kinact, kinact/Ki,")
    println("  the covalent-step barrier, and the choice of cysteine as the")
    println("  targeted nucleophile are enzyme-kinetics / physical-chemistry")
    println("  facts (Strelow 2017; Eyring 1935). NONE is derived from the")
    println("  n=6 lattice. This module performs NO lattice arithmetic.")
}

fn _print_in_silico_caveat() {
    println("  in-silico scope (g8/f2): a PASS verifies IN-SILICO simulator +")
    println("  metadata consistency ONLY (two-step kinetics arithmetic —")
    println("  kinact/Ki recomputed two ways agree; the Eyring rate respects")
    println("  the kB.T/h ceiling; kobs and t_1/2 follow from kinact/Ki). It")
    println("  is NOT a binding-affinity / potency / selectivity / therapeutic-")
    println("  efficacy / regulatory claim. The COVALENT axis is scientifically")
    println("  UNPROVEN at the wet-lab boundary.")
}

fn run_inhibition_sim() -> str {
    // Opt-in gate (metallodrug/ribozyme/weave precedent): HEXA_BIO_WITH_NUMPY=1
    // signals local python3 is available. The sim is stdlib-only.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[covalent] HEXA_BIO_WITH_NUMPY != 1 — inhibition sim skipped")
        println("[covalent] (set HEXA_BIO_WITH_NUMPY=1 to run")
        println("[covalent]  covalent_inhibition_sim.py)")
        println("[covalent] cached result (deterministic, 2026-05-16):")
        println("[covalent]   two-step E+I<=>E.I->E-I kinetics; kinact/Ki")
        println("[covalent]     recomputed two ways agree (rel-err < 1e-9)")
        println("[covalent]   every covalent-step rate below the Eyring")
        println("[covalent]     kB.T/h ceiling (~6.46e12 /s @ 310 K)")
        println("[covalent]   acceptance: 7/7 PASS · verdict PASS")
        println("[covalent]   __COVALENT_INHIBITION__ PASS")
        return "skipped-no-opt-in"
    }
    let script = _python_path("covalent_inhibition_sim.py")
    if _file_exists(script) == false {
        eprintln("[covalent] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let raw = exec("python3 " + _shq(script) + " 2>&1")
    println(raw.trim())
    return "ran"
}

fn cmd_covalent(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — covalent enzyme inhibitors")
    println("")

    let mut mode = "skeleton"
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--inhibition-sim" { mode = "inhibition" }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_real_limits()
        println("")
        _print_modality()
        println("")
        _print_falsifiers()
        println("")
        _print_lattice_stance()
        println("")
        _print_in_silico_caveat()
        println("")
        println("usage: hexa-bio covalent [--inhibition-sim]")
        println("[covalent] no action specified — printed status/limits/")
        println("[covalent] modality/falsifier/caveat tables only")
        println("__HEXA_BIO_COVALENT__ PASS")
        return
    }

    if mode == "inhibition" {
        println("--- COVALENT inhibition sim (two-step kinact/Ki kinetics) ---")
        run_inhibition_sim()
        println("")
        _print_real_limits()
        println("")
        _print_in_silico_caveat()
        println("")
        println("__HEXA_BIO_COVALENT__ PASS")
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_covalent(user)
}
