{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/covalent/spec/inhibition_v1.schema.json",
  "title": "covalent_inhibition_v1 — COVALENT axis inhibition-sim output",
  "description": "Output schema for _python_bridge/module/covalent_inhibition_sim.py. COVALENT is an EXPANSION-MAIN axis (NOT core-5) — the general covalent-inhibition modality (its reversible-warhead specialization is the separate REVERSIBLE-COVALENT sub-axis). A PASS row verifies IN-SILICO simulator+metadata consistency ONLY (two-step E+I<=>E.I->E-I kinetics arithmetic: kinact/Ki recomputed two ways agree, the Eyring covalent-step rate respects the kB.T/h ceiling, kobs and t_1/2 follow from kinact/Ki) — never a binding-affinity/potency/selectivity/therapeutic/regulatory claim (hexa-bio AGENTS.tape g8_in_silico_only / f2).",
  "type": "object",
  "required": ["schema", "ts", "axis", "axis_layer", "verdict",
               "real_limit_anchors", "rows", "acceptance"],
  "properties": {
    "schema": {"type": "string", "const": "covalent_inhibition_v1"},
    "ts": {"type": "string", "description": "fixed timestamp — deterministic witness"},
    "axis": {"type": "string", "const": "COVALENT"},
    "axis_layer": {
      "type": "string",
      "description": "expansion-layer marker — must declare NOT core-5",
      "pattern": "expansion-main"
    },
    "version": {"type": "string"},
    "model": {"type": "string"},
    "real_limit_anchors": {
      "type": "object",
      "description": "literature real-limit anchors (g1 real-limits-first)",
      "required": ["kinact_over_Ki_framework_citation", "eyring_tst_citation",
                   "eyring_prefactor_ceiling_per_s", "temperature_K"],
      "properties": {
        "kinact_over_Ki_framework_citation": {
          "type": "string",
          "description": "Strelow 2017 — kinact/Ki covalent-inhibitor framework"
        },
        "eyring_tst_citation": {
          "type": "string",
          "description": "Eyring 1935 — transition-state theory"
        },
        "eyring_prefactor_ceiling_per_s": {
          "type": "number", "exclusiveMinimum": 0,
          "description": "Eyring universal prefactor kB.T/h — hard rate ceiling"
        },
        "temperature_K": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "reference_inhibitor_conc_M": {"type": "number", "exclusiveMinimum": 0},
    "rows": {
      "type": "array",
      "description": "one two-step covalent-inhibitor kinetics row per panel entry",
      "minItems": 1,
      "items": {"$ref": "#/definitions/inhibitorRow"}
    },
    "potency_ranking": {
      "type": "object",
      "description": "in-silico kinact/Ki ranking of the panel — NOT a potency claim",
      "properties": {
        "metric": {"type": "string"},
        "framework_citation": {"type": "string"},
        "ranking": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["inhibitor", "kinact_over_Ki_M_per_s"],
            "properties": {
              "inhibitor": {"type": "string"},
              "kinact_over_Ki_M_per_s": {"type": "number", "minimum": 0},
              "drug_precedent": {"type": "string"}
            }
          }
        },
        "note": {"type": "string"}
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["criteria", "pass_count", "total", "verdict"],
      "properties": {
        "criteria": {
          "type": "object",
          "description": "C1..C7 in-silico simulator-consistency booleans",
          "additionalProperties": {"type": "boolean"}
        },
        "pass_count": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 1},
        "verdict": {"type": "string", "enum": ["PASS", "FAIL"]}
      }
    },
    "pass_count": {"type": "integer", "minimum": 0},
    "total_criteria": {"type": "integer", "minimum": 1},
    "verdict": {"type": "string", "enum": ["PASS", "FAIL"]},
    "subaxis_note": {
      "type": "string",
      "description": "must affirm COVALENT is the general modality and not duplicate the REVERSIBLE-COVALENT sub-axis"
    },
    "lattice_stance": {
      "type": "string",
      "description": "honest n=6 stance — must affirm no lattice derivation (g2/f1/f_lattice_fit)"
    },
    "in_silico_scope": {
      "type": "string",
      "description": "g8/f2 in-silico-only scope caveat"
    }
  },
  "definitions": {
    "inhibitorRow": {
      "type": "object",
      "required": ["schema", "inhibitor", "warhead_class", "Ki_molar",
                   "kinact_per_s", "kinact_over_Ki_M_per_s",
                   "kobs_per_s", "free_enzyme_half_life_s",
                   "dg_covalent_step_kcal_per_mol", "kinact_eyring_tst_per_s",
                   "metric_consistency_rel_err",
                   "kinact_below_eyring_ceiling"],
      "properties": {
        "schema": {"type": "string", "const": "covalent_inhibition_v1"},
        "inhibitor": {"type": "string"},
        "warhead_class": {"type": "string"},
        "drug_precedent": {"type": "string"},
        "temperature_K": {"type": "number", "exclusiveMinimum": 0},
        "two_step_mechanism": {"type": "string"},
        "Ki_molar": {
          "type": "number", "exclusiveMinimum": 0,
          "description": "step-1 reversible recognition constant (dissociation K)"
        },
        "kinact_per_s": {
          "type": "number", "exclusiveMinimum": 0,
          "description": "step-2 first-order covalent-step rate from saturated E.I"
        },
        "kinact_over_Ki_M_per_s": {
          "type": "number", "exclusiveMinimum": 0,
          "description": "kinact/Ki — the covalent-inhibitor efficiency metric (Strelow 2017)"
        },
        "inhibitor_conc_M": {"type": "number", "exclusiveMinimum": 0},
        "saturation_I_over_Ki": {"type": "number", "minimum": 0},
        "kobs_per_s": {"type": "number", "minimum": 0},
        "kobs_low_I_limit_per_s": {"type": "number", "minimum": 0},
        "kinact_over_Ki_from_kobs_M_per_s": {"type": "number", "minimum": 0},
        "metric_consistency_rel_err": {
          "type": "number", "minimum": 0,
          "description": "kinact/Ki recomputed two ways must agree (< 1e-9)"
        },
        "free_enzyme_half_life_s": {"type": "number", "minimum": 0},
        "free_enzyme_half_life_human": {"type": "string"},
        "dg_covalent_step_kcal_per_mol": {
          "type": "number",
          "description": "covalent-step activation barrier DG-double-dagger"
        },
        "kinact_eyring_tst_per_s": {
          "type": "number", "minimum": 0,
          "description": "Eyring-TST kinact predicted from DG-double-dagger"
        },
        "dg_implied_from_kinact_kcal_per_mol": {"type": "number"},
        "eyring_prefactor_ceiling_per_s": {
          "type": "number", "exclusiveMinimum": 0
        },
        "kinact_below_eyring_ceiling": {
          "type": "boolean",
          "description": "kinact must be below the Eyring kB.T/h ceiling"
        },
        "kinact_tst_below_eyring_ceiling": {"type": "boolean"}
      }
    }
  },
  "additionalProperties": true
}
