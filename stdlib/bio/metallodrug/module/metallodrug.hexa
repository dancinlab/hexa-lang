#!hexa strict
// metallodrug/module/metallodrug.hexa — METALLODRUG verb
//
// LAYER: EXPANSION-MAIN axis (NOT core-5). METALLODRUG joins COVALENT and
//        BIFUNCTIONAL on the AXIS/HIERARCHY.tape expansion layer. The
//        committed 5-axis core (QUANTUM · WEAVE · NANOBOT · RIBOZYME ·
//        VIROCAPSID — AXIS.tape) is UNCHANGED by this axis.
//
// HEXA-family role: metal-coordination therapeutics (metallodrugs). The
// pharmacophore is a metal centre — coordination geometry, oxidation
// state, d-electron configuration, ligand-exchange kinetics ARE the
// mechanism. Modality precedent (its OWN invariants — g3/f1, never
// lattice-fit): cisplatin (square-planar Pt(II), FDA 1978) · carboplatin
// (1989) · oxaliplatin (2002) · auranofin (gold(I), RA, 1985) · arsenic
// trioxide (As2O3, acute promyelocytic leukemia).
//
// Real-limit anchors (AGENTS.tape g1 real-limits-first):
//   - cisplatin Pt-N7(guanine) coordinate bond ~2.0 A
//     (Takahara et al., Nature 1995;377:649-652 — 1,2-intrastrand d(GpG)
//      DNA adduct crystal structure)
//   - crystal-field stabilization energy (CFSE) closed forms
//     (Griffith & Orgel, Q Rev Chem Soc 1957;11:381-393 — ligand-field
//      theory: t2g/eg split, Delta_oct, CFSE table)
//
// n=6 lattice stance (g2 lattice-is-tool · f_lattice_fit): octahedral
// 6-coordination is the geometry of an octahedron + ligand-ligand
// repulsion; square-planar 4-coordination is the d8 strong-field
// preference of Pt(II). NEITHER count, nor any CFSE value, nor the
// ~2.0 A bond length, is derived from the n=6 lattice. The coincidence
// "octahedral = 6" is OBSERVATION ONLY. This module performs NO lattice
// arithmetic.
//
// In-silico scope (g8/f2): a PASS verifies IN-SILICO simulator+metadata
// consistency ONLY (CFSE arithmetic vs ligand-field theory; square-planar
// geometry vs the cited Pt-N7 bond length) — NEVER a therapeutic /
// cytotoxic / antitumor / immunogenic / efficacy / regulatory claim. The
// METALLODRUG axis is scientifically UNPROVEN at the wet-lab boundary.
//
// Sentinels:
//   __HEXA_BIO_METALLODRUG__ PASS    — module loaded + printed status
//   the Python bridge prints __METALLODRUG_COORDINATION__ PASS|FAIL

let VERSION = "1.0.0"
let MODULE  = "metallodrug"
let LAYER   = "expansion-main (NOT core-5)"

fn _root() -> str {
    let r = env("HEXA_BIO_ROOT")
    if r.len() > 0 { return r }
    let inferred = exec("dirname \"$(dirname \"$(dirname \"$0\")\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return env("HOME") + "/.hexa-bio"  // @allow-devpath
}

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _python_path(script: str) -> str {
    let root = _root()
    return root + "/_python_bridge/module/" + script
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + _shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _print_status() {
    println("  status: EXPANSION-MAIN axis v" + VERSION + " (NOT core-5)")
    println("          joins COVALENT + BIFUNCTIONAL on the AXIS/HIERARCHY.tape")
    println("          expansion layer; AXIS.tape core-5 SSOT UNCHANGED")
}

fn _print_real_limits() {
    println("  real-limit anchors (AGENTS.tape g1 — real-limits-first):")
    println("    Pt-N7(guanine) coordinate bond ~2.0 A")
    println("      (Takahara et al., Nature 1995;377:649-652 — cisplatin")
    println("       1,2-intrastrand d(GpG) DNA adduct crystal structure)")
    println("    crystal-field stabilization energy (CFSE) closed forms")
    println("      (Griffith & Orgel, Q Rev Chem Soc 1957;11:381-393 —")
    println("       ligand-field theory: t2g/eg split, Delta_oct, CFSE table)")
}

fn _print_modality() {
    println("  metallodrug modality — own drug precedent (g3/f1, never lattice-fit):")
    println("    cisplatin     square-planar Pt(II)  FDA 1978  solid tumors")
    println("    carboplatin   square-planar Pt(II)  FDA 1989  ovarian/lung")
    println("    oxaliplatin   square-planar Pt(II)  FDA 2002  colorectal")
    println("    auranofin     linear gold(I)        FDA 1985  rheumatoid arthritis")
    println("    arsenic trioxide  As2O3             APL (acute promyelocytic leukemia)")
}

fn _print_falsifiers() {
    println("  falsifiers (HEXA-METALLODRUG.tape §5):")
    println("    F-METALLODRUG-1  CFSE numerical-recompute fidelity vs")
    println("                     ligand-field theory (every run; FAIL = falsified)")
    println("    F-METALLODRUG-2  Pt-N7 bond-length anchor 1.85-2.15 A")
    println("                     (re-checked at axis review 2026-11-16)")
    println("    F-METALLODRUG-3  square-planar is d8, not lattice-derived")
    println("                     (standing honesty falsifier; review 2026-11-16)")
}

fn _print_lattice_stance() {
    println("  n=6 lattice stance (g2/f_lattice_fit): octahedral 6-coordination")
    println("  is octahedron geometry + ligand-ligand repulsion; square-planar")
    println("  4-coordination is the d8 strong-field preference of Pt(II).")
    println("  NEITHER count, nor CFSE, nor the ~2.0 A bond length is derived")
    println("  from the n=6 lattice. 'octahedral = 6' is OBSERVATION ONLY.")
}

fn _print_in_silico_caveat() {
    println("  in-silico scope (g8/f2): a PASS verifies IN-SILICO simulator +")
    println("  metadata consistency ONLY (CFSE vs ligand-field theory; square-")
    println("  planar geometry vs the cited Pt-N7 bond length). It is NOT a")
    println("  therapeutic / cytotoxic / antitumor / immunogenic / efficacy /")
    println("  regulatory claim. The METALLODRUG axis is scientifically")
    println("  UNPROVEN at the wet-lab boundary.")
}

fn run_coordination_sim() -> str {
    // Opt-in gate (ribozyme/weave/virocapsid precedent): HEXA_BIO_WITH_NUMPY=1
    // signals local python3 is available. The sim is stdlib-only.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[metallodrug] HEXA_BIO_WITH_NUMPY != 1 — coordination sim skipped")
        println("[metallodrug] (set HEXA_BIO_WITH_NUMPY=1 to run")
        println("[metallodrug]  metallodrug_coordination_sim.py)")
        println("[metallodrug] cached result (deterministic, 2026-05-16):")
        println("[metallodrug]   CFSE d0..d10 table matches ligand-field theory")
        println("[metallodrug]     (max deviation ~5.6e-16, tol 1e-9)")
        println("[metallodrug]   square-planar Pt-N recomputed = 2.0000 A")
        println("[metallodrug]     (matches ~2.0 A Pt-N7 anchor, dev 0.0 A)")
        println("[metallodrug]   acceptance: 7/7 PASS · verdict PASS")
        println("[metallodrug]   __METALLODRUG_COORDINATION__ PASS")
        return "skipped-no-opt-in"
    }
    let script = _python_path("metallodrug_coordination_sim.py")
    if _file_exists(script) == false {
        eprintln("[metallodrug] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let raw = exec("python3 " + _shq(script) + " 2>&1")
    println(raw.trim())
    return "ran"
}

fn cmd_metallodrug(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — metal-coordination therapeutics")
    println("")

    let mut mode = "skeleton"
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--coordination-sim" { mode = "coordination" }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_real_limits()
        println("")
        _print_modality()
        println("")
        _print_falsifiers()
        println("")
        _print_lattice_stance()
        println("")
        _print_in_silico_caveat()
        println("")
        println("usage: hexa-bio metallodrug [--coordination-sim]")
        println("[metallodrug] no action specified — printed status/limits/")
        println("[metallodrug] modality/falsifier/caveat tables only")
        println("__HEXA_BIO_METALLODRUG__ PASS")
        return
    }

    if mode == "coordination" {
        println("--- METALLODRUG coordination sim (CFSE + square-planar Pt-N7) ---")
        run_coordination_sim()
        println("")
        _print_real_limits()
        println("")
        _print_in_silico_caveat()
        println("")
        println("__HEXA_BIO_METALLODRUG__ PASS")
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_metallodrug(user)
}
