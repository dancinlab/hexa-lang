{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/metallodrug/spec/coordination_v1.schema.json",
  "title": "metallodrug_coordination_v1 — METALLODRUG axis coordination-sim output",
  "description": "Output schema for _python_bridge/module/metallodrug_coordination_sim.py. METALLODRUG is an EXPANSION-MAIN axis (NOT core-5). A PASS row verifies IN-SILICO simulator+metadata consistency ONLY (CFSE arithmetic vs ligand-field theory; square-planar geometry vs the cited cisplatin Pt-N7 bond length) — never a therapeutic/cytotoxic/antitumor/regulatory claim (hexa-bio AGENTS.tape g8_in_silico_only / f2).",
  "type": "object",
  "required": ["schema", "ts", "axis", "verdict", "real_limit_anchors",
               "cfse_verification", "pt_n7_geometry_verification",
               "acceptance_criteria"],
  "properties": {
    "schema": {"type": "string", "const": "metallodrug_coordination_v1"},
    "ts": {"type": "string", "description": "fixed timestamp — deterministic witness"},
    "axis": {"type": "string", "const": "METALLODRUG"},
    "axis_layer": {
      "type": "string",
      "description": "expansion-layer marker — must declare NOT core-5",
      "pattern": "expansion-main"
    },
    "version": {"type": "string"},
    "real_limit_anchors": {
      "type": "object",
      "description": "literature real-limit anchors (g1 real-limits-first)",
      "required": ["pt_n7_bond_length_angstrom", "pt_n7_citation",
                   "cfse_closed_form_citation"],
      "properties": {
        "pt_n7_bond_length_angstrom": {
          "type": "number", "minimum": 1.85, "maximum": 2.15,
          "description": "cisplatin Pt-N7(guanine) coordinate bond ~2.0 A"
        },
        "pt_n7_citation": {"type": "string"},
        "cfse_closed_form_citation": {"type": "string"}
      }
    },
    "cfse_table": {
      "type": "array",
      "description": "d0..d10 CFSE table, octahedral HS/LS + square-planar",
      "items": {
        "type": "object",
        "required": ["d_count", "oct_high_spin", "oct_low_spin", "square_planar"],
        "properties": {
          "d_count": {"type": "integer", "minimum": 0, "maximum": 10},
          "oct_high_spin": {"$ref": "#/definitions/octConfig"},
          "oct_low_spin": {"$ref": "#/definitions/octConfig"},
          "square_planar": {
            "type": "object",
            "required": ["cfse_delta_oct"],
            "properties": {
              "cfse_delta_oct": {"type": "number"}
            }
          }
        }
      }
    },
    "cfse_verification": {
      "type": "object",
      "required": ["max_deviation_high_spin", "max_deviation_low_spin",
                   "tolerance", "pass"],
      "properties": {
        "max_deviation_high_spin": {"type": "number", "minimum": 0},
        "max_deviation_low_spin": {"type": "number", "minimum": 0},
        "tolerance": {"type": "number", "exclusiveMinimum": 0},
        "mismatches": {"type": "array", "items": {"type": "string"}},
        "pass": {"type": "boolean"}
      }
    },
    "square_planar_geometry": {
      "type": "object",
      "properties": {
        "bond_length_angstrom": {"type": "number"},
        "pt_ligand_distances_angstrom": {
          "type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4
        },
        "pt_ligand_distance_recomputed": {"type": "number"},
        "cis_ligand_separation_angstrom": {"type": "number"},
        "trans_ligand_separation_angstrom": {"type": "number"},
        "cis_L_Pt_L_angle_deg": {"type": "number"},
        "trans_L_Pt_L_angle_deg": {"type": "number"},
        "cis_sep_closed_form": {"type": "number"},
        "trans_sep_closed_form": {"type": "number"}
      }
    },
    "pt_n7_geometry_verification": {
      "type": "object",
      "required": ["recomputed_pt_n_angstrom", "deviation_angstrom",
                   "anchor_match", "pass"],
      "properties": {
        "real_limit_anchor": {"type": "string"},
        "anchor_value_angstrom": {"type": "number"},
        "anchor_tolerance_angstrom": {"type": "number", "exclusiveMinimum": 0},
        "recomputed_pt_n_angstrom": {"type": "number"},
        "deviation_angstrom": {"type": "number", "minimum": 0},
        "anchor_match": {"type": "boolean"},
        "square_geometry_self_consistent": {"type": "boolean"},
        "citation": {"type": "string"},
        "pass": {"type": "boolean"}
      }
    },
    "metallodrug_metadata": {
      "type": "array",
      "description": "representative metallodrugs by their OWN drug precedent (g3/f1 — never lattice-fit)",
      "items": {
        "type": "object",
        "required": ["name", "metal", "oxidation_state", "geometry"],
        "properties": {
          "name": {"type": "string"},
          "metal": {"type": "string"},
          "oxidation_state": {"type": "integer"},
          "d_count": {"type": ["integer", "null"], "minimum": 0, "maximum": 10},
          "geometry": {"type": "string"},
          "fda_year": {"type": "integer"},
          "indication": {"type": "string"}
        }
      }
    },
    "falsifiers": {
      "type": "object",
      "description": "F-METALLODRUG-1/2/3 boolean HOLD flags",
      "additionalProperties": {"type": "boolean"}
    },
    "acceptance_criteria": {
      "type": "object",
      "description": "C1..C7 pass/fail booleans",
      "additionalProperties": {"type": "boolean"}
    },
    "pass_count": {"type": "integer", "minimum": 0},
    "total_criteria": {"type": "integer", "minimum": 1},
    "verdict": {"type": "string", "enum": ["PASS", "FAIL"]},
    "lattice_stance": {
      "type": "string",
      "description": "honest n=6 stance — must affirm no lattice derivation (g2/f1/f_lattice_fit)"
    },
    "in_silico_scope": {
      "type": "string",
      "description": "g8/f2 in-silico-only scope caveat"
    }
  },
  "definitions": {
    "octConfig": {
      "type": "object",
      "required": ["n_t2g", "n_eg", "n_unpaired", "cfse_delta_oct"],
      "properties": {
        "n_t2g": {"type": "integer", "minimum": 0, "maximum": 6},
        "n_eg": {"type": "integer", "minimum": 0, "maximum": 4},
        "n_unpaired": {"type": "integer", "minimum": 0, "maximum": 5},
        "cfse_delta_oct": {"type": "number"}
      }
    }
  },
  "additionalProperties": true
}
