{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/metallodrug/spec/quantum_vqe_cross_v1.schema.json",
  "title": "metallodrug_quantum_vqe_cross_v1 — CROSS-AXIS A1 METALLODRUG->QUANTUM output",
  "description": "Output schema for _python_bridge/module/metallodrug_quantum_vqe_cross.py. Couples the METALLODRUG expansion-axis (ligand-field d-orbital splitting) to the core QUANTUM axis VQE pipeline: an exact, analytically-solvable (2e,2o) singlet CI shows E_corr = E_FCI - E_HF < 0 for a near-degenerate transition-metal d-orbital pair, proving the manifold is multireference and is exactly the active space the QUANTUM-axis VQE pipeline must treat. A PASS row verifies IN-SILICO simulator+metadata consistency ONLY (exact 2x2 CI algebra; correct multireference identification) — never a binding/therapeutic/cytotoxic/antitumor/regulatory claim, and never a claim that VQE was executed (the live qmirror/VQE dispatch is an honest DEFER) — see hexa-bio AGENTS.tape g1/g7/g8/f2.",
  "type": "object",
  "required": ["schema", "ts", "cross", "axis_from", "axis_to",
               "real_limit_anchors", "cross_claim", "cases",
               "degeneracy_limit_check", "coupling_zero_control",
               "vqe_dispatch", "acceptance_criteria", "verdict",
               "lattice_stance", "in_silico_scope"],
  "properties": {
    "schema": {"type": "string", "const": "metallodrug_quantum_vqe_cross_v1"},
    "ts": {"type": "string", "description": "fixed timestamp — deterministic witness"},
    "cross": {"type": "string", "const": "METALLODRUG->QUANTUM"},
    "axis_from": {
      "type": "string",
      "description": "source axis — must declare METALLODRUG expansion-layer (NOT core-5)",
      "pattern": "METALLODRUG"
    },
    "axis_to": {
      "type": "string",
      "description": "target axis — the core-5 QUANTUM VQE pipeline",
      "pattern": "QUANTUM"
    },
    "version": {"type": "string"},
    "real_limit_anchors": {
      "type": "object",
      "description": "literature / closed-form real-limit anchors (g1 real-limits-first)",
      "required": ["exact_2x2_ci_eigenvalue", "ligand_field_splitting_citation",
                   "multireference_casscf_citation",
                   "quantum_vqe_metal_motivation_citation"],
      "properties": {
        "exact_2x2_ci_eigenvalue": {"type": "string"},
        "ligand_field_splitting_citation": {"type": "string"},
        "multireference_casscf_citation": {"type": "string"},
        "quantum_vqe_metal_motivation_citation": {"type": "string"}
      }
    },
    "cross_claim": {
      "type": "string",
      "description": "one-sentence statement of the cross demonstrated"
    },
    "cases": {
      "type": "array",
      "description": "per-metal-d-manifold exact (2e,2o) CI cross rows",
      "minItems": 1,
      "items": {"$ref": "#/definitions/crossCase"}
    },
    "degeneracy_limit_check": {
      "type": "object",
      "description": "exact degeneracy limit: gap -> 0 => E_corr -> -|K|, HF weight -> 1/2",
      "required": ["coupling_k", "e_corr_at_degeneracy", "expected_e_corr",
                   "e_corr_deviation", "hf_weight_at_degeneracy",
                   "expected_hf_weight", "hf_weight_deviation", "pass"],
      "properties": {
        "coupling_k": {"type": "number"},
        "e_corr_at_degeneracy": {"type": "number", "maximum": 0},
        "expected_e_corr": {"type": "number", "maximum": 0},
        "e_corr_deviation": {"type": "number", "minimum": 0},
        "hf_weight_at_degeneracy": {"type": "number", "minimum": 0, "maximum": 1},
        "expected_hf_weight": {"type": "number", "const": 0.5},
        "hf_weight_deviation": {"type": "number", "minimum": 0},
        "pass": {"type": "boolean"}
      }
    },
    "coupling_zero_control": {
      "type": "object",
      "description": "K=0 control — HF is exact, E_corr must be exactly 0",
      "required": ["orbital_gap_delta_oct", "coupling_k", "e_corr",
                   "e_corr_is_exactly_zero", "interpretation"],
      "properties": {
        "orbital_gap_delta_oct": {"type": "number", "minimum": 0},
        "coupling_k": {"type": "number", "const": 0.0},
        "e_corr": {"type": "number"},
        "e_corr_is_exactly_zero": {"type": "boolean"},
        "interpretation": {"type": "string"}
      }
    },
    "vqe_dispatch": {
      "type": "object",
      "description": "QUANTUM-axis VQE dispatch status — MUST be an honest DEFER (g7 skip-is-honest); the live qmirror/VQE run is NOT executed in this module",
      "required": ["status", "tier", "reason", "handoff_object"],
      "properties": {
        "status": {"type": "string", "const": "DEFERRED"},
        "tier": {"type": "string", "pattern": "DEFERRED"},
        "reason": {"type": "string"},
        "handoff_object": {"type": "string"}
      }
    },
    "falsifiers": {
      "type": "object",
      "description": "F-CROSS-1..5 boolean HOLD flags",
      "additionalProperties": {"type": "boolean"}
    },
    "acceptance_criteria": {
      "type": "object",
      "description": "C1..C8 pass/fail booleans",
      "additionalProperties": {"type": "boolean"}
    },
    "pass_count": {"type": "integer", "minimum": 0},
    "total_criteria": {"type": "integer", "minimum": 1},
    "verdict": {"type": "string", "enum": ["PASS", "FAIL"]},
    "lattice_stance": {
      "type": "string",
      "description": "honest n=6 stance — must affirm no lattice derivation; (2e,2o) is the minimal double-excitation space, metal modality by own precedent (g2/g3/f1/f_lattice_fit)"
    },
    "in_silico_scope": {
      "type": "string",
      "description": "g8/f2 in-silico-only scope caveat — must also state VQE was NOT run (honest DEFER)"
    }
  },
  "definitions": {
    "crossCase": {
      "type": "object",
      "required": ["label", "metal_context", "ligand_field_source",
                   "orbital_gap_delta_oct", "coupling_k", "e_hf", "e_fci",
                   "e_corr", "hf_weight_in_fci", "double_weight_in_fci",
                   "is_multireference", "expected_strongly_multireference",
                   "checks", "vqe_handoff"],
      "properties": {
        "label": {"type": "string"},
        "metal_context": {
          "type": "string",
          "description": "transition-metal d-orbital manifold context (own precedent — no lattice fit)"
        },
        "ligand_field_source": {
          "type": "string",
          "description": "provenance of the orbital gap — must trace to the METALLODRUG axis ligand-field model"
        },
        "orbital_gap_delta_oct": {
          "type": "number", "minimum": 0,
          "description": "one-electron d-orbital gap in units of Delta_oct"
        },
        "coupling_k": {
          "type": "number",
          "description": "model determinant-mixing coupling K (units of Delta_oct)"
        },
        "e_hf": {
          "type": "number",
          "description": "Hartree-Fock reference energy (closed-shell |Phi_0>); anchored to 0"
        },
        "e_fci": {
          "type": "number",
          "description": "exact CI ground-state energy (lower 2x2 eigenvalue)"
        },
        "e_corr": {
          "type": "number", "maximum": 0,
          "description": "correlation energy E_FCI - E_HF; <= 0, and < 0 iff K != 0"
        },
        "hf_weight_in_fci": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "|<Phi_0|Psi_FCI>|^2 — HF-determinant weight in exact state"
        },
        "double_weight_in_fci": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "|<Phi_1|Psi_FCI>|^2 — double-excitation weight"
        },
        "is_multireference": {
          "type": "boolean",
          "description": "true when HF weight < 0.95 — a single determinant is insufficient"
        },
        "expected_strongly_multireference": {"type": "boolean"},
        "checks": {
          "type": "object",
          "required": ["ci_matches_closed_form", "ci_weights_sum_to_one",
                       "e_corr_strictly_negative", "mr_flag_matches_expectation"],
          "properties": {
            "ci_matches_closed_form": {"type": "boolean"},
            "ci_weights_sum_to_one": {"type": "boolean"},
            "e_corr_strictly_negative": {"type": "boolean"},
            "mr_flag_matches_expectation": {"type": "boolean"}
          }
        },
        "vqe_handoff": {"$ref": "#/definitions/vqeHandoff"}
      }
    },
    "vqeHandoff": {
      "type": "object",
      "description": "descriptor of the QUANTUM-axis VQE hand-off — DESCRIBED, not executed",
      "required": ["case", "active_space", "ci_hamiltonian_2csf",
                   "classical_reference_for_vqe", "quantum_axis_pipeline",
                   "dispatch_status", "dispatch_tier", "defer_reason",
                   "not_claimed"],
      "properties": {
        "case": {"type": "string"},
        "active_space": {"type": "string"},
        "ci_hamiltonian_2csf": {
          "type": "object",
          "required": ["E_a_phi0_hf", "E_b_phi1_double", "K_coupling"],
          "properties": {
            "E_a_phi0_hf": {"type": "number"},
            "E_b_phi1_double": {"type": "number"},
            "K_coupling": {"type": "number"}
          }
        },
        "classical_reference_for_vqe": {
          "type": "object",
          "required": ["e_casci_fci_analytic", "e_hf"],
          "properties": {
            "e_casci_fci_analytic": {"type": "number"},
            "e_hf": {"type": "number"}
          }
        },
        "quantum_axis_pipeline": {
          "type": "array", "items": {"type": "string"}
        },
        "dispatch_status": {"type": "string", "const": "DEFERRED"},
        "dispatch_tier": {"type": "string", "pattern": "DEFERRED"},
        "defer_reason": {"type": "string"},
        "not_claimed": {"type": "string"}
      }
    }
  },
  "additionalProperties": true
}
