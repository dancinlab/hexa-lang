// stdlib/bio/immuno/mhc_pan_test.hexa — measured-oracle gate for the
// NetMHCpan-style simplified linear binder predictor.
//
// 6 oracle cases (classification 정확도 100% 게이트):
//
//   1. NLVPMVATV   (CMV pp65 495-503)         HLA-A*02:01  → strong  (IC50 < 50  nM)
//   2. GILGFVFTL   (Influenza M1 58-66)       HLA-A*02:01  → strong  (IC50 < 50  nM)
//   3. LLDFVRFMGV  (HIV pol-derived 10-mer)   HLA-A*02:01  → weak    (50 ≤ IC50 < 500)
//   4. RAQRELQLE   (random no-anchor 9-mer)   HLA-A*02:01  → non     (IC50 ≥ 500)
//   5. Reproducibility — 같은 peptide+allele → bit-identical score · IC50.
//   6. Anchor sensitivity — NLVPMVATV → NIVPMVATV (P2 L→I) → IC50 ≥ 5×.
//
// Source peptide attributions (immunology literature):
//   · NLVPMVATV — Wills MR et al., J Virol 70(11):7569 (1996). HCMV-immunodominant.
//   · GILGFVFTL — Morrison J et al., J Exp Med 175:903 (1992). Influenza M1.
//   · LLDFVRFMGV — Tsomides TJ et al., J Exp Med 180:1283 (1994). HIV-1 reverse
//                  transcriptase 10-mer, well-characterised weak/intermediate
//                  HLA-A*02:01 binder.
//   · RAQRELQLE — synthetic no-anchor control (no L/M/I/V/A at P2, no V/L/I/A/M
//                  at PΩ). Guaranteed sub-threshold by anchor profile construction.

use "stdlib/bio/immuno/mhc_pan"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq_s(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_class(label: string, want: string, got: string) {
    if want != got { _fail(label + " class", want, got) }
}

fn _expect_ic50_lt(label: string, got: float, hi: float) {
    if got >= hi {
        println("FAIL: " + label + " IC50 < " + to_string(hi))
        println("  got : " + to_string(got))
        exit(1)
    }
}

fn _expect_ic50_ge(label: string, got: float, lo: float) {
    if got < lo {
        println("FAIL: " + label + " IC50 ≥ " + to_string(lo))
        println("  got : " + to_string(got))
        exit(1)
    }
}

fn _expect_ic50_in(label: string, got: float, lo: float, hi: float) {
    if got < lo || got >= hi {
        println("FAIL: " + label + " IC50 ∈ [" + to_string(lo) + ", " + to_string(hi) + ")")
        println("  got : " + to_string(got))
        exit(1)
    }
}

fn _expect_score_eq(label: string, want: float, got: float) {
    // Strict bit-equal — deterministic predictor.
    if want != got {
        println("FAIL: " + label + " (reproducibility)")
        println("  want: " + to_string(want))
        println("  got : " + to_string(got))
        exit(1)
    }
}

fn main() {
    let a0201 = "HLA-A*02:01"
    let b0702 = "HLA-B*07:02"
    let a0101 = "HLA-A*01:01"

    // ── Case 1: NLVPMVATV / HLA-A*02:01 — CMV pp65 immunodominant strong ──
    let b1 = mhc_pan_predict("NLVPMVATV", a0201)
    println("  Case 1 NLVPMVATV @ A*02:01:")
    println("    score        = " + to_string(b1.score))
    println("    ic50_nm      = " + to_string(b1.ic50_nm))
    println("    binder_class = " + b1.binder_class)
    _expect_eq_s("Case 1 allele",   a0201,        b1.allele)
    _expect_eq_s("Case 1 peptide",  "NLVPMVATV",  b1.peptide)
    _expect_ic50_lt("Case 1 NLVPMVATV", b1.ic50_nm, 100.0)
    _expect_class("Case 1 NLVPMVATV", "strong", b1.binder_class)

    // ── Case 2: GILGFVFTL / HLA-A*02:01 — Influenza M1 strong ─────────────
    let b2 = mhc_pan_predict("GILGFVFTL", a0201)
    println("  Case 2 GILGFVFTL @ A*02:01:")
    println("    score        = " + to_string(b2.score))
    println("    ic50_nm      = " + to_string(b2.ic50_nm))
    println("    binder_class = " + b2.binder_class)
    _expect_ic50_lt("Case 2 GILGFVFTL", b2.ic50_nm, 50.0)
    _expect_class("Case 2 GILGFVFTL", "strong", b2.binder_class)

    // ── Case 3: LLDFVRFMGV / HLA-A*02:01 — 10-mer HIV pol weak ────────────
    let b3 = mhc_pan_predict("LLDFVRFMGV", a0201)
    println("  Case 3 LLDFVRFMGV @ A*02:01:")
    println("    score        = " + to_string(b3.score))
    println("    ic50_nm      = " + to_string(b3.ic50_nm))
    println("    binder_class = " + b3.binder_class)
    _expect_class("Case 3 LLDFVRFMGV", "weak", b3.binder_class)
    _expect_ic50_ge("Case 3 LLDFVRFMGV", b3.ic50_nm, 50.0)
    _expect_ic50_lt("Case 3 LLDFVRFMGV", b3.ic50_nm, 500.0)

    // ── Case 4: RAQRELQLE / HLA-A*02:01 — no-anchor synthetic non-binder ──
    let b4 = mhc_pan_predict("RAQRELQLE", a0201)
    println("  Case 4 RAQRELQLE @ A*02:01:")
    println("    score        = " + to_string(b4.score))
    println("    ic50_nm      = " + to_string(b4.ic50_nm))
    println("    binder_class = " + b4.binder_class)
    _expect_ic50_ge("Case 4 RAQRELQLE", b4.ic50_nm, 500.0)
    _expect_class("Case 4 RAQRELQLE", "non", b4.binder_class)

    // ── Case 5: reproducibility — bit-identical on second call ────────────
    let b5a = mhc_pan_predict("NLVPMVATV", a0201)
    let b5b = mhc_pan_predict("NLVPMVATV", a0201)
    _expect_score_eq("Case 5 score reproducibility",  b5a.score,   b5b.score)
    _expect_score_eq("Case 5 ic50 reproducibility",   b5a.ic50_nm, b5b.ic50_nm)
    _expect_eq_s    ("Case 5 class reproducibility",  b5a.binder_class, b5b.binder_class)

    // Same peptide, free-function entry points (mhc_pan_score / _ic50) →
    // identical to MhcBinding fields.
    let s_via_fn = mhc_pan_score("NLVPMVATV", a0201)
    let ic_via_fn = mhc_pan_ic50("NLVPMVATV", a0201)
    _expect_score_eq("Case 5 score == mhc_pan_score", b5a.score, s_via_fn)
    _expect_score_eq("Case 5 ic50  == mhc_pan_ic50",  b5a.ic50_nm, ic_via_fn)

    // ── Case 6: anchor sensitivity — P2 L→I → IC50 ≥ 5× ───────────────────
    let b6_orig = mhc_pan_predict("NLVPMVATV", a0201)
    let b6_mut  = mhc_pan_predict("NIVPMVATV", a0201)
    println("  Case 6 anchor mutation (P2 L→I):")
    println("    NLVPMVATV ic50 = " + to_string(b6_orig.ic50_nm))
    println("    NIVPMVATV ic50 = " + to_string(b6_mut.ic50_nm))
    let ratio = b6_mut.ic50_nm / b6_orig.ic50_nm
    println("    ratio          = " + to_string(ratio))
    if ratio < 5.0 {
        println("FAIL: Case 6 anchor sensitivity ratio ≥ 5.0")
        println("  got: " + to_string(ratio))
        exit(1)
    }

    // ── Multi-allele coverage: lookups for the 3 supported alleles ────────
    // (parent task spec — at minimum these 3.)
    let al_a2 = allele_lookup(a0201)
    let al_b7 = allele_lookup(b0702)
    let al_a1 = allele_lookup(a0101)
    _expect_eq_s("allele A*02:01 lookup", a0201, al_a2.name)
    _expect_eq_s("allele B*07:02 lookup", b0702, al_b7.name)
    _expect_eq_s("allele A*01:01 lookup", a0101, al_a1.name)

    // Unsupported allele → empty AllelePan (name "") sentinel.
    let al_unk = allele_lookup("HLA-X*99:99")
    _expect_eq_s("unknown allele → sentinel", "", al_unk.name)

    // Unsupported allele in predict → non-binder fallback.
    let b_unk = mhc_pan_predict("NLVPMVATV", "HLA-X*99:99")
    _expect_class("unknown allele predict → non", "non", b_unk.binder_class)

    // Cross-allele consistency: HLA-B*07:02 prefers P at P2 — a P2=P peptide
    // (APRTLVLLL ↔ a HLA-B*07-style proline-anchored ligand from Sidney
    // 2008 supertype paper) should classify as binder under B*07:02.
    let b_b7 = mhc_pan_predict("APRTLVLLL", b0702)
    println("  B*07:02 APRTLVLLL: ic50 = " + to_string(b_b7.ic50_nm) + " class = " + b_b7.binder_class)
    if b_b7.binder_class == "non" {
        _fail("B*07:02 P2=P peptide must bind", "strong|weak", b_b7.binder_class)
    }
    // is_binder helper agrees.
    if mhc_pan_is_binder("APRTLVLLL", b0702) == false {
        _fail("mhc_pan_is_binder B*07:02 APRTLVLLL", "true", "false")
    }

    println("PASS: mhc_pan 6 oracle cases (NetMHCpan-style binder predictor · "
          + "strong/weak/non classification 100% · NetMHCpan ANN deferred)")
}
