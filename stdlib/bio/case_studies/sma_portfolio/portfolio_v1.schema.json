{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/dancinlab/hexa-bio/case_studies/sma_portfolio/portfolio_v1.schema.json",
  "title": "SMA portfolio case-study witness (v1)",
  "description": "In-silico simulator-consistency witness for the spinal muscular atrophy (SMA) portfolio case study. Aggregates the two in-axis drug modalities for SMA (risdiplam :> RNA-TARGETING-SMALL-MOLECULE; nusinersen :> OLIGONUCLEOTIDE) AND records the honestly-UNPLACED third FDA-approved SMA drug (onasemnogene abeparvovec / Zolgensma — a CBER-regulated AAV9 gene therapy that falls outside the hexa-bio criterion #4 drug-only/CDER scope boundary). The schema deliberately separates `in_scope_drugs` from `not_in_scope_drugs`: an honest portfolio acknowledges what it does NOT model. This is NEVER a therapeutic, clinical, efficacy, immunogenic, regulatory, or portfolio-recommendation claim (g8 / f2).",
  "type": "object",
  "required": [
    "schema_version",
    "case_study_id",
    "disease",
    "shared_gene_target",
    "in_scope_drugs",
    "not_in_scope_drugs",
    "cross_axis_touch_point",
    "honesty",
    "sentinel"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sma_portfolio_v1"
    },
    "case_study_id": {
      "type": "string",
      "const": "sma_portfolio.v1"
    },
    "disease": {
      "type": "object",
      "required": ["name", "abbreviation", "shared_gene", "shared_splicing_event"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "abbreviation": {"type": "string", "const": "SMA"},
        "shared_gene": {"type": "string"},
        "shared_splicing_event": {"type": "string"}
      }
    },
    "shared_gene_target": {"type": "string"},
    "in_scope_drugs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "description": "FDA-approved SMA drugs whose modality maps onto an in-repo axis. Each entry runs a deterministic axis sim with its own real-limit anchor.",
      "items": {
        "type": "object",
        "required": [
          "drug_name",
          "brand",
          "sponsor",
          "fda_year",
          "fda_center",
          "modality",
          "axis",
          "axis_layer",
          "axis_module",
          "in_scope",
          "real_limit_anchor",
          "real_limit_citations",
          "drug_precedent_citations",
          "model_signal_name",
          "model_signal_value",
          "model_signal_units",
          "in_silico_only"
        ],
        "additionalProperties": false,
        "properties": {
          "drug_name": {"type": "string"},
          "brand": {"type": "string"},
          "sponsor": {"type": "string"},
          "fda_year": {"type": "integer", "minimum": 1900, "maximum": 2100},
          "fda_center": {"type": "string", "const": "CDER"},
          "modality": {"type": "string"},
          "axis": {"type": "string"},
          "axis_layer": {
            "type": "string",
            "enum": ["expansion-main", "expansion-sub"]
          },
          "axis_module": {"type": "string"},
          "in_scope": {"type": "boolean", "const": true},
          "real_limit_anchor": {"type": "string"},
          "real_limit_citations": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "drug_precedent_citations": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "model_signal_name": {"type": "string"},
          "model_signal_value": {"type": "number"},
          "model_signal_units": {"type": "string"},
          "model_signal_detail": {"type": "object"},
          "in_silico_only": {"type": "boolean", "const": true}
        }
      }
    },
    "not_in_scope_drugs": {
      "type": "array",
      "minItems": 1,
      "description": "FDA-approved SMA drugs that are HONESTLY UNPLACED — modality falls outside the hexa-bio drug-only/CDER criterion #4 scope boundary; no code axis. This block is a feature, not a gap: a portfolio that acknowledges what it does NOT cover is more honest than one that pretends to.",
      "items": {
        "type": "object",
        "required": [
          "drug_name",
          "brand",
          "sponsor",
          "fda_year",
          "fda_center",
          "modality",
          "axis",
          "in_scope",
          "reason",
          "unplaced_precedent_in_repo",
          "drug_precedent_citations",
          "reported_not_run"
        ],
        "additionalProperties": false,
        "properties": {
          "drug_name": {"type": "string"},
          "brand": {"type": "string"},
          "sponsor": {"type": "string"},
          "fda_year": {"type": "integer", "minimum": 1900, "maximum": 2100},
          "fda_center": {
            "type": "string",
            "description": "FDA center of regulatory jurisdiction; CBER for biologics including gene/cell therapy.",
            "enum": ["CBER", "CDRH"]
          },
          "modality": {"type": "string"},
          "axis": {
            "description": "Null — UNPLACED by design (no code axis for this modality).",
            "type": "null"
          },
          "in_scope": {"type": "boolean", "const": false},
          "reason": {"type": "string"},
          "unplaced_precedent_in_repo": {
            "type": "string",
            "description": "Pointer to the in-repo precedent for honest UNPLACED handling (e.g. AXIS/HIERARCHY.tape @N genetic_medicine_status)."
          },
          "drug_precedent_citations": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "reported_not_run": {
            "type": "boolean",
            "const": true,
            "description": "Reported in the witness for honest portfolio coverage; NOT modeled (no axis sim run)."
          }
        }
      }
    },
    "cross_axis_touch_point": {
      "type": "object",
      "description": "Pointer to the existing in-repo SMN2 cross-axis comparison (Project A3) — this case study EXTENDS that single-disease pilot into a fuller portfolio writeup; it does NOT duplicate it.",
      "required": ["bridge_id", "module", "schema_version", "honesty_note"],
      "additionalProperties": false,
      "properties": {
        "bridge_id": {"type": "string", "const": "A3"},
        "module": {
          "type": "string",
          "const": "_python_bridge/module/rna_modality_comparison_smn2_cross.py"
        },
        "schema_version": {
          "type": "string",
          "const": "rna_modality_comparison_smn2_cross_v1"
        },
        "honesty_note": {"type": "string"}
      }
    },
    "honesty": {
      "type": "object",
      "required": [
        "in_silico_only",
        "not_a_portfolio_recommendation",
        "not_an_efficacy_ranking",
        "not_a_superiority_claim",
        "not_a_clinical_claim",
        "all_three_drugs_fda_approved",
        "unplaced_handling_is_honest",
        "no_lattice_derivation",
        "scope_is_one_disease_pilot",
        "statement"
      ],
      "additionalProperties": false,
      "properties": {
        "in_silico_only": {"type": "boolean", "const": true},
        "not_a_portfolio_recommendation": {"type": "boolean", "const": true},
        "not_an_efficacy_ranking": {"type": "boolean", "const": true},
        "not_a_superiority_claim": {"type": "boolean", "const": true},
        "not_a_clinical_claim": {"type": "boolean", "const": true},
        "all_three_drugs_fda_approved": {"type": "boolean", "const": true},
        "unplaced_handling_is_honest": {"type": "boolean", "const": true},
        "no_lattice_derivation": {"type": "boolean", "const": true},
        "scope_is_one_disease_pilot": {"type": "boolean", "const": true},
        "statement": {"type": "string"}
      }
    },
    "sentinel": {
      "type": "string",
      "const": "__SMA_PORTFOLIO__ PASS"
    }
  }
}
