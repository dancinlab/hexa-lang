// HEXA Standard Library — bio/topical_pk
//
// @version 0.1.0
// @capabilities [pure]
//
// 국소 / 경피 약동학 (topical · transdermal pharmacokinetics) closed-form
// primitives. demiurge TTR-ORAL V2 atlas-register handoff (INBOX T22:35Z)
// 의 6-fn 1차 batch. 모두 libm-class (sqrt/log/log10 only), 🟢 Tier2
// 검증 게이트(ε=1e-9) 적합. 거버넌스: g61 (stdlib SSOT in hexa-lang —
// primitives only), stdlib_trig_libm (libm builtins, no hand-rolled).
//
// 검증: `hexa verify --expr <fn> <args> <expected>` 11/11 🟢 SUPPORTED-NUMERICAL
//   (verify-arm = tool/verify_cli.hexa, register-arm = tool/atlas_cli.hexa)
//
// Surface (6 fn):
//   pub fn higuchi_flux(c0, dm, t) -> float       // sqrt(2·C0·Dm·t/π)
//   pub fn fick_steady_flux(p, dc) -> float       // P·ΔC
//   pub fn partition_coeff(c_oct, c_water) -> float  // log10(C_oct/C_water)
//   pub fn permeability_skin(d, k, h) -> float    // D·K/h
//   pub fn auc_first_order(c0, ke) -> float       // C0/ke
//   pub fn clearance(dose, auc) -> float          // Dose/AUC
//
// Naming: 기존 stdlib `higuchi` (2-arg simple form k_H·sqrt(t)) 과 충돌
// 회피 위해 `higuchi_flux` (3-arg planar diffusion flux) 로 명명. 기존
// `fick1` (3-arg gradient form -D·dC/dx) 도 별개 — `fick_steady_flux` 는
// permeability-based steady-state membrane form.

let _PK_PI: float = 3.14159265358979323846

// Higuchi 평면 확산 flux (1961): J(t) = sqrt(2 · C0 · Dm · t / π)
// semi-infinite source matrix → 평면 슬랩 통과 instantaneous flux.
// Source: Higuchi 1961 J Pharm Sci 50:874-875 (planar form).
pub fn higuchi_flux(c0: float, dm: float, t_time: float) -> float {
    return sqrt(2.0 * c0 * dm * t_time / _PK_PI)
}

// Fick steady-state flux: J = P · ΔC
// membrane permeability P + donor-receiver 농도차 ΔC. transdermal-delivery
// canonical primitive. Source: Fick 1855 Ann Phys 170:59-86.
pub fn fick_steady_flux(p_perm: float, d_c: float) -> float {
    return p_perm * d_c
}

// Octanol-water 분배계수 logP: log10(C_oct / C_water)
// drug-design 핵심 lipophilicity 지표 (Lipinski Rule-of-5 입력).
// Source: Hansch & Fujita 1964 JACS 86:1616.
pub fn partition_coeff(c_oct: float, c_water: float) -> float {
    let ln10 = log(10.0)
    return log(c_oct / c_water) / ln10
}

// Skin permeability: P = D · K / h
// stratum corneum 확산계수 D · partition K · 장벽두께 h.
// Source: Scheuplein & Blank 1971 Physiol Rev 51:702 (Potts-Guy model input).
pub fn permeability_skin(d_diff: float, k_part: float, h_thick: float) -> float {
    return d_diff * k_part / h_thick
}

// AUC under first-order elimination: AUC = C0 / ke
// IV-bolus single-compartment, mono-exponential elimination 의 area-under-curve.
// Source: Gibaldi & Perrier 1982 (Pharmacokinetics 2nd ed).
pub fn auc_first_order(c0: float, k_e: float) -> float {
    return c0 / k_e
}

// Total plasma clearance: CL = Dose / AUC
// 투여량 - AUC 의 textbook PK 정의식. Source: Rowland & Tozer 1995
// (Clinical Pharmacokinetics 3rd ed §6).
pub fn clearance(dose: float, auc: float) -> float {
    return dose / auc
}
