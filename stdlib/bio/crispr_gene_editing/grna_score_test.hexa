// stdlib/bio/crispr_gene_editing/grna_score_test.hexa — measured oracle for
// the Doench-2014 / Rule-Set-1 closed-form sgRNA activity score.
//
// Oracle strategy (algorithmic, no network, no fixture):
//   Hard-coded 30-mer → expected-score pairs. Values were calibrated by
//   running the closed-form Doench-2014 logistic model on five canonical
//   sgRNA 30-mer contexts spanning the activity regime — GC-balanced,
//   GC-rich (deep penalty), AT-rich (mild penalty), and high-activity
//   panel-representative sequences. The expected scores are the model's
//   own output at the published Sup. Table S5 weights; the test asserts
//   |computed - expected| ≤ 0.05 so the gate also tolerates the small
//   gap between Rule Set 1 (closed-form) and the Doench-2016 Rule Set 2
//   gradient-boosted score commonly cited downstream.
//
// Per @D measured-oracle (commons g3): the expected numbers are NOT
// invented — they are the deterministic output of the published Doench
// 2014 Sup. Table S5 weights on the input 30-mers, calibrated once and
// pinned here so any future weight typo trips the gate.

use "stdlib/bio/crispr_gene_editing/grna_score"

let TOL: float = 0.05

let mut pass_count: int = 0
let mut total_count: int = 0
let mut first_fail: string = ""

fn _abs_f(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

fn _fmt(x: float) -> string { return to_string(x) }

fn check_score(label: string, seq30: string, expected: float) {
    total_count = total_count + 1
    let got = doench_2016_score(seq30)
    let dev = _abs_f(got - expected)
    if dev <= TOL {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" {
            first_fail = label + ": want " + _fmt(expected)
                       + " got " + _fmt(got)
                       + " (|dev|=" + _fmt(dev) + " > " + _fmt(TOL) + ")"
        }
    }
}

fn check_bool(label: string, cond: bool) {
    total_count = total_count + 1
    if cond { pass_count = pass_count + 1 }
    else if first_fail == "" { first_fail = label }
}

fn main() {
    // ── oracle 1: GC-balanced (gc=13, mild penalty) ─────────────────
    // EMX1-style 30-mer; pos20=G PAM-adjacent → expected ≈ 0.26.
    check_score("balanced-gc13",
        "GCTGAAGGCATGAGCGGAGAGGGGAACGTG", 0.2643)

    // ── oracle 2: high-activity panel representative (gc=14) ────────
    check_score("activity-panel-1",
        "ACAGCTGAGAGGCAGCGAACTCATGGAGGT", 0.6435)

    // ── oracle 3: GC-rich (gc=18, deep penalty) ─────────────────────
    // Heavy GC penalty + pos23=G negative → expected near 0.07.
    check_score("gc-rich-penalty",
        "TCGGCGGCGCGCGGCGGCGCGAGGCGCGGG", 0.0720)

    // ── oracle 4: AT-rich (gc=7, mild gc-low penalty) ───────────────
    check_score("at-rich",
        "ATGAAGATCTATCAGAAAGAAGAAGCAGGA", 0.5268)

    // ── oracle 5: high-activity (gc=15, pos3=G+pos4=A favourable) ──
    check_score("high-activity",
        "TTGGAACCCAGGAGACGCCAAGCTGGGAGG", 0.8598)

    // ── range sanity: every score ∈ [0, 1] ──────────────────────────
    let probes = [
        "GCTGAAGGCATGAGCGGAGAGGGGAACGTG",
        "ACAGCTGAGAGGCAGCGAACTCATGGAGGT",
        "TCGGCGGCGCGCGGCGGCGCGAGGCGCGGG",
        "ATGAAGATCTATCAGAAAGAAGAAGCAGGA",
        "TTGGAACCCAGGAGACGCCAAGCTGGGAGG",
        "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
        "GGGGGGGGGGGGGGGGGGGGGGGGGGGGGG"
    ]
    let mut i = 0
    while i < len(probes) {
        let v = doench_2016_score(probes[i])
        check_bool("range[" + to_string(i) + "] in [0,1]", v >= 0.0 && v <= 1.0)
        i = i + 1
    }

    // ── monotonicity sanity: GC-rich homopolymer scores below the
    //    high-activity panel rep (sigmoid weight ordering preserved). ─
    let gc_rich = doench_2016_score("GGGGGGGGGGGGGGGGGGGGGGGGGGGGGG")
    let active  = doench_2016_score("TTGGAACCCAGGAGACGCCAAGCTGGGAGG")
    check_bool("gc-rich < high-activity", gc_rich < active)

    // ── explain surface returns ≥ 2 lines (intercept + sum/sigmoid) ─
    let lines = doench_2016_explain("GCTGAAGGCATGAGCGGAGAGGGGAACGTG")
    check_bool("explain non-empty", len(lines) >= 2)

    // ── Wallace Tm helper: GGGG...GG (gc=20) → 4·20 = 80.0 ─────────
    let tm_gc = doench_wallace_tm_spacer("GGGGGGGGGGGGGGGGGGGGGGGGGGGGGG")
    check_bool("wallace_tm GC20 == 80.0", _abs_f(tm_gc - 80.0) < 0.0001)

    // ── Wallace Tm helper: AAAA...AA (gc=0, at=20) → 2·20 = 40.0 ──
    let tm_at = doench_wallace_tm_spacer("AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA")
    check_bool("wallace_tm AT20 == 40.0", _abs_f(tm_at - 40.0) < 0.0001)

    if pass_count == total_count {
        println("PASS: doench-2014 / Rule-Set-1 sgRNA score — "
              + to_string(pass_count) + "/" + to_string(total_count)
              + " checks (5 measured oracle 30-mers, tol=±" + _fmt(TOL)
              + "; 7 range + 1 monotonicity + 1 explain + 2 wallace-Tm)")
    } else {
        println("FAIL: " + first_fail)
        println("  passed " + to_string(pass_count) + "/" + to_string(total_count))
        exit(1)
    }
}
