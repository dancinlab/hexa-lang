// stdlib/bio/crispr_gene_editing/off_target_test.hexa — measured oracle
// for the Cas-OFFinder-style off-target scan over a synthetic 2-chrom
// genome. PURE algorithmic; no network, no fixture.
//
// Five hand-counted cases on planted off-target sites:
//   case 1 — zero-mismatch on-target       (chrom1, +strand)
//   case 2 — 1 PAM-distal mismatch         (chrom2, +strand)
//   case 3 — 1 seed-region mismatch        (chrom_seed, +strand)
//   case 4 — no PAM → rejected             (chrom_nopam)
//   case 5 — reverse-strand hit            (chrom_rev, -strand)
//
// Per @D measured-oracle (commons g3): expected counts and positions
// are hand-traced through the synthetic genome, so any regression in
// the PAM matcher / RC helper / weighted-score gate trips immediately.

use "stdlib/bio/crispr_gene_editing/off_target"

let mut pass_count: int = 0
let mut total_count: int = 0
let mut first_fail: string = ""

fn _abs_f(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

fn check_bool(label: string, cond: bool) {
    total_count = total_count + 1
    if cond { pass_count = pass_count + 1 }
    else if first_fail == "" { first_fail = label }
}

fn check_int(label: string, want: int, got: int) {
    total_count = total_count + 1
    if want == got { pass_count = pass_count + 1 }
    else if first_fail == "" {
        first_fail = label + ": want " + to_string(want) + " got " + to_string(got)
    }
}

fn check_float(label: string, want: float, got: float, tol: float) {
    total_count = total_count + 1
    let dev = _abs_f(got - want)
    if dev <= tol { pass_count = pass_count + 1 }
    else if first_fail == "" {
        first_fail = label + ": want " + to_string(want) + " got " + to_string(got) + " (|dev|=" + to_string(dev) + ")"
    }
}

fn check_str(label: string, want: string, got: string) {
    total_count = total_count + 1
    if want == got { pass_count = pass_count + 1 }
    else if first_fail == "" {
        first_fail = label + ": want '" + want + "' got '" + got + "'"
    }
}

fn main() {
    // ── primitive surface checks ────────────────────────────────────
    // PAM matcher: "NGG" matches all four "?GG" forms, rejects "?GC".
    check_bool("pam NGG vs AGG", off_target_pam_match("AGG", "NGG"))
    check_bool("pam NGG vs CGG", off_target_pam_match("CGG", "NGG"))
    check_bool("pam NGG vs GGG", off_target_pam_match("GGG", "NGG"))
    check_bool("pam NGG vs TGG", off_target_pam_match("TGG", "NGG"))
    check_bool("pam NGG rejects AGC", off_target_pam_match("AGC", "NGG") == false)
    check_bool("pam NGG rejects len", off_target_pam_match("AGGA", "NGG") == false)

    // Hamming: identity=0, one substitution=1, len-mismatch=-1.
    check_int("hamming identity", 0, off_target_count_mismatches("AAAA", "AAAA"))
    check_int("hamming one diff", 1, off_target_count_mismatches("AACA", "AAAA"))
    check_int("hamming all diff", 4, off_target_count_mismatches("AAAA", "TTTT"))
    check_int("hamming len-mm",  -1, off_target_count_mismatches("AAA", "AAAA"))

    // ── synthetic genome — hand-counted off-target oracle ──────────
    // 20-nt spacer; PAM-distal = pos 0-8, seed = pos 9-19.
    let spacer = "GAGTCCGAGCAGAAGAAGAA"

    // ── case 1 — exact on-target, +strand, chrom1 (60 nt) ───────────
    //   layout: 10-nt prefix + spacer + "AGG" + 27-nt suffix.
    //   Expect 1 hit at position=10, mismatches=0, strand=+.
    let chrom1 =
        "ACGTACGTAC" +
        "GAGTCCGAGCAGAAGAAGAA" +
        "AGG" +
        "CACACACACACACACACACACACACAC"
    check_int("chrom1 length", 60, len(chrom1))

    let g1: [string] = [chrom1]
    let hits1 = off_target_scan(spacer, g1, "NGG", 0)
    check_int("case1 zero-mm hit count", 1, len(hits1))
    if len(hits1) >= 1 {
        let h = hits1[0]
        check_int("case1 mismatches", 0, h.mismatches)
        check_int("case1 position", 10, h.position)
        check_str("case1 strand", "+", h.strand)
        check_bool("case1 pam_match", h.pam_match)
        check_str("case1 chrom", "chr0", h.chrom)
        check_float("case1 score perfect", 1.0, h.score, 0.0001)
    }

    // ── case 2 — 1 PAM-distal mismatch at spacer pos 4 ──────────────
    //   chrom2 spacer = GAGTACGAGCAGAAGAAGAA  (C→A at idx 4, < 9).
    //   max_mm=0 → 0 hits; max_mm=1 → 1 hit, score = 1 - 1/28.
    let chrom2 =
        "ACGTACGTAC" +
        "GAGTACGAGCAGAAGAAGAA" +
        "AGG" +
        "CACACACACACACACACACACACACAC"
    check_int("chrom2 length", 60, len(chrom2))

    let g2: [string] = [chrom2]
    let hits2_strict = off_target_scan(spacer, g2, "NGG", 0)
    check_int("case2 strict rejects", 0, len(hits2_strict))
    let hits2 = off_target_scan(spacer, g2, "NGG", 1)
    check_int("case2 tolerated hit count", 1, len(hits2))
    if len(hits2) >= 1 {
        let h = hits2[0]
        check_int("case2 mismatches", 1, h.mismatches)
        check_int("case2 position", 10, h.position)
        check_str("case2 strand", "+", h.strand)
        // PAM-distal (pos 4 < 9) → weight 1 → score = 1 - 1/28.
        let want_distal = 1.0 - 1.0 / 28.0
        check_float("case2 score pam-distal weight=1",
                    want_distal, h.score, 0.0001)
    }

    // ── case 3 — 1 seed-region mismatch at spacer position 15 ──────
    //   chrom_seed spacer copy = GAGTCCGAGCAGAAGTAGAA  (A→T at idx 15).
    //   Seed weight is doubled → score = 1 - 2/28.
    let chrom_seed =
        "ACGTACGTAC" +
        "GAGTCCGAGCAGAAGTAGAA" +
        "AGG" +
        "CACACACACACACACACACACACACAC"
    check_int("chrom_seed length", 60, len(chrom_seed))

    let g3: [string] = [chrom_seed]
    let hits3 = off_target_scan(spacer, g3, "NGG", 1)
    check_int("case3 seed-mm hit count", 1, len(hits3))
    if len(hits3) >= 1 {
        let h = hits3[0]
        check_int("case3 mismatches", 1, h.mismatches)
        // Seed weight 2 → score = 1 - 2/28 ≈ 0.9286.
        let want_seed = 1.0 - 2.0 / 28.0
        check_float("case3 score seed weight=2",
                    want_seed, h.score, 0.0001)
        // Seed-region mismatch (weighted higher) should score strictly
        // lower than the PAM-distal mismatch in case 2.
        if len(hits2) >= 1 {
            check_bool("case3 seed-mm < case2 distal-mm",
                       h.score < hits2[0].score)
        }
    }

    // ── case 4 — exact spacer but bad PAM (CTT) → rejected ──────────
    let chrom_nopam =
        "ACGTACGTAC" +
        "GAGTCCGAGCAGAAGAAGAA" +
        "CTT" +
        "CACACACACACACACACACACACACAC"
    check_int("chrom_nopam length", 60, len(chrom_nopam))

    let g4: [string] = [chrom_nopam]
    let hits4 = off_target_scan(spacer, g4, "NGG", 3)
    check_int("case4 no-PAM rejects", 0, len(hits4))

    // ── case 5 — reverse-strand hit ─────────────────────────────────
    //   chrom_rev forward strand holds RC(spacer+"AGG"):
    //     spacer+pam = "GAGTCCGAGCAGAAGAAGAAAGG"
    //     RC         = "CCTTTCTTCTTCTGCTCGGACTC"   (23 nt)
    //   Planted at fwd pos 10. The scanner takes RC of this chrom,
    //   spacer+AGG re-emerges on the - strand, and the reporter maps
    //   the local hit index back to forward-strand position 10.
    let chrom_rev =
        "ACGTACGTAC" +
        "CCTTTCTTCTTCTGCTCGGACTC" +     // pos 10-32 (rc of spacer+AGG)
        "CACACACACACACACACACACACAC"     // pos 33-57 (25 nt suffix)
    // length = 10 + 23 + 25 = 58. Non-round on purpose so the strand-
    // mapping math does not accidentally depend on a particular size.
    check_int("chrom_rev length", 58, len(chrom_rev))

    let g5: [string] = [chrom_rev]
    let hits5 = off_target_scan(spacer, g5, "NGG", 0)
    check_int("case5 reverse-strand hit count", 1, len(hits5))
    if len(hits5) >= 1 {
        let h = hits5[0]
        check_int("case5 mismatches", 0, h.mismatches)
        check_str("case5 strand", "-", h.strand)
        check_bool("case5 pam_match", h.pam_match)
        // Forward-strand mapping: 58 - i - 23 = 10 ⇒ i = 25.
        check_int("case5 forward-mapped position", 10, h.position)
        check_float("case5 score perfect", 1.0, h.score, 0.0001)
    }

    // ── multi-chrom scan via off_target_scan_named ──────────────────
    //   Packed `[[name, seq], ...]` rows; expected 2 hits in input
    //   order (geneA mm=0, geneB mm=1).
    let rowA: [string] = ["geneA", chrom1]
    let rowB: [string] = ["geneB", chrom2]
    let chroms_multi: [[string]] = [rowA, rowB]
    let hits_multi = off_target_scan_named(spacer, chroms_multi,
                                            "NGG", 1)
    check_int("multi-chrom hit count", 2, len(hits_multi))
    if len(hits_multi) >= 2 {
        // hits_multi[0] should be the chrom1 (zero-mm) hit, since
        // the scanner walks chromosomes in input order.
        check_str("multi hits[0].chrom",  "geneA", hits_multi[0].chrom)
        check_int("multi hits[0].mismatches", 0, hits_multi[0].mismatches)
        check_str("multi hits[1].chrom",  "geneB", hits_multi[1].chrom)
        check_int("multi hits[1].mismatches", 1, hits_multi[1].mismatches)
    }

    if pass_count == total_count {
        println("PASS: cas-OFFinder-style off-target scan — "
              + to_string(pass_count) + "/" + to_string(total_count)
              + " checks (5 hand-counted cases on synthetic 2-chrom "
              + "genome — zero-mm, PAM-distal mm, seed-region mm, "
              + "no-PAM reject, reverse-strand hit + multi-chrom)")
    } else {
        println("FAIL: " + first_fail)
        println("  passed " + to_string(pass_count) + "/" + to_string(total_count))
        exit(1)
    }
}
