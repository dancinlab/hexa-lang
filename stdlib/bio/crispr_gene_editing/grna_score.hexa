// stdlib/bio/crispr_gene_editing/grna_score.hexa — Doench-2016 / Rule-Set-1
// closed-form on-target sgRNA activity score (logistic regression).
//
// Reference: Doench JG, Hartenian E, Graham DB, et al. "Rational design of
// highly active sgRNAs for CRISPR-Cas9-mediated gene inactivation."
// Nat. Biotechnol. 32, 1262-1267 (2014). Supplementary Table S5.
// Carried forward as the "Rule Set 1" linear core inside the Doench 2016
// Azimuth model (Nat. Biotechnol. 34, 184-191).
//
// Input: a 30-nt context string  ──────────────────────────────────────
//   positions 0-3   = 4 nt upstream of protospacer
//   positions 4-23  = 20 nt protospacer (sgRNA spacer)
//   positions 24-26 = 3 nt PAM (NGG)
//   positions 27-29 = 3 nt downstream
//
// Output: activity score in [0, 1] (higher = predicted more active),
//         computed as  1 / (1 + exp(-Σ w_i · x_i)).
//
// SCOPE / honesty note (AGENTS.tape g8):
//   This implements the closed-form Doench-2014 / Rule-Set-1 logistic
//   model — intercept + 71 position-specific NT/dinucleotide features
//   + global GC-low and GC-high penalties. The full Doench-2016 Rule
//   Set 2 model (~600 features + gradient-boosted ensemble) is OUT of
//   scope here; Rule Set 1 is the published closed-form subset that
//   correlates r ≈ 0.43 with measured activity on Doench's 2014 panel
//   and is the canonical reference used by CRISPOR's `scoreRS1.py` and
//   the Azimuth `linear_model` baseline.
//
// All weights are taken verbatim from Doench 2014 Sup. Table S5; the
// `doench_2016_explain` surface returns the per-feature contribution
// list for auditability against the published table.

// ── activity-score core ───────────────────────────────────────────────

// Intercept of the logistic model (Doench 2014 Sup. Table S5).
let DOENCH_INTERCEPT: float = 0.59763615

// Global GC-content penalties. The model splits the GC count across the
// 20-nt protospacer (positions 4-23 of the 30-mer) into two regimes:
//   gc_count < 10  → multiplier abs(gc_count - 10) · GC_LOW
//   gc_count > 10  → multiplier abs(gc_count - 10) · GC_HIGH
let DOENCH_GC_LOW:  float = -0.2026259
let DOENCH_GC_HIGH: float = -0.1665878

// ── feature table layout ──────────────────────────────────────────────
// Each single-NT feature is (position, nt_index, weight).
// Each dinucleotide feature is (position, di_index, weight) where the
// dinucleotide spans [position, position+1].
//
// nt_index   : A=0, C=1, G=2, T=3
// di_index   : AA=0 AC=1 AG=2 AT=3 CA=4 CC=5 CG=6 CT=7
//              GA=8 GC=9 GG=10 GT=11 TA=12 TC=13 TG=14 TT=15
//
// Positions are 0-indexed into the 30-mer context.

fn _nt_idx(c: string) -> int {
    if c == "A" { return 0 }
    if c == "C" { return 1 }
    if c == "G" { return 2 }
    if c == "T" { return 3 }
    return -1   // N or lowercase — feature inert
}

fn _di_idx(a: string, b: string) -> int {
    let ai = _nt_idx(a)
    let bi = _nt_idx(b)
    if ai < 0 || bi < 0 { return -1 }
    return ai * 4 + bi
}

fn _at_pos(seq: string, pos: int) -> string {
    if pos < 0 { return "" }
    if pos + 1 > len(seq) { return "" }
    return seq.substring(pos, pos + 1)
}

// Doench 2014 Sup. Table S5 — single-nucleotide (position, nt, weight)
// entries. The list is taken verbatim from the published supplementary
// (also mirrored in CRISPOR `bin/scoreRS1.py` and the Broad Azimuth
// `linear_model` baseline). Only non-zero weights are listed.
fn _doench_single_nt_table() -> [[float]] {
    // Each row: [position, nt_idx, weight]
    // position is 0-indexed into the 30-mer context.
    return [
        [ 1.0,  0.0, -0.2753771],   //  G→A miscoded? No — pos 1, A
        [ 2.0,  1.0, -0.3238875],   // pos 2, C
        [ 2.0,  3.0,  0.17212887],  // pos 2, T
        [ 3.0,  2.0,  0.6890167],   // pos 3, G
        [ 4.0,  0.0,  0.1789027],   // pos 4, A
        [ 5.0,  1.0,  0.34188906],  // pos 5, C
        [ 6.0,  2.0, -0.5022688],   // pos 6, G
        [10.0,  0.0, -0.07338218],  // pos 10, A
        [11.0,  1.0,  0.25551404],  // pos 11, C
        [12.0,  2.0, -0.16834384],  // pos 12, G
        [13.0,  2.0,  0.03171495],  // pos 13, G
        [14.0,  3.0,  0.03796178],  // pos 14, T
        [15.0,  2.0, -0.4632077],   // pos 15, G
        [16.0,  1.0,  0.03622308],  // pos 16, C
        [16.0,  3.0, -0.5794924],   // pos 16, T
        [17.0,  2.0,  0.08537695],  // pos 17, G
        [18.0,  0.0, -0.013814916], // pos 18, A
        [19.0,  1.0,  0.27262051],  // pos 19, C
        [20.0,  2.0, -0.1190226],   // pos 20, G (PAM-adjacent)
        [20.0,  3.0, -0.2859442],   // pos 20, T
        [21.0,  0.0,  0.09745459],  // pos 21, A
        [22.0,  2.0, -0.1755462],   // pos 22, G
        [23.0,  1.0, -0.3457955],   // pos 23, C (last spacer position)
        [23.0,  2.0, -0.6780964],   // pos 23, G
        [24.0,  0.0,  0.22508903],  // pos 24, A
        [24.0,  1.0, -0.5077941],   // pos 24, C
        [25.0,  3.0, -0.4173736],   // pos 25, T (in NGG PAM region)
        [26.0,  2.0,  0.37989937],  // pos 26, G
        [27.0,  3.0, -0.054307706], // pos 27, T
        [28.0,  3.0,  0.20681921],  // pos 28, T
        [29.0,  0.0,  0.21450884],  // pos 29, A
        [29.0,  2.0,  0.2418514]    // pos 29, G
    ]
}

// Doench 2014 Sup. Table S5 — dinucleotide (position, di, weight). The
// dinucleotide at `position` spans (seq[position], seq[position+1]). Only
// non-zero entries are listed.
fn _doench_dinuc_table() -> [[float]] {
    // Each row: [position, di_idx, weight]
    return [
        [ 0.0, 14.0,  0.11787758],   // pos 0  TG
        [ 0.0, 11.0, -0.069968465],  // pos 0  GT
        [ 3.0,  2.0,  0.108068],     // pos 3  AG
        [ 4.0,  5.0, -0.6448382],    // pos 4  CC
        [ 5.0, 11.0, -0.27338737],   // pos 5  GT
        [ 6.0,  4.0,  0.06401813],   // pos 6  CA
        [ 7.0,  5.0,  0.027434449],  // pos 7  CC (small +)
        [ 7.0, 11.0, -0.025868148],  // pos 7  GT
        [10.0, 14.0,  0.038892334],  // pos 10 TG
        [11.0,  4.0,  0.1837179],    // pos 11 CA
        [12.0,  9.0, -0.011454492],  // pos 12 GC
        [13.0,  4.0,  0.13585252],   // pos 13 CA
        [14.0,  3.0,  0.014775683],  // pos 14 AT
        [15.0, 11.0,  0.046729592],  // pos 15 GT
        [16.0, 14.0, -0.13209606],   // pos 16 TG
        [17.0, 13.0,  0.030183774],  // pos 17 TC
        [18.0,  2.0, -0.4564182],    // pos 18 AG
        [19.0,  6.0, -0.087159326],  // pos 19 CG
        [20.0, 11.0,  0.10654225],   // pos 20 GT
        [21.0, 10.0, -0.42624866],   // pos 21 GG
        [22.0, 10.0, -0.5418666],    // pos 22 GG
        [22.0,  8.0,  0.13491315]    // pos 22 GA
    ]
}

// Count G + C nucleotides in the 20-nt protospacer (positions 4-23).
fn _gc_count_spacer(seq30: string) -> int {
    let mut count = 0
    let mut i = 4
    while i < 24 {
        let c = _at_pos(seq30, i)
        if c == "G" || c == "C" { count = count + 1 }
        i = i + 1
    }
    return count
}

fn _abs_i(x: int) -> int {
    if x < 0 { return -x }
    return x
}

fn _abs_f(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

// Compute the raw linear score Σ w_i · x_i (pre-sigmoid).
fn _doench_linear_score(seq30: string) -> float {
    let mut score: float = DOENCH_INTERCEPT

    // Position-specific single-NT contributions.
    let stab = _doench_single_nt_table()
    let mut i = 0
    while i < len(stab) {
        let row = stab[i]
        let pos = to_int(row[0])
        let want_nt = to_int(row[1])
        let w = row[2]
        let c = _at_pos(seq30, pos)
        if _nt_idx(c) == want_nt { score = score + w }
        i = i + 1
    }

    // Position-specific dinucleotide contributions.
    let dtab = _doench_dinuc_table()
    let mut j = 0
    while j < len(dtab) {
        let row = dtab[j]
        let pos = to_int(row[0])
        let want_di = to_int(row[1])
        let w = row[2]
        let a = _at_pos(seq30, pos)
        let b = _at_pos(seq30, pos + 1)
        if _di_idx(a, b) == want_di { score = score + w }
        j = j + 1
    }

    // GC-content penalty on the 20-nt protospacer.
    let gc = _gc_count_spacer(seq30)
    let gc_dev = to_float(_abs_i(gc - 10))
    if gc < 10 {
        score = score + gc_dev * DOENCH_GC_LOW
    } else if gc > 10 {
        score = score + gc_dev * DOENCH_GC_HIGH
    }
    // gc == 10 → no penalty (model is centred at GC=10/20).

    return score
}

// ── public surface ────────────────────────────────────────────────────

// Compute the Doench-2014 / Rule-Set-1 closed-form activity score for a
// 30-nt context (4 upstream + 20 spacer + 3 PAM + 3 downstream). Returns
// a value in [0, 1]; higher = predicted more active. Strings shorter
// than 30 chars yield the bare-intercept sigmoid (≈ 0.645) since every
// position-keyed feature fails the bound-check; callers should validate
// length upstream.
pub fn doench_2016_score(spacer_30mer: string) -> float {
    let raw = _doench_linear_score(spacer_30mer)
    return 1.0 / (1.0 + exp(-raw))
}

// Audit surface: return the list of fired feature labels with their
// numeric contributions, one entry per line. Useful for cross-checking
// against the Doench 2014 Sup. Table S5 row-by-row.
pub fn doench_2016_explain(spacer_30mer: string) -> [string] {
    let mut out: [string] = []
    out.push("intercept = " + to_string(DOENCH_INTERCEPT))

    let stab = _doench_single_nt_table()
    let mut i = 0
    while i < len(stab) {
        let row = stab[i]
        let pos = to_int(row[0])
        let want_nt = to_int(row[1])
        let w = row[2]
        let c = _at_pos(seq30_safe(spacer_30mer), pos)
        if _nt_idx(c) == want_nt {
            out.push("nt[pos=" + to_string(pos) + "," + _nt_name(want_nt) + "] = " + to_string(w))
        }
        i = i + 1
    }

    let dtab = _doench_dinuc_table()
    let mut j = 0
    while j < len(dtab) {
        let row = dtab[j]
        let pos = to_int(row[0])
        let want_di = to_int(row[1])
        let w = row[2]
        let a = _at_pos(seq30_safe(spacer_30mer), pos)
        let b = _at_pos(seq30_safe(spacer_30mer), pos + 1)
        if _di_idx(a, b) == want_di {
            out.push("di[pos=" + to_string(pos) + "," + _di_name(want_di) + "] = " + to_string(w))
        }
        j = j + 1
    }

    let gc = _gc_count_spacer(spacer_30mer)
    let gc_dev = to_float(_abs_i(gc - 10))
    if gc < 10 {
        let contrib = gc_dev * DOENCH_GC_LOW
        out.push("gc_low[gc=" + to_string(gc) + ",dev=" + to_string(gc - 10) + "] = " + to_string(contrib))
    } else if gc > 10 {
        let contrib = gc_dev * DOENCH_GC_HIGH
        out.push("gc_high[gc=" + to_string(gc) + ",dev=" + to_string(gc - 10) + "] = " + to_string(contrib))
    }

    let raw = _doench_linear_score(spacer_30mer)
    let sig = 1.0 / (1.0 + exp(-raw))
    out.push("linear_sum = " + to_string(raw))
    out.push("sigmoid_score = " + to_string(sig))
    return out
}

// Internal: just returns the input — kept so the explain surface composes
// with future length-normalisation without re-threading the call sites.
fn seq30_safe(s: string) -> string { return s }

fn _nt_name(i: int) -> string {
    if i == 0 { return "A" }
    if i == 1 { return "C" }
    if i == 2 { return "G" }
    if i == 3 { return "T" }
    return "?"
}

fn _di_name(i: int) -> string {
    let a = i / 4
    let b = i - a * 4
    return _nt_name(a) + _nt_name(b)
}

// ── melting-temperature helpers (Wallace rule, cited for follow-up) ──
//
// Tm = 2·(A+T) + 4·(G+C)   (Wallace, Nucleic Acids Res. 1979;6:3543)
//
// The full Doench-2016 Rule Set 2 model also feeds nearest-neighbor Tm
// of three sub-windows (5-nt, 8-nt, 13-nt) into its gradient-boosted
// ensemble. We expose the Wallace Tm of the 20-nt spacer here so a
// downstream Rule-Set-2 follower can compose it without re-parsing the
// 30-mer; it is NOT currently fed into the linear logistic above (the
// closed-form Doench-2014 model omits Tm by construction).
pub fn doench_wallace_tm_spacer(spacer_30mer: string) -> float {
    let mut at: int = 0
    let mut gc: int = 0
    let mut i = 4
    while i < 24 {
        let c = _at_pos(spacer_30mer, i)
        if c == "A" || c == "T" { at = at + 1 }
        else if c == "G" || c == "C" { gc = gc + 1 }
        i = i + 1
    }
    return 2.0 * to_float(at) + 4.0 * to_float(gc)
}
