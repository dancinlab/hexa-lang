#!hexa strict
// oligonucleotide/module/oligonucleotide.hexa — OLIGONUCLEOTIDE verb
//
// LAYER: EXPANSION-MAIN axis (NOT a core-5 axis). The committed hexa-bio
//        core remains QUANTUM · WEAVE · NANOBOT · RIBOZYME · VIROCAPSID
//        (AXIS.tape — UNCHANGED by this module). See AXIS/HIERARCHY.tape
//        for the expansion-layer convention and HEXA-OLIGONUCLEOTIDE.tape
//        for this axis's architecture tape.
//
// MODALITY: antisense oligonucleotide (ASO) + siRNA therapeutics —
//        synthetic single/double-stranded oligonucleotide drugs that
//        Watson-Crick hybridize to a target transcript and silence it by
//        recruiting RNase-H (gapmer ASO) or the RISC/Ago2 complex (siRNA).
//        Described ONLY by its own drug precedent — nusinersen/Spinraza
//        (ASO, FDA 2016), patisiran/Onpattro (siRNA, FDA 2018), inclisiran
//        (siRNA, 2021) — NEVER derived from the n=6 lattice (AGENTS.tape
//        g3 / f1 / f_lattice_fit).
//
// NON-OVERLAP WITH THE RIBOZYME CORE AXIS (honesty note):
//        OLIGONUCLEOTIDE is RNA-domain-ADJACENT to the RIBOZYME core axis
//        but mechanism-DISTINCT (<30% overlap):
//          - ASO/siRNA = synthetic oligonucleotide DRUGS; the catalysis
//            is done by a recruited host enzyme (RNase-H / Ago2-RISC).
//            The oligo itself is a sequence-recognition guide, not an
//            enzyme.
//          - RIBOZYME = catalytic RNA ENZYMES (hammerhead / HDV / group
//            I-II / RNase P / the ribosome) — the RNA performs the
//            phosphoryl-transfer chemistry itself.
//        The shared substrate is Watson-Crick base-pairing; the catalytic
//        principle is orthogonal. See HEXA-OLIGONUCLEOTIDE.tape §non-overlap.
//
// REAL LIMIT (AGENTS.tape g1 — real-limits-first):
//        nucleic-acid duplex thermodynamics — the nearest-neighbor
//        base-pair stacking free energy bounds duplex stability.
//        Anchored to SantaLucia J Jr, PNAS 1998;95:1460-1465 (the unified
//        nearest-neighbor ΔH°/ΔS° parameters) + the van 't Hoff two-state
//        Tm equation. The deterministic computation lives in
//        _python_bridge/module/oligonucleotide_hybridization_sim.py.
//
// Falsifiers (HEXA-OLIGONUCLEOTIDE.tape §falsifiers):
//        F-OLIGO-1  ASO:mRNA duplex Tm tracks the SantaLucia NN sum —
//                   Tm of the Dickerson dodecamer reference duplex lands
//                   in the 57-62 °C literature regime.
//        F-OLIGO-2  GC>AT Tm ordering + length monotonicity — a GC-rich
//                   duplex melts higher than an equal-length AT-rich one,
//                   and extending a duplex lowers (more negative) ΔG°.
//        F-OLIGO-3  off-target hybridization is detectable — a ΔG-scored
//                   slide against a decoy pool flags a deliberately
//                   complementary low-complexity off-targeter.
//
// HONEST C2/C3 SCOPE (AGENTS.tape g8 / f2):
//        A PASS here verifies IN-SILICO simulator+metadata consistency
//        ONLY — that the NN-thermodynamics calculator reproduces the
//        SantaLucia (1998) model self-consistently. It is NOT a
//        therapeutic, clinical, regulatory, immunogenic, knockdown, or
//        efficacy claim. The 1 M Na+ standard state is non-physiological;
//        salt-corrected Tm, 2'-modified backbones (2'-OMe / 2'-MOE / LNA
//        / phosphorothioate), RNA:DNA hybrid parameters, RNase-H / RISC
//        recruitment, delivery and the wet-lab boundary are out of repo
//        scope (CLOSURE_RESIDUAL_BACKLOG.md §0).
//
//        Skeleton sentinel `__HEXA_BIO_OLIGONUCLEOTIDE__ PASS` indicates
//        the module loads; the Python bridge prints its own
//        `__OLIGONUCLEOTIDE_HYBRIDIZATION__ PASS` when the NN-model
//        self-check passes 8/8.

let VERSION = "1.0.0-expansion-main"
let MODULE  = "oligonucleotide"

fn _root() -> str {
    let r = env("HEXA_BIO_ROOT")
    if r.len() > 0 { return r }
    let inferred = exec("dirname \"$(dirname \"$(dirname \"$0\")\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return env("HOME") + "/.hexa-bio"  // @allow-devpath
}

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _python_path(script: str) -> str {
    let root = _root()
    return root + "/_python_bridge/module/" + script
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + _shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _print_layer() {
    println("  layer: EXPANSION-MAIN axis (NOT core-5)")
    println("         core-5 (QUANTUM · WEAVE · NANOBOT · RIBOZYME ·")
    println("         VIROCAPSID) is UNCHANGED — see AXIS.tape +")
    println("         AXIS/HIERARCHY.tape for the expansion convention.")
}

fn _print_modality() {
    println("  modality: antisense oligonucleotide (ASO) + siRNA therapeutics")
    println("            own drug precedent ONLY (AGENTS.tape g3 / f1):")
    println("              nusinersen / Spinraza   — ASO,  FDA 2016")
    println("              patisiran / Onpattro    — siRNA, FDA 2018")
    println("              inclisiran               — siRNA, 2021")
    println("            NOT derived from the n=6 lattice (f_lattice_fit).")
}

fn _print_non_overlap() {
    println("  non-overlap vs the RIBOZYME core axis (<30% overlap):")
    println("    ASO/siRNA = synthetic oligonucleotide DRUGS; catalysis is")
    println("                done by a recruited host enzyme (RNase-H /")
    println("                Ago2-RISC) — the oligo is a guide, not enzyme.")
    println("    RIBOZYME  = catalytic RNA ENZYMES — the RNA itself performs")
    println("                the phosphoryl-transfer chemistry.")
    println("    shared substrate = Watson-Crick pairing; catalytic")
    println("    principle = orthogonal. Mechanism-distinct axes.")
}

fn _print_real_limit() {
    println("  real limit (AGENTS.tape g1 — real-limits-first):")
    println("    nucleic-acid duplex thermodynamics — nearest-neighbor")
    println("    base-pair stacking free energy bounds duplex stability.")
    println("    anchor: SantaLucia J Jr, PNAS 1998;95:1460-1465")
    println("            (unified nearest-neighbor ΔH°/ΔS° parameters) +")
    println("            van 't Hoff two-state melting-temperature equation.")
}

fn _print_falsifiers() {
    println("  falsifiers (HEXA-OLIGONUCLEOTIDE.tape):")
    println("    F-OLIGO-1  ASO:mRNA duplex Tm tracks the SantaLucia NN sum")
    println("    F-OLIGO-2  GC>AT Tm ordering + length monotonicity of ΔG°")
    println("    F-OLIGO-3  off-target hybridization is ΔG-detectable")
}

fn _print_status() {
    println("  status: expansion-main axis v1.0.0")
    println("          hybridization sim: SantaLucia 1998 NN ΔG/ΔH/ΔS + Tm")
    println("          + ΔG-scored off-target screen (8/8 self-check)")
}

fn run_hybridization() -> str {
    // Opt-in gate (ribozyme/weave/virocapsid precedent):
    // HEXA_BIO_WITH_NUMPY=1 signals local python3 is available. The
    // hybridization sim is stdlib-only (no numpy/scipy) but the env flag
    // is the canonical signal — it skips the Python path under a docker
    // hard-landing.
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[oligonucleotide] HEXA_BIO_WITH_NUMPY != 1 — hybridization simulation skipped")
        println("[oligonucleotide] (set HEXA_BIO_WITH_NUMPY=1 to run oligonucleotide_hybridization_sim.py)")
        println("[oligonucleotide] cached hybridization result (SantaLucia 1998 NN model):")
        println("[oligonucleotide]   reference duplex 5'-CGCGAATTCGCG-3' (Dickerson dodecamer)")
        println("[oligonucleotide]   ΔH° ≈ -101.2 kcal/mol  (literature regime ~ -95)")
        println("[oligonucleotide]   ΔS° ≈ -273.8 cal/mol·K (literature regime ~ -266)")
        println("[oligonucleotide]   Tm  ≈ 60.8 °C          (literature regime ~ 57-62 °C)")
        println("[oligonucleotide]   off-target screen: ΔG-scored slide flags the")
        println("[oligonucleotide]                      deliberate low-complexity off-targeter")
        println("[oligonucleotide]   self-check 8/8 PASS — in-silico simulator-consistency ONLY")
        return "skipped-no-opt-in"
    }
    let script = _python_path("oligonucleotide_hybridization_sim.py")
    if _file_exists(script) == false {
        eprintln("[oligonucleotide] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let cmd = "python3 " + _shq(script) + " 2>&1"
    let raw = exec(cmd)
    println(raw.trim())
    return "ran"
}

fn cmd_oligonucleotide(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — ASO/siRNA hybridization primitive")
    println("")

    let mut mode = "skeleton"
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--hybridization" { mode = "hybridization" }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_layer()
        println("")
        _print_modality()
        println("")
        _print_non_overlap()
        println("")
        _print_real_limit()
        println("")
        _print_falsifiers()
        println("")
        println("usage: hexa-bio oligonucleotide [--hybridization]")
        println("[oligonucleotide] no action specified — printed axis card only")
        println("[oligonucleotide] scope: in-silico simulator-consistency ONLY (g8/f2)")
        println("__HEXA_BIO_OLIGONUCLEOTIDE__ PASS")
        return
    }

    if mode == "hybridization" {
        println("--- F-OLIGO hybridization (SantaLucia 1998 NN duplex thermodynamics + ΔG off-target screen) ---")
        run_hybridization()
        println("")
        _print_real_limit()
        println("")
        println("[oligonucleotide] scope: in-silico simulator-consistency ONLY (g8/f2)")
        println("__HEXA_BIO_OLIGONUCLEOTIDE__ PASS")
        return
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_oligonucleotide(user)
}
