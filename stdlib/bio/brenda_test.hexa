// stdlib/bio/brenda_test.hexa — measured-oracle gate for the BRENDA
// enzyme client (parse-surface build, SOAP wire deferred).
//
// Determinism: parse the synthetic JSON fixture at
// `compiler/bridges/_cache/brenda.frozen.json` (EC 3.1.1.7
// acetylcholinesterase, Homo sapiens) and byte-equal each field of the
// public `BrendaEnzyme` surface. No network. Per @D
// try-live-or-fallback: this is the 🔵 SUPPORTED-FORMAL leg —
// SOAP-live parity is deferred.

use "stdlib/bio/brenda"

let FIXTURE = "compiler/bridges/_cache/brenda.frozen.json"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_eq_f(label: string, want: float, got: float) {
    if want != got {
        let w = to_string(want)
        let g = to_string(got)
        _fail(label, w, g)
    }
}

fn main() {
    let body = read_file(FIXTURE)
    if len(body) == 0 {
        println("FAIL: fixture missing: " + FIXTURE)
        exit(1)
    }

    // ── pure brenda_parse oracle ────────────────────────────────
    let e = brenda_parse(body)
    _expect_eq("ec_number",        "3.1.1.7",              e.ec_number)
    _expect_eq("recommended_name", "Acetylcholinesterase", e.recommended_name)
    _expect_eq("organism",         "Homo sapiens",         e.organism)
    _expect_eq("substrate",        "acetylcholine",        e.substrate)
    _expect_eq_f("km_uM",                 92.5,    e.km_uM)
    _expect_eq_f("kcat_per_s",            14000.0, e.kcat_per_s)
    _expect_eq_f("ph_optimum",            8.0,     e.ph_optimum)
    _expect_eq_f("temperature_optimum_C", 37.0,    e.temperature_optimum_C)

    // ── lookup-by-EC fixture round-trip ─────────────────────────
    let hit = brenda_lookup_by_ec("3.1.1.7")
    _expect_eq("lookup hit ec",        "3.1.1.7",              hit.ec_number)
    _expect_eq("lookup hit name",      "Acetylcholinesterase", hit.recommended_name)
    _expect_eq_f("lookup hit km_uM",   92.5,                   hit.km_uM)

    // ── miss path (EC not in fixture) ───────────────────────────
    let miss = brenda_lookup_by_ec("1.1.1.1")
    _expect_eq("lookup miss ec is sentinel", "", miss.ec_number)

    // ── empty-body sentinel ─────────────────────────────────────
    let empty = brenda_parse("")
    _expect_eq("empty body ec",          "", empty.ec_number)
    _expect_eq_f("empty body km_uM",    0.0, empty.km_uM)

    // ── empty-ec sentinel ───────────────────────────────────────
    let no_ec = brenda_lookup_by_ec("")
    _expect_eq("empty ec sentinel", "", no_ec.ec_number)

    println("PASS: brenda_parse + lookup_by_ec + sentinel oracles (1 enzyme, 8 fields)")
}
