#!hexa strict
//
// virocapsid/module/corpus_subclause_audit.hexa — F-VIROCAPSID-1 sub-clause closure.
//
// HEXA-NATIVE port of _python_bridge/module/virocapsid_corpus_subclause_audit.py
// (R5 sunset 4/57, 2026-05-07). Per-sub-clause verdicts on n=10 corpus
// (schema raw_77_virocapsid_pdb_corpus_v2):
//   -genus  vertex_count=12 across all T-numbers
//   -1-b    >=3 distinct T-number strata
//   -1-c    source-class match-rate parity (max-min <= 0.20)
//   -1-d    >=70% rows annotate resolution + monomer count
//
// Per cross-cutting Require (R5) raw 9 hexa-only: hexa stdlib only.

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn load_corpus_rows() {
    let path = registry_path()
    if !file_exists(path) { return [] }
    let raw = read_file(path)
    let lines = raw.split("\n")
    let rows = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if len(ln) == 0 { i = i + 1; continue }
        // Pre-filter by literal schema string — avoids json_parse on every line
        // and dodges -Infinity/NaN sentinels emitted by other audits.
        if !ln.contains("raw_77_virocapsid_pdb_corpus_v2") { i = i + 1; continue }
        try {
            let obj = json_parse(ln)
            if obj != void {
                let sch = obj["schema"]
                if type_of(sch) == "string" && sch == "raw_77_virocapsid_pdb_corpus_v2" {
                    rows.push(obj)
                }
            }
        } catch e {
            // unparseable / bad numeric — skip
        }
        i = i + 1
    }
    return rows
}

fn dedupe_rows(rows) {
    let by_id = {}
    let mut i = 0
    while i < len(rows) {
        let r = rows[i]
        let pid = to_string(r["pdb_id"])
        if has_key(by_id, pid) {
            let prev = by_id[pid]
            let prev_fa = prev["fetched_at"]
            let curr_fa = r["fetched_at"]
            let mut prev_s = ""
            if type_of(prev_fa) == "string" { prev_s = prev_fa }
            let mut curr_s = ""
            if type_of(curr_fa) == "string" { curr_s = curr_fa }
            if curr_s > prev_s { by_id[pid] = r }
        } else {
            by_id[pid] = r
        }
        i = i + 1
    }
    let pids = keys(by_id)
    let n = len(pids)
    let mut a = 0
    while a < n {
        let mut b = a + 1
        while b < n {
            if pids[b] < pids[a] {
                let tmp = pids[a]
                pids[a] = pids[b]
                pids[b] = tmp
            }
            b = b + 1
        }
        a = a + 1
    }
    let out = []
    let mut k = 0
    while k < len(pids) { out.push(by_id[pids[k]]); k = k + 1 }
    return out
}

fn audit_genus(rows) {
    let n = len(rows)
    let mut matches = 0
    let mut i = 0
    while i < n {
        if rows[i]["vertex_count_expected"] == 12 { matches = matches + 1 }
        i = i + 1
    }
    let mut verdict = "FAIL"
    if matches == n && n >= 1 { verdict = "PASS" }
    let r = {}
    r["n"] = n
    r["vertex_count_12_count"] = matches
    r["verdict"] = verdict
    return r
}

fn audit_b(rows) {
    let strata = {}
    let mut i = 0
    while i < len(rows) {
        let t = to_string(rows[i]["t_number_declared"])
        if has_key(strata, t) { strata[t] = strata[t] + 1 } else { strata[t] = 1 }
        i = i + 1
    }
    let distinct = len(keys(strata))
    let mut verdict = "FAIL"
    if distinct >= 3 { verdict = "PASS" }
    let r = {}
    r["t_strata"] = strata
    r["distinct_t_count"] = distinct
    r["verdict"] = verdict
    return r
}

fn audit_c(rows) {
    let strata = {}
    let mut i = 0
    while i < len(rows) {
        let r = rows[i]
        let c = to_string(r["source_class"])
        if !has_key(strata, c) {
            let s = {}
            s["n"] = 0
            s["match"] = 0
            strata[c] = s
        }
        let s = strata[c]
        s["n"] = s["n"] + 1
        if r["vertex_count_expected"] == 12 { s["match"] = s["match"] + 1 }
        strata[c] = s
        i = i + 1
    }
    let rates = {}
    let strata_n = {}
    let class_keys = keys(strata)
    let mut k = 0
    let valid_rates = []
    while k < len(class_keys) {
        let c = class_keys[k]
        let s = strata[c]
        strata_n[c] = s["n"]
        if s["n"] > 0 {
            let rate = to_float(s["match"]) / to_float(s["n"])
            rates[c] = rate
            valid_rates.push(rate)
        } else {
            rates[c] = void
        }
        k = k + 1
    }
    let mut verdict = "FAIL"
    let mut max_minus_min = void
    if len(valid_rates) >= 2 {
        let mut maxv = valid_rates[0]
        let mut minv = valid_rates[0]
        let mut j = 1
        while j < len(valid_rates) {
            if valid_rates[j] > maxv { maxv = valid_rates[j] }
            if valid_rates[j] < minv { minv = valid_rates[j] }
            j = j + 1
        }
        max_minus_min = maxv - minv
        if max_minus_min <= 0.20 { verdict = "PASS" }
    }
    let r = {}
    r["strata_n"] = strata_n
    r["strata_match_rate"] = rates
    r["max_minus_min_rate"] = max_minus_min
    r["verdict"] = verdict
    return r
}

fn audit_d(rows) {
    let n = len(rows)
    let mut annotated = 0
    let mut i = 0
    while i < n {
        let r = rows[i]
        let res = r["resolution_angstrom"]
        let mc = r["rcsb_polymer_monomer_count"]
        let res_present = type_of(res) != "void" && res != void
        let mc_present = type_of(mc) != "void" && mc != void
        if res_present && mc_present { annotated = annotated + 1 }
        i = i + 1
    }
    let mut completeness = 0.0
    if n > 0 { completeness = to_float(annotated) / to_float(n) }
    let mut verdict = "FAIL"
    if completeness >= 0.70 { verdict = "PASS" }
    let r = {}
    r["n"] = n
    r["annotated_count"] = annotated
    r["completeness"] = completeness
    r["verdict"] = verdict
    return r
}

let RAW_91 = "Sub-clause audit on n=10 raw_77_virocapsid_pdb_corpus_v2. -genus tests vertex_count=12 invariant; -1-b tests T-number stratum coverage (>=3 strata); -1-c tests source-class match parity (max-min <= 0.20); -1-d tests annotation completeness (>=0.70). With curator-asserted icosahedral corpus -genus and -1-c are partially structural (match_rate trivially 1.0 per stratum); independent empirical refutation requires C3b full corpus (cycle 28+)."

fn build_witness(rows, audited_at: string) {
    let g = audit_genus(rows)
    let b = audit_b(rows)
    let c = audit_c(rows)
    let d = audit_d(rows)
    let overall = g["verdict"] == "PASS" && b["verdict"] == "PASS" && c["verdict"] == "PASS" && d["verdict"] == "PASS"

    let subs = {}
    subs["f_virocapsid_1_genus"] = g
    subs["f_virocapsid_1_b"] = b
    subs["f_virocapsid_1_c"] = c
    subs["f_virocapsid_1_d"] = d

    let w = {}
    w["schema"] = "raw_77_virocapsid_pdb_corpus_subclause_audit_v1"
    w["audited_at"] = audited_at
    w["n_corpus"] = len(rows)
    w["f_virocapsid_1_subclauses"] = subs
    w["overall_pass"] = overall
    w["raw_91_c3_disclose"] = RAW_91
    w["raw_77_append_only"] = true
    w["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    w["witness_ref"] = "state/discovery_absorption/registry.jsonl#raw_77_virocapsid_pdb_corpus_subclause_audit_v1"
    return w
}

fn parse_argv(av) {
    let r = {}
    r["emit"] = false
    r["summary"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--emit" { r["emit"] = true }
        if a == "--summary" { r["summary"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let parsed = parse_argv(args())
    let raw_rows = load_corpus_rows()
    let rows = dedupe_rows(raw_rows)
    if len(rows) == 0 {
        eprintln("error: no raw_77_virocapsid_pdb_corpus_v2 rows in registry")
        exit(2)
    }

    let audited_at = utc_iso_now()
    let witness = build_witness(rows, audited_at)

    if parsed["emit"] {
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(witness) + "\n")
        eprintln("emitted 1 witness row -> " + path)
    }

    if parsed["summary"] {
        println(json_encode(witness))
    } else {
        let subs = witness["f_virocapsid_1_subclauses"]
        let sub_keys = keys(subs)
        let mut i = 0
        while i < len(sub_keys) {
            let k = sub_keys[i]
            eprintln("  " + k + ": " + subs[k]["verdict"])
            i = i + 1
        }
        eprintln("overall_pass=" + to_string(witness["overall_pass"]))
    }

    if witness["overall_pass"] { exit(0) }
    exit(1)
}
