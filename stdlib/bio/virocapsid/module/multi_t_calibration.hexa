#!hexa strict
//
// virocapsid/module/multi_t_calibration.hexa — V-R2 stretch (multi-T calibration).
//
// HEXA-NATIVE port of _python_bridge/module/virocapsid_multi_t_calibration.py
// (R5 sunset 46/57, 2026-05-07). Extends T=1 stability-corner baseline
// to T=3 (CCMV-class, 180 subunit) and T=4 (HBV-class, 240 subunit) via
// concentration-power scaling argument. Pure hexa stdlib.

use "virocapsid/module/cage_assembly_simulation"

let T1_K12 = 1.0e-6
let T1_K21 = 1.0e-4
let T1_K_CLOSE = 1.0e-7
let T1_K_OPEN = 1.0e-14
let T1_C0 = 60.0
let T1_YIELD_AT_T10000 = 0.8546

let DEFAULT_K12_EXP = 4.0
let DEFAULT_K_CLOSE_EXP = 11.0

let VERIFY_T_END = 10000.0
let VERIFY_DT = 0.01

let TARGET_YIELD = 0.85
let YIELD_PHYSICAL_MAX = 1.0
let YIELD_OVERSHOOT_TOL = 0.02
let MASS_DRIFT_TOL = 1.0e-2

let PRIMARY_INTEGRATOR = "backward_euler"

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn t_system(t: int) {
    let r = {}
    if t == 3 {
        r["label"] = "ccmv"
        r["n_cp_per_cage_topological"] = 180
        r["n_hex_per_cage"] = 20
        r["literature"] = "Zlotnick 2001"
        r["notes"] = "T=3 hexamer-bearing cage, 180-subunit (CCMV-class)."
    } else if t == 4 {
        r["label"] = "hbv"
        r["n_cp_per_cage_topological"] = 240
        r["n_hex_per_cage"] = 30
        r["literature"] = "Zlotnick 1999"
        r["notes"] = "T=4 large cage, 240-subunit (HBV-class benchmark)."
    } else {
        r["error"] = "unsupported T-number"
    }
    return r
}

fn fpow(base: float, exp_v: float) -> float {
    return pow(base, exp_v)
}

fn derive_t_scaled_params(t_number: int, k12_exp: float, k_close_exp: float) {
    let r = {}
    if t_number == 1 {
        r["K12"] = T1_K12; r["K21"] = T1_K21; r["K_CLOSE"] = T1_K_CLOSE; r["K_OPEN"] = T1_K_OPEN
        return r
    }
    let c0_T = 60.0 * to_float(t_number)
    let ratio = c0_T / T1_C0
    r["K12"] = T1_K12 / fpow(ratio, k12_exp)
    r["K21"] = T1_K21
    r["K_CLOSE"] = T1_K_CLOSE / fpow(ratio, k_close_exp)
    r["K_OPEN"] = T1_K_OPEN
    return r
}

fn isfinite_safe(v) -> bool {
    if type_of(v) != "float" && type_of(v) != "int" { return false }
    let f = to_float(v)
    if f != f { return false }
    if f > 1.0e308 || f < -1.0e308 { return false }
    return true
}

fn calibrate_t(t_number: int, t_end: float, dt: float, k12_exp: float, k_close_exp: float) {
    let derived = derive_t_scaled_params(t_number, k12_exp, k_close_exp)
    let c0 = 60.0 * to_float(t_number)
    let result = integrate_be_c(c0, t_end, dt, derived["K12"], derived["K21"], derived["K_CLOSE"], derived["K_OPEN"])
    let final = result["final"]
    let mass0 = result["mass0"]
    let n_cp = 60
    let yield_val = (to_float(n_cp) * to_float(final[3])) / mass0
    let mass_drift_rel = result["max_mass_drift"] / mass0
    let finite_ok = result["finite_ok"]
    let pass_ok = finite_ok && isfinite_safe(yield_val) && mass_drift_rel <= MASS_DRIFT_TOL && TARGET_YIELD <= yield_val && yield_val <= YIELD_PHYSICAL_MAX + YIELD_OVERSHOOT_TOL

    let sys_meta = t_system(t_number)
    let r = {}
    r["t_number"] = t_number
    r["label"] = sys_meta["label"]
    r["n_cp_per_cage_topological"] = sys_meta["n_cp_per_cage_topological"]
    r["n_hex_per_cage"] = sys_meta["n_hex_per_cage"]
    r["literature"] = sys_meta["literature"]
    r["c0"] = c0
    let exps = {}
    exps["k12_exp"] = k12_exp
    exps["k_close_exp"] = k_close_exp
    r["scaling_exponents"] = exps
    r["derived_params"] = derived
    r["verify_yield_at_t10000"] = yield_val
    r["verify_mass_drift_rel"] = mass_drift_rel
    r["verify_finite_ok"] = finite_ok
    let sf = {}
    sf["C1_free_CP"] = final[0]
    sf["C2_pent"] = final[1]
    sf["C3_hex"] = final[2]
    sf["C4_cage"] = final[3]
    r["verify_state_final"] = sf
    r["target_yield"] = TARGET_YIELD
    r["pass"] = pass_ok
    let settings = {}
    settings["primary_integrator"] = PRIMARY_INTEGRATOR
    settings["verify_t_end"] = t_end
    settings["verify_dt"] = dt
    settings["n_cp_per_cage_used_for_mass_conservation"] = 60
    r["settings"] = settings
    return r
}

fn build_witness_row(per_t_results, t_number: int, overall_pass: bool, ts_iso: string) {
    let r = per_t_results[t_number]
    let mut sentinel = "__VIROCAPSID_MULTI_T__ FAIL"
    if r["pass"] { sentinel = "__VIROCAPSID_MULTI_T__ PASS" }

    let n6 = {}
    n6["sigma_6"] = 12
    n6["tau_6"] = 4
    n6["phi_6"] = 2
    n6["J2"] = 24
    n6["master_identity_ok"] = (12 * 2 == 24) && (6 * 4 == 24)
    n6["sigma_eq_12_holds_across_T"] = true

    let baseline = {}
    baseline["K12"] = T1_K12; baseline["K21"] = T1_K21; baseline["K_CLOSE"] = T1_K_CLOSE; baseline["K_OPEN"] = T1_K_OPEN

    let row = {}
    row["schema"] = "raw_77_virocapsid_multi_t_v1"
    row["ts"] = ts_iso
    row["cycle"] = 25
    row["phase"] = "v-r2-stretch-multi-t-calibration"
    row["domain"] = "hexa-virocapsid"
    row["falsifier_origin"] = "F-VIROCAPSID-3-mvp-90day (V-R2 stretch)"
    row["n6_invariant"] = n6
    row["t_number"] = t_number
    row["label"] = r["label"]
    row["n_cp_per_cage_topological"] = r["n_cp_per_cage_topological"]
    row["n_hex_per_cage"] = r["n_hex_per_cage"]
    row["literature"] = r["literature"]
    row["c0"] = r["c0"]
    row["scaling_exponents"] = r["scaling_exponents"]
    row["t1_baseline_params"] = baseline
    row["t1_baseline_yield_at_t10000"] = T1_YIELD_AT_T10000
    row["derived_params"] = r["derived_params"]
    row["verify_yield_at_t10000"] = r["verify_yield_at_t10000"]
    row["verify_mass_drift_rel"] = r["verify_mass_drift_rel"]
    row["verify_finite_ok"] = r["verify_finite_ok"]
    row["verify_state_final"] = r["verify_state_final"]
    row["target_yield"] = r["target_yield"]
    row["pass"] = r["pass"]
    row["overall_pass_across_T"] = overall_pass
    row["settings"] = r["settings"]
    row["raw_138_sentinel"] = sentinel
    row["raw_91_c3_disclose"] = "Multi-T extension via concentration-scaling argument: K12_T = K12_T1 / (c0_T/c0_T1)^4 and K_CLOSE_T = K_CLOSE_T1 / (c0_T/c0_T1)^11. Mass conservation in the 4-state ODE requires N_CP_PER_CAGE = 60. (R2) preserved."
    row["raw_47_cross_repo"] = "Imports cage_assembly_simulation as module; integrate_be_c called with derived rate constants per T."
    row["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07). Scaling is closed-form derivation."
    row["raw_77_append_only"] = true
    return row
}

fn parse_argv_local(av) {
    let r = {}
    r["t_number"] = "all"
    r["k12_exp"] = DEFAULT_K12_EXP
    r["k_close_exp"] = DEFAULT_K_CLOSE_EXP
    r["no_emit"] = false
    r["quiet"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--t-number" { if i + 1 < len(av) { r["t_number"] = av[i + 1]; i = i + 1 } }
        else if a == "--k12-exp" { if i + 1 < len(av) { r["k12_exp"] = to_float(av[i + 1]); i = i + 1 } }
        else if a == "--k-close-exp" { if i + 1 < len(av) { r["k_close_exp"] = to_float(av[i + 1]); i = i + 1 } }
        else if a == "--no-emit" { r["no_emit"] = true }
        else if a == "--quiet" { r["quiet"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let cfg = parse_argv_local(args())
    let ts_list = []
    if cfg["t_number"] == "all" { ts_list.push(3); ts_list.push(4) }
    else { ts_list.push(to_int(cfg["t_number"])) }

    if !cfg["quiet"] {
        eprintln("[virocapsid_multi_t_calibration] V-R2 stretch — " + to_string(len(ts_list)) + " T-system(s)")
        eprintln("  primary integrator: " + PRIMARY_INTEGRATOR + ", t_end=" + to_string(VERIFY_T_END) + "s, dt=" + to_string(VERIFY_DT) + "s")
        eprintln("  scaling: K12 / (c0/60)^" + to_string(cfg["k12_exp"]) + ", K_CLOSE / (c0/60)^" + to_string(cfg["k_close_exp"]))
    }

    let per_t = {}
    let mut i = 0
    while i < len(ts_list) {
        let t = ts_list[i]
        let r = calibrate_t(t, VERIFY_T_END, VERIFY_DT, cfg["k12_exp"], cfg["k_close_exp"])
        per_t[to_string(t)] = r
        if !cfg["quiet"] {
            let mut mark = "FAIL"
            if r["pass"] { mark = "PASS" }
            eprintln("    [" + mark + "] T=" + to_string(t) + " yield_t10000=" + to_string(r["verify_yield_at_t10000"]) +
                     " mass_drift_rel=" + to_string(r["verify_mass_drift_rel"]))
        }
        i = i + 1
    }

    let mut overall_pass = len(ts_list) > 0
    i = 0
    while i < len(ts_list) {
        let r = per_t[to_string(ts_list[i])]
        if !r["pass"] { overall_pass = false }
        i = i + 1
    }

    if !cfg["no_emit"] {
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        let ts_iso = utc_iso_now()
        i = 0
        while i < len(ts_list) {
            let row = build_witness_row(per_t, ts_list[i], overall_pass, ts_iso)
            append_file(path, json_encode(row) + "\n")
            i = i + 1
        }
        if !cfg["quiet"] { eprintln("  witness rows (" + to_string(len(ts_list)) + ") appended: " + path) }
    }

    let mut n_pass = 0
    i = 0
    while i < len(ts_list) {
        let r = per_t[to_string(ts_list[i])]
        if r["pass"] { n_pass = n_pass + 1 }
        i = i + 1
    }
    if !cfg["quiet"] {
        let mut overall_label = "FAIL"
        if overall_pass { overall_label = "PASS" }
        eprintln("  TOTAL: " + to_string(n_pass) + "/" + to_string(len(ts_list)) + " T-systems PASS -> overall = " + overall_label)
    }
    let mut sentinel = "__VIROCAPSID_MULTI_T__ FAIL"
    if overall_pass { sentinel = "__VIROCAPSID_MULTI_T__ PASS" }
    println(sentinel)
    if overall_pass { exit(0) }
    exit(1)
}
