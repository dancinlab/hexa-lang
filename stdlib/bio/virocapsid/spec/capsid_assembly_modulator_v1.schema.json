{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hexa-bio/virocapsid/spec/capsid_assembly_modulator_v1.schema.json",
  "title": "capsid_assembly_modulator_v1 — CAM scenario row",
  "description": "One capsid-assembly-modulator scenario row. Sub-axis :> VIROCAPSID (core). Zlotnick mean-field assembly equilibrium under a modulator-induced shift of the per-contact free energy, anchored to Caspar-Klug T-number geometry. In-silico simulator-consistency scope only (AGENTS.tape g8 / f2).",
  "type": "object",
  "required": [
    "schema_version", "scenario", "geometry", "g_contact_baseline_kcal",
    "delta_dg_modulator_kcal", "g_contact_cam_kcal", "c_total",
    "baseline", "modulated", "assembled_fraction_shift", "kinetic_trap_regime"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "capsid_assembly_modulator_v1"},
    "scenario": {"type": "string", "minLength": 1},
    "geometry": {
      "type": "object",
      "required": ["t_number", "n_subunits", "n_pentamers", "n_hexamers",
                   "n_capsomers", "capsomer_polyhedron", "euler_invariant_ok"],
      "properties": {
        "t_number": {"type": "integer", "minimum": 1},
        "n_subunits": {"type": "integer", "minimum": 60},
        "n_pentamers": {"type": "integer", "const": 12},
        "n_hexamers": {"type": "integer", "minimum": 0},
        "n_capsomers": {"type": "integer", "minimum": 12},
        "capsomer_polyhedron": {
          "type": "object",
          "required": ["V", "E", "F"],
          "properties": {
            "V": {"type": "integer", "minimum": 0},
            "E": {"type": "integer", "minimum": 0},
            "F": {"type": "integer", "minimum": 0}
          }
        },
        "euler_invariant_ok": {"const": true}
      }
    },
    "g_contact_baseline_kcal": {"type": "number", "maximum": 0},
    "delta_dg_modulator_kcal": {"type": "number"},
    "g_contact_cam_kcal": {"type": "number"},
    "c_total": {"type": "number", "exclusiveMinimum": 0},
    "baseline": {"$ref": "#/definitions/eqState"},
    "modulated": {"$ref": "#/definitions/eqState"},
    "assembled_fraction_shift": {"type": "number", "minimum": -1, "maximum": 1},
    "kinetic_trap_regime": {"type": "boolean"},
    "honest_scope": {"type": "string"}
  },
  "definitions": {
    "eqState": {
      "type": "object",
      "required": ["c_star", "assembled_fraction"],
      "properties": {
        "c_star": {"type": "number", "exclusiveMinimum": 0},
        "assembled_fraction": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
