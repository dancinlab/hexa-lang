#!hexa strict
// hexa-bio/_hexa_bridge/selftest/ppi_molecular_glue_cross.hexa
//
// hexa-native port of `_python_bridge/module/ppi_molecular_glue_cross.py`
// (T3; importlib/json/math/os/sys — deterministic, no network/time/random).
// CROSS-AXIS G3: PPI sub-axis (:> QUANTUM core) Bogan-Thorn hotspot
// energetics  ──same energetic ledger──▶  MOLECULAR-GLUE sub-axis
// (:> BIFUNCTIONAL expansion-main) cooperative ternary-complex
// feasibility. A glue is the INVERSE PPI problem — disrupting an
// interface vs creating one uses the SAME energetic accounting.
// The .py uses `importlib.util` to load ppi_sim.py + molecular_glue_sim.py.
// For byte-parity in hexa, the imported ppi_sim.interface_profile +
// INTERFACE_PANEL AND molecular_glue_sim.cooperative_ternary +
// BINARY_INSUFFICIENT_CEILING / TERNARY_SUFFICIENT_FLOOR are INLINED
// here — no importlib at hexa level. Witness JSON via compact-build →
// `json_parse` → `py_json2(wv, 0)` preserving .py insertion order.
//
// CPython 3.9 builtin sum() over a LIST is a naive left-fold
// accumulation (NOT Kahan) — reproduced exactly by fsum below.
//
// HONESTY: PASS here = in-silico simulator-CONSISTENCY ONLY (g8/f2) —
// MODEL-LEVEL UNIFICATION of two energetic accountings. NOT a binding-
// affinity, DC50/Dmax, immunogenic or therapeutic-efficacy claim.
// MODEL-LEVEL UNIFICATION != modality-interchangeability claim. CROSS
// != NEW AXIS — both PPI and MOLECULAR-GLUE stay SUB-AXES; core-5
// (QUANTUM · WEAVE · NANOBOT · RIBOZYME · VIROCAPSID) UNCHANGED. No
// quantity derived from the n=6 lattice.

import "_hexa_bridge/module/py_json2.hexa"

// ── helpers (paste-standard set; preserve %width padding from printf) ──────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fmax(a: float, b: float) -> float { if a > b { return a } return b }
// CPython 3.9 builtin sum() over a LIST is a naive left-fold accumulation
// (NOT Kahan-compensated). Reproduced exactly — plain accumulation.
fn fsum(xs: array) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < len(xs) {
        s = s + xs[i]
        i = i + 1
    }
    return s
}

// ── thermodynamic anchors (parallel .py module constants) ──────────────────
let TEMP_K = 310.0
let R_KCAL_PER_MOL_K = 1.987204258e-3
let M_TO_NM = 1.0e9
let K_GLUE_FIXED_nM = 10000.0
let SCHEMA_ID = "ppi_molecular_glue_cross_v1"
let HOTSPOT_DDG_THRESHOLD_KCAL = 2.0

// .py ALPHA_LADDER
let ALPHA_LADDER: array = [2.0, 5.0, 10.0, 25.0, 50.0, 100.0, 200.0, 500.0,
                           1000.0, 1500.0, 2000.0, 3000.0, 5000.0]
let ALPHA_N = 13

// molecular_glue_sim panel-published thresholds + assay concentrations
let BINARY_INSUFFICIENT_CEILING = 0.30
let TERNARY_SUFFICIENT_FLOOR = 0.50
let CONC_TARGET_nM = 1000.0
let CONC_E3_nM = 1000.0
let CONC_GLUE_nM = 1000.0

// ── ppi_sim.interface_profile inlined (only dg_hotspot_cluster needed) ─────
// .py: hotspots = [d for d in ddg if d >= 2.0]; sum via CPython sum() (naive);
//      dg_hotspot_cluster = -sum_hotspot. When the hotspot list is EMPTY,
//      Python sum([]) → int 0, and -0 → int 0 (NOT float). The witness then
//      emits "0" (no ".0") for ppi_hotspot_cluster_kcal_per_mol.

// ── ppi INTERFACE_PANEL lookups ────────────────────────────────────────────
let N_PANEL = 6
fn ppi_name(j: int) -> string {
    if j == 0 { return "bcl2_bh3_groove" }
    if j == 1 { return "bclxl_bh3_groove" }
    if j == 2 { return "mdm2_p53_cleft" }
    if j == 3 { return "kix_coactivator_groove" }
    if j == 4 { return "flat_diffuse_interface" }
    return "strong_hotspot_weak_mimic"
}
fn ppi_iclass(j: int) -> string {
    if j == 0 { return "bh3_helix_groove" }
    if j == 1 { return "bh3_helix_groove" }
    if j == 2 { return "alpha_helix_peptide_cleft" }
    if j == 3 { return "shallow_coactivator_groove" }
    if j == 4 { return "flat_diffuse_interface" }
    return "bh3_helix_groove"
}
fn ppi_precedent(j: int) -> string {
    if j == 0 { return "venetoclax — BH3-mimetic disrupting BCL-2 / BH3 PPI (FDA 2016)" }
    if j == 1 { return "navitoclax (ABT-263) — dual BCL-2/BCL-xL BH3-mimetic PPI inhibitor" }
    if j == 2 { return "p53-helix-cleft PPI modality (deep three-residue hotspot pocket)" }
    if j == 3 { return "shallow coactivator-groove PPI modality (modest hotspot depth)" }
    if j == 4 { return "flat diffuse PPI modality (energy spread over the surface, hotspot-poor)" }
    return "hotspot-rich PPI modality with an insufficient small-molecule mimic"
}
fn ppi_ddg(j: int) -> array {
    if j == 0 { return [4.5, 3.8, 2.6, 1.1, 0.6, 0.4] }
    if j == 1 { return [4.2, 3.5, 2.4, 1.0, 0.7, 0.5] }
    if j == 2 { return [4.8, 3.2, 2.2, 0.9, 0.5] }
    if j == 3 { return [2.5, 2.1, 1.4, 1.2, 0.8, 0.6] }
    if j == 4 { return [1.3, 1.1, 0.9, 0.8, 0.7, 0.6, 0.5] }
    return [4.6, 3.9, 2.8, 1.0, 0.5]
}
fn ppi_mimicry(j: int) -> float {
    if j == 0 { return 0.85 }
    if j == 1 { return 0.80 }
    if j == 2 { return 0.82 }
    if j == 3 { return 0.62 }
    if j == 4 { return 0.55 }
    return 0.30
}

// ── Gibbs conversion (parallel .py _k_d_nM_from_dg) ────────────────────────
// .py: k_d_M = exp(dg / (R * T)); return k_d_M * 1e9
fn k_d_nM_from_dg(dg: float) -> float {
    let k_d_M = exp(dg / (R_KCAL_PER_MOL_K * TEMP_K))
    return k_d_M * M_TO_NM
}

// ── molecular_glue_sim.cooperative_ternary inlined ─────────────────────────
// .py exact op order:
//   g = conc_glue / k_glue ; e = conc_e3 / k_ppi
//   Z = 1.0 + g + e + alpha * g * e
//   f_free = 1/Z ; f_binary_target = g/Z ; f_binary_ppi = e/Z
//   f_ternary = alpha*g*e/Z
// Returns the four state fractions and the glue signature flags.
// Parallel-array result via the row vars below; computed inline per call.

// ── shared row text constants ──────────────────────────────────────────────
let GLUE_DRUG_PRECEDENT = "lenalidomide / thalidomide (CRBN glues, IKZF1/IKZF3; Kronke 2014 · Lu 2014) and indisulam (DCAF15 glue, RBM39; Han 2017 · Uehara 2017)"
let UNIFICATION_NOTE = "Bogan-Thorn hotspot ledger (PPI disruption floor) ≡ K_PPI floor in Guldberg-Waage cooperative ternary mass-action (glue creation) — same energetic ledger, inverse problems"

fn main() {
    println("ppi_molecular_glue_cross — CROSS-AXIS G3")
    println("")
    println("cross:  PPI Bogan-Thorn hotspot ledger  ──same energetic floor──▶")
    println("        MOLECULAR-GLUE cooperative-ternary feasibility")
    println("        disrupting an interface (PPI) vs creating one (glue)")
    println("        uses the SAME energetic accounting (inverse problems)")
    println("")

    println("  real-limit anchor (PPI side)   : Bogan-Thorn hotspot theory")
    println("                                   (Bogan & Thorn, J. Mol. Biol. 280:1, 1998)")
    println("                                   hotspot ddG threshold = " +
            js(HOTSPOT_DDG_THRESHOLD_KCAL) + " kcal/mol")
    println("  real-limit anchor (glue side)  : cooperative ternary mass-action")
    println("                                   (Douglass JACS 135:6092, 2013; Han DDT 25:1832, 2020;")
    println("                                   Guldberg-Waage mass action 1864)")
    println("                                   binary insufficiency ceiling = " +
            js(BINARY_INSUFFICIENT_CEILING))
    println("                                   ternary sufficiency floor    = " +
            js(TERNARY_SUFFICIENT_FLOOR))
    println("")
    println("  fixed K_glue = " + fmt("%.0f", K_GLUE_FIXED_nM) +
            " nM  (modality-typical weak binary; isolates K_PPI as the cross variable)")
    // alpha ladder printed as Python repr of list
    let mut altxt = "["
    let mut ai0 = 0
    while ai0 < ALPHA_N {
        if ai0 > 0 { altxt = altxt + ", " }
        altxt = altxt + js(ALPHA_LADDER[ai0])
        ai0 = ai0 + 1
    }
    altxt = altxt + "]"
    println("  alpha ladder = " + altxt)
    println("")

    // ── build cross rows (parallel-array storage) ──────────────────────────
    let mut row_iface: array = []
    let mut row_iclass: array = []
    let mut row_ppi_prec: array = []
    let mut row_n_hot: array = []
    let mut row_dg_hot: array = []
    let mut row_dg_hot_isint: array = []   // true → emit "0" (Python int 0)
    let mut row_h_frac: array = []
    let mut row_hot_driven: array = []
    let mut row_kd_eff: array = []
    let mut row_alpha_req: array = []
    let mut row_fbt: array = []
    let mut row_fbp: array = []
    let mut row_ftn: array = []
    let mut row_achievable: array = []
    let mut row_floor_ok: array = []

    let mut i = 0
    while i < N_PANEL {
        // (1) PPI hotspot ledger (ppi_sim.interface_profile inlined)
        let ddg = ppi_ddg(i)
        let mut hot_arr: array = []
        let mut k = 0
        while k < len(ddg) {
            if ddg[k] >= HOTSPOT_DDG_THRESHOLD_KCAL { hot_arr.push(ddg[k]) }
            k = k + 1
        }
        let s_all = fsum(ddg)
        let s_hot = fsum(hot_arr)
        let n_hot = len(hot_arr)
        let hf = if s_all > 0.0 { s_hot / s_all } else { 0.0 }
        // dg_hotspot_cluster = -sum_hotspot; Python sum([]) → int 0, -0 → int 0
        let hot_empty = n_hot == 0
        let dg_hot = if hot_empty { 0.0 } else { -s_hot }
        let dg_iface = -s_all
        let driven = (hf >= 0.5) && (n_hot >= 2)

        // (2) Effective K_PPI via Gibbs. When dg_hot is Python int 0,
        // exp(0/rt) = exp(0.0) = 1.0 → k_ppi_effective = 1e9 exactly.
        let kd_eff = k_d_nM_from_dg(dg_hot)

        // (3) Sweep the alpha ladder for the smallest alpha clearing the
        // cooperative-ternary glue signature.
        let g = CONC_GLUE_nM / K_GLUE_FIXED_nM
        let e = CONC_E3_nM / kd_eff
        let mut alpha_req = 0.0
        let mut fbt = 0.0
        let mut fbp = 0.0
        let mut ftn = 0.0
        let mut achievable = false
        let mut li = 0
        while li < ALPHA_N {
            let alpha = ALPHA_LADDER[li]
            let Z = 1.0 + g + e + alpha * g * e
            let f_bt = g / Z
            let f_bp = e / Z
            let f_tn = alpha * g * e / Z
            let bt_low = f_bt < BINARY_INSUFFICIENT_CEILING
            let bp_low = f_bp < BINARY_INSUFFICIENT_CEILING
            let tn_high = f_tn > TERNARY_SUFFICIENT_FLOOR
            let sig = bt_low && bp_low && tn_high
            if !achievable && sig {
                alpha_req = alpha
                fbt = f_bt
                fbp = f_bp
                ftn = f_tn
                achievable = true
            }
            li = li + 1
        }
        // If no alpha within the ladder clears the gate, evaluate at the
        // ladder maximum so the row still carries diagnostic occupancies.
        if !achievable {
            let alpha = ALPHA_LADDER[ALPHA_N - 1]
            let Z = 1.0 + g + e + alpha * g * e
            fbt = g / Z
            fbp = e / Z
            ftn = alpha * g * e / Z
            alpha_req = ALPHA_LADDER[ALPHA_N - 1]
        }

        // real-limit ledger respect (Bogan-Thorn floor)
        let ppi_floor_ok = fabs(dg_hot) <= fabs(dg_iface) + 1e-9

        row_iface.push(ppi_name(i))
        row_iclass.push(ppi_iclass(i))
        row_ppi_prec.push(ppi_precedent(i))
        row_n_hot.push(n_hot)
        row_dg_hot.push(dg_hot)
        row_dg_hot_isint.push(hot_empty)
        row_h_frac.push(hf)
        row_hot_driven.push(driven)
        row_kd_eff.push(kd_eff)
        row_alpha_req.push(alpha_req)
        row_fbt.push(fbt)
        row_fbp.push(fbp)
        row_ftn.push(ftn)
        row_achievable.push(achievable)
        row_floor_ok.push(ppi_floor_ok)

        // print panel lines (parallels .py main loop)
        let ach = if achievable { "achievable" } else { "NOT achievable within ladder" }
        println("  [" + ljust(ppi_name(i), 26) + "] hotspots=" + str(n_hot) +
                "  ΔG_hotspot=" + fmt("%+6.2f", dg_hot) + " kcal/mol")
        println("      K_PPI_eff=" + fmt("%.3e", kd_eff) + " nM   α_required=" +
                fmt("%.0f", alpha_req) + "   f_ternary=" + fmt("%.3f", ftn) +
                "   (" + ach + ")")
        i = i + 1
    }

    // ── acceptance criteria (X1..X6) ───────────────────────────────────────
    // X1 — one row per PPI panel entry
    let x1 = (N_PANEL == 6)
    // X2 — every effective K_PPI finite and positive
    let mut x2 = true
    let mut k2 = 0
    while k2 < N_PANEL { if !(row_kd_eff[k2] > 0.0) { x2 = false }; k2 = k2 + 1 }
    // X3 — ppi floor respected on every row
    let mut x3 = true
    let mut k3 = 0
    while k3 < N_PANEL { if !row_floor_ok[k3] { x3 = false }; k3 = k3 + 1 }
    // X4 — alpha monotone with hotspot floor. Sort rows by dg_hot ascending
    // (more negative = hotspot-richer); alpha_required must be non-decreasing.
    let mut sidx: array = []
    let mut si = 0
    while si < N_PANEL { sidx.push(si); si = si + 1 }
    // insertion sort by row_dg_hot ascending (CPython sorted() is stable)
    let mut a = 1
    while a < N_PANEL {
        let key = sidx[a]
        let mut b = a - 1
        while b >= 0 && row_dg_hot[sidx[b]] > row_dg_hot[key] {
            sidx[b + 1] = sidx[b]
            b = b - 1
        }
        sidx[b + 1] = key
        a = a + 1
    }
    let mut x4 = true
    let mut m = 0
    while m < N_PANEL - 1 {
        let ra = sidx[m]
        let rb = sidx[m + 1]
        if row_dg_hot[ra] < row_dg_hot[rb] {
            if row_alpha_req[ra] > row_alpha_req[rb] { x4 = false }
        }
        m = m + 1
    }
    // X5 — discriminating gate: >=1 achievable AND >=1 not achievable
    let mut n_ach = 0
    let mut n_not = 0
    let mut k5 = 0
    while k5 < N_PANEL {
        if row_achievable[k5] { n_ach = n_ach + 1 } else { n_not = n_not + 1 }
        k5 = k5 + 1
    }
    let x5 = (n_ach >= 1) && (n_not >= 1)
    // X6 — bridge agrees with sister thresholds for achievable rows
    let mut x6 = true
    let mut k6 = 0
    while k6 < N_PANEL {
        if row_achievable[k6] {
            if !(row_fbt[k6] < BINARY_INSUFFICIENT_CEILING) { x6 = false }
            if !(row_fbp[k6] < BINARY_INSUFFICIENT_CEILING) { x6 = false }
            if !(row_ftn[k6] > TERNARY_SUFFICIENT_FLOOR) { x6 = false }
        }
        k6 = k6 + 1
    }

    let crit_keys = ["X1_one_row_per_ppi_panel_entry",
                     "X2_k_ppi_effective_finite_positive",
                     "X3_ppi_floor_respected",
                     "X4_alpha_monotone_with_hotspot_floor",
                     "X5_discriminating_gate_both_outcomes_present",
                     "X6_bridge_agrees_with_sister_thresholds"]
    let crit_vals = [x1, x2, x3, x4, x5, x6]
    let total_crit = 6
    let mut n_pass = 0
    let mut ci = 0
    while ci < total_crit { if crit_vals[ci] { n_pass = n_pass + 1 }; ci = ci + 1 }
    let verdict = if n_pass == total_crit { "PASS" } else { "FAIL" }

    println("")
    println("## acceptance — in-silico simulator-consistency criteria")
    let mut pi2 = 0
    while pi2 < total_crit {
        let tag = if crit_vals[pi2] { "PASS" } else { "FAIL" }
        println("  [" + tag + "] " + crit_keys[pi2])
        pi2 = pi2 + 1
    }
    println("")
    println("  --- " + str(n_pass) + "/" + str(total_crit) + "  →  verdict: " + verdict + " ---")

    println("")
    println("## honesty (g3 / g8 / f1 / f2 / f3)")
    println("  - Both sims IMPORTED, never re-implemented (f3). ppi_sim.")
    println("    interface_profile() and molecular_glue_sim.cooperative_ternary()")
    println("    are reused verbatim; the cross only bridges their outputs via the")
    println("    standard Gibbs relation K_d = exp(dG/RT).")
    println("  - The PPI ddG values and the K_glue / alpha values are illustrative")
    println("    literature-informed surrogates for the modality CLASSES (each")
    println("    parent sim's own honesty caveat). No claim sharper than either")
    println("    parent permits is made here.")
    println("  - This is a MODEL-LEVEL UNIFICATION of two energetic accountings —")
    println("    NOT a claim that every PPI is glue-able or vice versa. The two")
    println("    modalities have distinct mechanistic requirements (E3 ligase")
    println("    surface, ubiquitin handling) outside this energetic ledger.")
    println("  - Modality precedents are own-precedent only (g3 / f1 / f_lattice_fit):")
    println("    PPI side  — venetoclax (BCL-2/BH3 disruptor, FDA 2016) and")
    println("                navitoclax / ABT-263 (dual BCL-2/BCL-xL).")
    println("    Glue side — lenalidomide / thalidomide (CRBN glues, IKZF1/IKZF3,")
    println("                FDA-approved) and indisulam (DCAF15 glue, RBM39).")
    println("  - PASS certifies IN-SILICO simulator-CONSISTENCY ONLY (g8 / f2) —")
    println("    NOT a binding-affinity, degradation (DC50 / Dmax), immunogenicity")
    println("    or therapeutic-efficacy claim. No quantity is derived from the")
    println("    n=6 lattice. The cross is NOT a new axis — AXIS/HIERARCHY.tape")
    println("    unchanged; PPI :> QUANTUM core, MOLECULAR-GLUE :> BIFUNCTIONAL")
    println("    expansion-main are existing sub-axes.")

    // ── witness JSON (compact build → json_parse → py_json2 indent=2) ──────
    // alpha ladder array
    let mut alphaj = "["
    let mut aj = 0
    while aj < ALPHA_N {
        if aj > 0 { alphaj = alphaj + ", " }
        alphaj = alphaj + js(ALPHA_LADDER[aj])
        aj = aj + 1
    }
    alphaj = alphaj + "]"

    // rows array — exact .py build_cross_rows() insertion order
    let mut rowsJ = ""
    let mut wi = 0
    while wi < N_PANEL {
        if wi > 0 { rowsJ = rowsJ + ", " }
        // dg_hot: emit "0" when Python int 0 (empty hotspot list)
        let dg_hot_emit = if row_dg_hot_isint[wi] { "0" } else { js(row_dg_hot[wi]) }
        rowsJ = rowsJ + "{" +
            "\"schema\": " + json_stringify(SCHEMA_ID) +
            ", \"interface\": " + json_stringify(row_iface[wi]) +
            ", \"interface_class\": " + json_stringify(row_iclass[wi]) +
            ", \"ppi_drug_precedent\": " + json_stringify(row_ppi_prec[wi]) +
            ", \"glue_drug_precedent\": " + json_stringify(GLUE_DRUG_PRECEDENT) +
            ", \"n_hotspot_residues\": " + str(row_n_hot[wi]) +
            ", \"ppi_hotspot_cluster_kcal_per_mol\": " + dg_hot_emit +
            ", \"ppi_hotspot_energy_fraction\": " + js(row_h_frac[wi]) +
            ", \"ppi_hotspot_driven\": " + jsb(row_hot_driven[wi]) +
            ", \"temperature_K\": " + js(TEMP_K) +
            ", \"k_ppi_effective_nM\": " + js(row_kd_eff[wi]) +
            ", \"k_glue_nM\": " + js(K_GLUE_FIXED_nM) +
            ", \"alpha_required_for_glue_signature\": " + js(row_alpha_req[wi]) +
            ", \"alpha_search_max\": " + js(ALPHA_LADDER[ALPHA_N - 1]) +
            ", \"f_binary_target_at_required_alpha\": " + js(row_fbt[wi]) +
            ", \"f_binary_ppi_at_required_alpha\": " + js(row_fbp[wi]) +
            ", \"f_ternary_at_required_alpha\": " + js(row_ftn[wi]) +
            ", \"glue_signature_achievable\": " + jsb(row_achievable[wi]) +
            ", \"ppi_floor_respected\": " + jsb(row_floor_ok[wi]) +
            ", \"unification_note\": " + json_stringify(UNIFICATION_NOTE) +
            ", \"illustrative_only\": true" +
            "}"
        wi = wi + 1
    }

    // acceptance object (insertion order: criteria, pass_count, total, verdict)
    let crit_j = "{" +
        "\"X1_one_row_per_ppi_panel_entry\": " + jsb(x1) +
        ", \"X2_k_ppi_effective_finite_positive\": " + jsb(x2) +
        ", \"X3_ppi_floor_respected\": " + jsb(x3) +
        ", \"X4_alpha_monotone_with_hotspot_floor\": " + jsb(x4) +
        ", \"X5_discriminating_gate_both_outcomes_present\": " + jsb(x5) +
        ", \"X6_bridge_agrees_with_sister_thresholds\": " + jsb(x6) +
        "}"
    let acc_j = "{" +
        "\"criteria\": " + crit_j +
        ", \"pass_count\": " + str(n_pass) +
        ", \"total\": " + str(total_crit) +
        ", \"verdict\": " + json_stringify(verdict) +
        "}"

    // witness top-level — exact .py witness dict insertion order
    let witness = "{" +
        "\"schema\": " + json_stringify(SCHEMA_ID) +
        ", \"ts\": \"2026-05-16T00:00:00Z\"" +
        ", \"cross\": " + json_stringify("G3  PPI Bogan-Thorn hotspot ledger  ->  MOLECULAR-GLUE cooperative-ternary feasibility") +
        ", \"ppi_subaxis_source\": " + json_stringify("_python_bridge/module/ppi_sim.py (interface_profile imported; INTERFACE_PANEL reused — f3)") +
        ", \"molecular_glue_subaxis_source\": " + json_stringify("_python_bridge/module/molecular_glue_sim.py (cooperative_ternary imported — f3)") +
        ", \"real_limit_anchor_ppi\": " + json_stringify("Bogan-Thorn binding-hotspot theory (Bogan & Thorn, Anatomy of hot spots in protein interfaces, J. Mol. Biol. 280:1, 1998) — interface energy concentrated in hotspot residues; recoverable energy bounded by the alanine-scanning ddG ledger") +
        ", \"real_limit_anchor_glue\": " + json_stringify("cooperative ternary-complex equilibrium (Douglass et al., JACS 135:6092, 2013; Han, Drug Discov. Today 25:1832, 2020) atop the Guldberg-Waage law of mass action (1864) — occupancies <= 1.0") +
        ", \"temperature_K\": " + js(TEMP_K) +
        ", \"R_kcal_per_mol_K\": " + js(R_KCAL_PER_MOL_K) +
        ", \"k_glue_fixed_nM\": " + js(K_GLUE_FIXED_nM) +
        ", \"alpha_ladder\": " + alphaj +
        ", \"rows\": [" + rowsJ + "]" +
        ", \"acceptance\": " + acc_j +
        ", \"unification_demonstrated\": " + json_stringify("PPI inhibitors disrupt an interface; molecular glues create one; both are governed by the SAME Bogan-Thorn hotspot ledger plus Guldberg-Waage mass action. The hotspot ledger is the FLOOR a glue-induced neo-interface cannot beat — a hotspot-poor PPI yields a weak K_PPI_effective and the glue signature requires higher cooperativity alpha (or is not achievable within sane alpha); a hotspot-rich PPI yields a tight K_PPI_effective and the glue signature emerges at modest alpha") +
        ", \"modality_interchangeability_claim\": false" +
        ", \"in_silico_scope_caveat\": " + json_stringify("simulator-consistency ONLY (g8/f2) — NOT a binding-affinity, degradation-potency (DC50/Dmax), immunogenicity or therapeutic-efficacy claim. MODEL-LEVEL UNIFICATION of two energetic accountings, NOT a claim that every PPI is glue-able or vice versa. PPI :> QUANTUM core; MOLECULAR-GLUE :> BIFUNCTIONAL expansion-main — cross is NOT a new axis") +
        "}"

    let wv = json_parse(witness)
    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))

    println("")
    if verdict == "PASS" { println("__PPI_MOLECULAR_GLUE_CROSS__ PASS") } else { println("__PPI_MOLECULAR_GLUE_CROSS__ FAIL"); exit(1) }
}
