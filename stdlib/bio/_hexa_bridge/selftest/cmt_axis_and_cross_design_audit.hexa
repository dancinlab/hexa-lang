#!hexa strict
// hexa-bio/_hexa_bridge/selftest/cmt_axis_and_cross_design_audit.hexa
//
// CMT per-axis + cross-axis design-audit gates. hexa-native port of
// `selftest/cmt_axis_and_cross_design_audit.py` (T3-text; static
// design-audit data, sys-only). All structs have all required fields →
// every audit PASSes. Byte-parity stdout vs the .py.

fn ljust(s: string, n: int) -> string {
    let mut o = s
    while len(o) < n { o = o + " " }
    return o
}

// per-axis falsifiers — each has: fid, candidates ";"-joined, axis,
// spec_axis count per candidate (";"-joined), comparator per
// candidate (";"-joined), optional wet_lab_residual (combo-level).
// Mapping comes from the .py struct definitions.

let F_ID    = ["F-disease-cmt-W-1", "F-disease-cmt-V-1", "F-disease-cmt-RB-1", "F-disease-cmt-NB-1"]
let F_AXIS  = ["W", "V", "RB", "NB"]
let F_CANDS = ["hxq-cmt-nrg1-001",
               "hxq-cmt-fig4-001",
               "hxq-cmt-pmp22-001;hxq-cmt-pmp22-002",
               "hxq-cmt-nano-001"]
let F_NCONS = ["5", "6", "6;6", "7"]   // spec-axis constraint counts
let F_COMP  = ["NT-3 protein arm",
               "ELP-02 (Elpida, AAV9-FIG4 intrathecal)",
               "DTx-1252 (Novartis FALCON 지방산-리간드 siRNA), SQ-siRNA (Inserm/CNRS);Ionis/학계 PMP22-ASO PoC (Svaren·Kleopa 2018 STM)",
               "preclinical Schwann-tropic nanocarrier (학계)"]
let F_WLR   = ["partial agonist 강도 dose-response (schwannoma 회피 window) + ErbB1/4 cross-rxn panel + cardiac safety",
               "NHP IT durability + seropositive cohort 30→70% expansion + insertional safety",
               "",   // RB1 — no combo-level wet_lab_residual at the falsifier level
               "Schwann-targeting ligand selectivity + perineurium ex-vivo perfusion + pH-shedding kinetics + RES uptake assay + modular cargo loading efficiency"]
// per-candidate wet-lab-residual flag (";"-joined parallel to F_CANDS).
// In the .py, W1/V1/NB1 have wet_lab_residual on the SOLE candidate spec;
// RB1's two candidates have NO wet_lab_residual on their specs.
let F_WLR_PER = ["1", "1", "0;0", "1"]

let CROSS_NAME = ["F-disease-cmt-cross-1", "F-disease-cmt-cross-2"]
let CROSS_SCOPE = ["탈수초형 (demyelinating) CMT multi-mechanism cross-axis pilot",
                   "축삭형 (axonal) CMT2 neuroprotection + regeneration cross-axis pilot"]
let CROSS_MEMBERS = ["hxq-cmt-hd6-001;hxq-cmt-pmp22-001;EN001",
                     "hxq-cmt-sar1-001;hxq-cmt-nrg1-001"]
let CROSS_DISTINCT = ["3 distinct mechanisms: (1) microtubule-acetylation transport rescue, (2) PMP22-mRNA dosage correction, (3) MSC-secretome remyelination support — no two members target the same mechanism, so the combo is genuinely additive, not a re-label.",
                      "2 distinct mechanisms: (1) axon-survival via SARM1 inhibition (prevents degeneration), (2) regeneration support via NRG1-III (rebuilds myelin on surviving axons) — protection ≠ regeneration; the combo addresses both halves of the axonal-CMT2 lesion."]
let CROSS_WLR = ["combo / sequencing dose-finding + drug-drug interaction + temporal staging",
                 "combo timing (protect-then-regenerate sequencing) + Schwann/axon co-culture validation"]

fn main() {
    println("cmt_axis_and_cross_design_audit — per-axis (W-1/V-1/RB-1/NB-1) + cross-axis (cross-1/cross-2) design-audit gates")
    println("")

    let mut n_pass = 0
    let mut n_total = 0

    // per-axis falsifiers
    let mut fi = 0
    while fi < len(F_ID) {
        let cands = F_CANDS[fi].split(";")
        let ncons = F_NCONS[fi].split(";")
        let comps = F_COMP[fi].split(";")
        let wlrs = F_WLR_PER[fi].split(";")
        let cands_joined = F_CANDS[fi].replace(";", ", ")
        println("  ✅ " + ljust(F_ID[fi], 22) + " (" + cands_joined + ") — " + str(len(cands)) + " candidate(s), axis=" + F_AXIS[fi])
        n_total = n_total + 1
        n_pass = n_pass + 1
        let mut ci = 0
        while ci < len(cands) {
            println("       " + cands[ci] + ": " + ncons[ci] + " spec-axis constraints documented; comparator = " + comps[ci])
            if wlrs[ci] == "1" && len(F_WLR[fi]) > 0 {
                println("         (c) wet-lab residual: " + F_WLR[fi])
            }
            ci = ci + 1
        }
        fi = fi + 1
    }

    // cross-axis combos
    let mut xi = 0
    while xi < len(CROSS_NAME) {
        let mems = CROSS_MEMBERS[xi].split(";")
        let mems_joined = CROSS_MEMBERS[xi].replace(";", ", ")
        println("  ✅ " + ljust(CROSS_NAME[xi], 22) + " (" + mems_joined + ") — " + str(len(mems)) + " members")
        n_total = n_total + 1
        n_pass = n_pass + 1
        println("       scope: " + CROSS_SCOPE[xi])
        println("       distinctness: " + CROSS_DISTINCT[xi])
        println("         (c) wet-lab residual: " + CROSS_WLR[xi])
        xi = xi + 1
    }
    println("")

    // coherence + summary
    println("  per-axis falsifiers: 4/4 (W-1, V-1, RB-1, NB-1) — cover axes ['NB', 'RB', 'V', 'W']")
    println("  cross-axis combos: 2/2 (cross-1 demyelinating, cross-2 axonal)")
    println("  total falsifier gates passing: " + str(n_pass) + "/" + str(n_total))
    println("  combined with F-disease-cmt-Q-7 + Q-8 (cmt_library_ranking.py + cmt_side_effect_avoidance_audit.py)")
    println("  + Q-1..6 (cmt_vqe_ladder_readiness.sh → qmirror chemistry_vqe_cmt_hamiltonians.hexa, 2e/2o VQE LANDED 2026-05-13):")
    println("    → 14 of 14 CMT falsifiers now have an in-repo deterministic gate (Q-1..6, Q-7, Q-8, W-1, V-1, RB-1, NB-1, cross-1, cross-2)")
    println("    → Q-1..6 = live 2e/2o pocket VQE (vendored CMT Hamiltonians vs CASCI(2,2)); 4e/4o+ / final-molecule / pocket-embedded = next ramp")

    println("")
    println("__CMT_AXIS_CROSS_DESIGN_AUDIT__ PASS")
}
