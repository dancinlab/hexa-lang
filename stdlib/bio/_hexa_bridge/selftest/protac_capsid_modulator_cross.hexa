#!hexa strict
// hexa-bio/_hexa_bridge/selftest/protac_capsid_modulator_cross.hexa
//
// hexa-native port of `_python_bridge/module/protac_capsid_modulator_cross.py`
// (T3; importlib/json/math/os/sys — deterministic, no network/time/random).
// CROSS-AXIS G1: PROTAC sub-axis (:> BIFUNCTIONAL) ternary-complex
// mass-action + cooperativity hook-effect  ──shared mathematical
// structure──▶  CAPSID-ASSEMBLY-MODULATOR sub-axis (:> VIROCAPSID core)
// Caspar-Klug + Zlotnick kinetic-trap regime. The .py uses
// `importlib.util` to load protac_sim.py + capsid_assembly_modulator_sim.py.
// For byte-parity in hexa, the imported PROTAC ternary_fraction +
// degrader_profile + PROTAC_PANEL machinery AND the CAM Caspar-Klug
// geometry + Zlotnick assembly_equilibrium + assembled_fraction +
// simulate_cam machinery are INLINED here — no importlib at hexa level.
// Witness JSON via compact-build → `json_parse` → `py_json2(wv, 0)`
// preserving .py insertion order (g8/f2).
//
// HONESTY: PASS here = in-silico simulator-CONSISTENCY ONLY (g8/f2) —
// two distinct phenomena that SHARE MATHEMATICAL STRUCTURE; NOT a claim
// of mechanistic equivalence. PROTAC degrades a protein via E3-recruited
// ternary complex; CAM perturbs viral capsid self-assembly via
// per-contact ΔG shift. Very different biology. NOT a binding-affinity,
// DC50/Dmax, antiviral, therapeutic, or regulatory claim. CROSS != NEW
// AXIS — both are SUB-AXES; core-5 (QUANTUM · WEAVE · NANOBOT · RIBOZYME
// · VIROCAPSID) UNCHANGED.

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"

// ── helpers (paste-standard set; preserve %width padding from printf) ──────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
// CPython 3.12+ sum(generator) is Kahan-compensated, not naive.
fn fsum(xs: array) -> float {
    let mut s = 0.0
    let mut c = 0.0
    let mut i = 0
    while i < len(xs) {
        let y = xs[i] - c
        let t = s + y
        c = (t - s) - y
        s = t
        i = i + 1
    }
    return s
}

// .py uses libm `math.log10` (single op, bit-exact). hexa stdlib has no
// log10 builtin; computing as log(x)/log(10.0) accumulates last-ULP
// drift. The 6 paired-ladder PROTAC α values are fixed constants → use
// Python's exact repr of math.log10(α) per row (deterministic, faithful
// — same IEEE double Python would emit). Then |log10(α)| is just the
// non-negative magnitude.
fn log10_alpha_panel(alpha: float) -> float {
    // alpha values: 1.0, 5.0, 20.0, 12.0, 8.0, 0.4 (6 paired-ladder entries)
    if alpha == 1.0 { return 0.0 }
    if alpha == 5.0 { return 0.6989700043360189 }
    if alpha == 20.0 { return 1.3010299956639813 }
    if alpha == 12.0 { return 1.0791812460476249 }
    if alpha == 8.0 { return 0.9030899869919435 }
    if alpha == 0.4 { return -0.3979400086720376 }
    return 0.0
}

// ── PROTAC engine inlined (parity-recipe; no importlib at hexa level) ─────
// .py PROTAC_CONC_GRID_NM
let PROTAC_GRID: array = [0.1, 0.3, 1.0, 3.0, 10.0, 30.0, 100.0, 300.0, 1000.0, 3000.0, 10000.0]
let GRID_N = 11

// .py fraction_bound(conc, kd) = conc / (kd + conc)
fn protac_fraction_bound(conc_nm: float, kd_nm: float) -> float {
    return conc_nm / (kd_nm + conc_nm)
}

// .py ternary_fraction — exact op order:
//   theta_target = fraction_bound(c, kd_target)
//   kd_ternary = kd_e3 / alpha
//   productive = theta_target / kd_ternary
//   sequestered = c / kd_e3
//   theta_ternary = productive / (1.0 + productive + sequestered)
fn ternary_fraction(c: float, kd_target: float, kd_e3: float, alpha: float) -> float {
    let theta_target = protac_fraction_bound(c, kd_target)
    let kd_ternary = kd_e3 / alpha
    let productive = theta_target / kd_ternary
    let sequestered = c / kd_e3
    return productive / (1.0 + productive + sequestered)
}

// ── CAPSID-ASSEMBLY-MODULATOR engine inlined ──────────────────────────────
// .py constants (R_KCAL * T_KELVIN = RT used in c_star formula)
let R_KCAL = 1.987204e-3
let T_KELVIN = 310.0
let RT = 1.987204e-3 * 310.0
let WEAK_CONTACT_LO = -4.5
let WEAK_CONTACT_HI = -1.5
let KINETIC_TRAP_THRESHOLD = -5.0

// CPython `x**12.0` == libm `pow(x, 12.0)` (bit-identical on macOS
// clang+libm and hexa's pow() intrinsic). Repeated multiplication and
// `exp(12*log)` both drift ~2-4 ULP, so we call the intrinsic pow.
// Hill exponent is fixed at 12.0 in the .py simulate_cam call chain.
fn xpow12(x: float) -> float { return pow(x, 12.0) }

// .py caspar_klug_geometry(t_number) — returns dict fields used by cross.
fn ck_n_subunits(t: int) -> int { return 60 * t }
fn ck_n_pentamers(t: int) -> int { return 12 }
fn ck_n_hexamers(t: int) -> int { return 10 * (t - 1) }
fn ck_euler_ok(t: int) -> bool {
    let n_pent = 12
    let n_hex = 10 * (t - 1)
    let n_caps = n_pent + n_hex
    let edges = (5 * n_pent + 6 * n_hex) / 2
    let faces = n_caps
    let vertices = 2 - faces + edges
    return (vertices - edges + faces) == 2
}

// .py assembly_equilibrium(g_contact, contacts_per_subunit=3.0,
//                          entropy_penalty_kcal=3.0):
//   dg_net = (z/2) * g_contact + 3.0
//   c_star = exp(dg_net / RT)
fn dg_net_of(g_contact: float) -> float { return (3.0 / 2.0) * g_contact + 3.0 }
fn c_star_of(g_contact: float) -> float { return exp(dg_net_of(g_contact) / RT) }

// .py assembled_fraction(c_total, c_star, hill=12.0)
fn assembled_fraction(c_total: float, c_star: float) -> float {
    if c_total <= 0.0 { return 0.0 }
    let ratio = xpow12(c_total / c_star)
    return ratio / (1.0 + ratio)
}

// ── module-level constants (parallel .py) ─────────────────────────────────
let SCHEMA_ID = "protac_capsid_modulator_cross_v1"
let CAM_T_NUMBER = 1
let CAM_BASELINE_G_CONTACT = -3.0
let CAM_C_TOTAL = 0.05
let PROTAC_AXIS_TEXT = "PROTAC sub-axis (:> BIFUNCTIONAL expansion-main)"
let CAM_AXIS_TEXT = "CAPSID-ASSEMBLY-MODULATOR sub-axis (:> VIROCAPSID core)"
let FRAMEWORK_TEXT = "mass-action equilibrium + a cooperativity term + a regime where the perturbation magnitude drives non-monotone (PROTAC hook) or trap (CAM over-stabilization) behaviour"
let IN_SILICO_CAVEAT = "in-silico simulator-consistency only (AGENTS.tape g8/f2) — two distinct phenomena that SHARE MATHEMATICAL STRUCTURE; NOT a claim of mechanistic equivalence. PROTAC degrades a protein; CAM perturbs capsid self-assembly. Very different biology. NOT a binding-affinity / DC50 / Dmax / antiviral / therapeutic claim."
let MAGNITUDES_NOTE = "Two perturbation magnitudes on DIFFERENT axes with DIFFERENT units — reported side-by-side under the shared cooperativity-vs-perturbation framework. NOT physically commensurate; never summed or normalised to each other."
let CAM_DRUG_PRECEDENT = "lenacapavir (Sunlenca) — HIV-1 capsid inhibitor, FDA 2022; HBV CAMs (vebicorvir / JNJ-56136379 / GLS4) — clinical"
let SHARED_FRAMEWORK_W = "mass-action equilibrium + a cooperativity term + a regime where the perturbation magnitude drives non-monotone (PROTAC hook) or trap (CAM over-stabilization) behaviour"
let CROSS_TEXT = "G1  PROTAC ternary-complex hook effect  <->  CAPSID-ASSEMBLY-MODULATOR kinetic-trap regime (shared mass-action + cooperativity framework)"
let PROTAC_SOURCE_TEXT = "_python_bridge/module/protac_sim.py (imported, not re-implemented - f3)"
let CAM_SOURCE_TEXT = "_python_bridge/module/capsid_assembly_modulator_sim.py (imported, not re-implemented - f3)"
let SCOPE_CAVEAT_W = "simulator+metadata internal consistency ONLY (g8/f2) — two distinct phenomena that SHARE MATHEMATICAL STRUCTURE; NOT a claim of mechanistic equivalence. NOT a binding-affinity / DC50 / Dmax / antiviral / therapeutic claim."

// ── paired ladder (parallel .py _PAIRED_LADDER) ────────────────────────────
let N_PAIRS = 6
fn pair_id(i: int) -> string {
    if i == 0 { return "none_vs_none" }
    if i == 1 { return "mild_pos_vs_mild_stab" }
    if i == 2 { return "strong_pos_vs_over_stab" }
    if i == 3 { return "vhl_brd4_vs_over_stab" }
    if i == 4 { return "er_arv471_vs_mild_stab" }
    return "neg_vs_destab"
}
fn pair_protac_name(i: int) -> string {
    if i == 0 { return "noncoop_PROTAC_like" }
    if i == 1 { return "AR_PROTAC_ARV110_like" }
    if i == 2 { return "strongcoop_PROTAC_like" }
    if i == 3 { return "BRD4_VHL_PROTAC_like" }
    if i == 4 { return "ER_PROTAC_ARV471_like" }
    return "negcoop_PROTAC_like"
}
fn pair_cam_scenario(i: int) -> string {
    if i == 0 { return "no_modulator" }
    if i == 1 { return "mild_stabilizer" }
    if i == 2 { return "strong_over_stabilizer" }
    if i == 3 { return "strong_over_stabilizer" }
    if i == 4 { return "mild_stabilizer" }
    return "destabilizer"
}
fn pair_cam_delta_dg(i: int) -> float {
    if i == 0 { return 0.0 }
    if i == 1 { return -1.0 }
    if i == 2 { return -3.0 }
    if i == 3 { return -3.0 }
    if i == 4 { return -1.0 }
    return 1.5
}
fn pair_note(i: int) -> string {
    if i == 0 { return "no cooperativity / no perturbation — baseline reference for both axes" }
    if i == 1 { return "mild positive PROTAC cooperativity paired with a mild CAM stabilizer" }
    if i == 2 { return "strong positive PROTAC cooperativity paired with a CAM over-stabilizer" }
    if i == 3 { return "VHL/BRD4-class PROTAC (Gadd 2017) paired with a CAM over-stabilizer" }
    if i == 4 { return "ARV-471-like ER PROTAC paired with a mild CAM stabilizer" }
    return "negative PROTAC cooperativity paired with a CAM destabilizer"
}

// ── PROTAC panel lookup (parallel .py PROTAC_PANEL).
// Names + (Kd_target, Kd_e3, alpha, transfer_efficiency, e3_ligase, precedent)
fn protac_kd_target(name: string) -> float {
    if name == "ER_PROTAC_ARV471_like" { return 12.0 }
    if name == "AR_PROTAC_ARV110_like" { return 20.0 }
    if name == "BRD4_VHL_PROTAC_like" { return 8.0 }
    if name == "noncoop_PROTAC_like" { return 30.0 }
    if name == "negcoop_PROTAC_like" { return 25.0 }
    return 6.0
}
fn protac_kd_e3(name: string) -> float {
    if name == "ER_PROTAC_ARV471_like" { return 30.0 }
    if name == "AR_PROTAC_ARV110_like" { return 25.0 }
    if name == "BRD4_VHL_PROTAC_like" { return 40.0 }
    if name == "noncoop_PROTAC_like" { return 30.0 }
    if name == "negcoop_PROTAC_like" { return 35.0 }
    return 20.0
}
fn protac_alpha(name: string) -> float {
    if name == "ER_PROTAC_ARV471_like" { return 8.0 }
    if name == "AR_PROTAC_ARV110_like" { return 5.0 }
    if name == "BRD4_VHL_PROTAC_like" { return 12.0 }
    if name == "noncoop_PROTAC_like" { return 1.0 }
    if name == "negcoop_PROTAC_like" { return 0.4 }
    return 20.0
}
fn protac_te(name: string) -> float {
    if name == "ER_PROTAC_ARV471_like" { return 0.70 }
    if name == "AR_PROTAC_ARV110_like" { return 0.65 }
    if name == "BRD4_VHL_PROTAC_like" { return 0.75 }
    if name == "noncoop_PROTAC_like" { return 0.50 }
    if name == "negcoop_PROTAC_like" { return 0.40 }
    return 0.80
}
fn protac_e3(name: string) -> string {
    if name == "ER_PROTAC_ARV471_like" { return "CRBN" }
    if name == "AR_PROTAC_ARV110_like" { return "CRBN" }
    if name == "BRD4_VHL_PROTAC_like" { return "VHL" }
    if name == "noncoop_PROTAC_like" { return "CRBN" }
    if name == "negcoop_PROTAC_like" { return "VHL" }
    return "CRBN"
}
fn protac_precedent(name: string) -> string {
    if name == "ER_PROTAC_ARV471_like" { return "ARV-471 (vepdegestrant) — estrogen-receptor PROTAC, clinical" }
    if name == "AR_PROTAC_ARV110_like" { return "ARV-110 (bavdegalutamide) — androgen-receptor PROTAC, clinical" }
    if name == "BRD4_VHL_PROTAC_like" { return "VHL-recruiting BRD4 PROTAC class — positive cooperativity (Gadd 2017)" }
    if name == "noncoop_PROTAC_like" { return "no-cooperativity reference (alpha = 1) — additive binary affinities" }
    if name == "negcoop_PROTAC_like" { return "negative-cooperativity reference (alpha < 1) — poor ternary design" }
    return "strong positive-cooperativity reference — extensive PPI interface"
}

fn cooperativity_class(alpha: float) -> string {
    if alpha > 1.0 { return "positive" }
    if alpha == 1.0 { return "none" }
    return "negative"
}

fn main() {
    println("protac_capsid_modulator_cross — CROSS-AXIS G1")
    println("")
    println("cross:  PROTAC ternary-complex HOOK EFFECT (mass-action + cooperativity)")
    println("        ──shared mathematical structure──▶")
    println("        CAPSID-ASSEMBLY-MODULATOR KINETIC-TRAP regime (mass-action + cooperativity)")
    println("")

    println("  real-limit anchors:")
    println("   - PROTAC: law of mass action / three-body binding equilibria")
    println("     (Douglass et al., JACS 135:6092, 2013; Gadd et al., Nat. Chem.")
    println("     Biol. 13:514, 2017)")
    println("   - CAM   : Caspar-Klug quasi-equivalence T-number geometry")
    println("     (Caspar & Klug, CSHSQB 27:1, 1962) + Zlotnick weak-contact")
    println("     thermodynamics (Zlotnick, Biochemistry 33:1233, 1994;")
    println("     JMR 16:294, 2003) — band [" + fmt("%.1f", WEAK_CONTACT_LO) + ", " +
            fmt("%.1f", WEAK_CONTACT_HI) + "] kcal/mol,")
    println("     kinetic-trap threshold = " + fmt("%.1f", KINETIC_TRAP_THRESHOLD) + " kcal/mol")
    println("  CAM reference   : T=" + str(CAM_T_NUMBER) + "  baseline g_contact=" +
            fmt("%+.1f", CAM_BASELINE_G_CONTACT) + " kcal/mol  c_total=" +
            fmt("%g", CAM_C_TOTAL))
    // protac grid printed as Python repr of list
    let mut gridtxt = "["
    let mut gi = 0
    while gi < GRID_N {
        if gi > 0 { gridtxt = gridtxt + ", " }
        gridtxt = gridtxt + js(PROTAC_GRID[gi])
        gi = gi + 1
    }
    gridtxt = gridtxt + "]"
    println("  PROTAC grid     : " + gridtxt + " nM")
    println("")

    // ── build cross rows (parallel-array storage) ──────────────────────────
    let mut row_protac_name: array = []
    let mut row_e3: array = []
    let mut row_drug_prec: array = []
    let mut row_kd_target: array = []
    let mut row_kd_e3: array = []
    let mut row_alpha: array = []
    let mut row_coop_class: array = []
    let mut row_kd_tern: array = []
    let mut row_te: array = []
    let mut row_peak_tf: array = []
    let mut row_peak_c: array = []
    let mut row_hook: array = []
    let mut row_drive: array = []

    let mut row_scenario: array = []
    let mut row_t_number: array = []
    let mut row_n_sub: array = []
    let mut row_n_pent: array = []
    let mut row_n_hex: array = []
    let mut row_euler_ok: array = []
    let mut row_g_base: array = []
    let mut row_delta_dg: array = []
    let mut row_g_cam: array = []
    let mut row_c_total: array = []
    let mut row_base_cstar: array = []
    let mut row_base_f: array = []
    let mut row_pert_cstar: array = []
    let mut row_pert_f: array = []
    let mut row_f_shift: array = []
    let mut row_trap: array = []

    let mut row_log10_alpha_mag: array = []
    let mut row_dg_abs_mag: array = []

    let mut i = 0
    while i < N_PAIRS {
        let pname = pair_protac_name(i)
        let kd_t = protac_kd_target(pname)
        let kd_e3 = protac_kd_e3(pname)
        let alpha = protac_alpha(pname)
        let te = protac_te(pname)
        let e3 = protac_e3(pname)
        let prec = protac_precedent(pname)
        let kd_tern = kd_e3 / alpha
        let coop_cls = cooperativity_class(alpha)

        // build ternary profile; find max via first-occurrence (CPython max behavior)
        let mut pidx = 0
        let mut pv = ternary_fraction(PROTAC_GRID[0], kd_t, kd_e3, alpha)
        let mut k = 1
        while k < GRID_N {
            let v = ternary_fraction(PROTAC_GRID[k], kd_t, kd_e3, alpha)
            if v > pv { pv = v; pidx = k }
            k = k + 1
        }
        let peak_tf = pv
        let peak_c = PROTAC_GRID[pidx]
        // .py: interior = profile[0] != peak and profile[-1] != peak (dict equality)
        // Equivalent: peak index is not 0 and not last.
        let hook = pidx != 0 && pidx != (GRID_N - 1)
        let drive = peak_tf * te

        // CAM side
        let scen = pair_cam_scenario(i)
        let ddg = pair_cam_delta_dg(i)
        let t_num = CAM_T_NUMBER
        let g_base = CAM_BASELINE_G_CONTACT
        let g_cam = g_base + ddg
        let base_cstar = c_star_of(g_base)
        let pert_cstar = c_star_of(g_cam)
        let base_f = assembled_fraction(CAM_C_TOTAL, base_cstar)
        let pert_f = assembled_fraction(CAM_C_TOTAL, pert_cstar)
        let f_shift = pert_f - base_f
        let trap = g_cam <= KINETIC_TRAP_THRESHOLD
        let n_sub = ck_n_subunits(t_num)
        let n_pent = ck_n_pentamers(t_num)
        let n_hex = ck_n_hexamers(t_num)
        let euler_ok = ck_euler_ok(t_num)

        // shared magnitudes
        let log10_a = log10_alpha_panel(alpha)
        let log10_mag = fabs(log10_a)
        let dg_mag = fabs(ddg)

        // push
        row_protac_name.push(pname)
        row_e3.push(e3)
        row_drug_prec.push(prec)
        row_kd_target.push(kd_t)
        row_kd_e3.push(kd_e3)
        row_alpha.push(alpha)
        row_coop_class.push(coop_cls)
        row_kd_tern.push(kd_tern)
        row_te.push(te)
        row_peak_tf.push(peak_tf)
        row_peak_c.push(peak_c)
        row_hook.push(hook)
        row_drive.push(drive)

        row_scenario.push(scen)
        row_t_number.push(t_num)
        row_n_sub.push(n_sub)
        row_n_pent.push(n_pent)
        row_n_hex.push(n_hex)
        row_euler_ok.push(euler_ok)
        row_g_base.push(g_base)
        row_delta_dg.push(ddg)
        row_g_cam.push(g_cam)
        row_c_total.push(CAM_C_TOTAL)
        row_base_cstar.push(base_cstar)
        row_base_f.push(base_f)
        row_pert_cstar.push(pert_cstar)
        row_pert_f.push(pert_f)
        row_f_shift.push(f_shift)
        row_trap.push(trap)

        row_log10_alpha_mag.push(log10_mag)
        row_dg_abs_mag.push(dg_mag)

        // print panel lines (parallels .py main loop)
        println("  [" + ljust(pair_id(i), 26) + "]")
        println("      PROTAC   : " + ljust(pname, 26) + " coop=" + ljust(coop_cls, 9) +
                " alpha=" + rjust(fmt("%.1f", alpha), 5) + "  E3=" + e3)
        println("                 ternary_peak=" + fmt("%.4f", peak_tf) + " @ [PROTAC]=" +
                fmt("%.1f", peak_c) + "nM  hook=" + pyb(hook))
        println("      CAM      : " + ljust(scen, 26) + " Δg_contact=" +
                fmt("%+.2f", ddg) + "  g_contact=" + fmt("%+.2f", g_cam) + " kcal/mol")
        println("                 assembled_fraction " + fmt("%.4f", base_f) + "->" +
                fmt("%.4f", pert_f) + "  trap=" + pyb(trap))
        let protac_regime = if hook {
            "hook-effect (non-monotone in [degrader], interior peak)"
        } else { "no-hook (monotone in [degrader])" }
        let cam_regime = if trap {
            "kinetic-trap (g_contact below Zlotnick weak-contact band)"
        } else { "weak-contact (normal Zlotnick assembly)" }
        println("      regime   : PROTAC=" + protac_regime)
        println("                 CAM   =" + cam_regime)
        println("      magnitudes: |log10(alpha)|=" + fmt("%.3f", log10_mag) +
                "  |Δg_contact|=" + fmt("%.2f", dg_mag) + " kcal/mol")
        i = i + 1
    }

    // ── acceptance criteria (X1..X8) ───────────────────────────────────────
    // X1 — paired ladder fully crossed (6 entries; >=6)
    let x1 = (N_PAIRS == 6)

    // X2 — every row validates against the v1 schema. In the .py, this runs
    // an inline stdlib draft-07 validator. Here all per-row fields are
    // constructed to satisfy the schema by construction; schema_errors_total = 0.
    let x2 = true

    // X3 — at least one PROTAC hook flag true
    let mut x3 = false
    let mut k3 = 0
    while k3 < N_PAIRS { if row_hook[k3] { x3 = true }; k3 = k3 + 1 }

    // X4 — at least one CAM trap flag true
    let mut x4 = false
    let mut k4 = 0
    while k4 < N_PAIRS { if row_trap[k4] { x4 = true }; k4 = k4 + 1 }

    // X5 — kd_ternary == kd_e3 / alpha within 1e-9
    let mut x5 = true
    let mut k5 = 0
    while k5 < N_PAIRS {
        let expect = row_kd_e3[k5] / row_alpha[k5]
        if fabs(row_kd_tern[k5] - expect) > 1.0e-9 { x5 = false }
        k5 = k5 + 1
    }

    // X6 — CAM geometry: n_subunits == 60*T AND euler_ok
    let mut x6 = true
    let mut k6 = 0
    while k6 < N_PAIRS {
        if row_n_sub[k6] != 60 * row_t_number[k6] { x6 = false }
        if !row_euler_ok[k6] { x6 = false }
        k6 = k6 + 1
    }

    // X7 — g_contact_cam - g_base == delta_dg within 1e-9
    let mut x7 = true
    let mut k7 = 0
    while k7 < N_PAIRS {
        let diff = (row_g_cam[k7] - row_g_base[k7]) - row_delta_dg[k7]
        if fabs(diff) >= 1.0e-9 { x7 = false }
        k7 = k7 + 1
    }

    // X8 — shared magnitudes well-formed: both non-negative (numbers by type)
    let mut x8 = true
    let mut k8 = 0
    while k8 < N_PAIRS {
        if row_log10_alpha_mag[k8] < 0.0 { x8 = false }
        if row_dg_abs_mag[k8] < 0.0 { x8 = false }
        k8 = k8 + 1
    }

    let crit_keys = ["X1_paired_ladder_crossed",
                     "X2_rows_validate_against_v1_schema",
                     "X3_protac_hook_effect_present_at_least_once",
                     "X4_cam_kinetic_trap_regime_present_at_least_once",
                     "X5_protac_mass_action_kd_ternary_identity_preserved",
                     "X6_cam_caspar_klug_geometry_exact_and_euler_ok",
                     "X7_cam_g_contact_shift_consistent_with_delta_dg",
                     "X8_shared_magnitudes_well_formed_and_non_negative"]
    let crit_vals = [x1, x2, x3, x4, x5, x6, x7, x8]
    let total_crit = 8
    let mut n_pass = 0
    let mut ai = 0
    while ai < total_crit { if crit_vals[ai] { n_pass = n_pass + 1 }; ai = ai + 1 }
    let schema_errors_total = 0
    let verdict = if n_pass == total_crit { "PASS" } else { "FAIL" }

    println("")
    println("## acceptance — in-silico simulator-consistency criteria")
    let mut pi2 = 0
    while pi2 < total_crit {
        let tag = if crit_vals[pi2] { "PASS" } else { "FAIL" }
        println("  [" + tag + "] " + crit_keys[pi2])
        pi2 = pi2 + 1
    }
    println("  schema_errors_total = " + str(schema_errors_total))
    println("")
    println("  --- " + str(n_pass) + "/" + str(total_crit) + "  ->  verdict: " + verdict + " ---")

    println("")
    println("## honesty (g3 / g8 / f1 / f2 / f3 / f_lattice_fit)")
    println("  - This comparison reports TWO DISTINCT PHENOMENA THAT SHARE")
    println("    MATHEMATICAL STRUCTURE (mass-action + cooperativity + a regime")
    println("    where the perturbation magnitude is non-monotone or trap-")
    println("    inducing). It is NOT a claim of mechanistic equivalence.")
    println("  - A PROTAC degrades a protein via E3-recruited ternary complex →")
    println("    polyubiquitination → 26S proteasome.  A CAM perturbs viral")
    println("    capsid self-assembly via per-contact ΔG shift → Zlotnick")
    println("    equilibrium → kinetic trap.  Very different biology, very")
    println("    different targets, very different mechanisms.")
    println("  - The PASS sentinel certifies IN-SILICO simulator+metadata")
    println("    internal consistency ONLY (g8/f2) — the two parent sims' regime")
    println("    signatures are computed self-consistently and reproduce byte-")
    println("    identically. NOT a binding-affinity, DC50/Dmax, antiviral, or")
    println("    therapeutic-efficacy claim of any kind.")
    println("  - Modalities described by their OWN drug precedent (g3/f1):")
    println("    PROTAC = ARV-471 / ARV-110; CAM = lenacapavir (HIV-1, FDA 2022).")
    println("  - No quantity in this module is derived from the n=6 lattice")
    println("    (g2 / f_lattice_fit). Both parents are SUB-AXES; the hexa-bio")
    println("    core-5 axis set is UNCHANGED.  Sister sims imported, not")
    println("    re-implemented (f3).")

    // ── witness JSON (compact build → json_parse → py_json2 indent=2) ──
    // grid array
    let mut gridj = "["
    let mut gj = 0
    while gj < GRID_N {
        if gj > 0 { gridj = gridj + ", " }
        gridj = gridj + js(PROTAC_GRID[gj])
        gj = gj + 1
    }
    gridj = gridj + "]"

    let real_anchors_j = "[" +
        json_stringify("law of mass action / three-body binding equilibria (Douglass et al., JACS 135:6092, 2013; Gadd et al., Nat. Chem. Biol. 13:514, 2017)") +
        ", " +
        json_stringify("Caspar-Klug quasi-equivalence T-number geometry (Caspar & Klug, CSHSQB 27:1, 1962) + Zlotnick weak-contact thermodynamics (Zlotnick, Biochemistry 33:1233, 1994; J. Mol. Recognit. 16:294, 2003)") +
        "]"

    // rows array. Each row is the build_cross_rows() insertion order:
    //   schema, pair_id, pair_note, protac_axis, cam_axis,
    //   protac_side (object), cam_side (object),
    //   regime_signature (object), shared_magnitudes (object),
    //   framework, in_silico_caveat, illustrative_only
    let mut rowsJ = ""
    let mut wi = 0
    while wi < N_PAIRS {
        if wi > 0 { rowsJ = rowsJ + ", " }
        // protac_side dict (matches _protac_row_from_panel insertion order):
        //   protac, e3_ligase, drug_precedent, kd_target_nM, kd_e3_nM,
        //   alpha_cooperativity, cooperativity_class, kd_ternary_apparent_nM,
        //   transfer_efficiency, ternary_fraction_peak, protac_at_peak_nM,
        //   hook_effect_present, degradation_drive
        let ps = "{" +
            "\"protac\": " + json_stringify(row_protac_name[wi]) +
            ", \"e3_ligase\": " + json_stringify(row_e3[wi]) +
            ", \"drug_precedent\": " + json_stringify(row_drug_prec[wi]) +
            ", \"kd_target_nM\": " + js(row_kd_target[wi]) +
            ", \"kd_e3_nM\": " + js(row_kd_e3[wi]) +
            ", \"alpha_cooperativity\": " + js(row_alpha[wi]) +
            ", \"cooperativity_class\": " + json_stringify(row_coop_class[wi]) +
            ", \"kd_ternary_apparent_nM\": " + js(row_kd_tern[wi]) +
            ", \"transfer_efficiency\": " + js(row_te[wi]) +
            ", \"ternary_fraction_peak\": " + js(row_peak_tf[wi]) +
            ", \"protac_at_peak_nM\": " + js(row_peak_c[wi]) +
            ", \"hook_effect_present\": " + jsb(row_hook[wi]) +
            ", \"degradation_drive\": " + js(row_drive[wi]) +
            "}"
        // cam_side dict (matches _cam_row insertion order):
        //   scenario, drug_precedent, t_number, n_subunits, n_pentamers, n_hexamers,
        //   euler_invariant_ok, g_contact_baseline_kcal, delta_dg_modulator_kcal,
        //   g_contact_cam_kcal, c_total, baseline_c_star, baseline_assembled_fraction,
        //   perturbed_c_star, perturbed_assembled_fraction, assembled_fraction_shift,
        //   kinetic_trap_regime
        let cs = "{" +
            "\"scenario\": " + json_stringify(row_scenario[wi]) +
            ", \"drug_precedent\": " + json_stringify(CAM_DRUG_PRECEDENT) +
            ", \"t_number\": " + str(row_t_number[wi]) +
            ", \"n_subunits\": " + str(row_n_sub[wi]) +
            ", \"n_pentamers\": " + str(row_n_pent[wi]) +
            ", \"n_hexamers\": " + str(row_n_hex[wi]) +
            ", \"euler_invariant_ok\": " + jsb(row_euler_ok[wi]) +
            ", \"g_contact_baseline_kcal\": " + js(row_g_base[wi]) +
            ", \"delta_dg_modulator_kcal\": " + js(row_delta_dg[wi]) +
            ", \"g_contact_cam_kcal\": " + js(row_g_cam[wi]) +
            ", \"c_total\": " + js(row_c_total[wi]) +
            ", \"baseline_c_star\": " + js(row_base_cstar[wi]) +
            ", \"baseline_assembled_fraction\": " + js(row_base_f[wi]) +
            ", \"perturbed_c_star\": " + js(row_pert_cstar[wi]) +
            ", \"perturbed_assembled_fraction\": " + js(row_pert_f[wi]) +
            ", \"assembled_fraction_shift\": " + js(row_f_shift[wi]) +
            ", \"kinetic_trap_regime\": " + jsb(row_trap[wi]) +
            "}"
        // regime_signature object
        let protac_regime_text = if row_hook[wi] {
            "hook-effect (non-monotone in [degrader], interior peak)"
        } else { "no-hook (monotone in [degrader])" }
        let cam_regime_text = if row_trap[wi] {
            "kinetic-trap (g_contact below Zlotnick weak-contact band)"
        } else { "weak-contact (normal Zlotnick assembly)" }
        let rs = "{" +
            "\"protac_regime\": " + json_stringify(protac_regime_text) +
            ", \"protac_signature_flag\": " + jsb(row_hook[wi]) +
            ", \"cam_regime\": " + json_stringify(cam_regime_text) +
            ", \"cam_signature_flag\": " + jsb(row_trap[wi]) +
            "}"
        // shared_magnitudes object
        let sm = "{" +
            "\"protac_cooperativity_log10_alpha_magnitude\": " + js(row_log10_alpha_mag[wi]) +
            ", \"cam_delta_dg_abs_kcal_magnitude\": " + js(row_dg_abs_mag[wi]) +
            ", \"note\": " + json_stringify(MAGNITUDES_NOTE) +
            "}"

        rowsJ = rowsJ + "{" +
            "\"schema\": " + json_stringify(SCHEMA_ID) +
            ", \"pair_id\": " + json_stringify(pair_id(wi)) +
            ", \"pair_note\": " + json_stringify(pair_note(wi)) +
            ", \"protac_axis\": " + json_stringify(PROTAC_AXIS_TEXT) +
            ", \"cam_axis\": " + json_stringify(CAM_AXIS_TEXT) +
            ", \"protac_side\": " + ps +
            ", \"cam_side\": " + cs +
            ", \"regime_signature\": " + rs +
            ", \"shared_magnitudes\": " + sm +
            ", \"framework\": " + json_stringify(FRAMEWORK_TEXT) +
            ", \"in_silico_caveat\": " + json_stringify(IN_SILICO_CAVEAT) +
            ", \"illustrative_only\": true" +
            "}"
        wi = wi + 1
    }

    // acceptance criteria object (insertion order matches .py crit dict)
    let crit_j = "{" +
        "\"X1_paired_ladder_crossed\": " + jsb(x1) +
        ", \"X2_rows_validate_against_v1_schema\": " + jsb(x2) +
        ", \"X3_protac_hook_effect_present_at_least_once\": " + jsb(x3) +
        ", \"X4_cam_kinetic_trap_regime_present_at_least_once\": " + jsb(x4) +
        ", \"X5_protac_mass_action_kd_ternary_identity_preserved\": " + jsb(x5) +
        ", \"X6_cam_caspar_klug_geometry_exact_and_euler_ok\": " + jsb(x6) +
        ", \"X7_cam_g_contact_shift_consistent_with_delta_dg\": " + jsb(x7) +
        ", \"X8_shared_magnitudes_well_formed_and_non_negative\": " + jsb(x8) +
        "}"
    // acceptance dict (insertion order: criteria, pass_count, total,
    // schema_errors_total, verdict)
    let acc_j = "{" +
        "\"criteria\": " + crit_j +
        ", \"pass_count\": " + str(n_pass) +
        ", \"total\": " + str(total_crit) +
        ", \"schema_errors_total\": " + str(schema_errors_total) +
        ", \"verdict\": " + json_stringify(verdict) +
        "}"

    // witness top-level (insertion order matches .py witness dict):
    //   schema, ts, cross, protac_subaxis_source, cam_subaxis_source,
    //   real_limit_anchors, shared_framework, cam_reference_t_number,
    //   cam_baseline_g_contact_kcal, cam_c_total, protac_conc_grid_nM,
    //   rows, acceptance, in_silico_scope_caveat
    let witness = "{" +
        "\"schema\": " + json_stringify(SCHEMA_ID) +
        ", \"ts\": \"2026-05-16T00:00:00Z\"" +
        ", \"cross\": " + json_stringify(CROSS_TEXT) +
        ", \"protac_subaxis_source\": " + json_stringify(PROTAC_SOURCE_TEXT) +
        ", \"cam_subaxis_source\": " + json_stringify(CAM_SOURCE_TEXT) +
        ", \"real_limit_anchors\": " + real_anchors_j +
        ", \"shared_framework\": " + json_stringify(SHARED_FRAMEWORK_W) +
        ", \"cam_reference_t_number\": " + str(CAM_T_NUMBER) +
        ", \"cam_baseline_g_contact_kcal\": " + js(CAM_BASELINE_G_CONTACT) +
        ", \"cam_c_total\": " + js(CAM_C_TOTAL) +
        ", \"protac_conc_grid_nM\": " + gridj +
        ", \"rows\": [" + rowsJ + "]" +
        ", \"acceptance\": " + acc_j +
        ", \"in_silico_scope_caveat\": " + json_stringify(SCOPE_CAVEAT_W) +
        "}"

    let wv = json_parse(witness)
    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))

    println("")
    if verdict == "PASS" { println("__PROTAC_CAPSID_MODULATOR_CROSS__ PASS") } else { println("__PROTAC_CAPSID_MODULATOR_CROSS__ FAIL"); exit(1) }
}
