#!hexa strict
// hexa-bio/_hexa_bridge/selftest/cross_axis_matrix.hexa
//
// Cross-axis bridge reporter. hexa-native port of
// `selftest/cross_axis_matrix.py` (T3; glob/os/re). 24-axis registry,
// filename longest-match alias extractor, docstring CROSS:-block axis
// detection (word-bounded), manual-hints union, 24×24 visual matrix.
// Byte-parity stdout vs the .py.

fn shq(s: string) -> string { return "'" + s.replace("'", "'\\''") + "'" }

fn ljust(s: string, n: int) -> string { let mut o=s; while len(o)<n { o=o+" " }; return o }
fn rjust(s: string, n: int) -> string { let mut o=s; while len(o)<n { o=" "+o }; return o }
fn ws(c: string) -> bool { return c==" " || c=="\t" }
fn rep(c: string, n: int) -> string { let mut o=""; let mut i=0; while i<n { o=o+c; i=i+1 }; return o }
fn dashes(n: int) -> string { return rep("─", n) }
fn startswith(s: string, p: string) -> bool { if len(s)<len(p) { return false }; return s.substr(0,len(p))==p }
fn lstrip(s: string) -> string { let mut i=0; while i<len(s) && ws(s.substr(i,1)) { i=i+1 }; return s.substr(i, len(s)-i) }

// ── 24 axes ─────────────────────────────────────────────────────────
let AXES = ["QUANTUM","WEAVE","NANOBOT","RIBOZYME","VIROCAPSID",
            "COVALENT","BIFUNCTIONAL","METALLODRUG","OLIGONUCLEOTIDE",
            "PROTAC","LYTAC","AUTAC","RIBOTAC","COVALENT-DEGRADER","MOLECULAR-GLUE",
            "ALLOSTERIC","CRYPTIC-POCKET","PPI","PEPTIDE","MACROCYCLE",
            "REVERSIBLE-COVALENT","RNA-TARGETING-SMALL-MOLECULE","APTAMER",
            "CAPSID-ASSEMBLY-MODULATOR"]
let CORE_N = 5
let MAIN_N = 4   // EXPANSION_MAIN starts at index 5

fn axis_kind(i: int) -> string {
    if i < CORE_N { return "core" }
    if i < CORE_N + MAIN_N { return "main" }
    return "sub"
}

fn axis_idx(name: string) -> int {
    let mut i = 0
    while i < len(AXES) { if AXES[i] == name { return i }; i = i + 1 }
    return -1
}

// NAME_ALIASES (token → axis) — longest first; the consume-from-working
// algorithm relies on order so longer aliases eat substrings before
// shorter ones match them.
let NA_TOK = ["rna_targeting_small_molecule","rna_modality_comparison_smn2",
              "capsid_assembly_modulator","capsid_modulator","covalent_degrader",
              "reversible_covalent","molecular_glue","cryptic_pocket",
              "quantum_vqe","quantum","weave","nanobot","ribozyme","ribotac",
              "virocapsid","covalent","bifunctional","metallodrug",
              "oligonucleotide","protac","lytac","autac","allosteric","ppi",
              "peptide","macrocycle","aptamer"]
let NA_AX = ["RNA-TARGETING-SMALL-MOLECULE","RNA-TARGETING-SMALL-MOLECULE",
             "CAPSID-ASSEMBLY-MODULATOR","CAPSID-ASSEMBLY-MODULATOR",
             "COVALENT-DEGRADER","REVERSIBLE-COVALENT","MOLECULAR-GLUE",
             "CRYPTIC-POCKET","QUANTUM","QUANTUM","WEAVE","NANOBOT","RIBOZYME",
             "RIBOTAC","VIROCAPSID","COVALENT","BIFUNCTIONAL","METALLODRUG",
             "OLIGONUCLEOTIDE","PROTAC","LYTAC","AUTAC","ALLOSTERIC","PPI",
             "PEPTIDE","MACROCYCLE","APTAMER"]

// DOCSTRING_AXIS_TOKENS = AXES + ["QUANTUM VQE","QUANTUM-AXIS","GENCODE"]
// sorted longest-first. Plus alias map for the 3 variants.
fn docstring_tokens() -> array {
    let mut all: array = []
    let mut i = 0
    while i < len(AXES) { all.push(AXES[i]); i = i + 1 }
    all.push("QUANTUM VQE"); all.push("QUANTUM-AXIS"); all.push("GENCODE")
    // sort by length desc; tie-break stable (original order)
    let mut p = 1
    while p < len(all) {
        let cur = all[p]
        let mut q = p - 1
        while q >= 0 && len(all[q]) < len(cur) { all[q+1] = all[q]; q = q - 1 }
        all[q+1] = cur
        p = p + 1
    }
    return all
}

fn docstring_alias(tok: string) -> string {
    if tok == "QUANTUM VQE" { return "QUANTUM" }
    if tok == "QUANTUM-AXIS" { return "QUANTUM" }
    if tok == "GENCODE" { return "RIBOZYME" }
    return tok
}

fn manual_hint(fname: string) -> array {
    if fname == "capsid_modulator_pdb_anchor_cross.py" { return ["VIROCAPSID"] }
    if fname == "oligonucleotide_offtarget_gencode_cross.py" { return ["RIBOZYME"] }
    if fname == "reversible_covalent_mpro_vqe_cross.py" { return ["QUANTUM"] }
    if fname == "rna_modality_comparison_smn2_cross.py" { return ["OLIGONUCLEOTIDE"] }
    let e: array = []
    return e
}

// extract_axes: walk NA_TOK in order, consume "_token_" from "_stem_"
fn extract_axes(filename: string) -> array {
    let mut stem = filename
    // basename
    let mut bi = len(stem) - 1
    while bi >= 0 && stem.substr(bi,1) != "/" { bi = bi - 1 }
    stem = stem.substr(bi+1, len(stem)-bi-1)
    // strip suffix
    if startswith(stem, "") {
        let cs = "_cross.py"
        if len(stem) >= len(cs) && stem.substr(len(stem)-len(cs),len(cs)) == cs {
            stem = stem.substr(0, len(stem)-len(cs))
        } else if len(stem) >= 3 && stem.substr(len(stem)-3,3) == ".py" {
            stem = stem.substr(0, len(stem)-3)
        }
    }
    let mut working = "_" + stem.to_lower() + "_"
    let mut found: array = []
    let mut ti = 0
    while ti < len(NA_TOK) {
        let needle = "_" + NA_TOK[ti] + "_"
        while working.contains(needle) {
            // replace first occurrence with "_"
            let pos_idx = find_idx(working, needle)
            if pos_idx < 0 { break }
            working = working.substr(0, pos_idx) + "_" + working.substr(pos_idx + len(needle), len(working) - pos_idx - len(needle))
            let ax = NA_AX[ti]
            let mut dup = false
            let mut z = 0
            while z < len(found) { if found[z] == ax { dup = true }; z = z + 1 }
            if dup == false { found.push(ax) }
        }
        ti = ti + 1
    }
    return found
}

fn find_idx(hay: string, needle: string) -> int {
    let nl = len(needle); if nl == 0 { return -1 }
    let mut k = 0
    while k + nl <= len(hay) {
        if hay.substr(k, nl) == needle { return k }
        k = k + 1
    }
    return -1
}

// docstring_head: first 8KB lowercased
fn docstring_head(p: string) -> string {
    let t = exec("head -c 8192 " + shq(p) + " 2>/dev/null")
    return t.to_lower()
}

// extract the explicit CROSS: declaration block from lowercased text
fn extract_cross_block(text_lower: string) -> string {
    let lines = text_lower.split("\n")
    let mut block = ""
    let mut in_block = false
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let stripped = lstrip(line)
        if in_block == false {
            if startswith(stripped, "cross:") {
                in_block = true
                if len(block) > 0 { block = block + "\n" }
                block = block + stripped
            }
        } else {
            if stripped == "" { break }
            if startswith(line, " ") == false && startswith(line, "\t") == false { break }
            block = block + "\n" + stripped
        }
        i = i + 1
    }
    return block
}

// word-bounded char check: not in [A-Za-z0-9-]
fn is_axis_word_ch(c: string) -> bool {
    if c.len() != 1 { return false }
    return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-".contains(c)
}

// docstring_axes — scan the cross block for tokens (longest-first),
// word-bounded; return canonical axes in first-occurrence order.
fn docstring_axes(text_lower: string) -> array {
    let block = extract_cross_block(text_lower)
    let mut out: array = []
    if len(block) == 0 { return out }
    let toks = docstring_tokens()
    // collect (offset, axis) then sort by offset
    let mut offs: array = []
    let mut axs: array = []
    let mut seen: array = []
    let mut ti = 0
    while ti < len(toks) {
        let needle = toks[ti].to_lower()
        // find earliest word-bounded occurrence
        let mut k = 0
        let mut best = -1
        while k + len(needle) <= len(block) {
            if block.substr(k, len(needle)) == needle {
                let mut lok = true
                if k > 0 { if is_axis_word_ch(block.substr(k-1,1)) { lok = false } }
                let mut rok = true
                if k + len(needle) < len(block) { if is_axis_word_ch(block.substr(k+len(needle),1)) { rok = false } }
                if lok && rok { best = k; break }
            }
            k = k + 1
        }
        if best >= 0 {
            let axis = docstring_alias(toks[ti])
            if axis_idx(axis) >= 0 {
                let mut dup = false
                let mut z = 0
                while z < len(seen) { if seen[z] == axis { dup = true }; z = z + 1 }
                if dup == false { offs.push(best); axs.push(axis); seen.push(axis) }
            }
        }
        ti = ti + 1
    }
    // sort axs by offs (parallel insertion sort)
    let mut p = 1
    while p < len(offs) {
        let co = offs[p]; let ca = axs[p]
        let mut q = p - 1
        while q >= 0 && offs[q] > co { offs[q+1] = offs[q]; axs[q+1] = axs[q]; q = q - 1 }
        offs[q+1] = co; axs[q+1] = ca
        p = p + 1
    }
    return axs
}

// sniff_label via grep
fn sniff_label(p: string) -> string {
    let r = exec("head -c 8192 " + shq(p) + " 2>/dev/null | grep -ioE '(cross[- ]axis( integration)? |project )[A-Z][0-9]+' | head -1").trim()
    if len(r) == 0 { return "" }
    // extract trailing [A-Z][0-9]+ — last token
    let mut s = ""
    let mut i = len(r) - 1
    while i >= 0 {
        let c = r.substr(i,1)
        if c == " " { break }
        s = c + s
        i = i - 1
    }
    return s.to_upper()
}

fn abbreviate(name: string, width: int) -> string {
    if len(name) <= width { return ljust(name, width) }
    return name.substr(0, width)
}

fn main() {
    let root = exec("pwd").trim()
    let bridge = root + "/_python_bridge/module"

    println("cross_axis_matrix — hexa-bio cross-axis bridge REPORTER")
    println("  scans _python_bridge/module/*_cross.py, builds an axis x axis")
    println("  visual matrix, reports coverage. REPORTER, NOT ENFORCER.")
    println("  governance: g1 honest-coverage · g8 in-silico-only")
    println("")

    // glob *_cross.py sorted
    let listing = exec("ls -1 " + shq(bridge) + "/*_cross.py 2>/dev/null | LC_ALL=C sort").trim()
    let mut files: array = []
    if len(listing) > 0 {
        let ll = listing.split("\n")
        let mut li = 0
        while li < len(ll) { if len(ll[li]) > 0 { files.push(ll[li]) }; li = li + 1 }
    }
    println("discovered " + str(len(files)) + " cross file(s) under _python_bridge/module/*_cross.py")
    if len(files) == 0 {
        println("")
        println("  [SKIP] no cross files on host — nothing to report.")
        println("")
        println("__CROSS_AXIS_MATRIX__ FAIL")
        exit(1)
    }

    // process each file → row + cell marks
    let mut r_file: array = []
    let mut r_label: array = []
    let mut r_axes: array = []   // ";"-joined
    let mut unrec: array = []
    let mut multi: array = []
    // cells: parallel arrays of pair-keys and per-key labels
    // key = "ia,ib" (ia<ib). For each key, list of "LABEL:filename" entries.
    let mut ck: array = []
    let mut clabs: array = []     // ";"-joined per key

    let mut fi = 0
    while fi < len(files) {
        let path = files[fi]
        // basename
        let mut bi = len(path) - 1
        while bi >= 0 && path.substr(bi,1) != "/" { bi = bi - 1 }
        let fname = path.substr(bi+1, len(path)-bi-1)

        let text_lower = docstring_head(path)
        let mut label = sniff_label(path)
        if len(label) == 0 { label = "?" }
        let fn_axes = extract_axes(path)
        let ds_axes = docstring_axes(text_lower)
        let manual = manual_hint(fname)
        // union: filename → docstring → manual, dedup preserving order
        let mut union: array = []
        let mut ai = 0
        while ai < len(fn_axes) { union.push(fn_axes[ai]); ai = ai + 1 }
        let mut di = 0
        while di < len(ds_axes) {
            let a = ds_axes[di]
            let mut dup = false
            let mut z = 0
            while z < len(union) { if union[z] == a { dup = true }; z = z + 1 }
            if dup == false { union.push(a) }
            di = di + 1
        }
        let mut mi = 0
        while mi < len(manual) {
            let a = manual[mi]
            let mut dup = false
            let mut z = 0
            while z < len(union) { if union[z] == a { dup = true }; z = z + 1 }
            if dup == false { union.push(a) }
            mi = mi + 1
        }
        let mut joined = ""
        let mut ji = 0
        while ji < len(union) { if ji>0 { joined = joined + ";" }; joined = joined + union[ji]; ji = ji + 1 }
        r_file.push(fname); r_label.push(label); r_axes.push(joined)

        // validate + mark
        let mut bad = false
        let mut bi2 = 0
        while bi2 < len(union) { if axis_idx(union[bi2]) < 0 { bad = true }; bi2 = bi2 + 1 }
        if bad { unrec.push(fname); fi = fi + 1; continue }
        if len(union) >= 3 { multi.push(fname + ":" + joined) }
        if len(union) >= 2 {
            let mut a = 0
            while a < len(union) {
                let mut b = a + 1
                while b < len(union) {
                    let ia = axis_idx(union[a])
                    let ib = axis_idx(union[b])
                    let lo = if ia<ib { ia } else { ib }
                    let hi = if ia<ib { ib } else { ia }
                    let key = str(lo) + "," + str(hi)
                    let lab = label + ":" + fname
                    let mut found = -1
                    let mut x = 0
                    while x < len(ck) { if ck[x] == key { found = x }; x = x + 1 }
                    if found >= 0 { clabs[found] = clabs[found] + ";" + lab }
                    else { ck.push(key); clabs.push(lab) }
                    b = b + 1
                }
                a = a + 1
            }
        }
        fi = fi + 1
    }

    // per-file parse report
    println("")
    println("── per-file cross parse " + dashes(60))
    let mut ri = 0
    while ri < len(r_file) {
        let axparts = r_axes[ri].split(";")
        let mut axstr = ""
        if r_axes[ri] == "" { axstr = "(unparsed)" } else {
            let mut p = 0
            while p < len(axparts) { if p>0 { axstr = axstr + " x " }; axstr = axstr + axparts[p]; p = p + 1 }
        }
        println("  [" + ljust(r_label[ri], 3) + "]  " + ljust(r_file[ri], 54) + "  ->  " + axstr)
        ri = ri + 1
    }

    if len(unrec) > 0 {
        println("")
        println("  honest parse-warning — unrecognized axis token(s):")
        let mut u = 0
        while u < len(unrec) { println("    " + unrec[u]); u = u + 1 }
    }
    if len(multi) > 0 {
        println("")
        println("  multi-axis bridges (>2 axes — each pair marked):")
        let mut m = 0
        while m < len(multi) {
            // format ["A","B","C"]
            let parts = multi[m].split(":")
            let ax = parts[1].split(";")
            let mut s = "["
            let mut z = 0
            while z < len(ax) { if z>0 { s = s + ", " }; s = s + "'" + ax[z] + "'"; z = z + 1 }
            s = s + "]"
            println("    " + parts[0] + ": " + s)
            m = m + 1
        }
    }

    // matrix
    println("")
    println("── axis x axis matrix " + dashes(60))
    println("  symbols:  .  empty (no cross)   X  one cross   *  two or more crosses   -  self (diagonal)")
    println("")
    println("Row/Col axis legend (index : full name):")
    let mut i = 0
    while i < len(AXES) {
        println("  " + rjust(str(i), 2) + " [" + ljust(axis_kind(i), 4) + "]  " + AXES[i])
        i = i + 1
    }
    println("")

    // column header: 9 spaces + "j " for j in 0..23
    let mut hdr = "         "
    let mut j = 0
    while j < len(AXES) {
        if j > 0 { hdr = hdr + " " }
        hdr = hdr + rjust(str(j), 2)
        j = j + 1
    }
    println(hdr)
    println("         " + rep("-", 3*len(AXES) - 1))

    // rows
    let mut r = 0
    while r < len(AXES) {
        let row_label = rjust(str(r), 2) + " " + abbreviate(AXES[r], 8) + " |"
        let mut cells_str = ""
        let mut c = 0
        while c < len(AXES) {
            if r == c { cells_str = cells_str + "- " }
            else {
                let lo = if r<c { r } else { c }
                let hi = if r<c { c } else { r }
                let key = str(lo) + "," + str(hi)
                let mut found = -1
                let mut x = 0
                while x < len(ck) { if ck[x] == key { found = x }; x = x + 1 }
                if found < 0 { cells_str = cells_str + ". " }
                else {
                    let n = len(clabs[found].split(";"))
                    if n == 1 { cells_str = cells_str + "X " } else { cells_str = cells_str + "* " }
                }
            }
            c = c + 1
        }
        // rstrip
        let mut e = len(cells_str)
        while e > 0 && cells_str.substr(e-1,1) == " " { e = e - 1 }
        cells_str = cells_str.substr(0, e)
        println(row_label + " " + cells_str)
        r = r + 1
    }

    // per-cell roster (sorted by key ascending)
    println("")
    println("── per-cell bridge roster " + dashes(60))
    if len(ck) == 0 {
        println("  (no pairs marked — no bridges parsed successfully)")
    } else {
        // sort ck (parallel) by lo,hi
        let mut order: array = []
        let mut zi = 0
        while zi < len(ck) { order.push(zi); zi = zi + 1 }
        // sort indices by (lo,hi)
        let mut p2 = 1
        while p2 < len(order) {
            let cur = order[p2]
            let mut q = p2 - 1
            while q >= 0 {
                let pa = ck[order[q]].split(",")
                let pb = ck[cur].split(",")
                let mut a_lo = 0; let mut da = 0; while da < len(pa[0]) { let cc = pa[0].substr(da,1); let mut d = 0; while d < 10 { if str(d)==cc { a_lo = a_lo*10+d; break }; d=d+1 }; da=da+1 }
                let mut b_lo = 0; let mut db = 0; while db < len(pb[0]) { let cc = pb[0].substr(db,1); let mut d = 0; while d < 10 { if str(d)==cc { b_lo = b_lo*10+d; break }; d=d+1 }; db=db+1 }
                let mut a_hi = 0; let mut dha = 0; while dha < len(pa[1]) { let cc = pa[1].substr(dha,1); let mut d = 0; while d < 10 { if str(d)==cc { a_hi = a_hi*10+d; break }; d=d+1 }; dha=dha+1 }
                let mut b_hi = 0; let mut dhb = 0; while dhb < len(pb[1]) { let cc = pb[1].substr(dhb,1); let mut d = 0; while d < 10 { if str(d)==cc { b_hi = b_hi*10+d; break }; d=d+1 }; dhb=dhb+1 }
                let lt = if a_lo != b_lo { a_lo > b_lo } else { a_hi > b_hi }
                if lt { order[q+1] = order[q]; q = q - 1 } else { break }
            }
            order[q+1] = cur
            p2 = p2 + 1
        }
        let mut oi = 0
        while oi < len(order) {
            let kix = order[oi]
            let parts = ck[kix].split(",")
            let mut ia = 0; let mut da2 = 0; while da2 < len(parts[0]) { let cc = parts[0].substr(da2,1); let mut d = 0; while d < 10 { if str(d)==cc { ia = ia*10+d; break }; d=d+1 }; da2=da2+1 }
            let mut ib = 0; let mut db2 = 0; while db2 < len(parts[1]) { let cc = parts[1].substr(db2,1); let mut d = 0; while d < 10 { if str(d)==cc { ib = ib*10+d; break }; d=d+1 }; db2=db2+1 }
            println("  " + AXES[ia] + "  x  " + AXES[ib])
            let labs = clabs[kix].split(";")
            let mut li2 = 0
            while li2 < len(labs) { println("      " + labs[li2]); li2 = li2 + 1 }
            oi = oi + 1
        }
    }

    // coverage summary
    let n_axes = len(AXES)
    let n_possible = n_axes * (n_axes - 1) / 2
    let n_covered = len(ck)
    let mut n_bridges = 0
    let mut bi3 = 0
    while bi3 < len(clabs) { n_bridges = n_bridges + len(clabs[bi3].split(";")); bi3 = bi3 + 1 }
    let pct_str = exec("awk 'BEGIN{printf \"%.1f\", 100.0*" + str(n_covered) + "/" + str(n_possible) + "}'").trim()

    println("")
    println("── coverage summary " + dashes(60))
    println("  axes registered      : " + str(n_axes) + " (5 core + 4 expansion-main + 15 sub)")
    println("  possible axis pairs  : " + str(n_possible) + " (upper triangle, diagonal excluded)")
    println("  cross files on host  : " + str(len(files)))
    println("  pair-cells covered   : " + str(n_covered))
    println("  total pair-marks     : " + str(n_bridges) + " (may exceed cells if a pair has > 1 bridge or a 3-axis bridge contributes 3 pairs)")
    println("  coverage ratio       : " + str(n_covered) + "/" + str(n_possible) + " = " + pct_str + "%")
    println("")
    println("  HONESTY (g1, reporter != enforcer): coverage is a DESCRIPTIVE")
    println("  count of which axis pairs currently have a bridge file on disk.")
    println("  It is NOT a target. Most of the 276 axis pairs are NOT")
    println("  meaningfully crossable — e.g. NANOBOT x AUTAC, PEPTIDE x")
    println("  METALLODRUG share no common real-limit anchor. A bridge is")
    println("  added only when shared mathematical structure or a shared")
    println("  real-limit anchor makes the cross honest. Empty cells are")
    println("  HONEST; this script never claims '100% would be better'.")
    println("")
    println("  HONESTY (g8, in-silico scope): a marked cell verifies a bridge")
    println("  file exists and its axis pair parses. It is NOT a therapeutic,")
    println("  clinical, regulatory, immunogenic, or efficacy claim about the")
    println("  axis intersection. No n=6 lattice arithmetic is invoked.")
    println("")

    if n_bridges >= 1 {
        println("__CROSS_AXIS_MATRIX__ PASS")
        return
    }
    println("__CROSS_AXIS_MATRIX__ FAIL")
    exit(1)
}
