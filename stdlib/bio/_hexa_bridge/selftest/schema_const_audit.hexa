#!hexa strict
// hexa-bio/_hexa_bridge/selftest/schema_const_audit.hexa
//
// hexa-native port of `selftest/schema_const_audit.py` (T3; json/os/re/sys —
// no float math, structural-only audit). Walks 5 spec dirs (12 canonical
// SCHEMA_SEARCH_DIRS), parses every `*.schema.json`, and classifies the
// honesty-vocabulary fields as CONST-enforced or TYPED-ONLY.
//
// REPORTER, not ENFORCER — the sentinel `__SCHEMA_CONST_AUDIT__ PASS` fires
// iff the directory walk completed and every discovered schema parsed as
// JSON. TYPED-ONLY findings are NAMED, not FAILED.
//
// shq() is provided by the imported json_schema_validator module
// (discipline rule #1: no local fn duplicating an imported one).

import "_hexa_bridge/module/json_schema_validator.hexa"

// ── repo layout (parallel arrays — see SCHEMA_SEARCH_DIRS in .py) ──
let SCHEMA_SEARCH_DIRS = [
    "_python_bridge/spec",
    "case_studies",
    "bifunctional/spec",
    "covalent/spec",
    "metallodrug/spec",
    "nanobot/spec",
    "oligonucleotide/spec",
    "ribozyme/spec",
    "synbio/spec",
    "virocapsid/spec",
    "weave/spec",
    "selftest/spec",
]

let EXCLUDE_SEGMENTS = [
    "/.claude/",
    "/.git/",
    "/.venv/",
    "/node_modules/",
    "/__pycache__/",
]

let HONESTY_FIELDS = [
    "in_scope",
    "reported_not_run",
    "in_silico_only",
    "all_three_drugs_fda_approved",
    "both_drugs_fda_approved",
    "both_modalities_fda_approved",
    "both_modalities_have_fda_precedent",
    "unplaced_handling_is_honest",
    "no_lattice_derivation",
    "scope_is_one_disease_pilot",
    "one_disease_pilot_not_200_disease_remap",
    "research_stage_negatives_listed_honestly",
    "core_5_unchanged",
    "no_fork_of_sister_sims",
    "comparison_is_ranking",
    "signals_commensurable",
    "cross_is_three_axis",
    "cross_is_not_a_new_axis",
    "creates_a_new_axis",
    "modality_interchangeability_claim",
    "illustrative_only",
    "not_a_redesign_recommendation",
    "not_an_efficacy_ranking",
    "not_a_superiority_claim",
    "not_a_clinical_claim",
    "not_a_portfolio_recommendation",
    "fda_approved",
    "axis",
]

let AXIS_HONESTY_GATE = "axis"

let V_CONST = "CONST"
let V_TYPED_ONLY = "TYPED-ONLY"

// ── helpers (std set; no fsum / fabs — structural audit, no float math) ──

fn ljust(s: string, n: int) -> string {
    let mut o = s
    while len(o) < n { o = o + " " }
    return o
}

fn rjust(s: string, n: int) -> string {
    let mut o = s
    while len(o) < n { o = " " + o }
    return o
}

fn ends_with(s: string, suf: string) -> bool {
    if len(s) < len(suf) { return false }
    return s.substr(len(s) - len(suf), len(suf)) == suf
}

fn contains(s: string, sub: string) -> bool {
    let n = len(s)
    let m = len(sub)
    if m == 0 { return true }
    if n < m { return false }
    let mut i = 0
    while i + m <= n {
        if s.substr(i, m) == sub { return true }
        i = i + 1
    }
    return false
}

fn idx_of_s(arr: array, k: string) -> int {
    let mut i = 0
    while i < len(arr) { if arr[i] == k { return i }; i = i + 1 }
    return -1
}

// insertion sort on a FRESH COPY of a string array (discipline #4: never
// mutate the caller's array; aliasing would desync parallel arrays).
fn sort_str(a: array) -> array {
    let mut u: array = []
    let mut ai = 0
    while ai < len(a) { u.push(a[ai]); ai = ai + 1 }
    let mut p = 1
    while p < len(u) {
        let cur = u[p]
        let mut q = p - 1
        while q >= 0 && u[q] > cur { u[q + 1] = u[q]; q = q - 1 }
        u[q + 1] = cur
        p = p + 1
    }
    return u
}

// Python `_shorten(s, w)` — return `s` truncated to width `w-1` with `…`
// suffix when over. Pure string op; multibyte `…` is one rendered glyph.
fn shorten(s: string, w: int) -> string {
    if len(s) <= w { return s }
    return s.substr(0, w - 1) + "…"
}

// Check honesty-field membership. Schemas in this repo use lowercase
// property names exclusively, but match the .py `.lower()` discipline.
fn is_honesty_field(name: string) -> bool {
    let lc = name.to_lower()
    let mut i = 0
    while i < len(HONESTY_FIELDS) {
        if HONESTY_FIELDS[i] == lc { return true }
        i = i + 1
    }
    return false
}

// Mirror of .py `is_const_enforced`: const-keyword OR null-type (incl
// single-member ["null"] list).
fn is_const_enforced(prop_decl) -> bool {
    if type_of(prop_decl) != "map" { return false }
    if prop_decl.has("const") { return true }
    if prop_decl.has("type") {
        let t = prop_decl["type"]
        let h = type_of(t)
        if h == "string" && t == "null" { return true }
        if h == "array" && len(t) == 1 && t[0] == "null" { return true }
    }
    return false
}

// ── property-tree walk ──
// Findings: parallel arrays (field_name / breadcrumb / verdict). hexa has
// no tuples; parallel arrays preserve insertion order deterministically.
//
// Mutual-recursion-free: a single `_walk_properties` walks dict/list nodes.
// Sink arrays are mutated via `.push`; caller iterates final triples.

fn walk_properties(node, path_prefix: string, sink_f: array, sink_b: array, sink_v: array) {
    let h = type_of(node)
    if h == "map" {
        // `properties` block
        if node.has("properties") {
            let props = node["properties"]
            if type_of(props) == "map" {
                let pkeys = sort_str(dict_keys(props))
                let mut i = 0
                while i < len(pkeys) {
                    let prop_name = pkeys[i]
                    let prop_decl = props[prop_name]
                    if is_honesty_field(prop_name) {
                        if prop_name.to_lower() == AXIS_HONESTY_GATE {
                            // axis only counts when null-typed (UNPLACED gate)
                            if type_of(prop_decl) == "map" {
                                let mut null_typed = false
                                if prop_decl.has("type") {
                                    let t = prop_decl["type"]
                                    let th = type_of(t)
                                    if th == "string" && t == "null" { null_typed = true }
                                    else if th == "array" && len(t) == 1 && t[0] == "null" { null_typed = true }
                                }
                                let mut const_null = false
                                if prop_decl.has("const") && type_of(prop_decl["const"]) == "void" {
                                    const_null = true
                                }
                                if null_typed || const_null {
                                    sink_f.push(prop_name)
                                    sink_b.push(path_prefix + "." + prop_name)
                                    sink_v.push(V_CONST)
                                }
                            }
                        } else {
                            let v = if is_const_enforced(prop_decl) { V_CONST } else { V_TYPED_ONLY }
                            sink_f.push(prop_name)
                            sink_b.push(path_prefix + "." + prop_name)
                            sink_v.push(v)
                        }
                    }
                    walk_properties(prop_decl, path_prefix + "." + prop_name, sink_f, sink_b, sink_v)
                    i = i + 1
                }
            }
        }
        // `definitions` block — /defs/<name>
        if node.has("definitions") {
            let defs = node["definitions"]
            if type_of(defs) == "map" {
                let dkeys = sort_str(dict_keys(defs))
                let mut di = 0
                while di < len(dkeys) {
                    let dn = dkeys[di]
                    walk_properties(defs[dn], path_prefix + "/defs/" + dn, sink_f, sink_b, sink_v)
                    di = di + 1
                }
            }
        }
        // nested sub-schema keywords
        let nested_keys = ["items", "additionalProperties", "if", "then", "else", "contains", "not", "propertyNames"]
        let mut ki = 0
        while ki < len(nested_keys) {
            let key = nested_keys[ki]
            if node.has(key) {
                let sub = node[key]
                let sh = type_of(sub)
                if sh == "map" || sh == "array" {
                    walk_properties(sub, path_prefix + "/" + key, sink_f, sink_b, sink_v)
                }
            }
            ki = ki + 1
        }
        // array-of-schema keywords
        let aok = ["allOf", "anyOf", "oneOf"]
        let mut ai = 0
        while ai < len(aok) {
            let key = aok[ai]
            if node.has(key) {
                let lst = node[key]
                if type_of(lst) == "array" {
                    let mut li = 0
                    while li < len(lst) {
                        walk_properties(lst[li], path_prefix + "/" + key + "[" + str(li) + "]", sink_f, sink_b, sink_v)
                        li = li + 1
                    }
                }
            }
            ai = ai + 1
        }
    } else if h == "array" {
        let mut li = 0
        while li < len(node) {
            walk_properties(node[li], path_prefix + "[" + str(li) + "]", sink_f, sink_b, sink_v)
            li = li + 1
        }
    }
}

// ── path / discovery helpers ──

// Match .py's exclude logic: a schema path's dirpath normalised with
// trailing "/" is checked against each EXCLUDE_SEGMENTS string. We apply
// the same check on the (file) path's enclosing directory.
fn path_excluded(p: string) -> bool {
    let mut i = 0
    while i < len(EXCLUDE_SEGMENTS) {
        if contains(p + "/", EXCLUDE_SEGMENTS[i]) { return true }
        i = i + 1
    }
    return false
}

fn rel_path(root: string, abs_p: string) -> string {
    let prefix = root + "/"
    if len(abs_p) >= len(prefix) && abs_p.substr(0, len(prefix)) == prefix {
        return abs_p.substr(len(prefix), len(abs_p) - len(prefix))
    }
    return abs_p
}

// Discover schemas under one search dir (recursive). Uses `find` so we get
// all nested `*.schema.json` files; filters out paths whose enclosing dir
// matches any EXCLUDE_SEGMENTS substring, then dedups + sorts.
fn discover_under(root: string, reldir: string) -> array {
    let mut out: array = []
    let base = root + "/" + reldir
    if exec("[ -d " + shq(base) + " ] && echo y || echo n").trim() != "y" {
        return out
    }
    let raw = exec("find " + shq(base) + " -type f -name '*.schema.json' 2>/dev/null").trim()
    if len(raw) == 0 { return out }
    let lines = raw.split("\n")
    let mut i = 0
    while i < len(lines) {
        let p = lines[i].trim()
        if len(p) > 0 {
            // .py checks the *dirpath* (parent) — strip the filename:
            let mut slash = len(p) - 1
            while slash > 0 && p.substr(slash, 1) != "/" { slash = slash - 1 }
            let dp = p.substr(0, slash)
            if !path_excluded(dp) {
                out.push(p)
            }
        }
        i = i + 1
    }
    return out
}

// ── render helpers ──

fn render_schema_block(rel: string, fs: array, bs: array, vs: array) {
    println("  " + rel)
    if len(fs) == 0 {
        println("    (no honesty fields found — out-of-scope for this audit)")
        return
    }
    let mut w_field = 5      // len("field")
    let mut w_verdict = 7    // len("verdict")
    let mut i = 0
    while i < len(fs) {
        if len(fs[i]) > w_field { w_field = len(fs[i]) }
        if len(vs[i]) > w_verdict { w_verdict = len(vs[i]) }
        i = i + 1
    }
    if w_field > 38 { w_field = 38 }
    if w_verdict > 12 { w_verdict = 12 }
    let breadcrumb_w = 56
    println("    " + ljust("field", w_field) + "  " + ljust("verdict", w_verdict) + "  breadcrumb")
    let mut rule = "    "
    let mut k = 0
    while k < w_field { rule = rule + "-"; k = k + 1 }
    rule = rule + "  "
    k = 0
    while k < w_verdict { rule = rule + "-"; k = k + 1 }
    rule = rule + "  ----------"
    println(rule)
    let mut r = 0
    while r < len(fs) {
        println("    " + ljust(shorten(fs[r], w_field), w_field) + "  " +
                ljust(vs[r], w_verdict) + "  " +
                shorten(bs[r], breadcrumb_w))
        r = r + 1
    }
}

fn main() {
    let root = exec("pwd").trim()

    println("schema_const_audit — hexa-bio schema-const propagation audit (REPORTER, not enforcer)")
    println("  walks the canonical *.schema.json corpus, classifies each")
    println("  honesty field as CONST (structurally enforced) or TYPED-ONLY")
    println("  (typed but not const-enforced — a could-be-const gap).")
    println("  governance: g1 real-limits-first (validator semantics) ·")
    println("              g3 honest gap-naming (no inflation) ·")
    println("              g7 skip-is-honest (absent schema dirs SKIP) ·")
    println("              g8 in-silico-only scope")
    println("")

    // ── discover ──
    let mut all_paths: array = []
    let mut di = 0
    while di < len(SCHEMA_SEARCH_DIRS) {
        let found = discover_under(root, SCHEMA_SEARCH_DIRS[di])
        let mut fi = 0
        while fi < len(found) {
            // dedup
            if idx_of_s(all_paths, found[fi]) < 0 { all_paths.push(found[fi]) }
            fi = fi + 1
        }
        di = di + 1
    }
    let schemas = sort_str(all_paths)

    println("  discovered " + str(len(schemas)) + " *.schema.json under " +
            str(len(SCHEMA_SEARCH_DIRS)) + " canonical search dirs")
    println("")

    // ── audit each schema ──
    // Parallel: rels[], findings_f[i][], findings_b[i][], findings_v[i][] — but
    // hexa has no nested array of arrays as first-class; we use one row per
    // schema flattened via per-schema findings arrays referenced by index.
    let mut per_schema_rel: array = []
    let mut per_schema_f: array = []   // array of arrays
    let mut per_schema_b: array = []
    let mut per_schema_v: array = []
    let mut parse_err_rel: array = []
    let mut parse_err_msg: array = []

    let mut si = 0
    while si < len(schemas) {
        let path = schemas[si]
        let rel = rel_path(root, path)
        let ok_flag = exec("[ -r " + shq(path) + " ] && echo y || echo n").trim()
        if ok_flag != "y" {
            parse_err_rel.push(rel)
            parse_err_msg.push("OSError: not readable")
        } else {
            let raw = exec("cat " + shq(path) + " 2>/dev/null")
            // hexa json_parse: best-effort; the runtime returns void on parse error
            let parsed = json_parse(raw)
            let pt = type_of(parsed)
            if pt != "map" && pt != "array" {
                parse_err_rel.push(rel)
                parse_err_msg.push("JSONDecodeError: not a JSON object")
            } else {
                let mut sf: array = []
                let mut sb: array = []
                let mut sv: array = []
                walk_properties(parsed, "$", sf, sb, sv)
                // dedup triples (verdict primary, field, breadcrumb) — same as .py
                let mut df: array = []
                let mut db: array = []
                let mut dv: array = []
                let mut k = 0
                while k < len(sf) {
                    let mut seen = false
                    let mut j = 0
                    while j < len(df) {
                        if df[j] == sf[k] && db[j] == sb[k] && dv[j] == sv[k] {
                            seen = true
                            break
                        }
                        j = j + 1
                    }
                    if !seen { df.push(sf[k]); db.push(sb[k]); dv.push(sv[k]) }
                    k = k + 1
                }
                // sort: (0 if CONST else 1, field, breadcrumb) — selection sort
                let n = len(df)
                let mut p = 0
                while p < n {
                    let mut min_i = p
                    let mut q = p + 1
                    while q < n {
                        let pa_v = if dv[min_i] == V_CONST { 0 } else { 1 }
                        let pb_v = if dv[q] == V_CONST { 0 } else { 1 }
                        let mut lt = false
                        if pb_v < pa_v { lt = true }
                        else if pb_v == pa_v {
                            if df[q] < df[min_i] { lt = true }
                            else if df[q] == df[min_i] && db[q] < db[min_i] { lt = true }
                        }
                        if lt { min_i = q }
                        q = q + 1
                    }
                    if min_i != p {
                        let tf = df[p]; df[p] = df[min_i]; df[min_i] = tf
                        let tb = db[p]; db[p] = db[min_i]; db[min_i] = tb
                        let tv = dv[p]; dv[p] = dv[min_i]; dv[min_i] = tv
                    }
                    p = p + 1
                }
                per_schema_rel.push(rel)
                per_schema_f.push(df)
                per_schema_b.push(db)
                per_schema_v.push(dv)
            }
        }
        si = si + 1
    }

    // ── parse-error reporting ──
    if len(parse_err_rel) > 0 {
        let mut hdr = "── PARSE ERRORS "
        let mut h = 0
        while h < 60 { hdr = hdr + "─"; h = h + 1 }
        println(hdr)
        let mut ei = 0
        while ei < len(parse_err_rel) {
            println("  [FAIL] " + parse_err_rel[ei])
            println("         " + parse_err_msg[ei])
            ei = ei + 1
        }
        println("")
    }

    // ── partition: with-honesty vs without-honesty ──
    let mut with_rel: array = []
    let mut with_idx: array = []
    let mut without_rel: array = []
    let mut pi = 0
    while pi < len(per_schema_rel) {
        if len(per_schema_f[pi]) > 0 {
            with_rel.push(per_schema_rel[pi])
            with_idx.push(pi)
        } else {
            without_rel.push(per_schema_rel[pi])
        }
        pi = pi + 1
    }

    // ── per-schema honesty-field tables ──
    let mut hdr1 = "── per-schema honesty-field tables (" + str(len(with_rel)) +
                   " schemas with ≥1 honesty field) "
    let mut h1 = 0
    while h1 < 6 { hdr1 = hdr1 + "─"; h1 = h1 + 1 }
    println(hdr1)

    if len(with_rel) == 0 {
        println("  (none — no honesty fields found in the corpus)")
        println("")
    } else {
        // Sort by rel path (sorted(schemas_with_honesty)) — sort indices by rel
        let mut sorted_with: array = []
        let mut wi = 0
        while wi < len(with_rel) { sorted_with.push(wi); wi = wi + 1 }
        // selection sort indices by with_rel value
        let mut wp = 0
        while wp < len(sorted_with) {
            let mut mn = wp
            let mut wq = wp + 1
            while wq < len(sorted_with) {
                if with_rel[sorted_with[wq]] < with_rel[sorted_with[mn]] { mn = wq }
                wq = wq + 1
            }
            if mn != wp {
                let tmp = sorted_with[wp]; sorted_with[wp] = sorted_with[mn]; sorted_with[mn] = tmp
            }
            wp = wp + 1
        }
        let mut wj = 0
        while wj < len(sorted_with) {
            let idx = sorted_with[wj]
            let p_idx = with_idx[idx]
            render_schema_block(with_rel[idx], per_schema_f[p_idx], per_schema_b[p_idx], per_schema_v[p_idx])
            println("")
            wj = wj + 1
        }
    }

    // ── schemas with no honesty fields ──
    let mut hdr2 = "── schemas with no honesty fields (" + str(len(without_rel)) +
                   " schemas — legitimately out-of-scope) "
    let mut h2 = 0
    while h2 < 6 { hdr2 = hdr2 + "─"; h2 = h2 + 1 }
    println(hdr2)
    let sorted_without = sort_str(without_rel)
    let cap = if len(sorted_without) < 8 { len(sorted_without) } else { 8 }
    let mut woi = 0
    while woi < cap { println("  " + sorted_without[woi]); woi = woi + 1 }
    if len(sorted_without) > 8 {
        println("  … and " + str(len(sorted_without) - 8) + " more")
    }
    println("")

    // ── could-be-const gap summary ──
    let mut hdr3 = "── could-be-const gap summary "
    let mut h3 = 0
    while h3 < 50 { hdr3 = hdr3 + "─"; h3 = h3 + 1 }
    println(hdr3)
    println("  schemas with at least one TYPED-ONLY honesty field — these")
    println("  are HONEST GAPS a future targeted fix can close (g3). They")
    println("  are NOT failures; the audit is a REPORTER, not an enforcer.")
    println("")
    // gap summary across sorted_with
    let mut any_gap = false
    if len(with_rel) > 0 {
        let mut sorted_with2: array = []
        let mut wi2 = 0
        while wi2 < len(with_rel) { sorted_with2.push(wi2); wi2 = wi2 + 1 }
        let mut wp2 = 0
        while wp2 < len(sorted_with2) {
            let mut mn = wp2
            let mut wq = wp2 + 1
            while wq < len(sorted_with2) {
                if with_rel[sorted_with2[wq]] < with_rel[sorted_with2[mn]] { mn = wq }
                wq = wq + 1
            }
            if mn != wp2 {
                let tmp = sorted_with2[wp2]; sorted_with2[wp2] = sorted_with2[mn]; sorted_with2[mn] = tmp
            }
            wp2 = wp2 + 1
        }
        let mut sj2 = 0
        while sj2 < len(sorted_with2) {
            let idx = sorted_with2[sj2]
            let p_idx = with_idx[idx]
            // typed-only fields, sorted-unique
            let mut to_set: array = []
            let mut tj = 0
            while tj < len(per_schema_v[p_idx]) {
                if per_schema_v[p_idx][tj] == V_TYPED_ONLY {
                    let fn_ = per_schema_f[p_idx][tj]
                    if idx_of_s(to_set, fn_) < 0 { to_set.push(fn_) }
                }
                tj = tj + 1
            }
            if len(to_set) > 0 {
                any_gap = true
                println("  " + with_rel[idx])
                let to_sorted = sort_str(to_set)
                let mut tk = 0
                while tk < len(to_sorted) {
                    println("      could-be-const: " + to_sorted[tk])
                    tk = tk + 1
                }
            }
            sj2 = sj2 + 1
        }
    }
    if !any_gap {
        println("  (no TYPED-ONLY honesty fields found across the audited schema set)")
    }
    println("")

    // ── aggregate counts ──
    let mut n_const = 0
    let mut n_typed = 0
    let mut ag = 0
    while ag < len(per_schema_v) {
        let vs = per_schema_v[ag]
        let mut ai = 0
        while ai < len(vs) {
            if vs[ai] == V_CONST { n_const = n_const + 1 }
            else if vs[ai] == V_TYPED_ONLY { n_typed = n_typed + 1 }
            ai = ai + 1
        }
        ag = ag + 1
    }

    let mut hdr4 = "── aggregate counts "
    let mut h4 = 0
    while h4 < 55 { hdr4 = hdr4 + "─"; h4 = h4 + 1 }
    println(hdr4)
    println("  schemas covered                : " + str(len(per_schema_rel)))
    println("  schemas with honesty fields    : " + str(len(with_rel)))
    println("  schemas with NO honesty fields : " + str(len(without_rel)) + "  (out-of-scope, fine)")
    println("  CONST honesty-field declarations    : " + str(n_const))
    println("  TYPED-ONLY honesty-field declarations: " + str(n_typed) + "  (could-be-const gap candidates)")
    if len(parse_err_rel) > 0 {
        println("  PARSE-ERROR schemas                 : " + str(len(parse_err_rel)) + "  (blocks sentinel)")
    }
    println("")

    // ── honesty notes ──
    let mut hdr5 = "── honesty (g3 honest reporting · reporter ≠ enforcer) "
    let mut h5 = 0
    while h5 < 15 { hdr5 = hdr5 + "─"; h5 = h5 + 1 }
    println(hdr5)
    println("  TYPED-ONLY is a GAP, not a FAILURE. A typed honesty field is")
    println("  not 'wrong' — the schema simply does not yet structurally")
    println("  enforce the value via `const`. A future targeted fix can add")
    println("  `\"const\": true` (or false / null) one schema at a time. The")
    println("  audit names the gap so the fix is small and obvious.")
    println("")
    println("  The `axis` field is only counted when null-typed (the SMA")
    println("  portfolio's UNPLACED CBER-drug gold-standard pattern). Real")
    println("  string axes (\"VIROCAPSID\", \"WEAVE\") are intentional content,")
    println("  not honesty gates, and are NOT counted as could-be-const gaps.")
    println("")
    println("  Single-member `enum: [\"X\"]` declarations are structurally")
    println("  const-equivalent but conservatively classed TYPED-ONLY here.")
    println("  A future tightening could promote them to CONST; the current")
    println("  classification stays on the safe side (no false PASS).")
    println("")
    println("  (g8) A PASS here verifies the audit ran cleanly on the present")
    println("  in-silico schema corpus ONLY. It is NEVER a therapeutic /")
    println("  clinical / regulatory / efficacy claim, and it is NOT a claim")
    println("  that the schemas currently flagged TYPED-ONLY will or should")
    println("  all become CONST — only that the present state is faithfully")
    println("  named so future targeted work is informed.")
    println("")

    // ── sentinel ──
    if len(parse_err_rel) > 0 {
        println("__SCHEMA_CONST_AUDIT__ FAIL")
        exit(1)
    }
    println("__SCHEMA_CONST_AUDIT__ PASS")
}
