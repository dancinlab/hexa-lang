#!hexa strict
// hexa-bio/_hexa_bridge/selftest/oligonucleotide_nanobot_cross.hexa
//
// hexa-native port of `_python_bridge/module/oligonucleotide_nanobot_cross.py`
// (T3; math/json/sys — deterministic, no network/time/random). CROSS-AXIS F1:
// OLIGONUCLEOTIDE-axis SantaLucia (1998) NN duplex thermodynamics bounds the
// NANOBOT-axis (DNA-nanotech) origami staple assembly. NO FORK (f3): the
// OLIGONUCLEOTIDE NN calculator is the same float chain already byte-parity-
// verified in oligonucleotide_hybridization_sim.hexa (sister T3 recipe). The
// NANOBOT-axis modality basis is read out of nanobot/module/nanobot.hexa via
// exec("cat ...") — deterministic structural-text substring match for
// "Rothemund 2006 DNA origami" and "Seeman 1982". Witness JSON via
// compact-build → json_parse → py_json2(wv, 0) preserving .py insertion
// order. Recipe: exact .py op order; fsum() for sum(floats); fmt("%spec",v)
// for printf width specs; js(v) bare for json_stringify float prints.
//
// HONESTY: PASS = in-silico simulator-CONSISTENCY only (g8/f2). The
// SantaLucia 1 M Na+ NN Tm is illustrative; salt-corrected Tm, staple
// cooperativity, kinetic folding pathways are out of repo scope. CROSS !=
// new axis — core-5 axis set UNCHANGED.

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"

// ── helpers (paste-standard set; preserve %width padding from printf) ─────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
// CPython 3.12+ sum(generator) is Kahan-compensated, not naive.
fn fsum(xs: array) -> float {
    let mut s = 0.0
    let mut c = 0.0
    let mut i = 0
    while i < len(xs) { let y = xs[i] - c; let t = s + y; c = (t - s) - y; s = t; i = i + 1 }
    return s
}

// Python round(x, ndigits) — banker's rounding via integer-scale arithmetic.
fn round_at(x: float, scale: float) -> float {
    let s = if x < 0.0 { -1.0 } else { 1.0 }
    let a = fabs(x)
    let scaled = a * scale
    let floor_v = (scaled + 0.0) - ((scaled + 0.0) % 1.0)
    let frac = scaled - floor_v
    let mut r = floor_v
    if frac > 0.5 { r = floor_v + 1.0 }
    else if frac < 0.5 { r = floor_v }
    else {
        // tie → half to even
        let half = floor_v / 2.0
        let half_floor = half - (half % 1.0)
        if (half_floor * 2.0) == floor_v { r = floor_v } else { r = floor_v + 1.0 }
    }
    return s * r / scale
}
fn round4(x: float) -> float { return round_at(x, 10000.0) }
fn round6(x: float) -> float { return round_at(x, 1000000.0) }

// ── OLIGONUCLEOTIDE engine (inline recap of oligonucleotide_hybridization_sim.hexa) ──

let R_CAL = 1.98720425864083
let T37_K = 310.15

fn ocomp(c: string) -> string {
    if c == "A" { return "T" }
    if c == "T" { return "A" }
    if c == "G" { return "C" }
    return "G"
}
fn orevcomp(s: string) -> string {
    let mut o = ""
    let mut i = len(s) - 1
    while i >= 0 { o = o + ocomp(s.substr(i, 1)); i = i - 1 }
    return o
}
fn ois_selfc(s: string) -> bool { return s == orevcomp(s) }

fn onn_dh_direct(d: string) -> float {
    if d == "AA" { return -7.9 }   if d == "AT" { return -7.2 }
    if d == "TA" { return -7.2 }   if d == "CA" { return -8.5 }
    if d == "GT" { return -8.4 }   if d == "CT" { return -7.8 }
    if d == "GA" { return -8.2 }   if d == "CG" { return -10.6 }
    if d == "GC" { return -9.8 }   if d == "GG" { return -8.0 }
    return 1.0
}
fn onn_ds_direct(d: string) -> float {
    if d == "AA" { return -22.2 }  if d == "AT" { return -20.4 }
    if d == "TA" { return -21.3 }  if d == "CA" { return -22.7 }
    if d == "GT" { return -22.4 }  if d == "CT" { return -21.0 }
    if d == "GA" { return -22.2 }  if d == "CG" { return -27.2 }
    if d == "GC" { return -24.4 }  if d == "GG" { return -19.9 }
    return 1.0
}
fn odoublet_rc(d: string) -> string {
    return ocomp(d.substr(1, 1)) + ocomp(d.substr(0, 1))
}
fn onn_dh(d: string) -> float {
    let v = onn_dh_direct(d)
    if v != 1.0 { return v }
    return onn_dh_direct(odoublet_rc(d))
}
fn onn_ds(d: string) -> float {
    let v = onn_ds_direct(d)
    if v != 1.0 { return v }
    return onn_ds_direct(odoublet_rc(d))
}

// returns [dH, dS, dG37]
fn nn_thermo(s: string) -> array {
    let mut dh_terms: array = []
    let mut ds_terms: array = []
    let mut i = 0
    while i < len(s) - 1 {
        let d = s.substr(i, 2)
        dh_terms.push(onn_dh(d))
        ds_terms.push(onn_ds(d))
        i = i + 1
    }
    let ends = [s.substr(0, 1), s.substr(len(s) - 1, 1)]
    let mut e = 0
    while e < 2 {
        let b = ends[e]
        if b == "G" || b == "C" { dh_terms.push(0.1); ds_terms.push(-2.8) }
        else { dh_terms.push(2.3); ds_terms.push(4.1) }
        e = e + 1
    }
    if ois_selfc(s) { dh_terms.push(0.0); ds_terms.push(-1.4) }
    let dh = fsum(dh_terms)
    let ds = fsum(ds_terms)
    let dg37 = dh - T37_K * ds / 1000.0
    return [dh, ds, dg37]
}

fn tm_celsius(dh_kcal: float, ds_cal: float, total_M: float, selfc: bool) -> float {
    let x = if selfc { 1.0 } else { 4.0 }
    let dh_cal = dh_kcal * 1000.0
    let tm_k = dh_cal / (ds_cal + R_CAL * log(total_M / x))
    return tm_k - 273.15
}

// ── constants (mirror .py module-level) ──
let SCHEMA_ID = "oligonucleotide_nanobot_cross_v1"
let SENTINEL_OK = "__OLIGONUCLEOTIDE_NANOBOT_CROSS__ PASS"
let SENTINEL_FAIL = "__OLIGONUCLEOTIDE_NANOBOT_CROSS__ FAIL"
let FOLDING_TEMP_GATE_C = 45.0
let TOTAL_STRAND_M = 0.4e-6

// ── staple panel (5 rows; id, seq, design_note) ──
fn staple_id(i: int) -> string {
    if i == 0 { return "staple_short_at_rich" }
    if i == 1 { return "staple_typical_32mer" }
    if i == 2 { return "staple_gc_clamped_28mer" }
    if i == 3 { return "staple_long_40mer" }
    return "staple_minimal_12mer"
}
fn staple_seq(i: int) -> string {
    if i == 0 { return "ATATATATAATTATAT" }
    if i == 1 { return "GCTAGCATCGGATCCATGCAACGTTACGGCTA" }
    if i == 2 { return "GCGCATCGACGTACGGATCCATGCGCGC" }
    if i == 3 { return "GCTAGCATCGGATCCATGCAACGTTACGGCTAGCATCGAC" }
    return "ATCGATCGATCG"
}
fn staple_note(i: int) -> string {
    if i == 0 { return "16-mer AT-rich crossover staple — short + low GC" }
    if i == 1 { return "32-mer mixed-composition staple — typical origami crossover length" }
    if i == 2 { return "28-mer with GC-clamped ends — high-stability staple" }
    if i == 3 { return "40-mer extended staple — long binding region" }
    return "12-mer minimal staple — below typical origami crossover length"
}
let N_STAPLES = 5

// ── read NANOBOT axis modality basis from nanobot/module/nanobot.hexa ──
fn nanobot_src(root: string) -> string {
    return exec("cat " + shq(root + "/nanobot/module/nanobot.hexa") + " 2>/dev/null")
}

fn main() {
    println("oligonucleotide_nanobot_cross — CROSS-AXIS F1\n")
    println("cross:  OLIGONUCLEOTIDE-axis SantaLucia NN duplex thermodynamics")
    println("        ──bounds──▶  NANOBOT-axis (DNA-nanotech) origami assembly")
    println("        staple sequence → SantaLucia ΔG°/Tm → fold-competence gate\n")

    // ── nanobot modality basis (substring-detect; deterministic structural text) ──
    let root = exec("pwd").trim()
    let src = nanobot_src(root)
    let mut cites: array = []
    if src.find("Rothemund 2006 DNA origami") >= 0 {
        cites.push("Rothemund 2006 DNA origami (Nature 440:297-302)")
    }
    if src.find("Seeman 1982") >= 0 {
        cites.push("Seeman 1982 immobile DNA junctions (J Theor Biol 99:237-247)")
    }
    if len(cites) == 0 {
        println("RuntimeError: expected NANOBOT axis DNA-nanotech modality citations (Rothemund 2006 / Seeman 1982) in nanobot/module/nanobot.hexa")
        println(SENTINEL_FAIL)
        exit(1)
    }
    let axis_role = "NANOBOT core-5 axis — DNA-nanotechnology actuation (C0b 12-vertex polyhedral-skeleton simulator)"

    println("  real-limit anchor : SantaLucia 1998 unified nearest-neighbor duplex")
    println("                      thermodynamics (PNAS 95:1460-1465) — staple")
    println("                      stability bounded by base-pair stacking ΔG°")
    println("  NANOBOT axis      : " + axis_role)
    let mut ci = 0
    while ci < len(cites) {
        println("    modality basis  : " + cites[ci])
        ci = ci + 1
    }
    println("  folding gate      : staple:scaffold duplex Tm >= " +
            fmt("%.1f", FOLDING_TEMP_GATE_C) + " °C → fold-competent\n")

    // ── build per-staple cross rows ──
    let mut rows: array = []
    let mut tms: array = []
    let mut margins: array = []
    let mut gcs: array = []
    let mut lengths: array = []
    let mut competents: array = []
    let mut dh_list: array = []
    let mut ds_list: array = []
    let mut dg_list: array = []

    let mut k = 0
    while k < N_STAPLES {
        let seq = staple_seq(k)
        let nn = nn_thermo(seq)
        let dh = nn[0]; let ds = nn[1]; let dg37 = nn[2]
        let selfc = ois_selfc(seq)
        let tm_raw = tm_celsius(dh, ds, TOTAL_STRAND_M, selfc)
        // duplex_report() rounds dH/dS/dG37/Tm to 4dp
        let tm = round4(tm_raw)
        let dh_r = round4(dh)
        let ds_r = round4(ds)
        let dg37_r = round4(dg37)
        // gc_fraction: count G/C, divide by length, then round_to_4dp inside
        // duplex_report; build_cross_rows wraps with round(., 6).
        let n_nt = len(seq)
        let mut gc_count = 0
        let mut m = 0
        while m < n_nt {
            let c = seq.substr(m, 1)
            if c == "G" || c == "C" { gc_count = gc_count + 1 }
            m = m + 1
        }
        let gc_frac = round6((gc_count + 0.0) / (n_nt + 0.0))
        let fold_competent = tm >= FOLDING_TEMP_GATE_C
        let margin = round4(tm - FOLDING_TEMP_GATE_C)

        // ── per-row witness map (preserve .py insertion order) ──
        let mut row: any = {}
        row["schema"] = SCHEMA_ID
        row["staple_id"] = staple_id(k)
        row["design_note"] = staple_note(k)
        row["sequence_5to3"] = seq
        row["length_nt"] = n_nt
        row["gc_fraction"] = gc_frac
        row["nanobot_axis_source"] = "nanobot/module/nanobot.hexa"
        row["nanobot_axis_role"] = axis_role
        row["modality_basis_cited_by_axis"] = cites
        row["oligonucleotide_model"] = "SantaLucia 1998 unified NN (PNAS 95:1460); 1 M Na+ standard state"
        row["dH_kcal_mol"] = dh_r
        row["dS_cal_mol_K"] = ds_r
        row["dG37_kcal_mol"] = dg37_r
        row["Tm_celsius"] = tm
        row["total_strand_M"] = TOTAL_STRAND_M
        row["folding_temp_gate_celsius"] = FOLDING_TEMP_GATE_C
        row["tm_margin_celsius"] = margin
        row["fold_competent"] = fold_competent
        row["in_silico_caveat"] = "in-silico simulator-consistency only (AGENTS.tape g8/f2) — the SantaLucia 1 M Na+ NN Tm is illustrative, NOT a real origami folding temperature; NOT a structural/yield/nanodevice-function/therapeutic claim"
        row["illustrative_only"] = true
        rows.push(row)
        tms.push(tm)
        margins.push(margin)
        gcs.push(gc_frac)
        lengths.push(n_nt)
        competents.push(fold_competent)
        dh_list.push(dh_r)
        ds_list.push(ds_r)
        dg_list.push(dg37_r)
        k = k + 1
    }

    // ── per-row print lines (mirror .py main(): flag + size + GC + Tm + margin) ──
    let mut p = 0
    while p < N_STAPLES {
        let flag = if competents[p] { "fold-competent" } else { "BELOW GATE" }
        // f"[{r['staple_id']:<24}] {flag:<15} n={r['length_nt']:>2}  GC={r['gc_fraction']*100:5.1f}%  Tm={r['Tm_celsius']:6.2f} °C  (margin {r['tm_margin_celsius']:+6.2f})"
        let n_str = if lengths[p] < 10 { " " + str(lengths[p]) } else { str(lengths[p]) }
        let gc_pct = gcs[p] * 100.0
        println("  [" + ljust(staple_id(p), 24) + "] " + ljust(flag, 15) + " " +
                "n=" + n_str + "  " +
                "GC=" + fmt("%5.1f", gc_pct) + "%  " +
                "Tm=" + fmt("%6.2f", tms[p]) + " °C  " +
                "(margin " + fmt("%+6.2f", margins[p]) + ")")
        // f"    ΔG°(37)={r['dG37_kcal_mol']:8.2f} kcal/mol  ΔH°={r['dH_kcal_mol']:8.2f}  ΔS°={r['dS_cal_mol_K']:8.2f}"
        println("      ΔG°(37)=" + fmt("%8.2f", dg_list[p]) + " kcal/mol  " +
                "ΔH°=" + fmt("%8.2f", dh_list[p]) + "  " +
                "ΔS°=" + fmt("%8.2f", ds_list[p]))
        p = p + 1
    }

    // ── acceptance: X1..X6 ──
    // X1: panel size
    let X1 = (len(rows) == N_STAPLES) && (len(rows) >= 5)
    // X2: SantaLucia model used in every row
    let mut X2 = true
    let mut a2 = 0
    while a2 < len(rows) {
        if str(rows[a2]["oligonucleotide_model"]).find("SantaLucia 1998") < 0 { X2 = false }
        a2 = a2 + 1
    }
    // X3: nanobot modality basis read (>=1 per row)
    let mut X3 = true
    let mut a3 = 0
    while a3 < len(rows) {
        if len(rows[a3]["modality_basis_cited_by_axis"]) < 1 { X3 = false }
        a3 = a3 + 1
    }
    // X4: tm_margin consistency
    let mut X4 = true
    let mut a4 = 0
    while a4 < len(rows) {
        let m_chk = fabs(margins[a4] - (tms[a4] - FOLDING_TEMP_GATE_C))
        if !(m_chk < 1.0e-9) { X4 = false }
        if competents[a4] != (margins[a4] >= 0.0) { X4 = false }
        a4 = a4 + 1
    }
    // X5: both outcomes present
    let mut n_comp = 0
    let mut n_block = 0
    let mut a5 = 0
    while a5 < len(rows) {
        if competents[a5] { n_comp = n_comp + 1 } else { n_block = n_block + 1 }
        a5 = a5 + 1
    }
    let X5 = (n_comp >= 1) && (n_block >= 1)
    // X6: GC monotonicity within equal-length groups
    let mut X6 = true
    let mut a6 = 0
    while a6 < len(rows) {
        let mut a7 = 0
        while a7 < len(rows) {
            if lengths[a6] == lengths[a7] {
                if (gcs[a6] > gcs[a7]) && (tms[a6] < tms[a7]) { X6 = false }
            }
            a7 = a7 + 1
        }
        a6 = a6 + 1
    }

    // count
    let crit_vals = [X1, X2, X3, X4, X5, X6]
    let mut n_pass = 0
    let mut cp = 0
    while cp < 6 { if crit_vals[cp] { n_pass = n_pass + 1 }; cp = cp + 1 }
    let verdict = if n_pass == 6 { "PASS" } else { "FAIL" }

    println("")
    println("## acceptance — in-silico simulator-consistency criteria")
    println("  [" + (if X1 { "PASS" } else { "FAIL" }) + "] X1_panel_crossed")
    println("  [" + (if X2 { "PASS" } else { "FAIL" }) + "] X2_santalucia_model_used")
    println("  [" + (if X3 { "PASS" } else { "FAIL" }) + "] X3_nanobot_modality_basis_read")
    println("  [" + (if X4 { "PASS" } else { "FAIL" }) + "] X4_tm_margin_consistent")
    println("  [" + (if X5 { "PASS" } else { "FAIL" }) + "] X5_both_outcomes_present")
    println("  [" + (if X6 { "PASS" } else { "FAIL" }) + "] X6_gc_raises_tm_monotone")
    println("")
    println("  --- " + str(n_pass) + "/6  →  verdict: " + verdict + " ---")

    // ── honesty block ──
    println("")
    println("## honesty (g3 / g8 / f1 / f2 / f3)")
    println("  - Both sims are imported / read as data — no fork (f3): the")
    println("    SantaLucia NN calculator is called verbatim; the NANOBOT .hexa")
    println("    actuation logic is not executed and not duplicated.")
    println("  - The SantaLucia 1 M Na+ standard state is NOT the Mg2+-buffered")
    println("    condition real DNA-origami folding uses; salt-corrected Tm,")
    println("    staple cooperativity, scaffold routing and kinetic folding")
    println("    pathways are out of repo scope — the Tm values are illustrative.")
    println("  - The staple panel sequences are illustrative deterministic test")
    println("    inputs, NOT a published origami staple set.")
    println("  - This verdict certifies IN-SILICO simulator-CONSISTENCY ONLY: the")
    println("    chain staple-sequence → SantaLucia ΔG°/Tm → fold-competence is")
    println("    computed self-consistently and re-runs byte-identically. It is")
    println("    NOT a structural / folding-yield / nanodevice-function /")
    println("    therapeutic claim (g8/f2).")
    println("  - No ΔG°/ΔH°/ΔS°/Tm/count here is derived from the n=6 lattice")
    println("    (g2/f_lattice_fit). A cross-axis bridge is NOT a new axis — the")
    println("    core-5 set is UNCHANGED.")

    // ── witness JSON ──
    // Build acceptance map (preserve .py insertion order: criteria → pass_count → total → verdict)
    let mut crit_map: any = {}
    crit_map["X1_panel_crossed"] = X1
    crit_map["X2_santalucia_model_used"] = X2
    crit_map["X3_nanobot_modality_basis_read"] = X3
    crit_map["X4_tm_margin_consistent"] = X4
    crit_map["X5_both_outcomes_present"] = X5
    crit_map["X6_gc_raises_tm_monotone"] = X6
    let mut acc: any = {}
    acc["criteria"] = crit_map
    acc["pass_count"] = n_pass
    acc["total"] = 6
    acc["verdict"] = verdict

    // witness top-level (preserve .py dict insertion order)
    let mut wv: any = {}
    wv["schema"] = SCHEMA_ID
    wv["ts"] = "2026-05-16T00:00:00Z"
    wv["cross"] = "F1  OLIGONUCLEOTIDE-axis SantaLucia NN duplex thermodynamics ->  NANOBOT-axis DNA-origami staple assembly bound"
    wv["oligonucleotide_axis_source"] = "_python_bridge/module/oligonucleotide_hybridization_sim.py (SantaLucia NN calculator imported, not re-implemented — f3)"
    wv["nanobot_axis_source"] = "nanobot/module/nanobot.hexa (DNA-nanotech modality basis read as structural text; actuation logic untouched — f3)"
    wv["real_limit_anchor"] = "SantaLucia 1998 unified nearest-neighbor DNA duplex thermodynamics (PNAS 95:1460-1465) — staple stability bounded by base-pair stacking free energy"
    wv["modality_precedent"] = "DNA origami — Rothemund 2006 (Nature 440:297-302); immobile DNA junctions — Seeman 1982 (J Theor Biol 99:237-247); own precedent, NOT lattice-derived (g3/f1)"
    wv["folding_temp_gate_celsius"] = FOLDING_TEMP_GATE_C
    wv["total_strand_M"] = TOTAL_STRAND_M
    wv["rows"] = rows
    wv["acceptance"] = acc
    wv["in_silico_scope_caveat"] = "simulator-consistency ONLY (g8/f2) — the SantaLucia 1 M Na+ NN Tm is illustrative, NOT a real origami folding temperature; NOT a structural / folding-yield / nanodevice-function / therapeutic claim. Core-5 axis set UNCHANGED; this is a cross, not a new axis."

    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))

    println("")
    if verdict == "PASS" { println(SENTINEL_OK); return }
    println(SENTINEL_FAIL)
    exit(1)
}
