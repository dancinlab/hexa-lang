            q + "Goadsby PJ et al., Lancet Neurol 19:727 (2020) — atogepant phase IIb/III dose-finding" + q + ", " +
            q + "FDA NDA 215206 (Qulipta, 2021-09-28)" + q + "], " +
        q + "fda_application" + q + ": " + q + "NDA 215206 — Qulipta first approval 2021-09-28 (preventive treatment of episodic migraine in adults)" + q + ", " +
        q + "fda_center" + q + ": " + q + "CDER" + q + ", " +
        q + "fda_year" + q + ": 2021, " +
        q + "in_silico_only" + q + ": true, " +
        q + "modality" + q + ": " + q + modality_base + "preventive; " + modality_tail + q + ", " +
        q + "real_limit_anchor" + q + ": " + q + real_limit_anchor + q + ", " +
        q + "sim_run" + q + ": " + sim_run + ", " +
        q + "sponsor" + q + ": " + q + "AbbVie" + q + "}"

    let zavegepant = "{" +
        q + "axis_mapping" + q + ": " + axis_mapping + ", " +
        q + "brand" + q + ": " + q + "Zavzpret" + q + ", " +
        q + "drug" + q + ": " + q + "zavegepant" + q + ", " +
        q + "drug_precedent_refs" + q + ": [" +
            q + "Lipton RB et al., Lancet Neurol 22:209 (2023) — zavegepant intranasal phase III" + q + ", " +
            q + "Croop R et al., Headache 62:1153 (2022) — zavegepant intranasal phase II/III dose-ranging" + q + ", " +
            q + "FDA NDA 216386 (Zavzpret, 2023-03-09)" + q + "], " +
        q + "fda_application" + q + ": " + q + "NDA 216386 — Zavzpret first approval 2023-03-09 (acute treatment of migraine; first intranasal CGRP-receptor antagonist)" + q + ", " +
        q + "fda_center" + q + ": " + q + "CDER" + q + ", " +
        q + "fda_year" + q + ": 2023, " +
        q + "in_silico_only" + q + ": true, " +
        q + "modality" + q + ": " + q + modality_base + "intranasal acute; " + modality_tail + q + ", " +
        q + "real_limit_anchor" + q + ": " + q + real_limit_anchor + q + ", " +
        q + "sim_run" + q + ": " + sim_run + ", " +
        q + "sponsor" + q + ": " + q + "Pfizer" + q + "}"

    // -- not_in_scope_drugs (4 CBER mAbs; per-drug keys sorted) --
    let unplaced_precedent = "AXIS/HIERARCHY.tape @N genetic_medicine_status (same UNPLACED handling family) and @N adc_status (parallel CBER-antibody-scope UNPLACED note); case_studies/sma_portfolio/ Zolgensma row as the in-repo precedent for CBER FDA-approved biologics"

    let erenumab = "{" +
        q + "axis" + q + ": null, " +
        q + "brand" + q + ": " + q + "Aimovig" + q + ", " +
        q + "drug" + q + ": " + q + "erenumab" + q + ", " +
        q + "drug_precedent_refs" + q + ": [" +
            q + "Goadsby PJ et al., N Engl J Med 377:2123 (2017) — erenumab phase III STRIVE" + q + ", " +
            q + "FDA BLA 761077 (Aimovig, 2018-05-17, CBER)" + q + "], " +
        q + "fda_center" + q + ": " + q + "CBER" + q + ", " +
        q + "fda_year" + q + ": 2018, " +
        q + "in_scope" + q + ": false, " +
        q + "modality" + q + ": " + q + "anti-CGRP-RECEPTOR fully human IgG2 monoclonal antibody — subcutaneous; the only anti-receptor mAb in the class (the other three target the CGRP ligand itself)" + q + ", " +
        q + "reason" + q + ": " + q + "CBER biologic — criterion #4 drug-only/CDER scope boundary. Monoclonal antibodies are CBER-regulated; implementing a code axis for CBER mAbs would breach criterion #4 + g8 in-silico-only honesty. FDA-approved 2018 (BLA 761077)." + q + ", " +
        q + "reported_not_run" + q + ": true, " +
        q + "sponsor" + q + ": " + q + "Amgen / Novartis" + q + ", " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + unplaced_precedent + q + "}"

    let fremanezumab = "{" +
        q + "axis" + q + ": null, " +
        q + "brand" + q + ": " + q + "Ajovy" + q + ", " +
        q + "drug" + q + ": " + q + "fremanezumab" + q + ", " +
        q + "drug_precedent_refs" + q + ": [" +
            q + "Silberstein SD et al., N Engl J Med 377:2113 (2017) — fremanezumab phase III HALO-CM/HALO-EM" + q + ", " +
            q + "FDA BLA 761089 (Ajovy, 2018-09-14, CBER)" + q + "], " +
        q + "fda_center" + q + ": " + q + "CBER" + q + ", " +
        q + "fda_year" + q + ": 2018, " +
        q + "in_scope" + q + ": false, " +
        q + "modality" + q + ": " + q + "anti-CGRP humanized IgG2 monoclonal antibody — subcutaneous (monthly or quarterly); targets the CGRP ligand" + q + ", " +
        q + "reason" + q + ": " + q + "CBER biologic — criterion #4 drug-only/CDER scope boundary. Monoclonal antibodies are CBER-regulated; implementing a code axis for CBER mAbs would breach criterion #4 + g8 in-silico-only honesty. FDA-approved 2018 (BLA 761089)." + q + ", " +
        q + "reported_not_run" + q + ": true, " +
        q + "sponsor" + q + ": " + q + "Teva Pharmaceuticals" + q + ", " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + unplaced_precedent + q + "}"

    let galcanezumab = "{" +
        q + "axis" + q + ": null, " +
        q + "brand" + q + ": " + q + "Emgality" + q + ", " +
        q + "drug" + q + ": " + q + "galcanezumab" + q + ", " +
        q + "drug_precedent_refs" + q + ": [" +
            q + "Stauffer VL et al., JAMA Neurol 75:1080 (2018) — galcanezumab phase III EVOLVE-1" + q + ", " +
            q + "Skljarevski V et al., Cephalalgia 38:1442 (2018) — galcanezumab phase III EVOLVE-2" + q + ", " +
            q + "FDA BLA 761063 (Emgality, 2018-09-27, CBER)" + q + "], " +
        q + "fda_center" + q + ": " + q + "CBER" + q + ", " +
        q + "fda_year" + q + ": 2018, " +
        q + "in_scope" + q + ": false, " +
        q + "modality" + q + ": " + q + "anti-CGRP humanized IgG4 monoclonal antibody — subcutaneous monthly; targets the CGRP ligand" + q + ", " +
        q + "reason" + q + ": " + q + "CBER biologic — criterion #4 drug-only/CDER scope boundary. Monoclonal antibodies are CBER-regulated; implementing a code axis for CBER mAbs would breach criterion #4 + g8 in-silico-only honesty. FDA-approved 2018 (BLA 761063)." + q + ", " +
        q + "reported_not_run" + q + ": true, " +
        q + "sponsor" + q + ": " + q + "Eli Lilly" + q + ", " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + unplaced_precedent + q + "}"

    let eptinezumab = "{" +
        q + "axis" + q + ": null, " +
        q + "brand" + q + ": " + q + "Vyepti" + q + ", " +
        q + "drug" + q + ": " + q + "eptinezumab" + q + ", " +
        q + "drug_precedent_refs" + q + ": [" +
            q + "Ashina M et al., Cephalalgia 40:241 (2020) — eptinezumab phase III PROMISE-1" + q + ", " +
            q + "Lipton RB et al., Neurology 94:e1365 (2020) — eptinezumab phase III PROMISE-2" + q + ", " +
            q + "FDA BLA 761119 (Vyepti, 2020-02-21, CBER)" + q + "], " +
        q + "fda_center" + q + ": " + q + "CBER" + q + ", " +
        q + "fda_year" + q + ": 2020, " +
        q + "in_scope" + q + ": false, " +
        q + "modality" + q + ": " + q + "anti-CGRP humanized IgG1 monoclonal antibody — INTRAVENOUS (the only IV mAb in the class; quarterly infusion); targets the CGRP ligand" + q + ", " +
        q + "reason" + q + ": " + q + "CBER biologic — criterion #4 drug-only/CDER scope boundary. Monoclonal antibodies are CBER-regulated; implementing a code axis for CBER mAbs would breach criterion #4 + g8 in-silico-only honesty. FDA-approved 2020 (BLA 761119)." + q + ", " +
        q + "reported_not_run" + q + ": true, " +
        q + "sponsor" + q + ": " + q + "Lundbeck (Alder BioPharmaceuticals)" + q + ", " +
        q + "unplaced_precedent_in_repo" + q + ": " + q + unplaced_precedent + q + "}"

    // -- cross_axis_touch_points (G3; keys sorted: id, module, note) --
    let touch_g3 = "{" +
        q + "id" + q + ": " + q + "G3" + q + ", " +
        q + "module" + q + ": " + q + "_python_bridge/module/ppi_molecular_glue_cross.py" + q + ", " +
        q + "note" + q + ": " + q + "G3 (PPI × MOLECULAR-GLUE) is cited for COMPLETENESS only — gepants are PPI DISRUPTORS, NOT molecular glues. No migraine-specific molecular glue exists; this portfolio does NOT claim a molecular-glue modality for any gepant. The cross-axis touch-point is recorded so the parity table mirrors the BCL-2 portfolio's G3 reference." + q + "}"

    // -- disease (keys sorted: abbreviation, name, target_pathway) --
    let disease_json = "{" +
        q + "abbreviation" + q + ": " + q + "MIGRAINE" + q + ", " +
        q + "name" + q + ": " + q + "migraine (episodic and chronic; acute and preventive indications across the gepant class)" + q + ", " +
        q + "target_pathway" + q + ": " + q + "CGRP (calcitonin-gene-related-peptide) signalling at the CGRP receptor (CLR + RAMP1 receptor complex) on trigeminal sensory neurons and vascular smooth muscle" + q + "}"

    // -- honesty (keys sorted) --
    let honesty_statement = "Per-disease IN-SILICO composition of one existing sub-axis sim (PPI :> QUANTUM) for the four FDA-approved CDER small-molecule CGRP-receptor antagonists (gepants): rimegepant / Nurtec ODT (Pfizer/Biohaven, FDA 2020), ubrogepant / Ubrelvy (AbbVie/Allergan, FDA 2019), atogepant / Qulipta (AbbVie, FDA 2021) and zavegepant / Zavzpret (Pfizer, FDA 2023, intranasal). All four disrupt the CGRP / CGRP-receptor PPI by occupying the orthosteric peptide-binding site on the CLR + RAMP1 receptor complex — one PPI-disruption modality class, four approved drugs. The parent ppi_sim's `mdm2_p53_cleft` row is used as the panel-class surrogate (`alpha_helix_peptide_cleft` interface class) honestly — the parent sim's own honesty note states ΔΔG values are literature-informed surrogates for interface CLASSES, NOT fits to specific complexes. The four FDA-approved CBER monoclonal antibodies (erenumab / Aimovig 2018, fremanezumab / Ajovy 2018, galcanezumab / Emgality 2018, eptinezumab / Vyepti 2020) are honestly UNPLACED with axis=null and reported_not_run=true — CBER biologics fall outside the hexa-bio criterion #4 drug-only/CDER scope boundary (same honest pattern as Zolgensma in case_studies/sma_portfolio/). UNPLACED is the honest call — NOT a deferral or downgrade; all four mAbs are FDA-approved. G3 (PPI × MOLECULAR-GLUE) is cited for completeness only — no gepant is claimed as a molecular glue. NEVER a therapeutic / clinical / neurologic / efficacy / regulatory / portfolio-recommendation claim (g8 / f2). Drugs described by own published precedent (Croop 2019, Dodick 2019, Ailani 2021, Lipton 2023, and the FDA approval letters) — nothing is derived from the n=6 lattice (g3 / f1 / f_lattice_fit). The 200-disease re-mapping remains deferred per AXIS/HIERARCHY.tape Log."
    let honesty_json = "{" +
        q + "cber_mabs_unplaced_handled_honestly" + q + ": true, " +
        q + "core_5_unchanged" + q + ": true, " +
        q + "in_silico_only" + q + ": true, " +
        q + "no_fork_of_sister_sims" + q + ": true, " +
        q + "no_lattice_derivation" + q + ": true, " +
        q + "not_a_molecular_glue_claim" + q + ": true, " +
        q + "one_disease_pilot_not_200_disease_remap" + q + ": true, " +
        q + "statement" + q + ": " + q + honesty_statement + q + "}"

    // -- top-level witness (keys sorted: acceptance, case_study_id,
    //    cross_axis_touch_points, disease, honesty, in_scope_drugs,
    //    not_in_scope_drugs, schema_version, sentinel, ts) --
    let witness = "{" +
        q + "acceptance" + q + ": " + acc_json + ", " +
        q + "case_study_id" + q + ": " + q + CASE_STUDY_ID + q + ", " +
        q + "cross_axis_touch_points" + q + ": [" + touch_g3 + "], " +
        q + "disease" + q + ": " + disease_json + ", " +
        q + "honesty" + q + ": " + honesty_json + ", " +
        q + "in_scope_drugs" + q + ": [" + rimegepant + ", " + ubrogepant + ", " +
            atogepant + ", " + zavegepant + "], " +
        q + "not_in_scope_drugs" + q + ": [" + erenumab + ", " + fremanezumab + ", " +
            galcanezumab + ", " + eptinezumab + "], " +
        q + "schema_version" + q + ": " + q + SCHEMA_VERSION + q + ", " +
        q + "sentinel" + q + ": " + q + (if verdict_pass { SENTINEL_PASS } else { SENTINEL_FAIL }) + q + ", " +
        q + "ts" + q + ": " + q + TS_FIXED + q + "}"

    let wv = json_parse(witness)
    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))
    println("")

    if verdict_pass {
        println(SENTINEL_PASS)
        return
    }
    println(SENTINEL_FAIL)
    exit(1)
}
