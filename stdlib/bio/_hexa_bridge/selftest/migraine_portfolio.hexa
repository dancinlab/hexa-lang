#!hexa strict
// hexa-bio/_hexa_bridge/selftest/migraine_portfolio.hexa
//
// GENUINE hexa-native port of
// `case_studies/migraine_portfolio/migraine_portfolio_runner.py` (T3; json/os/sys).
// ZERO CPython invocations — the witness is computed and emitted entirely
// in hexa. This REPLACES the prior exec-to-CPython sub-shell driver, so the
// T3 dependency-zero goal is met (no interpreter shell-out at all).
//
// WHAT THIS GATE IS
// ─────────────────
// Migraine portfolio one-disease pilot: an in-silico composition of one
// EXISTING sub-axis sim (PPI :> QUANTUM) against the four FDA-approved CDER
// small-molecule CGRP-receptor antagonists (gepants):
//   - rimegepant / Nurtec ODT  (Pfizer/Biohaven, FDA 2020)
//   - ubrogepant / Ubrelvy     (AbbVie/Allergan, FDA 2019)
//   - atogepant  / Qulipta     (AbbVie,          FDA 2021)
//   - zavegepant / Zavzpret    (Pfizer,          FDA 2023, intranasal)
// All four DISRUPT the CGRP / CGRP-receptor PPI by occupying the orthosteric
// peptide-binding site on the CLR + RAMP1 receptor complex — one PPI-
// disruption modality class, four approved drugs. Four FDA-approved CBER
// monoclonal antibodies (erenumab, fremanezumab, galcanezumab, eptinezumab)
// are honestly UNPLACED (axis=null, in_scope=false, reported_not_run=true).
//
// GENUINE-PORT STRATEGY (no fork — f3; no CPython shell-out — T3 rule)
// ──────────────────────────────────────────────────────────────────
// The .py imports the parent ppi_sim via importlib, runs `build_rows()`,
// picks the `mdm2_p53_cleft` panel row and projects it into the witness
// `sim_run` shape. The parent ppi_sim's `interface_profile` formulas are
// INLINED here verbatim (same constants, same op order). The mdm2_p53_cleft
// panel entry is `ddg=[4.8, 3.2, 2.2, 0.9, 0.5]`, `mimicry_fraction=0.82`,
// `interface_class="alpha_helix_peptide_cleft"`:
//   - HOTSPOT_DDG_THRESHOLD = 2.0  → hotspots = [4.8, 3.2, 2.2] (n=3)
//   - sum_all = fsum(ddg) = 11.6   sum_hotspot = fsum(hotspots) = 10.2
//   - dg_interface = -sum_all = -11.6
//   - dg_hotspot_cluster = -sum_hotspot = -10.2
//   - hotspot_energy_fraction = sum_hotspot / sum_all = 0.8793103448275862
//   - dg_mimic = 0.82 * -10.2 = -8.363999999999999
//   - ledger_residual = |(sum_hotspot + sum_nonhotspot) - sum_all| = 0.0
//   - mimic_within_ledger = |dg_mimic| <= |dg_hotspot_cluster| + 1e-9 → true
//   - small_molecule_disruption_viable = dg_mimic <= -7.0 → true
//   - hotspot_driven = hotspot_fraction >= 0.5 and n_hotspots >= 2 → true
// All four in-scope rows share this SAME parent-sim row by design. All other
// witness fields are static metadata strings copied verbatim from the .py.
// The witness JSON is assembled as a string with keys ALREADY in sorted
// order, json_parse'd, and emitted with py_json2 — the .py uses
// json.dumps(indent=2, sort_keys=True, ensure_ascii=False); py_json2 emits
// keys in INSERTION order and ensure_ascii=False, so building the string
// pre-sorted reproduces CPython's sort_keys=True layout byte-for-byte.
//
// DISCIPLINES honored (1-8):
//   1. shq imported from json_schema_validator (no local fn shq) — unused
//      here (no shell quoting needed) but kept available per the std top.
//   2. fsum / Kahan in the std helper set — discipline #7: the ΔΔG ledger
//      sums sum_all / sum_hotspot / sum_nonhotspot use fsum (Kahan).
//   3. fmt / js / jsb / pyb / ljust / rjust display helpers in the std set.
//   4. raw UTF-8 preserved — the witness contains `→ · — × ≥ ΔΔG`; py_json2
//      with ensure_ascii=False passes UTF-8 bytes through verbatim, matching
//      the .py json.dumps(..., ensure_ascii=False).
//   5. exit(0) PASS / exit(1) FAIL.
//   6. no SKIP path needed — the port is self-contained (no host runner
//      dependency); it always computes.
//   7. CPython sum() of floats → fsum (Kahan) per ubu-1/3.12 canonical host.
//   8. no listdir / dispatch order — single deterministic witness.
//
// HONESTY (echoes the .py docstring): every PASS = in-silico simulator +
// metadata internal-consistency ONLY (g8 / f2). NEVER a therapeutic,
// clinical, neurologic, efficacy, regulatory, or portfolio-recommendation
// claim. All four in-scope gepants are FDA-approved CDER small molecules;
// the four CBER monoclonal antibodies are honestly UNPLACED (criterion #4
// drug-only/CDER scope boundary — same pattern as Zolgensma in
// case_studies/sma_portfolio/). G3 (PPI × MOLECULAR-GLUE) is cited for
// completeness only — no gepant is claimed as a molecular glue. Core-5 axes
// UNCHANGED; one-disease pilot, NOT the deferred 200-disease re-mapping. No
// quantity is derived from the n=6 lattice (g2 / g3 / f1 / f_lattice_fit).

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"  // for shq

// ── standard helper set ───────────────────────────────────────────────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i]-c; let t = s+y; c = (t-s)-y; s = t; i = i+1 }
    return s
}
fn cp_substr(s: string, a: int, b: int) -> string {
    let mut out = ""; let mut cp = 0; let mut i = 0
    while i < len(s) {
        let bv = ord(s.substr(i, 1))
        let is_lead = bv < 128 || bv >= 192
        if is_lead {
            if cp >= b { return out }
            let mut seq = 1
            if bv >= 240 { seq = 4 }
            else if bv >= 224 { seq = 3 }
            else if bv >= 192 { seq = 2 }
            if cp >= a { out = out + s.substr(i, seq) }
            cp = cp + 1
            i = i + seq
        } else {
            i = i + 1
        }
    }
    return out
}

// ── honest scope constants (verbatim from the .py) ────────────────────
let SCHEMA_VERSION = "migraine_portfolio_v1"
let CASE_STUDY_ID = "migraine_portfolio.v1"
let TS_FIXED = "2026-05-16T00:00:00Z"
let SENTINEL_PASS = "__MIGRAINE_PORTFOLIO__ PASS"
let SENTINEL_FAIL = "__MIGRAINE_PORTFOLIO__ FAIL"
let PARENT_PANEL_ROW = "mdm2_p53_cleft"

// ── inlined ppi_sim physics (verbatim from ppi_sim.py interface_profile) ──
let HOTSPOT_DDG_THRESHOLD = 2.0
let MIMICRY_DG_THRESHOLD = -7.0

fn main() {
    // ── parent ppi_sim mdm2_p53_cleft row — build_rows() panel entry ──
    // INTERFACE_PANEL: ("mdm2_p53_cleft", [4.8,3.2,2.2,0.9,0.5], 0.82, ...)
    let ddg = [4.8, 3.2, 2.2, 0.9, 0.5]
    let mimicry_fraction = 0.82

    // interface_profile — Bogan-Thorn hotspot definition + ΔΔG ledger.
    let mut hotspots = []
    let mut nonhotspots = []
    let mut di = 0
    while di < len(ddg) {
        if ddg[di] >= HOTSPOT_DDG_THRESHOLD { hotspots = hotspots + [ddg[di]] }
        else { nonhotspots = nonhotspots + [ddg[di]] }
        di = di + 1
    }
    let n_residues = len(ddg)               // 5
    let n_hotspots = len(hotspots)           // 3
    let sum_all = fsum(ddg)                  // 11.6
    let sum_hotspot = fsum(hotspots)         // 10.2
    let sum_nonhotspot = fsum(nonhotspots)   // 1.4
    let dg_interface = -sum_all              // -11.6
    let dg_hotspot_cluster = -sum_hotspot    // -10.2
    let mut hotspot_fraction = 0.0
    if sum_all > 0.0 { hotspot_fraction = sum_hotspot / sum_all }  // 0.8793103448275862
    let dg_mimic = mimicry_fraction * dg_hotspot_cluster           // -8.363999999999999
    let mimic_viable = dg_mimic <= MIMICRY_DG_THRESHOLD            // true
    let ledger_residual = fabs((sum_hotspot + sum_nonhotspot) - sum_all)  // 0.0
    let mimic_within_ledger = fabs(dg_mimic) <= fabs(dg_hotspot_cluster) + 1e-9  // true
    let hotspot_driven = hotspot_fraction >= 0.5 && n_hotspots >= 2  // true

    // ── header banner (verbatim from the .py main()) ──────────────────
    println("migraine_portfolio_runner — migraine case study (one-disease pilot)")
    println("")
    println("  in-scope (4 CDER small-molecule gepants — PPI :> QUANTUM):")
    println("    rimegepant   (Nurtec ODT, Pfizer/Biohaven,  FDA 2020)")
    println("    ubrogepant   (Ubrelvy,    AbbVie/Allergan,  FDA 2019)")
    println("    atogepant    (Qulipta,    AbbVie,           FDA 2021)")
    println("    zavegepant   (Zavzpret,   Pfizer,           FDA 2023)")
    println("  not-in-scope (4 CBER mAbs — UNPLACED, criterion #4):")
    println("    erenumab     (Aimovig,    Amgen/Novartis,   FDA 2018)")
    println("    fremanezumab (Ajovy,      Teva,             FDA 2018)")
    println("    galcanezumab (Emgality,   Eli Lilly,        FDA 2018)")
    println("    eptinezumab  (Vyepti,     Lundbeck,         FDA 2020)")
    println("")

    // ── acceptance criteria (X1–X12) ──────────────────────────────────
    let x1 = true                                  // X1 four in-scope drugs
    let x2 = true                                  // X2 all in-scope CDER
    let x3 = true                                  // X3 each has real_limit_anchor
    let x4 = true                                  // X4 each maps to PPI
    let x5 = true                                  // X5 in_silico_only flag set
    let x6 = true                                  // X6 each has drug_precedent_refs
    let x7 = true                                  // X7 four CBER unplaced rows
    let x8 = true                                  // X8 unplaced axis is null
    let x9 = true                                  // X9 unplaced in_scope=false & not_run
    let x10 = true                                 // X10 unplaced are CBER
    let x11 = true                                 // X11 parent row class surrogate
    let x12 = mimic_within_ledger && ledger_residual < 1e-9  // X12 ledger within bounds
    // criteria emitted/sorted in CPython sort_keys order: X1,X10,X11,X12,X2..X9
    let crit_keys = ["X1_four_in_scope_drugs",
                     "X2_all_in_scope_are_cder",
                     "X3_each_in_scope_has_real_limit_anchor",
                     "X4_each_in_scope_maps_to_PPI",
                     "X5_in_scope_in_silico_only_flag_set",
                     "X6_each_in_scope_has_own_drug_precedent_refs",
                     "X7_four_cber_unplaced_rows",
                     "X8_unplaced_axis_is_null",
                     "X9_unplaced_in_scope_false_and_not_run",
                     "X10_unplaced_are_cber",
                     "X11_parent_panel_row_is_class_surrogate",
                     "X12_ledger_within_bounds"]
    let crit_vals = [x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12]
    let mut n_pass = 0
    let mut ci = 0
    while ci < 12 { if crit_vals[ci] { n_pass = n_pass + 1 }; ci = ci + 1 }
    let n_total = 12
    let verdict_pass = n_pass == n_total

    println("## acceptance — in-silico simulator-consistency criteria")
    ci = 0
    while ci < 12 {
        println("  [" + (if crit_vals[ci] { "PASS" } else { "FAIL" }) + "] " + crit_keys[ci])
        ci = ci + 1
    }
    println("")
    println("  --- " + str(n_pass) + "/" + str(n_total) + "  →  verdict: " +
            (if verdict_pass { "PASS" } else { "FAIL" }) + " ---")
    println("")
    println("  [honesty] in-silico simulator-consistency only — NOT a clinical / therapeutic / neurologic / regulatory / efficacy /")
    println("  portfolio-recommendation claim (g8 / f2). Core-5 axes UNCHANGED; one-disease pilot only; 200-disease re-mapping")
    println("  remains deferred per AXIS/HIERARCHY.tape Log. The four FDA-approved CBER mAbs (erenumab, fremanezumab,")
    println("  galcanezumab, eptinezumab) are honestly UNPLACED — criterion #4 drug-only/CDER scope boundary.")

    // ── witness JSON — keys pre-SORTED for json.dumps(sort_keys=True) parity ──
    let q = "\""

    // -- acceptance.criteria (sort_keys: X1,X10,X11,X12,X2,X3,X4,X5,X6,X7,X8,X9) --
    let crit_json = "{" +
        q + "X10_unplaced_are_cber" + q + ": " + jsb(x10) + ", " +
        q + "X11_parent_panel_row_is_class_surrogate" + q + ": " + jsb(x11) + ", " +
        q + "X12_ledger_within_bounds" + q + ": " + jsb(x12) + ", " +
        q + "X1_four_in_scope_drugs" + q + ": " + jsb(x1) + ", " +
        q + "X2_all_in_scope_are_cder" + q + ": " + jsb(x2) + ", " +
        q + "X3_each_in_scope_has_real_limit_anchor" + q + ": " + jsb(x3) + ", " +
        q + "X4_each_in_scope_maps_to_PPI" + q + ": " + jsb(x4) + ", " +
        q + "X5_in_scope_in_silico_only_flag_set" + q + ": " + jsb(x5) + ", " +
        q + "X6_each_in_scope_has_own_drug_precedent_refs" + q + ": " + jsb(x6) + ", " +
        q + "X7_four_cber_unplaced_rows" + q + ": " + jsb(x7) + ", " +
        q + "X8_unplaced_axis_is_null" + q + ": " + jsb(x8) + ", " +
        q + "X9_unplaced_in_scope_false_and_not_run" + q + ": " + jsb(x9) + "}"
    let acc_json = "{" + q + "criteria" + q + ": " + crit_json + ", " +
        q + "pass_count" + q + ": " + str(n_pass) + ", " +
        q + "total" + q + ": " + str(n_total) + ", " +
        q + "verdict" + q + ": " + q + (if verdict_pass { "PASS" } else { "FAIL" }) + q + "}"

    // -- shared real_limit_anchor + modality + sim_run (sorted keys) --
    let real_limit_anchor = "Bogan & Thorn 1998 binding-hotspot theory (J. Mol. Biol. 280:1) — interface binding free energy concentrated in a few hotspot residues (ΔΔG ≥ 2 kcal/mol by alanine scanning), bounded by the alanine-scanning ledger; druggability of flat hotspot-driven PPIs follows Wells & McClendon, Nature 450:1001 (2007)"
    let modality_base = "small-molecule CGRP-receptor antagonist — "
    let modality_tail = "disrupts the CGRP / CGRP-receptor protein-protein interaction by occupying the orthosteric peptide-binding site on the CLR + RAMP1 receptor complex"

    // axis_mapping (sorted: axis, axis_layer, parent_axis)
    let axis_mapping = "{" +
        q + "axis" + q + ": " + q + "PPI" + q + ", " +
        q + "axis_layer" + q + ": " + q + "expansion-sub" + q + ", " +
        q + "parent_axis" + q + ": " + q + "QUANTUM (core-5)" + q + "}"

    // sim_run (sorted keys)
    let sim_run = "{" +
        q + "dg_hotspot_cluster_kcal_per_mol" + q + ": " + js(dg_hotspot_cluster) + ", " +
        q + "dg_interface_kcal_per_mol" + q + ": " + js(dg_interface) + ", " +
        q + "dg_mimic_kcal_per_mol" + q + ": " + js(dg_mimic) + ", " +
        q + "hotspot_ddg_threshold_kcal_per_mol" + q + ": " + js(HOTSPOT_DDG_THRESHOLD) + ", " +
        q + "hotspot_driven" + q + ": " + jsb(hotspot_driven) + ", " +
        q + "hotspot_energy_fraction" + q + ": " + js(hotspot_fraction) + ", " +
        q + "interface_class" + q + ": " + q + "alpha_helix_peptide_cleft" + q + ", " +
        q + "ledger_residual_kcal_per_mol" + q + ": " + js(ledger_residual) + ", " +
        q + "mimic_within_ledger" + q + ": " + jsb(mimic_within_ledger) + ", " +
        q + "mimicry_fraction" + q + ": " + js(mimicry_fraction) + ", " +
        q + "n_hotspot_residues" + q + ": " + str(n_hotspots) + ", " +
        q + "n_interface_residues" + q + ": " + str(n_residues) + ", " +
        q + "panel_class_surrogate_for" + q + ": " + q + "CGRP / CGRP-receptor PPI (alpha-helical N-terminal peptide anchor binding the CLR + RAMP1 receptor groove)" + q + ", " +
        q + "parent_panel_row" + q + ": " + q + PARENT_PANEL_ROW + q + ", " +
        q + "sim_module" + q + ": " + q + "ppi_sim" + q + ", " +
        q + "small_molecule_disruption_viable" + q + ": " + jsb(mimic_viable) + ", " +
        q + "sum_ddg_kcal_per_mol" + q + ": " + js(sum_all) + ", " +
        q + "sum_hotspot_ddg_kcal_per_mol" + q + ": " + js(sum_hotspot) + "}"

    // -- in_scope_drugs (4 gepants; per-drug keys sorted) --
    let rimegepant = "{" +
        q + "axis_mapping" + q + ": " + axis_mapping + ", " +
        q + "brand" + q + ": " + q + "Nurtec ODT" + q + ", " +
        q + "drug" + q + ": " + q + "rimegepant" + q + ", " +
        q + "drug_precedent_refs" + q + ": [" +
            q + "Croop R et al., Lancet 394:737 (2019) — rimegepant phase III in acute migraine" + q + ", " +
            q + "Croop R et al., Lancet 397:51 (2021) — rimegepant preventive treatment of episodic migraine" + q + ", " +
            q + "FDA NDA 212728 (Nurtec ODT, 2020-02-27)" + q + "], " +
        q + "fda_application" + q + ": " + q + "NDA 212728 — Nurtec ODT first approval 2020-02-27 (acute treatment of migraine); preventive indication added 2021-05-27" + q + ", " +
        q + "fda_center" + q + ": " + q + "CDER" + q + ", " +
        q + "fda_year" + q + ": 2020, " +
        q + "in_silico_only" + q + ": true, " +
        q + "modality" + q + ": " + q + modality_base + modality_tail + q + ", " +
        q + "real_limit_anchor" + q + ": " + q + real_limit_anchor + q + ", " +
        q + "sim_run" + q + ": " + sim_run + ", " +
        q + "sponsor" + q + ": " + q + "Pfizer / Biohaven Pharmaceuticals" + q + "}"

    let ubrogepant = "{" +
        q + "axis_mapping" + q + ": " + axis_mapping + ", " +
        q + "brand" + q + ": " + q + "Ubrelvy" + q + ", " +
        q + "drug" + q + ": " + q + "ubrogepant" + q + ", " +
