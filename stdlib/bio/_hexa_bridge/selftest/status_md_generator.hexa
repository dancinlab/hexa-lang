#!hexa strict
// hexa-bio/_hexa_bridge/selftest/status_md_generator.hexa
//
// AXIS/STATUS.md dashboard auto-generator + verification gate.
// hexa-native port of `selftest/status_md_generator.py` (T3). ZERO
// python3 — the three sub-gates are run as their hexa-native ports
// (`_hexa_bridge/selftest/{hexa_verify_tier_batch,falsifier_execution_gate,
// determinism_regression_gate}.hexa`), built with `hexa build` and exec'd.
// The hexa sub-gate stdout is byte-parity with the .py for the SUMMARY
// COUNT lines this generator parses, so the rendered dashboard + the
// written AXIS/STATUS.md are byte-identical to the .py path.
//
// GOVERNANCE (hexa-bio AGENTS.tape): g1 honest-aggregation (every number
// matches the underlying gate — no inflation), g7 skip-is-honest (an
// un-runnable gate → [SKIP], does NOT block the sentinel), g8 in-silico-
// only. SENTINEL: `__STATUS_MD_GENERATOR__ PASS` iff STATUS.md written
// AND the consistency check finds zero mismatches.

import "_hexa_bridge/module/json_schema_validator.hexa"   // for shq

// ── tier glyphs (literal UTF-8; hexa has no \u{} escape) ────────────
let TIER_NUMERICAL = "🟢"
let TIER_FORMAL    = "🔵"
let TIER_DEFERRED  = "🟠"
let TIER_FALSIFIED = "🔴"

// gate-unrunnable sentinel prefix — an improbable token that cannot
// open real sub-gate stdout. Detected via startswith().
let GATE_SKIP = "@@HXSG_GATE_UNRUNNABLE@@"

// Cohort-convention fixed generated-at (byte-identical re-runs).
let GENERATED_AT = "2026-05-16T00:00:00Z"

// Axis counts — architectural decision (SSOT-declared); NOT lattice-
// derived (f_lattice_fit). Mirrors the .py constants verbatim.
let CORE_AXES_COUNT = 5
let EXPANSION_MAIN_COUNT = 4
let SUB_AXES_COUNT = 15

// ── string helpers ──────────────────────────────────────────────────
fn startswith(s: string, p: string) -> bool {
    if len(s) < len(p) { return false }
    return s.substr(0, len(p)) == p
}
fn endswith(s: string, p: string) -> bool {
    if len(s) < len(p) { return false }
    return s.substr(len(s) - len(p), len(p)) == p
}
fn find_idx(hay: string, needle: string) -> int {
    let nl = len(needle)
    if nl == 0 { return -1 }
    let mut k = 0
    while k + nl <= len(hay) {
        if hay.substr(k, nl) == needle { return k }
        k = k + 1
    }
    return -1
}
fn count_substr(hay: string, needle: string) -> int {
    let nl = len(needle)
    if nl == 0 { return 0 }
    let mut n = 0
    let mut k = 0
    while k + nl <= len(hay) {
        if hay.substr(k, nl) == needle { n = n + 1; k = k + nl }
        else { k = k + 1 }
    }
    return n
}
fn count_nl(s: string) -> int { return count_substr(s, "\n") }
// CPython len(str) counts codepoints; hexa len() counts bytes — count
// non-continuation bytes to match Python len() on UTF-8 markdown.
fn cp_len(s: string) -> int {
    let mut n = 0
    let mut i = 0
    while i < len(s) {
        let b = ord(s.substr(i, 1))
        if b < 128 || b >= 192 { n = n + 1 }
        i = i + 1
    }
    return n
}

// parse the FIRST run of decimal digits found in `s`; -1 if none.
fn first_int(s: string) -> int {
    let mut i = 0
    while i < len(s) {
        let c = s.substr(i, 1)
        if "0123456789".contains(c) {
            let mut v = 0
            while i < len(s) {
                let d = s.substr(i, 1)
                if "0123456789".contains(d) == false { break }
                let mut q = 0
                let mut dv = 0
                while q < 10 { if str(q) == d { dv = q }; q = q + 1 }
                v = v * 10 + dv
                i = i + 1
            }
            return v
        }
        i = i + 1
    }
    return -1
}

// ── gate runner: build + exec a hexa sub-gate, capture stdout ───────
// Returns the combined stdout (stderr merged) of the hexa-native
// sub-gate. `ok` is false when the gate could not be built/run — the
// caller renders an honest [SKIP] (g7). The build+exec is the same
// byte-parity backend that run_all.sh uses for every T3 gate.
fn run_gate(label: string) -> string {
    let hexa_rel = "_hexa_bridge/selftest/" + label + ".hexa"
    let exists = exec("test -f " + shq(hexa_rel) + " && printf yes || printf no").trim()
    if exists != "yes" { return GATE_SKIP + "ABSENT" }
    let bin = "/tmp/hxsg_" + label + ".bin"
    let build = exec("hexa build " + shq(hexa_rel) + " -o " + shq(bin) +
                     " >/dev/null 2>&1; printf '%s' \"$?\"").trim()
    if build != "0" { return GATE_SKIP + "BUILDFAIL" }
    let out = exec(shq(bin) + " 2>&1")
    return out
}

// ── parsers (regex via grep -E against captured stdout) ─────────────
// tier: returns [green, blue, orange, red, total] + sentinel string.
fn grep_first(text: string, pat: string) -> string {
    let r = exec("printf '%s' " + shq(text) + " | grep -E " + shq(pat) +
                 " 2>/dev/null | head -1")
    return r.trim()
}

fn main() {
    println("status_md_generator — AXIS/STATUS.md dashboard generator + " +
            "consistency gate")
    println("  aggregates: tier batch reporter · falsifier execution gate " +
            "· determinism regression gate")
    println("  governance: g1 honest-aggregation · g7 skip-is-honest · " +
            "g8 in-silico-only")
    println("")

    // ── tier batch reporter ─────────────────────────────────────────
    println("── running tier batch reporter ...")
    let tier_out = run_gate("hexa_verify_tier_batch")
    let mut tiers_ok = true
    let mut t_green = 0
    let mut t_blue = 0
    let mut t_orange = 0
    let mut t_red = 0
    let mut t_total = 0
    let mut t_sent = "ABSENT"
    if startswith(tier_out, GATE_SKIP) {
        tiers_ok = false
        println("   [SKIP] tier gate could not be run on this host")
    } else {
        // green: 🟢 SUPPORTED-NUMERICAL  N
        let g_line = grep_first(tier_out, TIER_NUMERICAL + " SUPPORTED-NUMERICAL +[0-9]+")
        let b_line = grep_first(tier_out, TIER_FORMAL + " SUPPORTED-FORMAL +[0-9]+")
        // yellow uses 🟡 in .py but is summed only if present; orange =
        // DEFERRED + INSUFFICIENT (both 🟠). Report block lines only.
        let od_line = grep_first(tier_out, TIER_DEFERRED + " DEFERRED +[0-9]+")
        let oi_line = grep_first(tier_out, TIER_DEFERRED + " INSUFFICIENT +[0-9]+")
        let r_line = grep_first(tier_out, TIER_FALSIFIED + " FALSIFIED +[0-9]+")
        let tt_line = grep_first(tier_out, "^ *TOTAL +[0-9]+ *$")
        if len(g_line) > 0 { t_green = first_int(g_line) }
        if len(b_line) > 0 { t_blue = first_int(b_line) }
        let mut orange = 0
        if len(od_line) > 0 { orange = orange + first_int(od_line) }
        if len(oi_line) > 0 { orange = orange + first_int(oi_line) }
        t_orange = orange
        if len(r_line) > 0 { t_red = first_int(r_line) }
        if len(tt_line) > 0 { t_total = first_int(tt_line) }
        if tier_out.contains("__HEXA_VERIFY_TIER_BATCH__ PASS") { t_sent = "PASS" }
        else if tier_out.contains("__HEXA_VERIFY_TIER_BATCH__ FAIL") { t_sent = "FAIL" }
        println("   green=" + str(t_green) + " blue=" + str(t_blue) +
                " orange=" + str(t_orange) + " red=" + str(t_red) +
                " total=" + str(t_total) + " sentinel=" + t_sent)
    }

    // ── falsifier execution gate ────────────────────────────────────
    println("── running falsifier execution gate ...")
    let fals_out = run_gate("falsifier_execution_gate")
    let mut fals_ok = true
    let mut f_hold = 0
    let mut f_fals = 0
    let mut f_skip = 0
    let mut f_total = 0
    let mut f_sent = "ABSENT"
    let mut f_axes: array = []
    if startswith(fals_out, GATE_SKIP) {
        fals_ok = false
        println("   [SKIP] falsifier gate could not be run on this host")
    } else {
        // summary: "  12 HOLD · 0 FALSIFIED · 0 SKIP (of 12 falsifier rows)"
        let sum = grep_first(fals_out, "[0-9]+ HOLD .* FALSIFIED .* SKIP \\(of [0-9]+ falsifier rows\\)")
        if len(sum) > 0 {
            // four integers in order: hold, falsified, skip, total
            let mut rest = sum
            let h = first_int(rest)
            if h >= 0 { f_hold = h }
            let p1 = find_idx(rest, " HOLD")
            if p1 >= 0 { rest = rest.substr(p1 + 5, len(rest) - p1 - 5) }
            let fa = first_int(rest)
            if fa >= 0 { f_fals = fa }
            let p2 = find_idx(rest, " FALSIFIED")
            if p2 >= 0 { rest = rest.substr(p2 + 10, len(rest) - p2 - 10) }
            let sk = first_int(rest)
            if sk >= 0 { f_skip = sk }
            let p3 = find_idx(rest, " SKIP")
            if p3 >= 0 { rest = rest.substr(p3 + 5, len(rest) - p3 - 5) }
            let to = first_int(rest)
            if to >= 0 { f_total = to }
        }
        // per-axis section headers: "── <AXIS> axis ─"
        let ax_raw = exec("printf '%s' " + shq(fals_out) +
                          " | grep -oE '── [^ ]+ axis ─' 2>/dev/null")
        let ax_lines = ax_raw.split("\n")
        let mut ai = 0
        while ai < len(ax_lines) {
            let ln = ax_lines[ai].trim()
            if len(ln) > 0 {
                // strip leading "── " and trailing " axis ─"
                let mut nm = ln
                if startswith(nm, "── ") { nm = nm.substr(7, len(nm) - 7) }
                let suf = " axis ─"
                if endswith(nm, suf) { nm = nm.substr(0, len(nm) - len(suf)) }
                let mut dup = false
                let mut z = 0
                while z < len(f_axes) { if f_axes[z] == nm { dup = true }; z = z + 1 }
                if dup == false { f_axes.push(nm) }
            }
            ai = ai + 1
        }
        if fals_out.contains("__FALSIFIER_EXECUTION_GATE__ PASS") { f_sent = "PASS" }
        else if fals_out.contains("__FALSIFIER_EXECUTION_GATE__ FAIL") { f_sent = "FAIL" }
        println("   HOLD=" + str(f_hold) + " FALSIFIED=" + str(f_fals) +
                " SKIP=" + str(f_skip) + " total=" + str(f_total) +
                " sentinel=" + f_sent)
    }

    // ── determinism regression gate ─────────────────────────────────
    println("── running determinism regression gate ...")
    let det_out = run_gate("determinism_regression_gate")
    let mut det_ok = true
    let mut d_det = 0
    let mut d_non = 0
    let mut d_skip = 0
    let mut d_total = 0
    let mut d_sent = "ABSENT"
    if startswith(det_out, GATE_SKIP) {
        det_ok = false
        println("   [SKIP] determinism gate could not be run on this host")
    } else {
        let sum = grep_first(det_out, "[0-9]+ DETERMINISTIC .* NON_DETERMINISTIC .* SKIP \\(of [0-9]+ sims\\)")
        if len(sum) > 0 {
            let mut rest = sum
            let dd = first_int(rest)
            if dd >= 0 { d_det = dd }
            let p1 = find_idx(rest, " DETERMINISTIC")
            if p1 >= 0 { rest = rest.substr(p1 + 14, len(rest) - p1 - 14) }
            let nn = first_int(rest)
            if nn >= 0 { d_non = nn }
            let p2 = find_idx(rest, " NON_DETERMINISTIC")
            if p2 >= 0 { rest = rest.substr(p2 + 18, len(rest) - p2 - 18) }
            let sk = first_int(rest)
            if sk >= 0 { d_skip = sk }
            let p3 = find_idx(rest, " SKIP")
            if p3 >= 0 { rest = rest.substr(p3 + 5, len(rest) - p3 - 5) }
            let to = first_int(rest)
            if to >= 0 { d_total = to }
        }
        if det_out.contains("__DETERMINISM_REGRESSION_GATE__ PASS") { d_sent = "PASS" }
        else if det_out.contains("__DETERMINISM_REGRESSION_GATE__ FAIL") { d_sent = "FAIL" }
        println("   DETERMINISTIC=" + str(d_det) +
                " NON_DETERMINISTIC=" + str(d_non) +
                " SKIP=" + str(d_skip) + " total=" + str(d_total) +
                " sentinel=" + d_sent)
    }

    // ── filesystem-derived counts ───────────────────────────────────
    // cross-axis bridges: _python_bridge/module/*_cross.py not starting "_"
    let mut bridges_ok = true
    let mut n_bridges = 0
    let pb_exists = exec("test -d _python_bridge/module && printf yes || printf no").trim()
    if pb_exists != "yes" { bridges_ok = false }
    else {
        let listing = exec("ls -1 _python_bridge/module 2>/dev/null").trim()
        let ll = listing.split("\n")
        let mut li = 0
        while li < len(ll) {
            let nm = ll[li].trim()
            if len(nm) > 0 && endswith(nm, "_cross.py") && startswith(nm, "_") == false {
                n_bridges = n_bridges + 1
            }
            li = li + 1
        }
    }
    // case-study portfolios: case_studies/*/ dirs ending "_portfolio"
    let mut cs_ok = true
    let mut cs_names: array = []
    let cs_exists = exec("test -d case_studies && printf yes || printf no").trim()
    if cs_exists != "yes" { cs_ok = false }
    else {
        let listing = exec("ls -1 case_studies 2>/dev/null").trim()
        let ll = listing.split("\n")
        let mut li = 0
        while li < len(ll) {
            let nm = ll[li].trim()
            if len(nm) > 0 && endswith(nm, "_portfolio") {
                let isd = exec("test -d " + shq("case_studies/" + nm) +
                               " && printf yes || printf no").trim()
                if isd == "yes" { cs_names.push(nm) }
            }
            li = li + 1
        }
        // sorted (ls -1 already C-sorted on this fs, but normalize)
        let mut p = 1
        while p < len(cs_names) {
            let cur = cs_names[p]
            let mut q = p - 1
            while q >= 0 && cs_names[q] > cur { cs_names[q+1] = cs_names[q]; q = q - 1 }
            cs_names[q+1] = cur
            p = p + 1
        }
    }
    println("── filesystem-derived counts:")
    if bridges_ok { println("   cross-axis bridges: " + str(n_bridges)) }
    else { println("   cross-axis bridges: SKIP") }
    if cs_ok { println("   case-study portfolios: " + str(len(cs_names))) }
    else { println("   case-study portfolios: SKIP") }

    // ── render markdown ─────────────────────────────────────────────
    let mut L: array = []
    L.push("# AXIS/STATUS.md — hexa-bio gate-aggregation dashboard\n")
    L.push("> **Status: auto-generated from selftest gate outputs. " +
           "Hand-edits will be overwritten by " +
           "`selftest/status_md_generator.py`.** The DASHBOARD is " +
           "in-silico simulator-consistency only (g8/f2).\n")
    L.push("")
    L.push("> **Honesty fence (g8 / f2 / README criterion #4):** every " +
           "number below reports an IN-SILICO gate state. A PASS / " +
           "HOLD / DETERMINISTIC verdict verifies simulator-consistency " +
           "of a preregistered condition ONLY — NEVER a therapeutic, " +
           "clinical, regulatory, immunogenic, efficacy, potency, " +
           "selectivity, or wet-lab claim. Axis counts are an " +
           "architectural decision (`f_lattice_fit`), NOT derived from " +
           "any n=6 lattice scalar.\n")
    L.push("")
    L.push("---")
    L.push("")

    // §1 axis count summary
    let total_axes = CORE_AXES_COUNT + EXPANSION_MAIN_COUNT + SUB_AXES_COUNT
    L.push("## §1 Axis count summary\n")
    L.push("> _SSOT-declared totals (AXIS.tape core + AXIS/HIERARCHY.tape " +
           "expansion-layer). NOT lattice-derived (`f_lattice_fit`)._\n")
    L.push("")
    L.push("| Layer | Count | SSOT |")
    L.push("|---|---|---|")
    L.push("| **Core axes** | " + str(CORE_AXES_COUNT) + " | " +
           "`../AXIS.tape` (QUANTUM · WEAVE · NANOBOT · RIBOZYME · " +
           "VIROCAPSID) |")
    L.push("| **Expansion-MAIN** | " + str(EXPANSION_MAIN_COUNT) + " | " +
           "`HIERARCHY.tape` §1 (COVALENT · BIFUNCTIONAL · " +
           "METALLODRUG · OLIGONUCLEOTIDE) |")
    L.push("| **Sub-axes** | " + str(SUB_AXES_COUNT) + " | " +
           "`HIERARCHY.tape` §2 (6 :> BIFUNCTIONAL · 3 :> QUANTUM · " +
           "2 :> WEAVE · 1 :> COVALENT · 2 :> RIBOZYME · " +
           "1 :> VIROCAPSID) |")
    L.push("| **TOTAL** | **" + str(total_axes) + "** | architectural — " +
           "see `README.md` §4 (keep-5 dissent preserved) |")
    L.push("")

    // §2 tier distribution
    L.push("## §2 Tier distribution\n")
    L.push("> _From `selftest/hexa_verify_tier_batch.py` — a TIER REPORTER, " +
           "not enforcer. Glyph counts across the 44-sim roster._\n")
    L.push("")
    if tiers_ok == false {
        L.push("[SKIP] tier-batch gate could not be run on this host " +
               "(g7 skip-is-honest).")
    } else {
        L.push("| Tier | Glyph | Count |")
        L.push("|---|---|---|")
        L.push("| SUPPORTED-NUMERICAL | " + TIER_NUMERICAL + " | " +
               str(t_green) + " |")
        L.push("| SUPPORTED-FORMAL | " + TIER_FORMAL + " | " +
               str(t_blue) + " |")
        L.push("| DEFERRED / INSUFFICIENT | " + TIER_DEFERRED + " | " +
               str(t_orange) + " |")
        L.push("| FALSIFIED | " + TIER_FALSIFIED + " | " + str(t_red) + " |")
        L.push("| **Total** | — | **" + str(t_total) + "** |")
        L.push("")
        L.push("Gate sentinel: `__HEXA_VERIFY_TIER_BATCH__ " + t_sent + "`.")
    }
    L.push("")

    // §3 falsifier-gate status
    L.push("## §3 Falsifier-gate status\n")
    L.push("> _From `selftest/falsifier_execution_gate.py` — runs each " +
           "preregistered falsifier (F-METALLODRUG/OLIGO/COVALENT/" +
           "BIFUNCTIONAL-1/2/3) against its axis sim._\n")
    L.push("")
    if fals_ok == false {
        L.push("[SKIP] falsifier-gate could not be run on this host " +
               "(g7 skip-is-honest).")
    } else {
        L.push("| Verdict | Count |")
        L.push("|---|---|")
        L.push("| HOLD | " + str(f_hold) + " |")
        L.push("| FALSIFIED | " + str(f_fals) + " |")
        L.push("| SKIP | " + str(f_skip) + " |")
        L.push("| **Total** | **" + str(f_total) + "** |")
        L.push("")
        if len(f_axes) > 0 {
            let mut joined = ""
            let mut ji = 0
            while ji < len(f_axes) {
                if ji > 0 { joined = joined + " · " }
                joined = joined + f_axes[ji]
                ji = ji + 1
            }
            L.push("Axes covered: " + joined + ".")
            L.push("")
        }
        L.push("Gate sentinel: `__FALSIFIER_EXECUTION_GATE__ " + f_sent + "`.")
        L.push("")
        L.push("> _g7 honesty: a SKIP is an absent tape/sim on this " +
               "host — NOT a failure. Only a genuine FALSIFIED verdict " +
               "(axis reachable, preregistered condition violated) " +
               "blocks the sentinel._")
    }
    L.push("")

    // §4 determinism-gate status
    L.push("## §4 Determinism-gate status\n")
    L.push("> _From `selftest/determinism_regression_gate.py` — runs each " +
           "sim TWICE under `PYTHONHASHSEED=0` and compares stdout " +
           "byte-for-byte. This is the §11 deductive-verification " +
           "determinism contract._\n")
    L.push("")
    if det_ok == false {
        L.push("[SKIP] determinism-gate could not be run on this host " +
               "(g7 skip-is-honest).")
    } else {
        L.push("| Verdict | Count |")
        L.push("|---|---|")
        L.push("| DETERMINISTIC | " + str(d_det) + " |")
        L.push("| NON_DETERMINISTIC | " + str(d_non) + " |")
        L.push("| SKIP | " + str(d_skip) + " |")
        L.push("| **Total** | **" + str(d_total) + "** |")
        L.push("")
        L.push("Gate sentinel: `__DETERMINISM_REGRESSION_GATE__ " +
               d_sent + "`.")
    }
    L.push("")

    // §5 cross-axis coverage
    L.push("## §5 Cross-axis coverage\n")
    L.push("> _Filesystem-derived count of cross-axis bridge sims " +
           "(`_python_bridge/module/*_cross.py`). A cross-axis bridge " +
           "is NOT a new axis — core-5 unchanged._\n")
    L.push("")
    if bridges_ok == false {
        L.push("[SKIP] `_python_bridge/module/` not present on host " +
               "(g7 skip-is-honest).")
    } else {
        L.push("Cross-axis bridge sims: **" + str(n_bridges) + "**.")
        L.push("")
        L.push("> _Each bridge imports both sides' sims (no fork — " +
               "`f3`); each carries a passing sentinel + draft-07 " +
               "schema; each is honesty-fenced (mathematical " +
               "equivalence ≠ mechanistic equivalence; comparison " +
               "≠ ranking)._")
    }
    L.push("")

    // §6 case studies
    L.push("## §6 Case studies\n")
    L.push("> _One-disease in-silico pilots in `case_studies/`. NOT the " +
           "200-disease deferred work (which remains deferred)._\n")
    L.push("")
    if cs_ok == false {
        L.push("[SKIP] `case_studies/` not present on host " +
               "(g7 skip-is-honest).")
    } else {
        let mut joined = ""
        let mut ji = 0
        while ji < len(cs_names) {
            if ji > 0 { joined = joined + " · " }
            joined = joined + cs_names[ji]
            ji = ji + 1
        }
        L.push("Disease portfolios: **" + str(len(cs_names)) + "** " +
               "(" + joined + ").")
        L.push("")
        L.push("> _Each portfolio composes existing sims for " +
               "FDA-approved drugs against one disease, with " +
               "research-stage / CBER-scope items honestly listed " +
               "as UNPLACED. NOT a clinical, efficacy, or portfolio-" +
               "recommendation claim (g8)._")
    }
    L.push("")

    // §7 honesty caveats
    L.push("## §7 Honesty caveats\n")
    L.push("")
    L.push("- **g1 real-limits-first** — every gate is anchored in a " +
           "named real-limit (Eyring TST · SantaLucia NN · Caspar-" +
           "Klug · Zlotnick · Griffith-Orgel · MWC · Bell · Strelow · " +
           "Douglass/Han/Gadd · Zimm-Bragg · Nussinov · CODATA 2019). " +
           "The dashboard does NOT invent claims at the aggregation " +
           "layer — every number here matches the underlying gate.")
    L.push("- **g7 skip-is-honest** — a [SKIP] in any section above " +
           "means the underlying gate could not be run on this host " +
           "(file absent, subprocess timeout, non-zero exit). It is " +
           "NOT a failure. Only a `__STATUS_MD_GENERATOR__ FAIL` " +
           "(consistency-check mismatch) signals a real problem.")
    L.push("- **g8 in-silico-only-claim-scope** — a tier ≠ 🔴, a " +
           "falsifier HOLD, a DETERMINISTIC verdict, and a passing " +
           "case-study sentinel ALL verify in-silico simulator + " +
           "metadata internal consistency ONLY. None of them is a " +
           "wet-lab, clinical, regulatory, immunogenic, efficacy, " +
           "potency, selectivity, DC50, Dmax, or therapeutic claim.")
    L.push("- **f2 wet-lab-clinical-claim-from-in-silico** — never " +
           "claim therapeutic / clinical / regulatory progress from " +
           "a C2/C3 in-silico PASS. See `CLOSURE_RESIDUAL_BACKLOG.md` " +
           "§0 for the explicit out-of-software-scope items.")
    L.push("- **f_lattice_fit** — the axis counts in §1 are an " +
           "architectural decision grounded in computational scope, " +
           "NOT a lattice derivation. The hexa- token is a " +
           "dancinlab-family branding artifact (see `README.md` §0 " +
           "count-honesty paragraph).")
    L.push("- **README §4 keep-5 dissent** — the rigorous " +
           "axis-expansion analysis recommended KEEP 5 axes + cross-" +
           "cutting platform layer. The 4 expansion-main axes here " +
           "exist per explicit USER DIRECTION 2026-05-16, with the " +
           "dissent preserved verbatim (NOT erased) in " +
           "`README.md` §4 + `HIERARCHY.tape` `@N rigorous_dissent`.")
    L.push("- **Criterion #4 (drug-only / CDER)** — THERANOSTIC + " +
           "GENETIC-MEDICINE + ADC remain UNPLACED (CBER scope " +
           "tension); not implemented as code axes (honest).")
    L.push("")

    // §8 generated-at timestamp
    L.push("## §8 Generated-at timestamp\n")
    L.push("> _Fixed for byte-identical re-runs (cohort convention). " +
           "Re-run `python3 selftest/status_md_generator.py` to refresh " +
           "the gate-aggregated numbers; the timestamp string itself is " +
           "deliberately stable._\n")
    L.push("")
    L.push("- **generated-at**: `" + GENERATED_AT + "`")
    L.push("- **generator**: `selftest/status_md_generator.py`")
    L.push("- **output**: `AXIS/STATUS.md` (this file)")
    L.push("- **gates aggregated**:")
    L.push("    1. `selftest/hexa_verify_tier_batch.py`")
    L.push("    2. `selftest/falsifier_execution_gate.py`")
    L.push("    3. `selftest/determinism_regression_gate.py`")
    L.push("")
    L.push("---")
    L.push("")
    L.push("_End of auto-generated dashboard. Hand-edits will be " +
           "overwritten on next run of `selftest/status_md_generator.py`._")
    L.push("")

    // join with "\n"
    let mut md = ""
    let mut mi = 0
    while mi < len(L) {
        if mi > 0 { md = md + "\n" }
        md = md + L[mi]
        mi = mi + 1
    }

    // ── ensure AXIS/ exists, write the file ─────────────────────────
    let axis_exists = exec("test -d AXIS && printf yes || printf no").trim()
    if axis_exists != "yes" {
        println("")
        println("   AXIS/ directory missing — cannot write STATUS.md")
        println("__STATUS_MD_GENERATOR__ FAIL")
        exit(1)
    }
    let w_out = exec("printf '%s' " + shq(md) + " > " + shq("AXIS/STATUS.md") +
                     " 2>&1; printf '%s' \"$?\"").trim()
    if w_out != "0" {
        println("")
        println("   write failed: exit " + w_out)
        println("__STATUS_MD_GENERATOR__ FAIL")
        exit(1)
    }
    println("")
    println("── wrote AXIS/STATUS.md (" + str(cp_len(md)) + " chars, " +
            str(count_nl(md)) + " lines)")

    // ── consistency check (g1 — no inflation) ───────────────────────
    let mut mismatches: array = []

    if md.contains("**" + str(total_axes) + "**") == false {
        mismatches.push("axis total: expected " + str(total_axes) +
                        " in dashboard text, not found")
    }
    // tier rows
    if tiers_ok {
        let mg = grep_first(md, "\\| SUPPORTED-NUMERICAL \\|.*\\| [0-9]+ \\|")
        let mb = grep_first(md, "\\| SUPPORTED-FORMAL \\|.*\\| [0-9]+ \\|")
        let mo = grep_first(md, "\\| DEFERRED / INSUFFICIENT \\|.*\\| [0-9]+ \\|")
        let mr = grep_first(md, "\\| FALSIFIED \\| .* \\| [0-9]+ \\|")
        if len(mg) > 0 {
            let v = last_int_in_row(mg)
            if v != t_green { mismatches.push("tier green: dashboard=" + str(v) + " != gate-parsed=" + str(t_green)) }
        }
        if len(mb) > 0 {
            let v = last_int_in_row(mb)
            if v != t_blue { mismatches.push("tier blue: dashboard=" + str(v) + " != gate-parsed=" + str(t_blue)) }
        }
        if len(mo) > 0 {
            let v = last_int_in_row(mo)
            if v != t_orange { mismatches.push("tier orange: dashboard=" + str(v) + " != gate-parsed=" + str(t_orange)) }
        }
        if len(mr) > 0 {
            let v = last_int_in_row(mr)
            if v != t_red { mismatches.push("tier red: dashboard=" + str(v) + " != gate-parsed=" + str(t_red)) }
        }
    }
    // falsifier rows — scoped to the §3 block
    if fals_ok {
        let s3 = section_block(md, "## §3 ", "## §4 ")
        let mh = grep_first(s3, "\\| HOLD \\| [0-9]+ \\|")
        let mf = grep_first(s3, "\\| FALSIFIED \\| [0-9]+ \\|")
        let mk = grep_first(s3, "\\| SKIP \\| [0-9]+ \\|")
        if len(mh) > 0 {
            let v = first_int(mh)
            if v != f_hold { mismatches.push("falsifier HOLD: dashboard=" + str(v) + " != gate-parsed=" + str(f_hold)) }
        }
        if len(mf) > 0 {
            let v = first_int(mf)
            if v != f_fals { mismatches.push("falsifier FALSIFIED: dashboard=" + str(v) + " != gate-parsed=" + str(f_fals)) }
        }
        if len(mk) > 0 {
            let v = first_int(mk)
            if v != f_skip { mismatches.push("falsifier SKIP: dashboard=" + str(v) + " != gate-parsed=" + str(f_skip)) }
        }
    }
    // determinism rows — scoped to the §4 block
    if det_ok {
        let s4 = section_block(md, "## §4 ", "## §5 ")
        let mdt = grep_first(s4, "\\| DETERMINISTIC \\| [0-9]+ \\|")
        let mn = grep_first(s4, "\\| NON_DETERMINISTIC \\| [0-9]+ \\|")
        let msk = grep_first(s4, "\\| SKIP \\| [0-9]+ \\|")
        if len(mdt) > 0 {
            let v = first_int(mdt)
            if v != d_det { mismatches.push("determinism DETERMINISTIC: dashboard=" + str(v) + " != gate-parsed=" + str(d_det)) }
        }
        if len(mn) > 0 {
            let v = first_int(mn)
            if v != d_non { mismatches.push("determinism NON_DETERMINISTIC: dashboard=" + str(v) + " != gate-parsed=" + str(d_non)) }
        }
        if len(msk) > 0 {
            let v = first_int(msk)
            if v != d_skip { mismatches.push("determinism SKIP: dashboard=" + str(v) + " != gate-parsed=" + str(d_skip)) }
        }
    }
    // cross-axis bridge count — §5 block
    if bridges_ok {
        let s5 = section_block(md, "## §5 ", "## §6 ")
        let mb = grep_first(s5, "Cross-axis bridge sims: \\*\\*[0-9]+\\*\\*")
        if len(mb) > 0 {
            let v = first_int(mb)
            if v != n_bridges { mismatches.push("cross bridges: dashboard=" + str(v) + " != gate-parsed=" + str(n_bridges)) }
        }
    }
    // case study count — §6 block
    if cs_ok {
        let s6 = section_block(md, "## §6 ", "## §7 ")
        let mc = grep_first(s6, "Disease portfolios: \\*\\*[0-9]+\\*\\*")
        if len(mc) > 0 {
            let v = first_int(mc)
            if v != len(cs_names) { mismatches.push("case studies: dashboard=" + str(v) + " != gate-parsed=" + str(len(cs_names))) }
        }
    }
    if md.contains(GENERATED_AT) == false {
        mismatches.push("generated-at: expected " + GENERATED_AT +
                        " in dashboard text, not found")
    }

    if len(mismatches) > 0 {
        let mut word = "mismatches"
        if len(mismatches) == 1 { word = "mismatch" }
        println("")
        println("── consistency-check FAILED (" + str(len(mismatches)) +
                " " + word + "):")
        let mut mi2 = 0
        while mi2 < len(mismatches) {
            println("   - " + mismatches[mi2])
            mi2 = mi2 + 1
        }
        println("")
        println("__STATUS_MD_GENERATOR__ FAIL")
        exit(1)
    }
    println("── consistency-check PASS " +
            "(every dashboard number matches its gate output)")
    println("")
    println("__STATUS_MD_GENERATOR__ PASS")
}

// last decimal-integer run in a table row (for "| label | glyph | N |")
fn last_int_in_row(s: string) -> int {
    let mut last = -1
    let mut i = 0
    while i < len(s) {
        let c = s.substr(i, 1)
        if "0123456789".contains(c) {
            let mut v = 0
            while i < len(s) {
                let d = s.substr(i, 1)
                if "0123456789".contains(d) == false { break }
                let mut q = 0
                let mut dv = 0
                while q < 10 { if str(q) == d { dv = q }; q = q + 1 }
                v = v * 10 + dv
                i = i + 1
            }
            last = v
        } else {
            i = i + 1
        }
    }
    return last
}

// substring of `text` from marker `start` up to marker `end`
fn section_block(text: string, start: string, end: string) -> string {
    let si = find_idx(text, start)
    if si < 0 { return "" }
    let ei = find_idx(text, end)
    if ei < 0 { return text.substr(si, len(text) - si) }
    return text.substr(si, ei - si)
}
