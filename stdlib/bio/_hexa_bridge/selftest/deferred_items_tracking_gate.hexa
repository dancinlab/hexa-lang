#!hexa strict
// hexa-bio/_hexa_bridge/selftest/deferred_items_tracking_gate.hexa
//
// DEFERRED-items tracking gate — GENUINE hexa-native port of
// `selftest/deferred_items_tracking_gate.py` (T3). ZERO python-interpreter
// shell-outs: filesystem probes (file/dir presence, directory listings,
// text-/regex-marker scans) are done via `exec(...)` POSIX shell, and the
// JSON registry parse via the runtime `json_parse`. No CPython interpreter
// is invoked anywhere — pure hexa + POSIX shell.
//
// WHAT THE GATE DOES
// ------------------
// The hexa-bio repo carries an EXPLICIT list of DEFERRED items in
// AXIS/HIERARCHY.tape (`@N theranostic_status` / `@N genetic_medicine_status`
// / `@N adc_status`) and CHANGELOG.md's DEFERRED table. This gate is an
// honest boundary enforcer: it verifies, per item, that the deferred-state
// preconditions still hold on disk (no directory / sim appeared without a
// paired HIERARCHY.tape `@D` axis-declaration; no `@N` marker silently
// removed). PASS iff every item is STILL-DEFERRED or PARTIALLY-RESOLVED
// (no UN-DEFERRED-VIOLATION).
//
// The 5 tracked items: 200-disease re-mapping, GENETIC-MEDICINE code axis,
// ADC code axis, THERANOSTIC scope decision, hexa atlas 🔵 upgrade.
//
// BYTE-PARITY note: the .py output is fully deterministic (pure stdlib, no
// network / random / wall-clock). This port reproduces it verbatim,
// including the codepoint-width column padding of the summary table (the
// item name "hexa atlas 🔵 upgrade" carries a multibyte 🔵 — Python `len`
// counts codepoints, so the summary-table widths use cp_len here too).
//
// IMPLEMENTATION note: hexa has no user map-literal / map-return; each item
// and its preconditions are carried as flat parallel arrays keyed by item
// index — semantically identical to the .py per-item dicts.
//
// DISCIPLINES honored:
//   - shq imported from json_schema_validator (no local fn shq)
//   - cp_len / cp_substr for codepoint-correct width math (multibyte 🔵)
//   - g7 skip-is-honest: absent reference file ⇒ SKIP precondition
//   - exit(0) on PASS, exit(1) on FAIL (UN-DEFERRED-VIOLATION present)

import "_hexa_bridge/module/json_schema_validator.hexa"  // for shq

// ── verdict / precondition tokens ────────────────────────────────────────
let STILL_DEFERRED = "STILL-DEFERRED"
let PARTIALLY_RESOLVED = "PARTIALLY-RESOLVED"
let UN_DEFERRED_VIOLATION = "UN-DEFERRED-VIOLATION"
let MET = "MET"
let UN_MET = "UN-MET"
let SKIP = "SKIP"

// ── per-item / per-precondition state (flat parallel arrays) ─────────────
// item-level arrays — index 0..n_items-1
let mut it_name: array = []
let mut it_decl: array = []
let mut it_refs: array = []          // array of arrays
let mut it_partial_when: array = []  // bool — atlas-only partial path
let mut it_partial_rationale: array = []
let mut it_pc_lo: array = []         // first precondition index
let mut it_pc_hi: array = []         // one-past-last precondition index
// precondition-level arrays — appended in order
let mut pc_label: array = []
let mut pc_result: array = []
let mut pc_detail: array = []

// ── codepoint-correct string helpers (multibyte 🔵) ──────────────────────
fn cp_len(s: string) -> int {
    let mut cp = 0; let mut i = 0
    while i < len(s) {
        let bv = ord(s.substr(i, 1))
        if bv < 128 || bv >= 192 { cp = cp + 1 }
        i = i + 1
    }
    return cp
}

fn cp_substr(s: string, a: int, b: int) -> string {
    let mut out = ""; let mut cp = 0; let mut i = 0
    while i < len(s) {
        let bv = ord(s.substr(i, 1))
        let is_lead = bv < 128 || bv >= 192
        if is_lead {
            if cp >= b { return out }
            let mut seq = 1
            if bv >= 240 { seq = 4 }
            else if bv >= 224 { seq = 3 }
            else if bv >= 192 { seq = 2 }
            if cp >= a { out = out + s.substr(i, seq) }
            cp = cp + 1
            i = i + seq
        } else {
            i = i + 1
        }
    }
    return out
}

// right-pad `s` with spaces to `w` codepoints (Python f"{s:<w}")
fn ljust(s: string, w: int) -> string {
    let mut o = s
    let mut n = cp_len(s)
    while n < w { o = o + " "; n = n + 1 }
    return o
}

// `c` repeated `n` times (Python `c * n`); n<=0 ⇒ ""
fn repeat(c: string, n: int) -> string {
    let mut o = ""
    let mut i = 0
    while i < n { o = o + c; i = i + 1 }
    return o
}

// join an array of strings with `sep`
fn join_with(a: array, sep: string) -> string {
    let mut o = ""
    let mut i = 0
    while i < len(a) {
        if i > 0 { o = o + sep }
        o = o + str(a[i])
        i = i + 1
    }
    return o
}

// ── filesystem probes (POSIX shell — NOT a CPython interpreter) ──────────
fn is_file(path: string) -> bool {
    return exec("[ -f " + shq(path) + " ] && echo y || echo n").trim() == "y"
}

fn is_dir(path: string) -> bool {
    return exec("[ -d " + shq(path) + " ] && echo y || echo n").trim() == "y"
}

// literal substring presence in a file (== Python `pattern in text`).
// honest False on missing file.
fn file_contains(path: string, pattern: string) -> bool {
    if is_file(path) == false { return false }
    let body = exec("cat " + shq(path) + " 2>/dev/null")
    return body.contains(pattern)
}

// ERE-regex presence in a file with re.MULTILINE semantics
// (== Python `re.search(pattern, text, re.MULTILINE)`).
// `grep -E` is line-oriented so `^` already matches per-line.
fn file_matches(path: string, ere: string) -> bool {
    if is_file(path) == false { return false }
    return exec("grep -E " + shq(ere) + " " + shq(path) +
                " >/dev/null 2>&1 && echo y || echo n").trim() == "y"
}

// sorted list of immediate sub-directory names of `parent` ([] if absent)
fn list_dirs(parent: string) -> array {
    if is_dir(parent) == false { return [] }
    let raw = exec("for d in " + shq(parent) + "/*/; do " +
                   "[ -d \"$d\" ] || continue; " +
                   "b=$(basename \"$d\"); printf '%s\\n' \"$b\"; done | LC_ALL=C sort").trim()
    if len(raw) == 0 { return [] }
    return raw.split("\n")
}

// sorted list of files in `directory` whose basename matches ERE `ere`.
// The .py patterns begin with `^`, so an anchored `grep -E` is exact.
fn list_files_matching(directory: string, ere: string) -> array {
    if is_dir(directory) == false { return [] }
    let raw = exec("for f in " + shq(directory) + "/*; do " +
                   "[ -e \"$f\" ] || continue; " +
                   "b=$(basename \"$f\"); printf '%s\\n' \"$b\"; done " +
                   "| grep -E " + shq(ere) + " | LC_ALL=C sort").trim()
    if len(raw) == 0 { return [] }
    return raw.split("\n")
}

// ── item / precondition builders ─────────────────────────────────────────
// begin a new item; returns its index
fn begin_item(name: string, decl: string, refs: array,
              partial_when: bool, partial_rationale: string) -> int {
    let idx = len(it_name)
    it_name.push(name)
    it_decl.push(decl)
    it_refs.push(refs)
    it_partial_when.push(partial_when)
    it_partial_rationale.push(partial_rationale)
    it_pc_lo.push(len(pc_label))
    it_pc_hi.push(len(pc_label))   // updated by end_item
    return idx
}

fn add_pre(idx: int, label: string, result: string, detail: string) {
    pc_label.push(label)
    pc_result.push(result)
    pc_detail.push(detail)
    it_pc_hi[idx] = len(pc_label)
}

// resolved verdict for item `idx` (mirrors _finalize)
fn verdict_of(idx: int) -> string {
    let lo = it_pc_lo[idx]
    let hi = it_pc_hi[idx]
    let mut has_violation = false
    let mut is_atlas_partial = false
    let mut i = lo
    while i < hi {
        if str(pc_result[i]) == UN_MET { has_violation = true }
        if it_partial_when[idx] &&
           cp_substr(str(pc_label[i]), 0, 30) == "R1 atlas atom registry present" &&
           str(pc_result[i]) == MET {
            is_atlas_partial = true
        }
        i = i + 1
    }
    if has_violation { return UN_DEFERRED_VIOLATION }
    if is_atlas_partial { return PARTIALLY_RESOLVED }
    return STILL_DEFERRED
}

fn rationale_of(idx: int) -> string {
    let v = verdict_of(idx)
    if v == UN_DEFERRED_VIOLATION {
        return "at least one precondition UN-MET — see trace. A code " +
            "or declaration boundary was crossed without a paired " +
            "governance un-deferral entry (HIERARCHY.tape @D " +
            "axis_<X> registration or CHANGELOG.md DEFERRED-row " +
            "removal). FAIL until governance update is added."
    }
    if v == PARTIALLY_RESOLVED { return str(it_partial_rationale[idx]) }
    return "all preconditions MET (or honestly SKIPPED via g7); " +
        "no code/declaration boundary crossed."
}

// ── repo layout ──────────────────────────────────────────────────────────
fn repo_root() -> string {
    let e = env("REPO_ROOT")
    if len(e) > 0 { return e }
    return exec("pwd").trim()
}

// ── per-item checks ──────────────────────────────────────────────────────
fn check_200_disease_remapping(root: string) {
    let case_studies = root + "/case_studies"
    let changelog = root + "/CHANGELOG.md"
    let decl = "DEFERRED — CHANGELOG.md DEFERRED table row 1; HIERARCHY.tape Log " +
        "(\"200-disease re-mapping remains DEFERRED\"). One-disease " +
        "case_studies/ pilots are NOT a replacement (CHANGELOG.md L445)."
    let refs: array = ["CHANGELOG.md", "AXIS/HIERARCHY.tape"]
    let idx = begin_item("200-disease re-mapping", decl, refs, false, "")

    // Precondition 1: no 200-item disease-master-map file present
    let cand_rel: array = [
        "case_studies/disease_master_map.json",
        "case_studies/disease_panel_200.json",
        "case_studies/200_disease_remapping.json",
        "disease_master_map.json",
    ]
    let mut found_master: array = []
    let mut ci = 0
    while ci < len(cand_rel) {
        if is_file(root + "/" + str(cand_rel[ci])) { found_master.push(cand_rel[ci]) }
        ci = ci + 1
    }
    if len(found_master) == 0 {
        add_pre(idx, "no 200-item disease-master-map file present", MET,
            "checked " + join_with(cand_rel, ", ") + " — none present")
    } else {
        add_pre(idx, "no 200-item disease-master-map file present", UN_MET,
            "found: " + join_with(found_master, ", ") +
            " — a 200-disease panel artifact appeared without " +
            "a paired HIERARCHY.tape un-deferral declaration")
    }

    // Precondition 2: case_studies/ has only a small number of one-disease pilots
    let studies = list_dirs(case_studies)
    let mut disease_pilots: array = []
    let mut si = 0
    while si < len(studies) {
        let d = str(studies[si])
        if len(d) >= 10 && d.substr(len(d) - 10, 10) == "_portfolio" {
            disease_pilots.push(d)
        }
        si = si + 1
    }
    let pilot_threshold = 10
    let lbl2 = "≤" + str(pilot_threshold) + " one-disease pilots in case_studies/" +
        " (not the deferred 200-disease panel)"
    let pilots_disp = if len(disease_pilots) > 0 { join_with(disease_pilots, ", ") } else { "none" }
    let studies_disp = if len(studies) > 0 { join_with(studies, ", ") } else { "(empty)" }
    if len(disease_pilots) <= pilot_threshold {
        add_pre(idx, lbl2, MET,
            str(len(disease_pilots)) + " disease-pilot directories found " +
            "(" + pilots_disp + "); " +
            "all of case_studies/ subdirs: " + studies_disp)
    } else {
        add_pre(idx, lbl2, UN_MET,
            str(len(disease_pilots)) + " pilot directories — exceeds " +
            "the " + str(pilot_threshold) + " threshold consistent with " +
            "one-disease pilots; un-deferral may have occurred " +
            "silently")
    }

    // Precondition 3: CHANGELOG.md DEFERRED row 1 still declares 200-disease
    let lbl3 = "CHANGELOG.md still declares the 200-disease " +
        "re-mapping as DEFERRED"
    if is_file(changelog) {
        if file_contains(changelog, "200-disease re-mapping") {
            add_pre(idx, lbl3, MET,
                "CHANGELOG.md contains the literal string " +
                "'200-disease re-mapping' (DEFERRED-table marker)")
        } else {
            add_pre(idx, lbl3, UN_MET,
                "CHANGELOG.md present but no '200-disease " +
                "re-mapping' marker — declaration may have been " +
                "removed without a paired un-deferral entry")
        }
    } else {
        add_pre(idx, lbl3, SKIP,
            "CHANGELOG.md absent on host — g7 " +
            "skip-is-honest; cannot verify declaration")
    }
}

fn check_genetic_medicine(root: string) {
    let hierarchy = root + "/AXIS/HIERARCHY.tape"
    let py_module = root + "/_python_bridge/module"
    let decl = "UNPLACED (CBER scope, criterion #4) — HIERARCHY.tape " +
        "@N genetic_medicine_status; CHANGELOG.md DEFERRED table."
    let refs: array = ["AXIS/HIERARCHY.tape", "CHANGELOG.md"]
    let idx = begin_item("GENETIC-MEDICINE code axis", decl, refs, false, "")

    // Precondition 1: no genetic_medicine/module/ directory
    if is_dir(root + "/genetic_medicine/module") == false {
        add_pre(idx, "no genetic_medicine/module/ directory", MET,
            "genetic_medicine/module absent")
    } else {
        add_pre(idx, "no genetic_medicine/module/ directory", UN_MET,
            "genetic_medicine/module present — code axis " +
            "appeared without a paired HIERARCHY.tape " +
            "@D axis_genetic_medicine declaration")
    }

    // Precondition 2: no _python_bridge/module/genetic_medicine_*.py sim
    let gm_sims = list_files_matching(py_module, "^genetic_medicine.*\\.py$")
    if len(gm_sims) == 0 {
        add_pre(idx, "no _python_bridge/module/genetic_medicine_*.py sim", MET,
            "scanned _python_bridge/module — no " +
            "genetic_medicine_*.py files")
    } else {
        add_pre(idx, "no _python_bridge/module/genetic_medicine_*.py sim", UN_MET,
            "found: " + join_with(gm_sims, ", ") +
            " — sim appeared without a paired HIERARCHY.tape " +
            "@D axis_genetic_medicine declaration")
    }

    // Precondition 3: HIERARCHY.tape still carries @N genetic_medicine_status
    let lbl3 = "HIERARCHY.tape carries " +
        "@N genetic_medicine_status (UNPLACED note)"
    if is_file(hierarchy) {
        let has_note = file_matches(hierarchy,
            "^@N[[:space:]]+genetic_medicine_status[[:space:]]*:=")
        let unplaced_text = file_contains(hierarchy, "UNPLACED")
        if has_note {
            add_pre(idx, lbl3, MET,
                "@N genetic_medicine_status entry header still " +
                "present in HIERARCHY.tape; UNPLACED text " +
                "present=" + (if unplaced_text { "True" } else { "False" }))
        } else {
            add_pre(idx, lbl3, UN_MET,
                "@N genetic_medicine_status header NOT FOUND " +
                "in HIERARCHY.tape — UNPLACED declaration removed " +
                "without a paired @D axis_genetic_medicine " +
                "registration")
        }
    } else {
        add_pre(idx, lbl3, SKIP,
            "AXIS/HIERARCHY.tape absent — g7 " +
            "skip-is-honest; cannot verify the @N marker")
    }
}

fn check_adc(root: string) {
    let hierarchy = root + "/AXIS/HIERARCHY.tape"
    let py_module = root + "/_python_bridge/module"
    let decl = "UNPLACED (CBER antibody scope, criterion #4) — HIERARCHY.tape " +
        "@N adc_status; CHANGELOG.md DEFERRED table."
    let refs: array = ["AXIS/HIERARCHY.tape", "CHANGELOG.md"]
    let idx = begin_item("ADC code axis", decl, refs, false, "")

    // Precondition 1: no adc/module/ directory
    if is_dir(root + "/adc/module") == false {
        add_pre(idx, "no adc/module/ directory", MET,
            "adc/module absent")
    } else {
        add_pre(idx, "no adc/module/ directory", UN_MET,
            "adc/module present — code axis " +
            "appeared without a paired HIERARCHY.tape " +
            "@D axis_adc declaration")
    }

    // Precondition 2: no _python_bridge/module/adc_*.py sim
    let adc_sims = list_files_matching(py_module, "^adc_.*\\.py$")
    if len(adc_sims) == 0 {
        add_pre(idx, "no _python_bridge/module/adc_*.py sim", MET,
            "scanned _python_bridge/module — no " +
            "adc_*.py files")
    } else {
        add_pre(idx, "no _python_bridge/module/adc_*.py sim", UN_MET,
            "found: " + join_with(adc_sims, ", ") +
            " — sim appeared without a paired HIERARCHY.tape " +
            "@D axis_adc declaration")
    }

    // Precondition 3: HIERARCHY.tape still carries @N adc_status
    let lbl3 = "HIERARCHY.tape carries @N adc_status " +
        "(UNPLACED note)"
    if is_file(hierarchy) {
        let has_note = file_matches(hierarchy,
            "^@N[[:space:]]+adc_status[[:space:]]*:=")
        if has_note {
            add_pre(idx, lbl3, MET,
                "@N adc_status entry header still present in " +
                "HIERARCHY.tape")
        } else {
            add_pre(idx, lbl3, UN_MET,
                "@N adc_status header NOT FOUND in HIERARCHY.tape " +
                "— UNPLACED declaration removed without a paired " +
                "@D axis_adc registration")
        }
    } else {
        add_pre(idx, "HIERARCHY.tape carries @N adc_status (UNPLACED note)", SKIP,
            "AXIS/HIERARCHY.tape absent — g7 " +
            "skip-is-honest; cannot verify the @N marker")
    }
}

fn check_theranostic_scope(root: string) {
    let hierarchy = root + "/AXIS/HIERARCHY.tape"
    let theranostic_scope = root + "/AXIS/THERANOSTIC_SCOPE.md"
    let py_module = root + "/_python_bridge/module"
    let decl = "UNPLACED, DECISION DEFERRED — HIERARCHY.tape @N theranostic_status " +
        "+ AXIS/THERANOSTIC_SCOPE.md (FOR/AGAINST/DEFERRED, no decision); " +
        "CHANGELOG.md DEFERRED table."
    let refs: array = ["AXIS/HIERARCHY.tape", "AXIS/THERANOSTIC_SCOPE.md", "CHANGELOG.md"]
    let idx = begin_item("THERANOSTIC scope decision", decl, refs, false, "")

    // Precondition 1: HIERARCHY.tape still carries @N theranostic_status
    let lbl1 = "HIERARCHY.tape carries @N theranostic_status " +
        "(UNPLACED note)"
    if is_file(hierarchy) {
        let has_note = file_matches(hierarchy,
            "^@N[[:space:]]+theranostic_status[[:space:]]*:=")
        if has_note {
            add_pre(idx, lbl1, MET,
                "@N theranostic_status entry header still present " +
                "in HIERARCHY.tape")
        } else {
            add_pre(idx, lbl1, UN_MET,
                "@N theranostic_status header NOT FOUND in " +
                "HIERARCHY.tape — UNPLACED declaration removed " +
                "without a paired @D axis_theranostic " +
                "registration")
        }
    } else {
        add_pre(idx, lbl1, SKIP,
            "AXIS/HIERARCHY.tape absent — g7 " +
            "skip-is-honest")
    }

    // Precondition 2: AXIS/THERANOSTIC_SCOPE.md still reads DECISION DEFERRED
    let lbl2 = "AXIS/THERANOSTIC_SCOPE.md reads 'DECISION " +
        "DEFERRED' and 'does NOT pick a side'"
    if is_file(theranostic_scope) {
        let deferred_text = file_contains(theranostic_scope, "DECISION DEFERRED")
        let does_not_decide = file_contains(theranostic_scope, "does NOT pick a side") ||
            file_contains(theranostic_scope, "does NOT decide")
        if deferred_text && does_not_decide {
            add_pre(idx, lbl2, MET,
                "both markers present — the scope-resolution " +
                "document still defers the decision to the user")
        } else {
            add_pre(idx, lbl2, UN_MET,
                "DECISION DEFERRED text present=" +
                (if deferred_text { "True" } else { "False" }) + "; " +
                "'does NOT pick a side' text " +
                "present=" + (if does_not_decide { "True" } else { "False" }) +
                " — the deferred-state " +
                "markers have changed without a paired " +
                "HIERARCHY.tape un-deferral entry")
        }
    } else {
        add_pre(idx, lbl2, SKIP,
            "AXIS/THERANOSTIC_SCOPE.md absent — g7 " +
            "skip-is-honest; doc may have been renamed, but " +
            "the verdict still rests on the HIERARCHY.tape " +
            "@N marker (precondition 1)")
    }

    // Precondition 3: no theranostic/module/ dir and no theranostic_*.py sim
    let ther_module_dir = root + "/theranostic/module"
    let ther_sims = list_files_matching(py_module, "^theranostic.*\\.py$")
    let module_present = is_dir(ther_module_dir)
    let boundary_ok = (module_present == false) && (len(ther_sims) == 0)
    let lbl3 = "no theranostic/module/ directory and no " +
        "_python_bridge/module/theranostic_*.py sim"
    if boundary_ok {
        add_pre(idx, lbl3, MET,
            "theranostic/module absent; " +
            "no theranostic*.py files in " +
            "_python_bridge/module")
    } else {
        let mut detail_bits: array = []
        if module_present { detail_bits.push("theranostic/module present") }
        if len(ther_sims) > 0 {
            detail_bits.push("sim files: " + join_with(ther_sims, ", "))
        }
        add_pre(idx, lbl3, UN_MET,
            join_with(detail_bits, "; ") +
            " — code axis appeared without a paired " +
            "HIERARCHY.tape @D axis_theranostic declaration")
    }
}

fn check_atlas_blue_upgrade(root: string) {
    let changelog = root + "/CHANGELOG.md"
    let atlas_registry = root + "/_python_bridge/spec/atlas_atom_registry.json"
    let decl = "DEFERRED (sister-repo work) — CHANGELOG.md DEFERRED table; " +
        "partial-resolution path: R1 added " +
        "_python_bridge/spec/atlas_atom_registry.json with PROVEN atoms + " +
        "upgrade proposal; formal hexa verify 🔵 flip still pending in " +
        "hexa-meta sister repo."
    let refs: array = ["CHANGELOG.md", "_python_bridge/spec/atlas_atom_registry.json"]
    let partial_rationale = "R1 atlas atom registry is in-repo and PROVES a roster of " +
        "atoms (in-repo half resolved); formal hexa verify 🔵 tier " +
        "flip is sister-repo work (hexa-meta lean4, g5/g6/f3) and " +
        "is honestly still pending — PARTIALLY-RESOLVED, not " +
        "fully-resolved, not violated"
    let idx = begin_item("hexa atlas 🔵 upgrade", decl, refs, true, partial_rationale)

    // Precondition 1: R1 registry present
    let lbl1 = "R1 atlas atom registry present (partial " +
        "resolution: in-repo symbolic proofs)"
    if is_file(atlas_registry) {
        let blob = exec("cat " + shq(atlas_registry) + " 2>/dev/null")
        let reg = json_parse(blob)
        if type_of(reg) == "map" {
            let atoms = if reg.has("atoms") { reg["atoms"] } else { [] }
            let mut n_total = 0
            let mut n_proven = 0
            if type_of(atoms) == "array" {
                n_total = len(atoms)
                let mut ai = 0
                while ai < len(atoms) {
                    let a = atoms[ai]
                    if type_of(a) == "map" && a.has("proof_status") &&
                       str(a["proof_status"]) == "PROVEN" {
                        n_proven = n_proven + 1
                    }
                    ai = ai + 1
                }
            }
            let registry_ok = n_proven >= 1
            let rv = if reg.has("registry_version") { str(reg["registry_version"]) } else { "?" }
            add_pre(idx, lbl1, (if registry_ok { MET } else { UN_MET }),
                "_python_bridge/spec/atlas_atom_registry.json loaded; " +
                str(n_proven) + "/" + str(n_total) + " atom(s) PROVEN; " +
                "registry_version=" + rv)
        } else {
            add_pre(idx, lbl1, UN_MET,
                "_python_bridge/spec/atlas_atom_registry.json present but " +
                "unreadable / invalid JSON")
        }
    } else {
        add_pre(idx, lbl1, SKIP,
            "_python_bridge/spec/atlas_atom_registry.json absent — g7 " +
            "skip-is-honest; if registry is gone the item " +
            "reverts to STILL-DEFERRED, not violation")
    }

    // Precondition 2: CHANGELOG.md still declares the upgrade DEFERRED
    let lbl2 = "CHANGELOG.md still declares the 🔵 upgrade as " +
        "DEFERRED (formal flip pending sister-repo)"
    if is_file(changelog) {
        let has_declaration = file_contains(changelog, "hexa atlas` 🔵 upgrade") ||
            file_contains(changelog, "atlas` 🔵 upgrade") ||
            file_contains(changelog, "🔵 upgrade")
        if has_declaration {
            add_pre(idx, lbl2, MET,
                "CHANGELOG.md contains the '🔵 upgrade' DEFERRED " +
                "marker")
        } else {
            add_pre(idx, lbl2, UN_MET,
                "CHANGELOG.md present but no '🔵 upgrade' marker " +
                "— declaration may have been removed; if the " +
                "formal flip actually happened, this would be " +
                "honest (paired with a registered-axis update); " +
                "until verified, treat as un-met")
        }
    } else {
        add_pre(idx, lbl2, SKIP,
            "CHANGELOG.md absent — g7 " +
            "skip-is-honest")
    }
}

// ── printing ─────────────────────────────────────────────────────────────
fn print_item(num: int, idx: int) {
    let nm = str(it_name[idx])
    let dash = 60 - cp_len(nm)
    println("── item " + str(num) + ": " + nm + " " + repeat("─", dash))
    println("  deferred declaration : " + str(it_decl[idx]))
    println("  primary references   : " + join_with(it_refs[idx], ", "))
    println("  preconditions:")
    let lo = it_pc_lo[idx]
    let hi = it_pc_hi[idx]
    let mut i = lo
    while i < hi {
        println("    [" + ljust(str(pc_result[i]), 6) + "] " + str(pc_label[i]))
        println("             " + str(pc_detail[i]))
        i = i + 1
    }
    println("  VERDICT              : " + verdict_of(idx))
    println("  rationale            : " + rationale_of(idx))
    println("")
}

fn print_summary_table() {
    println("── summary table " + repeat("─", 56))
    let mut name_w = 0
    let mut verdict_w = 0
    let mut i = 0
    while i < len(it_name) {
        let nl = cp_len(str(it_name[i]))
        let vl = cp_len(verdict_of(i))
        if nl > name_w { name_w = nl }
        if vl > verdict_w { verdict_w = vl }
        i = i + 1
    }
    println("  " + ljust("#", 2) + " " + ljust("item", name_w) + "  " +
            ljust("verdict", verdict_w))
    println("  " + repeat("-", 2) + " " + repeat("-", name_w) + "  " +
            repeat("-", verdict_w))
    let mut k = 0
    while k < len(it_name) {
        println("  " + ljust(str(k + 1), 2) + " " +
                ljust(str(it_name[k]), name_w) + "  " +
                ljust(verdict_of(k), verdict_w))
        k = k + 1
    }
    println("")
}

fn main() {
    println("deferred_items_tracking_gate — hexa-bio DEFERRED items " +
            "boundary enforcer")
    println("  enumerates the explicitly-DEFERRED items declared in " +
            "AXIS/HIERARCHY.tape + CHANGELOG.md and verifies the deferred-")
    println("  state preconditions still hold on disk. PASS iff every item " +
            "is STILL-DEFERRED or PARTIALLY-RESOLVED (no silent " +
            "un-deferral).")
    println("  governance: g1 honest-boundary-check · g7 skip-is-honest " +
            "(absent ref ⇒ SKIP, not FAIL) · g8 in-silico-only " +
            "(governance metadata, not a clinical claim)")
    println("  honest framing: this gate is a BOUNDARY ENFORCER, not a " +
            "PERMANENT FREEZE. Un-deferral is a legitimate future")
    println("  action; it must be paired with a governance update " +
            "(HIERARCHY.tape @D axis_<X> registration or CHANGELOG.md")
    println("  DEFERRED-row removal) — that pairing is what this gate " +
            "checks.\n")

    let root = repo_root()
    check_200_disease_remapping(root)
    check_genetic_medicine(root)
    check_adc(root)
    check_theranostic_scope(root)
    check_atlas_blue_upgrade(root)

    let mut i = 0
    while i < len(it_name) {
        print_item(i + 1, i)
        i = i + 1
    }

    print_summary_table()

    let mut n_still = 0
    let mut n_partial = 0
    let mut n_violation = 0
    let mut j = 0
    while j < len(it_name) {
        let v = verdict_of(j)
        if v == STILL_DEFERRED { n_still = n_still + 1 }
        if v == PARTIALLY_RESOLVED { n_partial = n_partial + 1 }
        if v == UN_DEFERRED_VIOLATION { n_violation = n_violation + 1 }
        j = j + 1
    }
    let n_total = len(it_name)
    println("  " + str(n_still) + " STILL-DEFERRED · " + str(n_partial) +
            " PARTIALLY-RESOLVED · " + str(n_violation) +
            " UN-DEFERRED-VIOLATION (of " + str(n_total) + " items)\n")

    println("  HONESTY (g1): each verdict ties to concrete on-disk")
    println("    preconditions (file presence / @N marker / text marker).")
    println("    No precondition is fabricated; absent reference files are")
    println("    honestly SKIPPED (g7), not silently passed.")
    println("  HONESTY (g8): this gate is GOVERNANCE METADATA. PASS does")
    println("    NOT assert any axis is or is not a viable therapy; it")
    println("    asserts only that the DEFERRED declarations and the")
    println("    on-disk boundary are mutually consistent.")
    println("  HONESTY (framing): boundary-enforcer ≠ permanent-freeze.")
    println("    A FAIL here means an item was un-deferred without the")
    println("    paired governance update — the fix is to either pair")
    println("    the new code with a HIERARCHY.tape @D axis_<X> entry +")
    println("    CHANGELOG update, or remove the un-deferred artifact.\n")

    if n_violation == 0 {
        println("__DEFERRED_ITEMS_TRACKING_GATE__ PASS")
        exit(0)
    }
    println("__DEFERRED_ITEMS_TRACKING_GATE__ FAIL")
    exit(1)
}
