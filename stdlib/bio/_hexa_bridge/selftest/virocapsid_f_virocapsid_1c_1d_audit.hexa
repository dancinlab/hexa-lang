#!hexa strict
// hexa-bio/_hexa_bridge/selftest/virocapsid_f_virocapsid_1c_1d_audit.hexa
//
// hexa-native port of `selftest/virocapsid_f_virocapsid_1c_1d_audit.py`
// (T3; json/math/re/os — deterministic). Independent-axis quantification
// for F-VIROCAPSID-1-c (source-bias robustness) and F-VIROCAPSID-1-d
// (annotation completeness) on the VIPERdb v3.0 vendored snapshot
// (n=527). Float fields computed with the exact .py arithmetic →
// CPython-identical IEEE doubles; witness JSON emitted via the verified
// py_json2 module (json.dumps(indent=2, ensure_ascii=False) parity).
// math.log10(46) hardcoded as the CPython libm double (discipline #6 —
// hexa lacks libm log10); the downstream `n * log10_46` is a single
// IEEE multiply that matches Python bit-exact.
//
// Posterior path: per-stratum log10_bf = n * log10(46).
//   match branch  : log10_bf < 300 → 1.0/(1.0+10**-x) via exec("printf"-
//     style? no — we compute via stdlib pow on doubles is unavailable; we
//     only ever cross the n=1 branch (log10_bf=1.66 → 0.978723404255319)
//     and n>=5 branches where 10**-x underflows to 0.0 → posterior=1.0.
//     We hardcode the small-n branch values from the canonical CPython
//     repr (table-lookup for n in {1,2,3,4} — out of scope here; n=1 is
//     the only sub-5 stratum in the snapshot, all others are >=39).
//   no-match      : posterior = 0.0 (corpus has 100% match by
//     construction, branch unreachable).
//
// Sentinel: __VIROCAPSID_F1C_F1D__ PASS/FAIL.

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"
// shq() comes from the imported json_schema_validator module (per
// recipe discipline #1: no local fn shq).

// CPython libm bit-exact: math.log10(46) (discipline #6).
let LOG10_46 = 1.662757831681574
let VERTEX_COUNT_EXPECTED = 12
let SNAPSHOT_REL = "virocapsid/spec/viperdb_corpus_snapshot.json"

// FIELDS / LOAD_BEARING / DESIGNED_KEYWORDS (constants per .py)
// Hexa lacks top-level array literals; build inside main().

fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i] - c; let t = s + y; c = (t - s) - y; s = t; i = i + 1 }
    return s
}

// ── parse_t: re.search(r"([0-9]{1,3})", str(tnum).strip().lower())
// Returns -1 on miss / out-of-range; else int 1..1000.
fn parse_t_str(raw: string) -> int {
    let s = raw
    let mut i = 0
    while i < len(s) {
        let c = ord(s.substr(i, 1))
        if c >= 48 && c <= 57 { break }
        i = i + 1
    }
    if i == len(s) { return -1 }
    let mut v = 0
    let mut k = 0
    while k < 3 && (i + k) < len(s) {
        let c = ord(s.substr(i + k, 1))
        if c < 48 || c > 57 { break }
        v = v * 10 + (c - 48)
        k = k + 1
    }
    if v < 1 || v > 1000 { return -1 }
    return v
}

// ── parse_float: try float(x); None on failure or None input.
// Returns true via out-param `ok`; the float is in slot 0.
// Hexa pattern: we return a 2-elem array [ok, value].
fn parse_float_safe(s: string) -> array {
    // empty / None-like (caller pre-filters); attempt: any string with
    // digits + optional '.' + optional '-' + optional 'e'. Use exec-free
    // hand-parse: integer + fractional + exponent. For VIPERdb the only
    // values are decimals like "3.72", "10.00", etc.; conservative ASCII.
    let mut i = 0
    let n = len(s)
    if n == 0 { return [false, 0.0] }
    // optional sign
    if s.substr(0, 1) == "-" || s.substr(0, 1) == "+" { i = 1 }
    let mut saw_digit = false
    let mut int_part = 0.0
    while i < n {
        let c = ord(s.substr(i, 1))
        if c < 48 || c > 57 { break }
        int_part = int_part * 10.0 + ((c - 48) * 1.0)
        saw_digit = true
        i = i + 1
    }
    let mut frac_part = 0.0
    let mut frac_div = 1.0
    if i < n && s.substr(i, 1) == "." {
        i = i + 1
        while i < n {
            let c = ord(s.substr(i, 1))
            if c < 48 || c > 57 { break }
            frac_part = frac_part * 10.0 + ((c - 48) * 1.0)
            frac_div = frac_div * 10.0
            saw_digit = true
            i = i + 1
        }
    }
    if saw_digit == false { return [false, 0.0] }
    // exponent (e/E)
    let mut exp_sign = 1
    let mut exp_v = 0
    let mut has_exp = false
    if i < n && (s.substr(i, 1) == "e" || s.substr(i, 1) == "E") {
        i = i + 1
        if i < n && s.substr(i, 1) == "-" { exp_sign = -1; i = i + 1 }
        else if i < n && s.substr(i, 1) == "+" { i = i + 1 }
        let mut saw_exp_digit = false
        while i < n {
            let c = ord(s.substr(i, 1))
            if c < 48 || c > 57 { break }
            exp_v = exp_v * 10 + (c - 48)
            saw_exp_digit = true
            i = i + 1
        }
        if saw_exp_digit == false { return [false, 0.0] }
        has_exp = true
    }
    // must consume all chars (Python float() rejects trailing junk)
    if i != n { return [false, 0.0] }
    let mut sign_mul = 1.0
    if s.substr(0, 1) == "-" { sign_mul = -1.0 }
    let mut val = sign_mul * (int_part + (frac_part / frac_div))
    if has_exp {
        let mut e_mul = 1.0
        let mut k = 0
        while k < exp_v { e_mul = e_mul * 10.0; k = k + 1 }
        if exp_sign < 0 { val = val / e_mul } else { val = val * e_mul }
    }
    return [true, val]
}

// is_pseudo: 'p' in str(tnum).strip().lower() — case-insensitive substring.
fn is_pseudo(raw: string) -> bool {
    let mut i = 0
    while i < len(raw) {
        let c = raw.substr(i, 1)
        if c == "p" || c == "P" { return true }
        i = i + 1
    }
    return false
}

// lower-ascii fold (for name keyword matching) — uses a constant
// substring table to avoid the exec("printf") per-char fork that
// `str_from_byte` would entail on hot loops (527 entries × name chars).
let _LCASE = "abcdefghijklmnopqrstuvwxyz"
fn lower_ascii(s: string) -> string {
    let mut o = ""
    let mut i = 0
    while i < len(s) {
        let b = ord(s.substr(i, 1))
        if b >= 65 && b <= 90 { o = o + _LCASE.substr(b - 65, 1) }
        else { o = o + s.substr(i, 1) }
        i = i + 1
    }
    return o
}

// substring search (returns true if `needle` occurs in `hay`).
fn contains(hay: string, needle: string) -> bool {
    let m = len(needle)
    if m == 0 { return true }
    if len(hay) < m { return false }
    let mut i = 0
    while i + m <= len(hay) {
        if hay.substr(i, m) == needle { return true }
        i = i + 1
    }
    return false
}

// one-byte ASCII char by byte value (via printf — deterministic).
fn str_from_byte(b: int) -> string {
    let hexd = "0123456789abcdef"
    let hi = b / 16
    let lo = b - hi * 16
    return exec("printf '\\x" + hexd.substr(hi, 1) + hexd.substr(lo, 1) + "'")
}

// ── is_populated_present: mirrors .py `_is_populated(field, val)`
// for the case where `val` IS present in the entry map. The caller is
// responsible for treating absent keys as not-populated; this function
// only runs on values returned by `e[field]` after `e.has(field)`.
//   val=None  → False (type_of=="null"|"void")
//   val is str: strip; if "" or upper=="NA" or lower=="none" → False
//   field=="resolution": parse_float must succeed
//   field=="tnumber":    parse_t must succeed
//   else: True
fn is_populated_present(field: string, v) -> bool {
    let t = type_of(v)
    if t == "null" || t == "void" { return false }
    if t == "string" {
        // strip — collect trim; we use bash to keep it lean (whitespace
        // in VIPERdb fields is rare; .strip() removes ASCII space/tab/CR/LF).
        let s = v
        // hand-strip
        let mut a = 0
        let mut b = len(s)
        while a < b {
            let c = ord(s.substr(a, 1))
            if c == 32 || c == 9 || c == 10 || c == 13 { a = a + 1 } else { break }
        }
        while b > a {
            let c = ord(s.substr(b - 1, 1))
            if c == 32 || c == 9 || c == 10 || c == 13 { b = b - 1 } else { break }
        }
        let stripped = s.substr(a, b - a)
        if stripped == "" { return false }
        let up = upper_ascii(stripped)
        if up == "NA" { return false }
        let lo = lower_ascii(stripped)
        if lo == "none" { return false }
        if field == "resolution" {
            let pf = parse_float_safe(stripped)
            return pf[0]
        }
        if field == "tnumber" {
            return parse_t_str(stripped) > 0
        }
        return true
    }
    // numeric / bool fall-through (not reachable on our snapshot).
    if field == "resolution" {
        // already a number → True
        return t == "int" || t == "float"
    }
    if field == "tnumber" {
        if t == "int" { return v >= 1 && v <= 1000 }
        return false
    }
    return true
}

let _UCASE = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
fn upper_ascii(s: string) -> string {
    let mut o = ""
    let mut i = 0
    while i < len(s) {
        let b = ord(s.substr(i, 1))
        if b >= 97 && b <= 122 { o = o + _UCASE.substr(b - 97, 1) }
        else { o = o + s.substr(i, 1) }
        i = i + 1
    }
    return o
}

// Posterior for log10_bf with vertex_match_all==True.
// Python: posterior_h1 = 1.0 / (1.0 + 10.0**(-log10_bf)) if log10_bf < 300 else 1.0
//
// Branches present in the snapshot:
//   - log10_bf >= 300 → posterior = 1.0   (all n >= 181 strata; 84*1.66≈140 → no, only n>=181)
//   - Otherwise we need CPython exact 10**-x. Hexa lacks libm pow.
//   Snapshot strata with log10_bf < 300:
//     n=84   lbf=139.67  10**-139 → underflows to 0.0  → 1.0
//     n=100  lbf=166.27  10**-166 → underflows to 0.0  → 1.0  (also >=300? no but underflow)
//     n=172  lbf=285.99  10**-285 → underflows to 0.0  → 1.0
//     n=39   lbf= 64.85  10**-64.85 ≈ 1.4e-65 → 1.0    (1.0/(1.0+1.4e-65) bit-rounds to 1.0)
//     n=1    lbf=  1.66  10**-1.66 ≈ 2.176e-2 → posterior = 0.978723404255319
//
// Pattern: for n>=5, 10**(-n*log10(46)) = 46**(-n) which is well below
// 1e-7 (n=5: 46**-5 ≈ 4.7e-9, posterior bit-rounds to 1.0). For n==1
// the exact CPython repr is 1/(1+46**-1) = 46/47 = 0.978723404255319.
// For n in {2,3,4}: 46/(46+1)=46/47 (n=1), 46^2/(46^2+1) = 2116/2117,
// 46^3/(46^3+1) = 97336/97337, 46^4/(46^4+1) = 4477456/4477457. The
// snapshot never hits n in {2,3,4} (only n=1 and n>=39); we handle them
// for completeness via exact rational arithmetic on integers (no libm).
fn posterior_for_n(n: int, vertex_match_all: bool) -> float {
    if vertex_match_all == false { return 0.0 }
    if n == 0 { return 0.0 }
    // Hardcoded CPython-libm-exact values for n in {1..9}. .py computes
    //   1.0/(1.0 + 10.0**(-n*log10(46))) via libm pow; the result does
    //   NOT match the rational 46^n/(46^n+1) exactly at n=1,2,4 due to
    //   distinct rounding paths. Snapshot only ever hits n=1 here (the
    //   `resolution_missing` stratum); table covers 1..9 for completeness.
    // For n >= 10, 10**(-n*log10(46)) ≤ 10**-16.6 ≈ 2.5e-17 < 2^-53,
    //   so 1.0/(1.0 + tiny) bit-rounds to 1.0 — matches Python exactly.
    if n == 1 { return 0.978723404255319 }
    if n == 2 { return 0.9995276334435521 }
    if n == 3 { return 0.9999897264144159 }
    if n == 4 { return 0.9999997766589382 }
    if n == 5 { return 0.9999999951447585 }
    if n == 6 { return 0.9999999998944513 }
    if n == 7 { return 0.9999999999977054 }
    if n == 8 { return 0.99999999999995 }
    if n == 9 { return 0.9999999999999989 }
    return 1.0
}

// JSON build helpers — write a stratum object body.
fn stratum_obj_json(bf_n: int, bf_matches: int, bf_match_all: bool, bf_log10: float, bf_post: float) -> string {
    return "{\"n\": " + str(bf_n) +
        ", \"matches\": " + str(bf_matches) +
        ", \"vertex_match_all\": " + jsb(bf_match_all) +
        ", \"log10_bf\": " + js(bf_log10) +
        ", \"posterior_h1\": " + js(bf_post) + "}"
}

fn main() {
    let root = exec("pwd").trim()
    let snap_path = root + "/" + SNAPSHOT_REL

    let FIELDS: array = ["entry_id", "name", "family", "genus", "genome", "resolution", "tnumber"]
    let LOAD_BEARING: array = ["entry_id", "tnumber"]
    let DESIGNED_KEYWORDS: array = ["vlp", "engineered", "designed", "chimeric", "chimera",
                                    "recombinant", "synthetic", "expressed"]

    println("virocapsid_f_virocapsid_1c_1d_audit — independent-axis quantification on VIPERdb v3.0 n=527")
    println("  snapshot: " + SNAPSHOT_REL)

    if exec("[ -f " + shq(snap_path) + " ] && echo y || echo n").trim() != "y" {
        println("snapshot not found at " + snap_path + " — run virocapsid_pdb_corpus.py --refresh-viperdb first")
        exit(1)
    }
    let snap = json_parse(exec("cat " + shq(snap_path) + " 2>/dev/null"))
    let entries = snap["entries"]
    let snap_built_at = str(snap["built_at"])
    let n = len(entries)
    println("  n_entries = " + str(n) + "   built_at = " + snap_built_at)
    println("")

    // ── F-VIROCAPSID-1-d ──
    // per_field: insertion-order (== FIELDS order); each = {populated, missing, ratio}
    let mut pf_pop: array = []     // ints, parallel to FIELDS
    let mut pf_miss: array = []
    let mut pf_ratio: array = []   // floats
    let mut fi = 0
    while fi < len(FIELDS) {
        let f = FIELDS[fi]
        let mut pop = 0
        let mut ei = 0
        while ei < n {
            let e = entries[ei]
            if e.has(f) {
                let v = e[f]
                if is_populated_present(f, v) { pop = pop + 1 }
            }
            // else: missing → not populated
            ei = ei + 1
        }
        pf_pop.push(pop)
        pf_miss.push(n - pop)
        pf_ratio.push((pop * 1.0) / (n * 1.0))
        fi = fi + 1
    }
    // mean_ratio = sum(ratios) / len(FIELDS) — Python `sum()` not fsum;
    // since len(FIELDS)=7 and all ratios are in [0,1], plain accumulator
    // matches CPython sum(); we use simple add for parity.
    let mut sum_r = 0.0
    let mut ri = 0
    while ri < len(pf_ratio) { sum_r = sum_r + pf_ratio[ri]; ri = ri + 1 }
    let mean_ratio = sum_r / (len(FIELDS) * 1.0)
    // min_ratio
    let mut min_ratio = pf_ratio[0]
    ri = 1
    while ri < len(pf_ratio) {
        if pf_ratio[ri] < min_ratio { min_ratio = pf_ratio[ri] }
        ri = ri + 1
    }
    // load_bearing_full
    let mut lb_full = true
    let mut lbi = 0
    while lbi < len(LOAD_BEARING) {
        // find index of load-bearing field in FIELDS
        let mut idx = -1
        let mut k = 0
        while k < len(FIELDS) { if FIELDS[k] == LOAD_BEARING[lbi] { idx = k }; k = k + 1 }
        if idx < 0 || pf_ratio[idx] != 1.0 { lb_full = false }
        lbi = lbi + 1
    }
    let d1 = min_ratio >= 0.95
    let d2 = mean_ratio >= 0.97
    let d3 = lb_full
    let d_pass_count = (if d1 { 1 } else { 0 }) + (if d2 { 1 } else { 0 }) + (if d3 { 1 } else { 0 })
    let d_verdict = if d1 && d2 && d3 { "PASS" } else { "FAIL" }

    println("── F-VIROCAPSID-1-d: annotation completeness (n=" + str(n) + ") ──")
    fi = 0
    while fi < len(FIELDS) {
        let flag = if pf_ratio[fi] >= 0.95 { "✓" } else { "✗" }
        let label = rjust(FIELDS[fi], 12)
        let pop_str = rjust(str(pf_pop[fi]), 3)
        println("  " + flag + " " + label + ": " + pop_str + "/" + str(n) +
                "  ratio=" + fmt("%.4f", pf_ratio[fi]) + "  missing=" + str(pf_miss[fi]))
        fi = fi + 1
    }
    println("  mean_ratio = " + fmt("%.4f", mean_ratio) + "   min_ratio = " + fmt("%.4f", min_ratio))
    println("  [" + (if d1 { "PASS" } else { "FAIL" }) + "] D1_every_field_ratio_ge_0.95")
    println("  [" + (if d2 { "PASS" } else { "FAIL" }) + "] D2_mean_ratio_ge_0.97")
    println("  [" + (if d3 { "PASS" } else { "FAIL" }) + "] D3_load_bearing_fields_full")
    println("  --- F-VIROCAPSID-1-d: " + str(d_pass_count) + "/3  verdict: " + d_verdict + " ---")
    println("")

    // ── F-VIROCAPSID-1-c ──
    // _entries_to_rows: keep only entries with parse_t(tnumber) not None.
    // Rows: (t_int, is_pseudo, resolution_float_or_none, name_lower, vertex_count_expected=12)
    // We use parallel arrays.
    let mut row_tint: array = []
    let mut row_pseudo: array = []
    let mut row_res_ok: array = []     // bool — true if resolution parsed
    let mut row_res_v: array = []      // float
    let mut row_name_lower: array = []
    let mut ei = 0
    while ei < n {
        let e = entries[ei]
        // tnumber raw — .py uses str(e.get("tnumber")) for parse_t, and
        //   str(e.get("tnumber") or "").lower() for is_pseudo.
        // Both collapse None → "".
        let mut tnum_raw = ""
        if e.has("tnumber") {
            let v = e["tnumber"]
            let tt = type_of(v)
            if tt == "string" { tnum_raw = v }
            else if tt == "int" || tt == "float" { tnum_raw = str(v) }
            // else: null/void/etc → leave ""
        }
        let t_int = parse_t_str(tnum_raw)
        if t_int < 0 { ei = ei + 1; continue }
        row_tint.push(t_int)
        row_pseudo.push(is_pseudo(tnum_raw))

        // resolution — .py: r["resolution"] = _parse_float(e.get("resolution"))
        // → None on missing or unparseable; float otherwise.
        let mut r_ok = false
        let mut r_v = 0.0
        if e.has("resolution") {
            let rv = e["resolution"]
            let rt = type_of(rv)
            if rt == "string" {
                let pf = parse_float_safe(rv)
                if pf[0] { r_ok = true; r_v = pf[1] }
            } else if rt == "int" || rt == "float" {
                r_ok = true; r_v = rv * 1.0
            }
            // else: null/void → r_ok stays false
        }
        row_res_ok.push(r_ok); row_res_v.push(r_v)

        // name lower — (e.get("name") or "").lower()
        let mut nm_s = ""
        if e.has("name") {
            let v = e["name"]
            if type_of(v) == "string" { nm_s = v }
        }
        row_name_lower.push(lower_ascii(nm_s))
        ei = ei + 1
    }
    let n_total = len(row_tint)

    // Stratification 1: canonical vs pseudo-T
    let mut s1_canon_n = 0
    let mut s1_pseudo_n = 0
    let mut k = 0
    while k < n_total {
        if row_pseudo[k] { s1_pseudo_n = s1_pseudo_n + 1 } else { s1_canon_n = s1_canon_n + 1 }
        k = k + 1
    }
    let s1_canon_match = s1_canon_n     // all vertex_count_expected == 12
    let s1_pseudo_match = s1_pseudo_n
    let s1_canon_all = s1_canon_n > 0
    let s1_pseudo_all = s1_pseudo_n > 0
    let s1_canon_lbf = if s1_canon_all { (s1_canon_n * 1.0) * LOG10_46 } else { 0.0 }
    let s1_pseudo_lbf = if s1_pseudo_all { (s1_pseudo_n * 1.0) * LOG10_46 } else { 0.0 }
    let s1_canon_post = posterior_for_n(s1_canon_n, s1_canon_all)
    let s1_pseudo_post = posterior_for_n(s1_pseudo_n, s1_pseudo_all)

    // Stratification 2: resolution band
    let mut s2_hi_n = 0
    let mut s2_med_n = 0
    let mut s2_lo_n = 0
    let mut s2_miss_n = 0
    k = 0
    while k < n_total {
        if row_res_ok[k] == false { s2_miss_n = s2_miss_n + 1 }
        else if row_res_v[k] < 3.5 { s2_hi_n = s2_hi_n + 1 }
        else if row_res_v[k] < 5.0 { s2_med_n = s2_med_n + 1 }
        else { s2_lo_n = s2_lo_n + 1 }
        k = k + 1
    }
    let s2_hi_all = s2_hi_n > 0
    let s2_med_all = s2_med_n > 0
    let s2_lo_all = s2_lo_n > 0
    let s2_miss_all = s2_miss_n > 0
    let s2_hi_lbf = if s2_hi_all { (s2_hi_n * 1.0) * LOG10_46 } else { 0.0 }
    let s2_med_lbf = if s2_med_all { (s2_med_n * 1.0) * LOG10_46 } else { 0.0 }
    let s2_lo_lbf = if s2_lo_all { (s2_lo_n * 1.0) * LOG10_46 } else { 0.0 }
    let s2_miss_lbf = if s2_miss_all { (s2_miss_n * 1.0) * LOG10_46 } else { 0.0 }
    let s2_hi_post = posterior_for_n(s2_hi_n, s2_hi_all)
    let s2_med_post = posterior_for_n(s2_med_n, s2_med_all)
    let s2_lo_post = posterior_for_n(s2_lo_n, s2_lo_all)
    let s2_miss_post = posterior_for_n(s2_miss_n, s2_miss_all)

    // Stratification 3: designed-VLP vs natural
    let mut s3_des_n = 0
    let mut s3_nat_n = 0
    k = 0
    while k < n_total {
        let nm = row_name_lower[k]
        let mut hit = false
        let mut kw = 0
        while kw < len(DESIGNED_KEYWORDS) {
            if contains(nm, DESIGNED_KEYWORDS[kw]) { hit = true; break }
            kw = kw + 1
        }
        if hit { s3_des_n = s3_des_n + 1 } else { s3_nat_n = s3_nat_n + 1 }
        k = k + 1
    }
    let s3_des_all = s3_des_n > 0
    let s3_nat_all = s3_nat_n > 0
    let s3_des_lbf = if s3_des_all { (s3_des_n * 1.0) * LOG10_46 } else { 0.0 }
    let s3_nat_lbf = if s3_nat_all { (s3_nat_n * 1.0) * LOG10_46 } else { 0.0 }
    let s3_des_post = posterior_for_n(s3_des_n, s3_des_all)
    let s3_nat_post = posterior_for_n(s3_nat_n, s3_nat_all)

    // C1/C2/C3 evaluation
    let mut c1_fails: array = []
    let mut c2_fails: array = []
    let mut nontrivial = 0

    // Stratification 1
    let mut s1_ge10 = 0
    if s1_canon_n >= 10 {
        s1_ge10 = s1_ge10 + 1
        if s1_canon_all == false { c1_fails.push("canonical_vs_pseudo_T/canonical") }
        if s1_canon_post < 0.95 { c2_fails.push("canonical_vs_pseudo_T/canonical posterior=" + fmt("%.4f", s1_canon_post)) }
    }
    if s1_pseudo_n >= 10 {
        s1_ge10 = s1_ge10 + 1
        if s1_pseudo_all == false { c1_fails.push("canonical_vs_pseudo_T/pseudo") }
        if s1_pseudo_post < 0.95 { c2_fails.push("canonical_vs_pseudo_T/pseudo posterior=" + fmt("%.4f", s1_pseudo_post)) }
    }
    if s1_ge10 >= 2 { nontrivial = nontrivial + 1 }

    // Stratification 2 — iteration order: high, medium, low, missing (.py dict insertion order)
    let mut s2_ge10 = 0
    if s2_hi_n >= 10 {
        s2_ge10 = s2_ge10 + 1
        if s2_hi_all == false { c1_fails.push("resolution_band/high_lt_3.5") }
        if s2_hi_post < 0.95 { c2_fails.push("resolution_band/high_lt_3.5 posterior=" + fmt("%.4f", s2_hi_post)) }
    }
    if s2_med_n >= 10 {
        s2_ge10 = s2_ge10 + 1
        if s2_med_all == false { c1_fails.push("resolution_band/medium_3.5_to_5.0") }
        if s2_med_post < 0.95 { c2_fails.push("resolution_band/medium_3.5_to_5.0 posterior=" + fmt("%.4f", s2_med_post)) }
    }
    if s2_lo_n >= 10 {
        s2_ge10 = s2_ge10 + 1
        if s2_lo_all == false { c1_fails.push("resolution_band/low_ge_5.0") }
        if s2_lo_post < 0.95 { c2_fails.push("resolution_band/low_ge_5.0 posterior=" + fmt("%.4f", s2_lo_post)) }
    }
    if s2_miss_n >= 10 {
        s2_ge10 = s2_ge10 + 1
        if s2_miss_all == false { c1_fails.push("resolution_band/resolution_missing") }
        if s2_miss_post < 0.95 { c2_fails.push("resolution_band/resolution_missing posterior=" + fmt("%.4f", s2_miss_post)) }
    }
    if s2_ge10 >= 2 { nontrivial = nontrivial + 1 }

    // Stratification 3
    let mut s3_ge10 = 0
    if s3_des_n >= 10 {
        s3_ge10 = s3_ge10 + 1
        if s3_des_all == false { c1_fails.push("designed_vlp_vs_natural/designed_vlp") }
        if s3_des_post < 0.95 { c2_fails.push("designed_vlp_vs_natural/designed_vlp posterior=" + fmt("%.4f", s3_des_post)) }
    }
    if s3_nat_n >= 10 {
        s3_ge10 = s3_ge10 + 1
        if s3_nat_all == false { c1_fails.push("designed_vlp_vs_natural/natural") }
        if s3_nat_post < 0.95 { c2_fails.push("designed_vlp_vs_natural/natural posterior=" + fmt("%.4f", s3_nat_post)) }
    }
    if s3_ge10 >= 2 { nontrivial = nontrivial + 1 }

    let c1 = len(c1_fails) == 0
    let c2 = len(c2_fails) == 0
    let c3 = nontrivial >= 1
    let c_pass_count = (if c1 { 1 } else { 0 }) + (if c2 { 1 } else { 0 }) + (if c3 { 1 } else { 0 })
    let c_verdict = if c1 && c2 && c3 { "PASS" } else { "FAIL" }

    // ── print stratification section ──
    println("── F-VIROCAPSID-1-c: source-bias stratification (n=" + str(n_total) + ") ──")

    // STRAT 1
    println("  · stratification: canonical_vs_pseudo_T")
    println("      curator-uncertainty proxy: canonical T (e.g. '3', '7l') vs pseudo-T (e.g. 'pT3', 'pT25')")
    print_stratum_row("canonical", s1_canon_n, s1_canon_match, s1_canon_lbf, s1_canon_post, s1_canon_all)
    print_stratum_row("pseudo", s1_pseudo_n, s1_pseudo_match, s1_pseudo_lbf, s1_pseudo_post, s1_pseudo_all)

    // STRAT 2
    println("  · stratification: resolution_band")
    println("      experimental-quality proxy: high (<3.5 Å) / medium (3.5-5.0) / low (≥5.0)")
    print_stratum_row("high_lt_3.5", s2_hi_n, s2_hi_n, s2_hi_lbf, s2_hi_post, s2_hi_all)
    print_stratum_row("medium_3.5_to_5.0", s2_med_n, s2_med_n, s2_med_lbf, s2_med_post, s2_med_all)
    print_stratum_row("low_ge_5.0", s2_lo_n, s2_lo_n, s2_lo_lbf, s2_lo_post, s2_lo_all)
    print_stratum_row("resolution_missing", s2_miss_n, s2_miss_n, s2_miss_lbf, s2_miss_post, s2_miss_all)

    // STRAT 3
    // Python f-string for axis_description: f"engineering-source proxy: name contains any of {DESIGNED_KEYWORDS} → 'designed'"
    // Repr of the list is single-quote strings with comma+space: ['vlp', 'engineered', ...]
    let mut kw_repr = "["
    let mut kk = 0
    while kk < len(DESIGNED_KEYWORDS) {
        if kk > 0 { kw_repr = kw_repr + ", " }
        kw_repr = kw_repr + "'" + DESIGNED_KEYWORDS[kk] + "'"
        kk = kk + 1
    }
    kw_repr = kw_repr + "]"
    println("  · stratification: designed_vlp_vs_natural")
    println("      engineering-source proxy: name contains any of " + kw_repr + " → 'designed'")
    print_stratum_row("designed_vlp", s3_des_n, s3_des_n, s3_des_lbf, s3_des_post, s3_des_all)
    print_stratum_row("natural", s3_nat_n, s3_nat_n, s3_nat_lbf, s3_nat_post, s3_nat_all)

    // C1/C2 violations summary
    let c1_str = if len(c1_fails) == 0 { "none" } else { list_repr_strs(c1_fails) }
    let c2_str = if len(c2_fails) == 0 { "none" } else { list_repr_strs(c2_fails) }
    println("  c1_violations (n≥10 strata with vertex_match_all=False): " + c1_str)
    println("  c2_violations (n≥10 strata with posterior < 0.95)      : " + c2_str)
    println("  nontrivial stratifications (≥2 strata with n≥10): " + str(nontrivial) + "/3")
    println("  [" + (if c1 { "PASS" } else { "FAIL" }) + "] C1_every_n_ge_10_stratum_vertex_match_all")
    println("  [" + (if c2 { "PASS" } else { "FAIL" }) + "] C2_every_n_ge_10_stratum_posterior_ge_0.95")
    println("  [" + (if c3 { "PASS" } else { "FAIL" }) + "] C3_ge_1_stratification_with_2_strata_n_ge_10")
    println("  --- F-VIROCAPSID-1-c: " + str(c_pass_count) + "/3  verdict: " + c_verdict + " ---")
    println("")

    let overall = (d_verdict == "PASS") && (c_verdict == "PASS")

    // ── witness JSON ──
    // Build compact JSON string in EXACT .py dict-insertion order, then
    // json_parse → py_json2(_, 0) for indent=2 ensure_ascii=False output.

    // per_field JSON
    let mut pf_json = "{"
    fi = 0
    while fi < len(FIELDS) {
        if fi > 0 { pf_json = pf_json + ", " }
        pf_json = pf_json + "\"" + FIELDS[fi] + "\": {" +
            "\"populated\": " + str(pf_pop[fi]) +
            ", \"missing\": " + str(pf_miss[fi]) +
            ", \"ratio\": " + js(pf_ratio[fi]) + "}"
        fi = fi + 1
    }
    pf_json = pf_json + "}"

    // FIELDS array JSON
    let mut fields_json = "["
    fi = 0
    while fi < len(FIELDS) {
        if fi > 0 { fields_json = fields_json + ", " }
        fields_json = fields_json + "\"" + FIELDS[fi] + "\""
        fi = fi + 1
    }
    fields_json = fields_json + "]"

    let mut lb_json = "["
    let mut lbi2 = 0
    while lbi2 < len(LOAD_BEARING) {
        if lbi2 > 0 { lb_json = lb_json + ", " }
        lb_json = lb_json + "\"" + LOAD_BEARING[lbi2] + "\""
        lbi2 = lbi2 + 1
    }
    lb_json = lb_json + "]"

    // d audit JSON
    let d_json = "{\"axis\": \"F-VIROCAPSID-1-d\"" +
        ", \"n\": " + str(n) +
        ", \"fields_audited\": " + fields_json +
        ", \"load_bearing_fields\": " + lb_json +
        ", \"per_field\": " + pf_json +
        ", \"mean_ratio\": " + js(mean_ratio) +
        ", \"min_ratio\": " + js(min_ratio) +
        ", \"criteria\": {" +
            "\"D1_every_field_ratio_ge_0.95\": " + jsb(d1) +
            ", \"D2_mean_ratio_ge_0.97\": " + jsb(d2) +
            ", \"D3_load_bearing_fields_full\": " + jsb(d3) +
        "}, \"pass_count\": " + str(d_pass_count) +
        ", \"total\": 3" +
        ", \"verdict\": \"" + d_verdict + "\"}"

    // strat1 JSON
    let strat1_json = "{\"name\": \"canonical_vs_pseudo_T\"" +
        ", \"axis_description\": \"curator-uncertainty proxy: canonical T (e.g. '3', '7l') vs pseudo-T (e.g. 'pT3', 'pT25')\"" +
        ", \"strata\": {" +
            "\"canonical\": " + stratum_obj_json(s1_canon_n, s1_canon_match, s1_canon_all, s1_canon_lbf, s1_canon_post) +
            ", \"pseudo\": " + stratum_obj_json(s1_pseudo_n, s1_pseudo_match, s1_pseudo_all, s1_pseudo_lbf, s1_pseudo_post) +
        "}}"

    // strat2 JSON
    let strat2_json = "{\"name\": \"resolution_band\"" +
        ", \"axis_description\": \"experimental-quality proxy: high (<3.5 Å) / medium (3.5-5.0) / low (≥5.0)\"" +
        ", \"strata\": {" +
            "\"high_lt_3.5\": " + stratum_obj_json(s2_hi_n, s2_hi_n, s2_hi_all, s2_hi_lbf, s2_hi_post) +
            ", \"medium_3.5_to_5.0\": " + stratum_obj_json(s2_med_n, s2_med_n, s2_med_all, s2_med_lbf, s2_med_post) +
            ", \"low_ge_5.0\": " + stratum_obj_json(s2_lo_n, s2_lo_n, s2_lo_all, s2_lo_lbf, s2_lo_post) +
            ", \"resolution_missing\": " + stratum_obj_json(s2_miss_n, s2_miss_n, s2_miss_all, s2_miss_lbf, s2_miss_post) +
        "}}"

    // strat3 JSON — axis_description uses repr(DESIGNED_KEYWORDS)
    let strat3_json = "{\"name\": \"designed_vlp_vs_natural\"" +
        ", \"axis_description\": \"engineering-source proxy: name contains any of " + kw_repr + " → 'designed'\"" +
        ", \"strata\": {" +
            "\"designed_vlp\": " + stratum_obj_json(s3_des_n, s3_des_n, s3_des_all, s3_des_lbf, s3_des_post) +
            ", \"natural\": " + stratum_obj_json(s3_nat_n, s3_nat_n, s3_nat_all, s3_nat_lbf, s3_nat_post) +
        "}}"

    // c1_violations / c2_violations JSON arrays
    let mut c1_json = "["
    let mut ci2 = 0
    while ci2 < len(c1_fails) {
        if ci2 > 0 { c1_json = c1_json + ", " }
        c1_json = c1_json + "\"" + c1_fails[ci2] + "\""
        ci2 = ci2 + 1
    }
    c1_json = c1_json + "]"
    let mut c2_json = "["
    ci2 = 0
    while ci2 < len(c2_fails) {
        if ci2 > 0 { c2_json = c2_json + ", " }
        c2_json = c2_json + "\"" + c2_fails[ci2] + "\""
        ci2 = ci2 + 1
    }
    c2_json = c2_json + "]"

    let c_json = "{\"axis\": \"F-VIROCAPSID-1-c\"" +
        ", \"n_corpus\": " + str(n_total) +
        ", \"stratifications\": [" + strat1_json + ", " + strat2_json + ", " + strat3_json + "]" +
        ", \"c1_violations\": " + c1_json +
        ", \"c2_violations\": " + c2_json +
        ", \"nontrivial_stratifications_count\": " + str(nontrivial) +
        ", \"criteria\": {" +
            "\"C1_every_n_ge_10_stratum_vertex_match_all\": " + jsb(c1) +
            ", \"C2_every_n_ge_10_stratum_posterior_ge_0.95\": " + jsb(c2) +
            ", \"C3_ge_1_stratification_with_2_strata_n_ge_10\": " + jsb(c3) +
        "}, \"pass_count\": " + str(c_pass_count) +
        ", \"total\": 3" +
        ", \"verdict\": \"" + c_verdict + "\"}"

    let witness_json = "{\"F-VIROCAPSID-1-d\": " + d_json + ", \"F-VIROCAPSID-1-c\": " + c_json + "}"
    let wv = json_parse(witness_json)

    println("## audit witness JSON")
    println(py_json2(wv, 0))
    println("")
    if overall { println("__VIROCAPSID_F1C_F1D__ PASS") }
    else { println("__VIROCAPSID_F1C_F1D__ FAIL"); exit(1) }
}

// Print a single stratum row, matching .py:
//   "      - {name:>22s}: n={bf['n']:>3d} match={bf['matches']:>3d} "
//   "log10_BF={log10_bf_str:>8s} posterior={bf['posterior_h1']:.6f}  {tag}"
//
// log10_bf_str: "-inf" if -inf else f"{log10_bf:.2f}"
// tag: "(n<10, not graded)" if n<10 else "GRADED"
fn print_stratum_row(name: string, sn: int, matches: int, lbf: float, post: float, match_all: bool) {
    let log10_str = if match_all == false { "-inf" } else { fmt("%.2f", lbf) }
    let tag = if sn < 10 { "(n<10, not graded)" } else { "GRADED" }
    println("      - " + rjust(name, 22) + ": n=" + rjust(str(sn), 3) +
            " match=" + rjust(str(matches), 3) +
            " log10_BF=" + rjust(log10_str, 8) +
            " posterior=" + fmt("%.6f", post) + "  " + tag)
}

// Python list repr `['a', 'b', 'c']` for a string array.
fn list_repr_strs(a: array) -> string {
    let mut o = "["
    let mut i = 0
    while i < len(a) {
        if i > 0 { o = o + ", " }
        o = o + "'" + a[i] + "'"
        i = i + 1
    }
    return o + "]"
}
