#!hexa strict
// hexa-bio/_hexa_bridge/selftest/capsid_assembly_modulator_sim.hexa
//
// hexa-native port of `_python_bridge/module/capsid_assembly_modulator_sim.py`
// (T3; math/json/sys — deterministic, no network/time/random). CAPSID-
// ASSEMBLY-MODULATOR sub-axis: Caspar-Klug exact geometry + Zlotnick
// mean-field assembly equilibrium. Sim-recipe: hexa exp()/log() (glibc
// libm, bit-exact vs CPython math), full-precision feed via
// json_stringify (CPython repr-parity runtime), %e/%f/%+f formatting
// via `exec printf` (C printf == Python format spec, byte-identical).

let R_KCAL = 1.987204e-3
let T_KELVIN = 310.0
let RT = 1.987204e-3 * 310.0
let WEAK_CONTACT_LO = -4.5
let WEAK_CONTACT_HI = -1.5
let KINETIC_TRAP_THRESHOLD = -5.0

fn pybool(b: bool) -> string { if b { return "True" } return "False" }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }

// Python format spec via C printf (byte-identical rounding)
fn fmt(spec: string, v: float) -> string {
    return exec("printf '" + spec + "' " + json_stringify(v)).trim()
}

// x ** e for x > 0 (== CPython float ** via libm; 4-digit output is
// tolerant to sub-ULP differences anyway). NOT named pow/powf/expf —
// those collide with C math.h builtins in the generated C (discipline).
fn xpow(x: float, e: float) -> float { return exp(e * log(x)) }

// Caspar-Klug exact geometry → (n_subunits, euler_ok)
fn ck_n_subunits(t: int) -> int { return 60 * t }
fn ck_euler_ok(t: int) -> bool {
    let n_pent = 12
    let n_hex = 10 * (t - 1)
    let n_caps = n_pent + n_hex
    let edges = (5 * n_pent + 6 * n_hex) / 2
    let faces = n_caps
    let vertices = 2 - faces + edges
    return (vertices - edges + faces) == 2
}

// Zlotnick mean-field per-subunit equilibrium
fn dg_net(g_contact: float) -> float { return (3.0 / 2.0) * g_contact + 3.0 }
fn c_star_of(g_contact: float) -> float { return exp(dg_net(g_contact) / RT) }
fn k_assembly_of(g_contact: float) -> float { return exp(-dg_net(g_contact) / RT) }

fn assembled_fraction(c_total: float, c_star: float) -> float {
    if c_total <= 0.0 { return 0.0 }
    let ratio = xpow(c_total / c_star, 12.0)
    return ratio / (1.0 + ratio)
}

fn main() {
    // panel: (scenario, delta_dg); baseline g_contact = -3.0, c_total 0.05
    let names = ["no_modulator", "mild_stabilizer", "strong_over_stabilizer", "destabilizer"]
    let ddgs = [0.0, -1.0, -3.0, 1.5]
    let g_base = -3.0
    let c_total = 0.05
    let base_cstar = c_star_of(g_base)
    let f_base = assembled_fraction(c_total, base_cstar)

    // per-scenario derived
    let mut g_cam: array = []
    let mut cam_cstar: array = []
    let mut cam_f: array = []
    let mut shift: array = []
    let mut trap: array = []
    let mut i = 0
    while i < 4 {
        let gc = g_base + ddgs[i]
        let cs = c_star_of(gc)
        let fc = assembled_fraction(c_total, cs)
        g_cam.push(gc)
        cam_cstar.push(cs)
        cam_f.push(fc)
        shift.push(fc - f_base)
        trap.push(gc <= KINETIC_TRAP_THRESHOLD)
        i = i + 1
    }

    // ── checks (real computation, deterministic) ──
    let mut labels: array = []
    let mut oks: array = []

    // C1 Caspar-Klug exact for T in {1,3,4}
    let mut geom_ok = true
    let ts = [1, 3, 4]
    let mut ti = 0
    while ti < 3 {
        let t = ts[ti]
        if ck_n_subunits(t) != 60 * t || !ck_euler_ok(t) { geom_ok = false }
        ti = ti + 1
    }
    labels.push("C1 Caspar-Klug geometry exact (60*T subunits; Euler V-E+F=2)"); oks.push(geom_ok)

    // C2 baseline g in weak-contact band
    labels.push("C2 baseline g_contact in Zlotnick weak-contact band [-4.5,-1.5]")
    oks.push(WEAK_CONTACT_LO <= g_base && g_base <= WEAK_CONTACT_HI)

    // C3 dG<->K round-trip < 1e-9
    let kasm = k_assembly_of(g_base)
    let dg_back = -RT * log(kasm)
    let dgn = dg_net(g_base)
    let mut diff = dg_back - dgn
    if diff < 0.0 { diff = -diff }
    labels.push("C3 dG<->K round-trip self-consistent (<1e-9)"); oks.push(diff < 1e-9)

    // C4 stabilizer lowers c_star + raises assembled fraction
    labels.push("C4 stabilizer lowers c_star + raises assembled fraction")
    oks.push(cam_cstar[1] < base_cstar && shift[1] > 0.0)

    // C5 over-stabilizer trap; mild/none off
    labels.push("C5 over-stabilizer => Zlotnick kinetic-trap flag; mild stays off")
    oks.push(trap[2] && !trap[1] && !trap[0])

    // C6 fraction in [0,1], monotone, f=0.5 at c=c_star
    let cs6 = c_star_of(g_base)
    let f0 = assembled_fraction(0.2 * cs6, cs6)
    let f1 = assembled_fraction(cs6, cs6)
    let f2 = assembled_fraction(5.0 * cs6, cs6)
    let mut d1 = f1 - 0.5
    if d1 < 0.0 { d1 = -d1 }
    let c6 = (f0 >= 0.0 && f0 <= 1.0 && f1 >= 0.0 && f1 <= 1.0 && f2 >= 0.0 && f2 <= 1.0)
             && (f0 < f1 && f1 < f2) && (d1 < 1e-9)
    labels.push("C6 assembled fraction in [0,1], monotone, f=0.5 at c=c_star"); oks.push(c6)

    // C7 determinism — recompute panel, compare
    let mut det = true
    let mut di = 0
    while di < 4 {
        let gc = g_base + ddgs[di]
        if c_star_of(gc) != cam_cstar[di] { det = false }
        di = di + 1
    }
    labels.push("C7 determinism — byte-identical re-run"); oks.push(det)

    println("capsid_assembly_modulator_sim — CAPSID-ASSEMBLY-MODULATOR sub-axis (:> VIROCAPSID)")
    println("")
    let mut ci = 0
    while ci < len(labels) {
        println("  [" + (if oks[ci] { "PASS" } else { "FAIL" }) + "] " + labels[ci])
        ci = ci + 1
    }
    println("")
    let mut ri = 0
    while ri < 4 {
        println("  " + rjust(names[ri], 22) + "  g_contact=" + fmt("%+.2f", g_cam[ri]) +
                " kcal/mol  c*=" + fmt("%.4e", cam_cstar[ri]) +
                "  f=" + fmt("%.4f", cam_f[ri]) +
                "  Δf=" + fmt("%+.4f", shift[ri]) +
                "  trap=" + pybool(trap[ri]))
        ri = ri + 1
    }
    let mut n_pass = 0
    let mut pi = 0
    while pi < len(oks) { if oks[pi] { n_pass = n_pass + 1 }; pi = pi + 1 }
    let n_total = len(oks)
    println("")
    println("  --- summary --- " + str(n_pass) + "/" + str(n_total) + " PASS → verdict: " +
            (if n_pass == n_total { "PASS" } else { "FAIL" }) + " ---")
    println("  [honesty] in-silico simulator-consistency only — Caspar-Klug geometry +")
    println("  Zlotnick mean-field equilibrium. NOT a wet-lab / structural / binding /")
    println("  therapeutic / clinical / regulatory claim (g8/f2). Sub-axis :> VIROCAPSID;")
    println("  core-5 axis set UNCHANGED. No n=6-lattice derivation (g2/f_lattice_fit).")
    if n_pass == n_total {
        println("")
        println("__CAPSID_ASSEMBLY_MODULATOR__ PASS")
        return
    }
    println("")
    println("__CAPSID_ASSEMBLY_MODULATOR__ FAIL")
    exit(1)
}
