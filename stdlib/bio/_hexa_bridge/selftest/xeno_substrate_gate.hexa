#!hexa strict
// hexa-bio/_hexa_bridge/selftest/xeno_substrate_gate.hexa
//
// hexa-native port of `selftest/xeno_substrate_gate.sh`. CLI-direct
// delegation gate to xeno (exotic compute substrate orchestrator).
// Mirrors the .sh's PASS / SKIP / FAIL classification byte-for-byte.
// genuine 0-python3 — bash gate → hexa-native.

fn shq(s: string) -> string {
    let mut o = "'"
    let mut i = 0
    while i < len(s) {
        let c = s.substr(i, 1)
        if c == "'" { o = o + "'\\''" } else { o = o + c }
        i = i + 1
    }
    return o + "'"
}

fn tail_lines(s: string, n: int) -> string {
    let mut o = exec("printf '%s' " + shq(s) + " | tail -" + str(n))
    while len(o) > 0 && o.substr(len(o) - 1, 1) == "\n" { o = o.substr(0, len(o) - 1) }
    return o
}

fn main() {
    let SENTINEL_PASS = "__XENO_SUBSTRATE__ PASS"
    let SENTINEL_SKIP = "__XENO_SUBSTRATE__ SKIP"
    let SENTINEL_FAIL = "__XENO_SUBSTRATE__ FAIL"

    let home = exec("printf '%s' \"$HOME\"").trim()
    let xeno_root_env = exec("printf '%s' \"${XENO_ROOT:-}\"").trim()
    let mut xeno_root = xeno_root_env
    if len(xeno_root) == 0 { xeno_root = home + "/core/xeno" }
    let xeno_bin_env = exec("printf '%s' \"${XENO_BIN:-}\"").trim()
    let mut xeno_bin = xeno_bin_env
    if len(xeno_bin) == 0 { xeno_bin = xeno_root + "/bin/xeno" }

    println("xeno_substrate_gate — CLI-direct delegation to xeno orchestrator")
    println("  xeno root: " + xeno_root)
    println("  xeno bin:  " + xeno_bin)

    // (1) presence check
    let exec_check = exec("test -x " + shq(xeno_bin) + " && printf yes || printf no").trim()
    if exec_check != "yes" {
        println("")
        println("  SKIP: xeno CLI not found / not executable at " + xeno_bin)
        println("        Install via 'hx install xeno' or clone https://github.com/dancinlab/xeno")
        println("        to " + xeno_root + ". This is a sister-repo CLI integration — not a")
        println("        hexa-bio regression; the exotic-compute layer simply isn't wired")
        println("        on this host.")
        println(SENTINEL_SKIP)
        return
    }

    // (2) invoke xeno status with bounded timeout
    println("")
    println("  invoking: " + xeno_bin + " status")
    let tmp = exec("mktemp").trim()
    let rc_str = exec("timeout 30 " + shq(xeno_bin) + " status > " + shq(tmp) + " 2>&1; printf '%d' \"$?\"").trim()
    let OUT = exec("cat " + shq(tmp))
    exec("rm -f " + shq(tmp))
    let mut RC = -1
    if len(rc_str) > 0 { RC = int(rc_str) }

    // (3) classify result
    if RC == 0 {
        println(tail_lines(OUT, 15))
        println("")
        println("  xeno status: exit 0 (reachable + healthy)")
        println(SENTINEL_PASS)
        return
    }
    if RC == 91 {
        println(tail_lines(OUT, 8))
        println("")
        println("  SKIP: xeno status returned 91 (raw_91 honest C3 fail-loud — connection")
        println("        to a sister repo failed). NOT a hexa-bio regression. Check xeno")
        println("        sister-repo bridges (anima/nexus/hive/hexa-brain reachability).")
        println(SENTINEL_SKIP)
        return
    }
    if RC == 124 {
        println(tail_lines(OUT, 5))
        println("")
        println("  SKIP: xeno status timed out at 30s")
        println(SENTINEL_SKIP)
        return
    }
    println(tail_lines(OUT, 15))
    println("")
    println("  xeno status: exit " + str(RC) + " (real regression)")
    println(SENTINEL_FAIL)
    exit(1)
}
