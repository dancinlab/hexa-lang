#!hexa strict
// hexa-bio/_hexa_bridge/selftest/metallodrug_coordination_sim.hexa
//
// hexa-native port of `_python_bridge/module/metallodrug_coordination_sim.py`
// (T3; json/math/sys — deterministic). METALLODRUG axis (EXPANSION-MAIN, NOT
// core-5). Crystal-field stabilization energy table d0..d10 (octahedral
// HS/LS + square-planar) + square-planar Pt(II) geometry check against the
// cited cisplatin Pt-N7(guanine) ~2.0 Å coordinate-bond anchor (Takahara
// 1995). Float fields computed with the exact .py arithmetic → CPython-
// identical IEEE doubles; hexa sqrt() bit-exact vs CPython libm; witness
// JSON via py_json2 (CPython json.dumps(indent=2, ensure_ascii=False)
// parity); human panel via the sim-recipe (exec printf precision formats +
// json_stringify feed).

import "_hexa_bridge/module/py_json2.hexa"

// ── module identity ──
let VERSION = "1.0.0"
let AXIS = "METALLODRUG"
let AXIS_LAYER = "expansion-main (NOT core-5)"

// ── real-limit anchors (literature) ──
let PT_N7_BOND_ANGSTROM = 2.0
let PT_N7_TOLERANCE_ANGSTROM = 0.15
let GRIFFITH_ORGEL_1957 = "Griffith & Orgel, Q Rev Chem Soc 1957;11:381-393"
let TAKAHARA_1995 = "Takahara et al., Nature 1995;377:649-652"

// ── d-orbital geometry ──
let N_T2G_ORBITALS = 3
let N_EG_ORBITALS = 2
let CFSE_T2G_PER_ELECTRON = -0.4
let CFSE_EG_PER_ELECTRON = 0.6

fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i]-c; let t = s+y; c = (t-s)-y; s = t; i = i+1 }
    return s
}
fn dmax(x: float, y: float) -> float { if x > y { return x } return y }
fn imin(a: int, b: int) -> int { if a < b { return a } return b }
fn imax(a: int, b: int) -> int { if a > b { return a } return b }

// ── occupancy: returns [n_t2g, n_eg, n_unpaired] for d^n with low_spin flag ──
fn unpaired_in_set(electrons: int, n_orbitals: int) -> int {
    if electrons <= n_orbitals { return electrons }
    return 2 * n_orbitals - electrons
}

fn octahedral_occupancy(d_count: int, low_spin: bool) -> array {
    let mut n_t2g = 0
    let mut n_eg = 0
    if low_spin {
        n_t2g = imin(d_count, 6)
        n_eg = imax(0, d_count - 6)
    } else {
        let singles = imin(d_count, 5)
        let pairs = imax(0, d_count - 5)
        n_t2g = imin(singles, 3) + imin(pairs, 3)
        n_eg = imax(0, singles - 3) + imax(0, pairs - 3)
    }
    let mut n_unpaired = 0
    if low_spin {
        n_unpaired = unpaired_in_set(imin(d_count, 6), 3) + unpaired_in_set(imax(0, d_count - 6), 2)
    } else {
        n_unpaired = unpaired_in_set(d_count, 5)
    }
    return [n_t2g, n_eg, n_unpaired]
}

// ── CFSE (units of Δ_oct) ──
fn cfse_octahedral(d_count: int, low_spin: bool) -> float {
    let occ = octahedral_occupancy(d_count, low_spin)
    return CFSE_T2G_PER_ELECTRON * occ[0] + CFSE_EG_PER_ELECTRON * occ[1]
}

fn cfse_square_planar(d_count: int) -> float {
    let levels = [-0.514, -0.514, -0.428, 0.228, 1.228]
    let mut energy = 0.0
    let mut remaining = d_count
    let mut i = 0
    while i < len(levels) {
        let mut take = remaining
        if take > 2 { take = 2 }
        energy = energy + take * levels[i]
        remaining = remaining - take
        if remaining == 0 { break }
        i = i + 1
    }
    return energy
}

// ── reference table (Griffith & Orgel 1957) ──
fn ref_hs(d: int) -> float {
    if d == 0 { return 0.0 }
    if d == 1 { return -0.4 }
    if d == 2 { return -0.8 }
    if d == 3 { return -1.2 }
    if d == 4 { return -0.6 }
    if d == 5 { return 0.0 }
    if d == 6 { return -0.4 }
    if d == 7 { return -0.8 }
    if d == 8 { return -1.2 }
    if d == 9 { return -0.6 }
    return 0.0
}
fn ref_ls(d: int) -> float {
    if d == 0 { return 0.0 }
    if d == 1 { return -0.4 }
    if d == 2 { return -0.8 }
    if d == 3 { return -1.2 }
    if d == 4 { return -1.6 }
    if d == 5 { return -2.0 }
    if d == 6 { return -2.4 }
    if d == 7 { return -1.8 }
    if d == 8 { return -1.2 }
    if d == 9 { return -0.6 }
    return 0.0
}

fn main() {
    // build cfse_table rows
    let mut rows_d: array = []
    let mut rows_hs_nt: array = []
    let mut rows_hs_ne: array = []
    let mut rows_hs_unp: array = []
    let mut rows_hs_cfse: array = []
    let mut rows_ls_nt: array = []
    let mut rows_ls_ne: array = []
    let mut rows_ls_unp: array = []
    let mut rows_ls_cfse: array = []
    let mut rows_sp_cfse: array = []
    let mut d = 0
    while d <= 10 {
        let hs = cfse_octahedral(d, false)
        let ls = cfse_octahedral(d, true)
        let sp = cfse_square_planar(d)
        let occ_hs = octahedral_occupancy(d, false)
        let occ_ls = octahedral_occupancy(d, true)
        rows_d.push(d)
        rows_hs_nt.push(occ_hs[0]); rows_hs_ne.push(occ_hs[1]); rows_hs_unp.push(occ_hs[2]); rows_hs_cfse.push(hs)
        rows_ls_nt.push(occ_ls[0]); rows_ls_ne.push(occ_ls[1]); rows_ls_unp.push(occ_ls[2]); rows_ls_cfse.push(ls)
        rows_sp_cfse.push(sp)
        d = d + 1
    }

    // verify_cfse_table
    let mut max_dev_hs = 0.0
    let mut max_dev_ls = 0.0
    let mut mismatches: array = []
    let mut i = 0
    while i < len(rows_d) {
        let dd = rows_d[i]
        let hs = rows_hs_cfse[i]
        let ls = rows_ls_cfse[i]
        let dev_hs = fabs(hs - ref_hs(dd))
        let dev_ls = fabs(ls - ref_ls(dd))
        max_dev_hs = dmax(max_dev_hs, dev_hs)
        max_dev_ls = dmax(max_dev_ls, dev_ls)
        if dev_hs > 1.0e-9 { mismatches.push("d" + str(dd) + " oct-HS: got " + js(hs) + ", ref " + js(ref_hs(dd))) }
        if dev_ls > 1.0e-9 { mismatches.push("d" + str(dd) + " oct-LS: got " + js(ls) + ", ref " + js(ref_ls(dd))) }
        i = i + 1
    }
    let cfse_pass = (len(mismatches) == 0)

    // square_planar_geometry(PT_N7_BOND_ANGSTROM)
    let L = PT_N7_BOND_ANGSTROM
    // positions: (L,0), (0,L), (-L,0), (0,-L)
    // dist(0,0 → p) = hypot(px, py) -- math.hypot positive
    let d0 = sqrt(L*L + 0.0*0.0)
    let d1 = sqrt(0.0*0.0 + L*L)
    let d2 = sqrt(L*L + 0.0*0.0)
    let d3 = sqrt(0.0*0.0 + L*L)
    let pt_lig_dists = [d0, d1, d2, d3]
    let pt_lig_distance_recomputed = d0
    // cis = dist(p0, p1) = hypot(L-0, 0-L) = sqrt(2*L*L) = L*sqrt(2)
    let cis_sep = sqrt((L - 0.0)*(L - 0.0) + (0.0 - L)*(0.0 - L))
    // trans = dist(p0, p2) = hypot(L-(-L), 0-0) = 2L
    let trans_sep = sqrt((L - (-L))*(L - (-L)) + (0.0 - 0.0)*(0.0 - 0.0))
    let cis_angle_deg = 90.0
    let trans_angle_deg = 180.0
    let cis_closed = L * sqrt(2.0)
    let trans_closed = 2.0 * L

    // verify_pt_n7_geometry
    let recomputed = pt_lig_distance_recomputed
    let deviation = fabs(recomputed - PT_N7_BOND_ANGSTROM)
    let cis_ok = fabs(cis_sep - cis_closed) < 1.0e-9
    let trans_ok = fabs(trans_sep - trans_closed) < 1.0e-9
    let angle_ok = (fabs(cis_angle_deg - 90.0) < 1.0e-9) && (fabs(trans_angle_deg - 180.0) < 1.0e-9)
    let anchor_ok = deviation <= PT_N7_TOLERANCE_ANGSTROM
    let geom_self_consistent = cis_ok && trans_ok && angle_ok
    let geom_pass = anchor_ok && cis_ok && trans_ok && angle_ok

    // metallodrug metadata
    let md_name = ["cisplatin", "carboplatin", "oxaliplatin", "auranofin", "arsenic trioxide"]
    let md_metal = ["Pt", "Pt", "Pt", "Au", "As"]
    let md_ox = [2, 2, 2, 1, 3]
    // d_count: int or null; arsenic trioxide → null
    let md_d_has = [true, true, true, true, false]
    let md_d_val = [8, 8, 8, 10, 0]
    let md_geom = ["square-planar", "square-planar", "square-planar", "linear", "trigonal pyramidal"]
    let md_fda = [1978, 1989, 2002, 1985, 2000]
    let md_ind = ["broad solid tumors", "ovarian / lung carcinoma", "colorectal carcinoma",
                  "rheumatoid arthritis", "acute promyelocytic leukemia"]

    // F-METALLODRUG-3: every square-planar drug has d_count == 8
    let mut f3 = true
    let mut k = 0
    while k < len(md_name) {
        if md_geom[k] == "square-planar" {
            if !md_d_has[k] || md_d_val[k] != 8 { f3 = false }
        }
        k = k + 1
    }

    let f1 = cfse_pass
    let f2 = anchor_ok

    // acceptance criteria
    let c1 = cfse_pass
    let c2 = fabs(rows_hs_cfse[5]) < 1.0e-9
    let c3 = fabs(rows_ls_cfse[6] - (-2.4)) < 1.0e-9
    let c4 = fabs(rows_hs_cfse[3] - (-1.2)) < 1.0e-9
    let c5 = geom_self_consistent
    let c6 = anchor_ok
    let c7 = f1 && f2 && f3

    let mut n_pass = 0
    if c1 { n_pass = n_pass + 1 }
    if c2 { n_pass = n_pass + 1 }
    if c3 { n_pass = n_pass + 1 }
    if c4 { n_pass = n_pass + 1 }
    if c5 { n_pass = n_pass + 1 }
    if c6 { n_pass = n_pass + 1 }
    if c7 { n_pass = n_pass + 1 }
    let total = 7
    let verdict = if n_pass == total { "PASS" } else { "FAIL" }

    // ─── human panel ───
    println("metallodrug_coordination_sim — METALLODRUG axis (EXPANSION-MAIN, NOT core-5) v" + VERSION)
    println("")
    println("  (A) Crystal-field stabilization energy (CFSE), units of Delta_oct")
    println("      ligand-field theory closed form -- Griffith & Orgel 1957")
    println("      d^n  | oct HS  | oct LS  | square-planar")
    let mut r = 0
    while r < len(rows_d) {
        let dd = rows_d[r]
        let dstr = ljust(str(dd), 2)
        println("      d" + dstr + "  | " + fmt("%+6.3f", rows_hs_cfse[r]) +
                "  | " + fmt("%+6.3f", rows_ls_cfse[r]) +
                "  | " + fmt("%+7.3f", rows_sp_cfse[r]))
        r = r + 1
    }
    println("      CFSE table vs closed form: max dev HS = " + fmt("%.2e", max_dev_hs) +
            ", LS = " + fmt("%.2e", max_dev_ls) + "  (tol " + fmt("%.0e", 1.0e-9) + ")")
    println("")
    println("  (B) Square-planar Pt(II) geometry vs cisplatin Pt-N7(guanine) anchor")
    println("      real limit: Pt-N7 coordinate bond ~" + js(PT_N7_BOND_ANGSTROM) + " A  (" + TAKAHARA_1995 + ")")
    println("      recomputed Pt-N radial distance = " + fmt("%.4f", recomputed) + " A  " +
            "(deviation " + fmt("%.2e", deviation) + " A, tol " + js(PT_N7_TOLERANCE_ANGSTROM) + " A)")
    println("      cis ligand-ligand separation  = " + fmt("%.4f", cis_sep) + " A  " +
            "(closed form L*sqrt2 = " + fmt("%.4f", cis_closed) + " A)")
    println("      trans ligand-ligand separation = " + fmt("%.4f", trans_sep) + " A  " +
            "(closed form 2L = " + fmt("%.4f", trans_closed) + " A)")
    println("      cis L-Pt-L angle = " + fmt("%.1f", cis_angle_deg) + " deg, trans = " + fmt("%.1f", trans_angle_deg) + " deg")
    println("")
    println("  falsifiers:")
    let f1_tag = if f1 { "HOLD" } else { "FALSIFIED" }
    let f2_tag = if f2 { "HOLD" } else { "FALSIFIED" }
    let f3_tag = if f3 { "HOLD" } else { "FALSIFIED" }
    println("    [" + f1_tag + "] F-METALLODRUG-1_cfse_recompute_fidelity")
    println("    [" + f2_tag + "] F-METALLODRUG-2_pt_n7_bond_anchor")
    println("    [" + f3_tag + "] F-METALLODRUG-3_square_planar_is_d8")
    println("")
    println("  acceptance criteria:")
    let c1_tag = if c1 { "PASS" } else { "FAIL" }
    let c2_tag = if c2 { "PASS" } else { "FAIL" }
    let c3_tag = if c3 { "PASS" } else { "FAIL" }
    let c4_tag = if c4 { "PASS" } else { "FAIL" }
    let c5_tag = if c5 { "PASS" } else { "FAIL" }
    let c6_tag = if c6 { "PASS" } else { "FAIL" }
    let c7_tag = if c7 { "PASS" } else { "FAIL" }
    println("    [" + c1_tag + "] C1_cfse_table_matches_ligand_field_theory")
    println("    [" + c2_tag + "] C2_octahedral_hs_d5_cfse_zero")
    println("    [" + c3_tag + "] C3_octahedral_ls_d6_cfse_minus_2p4")
    println("    [" + c4_tag + "] C4_octahedral_hs_d3_cfse_minus_1p2")
    println("    [" + c5_tag + "] C5_square_planar_geometry_self_consistent")
    println("    [" + c6_tag + "] C6_pt_n7_bond_matches_2p0_angstrom_anchor")
    println("    [" + c7_tag + "] C7_all_falsifiers_hold")
    println("")
    println("  --- METALLODRUG coordination: " + str(n_pass) + "/" + str(total) + "  ->  verdict: " + verdict + " ---")
    println("")
    let lattice_stance = "No n=6 lattice arithmetic is performed. Octahedral 6-coordination and square-planar 4-coordination are coordination-chemistry geometries (octahedron vertices / d8 strong-field), NOT lattice derivations. Numerical coincidence with n=6 is OBSERVATION ONLY (HEXA-METALLODRUG.tape f_lattice_fit / n6_honest_stance)."
    let in_silico_scope = "PASS verifies IN-SILICO simulator+metadata consistency ONLY -- CFSE arithmetic vs ligand-field theory and square-planar geometry vs the cited Pt-N7 bond length. NOT a therapeutic/cytotoxic/antitumor/regulatory claim. The METALLODRUG axis is UNPROVEN at the wet-lab boundary (AGENTS.tape g8_in_silico_only / f2)."
    println("  n=6 lattice stance: " + lattice_stance)
    println("")
    println("  IN-SILICO SCOPE (g8/f2): " + in_silico_scope)

    // ─── witness JSON: compact-build → json_parse → py_json2 ───

    // cfse_table rows
    let mut rows_j = ""
    let mut rj = 0
    while rj < len(rows_d) {
        if rj > 0 { rows_j = rows_j + ", " }
        let dd = rows_d[rj]
        rows_j = rows_j + "{\"d_count\": " + str(dd) +
                 ", \"oct_high_spin\": {\"n_t2g\": " + str(rows_hs_nt[rj]) +
                 ", \"n_eg\": " + str(rows_hs_ne[rj]) +
                 ", \"n_unpaired\": " + str(rows_hs_unp[rj]) +
                 ", \"cfse_delta_oct\": " + js(rows_hs_cfse[rj]) + "}" +
                 ", \"oct_low_spin\": {\"n_t2g\": " + str(rows_ls_nt[rj]) +
                 ", \"n_eg\": " + str(rows_ls_ne[rj]) +
                 ", \"n_unpaired\": " + str(rows_ls_unp[rj]) +
                 ", \"cfse_delta_oct\": " + js(rows_ls_cfse[rj]) + "}" +
                 ", \"square_planar\": {\"cfse_delta_oct\": " + js(rows_sp_cfse[rj]) + "}}"
        rj = rj + 1
    }

    // cfse_verification (mismatches always empty here)
    let mut mismatches_j = ""
    let mut mi = 0
    while mi < len(mismatches) {
        if mi > 0 { mismatches_j = mismatches_j + ", " }
        // escape — none of our mismatch strings contain quotes or backslashes
        mismatches_j = mismatches_j + "\"" + mismatches[mi] + "\""
        mi = mi + 1
    }
    let cfse_ver_j = "{\"max_deviation_high_spin\": " + js(max_dev_hs) +
                     ", \"max_deviation_low_spin\": " + js(max_dev_ls) +
                     ", \"tolerance\": " + js(1.0e-9) +
                     ", \"mismatches\": [" + mismatches_j + "]" +
                     ", \"pass\": " + jsb(cfse_pass) + "}"

    // square_planar_geometry block
    let sp_geom_j = "{\"bond_length_angstrom\": " + js(PT_N7_BOND_ANGSTROM) +
                    ", \"pt_ligand_distances_angstrom\": [" + js(pt_lig_dists[0]) + ", " + js(pt_lig_dists[1]) + ", " + js(pt_lig_dists[2]) + ", " + js(pt_lig_dists[3]) + "]" +
                    ", \"pt_ligand_distance_recomputed\": " + js(pt_lig_distance_recomputed) +
                    ", \"cis_ligand_separation_angstrom\": " + js(cis_sep) +
                    ", \"trans_ligand_separation_angstrom\": " + js(trans_sep) +
                    ", \"cis_L_Pt_L_angle_deg\": " + js(cis_angle_deg) +
                    ", \"trans_L_Pt_L_angle_deg\": " + js(trans_angle_deg) +
                    ", \"cis_sep_closed_form\": " + js(cis_closed) +
                    ", \"trans_sep_closed_form\": " + js(trans_closed) + "}"

    // pt_n7_geometry_verification
    let geom_ver_j = "{\"real_limit_anchor\": \"cisplatin Pt-N7(guanine) coordinate bond\"" +
                     ", \"anchor_value_angstrom\": " + js(PT_N7_BOND_ANGSTROM) +
                     ", \"anchor_tolerance_angstrom\": " + js(PT_N7_TOLERANCE_ANGSTROM) +
                     ", \"recomputed_pt_n_angstrom\": " + js(recomputed) +
                     ", \"deviation_angstrom\": " + js(deviation) +
                     ", \"anchor_match\": " + jsb(anchor_ok) +
                     ", \"square_geometry_self_consistent\": " + jsb(geom_self_consistent) +
                     ", \"citation\": \"" + TAKAHARA_1995 + "\"" +
                     ", \"pass\": " + jsb(geom_pass) + "}"

    // metallodrug_metadata array
    let mut md_j = ""
    let mut mj = 0
    while mj < len(md_name) {
        if mj > 0 { md_j = md_j + ", " }
        let dval = if md_d_has[mj] { str(md_d_val[mj]) } else { "null" }
        md_j = md_j + "{\"name\": \"" + md_name[mj] + "\"" +
               ", \"metal\": \"" + md_metal[mj] + "\"" +
               ", \"oxidation_state\": " + str(md_ox[mj]) +
               ", \"d_count\": " + dval +
               ", \"geometry\": \"" + md_geom[mj] + "\"" +
               ", \"fda_year\": " + str(md_fda[mj]) +
               ", \"indication\": \"" + md_ind[mj] + "\"}"
        mj = mj + 1
    }

    let falsifiers_j = "{\"F-METALLODRUG-1_cfse_recompute_fidelity\": " + jsb(f1) +
                       ", \"F-METALLODRUG-2_pt_n7_bond_anchor\": " + jsb(f2) +
                       ", \"F-METALLODRUG-3_square_planar_is_d8\": " + jsb(f3) + "}"

    let crit_j = "{\"C1_cfse_table_matches_ligand_field_theory\": " + jsb(c1) +
                 ", \"C2_octahedral_hs_d5_cfse_zero\": " + jsb(c2) +
                 ", \"C3_octahedral_ls_d6_cfse_minus_2p4\": " + jsb(c3) +
                 ", \"C4_octahedral_hs_d3_cfse_minus_1p2\": " + jsb(c4) +
                 ", \"C5_square_planar_geometry_self_consistent\": " + jsb(c5) +
                 ", \"C6_pt_n7_bond_matches_2p0_angstrom_anchor\": " + jsb(c6) +
                 ", \"C7_all_falsifiers_hold\": " + jsb(c7) + "}"

    let anchors_j = "{\"pt_n7_bond_length_angstrom\": " + js(PT_N7_BOND_ANGSTROM) +
                    ", \"pt_n7_citation\": \"" + TAKAHARA_1995 + "\"" +
                    ", \"cfse_closed_form_citation\": \"" + GRIFFITH_ORGEL_1957 + "\"}"

    let witness = "{\"schema\": \"metallodrug_coordination_v1\"" +
                  ", \"ts\": \"2026-05-16T00:00:00Z\"" +
                  ", \"axis\": \"" + AXIS + "\"" +
                  ", \"axis_layer\": \"" + AXIS_LAYER + "\"" +
                  ", \"version\": \"" + VERSION + "\"" +
                  ", \"real_limit_anchors\": " + anchors_j +
                  ", \"cfse_table\": [" + rows_j + "]" +
                  ", \"cfse_verification\": " + cfse_ver_j +
                  ", \"square_planar_geometry\": " + sp_geom_j +
                  ", \"pt_n7_geometry_verification\": " + geom_ver_j +
                  ", \"metallodrug_metadata\": [" + md_j + "]" +
                  ", \"falsifiers\": " + falsifiers_j +
                  ", \"acceptance_criteria\": " + crit_j +
                  ", \"pass_count\": " + str(n_pass) +
                  ", \"total_criteria\": " + str(total) +
                  ", \"verdict\": \"" + verdict + "\"" +
                  ", \"lattice_stance\": \"" + lattice_stance + "\"" +
                  ", \"in_silico_scope\": \"" + in_silico_scope + "\"}"

    let wv = json_parse(witness)
    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))

    let ok = verdict == "PASS"
    if ok {
        println("")
        println("__METALLODRUG_COORDINATION__ PASS")
    } else {
        println("")
        println("__METALLODRUG_COORDINATION__ FAIL")
    }
}
