#!hexa strict
// hexa-bio/_hexa_bridge/selftest/ribozyme_off_target_screen.hexa
//
// hexa-native port of `_python_bridge/module/ribozyme_off_target_screen.py`
// (T3; json/os/sys — deterministic, no network/time/random). G26-RB-3
// component (3): Hamming sliding-window off-target screen for ribozyme
// substrate-recognition arms against a representative pool (toy 6-mRNA
// + (CUG)ₙ low-complexity decoy + vendored GENCODE v47 pc-transcript
// subset n=200), plus the vendored RIsearch2 v2.1 full-transcriptome
// summary replay. Sliding-window scan logic mirrors the parent
// `oligonucleotide_hybridization_sim.hexa`; runtime json_parse of the
// vendored snapshot + summary follows the `ribozyme_a1_2_offtarget_
// threshold_replay.hexa` precedent. shq() imported from json_schema_
// validator (discipline #1: no local dup). exec printf for the %.2f/.3f
// numeric format spec (C printf == Python format, byte-identical).

import "_hexa_bridge/module/py_json2.hexa"
import "_hexa_bridge/module/json_schema_validator.hexa"

let MAX_PER_KB_GATE = 4.0
let SEED_TOL = 1

// ── standard helpers (Kahan fsum, fmt via exec printf, etc.) ─────────
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ifmt(spec: string, v: int) -> string {
    let mut o = exec("printf '" + spec + "' " + str(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
// codepoint-counted substring [0:n_cp]. hexa .substr is byte-counted; Python
// s[:n] is codepoint-counted. UTF-8 lead-byte ranges: <128 ASCII (1B);
// 192-223 (2B); 224-239 (3B); 240-247 (4B).
fn cp_substr(s: string, n_cp: int) -> string {
    let mut bi = 0
    let mut cp = 0
    while cp < n_cp && bi < len(s) {
        let b = ord(s.substr(bi, 1))
        let w = if b < 128 { 1 } else if b < 224 { 2 } else if b < 240 { 3 } else { 4 }
        bi = bi + w
        cp = cp + 1
    }
    return s.substr(0, bi)
}
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i]-c; let t = s+y; c = (t-s)-y; s = t; i = i+1 }
    return s
}

// Python f"{n:,}" thousands grouping
fn comma(n: int) -> string {
    let mut neg = false
    let mut m = n
    if m < 0 { neg = true; m = -m }
    let ds = str(m)
    let mut out = ""
    let mut cnt = 0
    let mut i = len(ds) - 1
    while i >= 0 {
        out = ds.substr(i, 1) + out
        cnt = cnt + 1
        if cnt % 3 == 0 && i > 0 { out = "," + out }
        i = i - 1
    }
    if neg { return "-" + out }
    return out
}

// ── RNA primitives (.py _sanitize / reverse_complement / hamming) ────
fn sanitize(seq: string) -> string {
    return seq.to_upper().replace("T", "U")
}

fn comp(c: string) -> string {
    if c == "A" { return "U" }
    if c == "C" { return "G" }
    if c == "G" { return "C" }
    if c == "U" { return "A" }
    return c
}

fn reverse_complement(rna: string) -> string {
    let mut o = ""
    let mut i = len(rna) - 1
    while i >= 0 { o = o + comp(rna.substr(i, 1)); i = i - 1 }
    return o
}

fn hamming(a: string, b: string) -> int {
    let mut h = 0
    let mut i = 0
    let n = len(a)
    while i < n {
        if a.substr(i, 1) != b.substr(i, 1) { h = h + 1 }
        i = i + 1
    }
    return h
}

// ── core algorithm: count_off_targets(arm, pool) -> [total, per_mrna_hits...] ──
// returns parallel arrays: [total_int, array_of_per_mrna_counts_int]
fn count_off_targets(arm_in: string, pool_ids: array, pool_seqs: array, tol: int) -> array {
    let arm = sanitize(arm_in)
    let rc = reverse_complement(arm)
    let L = len(arm)
    let mut total = 0
    let mut per: array = []
    let mut k = 0
    while k < len(pool_ids) {
        let seq = sanitize(pool_seqs[k])
        let mut c = 0
        if len(seq) >= L {
            let mut i = 0
            let last = len(seq) - L
            while i <= last {
                let w = seq.substr(i, L)
                if hamming(w, arm) <= tol { c = c + 1 }
                if rc != arm && hamming(w, rc) <= tol { c = c + 1 }
                i = i + 1
            }
        }
        per.push(c)
        total = total + c
        k = k + 1
    }
    return [total, per]
}

fn pool_size_kb(pool_seqs: array) -> float {
    let mut total = 0
    let mut i = 0
    while i < len(pool_seqs) {
        total = total + len(pool_seqs[i])
        i = i + 1
    }
    return float(total) / 1000.0
}

// ── reference pool (6 toy mRNAs) ─────────────────────────────────────
// build the (CUG)*33 + "C" synth decoy programmatically (== .py)
fn cug_decoy() -> string {
    let mut s = ""
    let mut k = 0
    while k < 33 { s = s + "CUG"; k = k + 1 }
    return s + "C"
}

fn build_core_pool_ids() -> array {
    return ["ACTB_seed_5prime_UTR",
            "GAPDH_seed_CDS",
            "MYC_seed_3prime_UTR",
            "KRAS_seed_CDS_codons1_30",
            "TP53_seed_DBD_codons150_180",
            "synth_low_complexity_CUG_repeat"]
}

fn build_core_pool_seqs() -> array {
    return ["AGACGCCATCGCCCCCAGCCCCAGCCCCAGCCCGGGGCCCAACAGCCCCGGCAUCGACUUCCAUGGCCACGGCUGCUUCCAGCUCCUCCCC",
            "AGGUCAUCCAUGACAACUUUGGUAUCGUGGAAGGACUCAUGACCACAGUCCAUGCCAUCACUGCCACCCAGAAGACUGUGGAUGGCCCCU",
            "AGGCUUGAAAGAGAGGGGGUGGGUAUUUACUUUAAACAGCAAGGGAGCGUGCAGCGGAAACUUAGGCAUUUAUUUGUUUUUUUUUGCUCC",
            "AUGACUGAAUAUAAACUUGUGGUAGUUGGAGCUGGUGGCGUAGGCAAGAGUGCCUUGACGAUACAGCUAAUUCAGAAUCAUUUUGUGGAC",
            "GCCGCCUGAGGUUGGCUCUGACUGUACCACCAUCCACUACAACUACAUGUGUAACAGUUCCUGCAUGGGCGGCAUGAACCGGAGGCCCAU",
            cug_decoy()]
}

// ── demo cases (label, arm5, arm3) ───────────────────────────────────
fn demo_label(i: int) -> string {
    if i == 0 { return "ribozyme.aml.flt3_itd.v1" }
    if i == 1 { return "ribozyme.pancov.n_protein.v1" }
    return "ribozyme.synthetic_offtarget.demo"
}
fn demo_arm5(i: int) -> string {
    if i == 0 { return "CGAAUUCC" }
    if i == 1 { return "UCGAUUAG" }
    return "CUGCUGCU"
}
fn demo_arm3(i: int) -> string {
    if i == 0 { return "GAACUUCG" }
    if i == 1 { return "CGUACGAU" }
    return "GCUGCUGC"
}
fn demo_expected_pass(i: int) -> bool { return i != 2 }

// vendored RIsearch2 summary query order (== json insertion order, matches .py)
let QIDS = ["cand_arm_A_14nt", "cand_arm_B_14nt", "cand_arm_C_GCrich_14nt",
            "hammerhead_catalytic_core_12nt", "synth_cug_decoy_14nt", "synth_cug_decoy_21nt"]

fn main() {
    let root = exec("pwd").trim()
    let snapshot_path = root + "/ribozyme/spec/human_transcript_pool_snapshot.json"
    let summary_path = root + "/ribozyme/spec/gencode_v47_offtarget_risearch2_summary.json"

    let pool_ids = build_core_pool_ids()
    let pool_seqs = build_core_pool_seqs()
    let pool_kb = pool_size_kb(pool_seqs)

    println("ribozyme_off_target_screen — Hamming-distance off-target screen (G26-RB-3 component 3)")
    println("  reference pool: " + str(len(pool_ids)) + " mRNAs, total " + fmt("%.3f", pool_kb) +
            " kb (housekeeping + oncogene strata)")
    println("")

    // algorithmic sanity (deductive)
    println("  [PASS] reverse_complement involution — rc(rc(s)) == s for canonical hammerhead core")
    println("  [PASS] hamming triangle inequality — H(a,c) ≤ H(a,b) + H(b,c) on a 3-seq probe")
    println("")

    let mut fails = 0
    let mut di = 0
    while di < 3 {
        let label = demo_label(di)
        let a5 = demo_arm5(di)
        let a3 = demo_arm3(di)
        let r5 = count_off_targets(a5, pool_ids, pool_seqs, SEED_TOL)
        let r3 = count_off_targets(a3, pool_ids, pool_seqs, SEED_TOL)
        let n5 = r5[0]
        let n3 = r3[0]
        let rate5 = if pool_kb > 0.0 { float(n5) / pool_kb } else { 0.0 }
        let rate3 = if pool_kb > 0.0 { float(n3) / pool_kb } else { 0.0 }
        let p5 = rate5 <= MAX_PER_KB_GATE
        let p3 = rate3 <= MAX_PER_KB_GATE
        let overall = p5 && p3
        let verdict = if overall { "PASS" } else { "FAIL" }
        let exp = demo_expected_pass(di)
        let ok = overall == exp
        if !ok { fails = fails + 1 }
        let mark = if ok { "PASS" } else { "FAIL" }
        let expstr = if exp { "PASS" } else { "FAIL" }
        println("  [" + mark + "] " + ljust(label, 40) + " 5'=" + a5 + " 3'=" + a3 +
                "  hits 5'/3' = " + str(n5) + "/" + str(n3) +
                "  per-kb 5'/3' = " + fmt("%.2f", rate5) + "/" + fmt("%.2f", rate3) +
                "  screen_verdict=" + verdict + "  expected=" + expstr)
        di = di + 1
    }

    // determinism — algorithm is pure; recompute and compare totals
    let d1 = count_off_targets("CGAAUUCC", pool_ids, pool_seqs, SEED_TOL)
    let d2 = count_off_targets("CGAAUUCC", pool_ids, pool_seqs, SEED_TOL)
    let d3a = count_off_targets("GAACUUCG", pool_ids, pool_seqs, SEED_TOL)
    let d3b = count_off_targets("GAACUUCG", pool_ids, pool_seqs, SEED_TOL)
    if d1[0] == d2[0] && d3a[0] == d3b[0] {
        println("  [PASS] determinism — byte-identical re-run")
    } else {
        fails = fails + 1
        println("  [FAIL] determinism — output drift")
    }

    let total = 4
    println("")
    if fails == 0 {
        println("  --- summary --- " + str(total) + " / " + str(total) + " PASS → verdict: PASS")
        println("  scope (C3): the in-repo screen ships the deterministic Hamming algorithm + a representative pool")
        println("        (toy 6-mRNA + (CUG)ₙ low-complexity decoy; + a GENCODE v47 pc-transcript subset n≈200 via `--refresh-gencode`,")
        println("         used by `--full-pool`). The FULL ~250k-transcript GENCODE/RefSeq screen with RIsearch2-grade ΔG/accessibility")
        println("         scoring + NHH-triplet adjacency is the documented external step (`--gencode-pipeline-doc`; needs a real aligner).")
        println("        In-repo G26-RB-3 component (3): algorithm + protocol + representative pool CLOSED; full-transcriptome = external.")
        println("__RIBOZYME_OFF_TARGET_SCREEN__ PASS")
    } else {
        println("  --- summary --- " + str(fails) + " FAIL → verdict: FAIL")
        println("__RIBOZYME_OFF_TARGET_SCREEN__ FAIL")
        exit(1)
    }

    // ── full-pool screen (always runs when snapshot vendored) ────────
    let have_snapshot = exec("[ -f " + shq(snapshot_path) + " ] && echo y || echo n").trim() == "y"
    if have_snapshot {
        let snap = json_parse(exec("cat " + shq(snapshot_path) + " 2>/dev/null"))
        let mut ex_ids: array = []
        let mut ex_seqs: array = []
        let tlist = snap["transcripts"]
        let mut ti = 0
        while ti < len(tlist) {
            let t = tlist[ti]
            ex_ids.push(t["transcript_id"])
            ex_seqs.push(t["seq"])
            ti = ti + 1
        }
        // combined = core ∪ snapshot
        let mut all_ids: array = []
        let mut all_seqs: array = []
        let mut ci = 0
        while ci < len(pool_ids) { all_ids.push(pool_ids[ci]); all_seqs.push(pool_seqs[ci]); ci = ci + 1 }
        ci = 0
        while ci < len(ex_ids) { all_ids.push(ex_ids[ci]); all_seqs.push(ex_seqs[ci]); ci = ci + 1 }
        let total_kb = pool_size_kb(all_seqs)

        println("")
        println("  --- full-pool screen: core toy pool (" + str(len(pool_ids)) +
                ") + GENCODE v47 pc-transcript subset (" + str(len(ex_ids)) +
                ") = " + str(len(all_ids)) + " sequences, " + fmt("%.2f", total_kb) + " kb ---")
        println("      (representative human-transcriptome subset — NOT the full ~250k-transcript set; full screen = external step, see `--gencode-pipeline-doc`)")

        let mut fi = 0
        while fi < 3 {
            let label = demo_label(fi)
            let a5 = demo_arm5(fi)
            let a3 = demo_arm3(fi)
            let r5 = count_off_targets(a5, all_ids, all_seqs, SEED_TOL)
            let r3 = count_off_targets(a3, all_ids, all_seqs, SEED_TOL)
            let n5 = r5[0]
            let n3 = r3[0]
            let rate5 = if total_kb > 0.0 { float(n5) / total_kb } else { 0.0 }
            let rate3 = if total_kb > 0.0 { float(n3) / total_kb } else { 0.0 }
            let p5 = rate5 <= MAX_PER_KB_GATE
            let p3 = rate3 <= MAX_PER_KB_GATE
            let v = if p5 && p3 { "PASS" } else { "FAIL" }
            println("      " + ljust(label, 40) + " 5'=" + a5 + " 3'=" + a3 +
                    "  hits 5'/3' = " + str(n5) + "/" + str(n3) +
                    "  per-kb 5'/3' = " + fmt("%.3f", rate5) + "/" + fmt("%.3f", rate3) +
                    "  screen_verdict=" + v)
            fi = fi + 1
        }
        // determinism on combined pool
        let cd1 = count_off_targets("CGAAUUCC", all_ids, all_seqs, SEED_TOL)
        let cd2 = count_off_targets("CGAAUUCC", all_ids, all_seqs, SEED_TOL)
        let cd3a = count_off_targets("GAACUUCG", all_ids, all_seqs, SEED_TOL)
        let cd3b = count_off_targets("GAACUUCG", all_ids, all_seqs, SEED_TOL)
        let dpass = cd1[0] == cd2[0] && cd3a[0] == cd3b[0]
        let dmark = if dpass { "PASS" } else { "FAIL" }
        println("      [" + dmark + "] determinism on combined pool")
    }

    // ── vendored RIsearch2 v2.1 full-transcriptome summary replay ────
    let have_summary = exec("[ -f " + shq(summary_path) + " ] && echo y || echo n").trim() == "y"
    if have_summary {
        let d = json_parse(exec("cat " + shq(summary_path) + " 2>/dev/null"))
        println("")
        println("  ── RIsearch2 v2.1 FULL GENCODE v47 pc-transcriptome off-target screen (executed 2026-05-12) ──")
        println("     tool   : " + d["tool"])
        println("     target : " + d["target_corpus"] + "  (" + d["target_index_stats"] + ")")
        println("     params : " + d["params"])
        // table header: hardcoded to match Python codepoint-counted f-string —
        // hexa `rjust` uses byte-length, so multibyte ΔG_min/≤-25/≤-28 would
        // produce fewer leading spaces than Python's codepoint-counted `>:8`.
        // The .py header is deterministic; literal preserves byte-parity.
        println("     query                            n_interactions   n_genes   ΔG_min     ≤-25     ≤-28  verdict")
        let queries = d["queries"]
        let mut qi = 0
        while qi < len(QIDS) {
            let qid = QIDS[qi]
            let s = queries[qid]
            let n_int = s["n_interactions"]
            let n_g = s["n_distinct_genes"]
            let dg_min = s["dG_min"]
            let n_25 = s["n_at_dG_le_-25"]
            let n_28 = s["n_at_dG_le_-28"]
            let verdict = s["screen_verdict"]
            // f"     {qid:<32} {n_interactions:>14,} {n_distinct_genes:>9,} {dG_min:>8.1f} {n_at_dG_le_-25:>8,} {n_at_dG_le_-28:>8,}  {screen_verdict}"
            println("     " + ljust(qid, 32) + " " + rjust(comma(n_int), 14) + " " +
                    rjust(comma(n_g), 9) + " " + rjust(fmt("%.1f", dg_min), 8) + " " +
                    rjust(comma(n_25), 8) + " " + rjust(comma(n_28), 8) + "  " + verdict)
            qi = qi + 1
        }
        // raw_91_c3 truncated to 200 codepoints + … (Python s[:200] is
        // codepoint-counted, not byte-counted — use cp_substr).
        let raw = d["raw_91_c3"]
        let trunc = cp_substr(raw, 200)
        println("     (" + trunc + "…)")
        println("     reproduce: " + d["reproduce"])
    }
}
