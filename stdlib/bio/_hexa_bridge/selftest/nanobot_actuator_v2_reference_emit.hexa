#!hexa strict
// hexa-bio/_hexa_bridge/selftest/nanobot_actuator_v2_reference_emit.hexa
//
// hexa-native port of `_python_bridge/module/nanobot_actuator_v2_reference_emit.py`
// (T3; json/os/pathlib — deterministic, no network/time/random). N-R1 v2
// schema-conformance reference emitter: builds 3 canonical sample rows
// and validates each against actuator_output_v1.schema.json via the
// shared json_schema_validator module.
//
// emit() is replicated as deterministic JSON text (faithful field
// population), json_parse'd into a row (gap#2-safe now), then validated
// — sidesteps map-literal construction and reuses the proven json_parse
// + verified validator. shq() comes from the imported validator module
// (discipline #1: no local dup). Discipline #4: no in-place mutation of
// parallel-tracked arrays.

import "_hexa_bridge/module/json_schema_validator.hexa"

let SCHEMA_REL = "nanobot/spec/actuator_output_v1.schema.json"

fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }

// per-sample constant data (== .py _SAMPLE_INPUTS cycle-24 MVP corpus)
fn sample_id(i: int) -> string {
    if i == 1 { return "nanobot.aml.cd33.v1" }
    if i == 2 { return "nanobot.pancov.ace2_decoy.v1" }
    return "nanobot.senolytic.p16.v1"
}
fn sample_skeleton(i: int) -> string {
    if i == 2 { return "cuboctahedron" }
    return "truncated_icosahedron"
}
// ligand label for vertex j (0..11); "" means null/bare
fn sample_ligand(i: int, j: int) -> string {
    if i == 1 { if j < 6 { return "CD33-scFv" } return "" }
    if i == 2 { return "ACE2-D30" }
    if j < 4 { return "p16-aptamer" }
    return ""
}
fn sample_charge(i: int, j: int) -> int {
    if i == 1 { if j < 6 { return -1 } return 0 }
    if i == 2 { return -2 }
    if j < 4 { return -1 }
    return 0
}
// mass_amu as JSON-number text
fn sample_mass(i: int, j: int) -> string {
    if i == 1 { if j < 6 { return "27000.0" } return "0.0" }
    if i == 2 { return "3200.0" }
    if j < 4 { return "8000.0" }
    return "0.0"
}
fn sample_rep(i: int) -> int { if i == 1 { return 0 } if i == 2 { return 7 } return 12 }
// cycle rates k01,k12,k23,k30 as JSON-number text
fn sample_rate(i: int, which: int) -> string {
    if i == 1 { if which == 0 { return "10000.0" } if which == 1 { return "5000.0" } if which == 2 { return "20000.0" } return "8000.0" }
    if i == 2 { if which == 0 { return "20000.0" } if which == 1 { return "10000.0" } if which == 2 { return "30000.0" } return "15000.0" }
    if which == 0 { return "8000.0" } if which == 1 { return "4000.0" } if which == 2 { return "15000.0" } return "6000.0"
}
fn sample_nbind(i: int) -> int { if i == 1 { return 6 } if i == 2 { return 12 } return 4 }
fn sample_btarget(i: int) -> string { if i == 1 { return "CD33" } if i == 2 { return "spike_RBD" } return "p16_ink4a" }
fn sample_kd(i: int) -> string { if i == 1 { return "1.2e-09" } if i == 2 { return "8.0e-10" } return "5.0e-09" }
fn sample_kon(i: int) -> string { if i == 1 { return "1500000.0" } if i == 2 { return "2500000.0" } return "800000.0" }
fn sample_koff(i: int) -> string { if i == 1 { return "0.0018" } if i == 2 { return "0.002" } return "0.004" }
fn sample_work(i: int) -> string { if i == 1 { return "50.0" } if i == 2 { return "40.0" } return "35.0" }

fn build_row_json(i: int) -> string {
    let mut s = "{"
    s = s + "\"actuator_id\": \"" + sample_id(i) + "\""
    s = s + ", \"schema_version\": \"raw_77_nanobot_actuation_v2\""
    // vertex_decorations (12)
    s = s + ", \"vertex_decorations\": ["
    let mut j = 0
    while j < 12 {
        if j > 0 { s = s + ", " }
        let lg = sample_ligand(i, j)
        let lgtext = if len(lg) > 0 { "\"" + lg + "\"" } else { "null" }
        s = s + "{\"vertex_id\": " + str(j) + ", \"ligand\": " + lgtext +
                ", \"charge_e\": " + str(sample_charge(i, j)) +
                ", \"mass_amu\": " + sample_mass(i, j) + "}"
        j = j + 1
    }
    s = s + "]"
    // pose_canonical_form
    s = s + ", \"pose_canonical_form\": {\"representative_pose\": " + str(sample_rep(i)) +
            ", \"orbit_size\": 24, \"stabilizer_order\": 1}"
    // state_cycle: 4x4, only M[0][1],M[1][2],M[2][3],M[3][0] from rates
    s = s + ", \"state_cycle\": {\"states\": [\"S0\", \"S1\", \"S2\", \"S3\"], \"transition_matrix_per_s\": ["
    let mut r = 0
    while r < 4 {
        if r > 0 { s = s + ", " }
        s = s + "["
        let mut c = 0
        while c < 4 {
            if c > 0 { s = s + ", " }
            let mut cell = "0.0"
            if r == 0 && c == 1 { cell = sample_rate(i, 0) }
            if r == 1 && c == 2 { cell = sample_rate(i, 1) }
            if r == 2 && c == 3 { cell = sample_rate(i, 2) }
            if r == 3 && c == 0 { cell = sample_rate(i, 3) }
            s = s + cell
            c = c + 1
        }
        s = s + "]"
        r = r + 1
    }
    s = s + "]}"
    // binding_affinity (nbind entries, vertex_id 0..nbind-1)
    s = s + ", \"binding_affinity\": ["
    let nb = sample_nbind(i)
    let mut b = 0
    while b < nb {
        if b > 0 { s = s + ", " }
        s = s + "{\"vertex_id\": " + str(b) + ", \"target\": \"" + sample_btarget(i) +
                "\", \"K_d_M\": " + sample_kd(i) + ", \"k_on_M_s\": " + sample_kon(i) +
                ", \"k_off_s\": " + sample_koff(i) + "}"
        b = b + 1
    }
    s = s + "]"
    // n6_invariant, work, brownian, skeleton
    s = s + ", \"n6_invariant\": {\"sigma_6\": 12, \"tau_6\": 4, \"phi_6\": 2, \"J2\": 24}"
    s = s + ", \"work_per_cycle_kT\": " + sample_work(i)
    s = s + ", \"brownian_collapse_detected\": false"
    s = s + ", \"skeleton\": \"" + sample_skeleton(i) + "\""
    s = s + "}"
    return s
}

fn main() {
    let root = exec("pwd").trim()
    println("nanobot_actuator_v2_reference_emit — N-R1 v2 schema-conformance reference emitter")
    println("  schema: " + SCHEMA_REL)
    println("")

    let schema_path = root + "/" + SCHEMA_REL
    if exec("[ -f " + shq(schema_path) + " ] && echo y || echo n").trim() != "y" {
        println("  [FAIL] schema not found at " + schema_path)
        println("__NANOBOT_ACTUATOR_V2_REFERENCE_EMIT__ FAIL")
        exit(1)
    }
    let schema = json_parse(exec("cat " + shq(schema_path) + " 2>/dev/null"))

    let mut fails = 0
    let mut i = 1
    while i <= 3 {
        let js1 = build_row_json(i)
        let js2 = build_row_json(i)
        let row = json_parse(js1)
        let errs = validate(row, schema, "")
        if len(errs) > 0 {
            fails = fails + 1
            println("  [FAIL] sample " + str(i) + " (" + sample_id(i) + "): " + str(len(errs)) + " schema error(s)")
            let mut e = 0
            while e < len(errs) && e < 5 { println("         ✗ " + str(errs[e])); e = e + 1 }
            i = i + 1
            continue
        }
        if js1 != js2 {
            fails = fails + 1
            println("  [FAIL] sample " + str(i) + " (" + sample_id(i) + "): emitter is non-deterministic")
            i = i + 1
            continue
        }
        // ligand count: truthy ligand in vertex_decorations
        let vds = row["vertex_decorations"]
        let mut lc = 0
        let mut k = 0
        while k < len(vds) {
            let lg = vds[k]["ligand"]
            if type_of(lg) == "string" && len(lg) > 0 { lc = lc + 1 }
            k = k + 1
        }
        let wtext = json_stringify(row["work_per_cycle_kT"])
        println("  [PASS] sample " + str(i) + " " + ljust(sample_id(i), 36) +
                " skeleton=" + ljust(str(row["skeleton"]), 22) +
                " W=" + wtext + " kT  ligands=" + rjust(str(lc), 2) + "/12")
        i = i + 1
    }

    println("")
    let total = 3
    if fails == 0 {
        println("  --- summary --- " + str(total) + " / " + str(total) + " PASS → verdict: PASS")
        println("  scope (C3): reference emitter only. Production simulator")
        println("        (nanobot_actuation_simulation.py @ ~/core/nexus/sim_bridge/)")
        println("        adopts this field-population pattern in the external cycle;")
        println("        in-repo N-R1 (v2 emit-path demonstration) is CLOSED.")
        println("__NANOBOT_ACTUATOR_V2_REFERENCE_EMIT__ PASS")
        return
    }
    println("  --- summary --- " + str(fails) + " FAIL → verdict: FAIL")
    println("__NANOBOT_ACTUATOR_V2_REFERENCE_EMIT__ FAIL")
    exit(1)
}
