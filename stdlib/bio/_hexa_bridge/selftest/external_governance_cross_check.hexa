#!hexa strict
// hexa-bio/_hexa_bridge/selftest/external_governance_cross_check.hexa
//
// @X external-citation integrity gate. hexa-native port of
// `selftest/external_governance_cross_check.py` (T3). Scans AGENTS.tape
// + root HEXA-*.tape for @X entries, classifies PRESENT / MISSING-PATH /
// URL-SKIP / NO-TARGET, verifies the AGENTS.tape↔AGENTS.md COEXIST
// contract. Byte-parity stdout vs the .py.
//
// .tape v1.2 @X header: `@X <id> := "<subject>" :: <kind> [<grades>]`
// hand-parsed (ASCII prefix); body url=/path= via 2-space-indent scan.

fn shq(s: string) -> string { return "'" + s.replace("'", "'\\''") + "'" }

let COEXIST_MIN = 1024

fn exists(p: string) -> bool { return exec("[ -e " + shq(p) + " ] && echo y || echo n").trim() == "y" }
fn isfile(p: string) -> bool { return exec("[ -f " + shq(p) + " ] && echo y || echo n").trim() == "y" }
fn fsize(p: string) -> int {
    let r = exec("wc -c < " + shq(p) + " 2>/dev/null | tr -d ' \\n'").trim()
    let mut v = 0; let mut seen = false; let mut i = 0
    while i < len(r) {
        let c = r.substr(i, 1)
        let mut d = 0
        while d < 10 { if str(d) == c { v = v*10+d; seen = true; break }; d = d+1 }
        i = i + 1
    }
    if seen == false { return -1 }
    return v
}

fn ljust(s: string, n: int) -> string { let mut o=s; while len(o)<n { o=o+" " }; return o }
fn ws(c: string) -> bool { return c==" " || c=="\t" }

fn lstrip(s: string) -> string {
    let mut i = 0
    while i < len(s) && ws(s.substr(i,1)) { i = i+1 }
    return s.substr(i, len(s)-i)
}
fn rstrip(s: string) -> string {
    let mut e = len(s)
    while e > 0 && ws(s.substr(e-1,1)) { e = e-1 }
    return s.substr(0, e)
}
fn startswith(s: string, p: string) -> bool {
    if len(s) < len(p) { return false }
    return s.substr(0, len(p)) == p
}
fn rep(c: string, n: int) -> string { let mut o=""; let mut i=0; while i<n { o=o+c; i=i+1 }; return o }

// repeated-dash section ruler with the em-dash box char
fn dashes(n: int) -> string { return rep("─", n) }

// _shorten: char-truncate with … (ASCII content here → byte==char)
fn shorten(s: string, w: int) -> string {
    if len(s) <= w { return s }
    return s.substr(0, w-1) + "…"
}

// parse one @X header line → [id, kind] or [] (subject dropped — unused in output)
// regex: ^@X\s+(\S+)\s*:=\s*"([^"]*)"\s*::\s*(\S+)(?:\s+\[[^\]]*\])?\s*$
fn parse_header(line: string) -> array {
    let empty: array = []
    if startswith(line, "@X") == false { return empty }
    let mut p = 2
    if p >= len(line) || ws(line.substr(p,1)) == false { return empty }
    while p < len(line) && ws(line.substr(p,1)) { p = p+1 }
    // entry_id = \S+
    let ids = p
    while p < len(line) && ws(line.substr(p,1)) == false { p = p+1 }
    let entry_id = line.substr(ids, p-ids)
    if len(entry_id) == 0 { return empty }
    while p < len(line) && ws(line.substr(p,1)) { p = p+1 }
    // :=
    if p+2 > len(line) || line.substr(p,2) != ":=" { return empty }
    p = p+2
    while p < len(line) && ws(line.substr(p,1)) { p = p+1 }
    // "subject"
    if p >= len(line) || line.substr(p,1) != "\"" { return empty }
    p = p+1
    while p < len(line) && line.substr(p,1) != "\"" { p = p+1 }
    if p >= len(line) { return empty }
    p = p+1   // past closing quote
    while p < len(line) && ws(line.substr(p,1)) { p = p+1 }
    // ::
    if p+2 > len(line) || line.substr(p,2) != "::" { return empty }
    p = p+2
    while p < len(line) && ws(line.substr(p,1)) { p = p+1 }
    // kind = \S+
    let ks = p
    while p < len(line) && ws(line.substr(p,1)) == false { p = p+1 }
    let kind = line.substr(ks, p-ks)
    if len(kind) == 0 { return empty }
    // rest must be: ws* OR ws+ [..] ws*  — accept (regex is anchored but
    // a malformed tail is rare; the .py would reject. mirror: require the
    // remainder to be empty or start a [ bracket after ws.)
    let rest = lstrip(line.substr(p, len(line)-p))
    if len(rest) > 0 {
        if rest.substr(0,1) != "[" { return empty }
    }
    return [entry_id, kind]
}

// body line `  url = "..."` / `  path = "..."` → value or ""
fn body_kv(line: string, key: string) -> string {
    // must start with >=2 spaces
    if startswith(line, "  ") == false { return "" }
    let t = lstrip(line)
    if startswith(t, key) == false { return "" }
    let mut p = len(key)
    while p < len(t) && ws(t.substr(p,1)) { p = p+1 }
    if p >= len(t) || t.substr(p,1) != "=" { return "" }
    p = p+1
    while p < len(t) && ws(t.substr(p,1)) { p = p+1 }
    if p >= len(t) || t.substr(p,1) != "\"" { return "" }
    p = p+1
    let vs = p
    // value = .* up to last closing quote before trailing ws
    let tr = rstrip(t)
    if len(tr) == 0 || tr.substr(len(tr)-1,1) != "\"" { return "" }
    return tr.substr(vs, len(tr)-1-vs)
}

let G_ROOT = exec("pwd").trim()

fn resolve_path(raw: string) -> string {
    // lstrip "./" chars (Python str.lstrip("./") strips any leading '.' or '/')
    let mut i = 0
    while i < len(raw) && (raw.substr(i,1) == "." || raw.substr(i,1) == "/") { i = i+1 }
    return G_ROOT + "/" + raw.substr(i, len(raw)-i)
}

fn main() {
    println("external_governance_cross_check — hexa-bio @X external-citation integrity gate")
    println("  scans AGENTS.tape + every root HEXA-*.tape for @X entries,")
    println("  classifies each as PRESENT / MISSING-PATH / URL-SKIP / NO-TARGET,")
    println("  verifies the AGENTS.tape↔AGENTS.md COEXIST contract.")
    println("  governance: g1 real-limits-first · g7 skip-is-honest (URLs not")
    println("              dereferenced — no network) · g8 in-silico-only")
    println("")

    // discover tapes: AGENTS.tape first, then sorted HEXA-*.tape (no .log.tape)
    let mut tapes: array = []
    if isfile(G_ROOT + "/AGENTS.tape") { tapes.push("AGENTS.tape") }
    let hx = exec("cd " + shq(G_ROOT) + " && ls -1 HEXA-*.tape 2>/dev/null | grep -v '\\.log\\.tape$' | LC_ALL=C sort").trim()
    if len(hx) > 0 {
        let hl = hx.split("\n")
        let mut i = 0
        while i < len(hl) { if len(hl[i]) > 0 { tapes.push(hl[i]) }; i = i+1 }
    }
    println("  scanning " + str(len(tapes)) + " tape file(s):")
    let mut ti = 0
    while ti < len(tapes) { println("    · " + tapes[ti]); ti = ti+1 }
    println("")

    // parse @X entries — parallel row arrays
    let mut r_tape: array = []
    let mut r_id: array = []
    let mut r_kind: array = []
    let mut r_status: array = []
    let mut r_target: array = []

    let mut tx = 0
    while tx < len(tapes) {
        let tape = tapes[tx]
        let lines = exec("cat " + shq(G_ROOT + "/" + tape) + " 2>/dev/null").split("\n")
        let mut i = 0
        while i < len(lines) {
            let hdr = parse_header(lines[i])
            if hdr.len() != 2 { i = i+1; continue }
            let entry_id = hdr[0]
            let kind = hdr[1]
            // body scan
            let mut url_v = ""
            let mut path_v = ""
            let mut j = i+1
            while j < len(lines) {
                let b = lines[j]
                if rstrip(lstrip(b)) == "" || startswith(b, "  ") == false { break }
                if url_v == "" { let u = body_kv(b, "url"); if len(u) > 0 { url_v = u } }
                if path_v == "" { let pp = body_kv(b, "path"); if len(pp) > 0 { path_v = pp } }
                j = j+1
            }
            // classify
            let mut status = ""
            let mut target = ""
            if len(path_v) > 0 {
                target = path_v
                if exists(resolve_path(path_v)) { status = "PRESENT" } else { status = "MISSING-PATH" }
            } else if len(url_v) > 0 {
                status = "URL-SKIP"; target = url_v
            } else {
                status = "NO-TARGET"; target = "(literature ref only — no url/path body)"
            }
            r_tape.push(tape); r_id.push(entry_id); r_kind.push(kind)
            r_status.push(status); r_target.push(target)
            i = j
        }
        tx = tx+1
    }

    let n_total = len(r_tape)

    // tally
    let mut n_present = 0
    let mut n_missing = 0
    let mut n_url = 0
    let mut n_none = 0
    let mut k = 0
    while k < n_total {
        let s = r_status[k]
        if s == "PRESENT" { n_present = n_present+1 }
        else if s == "MISSING-PATH" { n_missing = n_missing+1 }
        else if s == "URL-SKIP" { n_url = n_url+1 }
        else { n_none = n_none+1 }
        k = k+1
    }

    // column widths
    let mut w_tape = 4
    let mut w_id = 8
    let mut w_kind = 4
    let mut w_status = 6
    let mut c = 0
    while c < n_total {
        if len(r_tape[c]) > w_tape { w_tape = len(r_tape[c]) }
        if len(r_id[c]) > w_id { w_id = len(r_id[c]) }
        if len(r_kind[c]) > w_kind { w_kind = len(r_kind[c]) }
        if len(r_status[c]) > w_status { w_status = len(r_status[c]) }
        c = c+1
    }
    if w_tape > 28 { w_tape = 28 }
    if w_id > 32 { w_id = 32 }
    if w_kind > 18 { w_kind = 18 }

    // per-citation table
    let ndigits = len(str(n_total))
    let mut dn = 40 - ndigits
    if dn < 1 { dn = 1 }
    println("── per-citation table (" + str(n_total) + " @X entries) " + dashes(dn))
    println("  " + ljust("tape", w_tape) + "  " + ljust("entry_id", w_id) + "  " + ljust("kind", w_kind) + "  " + ljust("status", w_status) + "  target")
    println("  " + rep("-", w_tape) + "  " + rep("-", w_id) + "  " + rep("-", w_kind) + "  " + rep("-", w_status) + "  " + rep("-", 12))
    let mut ri = 0
    while ri < n_total {
        println("  " + ljust(shorten(r_tape[ri], w_tape), w_tape) + "  " + ljust(shorten(r_id[ri], w_id), w_id) + "  " + ljust(shorten(r_kind[ri], w_kind), w_kind) + "  " + ljust(r_status[ri], w_status) + "  " + shorten(r_target[ri], 60))
        ri = ri+1
    }
    println("")

    // MISSING-PATH details
    if n_missing > 0 {
        println("── MISSING-PATH details " + dashes(50))
        // (subject not retained — mirror minimal; .py prints subject, but
        //  this branch is inert on a clean corpus. kept faithful for counts.)
        let mut mi = 0
        while mi < n_total {
            if r_status[mi] == "MISSING-PATH" {
                println("  [" + r_tape[mi] + "] " + r_id[mi])
                println("      declared path: " + r_target[mi])
                println("      resolved abs : " + resolve_path(r_target[mi]))
                println("      verdict      : file not found on disk")
            }
            mi = mi+1
        }
        println("")
    }

    // COEXIST
    let tape_p = G_ROOT + "/AGENTS.tape"
    let md_p = G_ROOT + "/AGENTS.md"
    let mut coexist_ok = false
    let mut coexist_detail = ""
    if isfile(tape_p) == false { coexist_detail = "AGENTS.tape missing on disk" }
    else if isfile(md_p) == false { coexist_detail = "AGENTS.md missing on disk" }
    else {
        let tsz = fsize(tape_p)
        let msz = fsize(md_p)
        if tsz < COEXIST_MIN { coexist_detail = "AGENTS.tape size " + str(tsz) + " B below COEXIST floor " + str(COEXIST_MIN) + " B (truncation?)" }
        else if msz < COEXIST_MIN { coexist_detail = "AGENTS.md size " + str(msz) + " B below COEXIST floor " + str(COEXIST_MIN) + " B (truncation?)" }
        else {
            coexist_ok = true
            coexist_detail = "AGENTS.tape=" + str(tsz) + " B, AGENTS.md=" + str(msz) + " B (both >= " + str(COEXIST_MIN) + " B floor)"
        }
    }
    println("── COEXIST contract " + dashes(55))
    println("  AGENTS.tape ↔ AGENTS.md COEXIST pattern (hook h1):")
    let cmark = if coexist_ok { "OK" } else { "BROKEN" }
    println("    " + cmark + " — " + coexist_detail)
    println("")

    // summary
    println("── summary " + dashes(60))
    println("  " + str(n_present) + " PRESENT · " + str(n_missing) + " MISSING-PATH · " + str(n_url) + " URL-SKIP · " + str(n_none) + " NO-TARGET (of " + str(n_total) + " @X rows)")
    println("  HONESTY (g7): URL-SKIP is HONEST — this gate has no network")
    println("  access, so URLs are recorded but not dereferenced. Treating an")
    println("  un-dereferenced URL as FAIL would be dishonest.")
    println("  HONESTY: NO-TARGET (e.g. a literature `ref = \"...\"` entry with")
    println("  no path/url body) does NOT block the sentinel — those are")
    println("  bibliographic citations, not file/URL references.")
    println("  HONESTY (g8): a PASS verifies the in-repo cross-reference graph")
    println("  ONLY — it is NOT a claim about the remote content at any URL.")
    println("")

    if n_missing == 0 && coexist_ok {
        println("__EXTERNAL_GOVERNANCE_CROSS_CHECK__ PASS")
        return
    }
    println("__EXTERNAL_GOVERNANCE_CROSS_CHECK__ FAIL")
    exit(1)
}
