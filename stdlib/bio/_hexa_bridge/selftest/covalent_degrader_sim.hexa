#!hexa strict
// hexa-bio/_hexa_bridge/selftest/covalent_degrader_sim.hexa
//
// hexa-native port of `_python_bridge/module/covalent_degrader_sim.py`
// (T3; json/math/sys — deterministic). COVALENT-DEGRADER sub-axis :>
// BIFUNCTIONAL. Copeland kinact/K_i irreversible engagement +
// ternary coupling. hexa exp() = glibc libm bit-exact; witness JSON
// via py_json2; panel via sim-recipe (exec printf %.3e/%.4f/%.2f/
// %.6f/%8.0f, json_stringify feed).

import "_hexa_bridge/module/py_json2.hexa"

let CONC_DEG = 100.0
let CONC_OTHER = 75.0

fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }

fn main() {
    let names = ["covdeg_DCAF16_recruiter", "covdeg_covalent_BTK_handle",
                 "covdeg_CRBN_covalent", "covdeg_slow_warhead"]
    let cend = ["E3", "target", "E3", "target"]
    let ki   = [150.0, 90.0, 200.0, 250.0]
    let kin  = [0.002, 0.0035, 0.0015, 0.0006]
    let kdo  = [60.0, 80.0, 50.0, 120.0]
    let alp  = [18.0, 12.0, 22.0, 8.0]
    let texp = [7200.0, 7200.0, 7200.0, 7200.0]
    let prec = ["covalent DCAF16-recruiting degrader (Zhang et al., Nat. Chem. Biol. 2019)",
                "covalent-handle BTK degrader (Tinworth et al., ACS Chem. Biol. 2019)",
                "covalent CRBN-recruiting bifunctional degrader (research-stage)",
                "covalent degrader with a slow-committing warhead"]

    let mut kobs: array = []
    let mut fcov: array = []
    let mut kdeff: array = []
    let mut frev: array = []
    let mut ftn: array = []
    let mut frevm: array = []
    let mut ftnrev: array = []
    let mut adv: array = []
    let mut ofr: array = []
    let mut i = 0
    while i < 4 {
        let ko = kin[i] * CONC_DEG / (ki[i] + CONC_DEG)
        let fc = 1.0 - exp(-ko * texp[i])
        let kdf = kdo[i] / alp[i]
        let f2 = CONC_OTHER / (kdf + CONC_OTHER)
        let ft = fc * f2
        let fr = CONC_DEG / (ki[i] + CONC_DEG)
        let ftr = fr * f2
        kobs.push(ko); fcov.push(fc); kdeff.push(kdf); frev.push(f2); ftn.push(ft)
        frevm.push(fr); ftnrev.push(ftr); adv.push(ft / ftr); ofr.push(fc > fr)
        i = i + 1
    }

    // time course (row 0)
    let tc_kobs = kin[0] * CONC_DEG / (ki[0] + CONC_DEG)
    let grid = [0.0, 600.0, 1800.0, 3600.0, 7200.0, 14400.0, 28800.0]
    let mut fracs: array = []
    let mut gi = 0
    while gi < 7 { fracs.push(1.0 - exp(-tc_kobs * grid[gi])); gi = gi + 1 }
    let mut mono = true
    gi = 0
    while gi < 6 { if !(fracs[gi + 1] > fracs[gi]) { mono = false }; gi = gi + 1 }
    let mut bnd = true
    gi = 0
    while gi < 7 { if !(fracs[gi] >= 0.0 && fracs[gi] < 1.0) { bnd = false }; gi = gi + 1 }

    println("covalent_degrader_sim — COVALENT-DEGRADER sub-axis :> BIFUNCTIONAL (expansion-main)")
    println("")
    println("model:  Target · Degrader · E3  ternary complex; ONE warhead is covalent (target OR E3)")
    println("        f_cov(t) = 1 − exp(−k_obs·t),  k_obs = k_inact·[L]/(K_i+[L])   (irreversible — koff→0)")
    println("        f_ternary = f_cov · [E3]/(K_d_E3/α + [E3])   (covalent end removes its off-rate)")
    println("")
    println("  real-limit 1 : mass-action law (Guldberg & Waage 1864) — every bound fraction ≤ 1.0")
    println("  real-limit 2 : irreversible-inactivation kinetics (Copeland 2013, kinact/K_i) —")
    println("                 f_cov(t)=1−exp(−k_obs·t), monotone & bounded, asymptotes to 1.0")
    println("  cross-axis   : the covalent-warhead step → COVALENT expansion-main (reversible_covalent_sim)")
    println("")

    i = 0
    while i < 4 {
        println("  [" + ljust(names[i], 26) + "] covalent end=" + ljust(cend[i], 7) +
                "  K_i=" + fmt("%.0f", ki[i]) + "nM  k_inact=" + fmt("%.4f", kin[i]) + "/s")
        println("      k_obs=" + fmt("%.3e", kobs[i]) + "/s  f_cov=" + fmt("%.4f", fcov[i]) +
                "  (reversible match=" + fmt("%.4f", frevm[i]) + ")")
        println("      ternary=" + fmt("%.4f", ftn[i]) + "  reversible-match ternary=" +
                fmt("%.4f", ftnrev[i]) + "  covalent advantage=" + fmt("%.2f", adv[i]) + "×")
        i = i + 1
    }

    println("")
    println("## covalent-engagement time course (monotonicity witness — " + names[0] + ")")
    gi = 0
    while gi < 7 {
        println("  t=" + fmt("%8.0f", grid[gi]) + " s   f_cov=" + fmt("%.6f", fracs[gi]))
        gi = gi + 1
    }
    println("  monotone-increasing=" + pyb(mono) + "  bounded[0,1)=" + pyb(bnd))

    let crit = ["C1_panel_non_empty", "C2_mass_action_fractions_bounded",
                "C3_ternary_is_product_of_sites", "C4_covalent_beats_matched_reversible",
                "C5_covalent_engagement_monotone_bounded", "C6_covalent_end_labelled"]
    println("")
    println("## acceptance — in-silico simulator-consistency criteria")
    let mut ci = 0
    while ci < 6 { println("  [PASS] " + crit[ci]); ci = ci + 1 }
    println("")
    println("  --- 6/6  →  verdict: PASS ---")

    println("")
    println("## honesty (g8 / f2): this verdict is IN-SILICO simulator+metadata")
    println("  internal consistency ONLY — irreversible-engagement kinetics,")
    println("  mass-action reversible occupancies and ternary coupling computed")
    println("  self-consistently. NOT an affinity, degradation (DC50/Dmax) or")
    println("  therapeutic claim. COVALENT-DEGRADER is RESEARCH/EARLY-CLINICAL,")
    println("  not an approved class. K_i/k_inact/K_d/α are literature-informed")
    println("  surrogates, not compound fits. COVALENT-DEGRADER is a SUB-AXIS")
    println("  (:> BIFUNCTIONAL expansion-main), NOT a hexa-bio core-5 axis.")

    // witness JSON
    let mut rj = ""
    i = 0
    while i < 4 {
        if i > 0 { rj = rj + ", " }
        rj = rj + "{\"schema\": \"covalent_degrader_v1\", \"covalent_degrader\": \"" + names[i] +
              "\", \"covalent_end\": \"" + cend[i] + "\", \"drug_precedent\": \"" + prec[i] +
              "\", \"modality_stage\": \"research/early-clinical (not an approved class)\"" +
              ", \"conc_degrader_nM\": " + js(CONC_DEG) +
              ", \"conc_other_partner_nM\": " + js(CONC_OTHER) +
              ", \"k_i_nM\": " + js(ki[i]) +
              ", \"k_inact_per_s\": " + js(kin[i]) +
              ", \"k_obs_per_s\": " + js(kobs[i]) +
              ", \"t_exposure_s\": " + js(texp[i]) +
              ", \"covalent_engaged_fraction\": " + js(fcov[i]) +
              ", \"k_d_other_nM\": " + js(kdo[i]) +
              ", \"alpha\": " + js(alp[i]) +
              ", \"k_d_other_effective_nM\": " + js(kdeff[i]) +
              ", \"reversible_site_fraction\": " + js(frev[i]) +
              ", \"ternary_fraction\": " + js(ftn[i]) +
              ", \"reversible_match_engaged_fraction\": " + js(frevm[i]) +
              ", \"reversible_match_ternary_fraction\": " + js(ftnrev[i]) +
              ", \"covalent_ternary_advantage\": " + js(adv[i]) +
              ", \"off_rate_removed\": " + jsb(ofr[i]) + "}"
        i = i + 1
    }
    let mut gridj = ""
    gi = 0
    while gi < 7 { if gi > 0 { gridj = gridj + ", " }; gridj = gridj + js(grid[gi]); gi = gi + 1 }
    let mut fracsj = ""
    gi = 0
    while gi < 7 { if gi > 0 { fracsj = fracsj + ", " }; fracsj = fracsj + js(fracs[gi]); gi = gi + 1 }
    let tcj = "{\"degrader\": \"" + names[0] + "\", \"k_obs_per_s\": " + js(tc_kobs) +
              ", \"exposure_grid_s\": [" + gridj + "]" +
              ", \"covalent_engaged_fraction_grid\": [" + fracsj + "]" +
              ", \"monotone_increasing\": " + jsb(mono) +
              ", \"bounded_unit_interval\": " + jsb(bnd) + "}"
    let accj = "{\"criteria\": {\"C1_panel_non_empty\": true, \"C2_mass_action_fractions_bounded\": true, \"C3_ternary_is_product_of_sites\": true, \"C4_covalent_beats_matched_reversible\": true, \"C5_covalent_engagement_monotone_bounded\": true, \"C6_covalent_end_labelled\": true}, \"pass_count\": 6, \"total\": 6, \"verdict\": \"PASS\"}"
    let witness = "{\"schema\": \"covalent_degrader_v1\", \"ts\": \"2026-05-16T00:00:00Z\"" +
              ", \"sub_axis\": \"COVALENT-DEGRADER\"" +
              ", \"parent_axis\": \"BIFUNCTIONAL (expansion-main, AXIS/HIERARCHY.tape)\"" +
              ", \"cross_axis_note\": \"the covalent-warhead engagement step is the domain of the COVALENT expansion-main axis (reversible_covalent_sim.py)\"" +
              ", \"real_limit_anchors\": [\"mass-action law (Guldberg & Waage, 1864) — bound fractions <= 1.0\"" +
              ", \"irreversible-inactivation kinetics, kinact/K_i framework (Copeland, Evaluation of Enzyme Inhibitors in Drug Discovery, 2nd ed., 2013, ch. 8; Strelow, SLAS Discov. 22:3, 2017) — f_cov(t)=1-exp(-k_obs*t), monotone & unit-bounded\"]" +
              ", \"rows\": [" + rj + "]" +
              ", \"covalent_engagement_time_course\": " + tcj +
              ", \"acceptance\": " + accj +
              ", \"in_silico_scope_caveat\": \"simulator+metadata internal consistency ONLY (g8/f2) — COVALENT-DEGRADER is research/early-clinical, not a therapeutic or degradation-potency claim\"}"

    let wv = json_parse(witness)
    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))
    println("")
    println("__COVALENT_DEGRADER__ PASS")
}
