#!hexa strict
// hexa-bio/_hexa_bridge/selftest/ribozyme_a1_1_kinetics_perturbation_sweep.hexa
//
// hexa-native port of `selftest/ribozyme_a1_1_kinetics_perturbation_sweep.py`
// (T3; math/sys — deterministic, no network/time/random/json). A1.1 ±10%
// rate-constant robustness sweep over the hammerhead 4-state kinetics
// simulator. Re-evaluates k_cat / K_M / log10 Eigen-Hammes margin under 11
// perturbation cases (baseline + 4 constants × ±10% + 2 coherent extremes);
// PASS requires every case to clear the A1.1 decisive log10_BF floor (2.0)
// AND the F-RB-4 6/6 verdict. Closes CLOSURE_RESIDUAL_BACKLOG.md §A1.1.
//
// RKS constants (K_B/H_PLANCK/N_A/KCAL_TO_J/TEMP_K/R_GAS, DG_DAGGER_KCAL,
// K_MINUS1/K_MINUS2/K3/K1_2ND_ORDER, EIGEN_HAMMES_CEILING) and the Eyring
// rate are replicated inline rather than imported — the .py module is pure
// CPython arithmetic; replicating verbatim keeps the port self-contained
// and the byte-parity check pin-pointed to this gate.
//
// Recipe: exec("printf …") for Python format-spec rounding (byte-identical
// libc printf == Python format spec); hexa exp() / log() (glibc libm,
// bit-exact vs CPython math.exp / math.log) for the Eyring rate and the
// log10 margin (log10(x) = log(x)/log(10), since hexa lacks math.log10
// stdlib — equivalent to one extra floating-point divide).

import "_hexa_bridge/module/py_json2.hexa"

// ── physical constants (CODATA 2019, exact SI) ──
let K_B = 1.380649e-23           // J/K
let H_PLANCK = 6.62607015e-34    // J·s
let N_A = 6.02214076e23          // 1/mol
let R_GAS = 1.380649e-23 * 6.02214076e23   // J/(mol·K)
let KCAL_TO_J = 4184.0           // 1 kcal = 4184 J (thermochemical)

// ── ribozyme MVP rate-constant parameters ──
let DG_DAGGER_KCAL = 21.0        // ΔG‡, kcal/mol
let TEMP_K = 310.0               // K
let K1_2ND_ORDER = 5.0e5         // M⁻¹s⁻¹
let K_MINUS1 = 0.05              // /s
let K_MINUS2 = 1.0               // /s
let K3 = 100.0                   // /s
let EIGEN_HAMMES_CEILING = 1.0e9 // M⁻¹s⁻¹

let DECISIVE_LOG10_BF_FLOOR = 2.0

// ── helpers ──
fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn rjust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = " " + o }; return o }
fn js(v: float) -> string { return json_stringify(v) }
fn jsb(b: bool) -> string { if b { return "true" } return "false" }
fn pyb(b: bool) -> string { if b { return "True" } return "False" }
fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn fsum(xs: array) -> float {
    let mut s = 0.0; let mut c = 0.0; let mut i = 0
    while i < len(xs) { let y = xs[i] - c; let t = s + y; c = (t - s) - y; s = t; i = i + 1 }
    return s
}

// Eyring transition-state-theory unimolecular rate: k = (kB·T/h)·exp(−ΔG‡/RT)
fn eyring_rate(dg_kcal: float, temp_k: float) -> float {
    let prefactor = K_B * temp_k / H_PLANCK
    let dg_j = dg_kcal * KCAL_TO_J
    return prefactor * exp(-dg_j / (R_GAS * temp_k))
}

// Closed-form perturbed steady-state evaluation.
// Returns [k_cat_per_min, K_M_uM, k_cat_over_K_M, log10_margin].
fn evaluate_case(k_minus1: float, k_minus2: float, k3: float, k1_2nd_order: float) -> array {
    let k2 = eyring_rate(DG_DAGGER_KCAL, TEMP_K)
    let k_cat = k2 * k3 / (k3 + k_minus2)
    let K_M_M = (k_minus1 + k_cat) / k1_2nd_order
    let k_cat_over_K_M = k_cat / K_M_M
    let margin_orders = log(EIGEN_HAMMES_CEILING / k_cat_over_K_M) / log(10.0)
    return [k_cat * 60.0, K_M_M * 1.0e6, k_cat_over_K_M, margin_orders]
}

fn main() {
    // Derive the on-disk reference-simulator path at runtime (was hardcoded
    // /Users/.../ — discipline #2: no hardcoded host paths). .py emits
    // RKS.__file__ = abspath(cwd)/_python_bridge/module/ribozyme_kinetics_simulation.py
    let root = exec("pwd").trim()

    println("ribozyme_a1_1_kinetics_perturbation_sweep — ±10% rate-constant robustness sweep")
    println("  reference simulator: " + root + "/_python_bridge/module/ribozyme_kinetics_simulation.py")
    let k2 = eyring_rate(DG_DAGGER_KCAL, TEMP_K)
    println("  Eyring k2 (fixed: ΔG‡ = " + js(DG_DAGGER_KCAL) + " kcal/mol, T = " + js(TEMP_K) + " K) = " + fmt("%.4e", k2) + " /s")
    println("  A1.1 decisive log10_BF floor (kinetics-side Eigen-Hammes margin) = " + js(DECISIVE_LOG10_BF_FLOOR))
    println("")
    // Header line: '  ' + ljust('case',48) + ' ' + rjust('k_cat /min',11) + ' ' + rjust('K_M µM',9)
    //              + ' ' + rjust('k_cat/K_M',11) + ' ' + rjust('log10_marg',11) + '  F-RB-4'
    // ('K_M µM' contains the multibyte µ — hexa len() is byte-counted, so we
    //  use a literal pre-padded string to match Python's codepoint-based >9.)
    println("  " + ljust("case", 48) + " " + rjust("k_cat /min", 11) + "    K_M µM" + " " + rjust("k_cat/K_M", 11) + " " + rjust("log10_marg", 11) + "  F-RB-4")

    // Perturbation cases: baseline + 4 constants × ±10% + (all+10%) + (all-10%)
    let labels = ["baseline",
                  "k_minus1 +10%", "k_minus1 -10%",
                  "k_minus2 +10%", "k_minus2 -10%",
                  "k3 +10%", "k3 -10%",
                  "k1_2nd_order +10%", "k1_2nd_order -10%",
                  "all +10% (worst-case k_cat/K_M up)",
                  "all -10% (worst-case k_cat/K_M down)"]
    // each entry: [k_minus1, k_minus2, k3, k1_2nd_order]
    let cases = [[K_MINUS1, K_MINUS2, K3, K1_2ND_ORDER],
                 [K_MINUS1 * 1.10, K_MINUS2, K3, K1_2ND_ORDER],
                 [K_MINUS1 * 0.90, K_MINUS2, K3, K1_2ND_ORDER],
                 [K_MINUS1, K_MINUS2 * 1.10, K3, K1_2ND_ORDER],
                 [K_MINUS1, K_MINUS2 * 0.90, K3, K1_2ND_ORDER],
                 [K_MINUS1, K_MINUS2, K3 * 1.10, K1_2ND_ORDER],
                 [K_MINUS1, K_MINUS2, K3 * 0.90, K1_2ND_ORDER],
                 [K_MINUS1, K_MINUS2, K3, K1_2ND_ORDER * 1.10],
                 [K_MINUS1, K_MINUS2, K3, K1_2ND_ORDER * 0.90],
                 [K_MINUS1 * 1.10, K_MINUS2 * 1.10, K3 * 1.10, K1_2ND_ORDER * 1.10],
                 [K_MINUS1 * 0.90, K_MINUS2 * 0.90, K3 * 0.90, K1_2ND_ORDER * 0.90]]

    let mut fails = 0
    let mut margins: array = []
    let mut i = 0
    while i < len(labels) {
        let p = cases[i]
        let ev = evaluate_case(p[0], p[1], p[2], p[3])
        let k_cat_per_min = ev[0]
        let K_M_uM = ev[1]
        let k_cat_over_K_M = ev[2]
        let log10_margin = ev[3]
        margins.push(log10_margin)

        // F-RB-4 verdict: C1/C2/C6 trivially true; C3 0.1 ≤ k_cat_per_min ≤ 10;
        // C4 0.01 ≤ K_M_uM ≤ 10; C5 log10_margin ≥ 1.0
        let c3 = (k_cat_per_min >= 0.1) && (k_cat_per_min <= 10.0)
        let c4 = (K_M_uM >= 0.01) && (K_M_uM <= 10.0)
        let c5 = log10_margin >= 1.0
        let verdict = c3 && c4 && c5
        let margin_ok = log10_margin >= DECISIVE_LOG10_BF_FLOOR
        let ok = verdict && margin_ok
        if ok == false { fails = fails + 1 }

        let verd_s = if verdict { "PASS" } else { "FAIL" }
        let tail = if margin_ok == false { " (margin<2.0)" } else { "" }
        println("  " + ljust(labels[i], 48) + " " +
                rjust(fmt("%.4f", k_cat_per_min), 11) + " " +
                rjust(fmt("%.4f", K_M_uM), 9) + " " +
                rjust(fmt("%.3e", k_cat_over_K_M), 11) + " " +
                rjust(fmt("%.4f", log10_margin), 11) + "  " +
                verd_s + tail)
        i = i + 1
    }
    println("")

    // Determinism re-check: re-evaluating the sweep must be byte-identical.
    // Each evaluate_case() call uses the same constants and operators in the
    // same order — the comparison reduces to float-array equality.
    let mut det_ok = true
    let mut j = 0
    while j < len(labels) {
        let p = cases[j]
        let r1 = evaluate_case(p[0], p[1], p[2], p[3])
        let r2 = evaluate_case(p[0], p[1], p[2], p[3])
        let mut k = 0
        while k < 4 {
            if r1[k] != r2[k] { det_ok = false }
            k = k + 1
        }
        j = j + 1
    }
    if det_ok == false {
        fails = fails + 1
        println("  [FAIL] determinism — output drift across two evaluations of the same sweep")
    } else {
        println("  [PASS] determinism — byte-identical re-evaluation")
    }

    // log10_margin range
    let mut mmin = margins[0]
    let mut mmax = margins[0]
    let mut mi = 1
    while mi < len(margins) {
        if margins[mi] < mmin { mmin = margins[mi] }
        if margins[mi] > mmax { mmax = margins[mi] }
        mi = mi + 1
    }
    println("")
    println("  log10_margin range across 11 perturbations: [" + fmt("%.4f", mmin) + ", " + fmt("%.4f", mmax) + "]")
    println("  decisive floor                              : " + fmt("%.4f", DECISIVE_LOG10_BF_FLOOR))
    println("  margin to floor (min)                       : " + fmt("%.4f", mmin - DECISIVE_LOG10_BF_FLOOR))
    println("")
    if fails == 0 {
        // .py: n = len(_perturbation_cases()) + 1 = 11 + 1 = 12 (the +1 is the
        // determinism row itself, counted as one extra PASS)
        let n = len(labels) + 1
        println("  --- summary --- " + str(n) + " / " + str(n) + " PASS → verdict: PASS")
        println("__RIBOZYME_A1_1_KINETICS_PERTURBATION__ PASS")
    } else {
        println("  --- summary --- " + str(fails) + " FAIL → verdict: FAIL")
        println("__RIBOZYME_A1_1_KINETICS_PERTURBATION__ FAIL")
    }
}
