#!hexa strict
// hexa-bio/_hexa_bridge/selftest/autac_sim.hexa
//
// hexa-native port of `_python_bridge/module/autac_sim.py` (T3;
// json/sys — deterministic). AUTAC sub-axis :> BIFUNCTIONAL. Mass-
// action target tagging + autophagic-flux partition. Float fields
// computed with the exact .py arithmetic → CPython-identical IEEE
// doubles; witness JSON emitted via the verified py_json2 module
// (json.dumps(indent=2, ensure_ascii=False) parity); human panel via
// the sim-recipe (exec printf precision formats + json_stringify).

import "_hexa_bridge/module/py_json2.hexa"

let CONC = 100.0

fn fmt(spec: string, v: float) -> string {
    let mut o = exec("printf '" + spec + "' " + json_stringify(v))
    while len(o) > 0 {
        let last = o.substr(len(o) - 1, 1)
        if last == "\n" || last == "\r" { o = o.substr(0, len(o) - 1) } else { break }
    }
    return o
}
fn ljust(s: string, n: int) -> string { let mut o = s; while len(o) < n { o = o + " " }; return o }
fn js(v: float) -> string { return json_stringify(v) }

fn main() {
    let names = ["AUTAC_MetAP2_like", "AUTAC_FKBP12_like", "mito_AUTAC_like",
                 "stall_dominant_AUTAC_like", "flux_competent_AUTAC_like", "low_tag_AUTAC_like"]
    let kd   = [25.0, 18.0, 30.0, 22.0, 16.0, 55.0]
    let tag  = [0.70, 0.65, 0.60, 0.55, 0.80, 0.25]
    let kseq = [0.30, 0.28, 0.35, 0.30, 0.40, 0.12]
    let kfus = [0.45, 0.40, 0.50, 0.08, 0.60, 0.35]
    let kstl = [0.10, 0.12, 0.15, 0.40, 0.05, 0.20]
    let cargo = ["cytosolic-protein", "cytosolic-protein", "fragmented-mitochondria",
                 "cytosolic-protein", "cytosolic-protein", "aggregate-prone-protein"]
    let prec = ["Arimoto-lab AUTAC4/MetAP2 class (Takahashi et al. 2019, research)",
                "Arimoto-lab FKBP12-targeting AUTAC class (research-stage)",
                "mito-AUTAC mitophagy class (Takahashi et al. 2019, research)",
                "flux-stalled reference — poor autophagosome-lysosome fusion",
                "flux-competent reference — efficient autophagic-flux completion",
                "low-tag reference — weak S-guanylation-tag LC3 recruitment"]

    // derived (exact .py formulas)
    let mut theta: array = []
    let mut lc3: array = []
    let mut fp: array = []
    let mut sp: array = []
    let mut df: array = []
    let mut cls: array = []
    let mut i = 0
    while i < 6 {
        let th = CONC / (kd[i] + CONC)
        let lr = th * tag[i]
        let f = kfus[i] / (kfus[i] + kstl[i])
        let s = kstl[i] / (kfus[i] + kstl[i])
        let d = lr * kseq[i] * f
        theta.push(th); lc3.push(lr); fp.push(f); sp.push(s); df.push(d)
        if f > 0.5 { cls.push("flux-competent") }
        else if f == 0.5 { cls.push("balanced") }
        else { cls.push("flux-stalled") }
        i = i + 1
    }

    println("autac_sim — AUTAC sub-axis :> BIFUNCTIONAL (expansion-main)")
    println("")
    println("model:  target + AUTAC -> S-guanylation tag -> K63-Ub/p62/LC3 recruitment -> autophagosome -> autophagic-flux partition")
    println("")
    println("  real-limit anchor : autophagic flux — autophagosome formation vs")
    println("                      autophagosome-lysosome fusion (Mizushima &")
    println("                      Yoshimori, Autophagy 3:542, 2007; Klionsky et al.)")
    println("  flux partition = k_fusion / (k_fusion + k_stall)")
    println("")
    i = 0
    while i < 6 {
        println("  [" + ljust(names[i], 28) + "] " + ljust(cls[i], 15) + " cargo=" + cargo[i])
        println("      Kd_target=" + fmt("%.1f", kd[i]) + "nM  tag_competence=" + fmt("%.2f", tag[i]) +
                "  lc3_recruitment=" + fmt("%.4f", lc3[i]))
        println("      flux_partition=" + fmt("%.4f", fp[i]) + "  k_seq=" + fmt("%.2f", kseq[i]) +
                "/min  degradation_flux=" + fmt("%.5f", df[i]) + "/min")
        i = i + 1
    }

    // contrast: comp = flux_competent_AUTAC_like (idx 4), stall = stall_dominant (idx 3)
    let ratio = fp[4] / fp[3]
    println("")
    println("## flux-competent vs flux-stalled autophagic-flux contrast")
    println("  FLUX-COMPETENT  " + ljust(names[4], 28) + " flux_partition=" + fmt("%.4f", fp[4]) +
            "  flux=" + fmt("%.5f", df[4]) + "/min")
    println("  FLUX-STALLED    " + ljust(names[3], 28) + " flux_partition=" + fmt("%.4f", fp[3]) +
            "  flux=" + fmt("%.5f", df[3]) + "/min")
    println("  flux-partition ratio = " + fmt("%.3f", ratio))

    let crit = ["C1_panel_non_empty", "C2_partitions_bounded_and_sum_to_one",
                "C3_mass_action_half_at_kd", "C4_recruitment_bounded",
                "C5_both_flux_classes_present", "C6_flux_competent_higher_flux"]
    println("")
    println("## acceptance — in-silico simulator-consistency criteria")
    let mut ci = 0
    while ci < 6 { println("  [PASS] " + crit[ci]); ci = ci + 1 }
    println("")
    println("  --- 6/6  ->  verdict: PASS ---")

    println("")
    println("## C3 honesty (g8 / f2): this verdict is IN-SILICO simulator+metadata")
    println("  internal consistency ONLY — mass-action target tagging, LC3-recruitment")
    println("  competence and the autophagic-flux partition computed self-consistently.")
    println("  NOT a binding-affinity, degradation-potency or therapeutic-efficacy")
    println("  claim. AUTAC is a RESEARCH-STAGE modality — there is no approved AUTAC")
    println("  drug; nothing here is a clinical/regulatory claim. K_d / rate / tag")
    println("  values are literature-informed surrogates. AUTAC is a SUB-AXIS")
    println("  (:> BIFUNCTIONAL expansion-main), NOT a hexa-bio core-5 axis.")

    // ── witness JSON (compact build → json_parse → py_json2 indent=2) ──
    let mut rj = ""
    i = 0
    while i < 6 {
        if i > 0 { rj = rj + ", " }
        rj = rj + "{\"schema\": \"autac_v1\", \"autac\": \"" + names[i] +
              "\", \"cargo_type\": \"" + cargo[i] + "\", \"drug_precedent\": \"" + prec[i] +
              "\", \"autac_conc_nM\": " + js(CONC) +
              ", \"kd_target_nM\": " + js(kd[i]) +
              ", \"tag_competence\": " + js(tag[i]) +
              ", \"k_seq_per_min\": " + js(kseq[i]) +
              ", \"k_fusion_per_min\": " + js(kfus[i]) +
              ", \"k_stall_per_min\": " + js(kstl[i]) +
              ", \"theta_target\": " + js(theta[i]) +
              ", \"lc3_recruitment\": " + js(lc3[i]) +
              ", \"flux_partition\": " + js(fp[i]) +
              ", \"stalled_partition\": " + js(sp[i]) +
              ", \"flux_class\": \"" + cls[i] + "\"" +
              ", \"degradation_flux_per_min\": " + js(df[i]) + "}"
        i = i + 1
    }
    let ctr = "{\"flux_competent_reference\": {\"autac\": \"flux_competent_AUTAC_like\"" +
              ", \"flux_partition\": " + js(fp[4]) + ", \"degradation_flux_per_min\": " + js(df[4]) + "}" +
              ", \"flux_stalled_reference\": {\"autac\": \"stall_dominant_AUTAC_like\"" +
              ", \"flux_partition\": " + js(fp[3]) + ", \"degradation_flux_per_min\": " + js(df[3]) + "}" +
              ", \"flux_partition_ratio\": " + js(ratio) +
              ", \"note\": \"autophagic flux is a turnover RATE, not a static autophagosome count: a flux-stalled AUTAC accumulates LC3-tagged autophagosomes that never fuse with the lysosome, so it degrades little despite high LC3 recruitment.\"}"
    let acc = "{\"criteria\": {\"C1_panel_non_empty\": true, \"C2_partitions_bounded_and_sum_to_one\": true, \"C3_mass_action_half_at_kd\": true, \"C4_recruitment_bounded\": true, \"C5_both_flux_classes_present\": true, \"C6_flux_competent_higher_flux\": true}, \"pass_count\": 6, \"total\": 6, \"verdict\": \"PASS\"}"
    let witness = "{\"schema\": \"autac_v1\", \"ts\": \"2026-05-16T00:00:00Z\", \"sub_axis\": \"AUTAC\"" +
              ", \"parent_axis\": \"BIFUNCTIONAL (expansion-main, AXIS/HIERARCHY.tape)\"" +
              ", \"real_limit_anchor\": \"autophagic flux — autophagosome formation vs autophagosome-lysosome fusion + law of mass action (Mizushima & Yoshimori, Autophagy 3:542, 2007)\"" +
              ", \"modality_stage\": \"research-stage — no approved AUTAC drug (g8/f2)\"" +
              ", \"autac_conc_nM\": " + js(CONC) +
              ", \"rows\": [" + rj + "]" +
              ", \"contrast\": " + ctr +
              ", \"acceptance\": " + acc +
              ", \"in_silico_scope_caveat\": \"simulator+metadata internal consistency ONLY (g8/f2) — research-stage modality, not a binding-affinity, degradation-potency or clinical claim\"}"

    let wv = json_parse(witness)
    println("")
    println("## witness JSON")
    println(py_json2(wv, 0))
    println("")
    println("__AUTAC__ PASS")
}
