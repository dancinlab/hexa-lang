{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hexa-bio/bifunctional/spec/ternary_complex_v1.schema.json",
  "title": "bifunctional_ternary_complex_v1 — BIFUNCTIONAL axis ternary-complex-sim output",
  "description": "Output schema for _python_bridge/module/bifunctional_ternary_complex_sim.py. BIFUNCTIONAL is an EXPANSION-MAIN axis (NOT core-5). A PASS row verifies IN-SILICO simulator+metadata consistency ONLY (mass-action three-body ternary-equilibrium algebra; the cooperativity-alpha dependence; the bell-shaped hook curve) — never a therapeutic/degradation-efficacy/DC50/Dmax/regulatory claim (hexa-bio AGENTS.tape g8_in_silico_only / f2).",
  "type": "object",
  "required": ["schema", "ts", "axis", "verdict", "real_limit_anchors",
               "cooperativity_verification", "hook_verification",
               "acceptance_criteria"],
  "properties": {
    "schema": {"type": "string", "const": "bifunctional_ternary_complex_v1"},
    "ts": {"type": "string", "description": "fixed timestamp — deterministic witness"},
    "axis": {"type": "string", "const": "BIFUNCTIONAL"},
    "axis_layer": {
      "type": "string",
      "description": "expansion-layer marker — must declare NOT core-5",
      "pattern": "expansion-main"
    },
    "version": {"type": "string"},
    "real_limit_anchors": {
      "type": "object",
      "description": "literature real-limit anchors (g1 real-limits-first)",
      "required": ["hook_effect_citation", "cooperativity_alpha_citation"],
      "properties": {
        "hook_effect_citation": {"type": "string"},
        "hook_effect_thermodynamics_citation": {"type": "string"},
        "cooperativity_alpha_citation": {"type": "string"}
      }
    },
    "model_parameters": {
      "type": "object",
      "description": "illustrative modeling magnitudes — NOT measured drug constants (g3/f1)",
      "properties": {
        "target_total_um": {"type": "number", "exclusiveMinimum": 0},
        "e3_total_um": {"type": "number", "exclusiveMinimum": 0},
        "kd_target_um": {"type": "number", "exclusiveMinimum": 0},
        "kd_e3_um": {"type": "number", "exclusiveMinimum": 0},
        "note": {"type": "string"}
      }
    },
    "cooperativity_scan": {
      "type": "array",
      "description": "ternary-complex concentration vs cooperativity factor alpha at a fixed degrader dose",
      "items": {
        "type": "object",
        "required": ["alpha", "degrader_dose_um", "ternary_TDE_um"],
        "properties": {
          "alpha": {"type": "number", "exclusiveMinimum": 0},
          "degrader_dose_um": {"type": "number", "minimum": 0},
          "ternary_TDE_um": {"type": "number", "minimum": 0},
          "binary_TD_um": {"type": "number", "minimum": 0},
          "binary_DE_um": {"type": "number", "minimum": 0}
        }
      }
    },
    "cooperativity_verification": {
      "type": "object",
      "required": ["monotone_non_decreasing_in_alpha", "pass"],
      "properties": {
        "monotone_non_decreasing_in_alpha": {"type": "boolean"},
        "violations": {"type": "array", "items": {"type": "string"}},
        "alpha_one_is_reference": {"type": "boolean"},
        "pass": {"type": "boolean"}
      }
    },
    "dose_scan_hook": {
      "type": "array",
      "description": "ternary-complex concentration vs total degrader dose — the bell-shaped hook curve",
      "items": {
        "type": "object",
        "required": ["degrader_dose_um", "ternary_TDE_um"],
        "properties": {
          "degrader_dose_um": {"type": "number", "minimum": 0},
          "ternary_TDE_um": {"type": "number", "minimum": 0},
          "binary_TD_um": {"type": "number", "minimum": 0},
          "binary_DE_um": {"type": "number", "minimum": 0},
          "free_degrader_um": {"type": "number", "minimum": 0}
        }
      }
    },
    "hook_verification": {
      "type": "object",
      "description": "the hook effect — a single interior maximum (rise then fall)",
      "required": ["interior_maximum", "rising_arm", "falling_arm_hook",
                   "non_monotonic_bell_shaped", "pass"],
      "properties": {
        "peak_index": {"type": "integer", "minimum": 0},
        "n_dose_points": {"type": "integer", "minimum": 1},
        "peak_dose_um": {"type": "number", "minimum": 0},
        "peak_ternary_TDE_um": {"type": "number", "minimum": 0},
        "low_dose_ternary_um": {"type": "number", "minimum": 0},
        "high_dose_ternary_um": {"type": "number", "minimum": 0},
        "interior_maximum": {"type": "boolean"},
        "rising_arm": {"type": "boolean"},
        "falling_arm_hook": {"type": "boolean"},
        "high_dose_binary_saturation": {"type": "boolean"},
        "non_monotonic_bell_shaped": {"type": "boolean"},
        "pass": {"type": "boolean"}
      }
    },
    "degrader_metadata": {
      "type": "array",
      "description": "representative bifunctional degraders by their OWN drug precedent (g3/f1 — never lattice-fit, never efficacy claims)",
      "items": {
        "type": "object",
        "required": ["name", "modality", "target", "e3_ligase", "status"],
        "properties": {
          "name": {"type": "string"},
          "modality": {"type": "string"},
          "target": {"type": "string"},
          "e3_ligase": {"type": "string"},
          "status": {"type": "string"},
          "developer": {"type": "string"}
        }
      }
    },
    "falsifiers": {
      "type": "object",
      "description": "F-BIFUNCTIONAL-1/2/3 boolean HOLD flags",
      "additionalProperties": {"type": "boolean"}
    },
    "acceptance_criteria": {
      "type": "object",
      "description": "C1..C7 pass/fail booleans",
      "additionalProperties": {"type": "boolean"}
    },
    "pass_count": {"type": "integer", "minimum": 0},
    "total_criteria": {"type": "integer", "minimum": 1},
    "verdict": {"type": "string", "enum": ["PASS", "FAIL"]},
    "lattice_stance": {
      "type": "string",
      "description": "honest n=6 stance — must affirm no lattice derivation (g2/f1/f_lattice_fit)"
    },
    "in_silico_scope": {
      "type": "string",
      "description": "g8/f2 in-silico-only scope caveat"
    }
  },
  "additionalProperties": true
}
