#!hexa strict
// bifunctional/module/bifunctional.hexa — BIFUNCTIONAL verb
//
// LAYER: EXPANSION-MAIN axis (NOT core-5). BIFUNCTIONAL joins COVALENT,
//        METALLODRUG, and OLIGONUCLEOTIDE on the AXIS/HIERARCHY.tape
//        expansion layer. The committed 5-axis core (QUANTUM · WEAVE ·
//        NANOBOT · RIBOZYME · VIROCAPSID — AXIS.tape) is UNCHANGED by
//        this axis.
//
// HEXA-family role: bifunctional / molecular-glue degraders (targeted
// protein degradation). A bifunctional degrader does NOT inhibit by
// occupancy — it bridges a target protein and an E3 ubiquitin ligase
// into a TERNARY complex (target — degrader — E3) that drives target
// poly-ubiquitination and proteasomal degradation. Modality precedent
// (its OWN invariants — g3/f1, never lattice-fit): PROTAC clinical
// agents ARV-471 (vepdegestrant, ER PROTAC) / ARV-110 (bavdegalutamide,
// AR PROTAC) · lenalidomide / thalidomide (CRBN molecular glues) ·
// RIBOTAC (RNase-recruiting bifunctional, research stage).
//
// Real-limit anchors (AGENTS.tape g1 real-limits-first):
//   - the hook effect — the bell-shaped non-monotonic ternary-complex
//     dose response (Douglass et al., J Am Chem Soc 2013;135:6092-6099 —
//     three-body binding-equilibrium model; Han, J Biol Chem 2020;
//     295:15280-15291 — closed-form ternary-complex / hook treatment)
//   - the ternary-complex cooperativity factor alpha
//     (Gadd et al., Nat Chem Biol 2017;13:514-521 — VHL-MZ1-BRD4
//      PROTAC ternary-complex crystal structure + ITC)
//
// n=6 lattice stance (g2 lattice-is-tool · f_lattice_fit): a ternary
// complex has three bodies because a heterobifunctional degrader bridges
// exactly one target and one E3 ligase — that is the modality's
// definition. The cooperativity alpha and the hook-effect dose maximum
// are chemical-equilibrium results. NEITHER alpha, nor any concentration,
// nor any K_d, nor the count of clinical PROTACs is derived from the
// n=6 lattice. This module performs NO lattice arithmetic.
//
// In-silico scope (g8/f2): a PASS verifies IN-SILICO simulator+metadata
// consistency ONLY (mass-action ternary-equilibrium algebra; the
// cooperativity alpha dependence; the bell-shaped hook curve) — NEVER a
// therapeutic / degradation-efficacy / DC50 / Dmax / immunogenic /
// regulatory claim. The BIFUNCTIONAL axis is scientifically UNPROVEN at
// the wet-lab boundary.
//
// Sentinels:
//   __HEXA_BIO_BIFUNCTIONAL__ PASS    — module loaded + printed status
//   the Python bridge prints __BIFUNCTIONAL_TERNARY_COMPLEX__ PASS|FAIL

let VERSION = "1.0.0"
let MODULE  = "bifunctional"
let LAYER   = "expansion-main (NOT core-5)"

fn _root() -> str {
    let r = env("HEXA_BIO_ROOT")
    if r.len() > 0 { return r }
    let inferred = exec("dirname \"$(dirname \"$(dirname \"$0\")\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return env("HOME") + "/.hexa-bio"  // @allow-devpath
}

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _python_path(script: str) -> str {
    let root = _root()
    return root + "/_python_bridge/module/" + script
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + _shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _print_status() {
    println("  status: EXPANSION-MAIN axis v" + VERSION + " (NOT core-5)")
    println("          joins COVALENT + METALLODRUG + OLIGONUCLEOTIDE on the")
    println("          AXIS/HIERARCHY.tape expansion layer; AXIS.tape core-5")
    println("          SSOT UNCHANGED")
}

fn _print_real_limits() {
    println("  real-limit anchors (AGENTS.tape g1 — real-limits-first):")
    println("    the hook effect — bell-shaped non-monotonic ternary-complex")
    println("    dose response")
    println("      (Douglass et al., J Am Chem Soc 2013;135:6092-6099 —")
    println("       three-body binding-equilibrium model; Han, J Biol Chem")
    println("       2020;295:15280-15291 — closed-form ternary/hook treatment)")
    println("    ternary-complex cooperativity factor alpha")
    println("      (Gadd et al., Nat Chem Biol 2017;13:514-521 — VHL-MZ1-BRD4")
    println("       PROTAC ternary-complex crystal structure + ITC)")
}

fn _print_modality() {
    println("  bifunctional-degrader modality — own drug precedent")
    println("  (g3/f1, never lattice-fit):")
    println("    ARV-471      PROTAC (ER degrader)     clinical (Arvinas/Pfizer)")
    println("    ARV-110      PROTAC (AR degrader)     clinical (Arvinas)")
    println("    lenalidomide CRBN molecular glue      marketed (multiple myeloma)")
    println("    thalidomide  CRBN molecular glue      marketed (IMiD class)")
    println("    RIBOTAC      RNase-recruiting bifunc  research (crosses RIBOZYME)")
}

fn _print_falsifiers() {
    println("  falsifiers (HEXA-BIFUNCTIONAL.tape §5):")
    println("    F-BIFUNCTIONAL-1  cooperativity-alpha monotonicity fidelity")
    println("                      (every run; FAIL = falsified)")
    println("    F-BIFUNCTIONAL-2  the hook effect — non-monotonic ternary")
    println("                      dose response (every run; FAIL = falsified)")
    println("    F-BIFUNCTIONAL-3  ternary equilibrium is mass-action, not")
    println("                      lattice-derived (standing; review 2026-11-16)")
}

fn _print_lattice_stance() {
    println("  n=6 lattice stance (g2/f_lattice_fit): a ternary complex has")
    println("  three bodies because a heterobifunctional degrader bridges one")
    println("  target and one E3 ligase — the modality definition. The")
    println("  cooperativity alpha and the hook-effect dose maximum are")
    println("  chemical-equilibrium results. NEITHER alpha, nor any K_d, nor")
    println("  any concentration, nor the count of clinical PROTACs is derived")
    println("  from the n=6 lattice. No lattice arithmetic is performed.")
}

fn _print_in_silico_caveat() {
    println("  in-silico scope (g8/f2): a PASS verifies IN-SILICO simulator +")
    println("  metadata consistency ONLY (mass-action ternary-equilibrium")
    println("  algebra; the cooperativity alpha dependence; the bell-shaped")
    println("  hook curve). It is NOT a therapeutic / degradation-efficacy /")
    println("  DC50 / Dmax / immunogenic / regulatory claim. The BIFUNCTIONAL")
    println("  axis is scientifically UNPROVEN at the wet-lab boundary.")
}

fn run_ternary_sim() -> str {
    // Opt-in gate (ribozyme/weave/virocapsid/metallodrug precedent):
    // HEXA_BIO_WITH_NUMPY=1 signals local python3 is available. The sim
    // is stdlib-only (the env flag is a uniform opt-in convention).
    let with_numpy = env("HEXA_BIO_WITH_NUMPY")
    if with_numpy != "1" {
        println("[bifunctional] HEXA_BIO_WITH_NUMPY != 1 — ternary sim skipped")
        println("[bifunctional] (set HEXA_BIO_WITH_NUMPY=1 to run")
        println("[bifunctional]  bifunctional_ternary_complex_sim.py)")
        println("[bifunctional] cached result (deterministic, 2026-05-16):")
        println("[bifunctional]   ternary dose curve is non-monotonic (hook")
        println("[bifunctional]     effect): rises then falls, interior maximum")
        println("[bifunctional]   peak ternary concentration is monotone in the")
        println("[bifunctional]     cooperativity factor alpha")
        println("[bifunctional]   acceptance: 7/7 PASS · verdict PASS")
        println("[bifunctional]   __BIFUNCTIONAL_TERNARY_COMPLEX__ PASS")
        return "skipped-no-opt-in"
    }
    let script = _python_path("bifunctional_ternary_complex_sim.py")
    if _file_exists(script) == false {
        eprintln("[bifunctional] ERROR: bridge script missing: " + script)
        return "error-missing-script"
    }
    let raw = exec("python3 " + _shq(script) + " 2>&1")
    println(raw.trim())
    return "ran"
}

fn cmd_bifunctional(args: [str]) {
    println("hexa-bio " + MODULE + " " + VERSION + " — bifunctional / molecular-glue degraders")
    println("")

    let mut mode = "skeleton"
    let mut i = 0
    while i < args.len() {
        let a = args[i]
        if a == "--ternary-sim" { mode = "ternary" }
        i = i + 1
    }

    if mode == "skeleton" {
        _print_status()
        println("")
        _print_real_limits()
        println("")
        _print_modality()
        println("")
        _print_falsifiers()
        println("")
        _print_lattice_stance()
        println("")
        _print_in_silico_caveat()
        println("")
        println("usage: hexa-bio bifunctional [--ternary-sim]")
        println("[bifunctional] no action specified — printed status/limits/")
        println("[bifunctional] modality/falsifier/caveat tables only")
        println("__HEXA_BIO_BIFUNCTIONAL__ PASS")
        return
    }

    if mode == "ternary" {
        println("--- BIFUNCTIONAL ternary-complex sim (cooperativity + hook effect) ---")
        run_ternary_sim()
        println("")
        _print_real_limits()
        println("")
        _print_in_silico_caveat()
        println("")
        println("__HEXA_BIO_BIFUNCTIONAL__ PASS")
    }
}

fn main() {
    let raw = args()
    let mut user: [str] = []
    let mut sidx = -1
    let mut i = 0
    while i < raw.len() {
        if raw[i].ends_with(".hexa") { sidx = i; break }
        i = i + 1
    }
    let mut start = 1
    if sidx >= 0 { start = sidx + 1 }
    let mut k = start
    while k < raw.len() {
        user = user + [raw[k]]
        k = k + 1
    }
    cmd_bifunctional(user)
}
