// stdlib/bio/brenda_soap_test.hexa — measured-oracle gate for the
// brenda-soap-wire extension (cycle 3, 2026-05-25). All assertions
// OFFLINE — no curl shellout, no live BRENDA hit. Pure envelope
// synthesizer + WS-Security MD5 embed + parser-handoff.
//
// 6 cases (mirrors task spec):
//   1. envelope structure        (soap:Body + wsse:Security + tns:<method> present)
//   2. MD5 RFC 1321 test vector  (`hello` → 5d41402abc4b2a76b9719d911017c592)
//   3. SOAPAction header         ("\"<ns>#getKmValue\"" exact)
//   4. Content-Type header       ("text/xml; charset=utf-8" exact)
//   5. parser handoff            (canned XML → brenda_soap_parse_response → cycle-2 fields)
//   6. round-trip integrity      (synthesize envelope → extract Username/Password → byte-equal)
//
// Per @D try-live-or-fallback: 🔵 SUPPORTED-FORMAL gate for the SOAP
// surface. Live-wire 🟠 DEFERRED until credentials manager carries
// `brenda.user` / `brenda.password`.

use "stdlib/bio/brenda"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_eq_f(label: string, want: float, got: float) {
    if want != got {
        let w = to_string(want)
        let g = to_string(got)
        _fail(label, w, g)
    }
}

fn _expect_contains(label: string, hay: string, needle: string) {
    // substring scan; fail if needle absent.
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return }
    if m > n { _fail(label + " (too short)", needle, hay) }
    let mut i = 0
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return }
        i = i + 1
    }
    _fail(label + " (missing)", needle, hay)
}

// Lightweight substring-find for the round-trip case (mirrors brenda's
// own _idx, but kept local to the test file).
fn _find(hay: string, needle: string, from: int) -> int {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return from }
    if m > n { return -1 }
    let mut i = from
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return i }
        i = i + 1
    }
    return -1
}

// Extract substring between `<tag>` and `</tag>` (no namespace prefix).
fn _between(hay: string, open: string, close: string) -> string {
    let a = _find(hay, open, 0)
    if a < 0 { return "" }
    let a2 = a + len(open)
    let z = _find(hay, close, a2)
    if z < 0 { return "" }
    return hay.substring(a2, z)
}

fn main() {
    // ── Case 1 — envelope structure ─────────────────────────────────
    let env_km = brenda_soap_envelope(
        "getKmValue",
        "alice@example.org",
        "hello",
        brenda_soap_arg_km("3.1.1.7", "Homo sapiens", "acetylcholine")
    )
    _expect_contains("env xml prolog", env_km, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>")
    _expect_contains("env soap:Envelope open", env_km, "<soap:Envelope")
    _expect_contains("env soap:Header open", env_km, "<soap:Header>")
    _expect_contains("env soap:Body open", env_km, "<soap:Body>")
    _expect_contains("env wsse:Security", env_km, "<wsse:Security")
    _expect_contains("env wsse:UsernameToken", env_km, "<wsse:UsernameToken>")
    _expect_contains("env tns:getKmValue open", env_km, "<tns:getKmValue>")
    _expect_contains("env tns:getKmValue close", env_km, "</tns:getKmValue>")
    _expect_contains("env ecNumber arg", env_km, "<ecNumber>3.1.1.7</ecNumber>")
    _expect_contains("env organism arg", env_km, "<organism>Homo sapiens</organism>")
    _expect_contains("env substrate arg", env_km, "<substrate>acetylcholine</substrate>")

    // ── Case 2 — MD5 RFC 1321 test vectors ──────────────────────────
    _expect_eq("md5 \"hello\"",
        "5d41402abc4b2a76b9719d911017c592",
        _md5_hex("hello"))
    _expect_eq("md5 \"\" (empty)",
        "d41d8cd98f00b204e9800998ecf8427e",
        _md5_hex(""))
    _expect_eq("md5 \"abc\" (RFC1321 A.5)",
        "900150983cd24fb0d6963f7d28e17f72",
        _md5_hex("abc"))
    // Verify the envelope embeds the MD5 hex (not the plaintext).
    _expect_contains("env embeds md5(hello) in Password",
        env_km,
        "<wsse:Password>5d41402abc4b2a76b9719d911017c592</wsse:Password>")
    // Plaintext "hello" must NOT appear in the password element.
    // (Username may legitimately contain other strings — restrict scan to
    // the Password element bracket.)
    let pw_inner = _between(env_km, "<wsse:Password>", "</wsse:Password>")
    _expect_eq("Password element = md5 hex (no plaintext)",
        "5d41402abc4b2a76b9719d911017c592",
        pw_inner)

    // ── Case 3 — SOAPAction header ──────────────────────────────────
    let hdrs = brenda_soap_headers("getKmValue")
    let want_action = "\"https://www.brenda-enzymes.org/soap/brenda_server.php#getKmValue\""
    _expect_eq("SOAPAction exact (quoted IRI#method)",
        want_action,
        to_string(hdrs["SOAPAction"]))

    // ── Case 4 — Content-Type header ────────────────────────────────
    _expect_eq("Content-Type exact",
        "text/xml; charset=utf-8",
        to_string(hdrs["Content-Type"]))

    // ── Case 5 — parser handoff (canned XML → BrendaEnzyme) ─────────
    // Canned BRENDA-shape response (mirrors the SOAP2 docs). km value
    // here is in millimolar (0.0925 mM = 92.5 μM — matches cycle-2
    // fixture). turnoverNumber is /s. All fields chosen to round-trip
    // against the cycle-2 fixture's float values.
    let fixture_xml = "<?xml version=\"1.0\"?>"
        + "<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">"
        + "<soap:Body>"
        + "<tns:getKmValueResponse>"
        + "<return>"
        + "<ecNumber>3.1.1.7</ecNumber>"
        + "<recommendedName>Acetylcholinesterase</recommendedName>"
        + "<organism>Homo sapiens</organism>"
        + "<substrate>acetylcholine</substrate>"
        + "<kmValue>0.0925</kmValue>"
        + "<turnoverNumber>14000</turnoverNumber>"
        + "<phOptimum>8.0</phOptimum>"
        + "<temperatureOptimum>37.0</temperatureOptimum>"
        + "</return>"
        + "</tns:getKmValueResponse>"
        + "</soap:Body>"
        + "</soap:Envelope>"

    let e = brenda_soap_parse_response(fixture_xml)
    _expect_eq("handoff ec_number",        "3.1.1.7",              e.ec_number)
    _expect_eq("handoff recommended_name", "Acetylcholinesterase", e.recommended_name)
    _expect_eq("handoff organism",         "Homo sapiens",         e.organism)
    _expect_eq("handoff substrate",        "acetylcholine",        e.substrate)
    _expect_eq_f("handoff km_uM",                 92.5,    e.km_uM)
    _expect_eq_f("handoff kcat_per_s",            14000.0, e.kcat_per_s)
    _expect_eq_f("handoff ph_optimum",            8.0,     e.ph_optimum)
    _expect_eq_f("handoff temperature_optimum_C", 37.0,    e.temperature_optimum_C)

    // ── Case 6 — round-trip integrity ───────────────────────────────
    // Synthesize → extract Username/Password elements → assert byte-equal
    // to the inputs we fed (Password = md5 of plaintext, Username = raw).
    let env_rt = brenda_soap_envelope(
        "getTurnoverNumber",
        "bob@uni.edu",
        "abc",
        brenda_soap_arg_kcat("1.1.1.1", "Saccharomyces cerevisiae")
    )
    let user_rt = _between(env_rt, "<wsse:Username>", "</wsse:Username>")
    let pw_rt = _between(env_rt, "<wsse:Password>", "</wsse:Password>")
    _expect_eq("round-trip Username", "bob@uni.edu", user_rt)
    _expect_eq("round-trip Password = md5(\"abc\")",
        "900150983cd24fb0d6963f7d28e17f72",
        pw_rt)
    // Method dispatch round-trip — extract method-name from body open tag.
    _expect_contains("round-trip method dispatch", env_rt, "<tns:getTurnoverNumber>")
    _expect_contains("round-trip kcat arg ecNumber", env_rt, "<ecNumber>1.1.1.1</ecNumber>")
    _expect_contains("round-trip kcat arg organism", env_rt,
        "<organism>Saccharomyces cerevisiae</organism>")

    println("PASS: brenda-soap-wire — 6 OFFLINE cases (envelope · md5 · action · content-type · handoff · round-trip)")
}
