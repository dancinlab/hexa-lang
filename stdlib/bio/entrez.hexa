// stdlib/bio/entrez.hexa — NCBI E-utilities client (db-generic, XML).
//
// Cross-database core of the Entrez Programming Utilities:
//   - `entrez_search(db, term, retmax)` → ID list  (esearch.fcgi)
//   - `entrez_fetch(db, ids)`           → raw response body (efetch.fcgi)
//   - `entrez_summary(db, ids)`         → [EntrezRecord] parsed DocSum (esummary.fcgi)
//   - `entrez_parse_esearch(xml)`       → pure: <Id> children of <IdList>
//   - `entrez_parse_esummary(xml)`      → pure: <DocSum> records into structs
//
// db-generic — dispatches against any Entrez database (nuccore, protein,
// gene, taxonomy, geoprofiles, sra, …). db-specific decoders (e.g.
// PubMed citation flattening) live in their own modules; here we capture
// only the universal DocSum shape:
//   <DocSum><Id>…</Id><Item Name="…" Type="…">…</Item>…</DocSum>
//
// Per @D try-live-or-fallback: callers needing offline determinism feed
// `entrez_parse_esummary` a pre-captured XML body; live verbs shell out
// via http_get and return "" / [] on network failure.
//
// XML strategy: lightweight `<tag>…</tag>` slicing — same approach as
// stdlib/research/arxiv.hexa. `_item_by_name` handles Item attr lookup.

struct EntrezRecord {
    db: string,       // source database, propagated from caller
    id: string,       // <Id> value (UID for this db)
    summary: string,  // tab-joined "Name=Value" pairs from <Item> children
}

let ENTREZ_BASE = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils"

// ── string utilities (mirror arxiv.hexa) ────────────────────────────

fn _idx(hay: string, needle: string, from: int) -> int {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return from }
    if m > n { return -1 }
    let mut i = from
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return i }
        i = i + 1
    }
    return -1
}

fn _trim(s: string) -> string {
    let n = len(s)
    let mut a = 0
    while a < n {
        let c = s.substring(a, a + 1)
        if c != " " && c != "\t" && c != "\n" && c != "\r" { break }
        a = a + 1
    }
    let mut b = n
    while b > a {
        let c = s.substring(b - 1, b)
        if c != " " && c != "\t" && c != "\n" && c != "\r" { break }
        b = b - 1
    }
    return s.substring(a, b)
}

fn _xml_decode(s: string) -> string {
    let mut out = s
    out = out.replace("&amp;",  "&")
    out = out.replace("&lt;",   "<")
    out = out.replace("&gt;",   ">")
    out = out.replace("&quot;", "\"")
    out = out.replace("&apos;", "'")
    return out
}

// Slice the inner text between the first `<tag>` and matching `</tag>`.
fn _slice_tag(xml: string, tag: string, from: int) -> string {
    let open  = "<"  + tag + ">"
    let close = "</" + tag + ">"
    let a = _idx(xml, open, from)
    if a < 0 { return "" }
    let body_from = a + len(open)
    let b = _idx(xml, close, body_from)
    if b < 0 { return "" }
    return xml.substring(body_from, b)
}

// Next `<DocSum>…</DocSum>` span from `from`. [-1, -1] when none left.
fn _next_docsum(xml: string, from: int) -> [int] {
    let a = _idx(xml, "<DocSum>", from)
    if a < 0 { return [-1, -1] }
    let body_from = a + len("<DocSum>")
    let b = _idx(xml, "</DocSum>", body_from)
    if b < 0 { return [-1, -1] }
    return [body_from, b + len("</DocSum>")]
}

// Inner text of the first `<Item Name="<name>" …>…</Item>` in `xml`.
// Returns "" if not found.
pub fn _item_by_name(xml: string, name: string) -> string {
    let needle = "Name=\"" + name + "\""
    let mut i = 0
    let n = len(xml)
    while i < n {
        let a = _idx(xml, "<Item ", i)
        if a < 0 { return "" }
        let close_open = _idx(xml, ">", a)
        if close_open < 0 { return "" }
        let head = xml.substring(a, close_open)
        if _idx(head, needle, 0) >= 0 {
            let body_from = close_open + 1
            let b = _idx(xml, "</Item>", body_from)
            if b < 0 { return "" }
            return xml.substring(body_from, b)
        }
        i = close_open + 1
    }
    return ""
}

// Flatten all `<Item Name="X" …>V</Item>` pairs in `block` into a
// single "X=V\tX2=V2…" string. Stable order = source order.
fn _items_flat(block: string) -> string {
    let mut out = ""
    let mut i = 0
    let n = len(block)
    while i < n {
        let a = _idx(block, "<Item ", i)
        if a < 0 { break }
        let close_open = _idx(block, ">", a)
        if close_open < 0 { break }
        let head = block.substring(a, close_open)
        let np = _idx(head, "Name=\"", 0)
        if np < 0 { i = close_open + 1; continue }
        let np_from = np + len("Name=\"")
        let np_end = _idx(head, "\"", np_from)
        if np_end <= np_from { i = close_open + 1; continue }
        let nm = head.substring(np_from, np_end)
        let body_from = close_open + 1
        let b = _idx(block, "</Item>", body_from)
        if b < 0 { break }
        let v = _xml_decode(_trim(block.substring(body_from, b)))
        let pair = nm + "=" + v
        if len(out) == 0 { out = pair } else { out = out + "\t" + pair }
        i = b + len("</Item>")
    }
    return out
}

// Comma-join an id list. Entrez efetch/esummary accept up to ~200 ids
// per call this way; chunking is the caller's responsibility.
fn _join_ids(ids: [string]) -> string {
    let mut out = ""
    let mut i = 0
    let n = len(ids)
    while i < n {
        if len(out) == 0 { out = ids[i] } else { out = out + "," + ids[i] }
        i = i + 1
    }
    return out
}

// ── public surface ──────────────────────────────────────────────────

// Parse an esearch.fcgi XML body: the `<Id>` children of the first
// `<IdList>` block. Safe on offline fixtures; never networks.
pub fn entrez_parse_esearch(xml: string) -> [string] {
    let mut out = []
    if len(xml) == 0 { return out }
    let idlist = _slice_tag(xml, "IdList", 0)
    if len(idlist) == 0 { return out }
    let mut i = 0
    let n = len(idlist)
    while i < n {
        let a = _idx(idlist, "<Id>", i)
        if a < 0 { break }
        let body_from = a + len("<Id>")
        let b = _idx(idlist, "</Id>", body_from)
        if b < 0 { break }
        out.push(_trim(idlist.substring(body_from, b)))
        i = b + len("</Id>")
    }
    return out
}

// Parse an esummary.fcgi XML body into EntrezRecord rows. `db` is left
// empty here (caller-supplied — NCBI does not echo it in the response);
// `entrez_summary` fills it in before returning. Pure; offline-safe.
pub fn entrez_parse_esummary(xml: string) -> [EntrezRecord] {
    let mut out = []
    if len(xml) == 0 { return out }
    let mut cursor = 0
    while true {
        let span = _next_docsum(xml, cursor)
        let s = span[0]
        let e = span[1]
        if s < 0 { break }
        let body = xml.substring(s, e - len("</DocSum>"))
        cursor = e
        let id  = _trim(_slice_tag(body, "Id", 0))
        let sum = _items_flat(body)
        out.push(EntrezRecord{ db: "", id: id, summary: sum })
    }
    return out
}

// Live esearch: returns the id list, or [] on network failure / empty
// term. `retmax` clamped to [1, 100000] per NCBI guidelines.
pub fn entrez_search(db: string, term: string, retmax: int) -> [string] {
    if len(db) == 0 { return [] }
    if len(term) == 0 { return [] }
    let mut n = retmax
    if n < 1 { n = 1 }
    if n > 100000 { n = 100000 }
    let url = ENTREZ_BASE + "/esearch.fcgi?db=" + db
        + "&term=" + term.replace(" ", "+")
        + "&retmax=" + to_string(n)
    return entrez_parse_esearch(http_get(url))
}

// Live efetch: returns the raw response body verbatim. db-specific
// decoders (GenBank flat-file, FASTA, GenPept, …) are the caller's job
// since efetch retmode/rettype space is too large to wrap generically.
pub fn entrez_fetch(db: string, ids: [string]) -> string {
    if len(db) == 0 { return "" }
    if len(ids) == 0 { return "" }
    let url = ENTREZ_BASE + "/efetch.fcgi?db=" + db
        + "&id=" + _join_ids(ids)
        + "&retmode=xml"
    return http_get(url)
}

// Live esummary: returns parsed EntrezRecord rows, or [] on failure.
// Each record's `db` field is filled in from the `db` argument so
// downstream pipelines can fan out to multi-db worklists.
pub fn entrez_summary(db: string, ids: [string]) -> [EntrezRecord] {
    if len(db) == 0 { return [] }
    if len(ids) == 0 { return [] }
    let url = ENTREZ_BASE + "/esummary.fcgi?db=" + db
        + "&id=" + _join_ids(ids)
    let recs = entrez_parse_esummary(http_get(url))
    let mut out = []
    let mut i = 0
    while i < len(recs) {
        let r = recs[i]
        out.push(EntrezRecord{ db: db, id: r.id, summary: r.summary })
        i = i + 1
    }
    return out
}
