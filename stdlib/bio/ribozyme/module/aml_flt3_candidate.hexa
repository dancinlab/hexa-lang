#!hexa strict
//
// ribozyme/module/aml_flt3_candidate.hexa — C2 cell R·α (RIBOZYME × α=AML).
//
// HEXA-NATIVE port of _python_bridge/module/ribozyme_aml_flt3_candidate.py
// (R5 sunset 16/57, 2026-05-07). FLT3-ITD-targeting hammerhead ribozyme
// candidate spec verified against F-RB-4 kinetics simulator. IN-SILICO
// numerical-primitive verification ONLY.
//
// Per cross-cutting Require (R5) raw 9 hexa-only: hexa stdlib only.

use "ribozyme/module/kinetics_simulation"

let ARM_5P_12NT = "GCCAUACGGUUC"
let ARM_3P_12NT = "AGCAUUGCCAGA"

fn registry_path_self() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn build_candidate() {
    let c = {}
    c["target_disease"] = "alpha_AML"
    c["target_oncogene"] = "FLT3-ITD"
    c["target_oncogene_full_name"] = "FLT3 internal tandem duplication, exon 14 juxtamembrane domain"
    c["target_mrna_reference"] = "NM_004119 (FLT3 RefSeq)"
    c["construct_class"] = "hammerhead-minimal trans-cleaving ribozyme"
    c["construct_topology"] = "5'-arm(12nt)-CATALYTIC_CORE(12nt)-3'-arm(12nt)"
    c["catalytic_core_12nt"] = CATALYTIC_CORE_12NT
    c["substrate_cleavage_motif"] = "NUH↓ triplet (canonical hammerhead, N=any, H=A/C/U)"
    c["substrate_recognition_arm_5p_12nt"] = ARM_5P_12NT
    c["substrate_recognition_arm_3p_12nt"] = ARM_3P_12NT
    c["full_designed_ribozyme_36nt"] = ARM_5P_12NT + CATALYTIC_CORE_12NT + ARM_3P_12NT
    c["n6_invariant_role"] = "σ(6)=12 catalytic-core nucleotide count preserved; τ(6)=4 reaction states (substrate-bound / TS / cleaved / product-released) inherited from F-RB-4 baseline."
    let anchors = []
    anchors.push("FLT3-ITD epidemiology: ~25-30% AML prevalence, recurrent driver")
    anchors.push("Hammerhead ribozyme design: Symons 1981; Hertel & Uhlenbeck 1992")
    anchors.push("RefSeq mRNA: NM_004119 (FLT3 transcript variant 1, public)")
    anchors.push("k_cat range: 0.1-10 min^-1 canonical hammerhead under Mg2+ 10 mM")
    c["source_literature_anchors"] = anchors
    let handoff = []
    handoff.push("ribozyme delivery (lipid nanoparticle / AAV / exosome) → NANOBOT or VIROCAPSID at next layer")
    handoff.push("in-cell efficacy / off-target profiling / pharmacokinetics → wet-lab (out-of-repo, C3+)")
    c["downstream_layer_handoff"] = handoff
    return c
}

fn verify_with_ribozyme_sim(t_end: float, dt: float, S_eff: float) {
    let sample_times = []
    let mut si = 0
    while si < len(SAMPLE_TIMES) {
        if SAMPLE_TIMES[si] <= t_end { sample_times.push(SAMPLE_TIMES[si]) }
        si = si + 1
    }
    if len(sample_times) == 0 || sample_times[len(sample_times) - 1] != t_end {
        sample_times.push(t_end)
    }
    let n6_check = n6_invariant_check()
    let rk4_result = integrate("rk4", t_end, dt, sample_times, S_eff)
    let euler_result = integrate("euler", t_end, dt, sample_times, S_eff)
    let kinetics = compute_kcat_KM(rk4_result, S_eff)
    let pass_eval = evaluate_pass(rk4_result, euler_result, kinetics)
    let v = {}
    v["n6_check"] = n6_check
    v["kinetics"] = kinetics
    v["pass_eval"] = pass_eval
    v["rk4_final"] = rk4_result["final"]
    v["samples_count"] = len(rk4_result["samples_t"])
    return v
}

fn build_witness(verify_result, candidate) {
    let pe = verify_result["pass_eval"]
    let kin = verify_result["kinetics"]
    let overall_pass = pe["overall_pass"]

    let kcat_KM = kin["kcat_over_KM"]
    let mut eigen_pass = false
    if (type_of(kcat_KM) == "float" || type_of(kcat_KM) == "int") && to_float(kcat_KM) <= 1.0e9 {
        eigen_pass = true
    }

    let verification = {}
    verification["simulator"] = "ribozyme_kinetics_simulation (F-RB-4 PASS, cycle 24 C0b)"
    verification["kinetics_pass"] = overall_pass
    verification["kcat_per_s"] = kin["k_cat"]
    verification["kcat_per_min"] = kin["k_cat_per_min"]
    verification["K_M_uM"] = kin["K_M_uM"]
    verification["kcat_over_KM"] = kcat_KM
    verification["eigen_hammes_ceiling_M_minus1_s_minus1"] = 1.0e9
    verification["diffusion_margin_log10"] = kin["diffusion_margin_log10"]
    verification["eigen_hammes_pass"] = eigen_pass
    verification["pass_count"] = pe["pass_count"]
    verification["total_count"] = pe["total_count"]

    let disclosures = []
    disclosures.push("Substrate-recognition arms (12-nt 5' and 12-nt 3') are illustrative reverse-complements of public FLT3 juxtamembrane region context — they demonstrate the design-step and arm-length convention, not a clinically validated targeting sequence.")
    disclosures.push("Kinetics PASS (k_cat/K_M ≤ Eigen-Hammes ceiling, mass conservation, RK4-Euler agreement) is sequence-INDEPENDENT in the F-RB-4 model — the rate constants {k1, k_minus1, k2, k3, k4} are derived from Eyring TST + Turner NN, not from explicit substrate-arm pairing.")
    disclosures.push("Therefore a PASS here verifies that the simulator + candidate metadata combination is internally consistent — it does NOT verify FLT3-ITD-specific in-cell cleavage activity, off-target profile, in-vivo pharmacokinetics, immunogenicity, or therapeutic efficacy.")
    disclosures.push("Ribozyme delivery (lipid nanoparticle / AAV / exosome) is out-of-scope at this primitive — handoff to NANOBOT (delivery actuator) or VIROCAPSID (gene cage) at next composition layer.")
    disclosures.push("16-cell matrix R·α at IN-SILICO grade only. Cure-grade requires C3+ external (CRO / wet-lab / regulatory / clinical).")

    let mut sentinel = "__R_ALPHA_AML_C2__ FAIL"
    if overall_pass { sentinel = "__R_ALPHA_AML_C2__ PASS" }

    let row = {}
    row["schema"] = "raw_77_c2_ribozyme_aml_v1"
    row["ts"] = utc_iso_now()
    row["cycle"] = 25
    row["phase"] = "c2-r-alpha-aml-flt3-itd-ribozyme-candidate"
    row["domain"] = "hexa-ribozyme"
    row["matrix_cell"] = "R_alpha"
    row["disease_class"] = "alpha_AML"
    row["candidate"] = candidate
    row["verification"] = verification
    row["n6_invariant"] = verify_result["n6_check"]
    row["in_silico_grade_disclose"] = "IN-SILICO stage only. Numerical-primitive verification of F-RB-4 simulator under candidate-spec metadata. No clinical, regulatory, immunological, or wet-lab claim."
    row["raw_91_c3_disclose"] = disclosures
    row["raw_47_cross_repo"] = "Imports ribozyme_kinetics_simulation (F-RB-4 PASS, cycle 24 C0b) as module; reuses its integrate/compute_kcat_KM/evaluate_pass API without modification (R2 preserved)."
    row["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    row["raw_138_sentinel"] = sentinel
    row["raw_77_append_only"] = true
    return row
}

fn parse_argv_cand(av) {
    let r = {}
    r["t_end"] = 600.0
    r["dt"] = 0.01
    r["no_emit"] = false
    r["quiet"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--no-emit" { r["no_emit"] = true }
        else if a == "--quiet" { r["quiet"] = true }
        else if a == "--t-end" { if i + 1 < len(av) { r["t_end"] = to_float(av[i + 1]); i = i + 1 } }
        else if a == "--dt" { if i + 1 < len(av) { r["dt"] = to_float(av[i + 1]); i = i + 1 } }
        i = i + 1
    }
    return r
}

fn main() {
    let parsed = parse_argv_cand(args())
    let candidate = build_candidate()
    let result = verify_with_ribozyme_sim(parsed["t_end"], parsed["dt"], 1.0)
    let pe = result["pass_eval"]
    let overall_pass = pe["overall_pass"]
    let witness = build_witness(result, candidate)

    if !parsed["no_emit"] {
        let path = registry_path_self()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(witness) + "\n")
    }

    let mut sentinel = "__R_ALPHA_AML_C2__ FAIL"
    if overall_pass { sentinel = "__R_ALPHA_AML_C2__ PASS" }
    println(sentinel)

    if overall_pass { exit(0) }
    exit(1)
}
