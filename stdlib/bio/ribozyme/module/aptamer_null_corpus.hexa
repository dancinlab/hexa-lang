#!hexa strict
//
// ribozyme/module/aptamer_null_corpus.hexa — F-RB-1-c aptamer null corpus.
//
// HEXA-NATIVE port of _python_bridge/module/ribozyme_aptamer_null_corpus.py
// (R5 sunset 2/57, 2026-05-07). Hand-curated n=10 published RNA aptamers —
// RNAs that BIND ligands but do NOT catalyze bond-breaking events. Used as
// negative-control corpus: PASS means the n6 lattice correctly REJECTS
// binding-only RNAs as catalytic ribozymes.
//
// PASS criterion: every aptamer has k_cat = 0, max n6_match_count ≤ 1
// (only φ binary by accident), all aptamers Eigen-Hammes distinguishable
// from catalytic ribozymes (k_cat = 0 ⇒ no saturation possible).
//
// Per cross-cutting Require (R5) raw 9 hexa-only: hexa stdlib only.
//
// Usage:
//   hexa run ribozyme/module/aptamer_null_corpus.hexa --emit
//   hexa run ribozyme/module/aptamer_null_corpus.hexa --summary

fn registry_path() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn aptamer(paper_ref: string, ligand: string, k_d_nM: int, k_cat_per_s: float) {
    let e = {}
    e["paper_ref"] = paper_ref
    e["ligand"] = ligand
    e["k_d_nM"] = k_d_nM
    e["k_cat_per_s"] = k_cat_per_s
    return e
}

fn build_corpus() {
    let c = []
    c.push(aptamer("Jenison-Ellington 1994 Science 263:1425", "theophylline", 100, 0.0))
    c.push(aptamer("Sassanfar-Szostak 1993 Nature 364:550", "ATP", 6000, 0.0))
    c.push(aptamer("Werstuck-Green 1998 Science 282:296", "tetracycline", 770, 0.0))
    c.push(aptamer("Grate-Wilson 1999 PNAS 96:6131", "malachite green", 800, 0.0))
    c.push(aptamer("Famulok 1994 JACS 116:1698", "L-arginine", 60000, 0.0))
    c.push(aptamer("Wallace-Schroeder 1998 RNA 4:112", "aminoglycoside (neomycin)", 100, 0.0))
    c.push(aptamer("Wallis-Schroeder 1995 Chem Biol 2:543", "tobramycin", 1500, 0.0))
    c.push(aptamer("Geiger-Burgstaller 1996 NAR 24:1029", "L-tryptophan", 18000, 0.0))
    c.push(aptamer("Convery-Westhof 2001 NSMB 8:688", "flavin mononucleotide", 500, 0.0))
    c.push(aptamer("Wallis-Schroeder 1996 Chem Biol 3:737", "streptomycin", 1000, 0.0))
    return c
}

// Per-axis match of an aptamer against canonical n6 lattice.
// Aptamers should fail σ / τ / J₂; φ (binary bound/unbound) matches by accident.
fn axes_match(_entry) {
    let ax = {}
    ax["sigma"] = 0  // variable binding-pocket size, NOT 12-nt catalytic core
    ax["tau"]   = 0  // 1-step binding, NOT 4-state reaction ladder
    ax["phi"]   = 1  // bound/unbound binary matches φ=2
    ax["J2"]    = 0  // no transition-state pose group
    return ax
}

fn axes_sum(ax) -> int {
    return ax["sigma"] + ax["tau"] + ax["phi"] + ax["J2"]
}

let RAW_91_DISCLOSURE = "Aptamer null corpus is NEGATIVE CONTROL — PASS means the lattice correctly REJECTS binding-only RNAs as ribozymes (k_cat = 0; only phi binary axis 'matches' by accident). All k_d / k_cat values are literature-anchored (citations in paper_ref). Hand-curated, n=10."

fn run_audit() {
    let corpus = build_corpus()
    let mut n_zero_kcat = 0
    let mut max_n6 = 0
    let mut all_eigen_pass = true
    let per_entry = []
    let mut i = 0
    while i < len(corpus) {
        let entry = corpus[i]
        let ax = axes_match(entry)
        let n6 = axes_sum(ax)
        if n6 > max_n6 { max_n6 = n6 }
        if entry["k_cat_per_s"] == 0.0 { n_zero_kcat = n_zero_kcat + 1 }
        let eigen_dist = entry["k_cat_per_s"] == 0.0 && entry["k_d_nM"] > 0
        if !eigen_dist { all_eigen_pass = false }
        let pe = {}
        pe["paper_ref"] = entry["paper_ref"]
        pe["axes_match"] = ax
        pe["n6_match_count"] = n6
        pe["k_cat_per_s"] = entry["k_cat_per_s"]
        per_entry.push(pe)
        i = i + 1
    }
    let n = len(corpus)
    let all_zero_kcat = n_zero_kcat == n
    let n6_rejection_pass = max_n6 <= 1
    let overall = all_zero_kcat && n6_rejection_pass && all_eigen_pass
    let r = {}
    r["corpus"] = corpus
    r["per_entry"] = per_entry
    r["n_corpus"] = n
    r["n_zero_kcat"] = n_zero_kcat
    r["max_n6_match"] = max_n6
    r["all_zero_kcat"] = all_zero_kcat
    r["n6_rejection_pass"] = n6_rejection_pass
    r["eigen_pass"] = all_eigen_pass
    r["overall_pass"] = overall
    return r
}

fn build_witness(audit, audited_at: string) {
    let mut verdict = "FAIL"
    if audit["overall_pass"] { verdict = "PASS" }

    let criteria = {}
    criteria["all_zero_kcat"] = audit["all_zero_kcat"]
    criteria["max_n6_match_le_1"] = audit["n6_rejection_pass"]
    criteria["all_eigen_hammes_distinguishable"] = audit["eigen_pass"]

    let f_rb_1_c = {}
    f_rb_1_c["verdict"] = verdict
    f_rb_1_c["n_corpus"] = audit["n_corpus"]
    f_rb_1_c["n_zero_kcat"] = audit["n_zero_kcat"]
    f_rb_1_c["max_n6_match_count"] = audit["max_n6_match"]
    f_rb_1_c["criteria"] = criteria
    f_rb_1_c["raw_91_c3_disclose"] = RAW_91_DISCLOSURE

    let subs = {}
    subs["f_rb_1_c"] = f_rb_1_c

    let w = {}
    w["schema"] = "raw_77_ribozyme_aptamer_null_corpus_v1"
    w["audited_at"] = audited_at
    w["audit_kind"] = "f_rb_1_c_aptamer_null_corpus"
    w["corpus"] = audit["corpus"]
    w["per_entry_axes"] = audit["per_entry"]
    w["f_rb_1_subclauses"] = subs
    w["raw_91_c3_disclose"] = RAW_91_DISCLOSURE
    w["raw_77_append_only"] = true
    w["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    w["witness_ref"] = "state/discovery_absorption/registry.jsonl#raw_77_ribozyme_aptamer_null_corpus_v1"
    return w
}

fn parse_argv(av) {
    let r = {}
    r["emit"] = false
    r["summary"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--emit" { r["emit"] = true }
        if a == "--summary" { r["summary"] = true }
        i = i + 1
    }
    return r
}

fn main() {
    let parsed = parse_argv(args())
    let audit = run_audit()
    let audited_at = utc_iso_now()
    let witness = build_witness(audit, audited_at)

    if parsed["emit"] {
        let line = json_encode(witness) + "\n"
        let path = registry_path()
        let last_slash = path.last_index_of("/")
        let dir = path.substring(0, last_slash)
        exec("mkdir -p " + dir)
        append_file(path, line)
        eprintln("emitted 1 witness row -> " + path)
    }

    if parsed["summary"] {
        println(json_encode(witness))
    } else {
        let mut verdict = "FAIL"
        if audit["overall_pass"] { verdict = "PASS" }
        eprintln("n=" + to_string(audit["n_corpus"]) +
            "  zero_kcat=" + to_string(audit["n_zero_kcat"]) + "/10" +
            "  max_n6_match=" + to_string(audit["max_n6_match"]) + "/4" +
            "  verdict=" + verdict)
    }

    if audit["overall_pass"] { exit(0) }
    exit(1)
}
