#!hexa strict
//
// ribozyme/module/scd_hbb_candidate.hexa — C2 cell R·β (RIBOZYME × β=SCD).
//
// HEXA-NATIVE port of _python_bridge/module/ribozyme_scd_hbb_candidate.py
// (R5 sunset 17/57, 2026-05-07). HBB-targeting hammerhead ribozyme
// candidate spec for sickle-cell disease cell. IN-SILICO numerical-
// primitive verification ONLY.
//
// Per cross-cutting Require (R5) raw 9 hexa-only: hexa stdlib only.

use "ribozyme/module/kinetics_simulation"

let ARM_5P_12NT = "GCAUACGUUACG"
let ARM_3P_12NT = "AGCCAUUGCCGA"

fn registry_path_self() -> string {
    let cwd = exec("pwd").trim()
    return cwd + "/state/discovery_absorption/registry.jsonl"
}

fn build_candidate() {
    let c = {}
    c["target_disease_class_label"] = "beta_SCD"
    c["matrix_cell_label"] = "R_beta"
    c["target_pre_mrna"] = "HBB pre-mRNA (β-globin precursor)"
    c["target_pre_mrna_reference"] = "HBB RefSeq (public sequence database)"
    c["construct_class"] = "hammerhead-minimal trans-cleaving ribozyme"
    c["construct_topology"] = "5'-arm(12nt)-CATALYTIC_CORE(12nt)-3'-arm(12nt)"
    c["catalytic_core_12nt"] = CATALYTIC_CORE_12NT
    c["substrate_cleavage_motif"] = "NUH↓ triplet (canonical hammerhead)"
    c["substrate_recognition_arm_5p_12nt"] = ARM_5P_12NT
    c["substrate_recognition_arm_3p_12nt"] = ARM_3P_12NT
    c["full_designed_ribozyme_36nt"] = ARM_5P_12NT + CATALYTIC_CORE_12NT + ARM_3P_12NT
    c["n6_invariant_role"] = "σ(6)=12 catalytic-core nucleotide count preserved; τ(6)=4 reaction states inherited from F-RB-4 baseline."
    let anchors = []
    anchors.push("HBB pre-mRNA — public open-access hematology / sequence database")
    anchors.push("Hammerhead ribozyme design: Symons 1981; Hertel & Uhlenbeck 1992")
    c["source_literature_anchors"] = anchors
    let handoff = []
    handoff.push("ribozyme delivery (LNP / AAV / exosome) → NANOBOT or VIROCAPSID at next layer")
    handoff.push("in-cell efficacy / off-target / pharmacokinetics → wet-lab (out-of-repo, C3+)")
    c["downstream_layer_handoff"] = handoff
    return c
}

fn verify_with_ribozyme_sim(t_end: float, dt: float, S_eff: float) {
    let sample_times = []
    let mut si = 0
    while si < len(SAMPLE_TIMES) {
        if SAMPLE_TIMES[si] <= t_end { sample_times.push(SAMPLE_TIMES[si]) }
        si = si + 1
    }
    if len(sample_times) == 0 || sample_times[len(sample_times) - 1] != t_end {
        sample_times.push(t_end)
    }
    let n6_check = n6_invariant_check()
    let rk4_result = integrate("rk4", t_end, dt, sample_times, S_eff)
    let euler_result = integrate("euler", t_end, dt, sample_times, S_eff)
    let kinetics = compute_kcat_KM(rk4_result, S_eff)
    let pass_eval = evaluate_pass(rk4_result, euler_result, kinetics)
    let v = {}
    v["n6_check"] = n6_check
    v["kinetics"] = kinetics
    v["pass_eval"] = pass_eval
    return v
}

fn build_witness(verify_result, candidate) {
    let pe = verify_result["pass_eval"]
    let kin = verify_result["kinetics"]
    let overall_pass = pe["overall_pass"]

    let kcat_KM = kin["kcat_over_KM"]
    let mut eigen_pass = false
    if (type_of(kcat_KM) == "float" || type_of(kcat_KM) == "int") && to_float(kcat_KM) <= 1.0e9 {
        eigen_pass = true
    }

    let verification = {}
    verification["simulator"] = "ribozyme_kinetics_simulation (F-RB-4 PASS, cycle 24 C0b)"
    verification["kinetics_pass"] = overall_pass
    verification["k_cat_per_min"] = kin["k_cat_per_min"]
    verification["K_M_uM"] = kin["K_M_uM"]
    verification["kcat_over_KM"] = kcat_KM
    verification["eigen_hammes_ceiling"] = 1.0e9
    verification["diffusion_margin_log10"] = kin["diffusion_margin_log10"]
    verification["eigen_hammes_pass"] = eigen_pass
    verification["pass_count"] = pe["pass_count"]
    verification["total_count"] = pe["total_count"]

    let disclosures = []
    disclosures.push("Substrate-recognition arms are illustrative reverse-complements of public HBB pre-mRNA context — they demonstrate the design step's arm-length convention, not a clinically validated targeting sequence.")
    disclosures.push("Kinetics PASS is sequence-INDEPENDENT in the F-RB-4 model — rate constants come from Eyring TST + Turner NN, not from explicit substrate-arm pairing. PASS verifies internal model consistency, NOT HBB-specific in-cell cleavage.")
    disclosures.push("Ribozyme delivery (LNP / AAV / exosome) is out-of-scope at this primitive — handoff to NANOBOT or VIROCAPSID at next layer.")
    disclosures.push("16-cell matrix R·β at IN-SILICO grade only.")

    let mut sentinel = "__R_BETA_SCD_C2__ FAIL"
    if overall_pass { sentinel = "__R_BETA_SCD_C2__ PASS" }

    let row = {}
    row["schema"] = "raw_77_c2_ribozyme_scd_v1"
    row["ts"] = utc_iso_now()
    row["cycle"] = 25
    row["phase"] = "c2-r-beta-scd-hbb-ribozyme-candidate"
    row["domain"] = "hexa-ribozyme"
    row["matrix_cell"] = "R_beta"
    row["disease_class_label"] = "beta_SCD"
    row["candidate"] = candidate
    row["verification"] = verification
    row["n6_invariant"] = verify_result["n6_check"]
    row["in_silico_grade_disclose"] = "IN-SILICO numerical-primitive verification ONLY. No biological, clinical, regulatory, or treatment claim is being made or implied."
    row["raw_91_c3_disclose"] = disclosures
    row["raw_47_cross_repo"] = "Imports ribozyme_kinetics_simulation (F-RB-4 PASS, cycle 24 C0b) as module; reuses its API (R2 preserved)."
    row["raw_9_hexa_only"] = "hexa stdlib only (R5 sunset 2026-05-07)"
    row["raw_138_sentinel"] = sentinel
    row["raw_77_append_only"] = true
    return row
}

fn parse_argv_cand(av) {
    let r = {}
    r["t_end"] = 600.0
    r["no_emit"] = false
    r["quiet"] = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--no-emit" { r["no_emit"] = true }
        else if a == "--quiet" { r["quiet"] = true }
        else if a == "--t-end" { if i + 1 < len(av) { r["t_end"] = to_float(av[i + 1]); i = i + 1 } }
        i = i + 1
    }
    return r
}

fn main() {
    let parsed = parse_argv_cand(args())
    let candidate = build_candidate()
    let result = verify_with_ribozyme_sim(parsed["t_end"], 0.01, 1.0)
    let pe = result["pass_eval"]
    let overall_pass = pe["overall_pass"]
    let witness = build_witness(result, candidate)

    if !parsed["no_emit"] {
        let path = registry_path_self()
        let last_slash = path.last_index_of("/")
        exec("mkdir -p " + path.substring(0, last_slash))
        append_file(path, json_encode(witness) + "\n")
    }

    let mut sentinel = "__R_BETA_SCD_C2__ FAIL"
    if overall_pass { sentinel = "__R_BETA_SCD_C2__ PASS" }
    println(sentinel)

    if overall_pass { exit(0) }
    exit(1)
}
