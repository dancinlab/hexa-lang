// stdlib/bio/uniprot_test.hexa — measured-oracle gate for the UniProt
// + AlphaFold DB stdlib clients.
//
// Determinism strategy: parse the two captured fixtures
//   · compiler/bridges/_cache/uniprot.frozen.json
//   · compiler/bridges/_cache/alphafold.frozen.json
// (P05067 — Amyloid-β Precursor Protein, 2026-05-24 snapshot) and
// byte-equal assert field extraction. No network.
//
// ⚠ The AlphaFold DB endpoint sunset is 2026-06-25; the fixture
// continues to gate the parser shape even after the live endpoint
// disappears.

use "stdlib/bio/uniprot"

let UNIPROT_FIXTURE   = "compiler/bridges/_cache/uniprot.frozen.json"
let ALPHAFOLD_FIXTURE = "compiler/bridges/_cache/alphafold.frozen.json"

fn _fail(label: string, want: string, got: string) {
    println("FAIL: " + label)
    println("  want: " + want)
    println("  got : " + got)
    exit(1)
}

fn _expect_eq(label: string, want: string, got: string) {
    if want != got { _fail(label, want, got) }
}

fn _expect_eq_i(label: string, want: int, got: int) {
    if want != got { _fail(label, to_string(want), to_string(got)) }
}

fn _expect_contains(label: string, hay: string, needle: string) {
    let n = len(hay)
    let m = len(needle)
    if m == 0 { return }
    if m > n { _fail(label + " contains", needle, hay); return }
    let mut i = 0
    while i + m <= n {
        if hay.substring(i, i + m) == needle { return }
        i = i + 1
    }
    _fail(label + " contains", needle, hay)
}

fn _expect_ends_with(label: string, hay: string, suffix: string) {
    let n = len(hay)
    let m = len(suffix)
    if m > n { _fail(label + " ends_with", suffix, hay); return }
    if hay.substring(n - m, n) != suffix { _fail(label + " ends_with", suffix, hay) }
}

fn main() {
    // ── UniProt ───────────────────────────────────────────────────
    let u_body = read_file(UNIPROT_FIXTURE)
    if len(u_body) == 0 {
        println("FAIL: uniprot fixture missing: " + UNIPROT_FIXTURE)
        exit(1)
    }
    let u = uniprot_parse(u_body)

    _expect_eq("uniprot.accession", "P05067", u.accession)
    _expect_eq("uniprot.gene",      "APP",    u.gene)
    _expect_contains("uniprot.organism", u.organism, "Homo sapiens")
    _expect_eq("uniprot.name",  "Amyloid-beta precursor protein", u.name)
    _expect_eq_i("uniprot.sequence_length", 770, u.sequence_length)

    // Sequence sanity: starts with the APP signal-peptide M-L-P-G prefix
    // and the byte length matches the metadata field exactly.
    _expect_eq_i("uniprot.sequence byte length", 770, len(u.sequence))
    _expect_eq("uniprot.sequence prefix", "MLPGLALLLLAA", u.sequence.substring(0, 12))
    _expect_contains("uniprot.function", u.function, "cell surface receptor")

    // ── AlphaFold ─────────────────────────────────────────────────
    let a_body = read_file(ALPHAFOLD_FIXTURE)
    if len(a_body) == 0 {
        println("FAIL: alphafold fixture missing: " + ALPHAFOLD_FIXTURE)
        exit(1)
    }
    let p = alphafold_parse(a_body)

    _expect_eq("alphafold.accession", "P05067",       p.accession)
    _expect_contains("alphafold.pdb_url", p.pdb_url,  "AF-P05067-F1-model")
    _expect_ends_with("alphafold.pdb_url", p.pdb_url, ".pdb")
    _expect_contains("alphafold.cif_url", p.cif_url,  "AF-P05067-F1-model")
    _expect_ends_with("alphafold.cif_url", p.cif_url, ".cif")
    _expect_eq("alphafold.model_url",    "AF-P05067-F1", p.model_url)
    _expect_eq_i("alphafold.version",    6,              p.version)

    // ── empty / error path ────────────────────────────────────────
    let u_empty = uniprot_parse("")
    _expect_eq("uniprot_parse('') sentinel",   "", u_empty.accession)
    _expect_eq_i("uniprot_parse('') length",   0,  u_empty.sequence_length)

    let a_empty = alphafold_parse("")
    _expect_eq("alphafold_parse('') sentinel", "", a_empty.accession)
    _expect_eq_i("alphafold_parse('') version", 0, a_empty.version)

    let u_nofetch = uniprot_fetch("")
    _expect_eq("uniprot_fetch('') sentinel",   "", u_nofetch.accession)
    let a_nofetch = alphafold_fetch("")
    _expect_eq("alphafold_fetch('') sentinel", "", a_nofetch.accession)

    println("PASS: uniprot + alphafold parse oracles (13 fields / 2 entries)")
}
