    println(raw.trim())
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_BIO_VIROCAPSID__ PASS") { "true" } else { "false" }
        println("{\"hexa_bio\":\"" + VERSION + "\",\"subcmd\":\"virocapsid\",\"pass\":" + pass + ",\"status\":\"c0b_multi_t\"}")
    }
