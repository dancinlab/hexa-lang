}

fn cmd_subhelp(sub: str) {
    if sub == "status" {
        println("hexa-bio status [--json]")
        println("  show 5-axis status table + n=6 lattice + caveats")
        println("  cost: $0 (read-only)")
    } else if sub == "weave" {
        println("hexa-bio weave [--cage-assembly | --bayesian-audit | --all] [--t-end N] [--json]")
        println("  protein cage / polyhedral self-assembly (Caspar-Klug 1962 + Zlotnick 2003)")
        println("  empirical paths require HEXA_BIO_WITH_NUMPY=1 (numpy/scipy opt-in)")
        println("  cost: $0 (textbook corpus + python stdlib for skeleton)")
    } else if sub == "nanobot" {
        println("hexa-bio nanobot [--json]")
        println("  molecular actuation axis — C0b skeleton (F-NB-4 actuation MVP)")
        println("  prints n=6 lattice (σ(6)=12 12-vertex polyhedron) + falsifier preregister table")
        println("  cost: $0")
    } else if sub == "ribozyme" {
        println("hexa-bio ribozyme [--json]")
        println("  RNA-catalyst axis — C0b skeleton (F-RB-4 kinetics MVP)")
        println("  prints n=6 lattice (σ(6)=12 12-nt hammerhead core) + falsifier preregister table")
        println("  cost: $0")
    } else if sub == "virocapsid" {
        println("hexa-bio virocapsid [--json]")
        println("  viral capsid assembly axis — C0b skeleton + RCSB PDB corpus (multi-T, cycle 26)")
        println("  T=1 σ(6)=12 grounded via weave; T>1 = V-R2 stretch")
        println("  cost: $0")
    } else if sub == "quantum" {
        println("hexa-bio quantum [status | falsifiers | n6 | pilot-runner | help] [--json]")
        println("  5th axis — qpu_bridge VQE (H₂ 0.4 µHa, LiH 1.41 mHa) + ML pilots (ProteinMPNN/Boltz-2/RhoFold+)")
        println("  default `status` = Phase + falsifier snapshot (pure hexa, $0). F-Q-1…5 PASS; pocket-VQE F-Q-6 open.")
        println("  full VQE path needs qiskit-aer + a qmirror checkout; roadmap: .roadmap.quantum")
        println("  cost: $0 for status; full VQE = local Aer simulator (CPU) + ANU QRNG (free public API)")
    } else if sub == "selftest" {
        println("hexa-bio selftest [--json]")
        println("  5-axis sentinel sweep + 16-cell C2 matrix sweep")
        println("  PASS = sentinels present + dispatchers accept flags; does NOT imply empirical claim validation")
        println("  cost: $0 (~5-10s on Mac)")
    } else {
        cmd_help()
    }
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_bio_cli", "hexa_bio_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        if sub == "--help" || sub == "-h" || sub == "help" {
            cmd_help()
        } else {
            cmd_subhelp(sub)
        }
        return
    }

    if sub == "help" { cmd_help(); return }

    if sub == "status" {
        cmd_status(a)
    } else if sub == "weave" {
        cmd_weave(a)
    } else if sub == "nanobot" {
        cmd_nanobot(a)
    } else if sub == "ribozyme" {
        cmd_ribozyme(a)
    } else if sub == "virocapsid" {
        cmd_virocapsid(a)
    } else if sub == "quantum" {
        cmd_quantum(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else if sub == "tape-lint" {
        cmd_tape_lint(a)
    } else {
        eprintln("hexa-bio: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-bio help' for usage")
        _audit(sub, "", 2)
        exit(2)
    }
}
