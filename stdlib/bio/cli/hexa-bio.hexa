#!hexa strict
// hexa-bio/cli/hexa-bio.hexa — standalone hexa-bio CLI router
//
// 5-axis Molecular Toolkit (HEXA family) router. 4 bio axes form the n=6
// τ-quartet tetrahedron; `quantum` is the 5th axis (qpu_bridge VQE compute
// substrate). Axis count is locked — .roadmap.axis_expansion_decision_2026_05_08.
//   weave       — protein cage / polyhedral self-assembly  (WIRED, v1.0.0)
//   nanobot     — molecular actuation primitive            (C0b skeleton)
//   ribozyme    — RNA-catalyst primitive                    (C0b skeleton)
//   virocapsid  — viral capsid assembly primitive           (C0b skeleton + PDB corpus)
//   quantum     — qpu_bridge VQE / ML pilot compute axis    (Phase 1+; F-Q-1…5 PASS)
//
// Plus utility subcmds:
//   status      — 5-axis status table
//   selftest    — run all 5 axes + verify sentinels + 16-cell C2 sweep
//   help        — this help
//   --version   — print version
//
// Root resolution: $HEXA_BIO_ROOT env, else inferred from $0 dirname.
// No nexus dependency — feature/module/ trees live alongside this script.
//
// Constraints:
//
// Cost: $0 (Mac local; pure skeletons + textbook-corpus weave audit + pure-hexa
//           quantum status snapshot).
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local CLI router; modules manage their own bridges.")

let VERSION = "1.0.0"

// ─── env / path resolve ───

let HOME = env("HOME")
let HEXA_BIO_ROOT_ENV = env("HEXA_BIO_ROOT")

fn hexa_bio_root() -> str {
    if HEXA_BIO_ROOT_ENV.len() > 0 { return HEXA_BIO_ROOT_ENV }
    let inferred = exec("dirname \"$(dirname \"$0\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return HOME + "/.hexa-bio"  // @allow-devpath
}

let HB = hexa_bio_root()
let HEXA_BIN = exec("command -v hexa 2>/dev/null || echo hexa").trim()
// Feature-grouped layout (canonical 2026-05-05): <feature>/module/<feature>.hexa
let MOD_DIR = HB

let MOD_WEAVE      = MOD_DIR + "/weave/module/weave.hexa"
let MOD_NANOBOT    = MOD_DIR + "/nanobot/module/nanobot.hexa"
let MOD_RIBOZYME   = MOD_DIR + "/ribozyme/module/ribozyme.hexa"
let MOD_VIROCAPSID = MOD_DIR + "/virocapsid/module/virocapsid.hexa"
let MOD_QUANTUM    = MOD_DIR + "/quantum/module/quantum.hexa"
let MOD_SELFTEST   = MOD_DIR + "/selftest/module/selftest.hexa"

let LOG_PATH = HB + "/state/hexa_bio_cli.log"

// ─── arg helpers ───

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn has_flag(a: [str], flag: str) -> bool {
    for x in a {
        if x == flag { return true }
    }
    return false
}

fn json_mode(a: [str]) -> bool {
    return has_flag(a, "--json")
}

// ─── audit log (jsonl) ───

fn _ts_now() -> str {
    return exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
}

fn _audit(subcmd: str, args_str: str, exit_code: int) {
    let line = "{\"ts\":\"" + _ts_now() + "\",\"caller\":\"hexa_bio_standalone\",\"subcmd\":\"hexa-bio " +
               subcmd + "\",\"args\":\"" + args_str.replace("\"", "\\\"") +
               "\",\"exit_code\":" + str(exit_code) + ",\"version\":\"" + VERSION + "\"}"
    exec("mkdir -p " + shq(HB + "/state") + " 2>/dev/null")
    exec("echo " + shq(line) + " >> " + shq(LOG_PATH) + " 2>/dev/null")
}

// ─── module runner ───

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _run_module(script: str, extra: [str]) -> str {
    if _file_exists(script) == false {
        return "ERROR: module not found: " + script + " (set HEXA_BIO_ROOT or run from repo root)"
    }
    let mut cmd = "HEXA_BIO_ROOT=" + shq(HB) + " " + shq(HEXA_BIN) + " run " + shq(script)
    for x in extra {
        cmd = cmd + " " + shq(x)
    }
    return exec(cmd + " 2>&1")
}


fn _print_caveats() {
    println("")
    println("  1. 5-axis framework (Q/W/N/R/V), count locked. 1/5 fully wired (weave).")
    println("     3/5 C0b skeleton (nanobot/ribozyme/virocapsid). 1/5 Phase-1+ (quantum:")
    println("     H₂/LiH VQE, F-Q-1…5 PASS, pocket-VQE F-Q-6 open).")
    println("  2. Falsifier deadlines for the non-weave axes are working dates;")
    println("     revisions land per cycle as the empirical sandboxes mature (.roadmap.*).")
    println("  3. n=6 invariant lattice (σ=12, τ=4, φ=2, J₂=24): grounded for weave")
    println("     (T=1 cage, posterior 0.97) and quantum (H₂ 6-Pauli × 2-qubit).")
    println("     nanobot/ribozyme/T>1-virocapsid carry it as STRUCTURAL-EXACT-CANDIDATE.")
    println("  4. Migration of nexus/sim_bridge/weave/ may break edge-case consumers")
    println("     (canon cross-link path, runs/ ledger schema readers).")
    println("  5. GitHub-only distribution (HF Hub mirror retired 2026-05-04). GitHub")
    println("     remains canonical at https://github.com/dancinlab/hexa-bio.")
}

// ─── subcommand: tape-lint (cohort LATTICE_POLICY honesty lint) ───
//
// Generic per-file lint (NOT 5-axis). hexa-bio owns LATTICE_POLICY
// enforcement for the HEXA cohort; sibling repos shell out here rather
// than reimplement (g5_sister_repo_cli). Usage:
//   hexa-bio tape-lint <path/to/DOMAIN.tape> [--json]

fn cmd_tape_lint(a: [str]) {
    let n = len(a)
    if n < 4 {
        eprintln("hexa-bio tape-lint: usage: hexa-bio tape-lint <DOMAIN.tape> [--json]")
        _audit("tape-lint", "", 2)
        exit(2)
    }
    let target = a[3]
    let script = HB + "/selftest/tape_lattice_honesty_lint.py"
    if _file_exists(script) == false {
        eprintln("hexa-bio tape-lint: linter missing: " + script)
        _audit("tape-lint", "", 2)
        exit(2)
    }
    let mut cmd = "python3 " + shq(script) + " " + shq(target)
    if json_mode(a) { cmd = cmd + " --json" }
    let out = exec(cmd + " 2>&1")
    println(out.trim())
    let pass = out.contains("__TAPE_LATTICE_HONESTY__ PASS")
    let skip = out.contains("__TAPE_LATTICE_HONESTY__ SKIP")
    _audit("tape-lint", target, if pass { 0 } else { if skip { 0 } else { 1 } })
    if pass == false {
        if skip == false { exit(1) }
    }
}

// ─── subcommand: status ───

fn cmd_status(a: [str]) {
    if json_mode(a) {
        let mut js = "{\"hexa_bio\":\"" + VERSION + "\",\"subcmd\":\"status\","
        js = js + "\"axes_total\":5,\"axes_wired\":1,\"axes_c0b_skeleton\":3,\"axes_phase1_plus\":1,"
        js = js + "\"axis_count_lock\":\".roadmap.axis_expansion_decision_2026_05_08\","
        js = js + "\"verdict\":\"PARTIAL_PASS\","
        js = js + "\"axes\":[\"weave:wired\",\"virocapsid:c0b\",\"nanobot:c0b\",\"ribozyme:c0b\",\"quantum:phase1+\"],"
        js = js + "\"n6_lattice_verified\":[\"weave_T1\",\"quantum_H2_6pauli\"]"
        js = js + "}"
        println(js)
        return
    }

    println("hexa-bio " + VERSION + " status — 5-axis Molecular Toolkit (HEXA family)")
    println("")
    println("  axis        role          status              n=6 lattice                      sandbox / detail")
    println("  ----------- ------------- ------------------- -------------------------------- ----------------------------------")
    println("  weave       composition   WIRED v1.0.0        STRUCTURAL-EXACT (T=1, post 0.97) cage-assembly ODE + Bayesian audit")
    println("  virocapsid  assembly      C0b + multi-T       STRUCTURAL-EXACT (T=1 + multi-T)  PDB-corpus T-number discrimination")
    println("  nanobot     actuation     C0b skeleton        STRUCTURAL-EXACT-CANDIDATE (12-v) 4-state DNA-origami actuation sim")
    println("  ribozyme    catalysis     C0b skeleton        STRUCTURAL-EXACT-CANDIDATE (12-nt) hammerhead-minimal kinetics sim")
    println("  quantum     computation   Phase 1+ (qpu L1)   VERIFIED (H₂ 6-Pauli / LiH path)  VQE H₂ 0.4 µHa / LiH 1.41 mHa + ML pilots")
    println("")
    println("  verdict: PARTIAL_PASS — weave wired; virocapsid/nanobot/ribozyme C0b; quantum Phase-1+ (F-Q-1…5 PASS, F-Q-6 open)")
    println("  axis count: 5 (locked — .roadmap.axis_expansion_decision_2026_05_08; 6th/7th candidates reject/defer)")
    println("")
    println("  to drill into an axis:")
    println("    hexa-bio weave [--cage-assembly|--bayesian-audit|--all] [--t-end N]")
    println("    hexa-bio nanobot       (prints n=6 lattice + falsifier table)")
    println("    hexa-bio ribozyme      (prints n=6 lattice + falsifier table)")
    println("    hexa-bio virocapsid    (prints n=6 lattice + falsifier table)")
    println("    hexa-bio quantum [status|falsifiers|n6|pilot-runner]")
    println("    hexa-bio selftest      (5-axis sentinel sweep + 16-cell C2 sweep)")
    _print_caveats()
}

// ─── subcommand: weave ───

fn cmd_weave(a: [str]) {
    let mut extras: [str] = []
    let mut i = 3
    while i < a.len() {
        extras = extras + [a[i]]
        i = i + 1
    }
    let raw = _run_module(MOD_WEAVE, extras)
    println(raw.trim())
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_BIO_WEAVE__ PASS") { "true" } else { "false" }
        println("{\"hexa_bio\":\"" + VERSION + "\",\"subcmd\":\"weave\",\"pass\":" + pass + "}")
    }
    _audit("weave", "", 0)
}

// ─── subcommand: nanobot ───

fn cmd_nanobot(a: [str]) {
    let raw = _run_module(MOD_NANOBOT, [])
    println(raw.trim())
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_BIO_NANOBOT__ PASS") { "true" } else { "false" }
        println("{\"hexa_bio\":\"" + VERSION + "\",\"subcmd\":\"nanobot\",\"pass\":" + pass + ",\"status\":\"c0b_skeleton\"}")
    }
    _audit("nanobot", "", 0)
}

