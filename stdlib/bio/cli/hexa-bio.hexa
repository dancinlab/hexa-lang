}

// ─── subcommand: quantum (5th axis — qpu_bridge VQE / ML pilots) ───

fn cmd_quantum(a: [str]) {
    // Pass through any extra args (status | falsifiers | n6 | pilot-runner | help).
    let mut extras: [str] = []
    let mut i = 3
    while i < a.len() {
        if a[i] != "--json" { extras = extras + [a[i]] }
        i = i + 1
    }
    let raw = _run_module(MOD_QUANTUM, extras)
    println(raw.trim())
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_BIO_QUANTUM__ PASS") { "true" } else { "false" }
        println("{\"hexa_bio\":\"" + VERSION + "\",\"subcmd\":\"quantum\",\"pass\":" + pass + ",\"status\":\"phase1+\",\"roadmap\":\".roadmap.quantum\"}")
    }
    _audit("quantum", "", 0)
}

// ─── subcommand: selftest ───

fn cmd_selftest(a: [str]) {
    let raw = _run_module(MOD_SELFTEST, [])
    println(raw.trim())
    let pass_overall = raw.contains("__HEXA_BIO_SELFTEST__ PASS")
    if json_mode(a) {
        println("{\"hexa_bio\":\"" + VERSION + "\",\"subcmd\":\"selftest\",\"verdict\":\"" + (if pass_overall { "PASS" } else { "FAIL" }) + "\"}")
    }
    _print_caveats()
    _audit("selftest", "", if pass_overall { 0 } else { 1 })
    if pass_overall == false { exit(1) }
}

// ─── version ───

fn cmd_version() {
    println("hexa-bio " + VERSION)
    println("standalone 5-axis Molecular Toolkit (HEXA family — extracted from nexus 2026-05-04)")
    println("axes:    quantum / weave / nanobot / ribozyme / virocapsid (count locked)")
    println("license: Apache-2.0")
    println("repo:    https://github.com/dancinlab/hexa-bio")
}

