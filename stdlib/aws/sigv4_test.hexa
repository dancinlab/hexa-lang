// HEXA Standard Library — aws/sigv4 tests
//
// Falsifier: the official AWS `aws-sig-v4-test-suite` `get-vanilla` case.
// Published oracles (verbatim from the test suite's .creq / .sts / .authz):
//   - canonical request hash (the .sts 4th line):
//       bb579772317eb040ac9ed261061d46c1f17a8133879d6129b6e1c25292927e63
//   - Authorization header (the .authz file):
//       AWS4-HMAC-SHA256 Credential=AKIDEXAMPLE/20150830/us-east-1/service/
//       aws4_request, SignedHeaders=host;x-amz-date,
//       Signature=5fa00fa31553b73ebf1942676e86291e8372ff2a2260956d9b8aae1d763fbf31
//
// get-vanilla request:  GET /  (empty query, empty payload)
//   Host: example.amazonaws.com
//   X-Amz-Date: 20150830T123600Z
//   access=AKIDEXAMPLE  secret=wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY
//   region=us-east-1  service=service
//
// SigV4 is pure + deterministic — these are exact byte-level oracles, so
// correctness is measurable with zero AWS account or network.

import "sigv4.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check_eq(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
        println("  got  = " + got)
        println("  want = " + want)
    }
}

fn main() {
    // ── aws-sig-v4-test-suite: get-vanilla ───────────────────────────
    let headers = [
        Sigv4Header { name: "Host",       value: "example.amazonaws.com" },
        Sigv4Header { name: "X-Amz-Date", value: "20150830T123600Z" }
    ]
    let req = Sigv4Request {
        method:        "GET",
        host:          "example.amazonaws.com",
        region:        "us-east-1",
        service:       "service",
        path:          "/",
        query:         "",
        headers:       headers,
        payload:       "",
        access_key:    "AKIDEXAMPLE",
        secret_key:    "wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY",
        amz_date:      "20150830T123600Z",
        session_token: ""
    }
    let r = sigv4_sign(req)

    // Canonical request — exact text per the test suite .creq fixture.
    let want_creq = "GET\n"
        + "/\n"
        + "\n"
        + "host:example.amazonaws.com\n"
        + "x-amz-date:20150830T123600Z\n"
        + "\n"
        + "host;x-amz-date\n"
        + "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    check_eq("canonical request", r.canonical_request, want_creq)

    // String to sign — exact text per the test suite .sts fixture.
    let want_sts = "AWS4-HMAC-SHA256\n"
        + "20150830T123600Z\n"
        + "20150830/us-east-1/service/aws4_request\n"
        + "bb579772317eb040ac9ed261061d46c1f17a8133879d6129b6e1c25292927e63"
    check_eq("string to sign", r.string_to_sign, want_sts)

    // Final signature + Authorization header (.authz fixture).
    check_eq("signature",
        r.signature,
        "5fa00fa31553b73ebf1942676e86291e8372ff2a2260956d9b8aae1d763fbf31")
    check_eq("signed headers", r.signed_headers, "host;x-amz-date")
    check_eq("credential scope",
        r.credential_scope, "20150830/us-east-1/service/aws4_request")
    check_eq("authorization header",
        r.authorization,
        "AWS4-HMAC-SHA256 Credential=AKIDEXAMPLE/20150830/us-east-1/service/aws4_request, SignedHeaders=host;x-amz-date, Signature=5fa00fa31553b73ebf1942676e86291e8372ff2a2260956d9b8aae1d763fbf31")

    // x-amz-content-sha256 of an empty payload = SHA256("").
    check_eq("x-amz-content-sha256 (empty payload)",
        r.x_amz_content_sha256,
        "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")
    check_eq("x-amz-date passthrough", r.x_amz_date, "20150830T123600Z")

    // Header sorting: out-of-order input must still canonicalise sorted.
    let unsorted = [
        Sigv4Header { name: "X-Amz-Date", value: "20150830T123600Z" },
        Sigv4Header { name: "Host",       value: "example.amazonaws.com" }
    ]
    let req2 = Sigv4Request {
        method:        "GET",
        host:          "example.amazonaws.com",
        region:        "us-east-1",
        service:       "service",
        path:          "/",
        query:         "",
        headers:       unsorted,
        payload:       "",
        access_key:    "AKIDEXAMPLE",
        secret_key:    "wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY",
        amz_date:      "20150830T123600Z",
        session_token: ""
    }
    let r2 = sigv4_sign(req2)
    check_eq("header sort order-independence",
        r2.authorization, r.authorization)

    // ── UriEncode unit oracles (RFC 3986 §2.3) ───────────────────────
    // Unreserved set passes through; everything else %XX uppercase-hex.
    check_eq("uriencode unreserved",
        sigv4_uri_encode("aZ09-_.~", false), "aZ09-_.~")
    check_eq("uriencode space (query)",
        sigv4_uri_encode("a b", false), "a%20b")
    check_eq("uriencode slash query",
        sigv4_uri_encode("a/b", false), "a%2Fb")
    check_eq("uriencode slash path",
        sigv4_uri_encode("a/b", true), "a/b")
    check_eq("uriencode plus + equals",
        sigv4_uri_encode("a+b=c", false), "a%2Bb%3Dc")
    // UTF-8 byte-wise: U+1234 (ሴ) = E1 88 B4 -> %E1%88%B4
    check_eq("uriencode utf8 byte-wise",
        sigv4_uri_encode("ሴ", true), "%E1%88%B4")

    // ── aws-sig-v4-test-suite: get-vanilla-query-order-key-case ──────
    // Raw query "Param2=value2&Param1=value1" MUST canonicalise sorted to
    // "Param1=value1&Param2=value2". Published oracles (verbatim from the
    // suite's .creq / .sts / .authz):
    //   creq query line: Param1=value1&Param2=value2
    //   .sts hash      : 816cd5b414d056048ba4f7c5386d6e0533120fb1fcfa93762cf0fc39e2cf19e0
    //   signature      : b97d918cfa904a5beff61c982a1b6f458b799221646efd99d3219ec94cdf2500
    let qhdr = [
        Sigv4Header { name: "Host",       value: "example.amazonaws.com" },
        Sigv4Header { name: "X-Amz-Date", value: "20150830T123600Z" }
    ]
    let qreq = Sigv4Request {
        method:        "GET",
        host:          "example.amazonaws.com",
        region:        "us-east-1",
        service:       "service",
        path:          "/",
        query:         "Param2=value2&Param1=value1",
        headers:       qhdr,
        payload:       "",
        access_key:    "AKIDEXAMPLE",
        secret_key:    "wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY",
        amz_date:      "20150830T123600Z",
        session_token: ""
    }
    let qr = sigv4_sign(qreq)
    let want_qcreq = "GET\n"
        + "/\n"
        + "Param1=value1&Param2=value2\n"
        + "host:example.amazonaws.com\n"
        + "x-amz-date:20150830T123600Z\n"
        + "\n"
        + "host;x-amz-date\n"
        + "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    check_eq("query-order canonical request", qr.canonical_request, want_qcreq)
    let want_qsts = "AWS4-HMAC-SHA256\n"
        + "20150830T123600Z\n"
        + "20150830/us-east-1/service/aws4_request\n"
        + "816cd5b414d056048ba4f7c5386d6e0533120fb1fcfa93762cf0fc39e2cf19e0"
    check_eq("query-order string to sign", qr.string_to_sign, want_qsts)
    check_eq("query-order signature",
        qr.signature,
        "b97d918cfa904a5beff61c982a1b6f458b799221646efd99d3219ec94cdf2500")
    check_eq("query-order authorization",
        qr.authorization,
        "AWS4-HMAC-SHA256 Credential=AKIDEXAMPLE/20150830/us-east-1/service/aws4_request, SignedHeaders=host;x-amz-date, Signature=b97d918cfa904a5beff61c982a1b6f458b799221646efd99d3219ec94cdf2500")

    // ── aws-sig-v4-test-suite: get-vanilla-query-unreserved ──────────
    // Query name & value are the full RFC-3986 unreserved alphabet — none
    // of it may be percent-encoded. Published oracles:
    //   .sts hash : c30d4703d9f799439be92736156d47ccfb2d879ddf56f5befa6d1d6aab979177
    //   signature : 9c3e54bfcdf0b19771a7f523ee5669cdf59bc7cc0884027167c21bb143a40197
    let unres = "-._~0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
    let ureq = Sigv4Request {
        method:        "GET",
        host:          "example.amazonaws.com",
        region:        "us-east-1",
        service:       "service",
        path:          "/",
        query:         unres + "=" + unres,
        headers:       qhdr,
        payload:       "",
        access_key:    "AKIDEXAMPLE",
        secret_key:    "wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY",
        amz_date:      "20150830T123600Z",
        session_token: ""
    }
    let urr = sigv4_sign(ureq)
    let want_ucreq = "GET\n"
        + "/\n"
        + unres + "=" + unres + "\n"
        + "host:example.amazonaws.com\n"
        + "x-amz-date:20150830T123600Z\n"
        + "\n"
        + "host;x-amz-date\n"
        + "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    check_eq("query-unreserved canonical request",
        urr.canonical_request, want_ucreq)
    check_eq("query-unreserved string to sign",
        urr.string_to_sign,
        "AWS4-HMAC-SHA256\n20150830T123600Z\n20150830/us-east-1/service/aws4_request\nc30d4703d9f799439be92736156d47ccfb2d879ddf56f5befa6d1d6aab979177")
    check_eq("query-unreserved signature",
        urr.signature,
        "9c3e54bfcdf0b19771a7f523ee5669cdf59bc7cc0884027167c21bb143a40197")

    // ── aws-sig-v4-test-suite: normalize-path/get-space ──────────────
    // Path "/example space/" -> CanonicalURI "/example%20space/" (space
    // encoded, '/' kept as separator). Published oracles:
    //   creq URI line : /example%20space/
    //   .sts hash     : 63ee75631ed7234ae61b5f736dfc7754cdccfedbff4b5128a915706ee9390d86
    //   signature     : 652487583200325589f1fba4c7e578f72c47cb61beeca81406b39ddec1366741
    let sreq = Sigv4Request {
        method:        "GET",
        host:          "example.amazonaws.com",
        region:        "us-east-1",
        service:       "service",
        path:          "/example space/",
        query:         "",
        headers:       qhdr,
        payload:       "",
        access_key:    "AKIDEXAMPLE",
        secret_key:    "wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY",
        amz_date:      "20150830T123600Z",
        session_token: ""
    }
    let srr = sigv4_sign(sreq)
    let want_screq = "GET\n"
        + "/example%20space/\n"
        + "\n"
        + "host:example.amazonaws.com\n"
        + "x-amz-date:20150830T123600Z\n"
        + "\n"
        + "host;x-amz-date\n"
        + "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    check_eq("get-space canonical request", srr.canonical_request, want_screq)
    check_eq("get-space string to sign",
        srr.string_to_sign,
        "AWS4-HMAC-SHA256\n20150830T123600Z\n20150830/us-east-1/service/aws4_request\n63ee75631ed7234ae61b5f736dfc7754cdccfedbff4b5128a915706ee9390d86")
    check_eq("get-space signature",
        srr.signature,
        "652487583200325589f1fba4c7e578f72c47cb61beeca81406b39ddec1366741")

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
