// HEXA Standard Library — aws/sigv4
//
// @version 0.1.0
// @capabilities [pure, crypto]
//
// AWS Signature Version 4 request signer — a PURE, deterministic function.
// No network, no I/O. Given the request fields it returns the SigV4
// `Authorization` header value plus the `x-amz-date` and
// `x-amz-content-sha256` headers a caller must attach to the request.
//
// Closes inbox/patches/phanes-aws-sigv4-signer-for-stdlib.md and un-defers
// the SigV4 path in self/stdlib/bedrock_sdk.hexa (GAP-D). SigV4 is the auth
// primitive for every AWS service reached over HTTP/JSON (DynamoDB, S3,
// Bedrock, STS, ...). Per @D g_stdlib_ownership it lives here once;
// downstream repos `import` it, never vendor a copy.
//
// The 4-step algorithm (AWS General Reference, "Create a signed request"):
//   1. Canonical request — METHOD \n URI \n QUERY \n HEADERS \n
//      SIGNED_HEADERS \n hex(SHA256(payload))
//   2. String to sign    — "AWS4-HMAC-SHA256" \n amzDate \n
//      date/region/service/aws4_request \n hex(SHA256(canonicalRequest))
//   3. Signing key       — 4-link HMAC chain:
//        kDate    = HMAC("AWS4"+secret, dateStamp)
//        kRegion  = HMAC(kDate, region)
//        kService = HMAC(kRegion, service)
//        kSigning = HMAC(kService, "aws4_request")
//      signature = hex(HMAC(kSigning, stringToSign))
//   4. Authorization     — "AWS4-HMAC-SHA256 Credential=.../scope,
//      SignedHeaders=..., Signature=..."
//
// Verified byte-equal against the official aws-sig-v4-test-suite
// `get-vanilla` fixture in the companion sigv4_test.hexa — see that file
// for the published string-to-sign hash + signature oracles.
//
// @cite FIPS 198-1 (HMAC) · FIPS 180-4 (SHA-256) · AWS SigV4 spec

import "../core/hash/hmac.hexa"

// ── Sign request / result structs ────────────────────────────────────
struct Sigv4Header {
    name:  str,    // header name (caller-supplied case; lowercased internally)
    value: str
}

struct Sigv4Request {
    method:        str,           // "GET", "POST", ...
    host:          str,           // e.g. "dynamodb.us-east-1.amazonaws.com"
    region:        str,           // e.g. "us-east-1"
    service:       str,           // e.g. "dynamodb"
    path:          str,           // absolute path, e.g. "/" or "/key"
    query:         str,           // raw query string without "?", "" if none
    headers:       [Sigv4Header], // request headers (host + any others)
    payload:       str,           // request body, "" if none
    access_key:    str,
    secret_key:    str,
    amz_date:      str,           // ISO8601 basic, e.g. "20150830T123600Z"
    session_token: str            // STS session token, "" if not used
}

struct Sigv4Result {
    authorization:        str,    // value for the Authorization header
    x_amz_date:           str,    // value for the x-amz-date header
    x_amz_content_sha256: str,    // value for the x-amz-content-sha256 header
    // diagnostics — exposed so callers / tests can assert intermediates:
    canonical_request:    str,
    string_to_sign:       str,
    signature:            str,
    signed_headers:       str,
    credential_scope:     str
}

// ── ASCII helpers (locale-free) ──────────────────────────────────────
// Header names are ASCII; lowercase with explicit codepoint math so the
// canonical form never depends on a runtime locale.
fn sigv4_lower(s) -> string {
    let result = ""
    let i = 0
    while i < len(s) {
        let c = ord(s[i])
        if c >= 65 && c <= 90 {
            c = c + 32
        }
        result = result + chr(c)
        i = i + 1
    }
    return result
}

// Trim leading/trailing ASCII spaces and collapse internal runs of spaces
// to a single space — the SigV4 Trim() rule for header values.
fn sigv4_trim(s) -> string {
    let bytes = string_to_byte_array(s)
    let n = len(bytes)
    let start = 0
    while start < n && bytes[start] == 32 {
        start = start + 1
    }
    let end = n
    while end > start && bytes[end - 1] == 32 {
        end = end - 1
    }
    let result = ""
    let i = start
    let prev_space = 0
    while i < end {
        if bytes[i] == 32 {
            if prev_space == 0 {
                result = result + " "
            }
            prev_space = 1
        } else {
            result = result + chr(bytes[i])
            prev_space = 0
        }
        i = i + 1
    }
    return result
}

// ── Hex helper ───────────────────────────────────────────────────────
fn sigv4_sha256_hex(s) -> string {
    return sha256_hex_bytes(string_to_byte_array(s))
}

// ── Step 1: canonical request ────────────────────────────────────────
// Headers must be sorted by lowercased name; SignedHeaders is the
// semicolon-joined sorted lowercase name list.
fn sigv4_canonical_headers(headers: [Sigv4Header]) -> [str] {
    // collect lowercased "name:trimmed-value" plus the name alone
    let names = []
    let lines = []
    let i = 0
    while i < len(headers) {
        let lname = sigv4_lower(headers[i].name)
        names = names.push(lname)
        lines = lines.push(lname + ":" + sigv4_trim(headers[i].value))
        i = i + 1
    }
    // insertion sort on names, carrying lines along (stable, small n)
    let a = 1
    while a < len(names) {
        let key_n = names[a]
        let key_l = lines[a]
        let b = a - 1
        while b >= 0 && names[b] > key_n {
            names[b + 1] = names[b]
            lines[b + 1] = lines[b]
            b = b - 1
        }
        names[b + 1] = key_n
        lines[b + 1] = key_l
        a = a + 1
    }
    // canonical headers block: each line + "\n"
    let canon = ""
    let signed_hdrs = ""
    let j = 0
    while j < len(names) {
        canon = canon + lines[j] + "\n"
        if j > 0 {
            signed_hdrs = signed_hdrs + ";"
        }
        signed_hdrs = signed_hdrs + names[j]
        j = j + 1
    }
    return [canon, signed_hdrs]
}

fn sigv4_canonical_request(req: Sigv4Request, payload_hash) -> [str] {
    let hp = sigv4_canonical_headers(req.headers)
    let canon_headers = hp[0]
    let signed_headers = hp[1]
    // CanonicalURI: empty path -> "/". Path is assumed already-encoded by
    // the caller (AWS service paths like DynamoDB are always "/").
    let uri = req.path
    if uri == "" {
        uri = "/"
    }
    let creq = req.method + "\n"
        + uri + "\n"
        + req.query + "\n"
        + canon_headers + "\n"
        + signed_headers + "\n"
        + payload_hash
    return [creq, signed_headers]
}

// ── Step 3: 4-link HMAC signing-key chain ────────────────────────────
// Each link feeds the previous link's 32 RAW bytes as the next key — this
// is exactly why hmac_sha256_bytes (byte-in/byte-out) is required.
fn sigv4_signing_key(secret, date_stamp, region, service) -> [int] {
    let k_secret = string_to_byte_array("AWS4" + secret)
    let k_date = hmac_sha256_bytes(k_secret, string_to_byte_array(date_stamp))
    let k_region = hmac_sha256_bytes(k_date, string_to_byte_array(region))
    let k_service = hmac_sha256_bytes(k_region, string_to_byte_array(service))
    return hmac_sha256_bytes(k_service, string_to_byte_array("aws4_request"))
}

// ── Public entry point ───────────────────────────────────────────────
// Returns a Sigv4Result. The caller attaches:
//   Authorization:          result.authorization
//   x-amz-date:             result.x_amz_date
//   x-amz-content-sha256:   result.x_amz_content_sha256
//   x-amz-security-token:   req.session_token   (only when non-empty)
// NOTE: req.headers MUST already contain `host`, `x-amz-date`, and (when a
// session token is used) `x-amz-security-token`, since every signed header
// must appear in the canonical headers block.
pub fn sigv4_sign(req: Sigv4Request) -> Sigv4Result {
    // date stamp = first 8 chars of the ISO8601 amz_date (YYYYMMDD)
    let date_stamp = ""
    let d = 0
    while d < 8 {
        date_stamp = date_stamp + req.amz_date[d]
        d = d + 1
    }

    // payload hash — hex(SHA256(body)); empty body hashes the empty string.
    let payload_hash = sigv4_sha256_hex(req.payload)

    // Step 1 — canonical request.
    let cr = sigv4_canonical_request(req, payload_hash)
    let canonical_request = cr[0]
    let signed_headers = cr[1]

    // Step 2 — string to sign.
    let cred_scope = date_stamp + "/" + req.region + "/" + req.service + "/aws4_request"
    let string_to_sign = "AWS4-HMAC-SHA256" + "\n"
        + req.amz_date + "\n"
        + cred_scope + "\n"
        + sigv4_sha256_hex(canonical_request)

    // Step 3 — signing key + signature.
    let k_signing = sigv4_signing_key(req.secret_key, date_stamp, req.region, req.service)
    let signature = hmac_sha256_hex(k_signing, string_to_byte_array(string_to_sign))

    // Step 4 — Authorization header value.
    let authorization = "AWS4-HMAC-SHA256 "
        + "Credential=" + req.access_key + "/" + cred_scope + ", "
        + "SignedHeaders=" + signed_headers + ", "
        + "Signature=" + signature

    return Sigv4Result {
        authorization:        authorization,
        x_amz_date:           req.amz_date,
        x_amz_content_sha256: payload_hash,
        canonical_request:    canonical_request,
        string_to_sign:       string_to_sign,
        signature:            signature,
        signed_headers:       signed_headers,
        credential_scope:     cred_scope
    }
}
