// HEXA Standard Library — mol Stage-2 SMILES parser tests
//
// Self-validating gate for mol_from_smiles (hoisted byte-parity cmt
// parser). Stage-2 = NEW kernel (rdkit not installed → no .py golden);
// validated against known molecules + the cmt failure convention
// (invalid SMILES → empty flagged Mol, mol_num_atoms == 0).
//
// Note: the cmt parser keeps HEAVY atoms only (H implicit). Assertions
// are heavy-atom-consistent — they do not assume an explicit-H graph.

import "stdlib/mol/mod.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: string, cond: bool) {
    total_count = total_count + 1
    if cond { pass_count = pass_count + 1 }
    else { if failed == "" { failed = name } }
}

fn count_sym(m: Mol, sym: string) -> int {
    let at = mol_atoms(m)
    let mut k = 0
    let mut i = 0
    while i < len(at) {
        if at[i] == sym { k = k + 1 }
        i = i + 1
    }
    return k
}

fn has_bond_order(m: Mol, ord: int) -> bool {
    let bs = m.bonds
    let mut i = 0
    while i < len(bs) {
        let b = bs[i]
        if b[2] == ord { return true }
        i = i + 1
    }
    return false
}

fn main() {
    // ── "C" → single carbon, no bonds ──
    let m_c = mol_from_smiles("C")
    check("C: 1 heavy atom", mol_num_atoms(m_c) == 1)
    check("C: atom is C", count_sym(m_c, "C") == 1)
    check("C: 0 bonds", mol_num_bonds(m_c) == 0)

    // ── "CCO" (ethanol) → 2 C + 1 O heavy, >= 2 bonds ──
    let m_cco = mol_from_smiles("CCO")
    check("CCO: 3 heavy atoms", mol_num_atoms(m_cco) == 3)
    check("CCO: 2 C", count_sym(m_cco, "C") == 2)
    check("CCO: 1 O", count_sym(m_cco, "O") == 1)
    check("CCO: >= 2 bonds", mol_num_bonds(m_cco) >= 2)

    // ── "c1ccccc1" (benzene) → 6 aromatic C, 6 ring bonds ──
    let m_bz = mol_from_smiles("c1ccccc1")
    check("benzene: 6 heavy atoms", mol_num_atoms(m_bz) == 6)
    check("benzene: 6 C", count_sym(m_bz, "C") == 6)
    check("benzene: 6 ring bonds", mol_num_bonds(m_bz) == 6)

    // ── "[NH4+]" → charge +1 ──
    let m_nh4 = mol_from_smiles("[NH4+]")
    check("[NH4+]: 1 heavy atom (N)", mol_num_atoms(m_nh4) == 1)
    check("[NH4+]: charge +1", mol_charge(m_nh4) == 1)

    // ── "[O-]" → charge -1 ──
    let m_om = mol_from_smiles("[O-]")
    check("[O-]: 1 heavy atom (O)", mol_num_atoms(m_om) == 1)
    check("[O-]: charge -1", mol_charge(m_om) == -1)

    // ── "CC(=O)O" (acetic acid) → has a double bond (order 2) ──
    let m_aa = mol_from_smiles("CC(=O)O")
    check("acetic acid: 4 heavy atoms (2C 2O)", mol_num_atoms(m_aa) == 4)
    check("acetic acid: 2 C", count_sym(m_aa, "C") == 2)
    check("acetic acid: 2 O", count_sym(m_aa, "O") == 2)
    check("acetic acid: has double bond (order 2)", has_bond_order(m_aa, 2))

    // ── invalid "C(" → cmt convention: parse fails → empty Mol ──
    let m_bad = mol_from_smiles("C(")
    check("C(: invalid → 0 heavy atoms (flagged Mol)", mol_num_atoms(m_bad) == 0)
    check("C(: invalid → 0 bonds", mol_num_bonds(m_bad) == 0)

    // ── invalid ")" → unbalanced, flagged Mol ──
    let m_bad2 = mol_from_smiles(")")
    check(")(: invalid → 0 heavy atoms", mol_num_atoms(m_bad2) == 0)

    // ── cross-check with committed descriptor (heavy-atom consistent):
    // mol_hba counts N+O atoms; ethanol heavy graph has 1 O → HBA 1.
    check("CCO: mol_hba == 1 (1 O heavy)", mol_hba(m_cco) == 1)

    if pass_count == total_count {
        println("__MOL_SMILES_TEST__ PASS (" + str(pass_count) + "/" + str(total_count) + ")")
        return
    }
    println("__MOL_SMILES_TEST__ FAIL (" + str(pass_count) + "/" + str(total_count) + ") first-fail: " + failed)
    exit(1)
}
