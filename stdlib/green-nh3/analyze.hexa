#!hexa strict
// green-nh3 analyze â€” Gibbs Î”G for Nâ‚‚+3Hâ‚‚â†’2NHâ‚ƒ at 298 K.
fn main() {
    let dH_kJmol = -92.4
    let dS_JmolK = -198.3
    let T_K = 298.0
    let dG_kJmol = dH_kJmol - T_K * dS_JmolK / 1000.0
    println("green-nh3_analyze (Haber-Bosch Â· 298 K):")
    println("  dH_kJ_per_mol = " + str(dH_kJmol))
    println("  dS_J_per_molK = " + str(dS_JmolK))
    println("  dG_kJ_per_mol = " + str(dG_kJmol))
    println("__HEXA_GREEN_NH3_ANALYZE__ PASS gate=GATE_OPEN absorbed=false")
}
