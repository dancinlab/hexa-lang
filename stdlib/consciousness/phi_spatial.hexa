// HEXA Standard Library — consciousness/phi_spatial
//
// @version 0.1.0
// @capabilities [pure]
//
// Spatial integrated information (Φ) over a flat row-major n_cells × dim state.
// Composition wrapper that ties together the already-landed info/math stdlib
// modules. Promoted from anima HEXAD/LIFE phi_native.hexa (`phi_native_spatial`)
// per RFC stdlib_scaffold §5 (2nd wave, following M3 precedent PR #769).
//
//   Φ_spatial = max(total_MI − min_partition_MI, 0) / max(n_cells − 1, 1)
//
// Algorithm (RFC 036 byte-equal target: phi_spatial builtin / c_measure_phi,
// self/runtime.c:7941-8003):
//   step 3a/3b  pairwise MI matrix (upper triangle) + total MI
//   step 3c     min-information partition — cell 0 pinned to A, exhaustive over
//               2^(n−1) − 1 non-trivial bipartitions (n_cells ≤ 20)
//   step 4      scalar Φ normalisation
//
// HONEST CARVE-OUT (anima spec § L3): n_cells > 20 is out of v1 scope. The C
// replica silently returns the min_part = 0 placeholder; this module PANICs so
// callers cannot mistake a placeholder for a real Φ. The greedy path is a
// future cycle.
//
// Byte-equality note: this calls `pow2_int`/`bit_set` from stdlib/math/bitops,
// which codegen to native `<<`/`&` rather than the anima source's
// multiplication accumulator. The integer results are identical, so the
// byte-equal target (RFC 036 phi_spatial builtin) is preserved. The downstream
// byte-equal-vs-builtin comparison is deferred to integration.
//
// NAME — exported as `phi_spatial_native` (NOT `phi_spatial`): `phi_spatial` is
// already a builtin (codegen → hexa_phi_spatial, runtime.c:7941); a stdlib fn of
// that name collides (redefinition) when imported + flattened. This pure-hexa
// replica is the byte-equal-FROZEN reference — the C-replica builtin has since
// drifted from it (rfc_036_c_replica_drift), so callers wanting the frozen
// values must use this module, not the builtin.
//
// Surface:
//   pub fn phi_spatial_native(state: int, n_cells: int, dim: int, n_bins: int) -> float
//     state  = flat farr handle, length >= n_cells * dim (row-major; cell i
//              row = state[i*dim .. i*dim+dim]).
//     n_cells = number of IIT cells (<= 20 for exact bipartition; > 20 panics).
//     dim     = per-cell state vector length.
//     n_bins  = histogram bin count for the MI estimator.

import "stdlib/info/mutual_info.hexa"
import "stdlib/math/bitops.hexa"

pub fn phi_spatial_native(state: int, n_cells: int, dim: int, n_bins: int) -> float {
    // Degenerate guards (runtime.c:7949-7951).
    if n_cells <= 0 { return 0.0 }
    if dim <= 0 { return 0.0 }
    if n_bins <= 0 { return 0.0 }
    if n_cells <= 1 { return 0.0 }

    // L3 carve-out — exact path only for n_cells <= 20 (spec § L3 / 7995).
    // C replica returns min_part = 0 silently; we panic so callers cannot
    // mistake a placeholder for a real Φ. Greedy path = future cycle.
    if n_cells > 20 {
        panic("phi_spatial_native: n_cells > 20 not yet supported (greedy path TODO; spec § L3)")
    }

    // ── step 3a + 3b — pairwise MI matrix + total (upper triangle sum) ─────
    // runtime.c:7953-7963. C uses S + i*dim pointer slice; hexa has no farr
    // view (spec § L2) so we row-copy into temp farrs per (i, j) pair.
    let mi = farr_zeros(n_cells * n_cells)
    let mut total = 0.0
    let mut i = 0
    while i < n_cells {
        let mut j = i + 1
        while j < n_cells {
            let row_i = farr_zeros(dim)
            let row_j = farr_zeros(dim)
            let mut d = 0
            while d < dim {
                let _ = farr_set(row_i, d, farr_get(state, i * dim + d))
                let _ = farr_set(row_j, d, farr_get(state, j * dim + d))
                d = d + 1
            }
            let v = mutual_info_pair(row_i, row_j, dim, n_bins)
            let _ = farr_set(mi, i * n_cells + j, v)
            let _ = farr_set(mi, j * n_cells + i, v)    // symmetric
            total = total + v
            let _ = farr_free(row_i)
            let _ = farr_free(row_j)
            j = j + 1
        }
        i = i + 1
    }

    // ── step 3c — min-information partition (runtime.c:7965-7996) ──────────
    // cell 0 pinned to A; bit b of mask ⇒ cell b+1 ∈ A iff set.
    let mut min_part = 0.0
    if n_cells == 2 {
        min_part = farr_get(mi, 1)                      // mi[0*nc+1] = mi[1]
    } else {
        // n_cells ∈ [3, 20] — exhaustive over 2^(n-1) - 1 non-trivial masks.
        min_part = 1.0e308                              // +INF proxy (7969)
        let max_mask = pow2_int(n_cells - 1)
        let mut mask = 1
        while mask < max_mask {
            // Skip trivial (B empty) — i.e. all (n-1) lower bits are set.
            // any_b = 1 if at least one bit is UNSET (runtime.c:7973-7975).
            let mut any_b = 0
            let mut b = 0
            while b < n_cells - 1 {
                if bit_set(mask, b) == 0 { any_b = 1 }
                b = b + 1
            }
            if any_b == 1 {
                // cross-partition MI sum: A = {0} ∪ {b+1 : bit b set}; B = rest.
                let mut cross = 0.0
                let mut ia = 0
                while ia < n_cells {
                    let mut inA = 0
                    if ia == 0 {
                        inA = 1
                    } else {
                        if bit_set(mask, ia - 1) == 1 { inA = 1 }
                    }
                    if inA == 1 {
                        let mut jb = 0
                        while jb < n_cells {
                            let mut jInA = 0
                            if jb == 0 {
                                jInA = 1
                            } else {
                                if bit_set(mask, jb - 1) == 1 { jInA = 1 }
                            }
                            // jb ∈ B only (jInA == 0) — runtime.c:7986.
                            if jInA == 0 {
                                cross = cross + farr_get(mi, ia * n_cells + jb)
                            }
                            jb = jb + 1
                        }
                    }
                    ia = ia + 1
                }
                if cross < min_part { min_part = cross }
            }
            mask = mask + 1
        }
    }

    let _ = farr_free(mi)

    // ── step 4 — scalar Φ (runtime.c:7998-8003) ────────────────────────────
    let n = n_cells                                     // promote to float in /
    let mut denom = 1.0
    if (n - 1.0) > 1.0 { denom = n - 1.0 }              // max(n-1, 1)
    let mut sp = total - min_part
    if sp < 0.0 { sp = 0.0 }                            // 8002 clamp ≥ 0
    return sp / denom
}
