// HEXA Standard Library — consciousness/phi_spatial
//
// @version 0.1.0
// @capabilities [pure]
//
// Pure-hexa port of the RFC 036 phi_spatial pipeline, composed from
// stdlib leaves (math/bitops + info/mutual_info). Wrapper-only — all
// numerical primitives live in info/* + math/*.
//
// Surface:
//   pub fn phi_spatial(state: int, n_cells: int, dim: int, n_bins: int)
//                                                              -> float
//     state   : flat farr handle, length ≥ n_cells * dim (row-major)
//     n_cells : IIT cell count (≤ 20 exhaustive bipartition; > 20 = panic)
//     dim     : per-cell vector length
//     n_bins  : histogram bin count for MI estimator
//
//   Output: spatial Φ = max(total_MI − min_partition_MI, 0) / max(n_cells - 1, 1)
//
// Reference impl (byte-equal target): anima/HEXAD/LIFE/lib/phi_native.hexa
// § phi_native_spatial (332 LoC source). This wrapper is ~90 LoC because
// the 4 numerical leaves (bin, entropy, MI, bitops) live in stdlib.
//
// Carve-outs (inherited from anima reference):
//   L1  C replica f32-cast bin drift — n/a here (f64 throughout)
//   L2  hexa no farr-view → row-copy per (i,j) pair (n² × dim memcpy)
//   L3  n_cells > 20 panic (greedy MIP path future cycle)
//   L4  log2 multiply→divide drift (M4 regression 2026-05-25) — within PHI 🟢
//
// Stack: anima STDLIB M3 phase 1 closure + M3-6 (2nd-wave wrapper).

import "stdlib/math/bitops.hexa"
import "stdlib/info/mutual_info.hexa"

pub fn phi_spatial(state: int, n_cells: int, dim: int, n_bins: int) -> float {
    if n_cells <= 0 { return 0.0 }
    if dim <= 0 { return 0.0 }
    if n_bins <= 0 { return 0.0 }
    if n_cells <= 1 { return 0.0 }

    // L3 carve-out — exact path only for n_cells ≤ 20.
    if n_cells > 20 {
        panic("phi_spatial: n_cells > 20 not yet supported (greedy path future cycle; spec § L3)")
    }

    // step 3a + 3b — pairwise MI matrix + total (upper triangle sum).
    let mi = farr_zeros(n_cells * n_cells)
    let mut total = 0.0
    let mut i = 0
    while i < n_cells {
        let mut j = i + 1
        while j < n_cells {
            let row_i = farr_zeros(dim)
            let row_j = farr_zeros(dim)
            let mut d = 0
            while d < dim {
                let _ = farr_set(row_i, d, farr_get(state, i * dim + d))
                let _ = farr_set(row_j, d, farr_get(state, j * dim + d))
                d = d + 1
            }
            let v = mutual_info_pair(row_i, row_j, dim, n_bins)
            let _ = farr_set(mi, i * n_cells + j, v)
            let _ = farr_set(mi, j * n_cells + i, v)
            total = total + v
            let _ = farr_free(row_i)
            let _ = farr_free(row_j)
            j = j + 1
        }
        i = i + 1
    }

    // step 3c — min-information partition.
    let mut min_part = 0.0
    if n_cells == 2 {
        min_part = farr_get(mi, 1)
    } else {
        min_part = 1.0e308
        let max_mask = pow2_int(n_cells - 1)
        let mut mask = 1
        while mask < max_mask {
            let mut any_b = 0
            let mut b = 0
            while b < n_cells - 1 {
                if bit_set(mask, b) == 0 { any_b = 1 }
                b = b + 1
            }
            if any_b == 1 {
                let mut cross = 0.0
                let mut ia = 0
                while ia < n_cells {
                    let mut inA = 0
                    if ia == 0 {
                        inA = 1
                    } else {
                        if bit_set(mask, ia - 1) == 1 { inA = 1 }
                    }
                    if inA == 1 {
                        let mut jb = 0
                        while jb < n_cells {
                            let mut jInA = 0
                            if jb == 0 {
                                jInA = 1
                            } else {
                                if bit_set(mask, jb - 1) == 1 { jInA = 1 }
                            }
                            if jInA == 0 {
                                cross = cross + farr_get(mi, ia * n_cells + jb)
                            }
                            jb = jb + 1
                        }
                    }
                    ia = ia + 1
                }
                if cross < min_part { min_part = cross }
            }
            mask = mask + 1
        }
    }

    let _ = farr_free(mi)

    // step 4 — scalar Φ.
    let n = n_cells
    let mut denom = 1.0
    if (n - 1.0) > 1.0 { denom = n - 1.0 }
    let mut sp = total - min_part
    if sp < 0.0 { sp = 0.0 }
    return sp / denom
}
