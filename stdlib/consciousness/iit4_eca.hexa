// HEXA Standard Library — consciousness/iit4_eca
//
// @version 0.1.0
// @capabilities [pure]
//
// IIT 4.0 M6 — elementary cellular automaton (ECA) substrate bridge.
// Promoted from anima HEXAD/IIT4/lib/iit4_eca.hexa per g61 (absolute-path
// import resolution: anima bench/basin_phi_coupling/bench.hexa was reaching
// into the anima repo for this, which the stdlib advisory flagged).
//
// ROLE
//   Bridges the LIFE lane's substrate — the deterministic binary dynamical
//   systems behind H_002 C2 / H_278 (elementary CA, Wolfram rules) — into an
//   IIT 4.0 state-by-node TPM so the faithful causal engine (M1-M4) can
//   re-measure them. A periodic ring of n cells under an ECA rule IS a TPM:
//   cell i's next value is determined deterministically by its 3-cell
//   neighborhood, so each of the 2^n states maps to per-cell next-probabilities
//   (0.0 / 1.0). This is the SAME family of substrates the proxy phi_spatial
//   (RFC 036, correlational MI) measured — now measured CAUSALLY.
//
// FORMULA
//   eca_tpm(rule, n) — Wolfram rule ∈ [0, 255] · n cells in a periodic ring.
//     TPM[s*n + i] = bit_{(4·L + 2·C + R)}(rule)
//   where (L, C, R) are the left / centre / right neighbours of cell i in
//   state s with ring wrap. Deterministic ⇒ entries are 0.0 / 1.0.
//
// Surface:
//   pub fn eca_tpm(rule: int, n: int) -> array
//     Returns a flat state-by-node TPM of length n · 2^n.

import "stdlib/consciousness/iit4_tpm.hexa"

pub fn eca_tpm(rule: int, n: int) -> array {
    let full = iit4_pow2(n)
    let mut t = []
    let mut s = 0
    while s < full {
        let mut i = 0
        while i < n {
            let l = iit4_bit(s, (i - 1 + n) % n)           // left neighbour (ring wrap)
            let c = iit4_bit(s, i)                          // centre
            let r = iit4_bit(s, (i + 1) % n)               // right neighbour
            let idx = 4 * l + 2 * c + r                    // Wolfram neighbourhood index 0..7
            t = t.push(to_float(iit4_bit(rule, idx)))      // next value = bit idx of rule
            i = i + 1
        }
        s = s + 1
    }
    return t
}
