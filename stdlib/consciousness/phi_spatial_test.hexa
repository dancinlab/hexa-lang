// HEXA Standard Library — consciousness/phi_spatial_test
//
// Canonical import-based test for stdlib/consciousness/phi_spatial.
// NOTE: single-file `hexa build` does not flatten `import "stdlib/..."`, so
// this file is the canonical test even though it cannot be built standalone.
// The self-contained algorithm verify (inlined sc_ copies, no imports) is the
// build-runnable counterpart and is intentionally NOT committed.

import "stdlib/consciousness/phi_spatial.hexa"

fn _check_flag(name: string, ok: int) -> int {
    if ok == 1 {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name)
    return 1
}

fn main() {
    let mut fails = 0

    // ── 2-cell sanity: n_cells=2, dim=4, n_bins=4 — runs, Φ >= 0 ──
    // Two distinct ramps so MI is well-defined.
    let st = farr_zeros(8)
    let _ = farr_set(st, 0, 0.0)
    let _ = farr_set(st, 1, 1.0)
    let _ = farr_set(st, 2, 2.0)
    let _ = farr_set(st, 3, 3.0)
    let _ = farr_set(st, 4, 3.0)
    let _ = farr_set(st, 5, 2.0)
    let _ = farr_set(st, 6, 1.0)
    let _ = farr_set(st, 7, 0.0)
    let phi = phi_spatial_native(st, 2, 4, 4)
    let mut ok = 0
    if phi >= 0.0 { ok = 1 }
    fails = fails + _check_flag("phi_spatial 2-cell >= 0", ok)
    let _ = farr_free(st)

    // ── degenerate guards return 0.0 ──
    let st2 = farr_zeros(4)
    let g1 = phi_spatial_native(st2, 1, 4, 4)   // n_cells <= 1
    let g2 = phi_spatial_native(st2, 0, 4, 4)   // n_cells <= 0
    let g3 = phi_spatial_native(st2, 2, 0, 4)   // dim <= 0
    let g4 = phi_spatial_native(st2, 2, 4, 0)   // n_bins <= 0
    let mut gok = 0
    if g1 == 0.0 { if g2 == 0.0 { if g3 == 0.0 { if g4 == 0.0 { gok = 1 } } } }
    fails = fails + _check_flag("phi_spatial degenerate guards = 0.0", gok)
    let _ = farr_free(st2)

    // ── 3-cell exhaustive-partition path runs, Φ >= 0 ──
    let st3 = farr_zeros(6)
    let _ = farr_set(st3, 0, 0.0)
    let _ = farr_set(st3, 1, 1.0)
    let _ = farr_set(st3, 2, 1.0)
    let _ = farr_set(st3, 3, 0.0)
    let _ = farr_set(st3, 4, 0.0)
    let _ = farr_set(st3, 5, 1.0)
    let phi3 = phi_spatial_native(st3, 3, 2, 2)
    let mut ok3 = 0
    if phi3 >= 0.0 { ok3 = 1 }
    fails = fails + _check_flag("phi_spatial 3-cell exhaustive >= 0", ok3)
    let _ = farr_free(st3)

    // ── positive control: n_cells >= 3 yields Φ > 0 with shared structure ──
    // (n_cells == 2 always gives Φ == 0: the single bipartition equals total.)
    // Cells 0,1 are identical ramps (high MI); cell 2 is the anti-ramp.
    let st4 = farr_zeros(12)
    let _ = farr_set(st4, 0, 0.0)
    let _ = farr_set(st4, 1, 1.0)
    let _ = farr_set(st4, 2, 2.0)
    let _ = farr_set(st4, 3, 3.0)
    let _ = farr_set(st4, 4, 0.0)
    let _ = farr_set(st4, 5, 1.0)
    let _ = farr_set(st4, 6, 2.0)
    let _ = farr_set(st4, 7, 3.0)
    let _ = farr_set(st4, 8, 3.0)
    let _ = farr_set(st4, 9, 2.0)
    let _ = farr_set(st4, 10, 1.0)
    let _ = farr_set(st4, 11, 0.0)
    let phi4 = phi_spatial_native(st4, 3, 4, 4)
    let mut ok4 = 0
    if phi4 > 0.0 { ok4 = 1 }
    fails = fails + _check_flag("phi_spatial 3-cell structured > 0", ok4)
    let _ = farr_free(st4)

    if fails == 0 {
        println("ALL PASS — stdlib consciousness/phi_spatial")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
