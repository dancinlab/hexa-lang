// stdlib/consciousness/iit4_eca_test — self-test for eca_tpm.
//
// Oracles (4):
//   1. shape — eca_tpm(rule, n) returns length n · 2^n
//   2. Wolfram rule 0  — every neighbourhood → 0, so all TPM entries = 0.0
//   3. Wolfram rule 255 — every neighbourhood → 1, so all TPM entries = 1.0
//   4. Wolfram rule 30 — known canonical: state 0 (all-zero ring n=3) → all 0;
//      state 1 (cell 0 alive in ring n=3) → next state per rule-30 transition
//      table — verifies bit-extraction matches the Wolfram convention.
//
// Self-contained (no cross-stdlib import beyond the unit under test).

import "stdlib/consciousness/iit4_eca.hexa"
import "stdlib/consciousness/iit4_tpm.hexa"

fn _fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

fn _approx(a: float, b: float) -> int {
    if _fabs(a - b) < 0.000001 { return 1 }
    return 0
}

fn main() {
    let mut fails = 0

    // 1. Shape: rule 30, n=3 → length 3 · 8 = 24
    let t30 = eca_tpm(30, 3)
    if len(t30) == 24 {
        println("PASS shape n=3 len=24")
    } else {
        println("FAIL shape len=" + to_string(len(t30)))
        fails = fails + 1
    }

    // 2. Rule 0 → all zero
    let t0 = eca_tpm(0, 4)
    let mut all_zero = 1
    let mut i = 0
    while i < len(t0) {
        if _approx(t0[i], 0.0) == 0 { all_zero = 0 }
        i = i + 1
    }
    if all_zero == 1 {
        println("PASS rule 0 all-zero TPM")
    } else {
        println("FAIL rule 0 nonzero entries")
        fails = fails + 1
    }

    // 3. Rule 255 → all one
    let t255 = eca_tpm(255, 4)
    let mut all_one = 1
    let mut j = 0
    while j < len(t255) {
        if _approx(t255[j], 1.0) == 0 { all_one = 0 }
        j = j + 1
    }
    if all_one == 1 {
        println("PASS rule 255 all-one TPM")
    } else {
        println("FAIL rule 255 non-one entries")
        fails = fails + 1
    }

    // 4. Rule 30 on n=3, state 0 (000): each cell sees (L=0,C=0,R=0) → idx=0
    //    → bit_0(30) = bit_0(0b00011110) = 0. All zero.
    //    For state 1 (001): cell 0 sees (L=1[wrap],C=0,R=0)=4·1+0+0=4 → bit_4(30)=
    //      0b00011110 bit 4 = 1. cell 1 sees (L=0,C=0,R=1)=0+0+1=1 → bit_1(30)=1.
    //      cell 2 sees (L=0,C=1,R=0[wrap])=0+2+0=2 → bit_2(30)=1.
    //    So state 1 row = [1.0, 1.0, 1.0].
    //
    // State 0 row (indices 0,1,2):
    let s0_c0 = t30[0]
    let s0_c1 = t30[1]
    let s0_c2 = t30[2]
    if _approx(s0_c0, 0.0) == 1 && _approx(s0_c1, 0.0) == 1 && _approx(s0_c2, 0.0) == 1 {
        println("PASS rule 30 state-0 row [0,0,0]")
    } else {
        println("FAIL rule 30 state-0: [" + to_string(s0_c0) + "," + to_string(s0_c1) + "," + to_string(s0_c2) + "]")
        fails = fails + 1
    }

    // State 1 row (indices 3,4,5):
    let s1_c0 = t30[3]
    let s1_c1 = t30[4]
    let s1_c2 = t30[5]
    if _approx(s1_c0, 1.0) == 1 && _approx(s1_c1, 1.0) == 1 && _approx(s1_c2, 1.0) == 1 {
        println("PASS rule 30 state-1 row [1,1,1]")
    } else {
        println("FAIL rule 30 state-1: [" + to_string(s1_c0) + "," + to_string(s1_c1) + "," + to_string(s1_c2) + "]")
        fails = fails + 1
    }

    if fails == 0 {
        println("ALL PASS — stdlib/consciousness/iit4_eca")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
