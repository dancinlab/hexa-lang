// HEXAD/IIT4/lib/iit4_complex.hexa — IIT 4.0 engine M10: exclusion postulate.
//
//   ROLE
//     The exclusion postulate (IIT 4.0, DESIGN §2 ⑦ family). big_phi (M4,
//     iit4_bigphi.hexa) measures the irreducibility of THE given n-unit system.
//     But IIT 4.0 says the conscious entity is the MAXIMAL COMPLEX — the
//     subsystem S (a subset of the n units) whose big-Φ is maximal among ALL
//     candidate subsystems. Overlapping lower-Φ candidates are EXCLUDED. This
//     module searches every non-empty subset and returns the maximal complex.
//
//   subsystem_tpm(tpm, n, subset_mask, sys_state)
//     Build the |S|-unit state-by-node TPM for the subsystem S = `subset_mask`,
//     treating the EXTERNAL units (those NOT in S) as a FIXED BACKGROUND pinned
//     to their values in `sys_state`. For each compact sub-state cs of S (over
//     2^|S| states) and each S-unit u, the next-ON probability is the original
//     TPM marginal with BOTH the S-units pinned to cs AND the external units
//     pinned to their `sys_state` values — i.e. iit4_marginal_on with
//     fix_mask = (subset_mask ∪ external_units) = the full mask, fix_state =
//     (cs expanded onto S-positions) + (sys_state restricted to external
//     positions). The returned TPM uses COMPACT indices 0..|S|-1 mapping to the
//     ascending absolute S-units. Length = 2^|S| * |S|.
//
//   find_complex(tpm, n, sys_state) -> [complex_mask, complex_phi, complex_size]
//     argmax big_phi over all 2^n − 1 non-empty candidate subsets. Each subset S
//     is re-measured as its OWN system via subsystem_tpm + big_phi at S's own
//     restricted sub-state (sys_state projected onto S's compact indices).
//     TIE-BREAK (documented, deterministic): strictly-greater Φ wins; on an
//     exact Φ tie, prefer the LARGER subset (more units = a bigger entity), and
//     on equal size prefer the LOWER absolute mask. A subset of size 1 has
//     big_phi ≡ 0 (n < 2 guard in big_phi) so a singleton never wins unless ALL
//     Φ are 0, in which case there is NO complex and we return mask = 0
//     (complex_size = 0, complex_phi = 0) — "all-noise → no complex".
//
//   HONEST CARVE-OUT (g5)
//     Subsystem big-Φ uses BACKGROUND-CONDITIONING of external units (each
//     external unit pinned to its sys_state value — the IIT 4.0 "fix the
//     background to the current state" convention, a documented modeling
//     choice). This is the causal-marginalization read of exclusion, not a
//     full re-derivation of the partitioned normalization (that + PyPhi
//     calibration remain the M5 carve-out noted in iit4_bigphi.hexa). Reported
//     Φ values are the real engine output of big_phi on the conditioned TPM.
//
//   IMPORT-SAFE  NO `fn main()` / NO top-level call. snake_case · English code ·
//     bitwise ops avoided (iit4_bit / iit4_pow2 only). Imports iit4_bigphi
//     (single chain → big_phi + all M1-M4 helpers visible).
// ════════════════════════════════════════════════════════════════════════════
import "stdlib/consciousness/iit4_bigphi.hexa"


// ── absolute mask of external units (those NOT in `subset_mask`, within [0,n)). ──
pub fn iit4_external_mask(subset_mask: int, n: int) -> int {
    let mut ext = 0
    let mut i = 0
    while i < n {
        if iit4_bit(subset_mask, i) == 0 { ext = ext + iit4_pow2(i) }
        i = i + 1
    }
    return ext
}


// ── project an absolute `sys_state` onto the COMPACT sub-indices of `units`. ──
// returns the compact sub-state (bit b = value of absolute unit units[b] in sys_state).
pub fn iit4_project_state(sys_state: int, units: array) -> int {
    let mut cs = 0
    let mut b = 0
    let k = len(units)
    while b < k {
        if iit4_bit(sys_state, units[b]) == 1 { cs = cs + iit4_pow2(b) }
        b = b + 1
    }
    return cs
}


// ── subsystem TPM — condition external units to their fixed sys_state values. ──
// Returns a flat |S|-unit state-by-node TPM (length 2^|S| * |S|), compact-indexed.
pub fn subsystem_tpm(tpm: array, n: int, subset_mask: int, sys_state: int) -> array {
    let s_units = iit4_units(subset_mask, n)          // ascending absolute S-units
    let k = len(s_units)
    let ext_mask = iit4_external_mask(subset_mask, n) // external (background) units
    // external units stay pinned to their CURRENT (sys_state) values throughout.
    let full_fix_mask = subset_mask + ext_mask        // = (2^n − 1) over the n units
    let sub_states = iit4_pow2(k)

    let mut out = []
    let mut cs = 0
    while cs < sub_states {
        // expand compact sub-state cs onto the absolute S-positions.
        let s_abs = iit4_expand(cs, s_units)
        // fixed state = S pinned to cs (absolute) + external pinned to sys_state.
        // external bits taken from sys_state; S bits taken from s_abs; the two
        // masks are disjoint and cover all n units, so a simple sum composes them.
        let mut fix_state = s_abs
        let mut i = 0
        while i < n {
            if iit4_bit(ext_mask, i) == 1 {
                if iit4_bit(sys_state, i) == 1 { fix_state = fix_state + iit4_pow2(i) }
            }
            i = i + 1
        }
        // each S-unit's next-ON marginal under the fully-pinned background.
        let mut b = 0
        while b < k {
            let target = s_units[b]
            let p = iit4_marginal_on(tpm, n, full_fix_mask, fix_state, target)
            out = out.push(p)
            b = b + 1
        }
        cs = cs + 1
    }
    return out
}


// ── find the maximal complex (exclusion postulate). ─────────────────────────
// Returns [complex_mask, complex_phi, complex_size]. See header for tie-break.
pub fn find_complex(tpm: array, n: int, sys_state: int) -> array {
    let full = iit4_pow2(n)
    let mut best_mask = 0
    let mut best_phi = 0.0
    let mut best_size = 0
    let eps = 1.0e-9

    let mut cand = 1                                  // every non-empty subset
    while cand < full {
        let s_units = iit4_units(cand, n)
        let k = len(s_units)
        // build S's own system TPM (external background conditioned) and its
        // own restricted sub-state, then measure big-Φ.
        let sub_tpm = subsystem_tpm(tpm, n, cand, sys_state)
        let sub_state = iit4_project_state(sys_state, s_units)
        let r = big_phi(sub_tpm, k, sub_state)
        let phi = r[0]

        // accept iff this candidate beats the incumbent under the tie-break:
        //   (1) strictly greater Φ                            → win
        //   (2) Φ tie within eps AND larger subset            → win
        //   (3) Φ tie within eps AND equal size AND lower mask → win (cand ascends,
        //        so the FIRST equal-size tie already holds the lowest mask; we keep it)
        let mut take = 0
        if phi > best_phi + eps { take = 1 }
        else {
            let tie = (phi > best_phi - eps) && (phi < best_phi + eps)
            if tie {
                if k > best_size { take = 1 }
            }
        }
        if take == 1 {
            best_mask = cand
            best_phi = phi
            best_size = k
        }
        cand = cand + 1
    }

    // all-noise / fully-reducible everywhere ⇒ max Φ = 0 ⇒ NO complex.
    if best_phi <= eps {
        return [0.0, 0.0, 0.0]
    }
    return [to_float(best_mask), best_phi, to_float(best_size)]
}
