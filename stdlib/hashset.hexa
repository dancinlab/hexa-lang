// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/hashset.hexa — canonical HashSet[T] (map-backed)
//
//  @module(slug="hashset", desc="canonical set-of-T over the native map primitive")
//  @usage(use "stdlib/hashset"; let s = hashset_new(); hashset_insert(s, x))
//
//  ── module governance metadata ─────────────────────────────────────────────
//  @version 0.2.0
//  @capabilities [hashset_new, hashset_from_array, hashset_insert,
//                 hashset_contains, hashset_remove, hashset_len,
//                 hashset_is_empty, hashset_clear, hashset_to_array,
//                 hashset_union, hashset_intersect, hashset_difference,
//                 hashset_symmetric_difference, hashset_is_subset,
//                 hashset_is_superset]
//  @stability preview
//  @since 2026-05-24
//  @maintainer hexa-core
//  @priority P0
//
//  ── PROBLEM ───────────────────────────────────────────────────────────────
//
//  Sister repos (anima, nexus, phanes, wilson) repeatedly reinvent
//  "set membership" by hand on top of arrays:
//
//      // contains
//      let mut found = false
//      let mut i = 0
//      while i < len(arr) {
//          if arr[i] == x { found = true; break }
//          i = i + 1
//      }
//      // insert-if-absent
//      if !found { arr.push(x) }
//
//  This is O(n) per op and silently drops uniqueness if a caller forgets
//  the membership scan before push. hexa already has a native map
//  primitive — `[k:v]` literals + `has_key` / `m[k] = v` / `map_remove` —
//  so a HashSet is just a map with value=true and a thin facade.
//
//  ── DESIGN ───────────────────────────────────────────────────────────────
//
//  Backing store choice: `[T:bool]` (map T → bool, value always true).
//
//  Why bool over int(1) — semantically "membership" is a boolean predicate,
//  and `dict_keys` is the only iteration primitive we need; the value
//  payload is never read. bool keeps json_object_get_bool-style debugging
//  output clean ("true" not "1").
//
//  The set is a struct wrapping the map (`items: any` — hexa stage-1
//  lacks struct-field generics, identical pattern as stdlib/future.hexa).
//  Mutations operate on the inner map by reference — map is a hexa
//  reference type, so `m[k] = v` inside a function call is visible to
//  the caller (verified pattern, see stdlib/jsonl_pool.hexa L210).
//
//  Hash strategy — keys are normalised through `to_string` before being
//  stored, mirroring `counter()` in stdlib/alloc/collections.hexa. This
//  side-steps the stage-1 codegen quirk where `m[int_expr] = v` lowers
//  to an array-index store on a freshly-constructed map literal (the
//  literal's element-type is inferred from the first index access).
//  Tradeoff: `1` and `"1"` collide; numerically-distinct callers must
//  partition upstream. MVP-acceptable — see stdlib/alloc/collections
//  for the same precedent.
//
//  ── BACKWARD COMPATIBILITY ────────────────────────────────────────────────
//
//  ADD-only. No existing stdlib signature is modified.
//
//  ── See also ──────────────────────────────────────────────────────────────
//
//  · stdlib/alloc/collections.hexa — counter()/filter() — sister surface
//  · stdlib/alloc/json_object.hexa — has_key/map_remove canonical use
//  · test/hashset_smoke.hexa — selftest
// ═══════════════════════════════════════════════════════════════════════════

// ── HashSet struct ────────────────────────────────────────────────────────

pub struct HashSet {
    items: any
}

// ── constructors ──────────────────────────────────────────────────────────

// Create a fresh, empty HashSet. O(1).
pub fn hashset_new() -> HashSet {
    return HashSet { items: {} }
}

// Build a HashSet from an array, deduplicating on the way in.
// O(n) — one insert per element.
pub fn hashset_from_array(arr) -> HashSet {
    let s = hashset_new()
    let mut i = 0
    while i < len(arr) {
        hashset_insert(s, arr[i])
        i = i + 1
    }
    return s
}

// ── mutation ──────────────────────────────────────────────────────────────

// Insert `item`. Returns true if the item was newly added, false if it
// was already present. O(1) amortised (one map lookup + one map set).
pub fn hashset_insert(s: HashSet, item) -> bool {
    let k = to_string(item)
    let m = s.items
    if has_key(m, k) {
        return false
    }
    m[k] = true
    return true
}

// Remove `item`. Returns true if the item was present (and removed),
// false if it was already absent. O(1) amortised.
//
// Delegates to map_remove (hexa_map_remove), which silently no-ops on
// missing keys — we pre-check has_key to compute the return signal.
pub fn hashset_remove(s: HashSet, item) -> bool {
    let k = to_string(item)
    let m = s.items
    if !has_key(m, k) {
        return false
    }
    s.items = map_remove(m, k)
    return true
}

// Drop every element. After clear() the set is empty but the wrapper
// struct is reusable.
pub fn hashset_clear(s: HashSet) {
    s.items = {}
}

// ── observation ───────────────────────────────────────────────────────────

// Membership test. O(1) amortised.
pub fn hashset_contains(s: HashSet, item) -> bool {
    return has_key(s.items, to_string(item))
}

// Number of distinct elements.
pub fn hashset_len(s: HashSet) -> i64 {
    return len(dict_keys(s.items))
}

// True iff the set has no elements.
pub fn hashset_is_empty(s: HashSet) -> bool {
    return hashset_len(s) == 0
}

// ── iteration ─────────────────────────────────────────────────────────────

// Snapshot the set as an array. Order follows dict_keys() — insertion
// order for the current map implementation (see stdlib/http.hexa L88
// for the same ordering guarantee). For ordering-sensitive callers,
// pipe through stdlib/alloc/collections.sort().
pub fn hashset_to_array(s: HashSet) {
    return dict_keys(s.items)
}

// ── set algebra (RFC r16 P1) ───────────────────────────────────────────────
//
// union / intersect / difference / symmetric_difference / is_subset /
// is_superset. Each set-returning op produces a NEW HashSet (Python `|` vs
// `|=` distinction — ops are non-mutating; add/remove mutate). Built on the
// existing primitives so the stringified-element model (`1`/`"1"` collide,
// the documented P1 limitation) is consistent across all ops. O(n) over the
// operands' element snapshots; each membership probe is O(1) amortised.
//
// NOTE: hashset_to_array yields the normalised (stringified) keys, so
// re-inserting them is idempotent under to_string — the algebra is coherent.

// a ∪ b — every element of a and b.
pub fn hashset_union(a: HashSet, b: HashSet) -> HashSet {
    let out = hashset_new()
    let ka = hashset_to_array(a)
    let mut i = 0
    while i < len(ka) {
        hashset_insert(out, ka[i])
        i = i + 1
    }
    let kb = hashset_to_array(b)
    let mut j = 0
    while j < len(kb) {
        hashset_insert(out, kb[j])
        j = j + 1
    }
    return out
}

// a ∩ b — elements present in BOTH a and b.
pub fn hashset_intersect(a: HashSet, b: HashSet) -> HashSet {
    let out = hashset_new()
    let ka = hashset_to_array(a)
    let mut i = 0
    while i < len(ka) {
        if hashset_contains(b, ka[i]) {
            hashset_insert(out, ka[i])
        }
        i = i + 1
    }
    return out
}

// a \ b — elements in a but NOT in b.
pub fn hashset_difference(a: HashSet, b: HashSet) -> HashSet {
    let out = hashset_new()
    let ka = hashset_to_array(a)
    let mut i = 0
    while i < len(ka) {
        if !hashset_contains(b, ka[i]) {
            hashset_insert(out, ka[i])
        }
        i = i + 1
    }
    return out
}

// a △ b — elements in exactly one of a or b ((a\b) ∪ (b\a)).
pub fn hashset_symmetric_difference(a: HashSet, b: HashSet) -> HashSet {
    let out = hashset_new()
    let ka = hashset_to_array(a)
    let mut i = 0
    while i < len(ka) {
        if !hashset_contains(b, ka[i]) {
            hashset_insert(out, ka[i])
        }
        i = i + 1
    }
    let kb = hashset_to_array(b)
    let mut j = 0
    while j < len(kb) {
        if !hashset_contains(a, kb[j]) {
            hashset_insert(out, kb[j])
        }
        j = j + 1
    }
    return out
}

// a ⊆ b — true iff every element of a is also in b.
pub fn hashset_is_subset(a: HashSet, b: HashSet) -> bool {
    let ka = hashset_to_array(a)
    let mut i = 0
    while i < len(ka) {
        if !hashset_contains(b, ka[i]) {
            return false
        }
        i = i + 1
    }
    return true
}

// a ⊇ b — true iff a contains every element of b (b ⊆ a).
pub fn hashset_is_superset(a: HashSet, b: HashSet) -> bool {
    return hashset_is_subset(b, a)
}
