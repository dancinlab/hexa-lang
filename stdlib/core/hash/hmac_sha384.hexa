// HEXA Standard Library — core/hash/hmac_sha384
//
// @version 0.1.0
// @capabilities [pure]
//
// HMAC-SHA-384 (RFC 2104 / FIPS 198-1) — pure hexa. SHA-384 shares SHA-512's
// 128-byte block, so block_size = 128; the digest is 48 bytes. Used by the
// HKDF-SHA384 key schedule of the TLS_AES_256_GCM_SHA384 suite. let-mut (#1506).
//
// HMAC(K, m) = H((K ⊕ opad) ‖ H((K ⊕ ipad) ‖ m)) with H = SHA-384.
//
// Surface:
//   pub fn hmac_sha384_bytes(key: [int], data: [int]) -> [int]   — 48-byte tag

use "stdlib/crypto/sha512"

@pure
pub fn hmac_sha384_bytes(key: [int], data: [int]) -> [int] {
    let block_size = 128
    let mut key_bytes: [int] = []
    let mut i = 0
    if len(key) > block_size {
        let h = sha384_bytes(key)
        while i < len(h) { key_bytes.push(h[i]); i = i + 1 }
    } else {
        while i < len(key) { key_bytes.push(key[i]); i = i + 1 }
    }
    while len(key_bytes) < block_size { key_bytes.push(0) }
    let mut ipad: [int] = []
    let mut opad: [int] = []
    i = 0
    while i < block_size {
        ipad.push(0x36 ^ key_bytes[i])
        opad.push(0x5c ^ key_bytes[i])
        i = i + 1
    }
    let mut inner_msg = ipad
    i = 0
    while i < len(data) { inner_msg.push(data[i]); i = i + 1 }
    let inner_digest = sha384_bytes(inner_msg)
    let mut outer_msg = opad
    i = 0
    while i < len(inner_digest) { outer_msg.push(inner_digest[i]); i = i + 1 }
    return sha384_bytes(outer_msg)
}
