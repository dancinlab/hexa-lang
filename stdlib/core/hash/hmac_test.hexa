// HEXA Standard Library — hash/hmac tests
//
// Falsifiers for the byte-level HMAC-SHA256 + the pure-hexa SHA-256 core:
//   - SHA-256: FIPS 180-4 Appendix B vectors (empty + "abc") — proves the
//     in-module sha256_digest_bytes is byte-equal to the runtime builtin.
//   - HMAC-SHA256: RFC 4231 §4 test cases 1 & 2 — published known answers.

import "hmac.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check_eq(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
        println("  got  = " + got)
        println("  want = " + want)
    }
}

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

// helper: bytes from a string (ASCII test inputs)
fn s2b(s) -> [int] {
    return string_to_byte_array(s)
}

fn main() {
    // ── SHA-256 core vectors (FIPS 180-4 Appendix B) ─────────────────
    // Proves sha256_digest_bytes matches the canonical SHA-256.
    check_eq("sha256(\"\")",
        sha256_hex_bytes([]),
        "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")
    check_eq("sha256(\"abc\")",
        sha256_hex_bytes(s2b("abc")),
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")

    // ── HMAC-SHA256 vectors (RFC 4231 §4) ────────────────────────────
    // Test Case 1: key = 0x0b x20, data = "Hi There".
    let key1 = []
    let ki = 0
    while ki < 20 {
        key1 = key1.push(11)
        ki = ki + 1
    }
    check_eq("hmac rfc4231 case1",
        hmac_sha256_hex(key1, s2b("Hi There")),
        "b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7")

    // Test Case 2: key = "Jefe", data = "what do ya want for nothing?".
    check_eq("hmac rfc4231 case2",
        hmac_sha256_hex(s2b("Jefe"), s2b("what do ya want for nothing?")),
        "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843")

    // Byte-level surface: hmac_sha256_bytes returns 32 raw bytes, and the
    // hex of those bytes equals hmac_sha256_hex (key-chain safety).
    let mac = hmac_sha256_bytes(s2b("Jefe"), s2b("what do ya want for nothing?"))
    check_eq("hmac byte len == 32", to_string(len(mac)), "32")
    check_eq("hmac bytes match hex",
        bytes_to_hex_lower(mac),
        "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843")

    // Chaining proof: HMAC of an HMAC output used AS the key must use the
    // 32 raw bytes, NOT the 64-char hex string. These two MUST differ —
    // this is the exact bug the byte-level surface fixes (patch §3).
    let chained_bytes = hmac_sha256_hex(mac, s2b("next"))
    let chained_hexstr = hmac_sha256_hex(s2b(bytes_to_hex_lower(mac)), s2b("next"))
    check("byte-key != hex-key chain (distinct)",
        chained_bytes != chained_hexstr)

    // String wrapper agrees with the byte path.
    check_eq("hmac_sha256_str wrapper",
        hmac_sha256_str("Jefe", "what do ya want for nothing?"),
        "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843")

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
