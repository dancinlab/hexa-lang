// HEXA Standard Library — hash/sha256 tests (v0.3.0 byte/stream surface)
//
// Falsifiers for the v0.3.0 additions to hash/sha256.hexa:
//   - sha256_of_bytes: FIPS 180-4 Appendix B vector ("abc" = [97,98,99])
//     plus empty input, a prefix-slice (n < len), and a clamp (n > len).
//   - sha256_of_lines_filtered: grep-style `grep -v <prefix> | shasum`
//     parity, verified against a hand-rolled reference digest of the
//     reconstructed stream and against the string surface.
//   - Cross-check: sha256_of_bytes agrees with the string surface
//     sha256_hex on the same logical input.

import "sha256.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check_eq(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
        println("  got  = " + got)
        println("  want = " + want)
    }
}

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn main() {
    let abc_digest = "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
    let empty_digest = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

    // ── sha256_of_bytes — FIPS 180-4 Appendix B "abc" = [97,98,99] ────
    check_eq("sha256_of_bytes(abc,3)",
        sha256_of_bytes([97, 98, 99], 3),
        abc_digest)

    // Empty input (n = 0).
    check_eq("sha256_of_bytes(empty)",
        sha256_of_bytes([], 0),
        empty_digest)

    // n = 0 over a non-empty array hashes nothing → empty digest.
    check_eq("sha256_of_bytes(abc,0)",
        sha256_of_bytes([97, 98, 99], 0),
        empty_digest)

    // Prefix slice: hash only first 3 bytes of a longer array.
    // [97,98,99,100,101] with n=3 == digest of "abc".
    check_eq("sha256_of_bytes prefix-slice (n<len)",
        sha256_of_bytes([97, 98, 99, 100, 101], 3),
        abc_digest)

    // Clamp: n > len(b) is clamped to len(b).
    check_eq("sha256_of_bytes clamp (n>len)",
        sha256_of_bytes([97, 98, 99], 99),
        abc_digest)

    // Byte values are masked to 0..255 (256 == 0).
    check_eq("sha256_of_bytes mask (256 -> 0)",
        sha256_of_bytes([256], 1),
        sha256_of_bytes([0], 1))

    // Cross-check against the string surface on the same logical input.
    check_eq("sha256_of_bytes == sha256_hex (\"abc\")",
        sha256_of_bytes([97, 98, 99], 3),
        sha256_hex("abc"))

    // ── sha256_of_lines_filtered — grep -v | shasum parity ───────────
    // Build a temp file: 3 lines, one starting with "timestamp".
    let tmp = "/tmp/__hexa_sha256_filtered_test.txt"
    write_file(tmp, "alpha\ntimestamp: 2026\nbeta\n")

    // After `grep -v timestamp`, the surviving stream is "alpha\nbeta\n".
    // Reference: hash the reconstructed stream directly.
    let want_filtered = sha256_hex("alpha\nbeta\n")
    check_eq("sha256_of_lines_filtered drops prefix",
        sha256_of_lines_filtered(tmp, "timestamp"),
        want_filtered)

    // Empty skip_prefix filters nothing → all 3 lines re-streamed.
    // rt_read_lines strips newlines; we rejoin each + "\n", so the
    // round-trip equals the original 3-line file content.
    check_eq("sha256_of_lines_filtered empty-prefix keeps all",
        sha256_of_lines_filtered(tmp, ""),
        sha256_hex("alpha\ntimestamp: 2026\nbeta\n"))

    // A prefix that matches nothing keeps everything (same as empty-prefix).
    check_eq("sha256_of_lines_filtered no-match keeps all",
        sha256_of_lines_filtered(tmp, "ZZZ_no_such_prefix"),
        sha256_hex("alpha\ntimestamp: 2026\nbeta\n"))

    // Missing file → "" (rt_read_lines returns []).
    check_eq("sha256_of_lines_filtered missing-file -> empty",
        sha256_of_lines_filtered("/tmp/__hexa_no_such_file_xyz.txt", "x"),
        "")

    // All lines filtered out → digest of the empty stream.
    write_file(tmp, "timestamp: a\ntimestamp: b\n")
    check_eq("sha256_of_lines_filtered all-dropped -> empty-stream digest",
        sha256_of_lines_filtered(tmp, "timestamp"),
        empty_digest)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
