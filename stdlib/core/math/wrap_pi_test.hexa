// HEXA Standard Library — math/wrap_pi tests
//
// Boundary + wrap correctness for the angle-normalization primitive.
// Critical falsifier: exact +π must stay at +π (the orbital pilot's
// cross-language parity bug — see #5b reconcile note).

import "wrap_pi.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn approx_eq(a: float, b: float, tol: float) -> bool {
    let d = a - b
    if d < 0.0 { return -d < tol }
    return d < tol
}

fn check_close(name, got: float, want: float, tol: float) {
    total_count = total_count + 1
    if approx_eq(got, want, tol) {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
        println("  got  = " + to_string(got))
        println("  want = " + to_string(want))
    }
}

fn check_exact(name, got: float, want: float) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
        println("  got  = " + to_string(got))
        println("  want = " + to_string(want))
    }
}

fn main() {
    let p = pi()
    let two_p = tau()
    let eps = 1.0e-12

    // ── boundary cases ───────────────────────────────────────────────
    // The +π preservation is the cross-language-parity invariant that
    // motivated lifting wrap_pi into stdlib.
    check_exact("wrap_pi(+π) == +π (boundary)", wrap_pi(p), p)
    check_exact("wrap_pi(-π) == -π (boundary)", wrap_pi(0.0 - p), 0.0 - p)
    check_exact("wrap_pi(0)  == 0",             wrap_pi(0.0), 0.0)

    // ── interior (no wrap needed) ────────────────────────────────────
    check_close("wrap_pi(0.5π)  unchanged", wrap_pi(0.5 * p),  0.5 * p,  eps)
    check_close("wrap_pi(-0.5π) unchanged", wrap_pi(-0.5 * p), -0.5 * p, eps)

    // ── single positive wrap ─────────────────────────────────────────
    // 1.5π is in (π, 2π) → maps to 1.5π − 2π = −0.5π.
    check_close("wrap_pi(1.5π)  → -0.5π", wrap_pi(1.5 * p), -0.5 * p, eps)
    // 2π exactly wraps to 0 (in [0, 2π) reduction; 0 ≤ π so no shift).
    check_close("wrap_pi(2π)    → 0",     wrap_pi(two_p),    0.0,      eps)

    // ── large positive wrap ──────────────────────────────────────────
    // 2.5π = 2π + 0.5π → 0.5π.
    check_close("wrap_pi(2.5π)  → 0.5π", wrap_pi(2.5 * p), 0.5 * p, eps)
    // 3π = 2π + π → π (boundary preserved across the wrap as well).
    check_exact("wrap_pi(3π)    == +π",  wrap_pi(3.0 * p), p)

    // ── large negative wrap ──────────────────────────────────────────
    // −2.5π → reduce to [0, 2π): (-2.5π) − 2π·floor(-2.5π/2π)
    //                          = -2.5π − 2π·(-2) = 1.5π → shift to -0.5π.
    check_close("wrap_pi(-2.5π) → -0.5π", wrap_pi(-2.5 * p), -0.5 * p, eps)
    // -3π → reduce to π; sits at the boundary → stays +π.
    check_exact("wrap_pi(-3π)   == +π",   wrap_pi(-3.0 * p), p)

    // ── idempotence: wrap_pi(wrap_pi(x)) = wrap_pi(x) ───────────────
    // Any output is already in (−π, π], so re-wrapping is a no-op.
    let r = wrap_pi(2.7 * p)
    check_exact("wrap_pi idempotent on output", wrap_pi(r), r)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
