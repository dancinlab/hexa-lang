// HEXA Standard Library — core/math number-theory G5 tests (TECS-L M2)
//
// Exercises the pure-integer arithmetic functions exposed by
// stdlib/core/math.hexa:
//   sigma(n) = Σ_{d|n} d        (divisor sum)
//   tau(n)   = #{d | n}         (divisor count)
//   phi(n)   = Euler totient    (#{1≤k≤n : gcd(k,n)=1})
//   sopfr(n) = Σ p·mult(p)      (sum of prime factors with repetition)
//
// Known values cross-checked against `hexa verify --expr` (g5, 🔵
// SUPPORTED-FORMAL) for sigma/tau/phi at n∈{1,6,12,28} — see
// .verdicts/tecs-l-arith-stdlib/.  sopfr known values are textbook
// (6=2+3, 12=2+2+3, 28=2+2+7).
//
// Self-contained — inline the module surface (sidesteps cross-file
// import path, matching collections_test.hexa idiom).

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

// ── inlined module surface (verbatim from stdlib/core/math.hexa) ────────

fn abs_t(x) -> int {
    if x < 0 { -x } else { x }
}

fn gcd_t(a, b) -> int {
    let x = abs_t(a)
    let y = abs_t(b)
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

fn sigma_t(n) -> int {
    let sum = 0
    let i = 1
    while i <= n {
        if n % i == 0 { sum = sum + i }
        i = i + 1
    }
    sum
}

fn phi_t(n) -> int {
    if n == 1 { return 1 }
    let count = 0
    let i = 1
    while i < n {
        if gcd_t(i, n) == 1 { count = count + 1 }
        i = i + 1
    }
    count
}

fn tau_t(n) -> int {
    let count = 0
    let i = 1
    while i <= n {
        if n % i == 0 { count = count + 1 }
        i = i + 1
    }
    count
}

fn sopfr_t(n) -> int {
    let sum = 0
    let x = n
    let d = 2
    while d * d <= x {
        while x % d == 0 {
            sum = sum + d
            x = x / d
        }
        d = d + 1
    }
    if x > 1 { sum = sum + x }
    sum
}

fn main() {
    // ── sigma — cross-checked 🔵 via hexa verify --expr ───────────────
    check_eq_int("sigma(1)", sigma_t(1), 1)
    check_eq_int("sigma(6)", sigma_t(6), 12)
    check_eq_int("sigma(12)", sigma_t(12), 28)
    check_eq_int("sigma(28)", sigma_t(28), 56)

    // ── tau — cross-checked 🔵 via hexa verify --expr ─────────────────
    check_eq_int("tau(1)", tau_t(1), 1)
    check_eq_int("tau(6)", tau_t(6), 4)
    check_eq_int("tau(12)", tau_t(12), 6)
    check_eq_int("tau(28)", tau_t(28), 6)

    // ── phi — cross-checked 🔵 via hexa verify --expr ─────────────────
    check_eq_int("phi(1)", phi_t(1), 1)
    check_eq_int("phi(6)", phi_t(6), 2)
    check_eq_int("phi(12)", phi_t(12), 4)
    check_eq_int("phi(28)", phi_t(28), 12)

    // ── sopfr — textbook prime-factor sums with repetition ────────────
    check_eq_int("sopfr(6)", sopfr_t(6), 5)     // 2 + 3
    check_eq_int("sopfr(12)", sopfr_t(12), 7)   // 2 + 2 + 3
    check_eq_int("sopfr(28)", sopfr_t(28), 11)  // 2 + 2 + 7
    check_eq_int("sopfr(1)", sopfr_t(1), 0)     // empty product
    check_eq_int("sopfr(7)", sopfr_t(7), 7)     // prime → itself

    // ── n=6 perfect-number identity σ·φ = n·τ (TECS-L M1 echo) ────────
    check_eq_int("n6 identity sigma*phi", sigma_t(6) * phi_t(6), 24)
    check_eq_int("n6 identity n*tau", 6 * tau_t(6), 24)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
