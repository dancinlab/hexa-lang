fn cmd_selftest(args: [str]) {
    println("[sim-universe/selftest] Tier-A substrate smoke pass")
    println("")
    let mut all_ok = 1
    // INBOX 2026-05-25T23:10Z (e): harness PASS judgment used `raw.contains("PASS")`
    // but 5/6 sub-tests never emit "PASS" sentinel. Switched to exec rc==0 + non-empty
    // stdout — sub-tests that complete without error count as PASS. qpu_bridge path
    // typo also fixed (`qpu_bridge/qpu_bridge.hexa` → `qpu_bridge/vqe_h2_demo.hexa`,
    // mirrors cmd_qpu).
    let names = ["anu_time/mini_world", "multiverse/interferometer", "qpu_bridge/vqe_h2_demo", "ouroboros_qrng/baseline_run", "bostrom_test/anu_collector", "godel_q/bootstrap"]
    let hexa_bin = exec("command -v hexa 2>/dev/null || echo hexa").trim()
    let mut i = 0
    while i < len(names) {
        let path = "stdlib/sim_universe/" + names[i] + ".hexa"
        let cmd = _shq(hexa_bin) + " run " + _shq(path) + " 2>&1"
        let pair = exec_with_status(cmd)
        let raw = to_string(pair[0])
        let rc = pair[1]
        if rc == 0 && len(raw) > 0 {
            println("  " + names[i] + ": PASS")
        } else {
            println("  " + names[i] + ": FAIL (rc=" + to_string(rc) + ")")
            all_ok = 0
        }
        i = i + 1
    }
    println("")
    if all_ok == 1 {
        println("  verdict: PASS (substrate smoke)")
        println("__SIM_UNIVERSE_SELFTEST__ PASS")
    } else {
        println("  verdict: FAIL")
        println("__SIM_UNIVERSE_SELFTEST__ FAIL")
        exit(1)
    }
}

fn _experiment_path(name: str) -> str {
    if name == "fvd" { return "stdlib/sim_universe/experiments/fvd/fvd.hexa" }
    if name == "stark" { return "stdlib/sim_universe/experiments/stark_fragmentation/stark_frag.hexa" }
    if name == "qdarwin" { return "stdlib/sim_universe/experiments/quantum_darwinism/qdarwin.hexa" }
    if name == "ca-qm" { return "stdlib/sim_universe/experiments/ca_qm/ca_qm.hexa" }
    if name == "supremacy" { return "stdlib/sim_universe/experiments/supremacy_frontier/supremacy_frontier.hexa" }
    if name == "mbs" { return "stdlib/sim_universe/experiments/mbs_revival/mbs_revival.hexa" }
    if name == "dtc" { return "stdlib/sim_universe/experiments/fock_prethermal_dtc/dtc.hexa" }
    if name == "z2gauge" { return "stdlib/sim_universe/experiments/z2_gauge_prethermal/z2gauge.hexa" }
    if name == "preheating" { return "stdlib/sim_universe/experiments/preheating_analog/preheating.hexa" }
    if name == "multipolar" { return "stdlib/sim_universe/experiments/multipolar_prethermal/multipolar.hexa" }
    if name == "surface-code" { return "stdlib/sim_universe/experiments/surface_code/surface_code.hexa" }
    if name == "ssh" { return "stdlib/sim_universe/experiments/ssh_topology/ssh_topo.hexa" }
    if name == "hofstadter" { return "stdlib/sim_universe/experiments/hofstadter/hofstadter.hexa" }
    if name == "dqpt" { return "stdlib/sim_universe/experiments/dqpt_loschmidt/dqpt.hexa" }
    if name == "wdw" { return "stdlib/sim_universe/experiments/wdw_minisuperspace/wdw.hexa" }
    return ""
}

fn cmd_experiment(name: str, args: [str]) {
    let path = _experiment_path(name)
    if len(path) == 0 {
        println("hexa sim-universe " + name + ": unknown experiment")
        exit(2)
    }
    println("[sim-universe/" + name + "] running " + path)
    let raw = _run_module(path, args)
    println(raw)
}

fn main() {
    let argv = args()
    let n = len(argv)
    let mut subcmd_idx = -1
    let mut i = 0
    while i < n {
        if argv[i].ends_with(".hexa") { subcmd_idx = i + 1; break }
        i = i + 1
    }
    if subcmd_idx < 0 { subcmd_idx = 2 }

    if subcmd_idx >= n {
        cmd_status()
        return
    }

    let sub = argv[subcmd_idx]
    let mut sub_args = []
    let mut j = subcmd_idx + 1
    while j < n {
        sub_args.push(argv[j])
        j = j + 1
    }

    if sub == "--help" || sub == "-h" || sub == "help" {
        cmd_help()
    } else if sub == "--version" || sub == "-v" || sub == "version" {
        cmd_version()
    } else if sub == "status" {
        cmd_status()
    } else if sub == "selftest" {
        cmd_selftest(sub_args)
    } else if sub == "anu" {
        cmd_anu(sub_args)
    } else if sub == "multiverse" {
        cmd_multiverse(sub_args)
    } else if sub == "qpu" {
        cmd_qpu(sub_args)
    } else if sub == "qrng" {
        cmd_qrng(sub_args)
    } else if sub == "bostrom" {
        cmd_bostrom(sub_args)
    } else if sub == "godel" {
        cmd_godel(sub_args)
    } else if sub == "sr" {
        cmd_sr(sub_args)
    } else if sub == "fvd" || sub == "stark" || sub == "qdarwin" || sub == "ca-qm" ||
              sub == "supremacy" || sub == "mbs" || sub == "dtc" || sub == "z2gauge" ||
              sub == "preheating" || sub == "multipolar" || sub == "surface-code" ||
              sub == "ssh" || sub == "hofstadter" || sub == "dqpt" || sub == "wdw" {
        cmd_experiment(sub, sub_args)
    } else {
        println("hexa sim-universe: unknown subcommand '" + sub + "'")
        println("run 'hexa sim-universe --help' for usage")
        exit(2)
    }
}
