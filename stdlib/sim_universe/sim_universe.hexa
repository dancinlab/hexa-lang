fn cmd_sr(args: [str]) {
    println("[sim-universe/sr] sr_harness demo")
    let raw = _run_module("stdlib/sim_universe/sr_harness/demo_ouroboros_sr.hexa", [])
    println(raw)
}

fn cmd_selftest(args: [str]) {
    println("[sim-universe/selftest] Tier-A substrate smoke pass")
    println("")
    let mut all_ok = 1
    let names = ["anu_time/mini_world", "multiverse/interferometer", "qpu_bridge/qpu_bridge", "ouroboros_qrng/baseline_run", "bostrom_test/anu_collector", "godel_q/bootstrap"]
    let mut i = 0
    while i < len(names) {
        let path = "stdlib/sim_universe/" + names[i] + ".hexa"
        let raw = _run_module(path, [])
        if raw.contains("PASS") {
            println("  " + names[i] + ": PASS")
        } else {
            println("  " + names[i] + ": FAIL (see output)")
            all_ok = 0
        }
        i = i + 1
    }
    println("")
    if all_ok == 1 {
        println("  verdict: PASS (substrate smoke)")
        println("__SIM_UNIVERSE_SELFTEST__ PASS")
    } else {
        println("  verdict: FAIL")
        println("__SIM_UNIVERSE_SELFTEST__ FAIL")
        exit(1)
    }
}

fn cmd_experiment_deferred(name: str) {
    println("hexa sim-universe " + name + " — DEFERRED to RFC 046-B experiments migration")
    println("")
    println("Run the frozen archive version:")
    println("  hexa run ~/core/archive_sim-universe/" + name + "/module/*.hexa")
    println("")
    println("Or wait for RFC 046-B (16 experiments + per-experiment tests) follow-up.")
    exit(2)
}

fn main() {
    let argv = args()
    let n = len(argv)
    let mut subcmd_idx = -1
    let mut i = 0
    while i < n {
        if argv[i].ends_with(".hexa") { subcmd_idx = i + 1; break }
        i = i + 1
    }
    if subcmd_idx < 0 { subcmd_idx = 2 }

    if subcmd_idx >= n {
        cmd_status()
        return
    }

    let sub = argv[subcmd_idx]
    let mut sub_args = []
    let mut j = subcmd_idx + 1
    while j < n {
        sub_args.push(argv[j])
        j = j + 1
    }

    if sub == "--help" || sub == "-h" || sub == "help" {
        cmd_help()
    } else if sub == "--version" || sub == "-v" || sub == "version" {
        cmd_version()
    } else if sub == "status" {
        cmd_status()
    } else if sub == "selftest" {
        cmd_selftest(sub_args)
    } else if sub == "anu" {
        cmd_anu(sub_args)
    } else if sub == "multiverse" {
        cmd_multiverse(sub_args)
    } else if sub == "qpu" {
        cmd_qpu(sub_args)
    } else if sub == "qrng" {
        cmd_qrng(sub_args)
    } else if sub == "bostrom" {
        cmd_bostrom(sub_args)
    } else if sub == "godel" {
        cmd_godel(sub_args)
    } else if sub == "sr" {
        cmd_sr(sub_args)
    } else if sub == "fvd" || sub == "stark" || sub == "qdarwin" || sub == "ca-qm" ||
              sub == "supremacy" || sub == "mbs" || sub == "dtc" || sub == "z2gauge" ||
              sub == "preheating" || sub == "multipolar" || sub == "surface-code" ||
              sub == "ssh" || sub == "hofstadter" || sub == "dqpt" || sub == "wdw" {
        cmd_experiment_deferred(sub)
    } else {
        println("hexa sim-universe: unknown subcommand '" + sub + "'")
        println("run 'hexa sim-universe --help' for usage")
        exit(2)
    }
}
