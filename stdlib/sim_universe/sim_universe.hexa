fn cmd_deferred(name: str) {
    println("hexa sim-universe " + name + " — DEFERRED to RFC 046-A/B code migration")
    println("")
    println("Status: " + PHASE)
    println("")
    println("This subcommand requires the actual .hexa module code which has not yet")
    println("been migrated from the archive. To run the original (frozen) version:")
    println("")
    println("  hexa run ~/core/archive_sim-universe/cli/sim-universe.hexa " + name)
    println("")
    println("Or wait for RFC 046-A (substrate) / RFC 046-B (experiments) follow-up commits.")
    exit(2)
}

fn main() {
    let argv = args()
    let n = len(argv)
    let mut subcmd_idx = -1
    let mut i = 0
    while i < n {
        if argv[i].ends_with(".hexa") { subcmd_idx = i + 1; break }
        i = i + 1
    }
    if subcmd_idx < 0 { subcmd_idx = 2 }

    if subcmd_idx >= n {
        cmd_status()
        return
    }

    let sub = argv[subcmd_idx]

    if sub == "--help" || sub == "-h" || sub == "help" {
        cmd_help()
    } else if sub == "--version" || sub == "-v" || sub == "version" {
        cmd_version()
    } else if sub == "status" {
        cmd_status()
    } else if sub == "selftest" || sub == "anu" || sub == "multiverse" || sub == "qpu" ||
              sub == "qrng" || sub == "bostrom" || sub == "godel" || sub == "fvd" ||
              sub == "stark" || sub == "qdarwin" || sub == "ca-qm" || sub == "supremacy" ||
              sub == "mbs" || sub == "dtc" || sub == "z2gauge" || sub == "preheating" ||
              sub == "multipolar" || sub == "surface-code" || sub == "ssh" ||
              sub == "hofstadter" || sub == "dqpt" || sub == "wdw" {
        cmd_deferred(sub)
    } else {
        println("hexa sim-universe: unknown subcommand '" + sub + "'")
        println("run 'hexa sim-universe --help' for usage")
        exit(2)
    }
}
