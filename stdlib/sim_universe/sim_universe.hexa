    println("hexa sim-universe " + VERSION)
    println("stdlib/sim_universe — RFC 046 absorption of dancinlab/sim-universe v1.1.0")
    println("license: Apache-2.0  |  DOI: 10.5281/zenodo.20102970")
    println("status: " + SUBSTRATE_PHASE)
}

