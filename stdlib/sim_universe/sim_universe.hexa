    println("status: " + SUBSTRATE_PHASE)
    println("")
    println("USAGE")
    println("  hexa sim-universe                         status (default)")
    println("  hexa sim-universe status                  module inventory + tier table")
    println("  hexa sim-universe selftest                Tier-A smoke pass")
    println("  hexa sim-universe --help, -h              this help")
    println("  hexa sim-universe --version, -v           version")
    println("")
    println("SUBSTRATE (RFC 046-A — LANDED)")
    println("  anu                                       anu_time τ-clock mini_world (5.9k LoC)")
    println("  multiverse [--bio]                        interferometer + KS-test + MI (4.2k LoC)")
    println("  qpu                                       qpu_bridge VQE-H2 + ANU noise")
    println("  qrng                                      ouroboros QRNG (consumes stdlib/qrng/)")
    println("  bostrom                                   Bostrom test (anu_collector)")
    println("  godel                                     Gödel-Q mutator + bootstrap")
    println("  sr                                        sr_harness demo (ouroboros SR)")
    println("")
    println("EXPERIMENTS (RFC 046-B — PENDING, 16 modules ~14k LoC)")
    println("  fvd / stark / qdarwin / ca-qm / supremacy / mbs / dtc / z2gauge /")
    println("  preheating / multipolar / surface-code / ssh / hofstadter / dqpt / wdw")
    println("")
    println("ARCHIVE")
    println("  ~/core/archive_sim-universe/              frozen 묘비 (RFC 046 헌법 v2 룰 3)")
    println("  DOI: 10.5281/zenodo.20102970")
    println("")
