fn cmd_anu(args: [str]) {
    println("[sim-universe/anu] τ-clock mini_world (anu_time)")
    let raw = _run_module("stdlib/sim_universe/anu_time/mini_world.hexa", [])
    println(raw)
}

fn cmd_multiverse(args: [str]) {
    let use_bio = _find_flag(args, "--bio", "0")
    if use_bio == "1" {
        let bm = _find_flag(args, "--bm", "8")
        let bw = _find_flag(args, "--bw", "100")
        let out_dir = _find_flag(args, "--out", "/tmp/sim_universe_mv_bio")
        println("[sim-universe/multiverse --bio] bio_interferometer M=" + bm + " T=" + bw)
        let raw = _run_module("stdlib/sim_universe/multiverse/bio_variant/bio_interferometer.hexa", [bm, bw, out_dir])
        println(raw)
        return
    }
    println("[sim-universe/multiverse] interferometer + KS")
    let raw = _run_module("stdlib/sim_universe/multiverse/interferometer.hexa", [])
    println(raw)
}

