// multiverse/module/bio_variant/bio_ks_test.hexa
//   2-sample KS test on cross-world k_cat distributions for ribozyme variants.
//
// Per-variant analysis: pairwise KS between variant_0 (canonical, d=0) k_cat
// distribution across W worlds vs variant_i (d>0) k_cat distribution across
// W worlds. Output: M-1 KS rows (canonical vs each non-canonical variant).
//
// Also: pooled KS — all-variants vs reshuffled-cross-variants (null).
//
// Reuses the KS-implementation pattern from
// `multiverse/module/ks_test.hexa` (sister module) — exp_neg_scaled, isqrt,
// sort_asc — but ported here for self-contained bio-axis runner.
//
// Usage:
//   hexa bio_ks_test.hexa <kcat_tsv> <out_jsonl>
//

fn abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }

fn isqrt(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n < 4 { return 1 }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x { x = y; y = (x + n / x) / 2 }
    return x
}

fn sort_asc(a: [i64]) -> [i64] {
    let mut arr = a
    let mut i = 1
    while i < arr.len() {
        let v = arr[i]
        let mut j = i - 1
        while j >= 0 && arr[j] > v { arr[j + 1] = arr[j]; j = j - 1 }
        arr[j + 1] = v
        i = i + 1
    }
    return arr
}

fn exp_neg_scaled(x_scaled: i64) -> i64 {
    if x_scaled <= 0 { return 1000 }
    if x_scaled >= 20000 { return 0 }
    let k = x_scaled / 1000
    let r = x_scaled - k * 1000
    let mut eneg_k: i64 = 1000
    let mut ik = 0
    while ik < k { eneg_k = eneg_k * 368 / 1000; if eneg_k <= 0 { return 0 } ik = ik + 1 }
    let r2 = r * r / 1000
    let r3 = r2 * r / 1000
    let r4 = r3 * r / 1000
    let mut eneg_r = 1000 - r + (r2 / 2) - (r3 / 6) + (r4 / 24)
    if eneg_r < 0 { eneg_r = 0 }
    if eneg_r > 1000 { eneg_r = 1000 }
    return eneg_k * eneg_r / 1000
}

fn ks_d(a: [i64], b: [i64]) -> i64 {
    let sa = sort_asc(a)
    let sb = sort_asc(b)
    let n = sa.len()
    let m = sb.len()
    if n == 0 || m == 0 { return 0 }
    let mut i = 0
    let mut j = 0
    let mut max_d: i64 = 0
    while i < n && j < m {
        let va = sa[i]
        let vb = sb[j]
        if va < vb { i = i + 1 } else if vb < va { j = j + 1 } else { i = i + 1; j = j + 1 }
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    while i < n {
        i = i + 1
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    while j < m {
        j = j + 1
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    return max_d
}

fn ks_pval(d_s: i64, n: i64, m: i64) -> [i64] {
    if n <= 0 || m <= 0 {
        let mut z: [i64] = []
        z.push(0); z.push(0); z.push(1000)
        return z
    }
    let nm_over = n * m * 1000 * 1000 / (n + m)
    let sqrt_term = isqrt(nm_over)
    let lambda_s = d_s * sqrt_term / 1000
    // D=0 → identical empirical CDFs → p=1 (avoid asymptotic-series degeneracy
    // where 10-term alternating sum oscillates to ~0 instead of 1).
    if d_s == 0 {
        let mut z: [i64] = []
        z.push(0); z.push(0); z.push(1000)
        return z
    }
    let mut p_s: i64 = 0
    let mut k: i64 = 1
    let mut sign: i64 = 1
    while k <= 10 {
        let lambda_sq = lambda_s * lambda_s / 1000
        let exponent = 2 * k * k * lambda_sq
        let term = exp_neg_scaled(exponent)
        p_s = p_s + sign * term
        sign = 0 - sign
        k = k + 1
    }
    p_s = 2 * p_s
    if p_s < 0 { p_s = 0 }
    if p_s > 1000 { p_s = 1000 }
    let mut out: [i64] = []
    out.push(d_s); out.push(lambda_s); out.push(p_s)
    return out
}

// parse kcat tsv: each line "<idx>\t<d>\t<v1>,<v2>,...,<vW>"
// returns 3-tuple of arrays: [idxs, ds, all_kcats_flat], plus W (worlds per variant)
// plus M (variant count) — encoded as: out[0]=idxs, out[1]=ds, out[2]=all_kcats_flat, out[3]=[M, W]
fn parse_kcat_tsv(path: string) -> [[i64]] {
    let mut raw = ""
    try { raw = read_file(path) } catch e { raw = "" }
    let mut idxs: [i64] = []
    let mut ds: [i64] = []
    let mut flat: [i64] = []
    let mut W: i64 = 0
    let lines = raw.split("\n")
    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        if line.len() > 0 {
            let parts = line.split("\t")
            if parts.len() >= 3 {
                let mut vi: i64 = 0
                let mut vd: i64 = 0
                try { vi = to_int(parts[0].trim()) } catch e { vi = 0 }
                try { vd = to_int(parts[1].trim()) } catch e { vd = 0 }
                idxs.push(vi)
                ds.push(vd)
                let kvs = parts[2].split(",")
                let mut k = 0
                while k < kvs.len() {
                    let t = kvs[k].trim()
                    if t.len() > 0 {
                        let mut x: i64 = 0
                        try { x = to_int(t) } catch e { x = 0 }
                        flat.push(x)
                    }
                    k = k + 1
                }
                if W == 0 { W = kvs.len() }
            }
        }
        i = i + 1
    }
    let mut meta: [i64] = []
    meta.push(idxs.len()); meta.push(W)
    let mut out: [[i64]] = []
    out.push(idxs); out.push(ds); out.push(flat); out.push(meta)
    return out
}

fn extract_variant_kcats(flat: [i64], variant_idx: i64, W: i64) -> [i64] {
    let mut out: [i64] = []
    let base = variant_idx * W
    let mut k = 0
    while k < W {
        out.push(flat[base + k])
        k = k + 1
    }
    return out
}

// CLI entrypoint
let _args = args()
if _args.len() < 3 {
    println("usage: hexa bio_ks_test.hexa <kcat_tsv> <out_jsonl>")
} else {
    let kcat_tsv = _args[1]
    let out_jsonl = _args[2]

    let parsed = parse_kcat_tsv(kcat_tsv)
    let idxs = parsed[0]
    let ds = parsed[1]
    let flat = parsed[2]
    let meta = parsed[3]
    let M = meta[0]
    let W = meta[1]
    println("[bio_ks_test] M=" + to_string(M) + " W=" + to_string(W) + " kcats_flat=" + to_string(flat.len()))

    if M < 2 || W < 5 {
        println("[bio_ks_test] ERROR: need M>=2 and W>=5")
    } else {
        // Reference = variant 0 (canonical, d=0)
        let canonical_kcats = extract_variant_kcats(flat, 0, W)

        // Output buffer
        let mut buf = ""
        let mut sig_count: i64 = 0
        let mut total: i64 = 0

        let mut i = 1
        while i < M {
            let var_kcats = extract_variant_kcats(flat, i, W)
            let d_s = ks_d(canonical_kcats, var_kcats)
            let pv = ks_pval(d_s, canonical_kcats.len(), var_kcats.len())
            let line = "{\"variant_idx\":" + to_string(idxs[i]) + ",\"hamming_d\":" + to_string(ds[i]) + ",\"D_scaled\":" + to_string(pv[0]) + ",\"lambda_scaled\":" + to_string(pv[1]) + ",\"p_scaled\":" + to_string(pv[2]) + ",\"n\":" + to_string(canonical_kcats.len()) + ",\"m\":" + to_string(var_kcats.len()) + ",\"reference\":\"variant_0_canonical\",\"scale\":1000}\n"
            buf = buf + line
            if pv[2] < 50 { sig_count = sig_count + 1 }
            total = total + 1
            println("  variant_" + to_string(idxs[i]) + " d=" + to_string(ds[i]) + " D=" + to_string(pv[0]) + " p_scaled=" + to_string(pv[2]))
            i = i + 1
        }

        try { write_file(out_jsonl, buf) } catch e {}
        println("[bio_ks_test] wrote " + out_jsonl + " (" + to_string(total) + " variant-vs-canonical KS rows; " + to_string(sig_count) + " significant at p<0.05)")
    }
}
