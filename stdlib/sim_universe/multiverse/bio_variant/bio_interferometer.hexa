// multiverse/module/bio_variant/bio_interferometer.hexa
//   Multiverse interferometer driver for the RIBOZYME variant axis.
//
// Pipeline (all in-process, single hexa run):
//   1. Generate M variants of the 12-nt catalytic core (ribozyme_variants.hexa logic inlined).
//   2. For each variant, compute W cross-world k_cat values (kcat_compute.hexa logic inlined).
//   3. Per-variant 2-sample KS test: variant_i vs canonical (variant_0).
//   4. Pairwise MI on σ(6)=12 catalytic-core conservation across the M-variant ensemble.
//   5. Write summary JSON.
//
// hexa-stage0 has no module imports → critical functions are inlined here.
// Single-file driver matches the pattern of multiverse/module/interferometer.hexa.
//
// Usage:
//   hexa bio_interferometer.hexa <M> <W> <out_dir>
//
// Outputs in <out_dir>:
//   variants.tsv         — M variant records (idx, hamming_d, core_seq, mask)
//   kcat_per_world.tsv   — M × W log10(k_cat/s) scaled values
//   ks_results.jsonl     — M-1 per-variant KS rows (vs canonical)
//   conservation_mi.json — σ(6)=12 conservation MI summary
//   summary.json         — top-level interferometer summary
//

const CORE_LEN: i64 = 12
const NBASES: i64 = 4
const LOG_SCALE: i64 = 1000
const RT_LN10_SCALED: i64 = 1418
const PREFACTOR_LOG10_SCALED: i64 = 12810
const DELTA_G_REF_SCALED: i64 = 21000
const DELTA_G_PER_MISMATCH_SCALED: i64 = 1500
const NOISE_SIGMA_SCALED: i64 = 500

fn abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }

// --- variant generation (inlined from ribozyme_variants.hexa) ---

fn canonical_core() -> [i64] {
    let mut c: [i64] = []
    c.push(1); c.push(3); c.push(2); c.push(0); c.push(3); c.push(2)
    c.push(0); c.push(2); c.push(2); c.push(1); c.push(1); c.push(2)
    return c
}

fn hamming_of(idx: i64, M: i64) -> i64 {
    if idx == 0 { return 0 }
    let mut schedule: [i64] = []
    schedule.push(0); schedule.push(1); schedule.push(1); schedule.push(2)
    schedule.push(2); schedule.push(2); schedule.push(3); schedule.push(3)
    schedule.push(4); schedule.push(4); schedule.push(5); schedule.push(6)
    schedule.push(7); schedule.push(8); schedule.push(10)
    if idx < schedule.len() && idx < 15 { return schedule[idx] }
    let mut h = (idx * 3 + 1) % (CORE_LEN + 1)
    if h < 1 { h = 1 }
    return h
}

fn select_positions(seed: i64, d: i64) -> [i64] {
    let mut state = seed * 1103515245 + 12345
    if state < 0 { state = 0 - state }
    let mut chosen: [i64] = []
    let mut tries = 0
    while chosen.len() < d && tries < 200 {
        state = (state * 1103515245 + 12345) & 2147483647
        let pos = state % CORE_LEN
        let mut found = false
        let mut k = 0
        while k < chosen.len() {
            if chosen[k] == pos { found = true }
            k = k + 1
        }
        if !found { chosen.push(pos) }
        tries = tries + 1
    }
    return chosen
}

fn alt_base(orig: i64, seed: i64) -> i64 {
    let mut state = (seed * 22695477 + 1) & 2147483647
    let r = state % 3
    let mut alt = (orig + 1 + r) % 4
    if alt < 0 { alt = alt + 4 }
    return alt
}

fn perturb_core(d: i64, variant_idx: i64) -> [i64] {
    let mut core = canonical_core()
    if d == 0 { return core }
    let positions = select_positions(variant_idx + 7919, d)
    let mut k = 0
    while k < positions.len() {
        let pos = positions[k]
        let orig = core[pos]
        let nb = alt_base(orig, variant_idx * 31 + pos * 17 + 5)
        core[pos] = nb
        k = k + 1
    }
    return core
}

fn base_to_char(b: i64) -> string {
    if b == 0 { return "A" }
    if b == 1 { return "C" }
    if b == 2 { return "G" }
    if b == 3 { return "U" }
    return "N"
}

fn core_to_string(core: [i64]) -> string {
    let mut s = ""
    let mut i = 0
    while i < core.len() { s = s + base_to_char(core[i]); i = i + 1 }
    return s
}

fn hamming_distance(a: [i64], b: [i64]) -> i64 {
    let mut d: i64 = 0
    let mut i = 0
    while i < a.len() && i < b.len() {
        if a[i] != b[i] { d = d + 1 }
        i = i + 1
    }
    return d
}

fn position_mask(canonical: [i64], variant: [i64]) -> string {
    let mut s = ""
    let mut i = 0
    while i < canonical.len() {
        if canonical[i] == variant[i] { s = s + "1" } else { s = s + "0" }
        i = i + 1
    }
    return s
}

// --- k_cat (inlined from kcat_compute.hexa) ---

fn noise_kcal_scaled(variant_idx: i64, world_idx: i64) -> i64 {
    let mut state = variant_idx * 2654435761 + world_idx * 40503
    state = state * 1103515245 + 12345
    let r = state % 2001
    let centered = r - 1000
    let n = centered * NOISE_SIGMA_SCALED / 1000
    return n
}

fn log10_kcat_from_dG_scaled(dG_scaled: i64) -> i64 {
    let delta = dG_scaled * 1000 / RT_LN10_SCALED
    return PREFACTOR_LOG10_SCALED - delta
}

fn kcat_per_world(variant_d: i64, variant_idx: i64, W: i64) -> [i64] {
    let mut out: [i64] = []
    let base_dG = DELTA_G_REF_SCALED + variant_d * DELTA_G_PER_MISMATCH_SCALED
    let mut w = 0
    while w < W {
        let noise = noise_kcal_scaled(variant_idx, w)
        let dG_eff = base_dG + noise
        let log10_k = log10_kcat_from_dG_scaled(dG_eff)
        out.push(log10_k)
        w = w + 1
    }
    return out
}

// --- KS test (inlined from bio_ks_test.hexa) ---

fn isqrt(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n < 4 { return 1 }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x { x = y; y = (x + n / x) / 2 }
    return x
}

fn sort_asc(a: [i64]) -> [i64] {
    let mut arr = a
    let mut i = 1
    while i < arr.len() {
        let v = arr[i]
        let mut j = i - 1
        while j >= 0 && arr[j] > v { arr[j + 1] = arr[j]; j = j - 1 }
        arr[j + 1] = v
        i = i + 1
    }
    return arr
}

fn exp_neg_scaled(x_scaled: i64) -> i64 {
    if x_scaled <= 0 { return 1000 }
    if x_scaled >= 20000 { return 0 }
    let k = x_scaled / 1000
    let r = x_scaled - k * 1000
    let mut eneg_k: i64 = 1000
    let mut ik = 0
    while ik < k { eneg_k = eneg_k * 368 / 1000; if eneg_k <= 0 { return 0 } ik = ik + 1 }
    let r2 = r * r / 1000
    let r3 = r2 * r / 1000
    let r4 = r3 * r / 1000
    let mut eneg_r = 1000 - r + (r2 / 2) - (r3 / 6) + (r4 / 24)
    if eneg_r < 0 { eneg_r = 0 }
    if eneg_r > 1000 { eneg_r = 1000 }
    return eneg_k * eneg_r / 1000
}

fn ks_d(a: [i64], b: [i64]) -> i64 {
    let sa = sort_asc(a)
    let sb = sort_asc(b)
    let n = sa.len()
    let m = sb.len()
    if n == 0 || m == 0 { return 0 }
    let mut i = 0
    let mut j = 0
    let mut max_d: i64 = 0
    while i < n && j < m {
        let va = sa[i]
        let vb = sb[j]
        if va < vb { i = i + 1 } else if vb < va { j = j + 1 } else { i = i + 1; j = j + 1 }
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    while i < n {
        i = i + 1
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    while j < m {
        j = j + 1
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    return max_d
}

fn ks_pval(d_s: i64, n: i64, m: i64) -> [i64] {
    if n <= 0 || m <= 0 {
        let mut z: [i64] = []
        z.push(0); z.push(0); z.push(1000)
        return z
    }
    let nm_over = n * m * 1000 * 1000 / (n + m)
    let sqrt_term = isqrt(nm_over)
    let lambda_s = d_s * sqrt_term / 1000
    // D=0 → identical empirical CDFs → p=1 (avoid asymptotic-series degeneracy).
    if d_s == 0 {
        let mut z: [i64] = []
        z.push(0); z.push(0); z.push(1000)
        return z
    }
    let mut p_s: i64 = 0
    let mut k: i64 = 1
    let mut sign: i64 = 1
    while k <= 10 {
        let lambda_sq = lambda_s * lambda_s / 1000
        let exponent = 2 * k * k * lambda_sq
        let term = exp_neg_scaled(exponent)
        p_s = p_s + sign * term
        sign = 0 - sign
        k = k + 1
    }
    p_s = 2 * p_s
    if p_s < 0 { p_s = 0 }
    if p_s > 1000 { p_s = 1000 }
    let mut out: [i64] = []
    out.push(d_s); out.push(lambda_s); out.push(p_s)
    return out
}

// --- conservation MI (inlined from core_conservation_mi.hexa) ---

fn log_scaled(num: i64, den: i64) -> i64 {
    if num <= 0 { return 0 - 20000 }
    if den <= 0 { return 20000 }
    let r = num * LOG_SCALE / den
    if r <= 0 { return 0 - 20000 }
    let mut x = r
    let mut l2: i64 = 0
    if x >= LOG_SCALE {
        let mut tmp = x
        while tmp >= (LOG_SCALE * 2) { tmp = tmp / 2; l2 = l2 + 1 }
        let frac = tmp - LOG_SCALE
        let f = frac
        let log2_frac = f - (f * f / (2 * LOG_SCALE))
        let total_log2 = l2 * LOG_SCALE + log2_frac
        return total_log2 * 693 / LOG_SCALE
    } else {
        let mut tmp = x
        while tmp * 2 <= LOG_SCALE { tmp = tmp * 2; l2 = l2 + 1 }
        let frac = tmp - LOG_SCALE
        let f = frac
        let log2_frac = f - (f * f / (2 * LOG_SCALE))
        let total_log2 = log2_frac - l2 * LOG_SCALE
        return total_log2 * 693 / LOG_SCALE
    }
}

fn pair_mi_seqs(all_seqs: [[i64]], p1: i64, p2: i64) -> i64 {
    let M = all_seqs.len()
    if M == 0 { return 0 }
    let mut joint: [i64] = []
    let mut k = 0
    while k < NBASES * NBASES { joint.push(0); k = k + 1 }
    let mut px: [i64] = []
    let mut a = 0
    while a < NBASES { px.push(0); a = a + 1 }
    let mut py: [i64] = []
    let mut b = 0
    while b < NBASES { py.push(0); b = b + 1 }
    let mut i = 0
    while i < M {
        let bx = all_seqs[i][p1]
        let by = all_seqs[i][p2]
        joint[bx * NBASES + by] = joint[bx * NBASES + by] + 1
        px[bx] = px[bx] + 1
        py[by] = py[by] + 1
        i = i + 1
    }
    let mut mi: i64 = 0
    let mut bxi = 0
    while bxi < NBASES {
        let pxb = px[bxi]
        if pxb > 0 {
            let mut byi = 0
            while byi < NBASES {
                let pyb = py[byi]
                let pxy = joint[bxi * NBASES + byi]
                if pxy > 0 && pyb > 0 {
                    let log_term = log_scaled(pxy * M, pxb * pyb)
                    mi = mi + (pxy * log_term / M)
                }
                byi = byi + 1
            }
        }
        bxi = bxi + 1
    }
    return mi
}

fn position_entropy_seqs(all_seqs: [[i64]], pos: i64) -> i64 {
    let M = all_seqs.len()
    if M == 0 { return 0 }
    let mut counts: [i64] = []
    let mut k = 0
    while k < NBASES { counts.push(0); k = k + 1 }
    let mut i = 0
    while i < M {
        let b = all_seqs[i][pos]
        counts[b] = counts[b] + 1
        i = i + 1
    }
    let mut h: i64 = 0
    let mut b = 0
    while b < NBASES {
        let cb = counts[b]
        if cb > 0 {
            let lg = log_scaled(cb, M)
            h = h - (cb * lg / M)
        }
        b = b + 1
    }
    return h
}

// --- main driver ---

let _args = args()
if _args.len() < 4 {
    println("usage: hexa bio_interferometer.hexa <M> <W> <out_dir>")
    println("  M: number of variants (≥3, default 15)")
    println("  W: number of cross-world k_cat samples per variant (≥10, default 50)")
    println("  out_dir: directory to write results")
} else {
    let mut M = 15
    try { M = to_int(_args[1]) } catch e { M = 15 }
    let mut W = 50
    try { W = to_int(_args[2]) } catch e { W = 50 }
    let out_dir = _args[3]
    if M < 3 { M = 3 }
    if W < 10 { W = 10 }

    println("[bio_interferometer] M=" + to_string(M) + " W=" + to_string(W) + " out_dir=" + out_dir)
    println("[bio_interferometer] canonical core = CUGAUGAGGCCG (hexa-bio F-RB-4 cycle 24 C0b reference)")

    try { exec("mkdir -p '" + out_dir + "'") } catch e {}

    // 1. Generate variants
    let canonical = canonical_core()
    let mut variant_seqs: [[i64]] = []
    let mut variant_d_arr: [i64] = []
    let mut variants_text = ""
    let mut i = 0
    while i < M {
        let d_target = hamming_of(i, M)
        let v = perturb_core(d_target, i)
        let d_actual = hamming_distance(canonical, v)
        let seq = core_to_string(v)
        let mask = position_mask(canonical, v)
        variant_seqs.push(v)
        variant_d_arr.push(d_actual)
        variants_text = variants_text + to_string(i) + "\t" + to_string(d_actual) + "\t" + seq + "\t" + mask + "\n"
        i = i + 1
    }
    try { write_file(out_dir + "/variants.tsv", variants_text) } catch e {}
    println("[bio_interferometer] step 1 done — " + to_string(M) + " variants generated")

    // 2. k_cat per world
    let mut all_kcats: [[i64]] = []
    let mut kcat_text = ""
    let mut vi = 0
    while vi < M {
        let kc = kcat_per_world(variant_d_arr[vi], vi, W)
        all_kcats.push(kc)
        let mut row = to_string(vi) + "\t" + to_string(variant_d_arr[vi]) + "\t"
        let mut w = 0
        while w < kc.len() {
            if w > 0 { row = row + "," }
            row = row + to_string(kc[w])
            w = w + 1
        }
        kcat_text = kcat_text + row + "\n"
        vi = vi + 1
    }
    try { write_file(out_dir + "/kcat_per_world.tsv", kcat_text) } catch e {}
    println("[bio_interferometer] step 2 done — " + to_string(M * W) + " k_cat samples")

    // 3. KS test per variant vs canonical
    let canonical_kcats = all_kcats[0]
    let mut ks_text = ""
    let mut sig_count: i64 = 0
    let mut min_p: i64 = 1000
    let mut max_p: i64 = 0
    let mut sum_p: i64 = 0
    let mut ks_count: i64 = 0
    let mut k = 1
    while k < M {
        let var_kc = all_kcats[k]
        let d_s = ks_d(canonical_kcats, var_kc)
        let pv = ks_pval(d_s, canonical_kcats.len(), var_kc.len())
        let line = "{\"variant_idx\":" + to_string(k) + ",\"hamming_d\":" + to_string(variant_d_arr[k]) + ",\"D_scaled\":" + to_string(pv[0]) + ",\"lambda_scaled\":" + to_string(pv[1]) + ",\"p_scaled\":" + to_string(pv[2]) + ",\"n\":" + to_string(canonical_kcats.len()) + ",\"m\":" + to_string(var_kc.len()) + ",\"reference\":\"variant_0_canonical\",\"scale\":1000}\n"
        ks_text = ks_text + line
        if pv[2] < 50 { sig_count = sig_count + 1 }
        if pv[2] < min_p { min_p = pv[2] }
        if pv[2] > max_p { max_p = pv[2] }
        sum_p = sum_p + pv[2]
        ks_count = ks_count + 1
        k = k + 1
    }
    try { write_file(out_dir + "/ks_results.jsonl", ks_text) } catch e {}
    let mean_p = if ks_count > 0 { sum_p / ks_count } else { 0 }
    println("[bio_interferometer] step 3 done — KS p_scaled: min=" + to_string(min_p) + " max=" + to_string(max_p) + " mean=" + to_string(mean_p) + " (" + to_string(sig_count) + "/" + to_string(ks_count) + " significant at p<0.05)")

    // 4. Conservation MI
    let mut entropies: [i64] = []
    let mut p = 0
    while p < CORE_LEN {
        entropies.push(position_entropy_seqs(variant_seqs, p))
        p = p + 1
    }
    let mut mi_values: [i64] = []
    let mut sum_mi: i64 = 0
    let mut max_mi: i64 = 0 - 9999
    let mut max_mi_p1: i64 = 0
    let mut max_mi_p2: i64 = 0
    let mut a = 0
    while a < CORE_LEN {
        let mut b = a + 1
        while b < CORE_LEN {
            let mi_v = pair_mi_seqs(variant_seqs, a, b)
            mi_values.push(mi_v)
            sum_mi = sum_mi + mi_v
            if mi_v > max_mi { max_mi = mi_v; max_mi_p1 = a; max_mi_p2 = b }
            b = b + 1
        }
        a = a + 1
    }
    let pair_count = mi_values.len()
    let mean_mi = if pair_count > 0 { sum_mi / pair_count } else { 0 }
    let mut sum_h: i64 = 0
    let mut hi = 0
    while hi < entropies.len() { sum_h = sum_h + entropies[hi]; hi = hi + 1 }
    let mean_h = sum_h / entropies.len()
    let mut h_str = "["
    let mut hk = 0
    while hk < entropies.len() {
        if hk > 0 { h_str = h_str + "," }
        h_str = h_str + to_string(entropies[hk])
        hk = hk + 1
    }
    h_str = h_str + "]"

    let mi_json = "{\"M\":" + to_string(M) + ",\"core_len\":" + to_string(CORE_LEN) + ",\"sigma_6\":12,\"pair_count\":" + to_string(pair_count) + ",\"mean_mi_scaled\":" + to_string(mean_mi) + ",\"max_mi_scaled\":" + to_string(max_mi) + ",\"max_mi_pair\":[" + to_string(max_mi_p1) + "," + to_string(max_mi_p2) + "],\"mean_position_entropy_scaled\":" + to_string(mean_h) + ",\"per_position_entropy_scaled\":" + h_str + ",\"scale\":1000,\"log_unit\":\"nats\"}\n"
    try { write_file(out_dir + "/conservation_mi.json", mi_json) } catch e {}
    println("[bio_interferometer] step 4 done — mean_MI_scaled=" + to_string(mean_mi) + " max_MI_scaled=" + to_string(max_mi) + " (positions " + to_string(max_mi_p1) + "," + to_string(max_mi_p2) + ")")

    // 5. Top-level summary
    let summary = "{\"axis\":\"sim_universe.multiverse.bio_variant\",\"reference\":\"hexa-bio F-RB-4 cycle 24 C0b\",\"canonical_core\":\"CUGAUGAGGCCG\",\"M\":" + to_string(M) + ",\"W\":" + to_string(W) + ",\"ks_summary\":{\"min_p_scaled\":" + to_string(min_p) + ",\"max_p_scaled\":" + to_string(max_p) + ",\"mean_p_scaled\":" + to_string(mean_p) + ",\"significant_at_0_05\":" + to_string(sig_count) + ",\"total\":" + to_string(ks_count) + "},\"conservation_mi_summary\":{\"mean_mi_scaled\":" + to_string(mean_mi) + ",\"max_mi_scaled\":" + to_string(max_mi) + ",\"mean_position_entropy_scaled\":" + to_string(mean_h) + ",\"sigma_6\":12},\"raw_10_honest_c3\":\"toy lattice; not 1:1 wet-lab mapping; see bio_variant/README.md\",\"scale\":1000}\n"
    try { write_file(out_dir + "/summary.json", summary) } catch e {}

    println("[bio_interferometer] summary -> " + out_dir + "/summary.json")
    println("__SIM_UNIVERSE_BIO_INTERFEROMETER__ PASS")
}
