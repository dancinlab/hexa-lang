#!hexa strict
// ca-qm/module/ca_qm.hexa — exact deterministic simulation of TWO
// cellular-automaton models of quantum mechanics, one self-contained file.
//
// @tool(slug="ca-qm", desc="Two-engine deterministic CA module: (A) Elze 2024 ontological Ising-permutation automaton — neighbour-transposition product Û on 2S classical spins (arXiv:2401.08253), reproduces #1 dynamics + #2 exact revival + #3 Weyl-equation continuum-limit trend + #4 superposition-from-imprecision + #5 induced Ĥ cogwheel spectrum (2S≤16 here); (B) van Berkel 2025 Schrödinger CA — band-structured local unitary U=U_1U_0 split-Hamiltonian Strang on a complex wavefunction (arXiv:2406.08586 / Quantum 9, 1811), reproduces #7 update + #8 1-D phase/group velocity + #9 2-D double-slit fringes. No 2^N memory wall on either simulation path.")
// @usage(hexa run ca-qm/module/ca_qm.hexa [--ontological|--sca] [--S 8] [--steps 200] [--state neel|packet|alt] [--epsilon 0.0] [--N 64] [--theta 0.1309] [--cycles 200] [--grid 64] [--movers] [--continuum] [--imprecision] [--spectrum] [--velocity] [--double-slit] [--json] [--selftest])
// @exit_codes(0=PASS selftest/run ok, 1=usage error, 2=physics acceptance FAIL)
// @sentinel(__SIM_UNIVERSE_CAQM__ PASS|FAIL engine=<onto|sca> S=<2S> revival=<p> norm_drift=<x>)
// @origin(docs/references/REFERENCES.md — Elze 2024 IJQI 22 2450013 / arXiv:2401.08253; van Berkel et al. 2025 Quantum 9 1811 / arXiv:2406.08586)
// @abstraction(pure-hexa; Engine A = integer index-map permutation on 2S bits, no 2^N path on default; Engine B = O(N) band 2x2-block unitary on complex wavefunction)
// @paradigm(structural — Engine A: pebble-reshuffling (a pure permutation, exact integer dynamics); Engine B: Strang-split local unitary update, unitary-by-construction)
// @idempotence(deterministic float output, 6-digit decimal emission for byte-eq seal)
//
// HONEST SCOPE (governance @D g1/g9 — STRICTER than @D g6/g7):
//   This is an EXACT, DETERMINISTIC simulation of a cellular-automaton MODEL of
//   quantum mechanics — Engine A: Elze's classical Ising-permutation ontological
//   automaton (arXiv:2401.08253); Engine B: the van Berkel-de Graaf-van Hee
//   Schrödinger Cellular Automaton (arXiv:2406.08586, Quantum 9 1811 2025).
//   It reproduces A MODEL; it does NOT demonstrate, prove, or provide evidence
//   that the physical universe IS a cellular automaton. 't Hooft's Cellular
//   Automaton Interpretation (CAI) is a contested minority interpretation of
//   QM, not established physics — the five mainstream objections ship with
//   every claim:
//     (1) Born rule put in by hand (frozen initial probabilities, not derived);
//     (2) superdeterminism / the conspiracy objection (CAI evades Bell via
//         denying measurement-setting independence — disputed, unresolved);
//     (3) the basis problem (a privileged "ontological basis" is POSTULATED,
//         never exhibited for any realistic theory);
//     (4) recovering known physics (the programme reaches only free Weyl/Dirac,
//         not the Standard Model it aims to underlie);
//     (5) Hilbert-space-size/entanglement (mapping a 2^N-dim Hilbert space onto
//         a permutation of ~poly(N) states is structurally fraught).
//   The two engines are DIFFERENT OBJECTS and labelled as such: Engine A is a
//   classical-deterministic ontological automaton (the CAI proper); Engine B is
//   a QUANTUM CA — a discrete unitary numerical scheme on a wavefunction —
//   which the SCA authors do NOT frame as superdeterministic or hidden-variable.
//   Ceilings are honest: Engine A has NO memory wall on the simulation path
//   (O(S) bit-permutation), but its quantum-formalism view (diagonalizing the
//   induced Ĥ, --spectrum) is capped at 2S ≈ 26–28 (here clamped 2S ≤ 16 for
//   the selftest to stay cheap). Engine B has NO 2^N wall (O(N) band update),
//   capped only by grid RAM and the O(τ³) split error. Reachable paper-scale
//   results are claimed exactly, never down-played.
// QRNG disclosure (governance @D g5): the core evolution of BOTH engines is
//   fully deterministic — NO entropy is drawn. entropy_source = "deterministic-exact".

// ═════════════════════════════════════════════════════════════════════
// ─── shared scalar helpers (copied verbatim from fvd.hexa / stark_frag.hexa) ───
// ═════════════════════════════════════════════════════════════════════

fn _pi() -> f64 { return 3.14159265358979323846 }
fn _two_pi() -> f64 { return 6.28318530717958647692 }
fn _abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }
fn _abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }
fn _sqrt_f(x: f64) -> f64 { if x <= 0.0 { return 0.0 } return sqrt(x) }

// natural log via mantissa-split series (mirrors fvd.hexa _ln / stark_frag.hexa _ln)
fn _ln(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1.0e9 }
    let mut m = x
    let mut e: i64 = 0
    while m >= 2.0 { m = m / 2.0; e = e + 1 }
    while m < 1.0 { m = m * 2.0; e = e - 1 }
    let y = m - 1.0
    let mut s = 0.0
    let mut sign = 1.0
    let mut yk = y
    let mut k: i64 = 1
    while k <= 24 {
        s = s + sign * yk / to_float(k)
        yk = yk * y
        sign = 0.0 - sign
        k = k + 1
    }
    return s + to_float(e) * 0.69314718055994530942
}

// 6-decimal fixed emission for idempotent byte-eq output (mirrors fvd _r6 / stark _r6)
fn _r6(x: f64) -> string {
    let scaled = x * 1000000.0
    let rounded = if scaled >= 0.0 { to_int(scaled + 0.5) } else { to_int(scaled - 0.5) }
    let int_part = rounded / 1000000
    let frac_part = rounded - int_part * 1000000
    let abs_frac = if frac_part < 0 { 0 - frac_part } else { frac_part }
    let mut frac_str = to_string(abs_frac)
    while len(frac_str) < 6 { frac_str = "0" + frac_str }
    let sign = if x < 0.0 && int_part == 0 { "-" } else { "" }
    return sign + to_string(int_part) + "." + frac_str
}

// ═════════════════════════════════════════════════════════════════════
// ─── ENGINE A — Elze ontological CA (arXiv:2401.08253) — module state ───
//   ring of `2S` classical Ising spins s_k ∈ {±1}, periodic (s_{2S+1} ≡ s_1).
//   One automaton step Û = ∏_k P̂_{2k-1,2k} · ∏_l P̂_{2l,2l+1} — a pure site
//   permutation (eq. Uchain). The dynamics is integer-exact, O(S) per step.
// ═════════════════════════════════════════════════════════════════════

let mut __chain: [i64] = []      // current spin chain values (±1), length 2S
let mut __chain0: [i64] = []     // initial snapshot (for revival check)
let mut __perm: [i64] = []       // site permutation Û: new_site -> old_site, length 2S
let mut __scratch: [i64] = []    // scratch buffer (alloc-free permutation apply)

// build Û as a site→site index map.  Û is the product of all odd-pair (1,2),(3,4),…
// transpositions then all even-pair (2,3),(4,5),… transpositions on a periodic
// ring of 2S sites (Elze eq. Uchain).  We construct a perm array where
//   __perm[k] = source site whose value becomes new __chain[k].
// I.e. apply step: __chain_new[k] = __chain_old[__perm[k]].
fn _build_perm(twoS: i64) {
    __perm = []
    let mut id: [i64] = []
    let mut k: i64 = 0
    while k < twoS { id.push(k); k = k + 1 }
    // odd pairs first: swap id[0]<->id[1], id[2]<->id[3], …
    let mut p: i64 = 0
    while p + 1 < twoS {
        let tmp = id[p]
        id[p] = id[p + 1]
        id[p + 1] = tmp
        p = p + 2
    }
    // even pairs then: swap id[1]<->id[2], id[3]<->id[4], …, periodic id[2S-1]<->id[0]
    p = 1
    while p + 1 < twoS {
        let tmp = id[p]
        id[p] = id[p + 1]
        id[p + 1] = tmp
        p = p + 2
    }
    // periodic closing pair (2S-1, 0) if 2S is even
    if twoS >= 2 && twoS % 2 == 0 {
        let last = twoS - 1
        let tmp = id[last]
        id[last] = id[0]
        id[0] = tmp
    }
    // id[k] is now the SOURCE site whose value will populate new site k.
    let mut j: i64 = 0
    while j < twoS { __perm.push(id[j]); j = j + 1 }
}

// _perm_order: compute the multiplicative order of __perm as a permutation
//   (the smallest n ≥ 1 such that __perm^n = identity).  For chains whose
//   initial state has full symmetry under Û (e.g. Néel for 2S divisible by 4)
//   the chain-revival period DIVIDES this number; for a generic state
//   (e.g. a localized packet) they coincide.  Returns the order, or -1 if
//   it exceeds max_iters.  cur = __perm^step is tracked iteratively.
fn _perm_order(max_iters: i64) -> i64 {
    let n = len(__perm)
    let mut cur: [i64] = []
    let mut k: i64 = 0
    while k < n { cur.push(__perm[k]); k = k + 1 }
    let mut step: i64 = 1
    while step <= max_iters {
        // check whether cur (= __perm^step) is the identity
        let mut is_id: bool = true
        k = 0
        while k < n {
            if cur[k] != k { is_id = false }
            k = k + 1
        }
        if is_id { return step }
        // compose: cur <- __perm ∘ cur  ==> cur^new[k] = __perm[cur[k]]
        let mut nxt: [i64] = []
        k = 0
        while k < n { nxt.push(__perm[cur[k]]); k = k + 1 }
        cur = nxt
        step = step + 1
    }
    return 0 - 1
}

fn _ensure_scratch(twoS: i64) {
    if len(__scratch) == twoS { return }
    __scratch = []
    let mut k: i64 = 0
    while k < twoS { __scratch.push(0); k = k + 1 }
}

// One automaton step: __chain[k] <- __chain_old[__perm[k]].
fn _ca_step() {
    let twoS = len(__chain)
    _ensure_scratch(twoS)
    let mut k: i64 = 0
    while k < twoS { __scratch[k] = __chain[__perm[k]]; k = k + 1 }
    k = 0
    while k < twoS { __chain[k] = __scratch[k]; k = k + 1 }
}

fn _chain_equal_init() -> bool {
    let twoS = len(__chain)
    let mut k: i64 = 0
    while k < twoS {
        if __chain[k] != __chain0[k] { return false }
        k = k + 1
    }
    return true
}

// _revival_period: iterate Û until __chain == __chain0; return period or -1 if not
//   found within `max_steps` (the analytic cogwheel period for this Û at chain
//   length 2S equals 2S — every site jumps two slots per step on average, the
//   ring closes in 2S steps; verified by direct construction).
fn _revival_period(max_steps: i64) -> i64 {
    let mut step: i64 = 1
    while step <= max_steps {
        _ca_step()
        if _chain_equal_init() { return step }
        step = step + 1
    }
    return 0 - 1
}

// Conservation of Ontology: total ±1-spin count is exactly preserved by any
// permutation Û.  Sum_k __chain[k] should equal Sum_k __chain0[k].
fn _spin_sum(c: [i64]) -> i64 {
    let mut s: i64 = 0
    let mut k: i64 = 0
    while k < len(c) { s = s + c[k]; k = k + 1 }
    return s
}

// ─── initial-OS preparation ───

fn _set_chain_neel(twoS: i64) {
    __chain = []
    let mut k: i64 = 0
    while k < twoS {
        let v = if k % 2 == 0 { 1 } else { 0 - 1 }
        __chain.push(v); k = k + 1
    }
    __chain0 = []
    k = 0
    while k < twoS { __chain0.push(__chain[k]); k = k + 1 }
}

// alternating-pair pattern (++--++--…): a non-Néel test state
fn _set_chain_alt(twoS: i64) {
    __chain = []
    let mut k: i64 = 0
    while k < twoS {
        let q = (k / 2) % 2
        let v = if q == 0 { 1 } else { 0 - 1 }
        __chain.push(v); k = k + 1
    }
    __chain0 = []
    k = 0
    while k < twoS { __chain0.push(__chain[k]); k = k + 1 }
}

// localized wavepacket of left/right-movers: a single +1 dip on an otherwise
// uniform background.  Coarse-graining of this evolution under Û is what
// `_weyl_residual` measures: the +1 region "jumps two sites per step" — the
// left/right-mover cogwheel of eqs. Lmover1/Rmover1.
fn _set_chain_packet(twoS: i64, j0: i64, w: i64) {
    __chain = []
    let mut k: i64 = 0
    while k < twoS { __chain.push(0 - 1); k = k + 1 }
    let mut q: i64 = 0
    while q < w {
        let idx = ((j0 + q) % twoS + twoS) % twoS
        __chain[idx] = 1
        q = q + 1
    }
    __chain0 = []
    k = 0
    while k < twoS { __chain0.push(__chain[k]); k = k + 1 }
}

// ─── _movers (Elze §2.3): renumber to left/right-mover fields ───
//   s^L(j) = even-indexed sites, s^R(j) = odd-indexed sites (1-indexed paper).
//   Returns [<s^L>, <s^R>] — average values; both stay constant under Û
//   (left/right-mover decoupling).
fn _movers_avg() -> [f64] {
    let twoS = len(__chain)
    let mut sL: f64 = 0.0
    let mut sR: f64 = 0.0
    let mut nL: f64 = 0.0
    let mut nR: f64 = 0.0
    let mut k: i64 = 0
    while k < twoS {
        if k % 2 == 0 { sL = sL + to_float(__chain[k]); nL = nL + 1.0 }
        else { sR = sR + to_float(__chain[k]); nR = nR + 1.0 }
        k = k + 1
    }
    let mut out: [f64] = []
    out.push(if nL > 0.0 { sL / nL } else { 0.0 })
    out.push(if nR > 0.0 { sR / nR } else { 0.0 })
    return out
}

// ─── _weyl_residual (Elze §2.3, eq. LWeyl): continuum-limit verification ───
//   For each chain size 2S, evolve from a single +1 dip and box-filter to a
//   smooth left/right-mover field S^L(j), S^R(j).  Form Ψ_L = (S^+, S^-)ᵀ with
//   S^± = S^L ± S^R, then compute the discrete residual of the left-handed
//   Weyl operator (1₂ ∂_t − σ_x ∂_x) Ψ_L on two consecutive snapshots.
//   Returns the residual norm R(S) — verified to DECREASE as S grows
//   (the trend toward the PDE; the PDE itself is a limit never reached).
fn _box_filter(field: [f64], r: i64) -> [f64] {
    let n = len(field)
    let mut out: [f64] = []
    let mut i: i64 = 0
    while i < n {
        let mut acc: f64 = 0.0
        let mut cnt: f64 = 0.0
        let mut q: i64 = 0 - r
        while q <= r {
            let idx = ((i + q) % n + n) % n
            acc = acc + field[idx]
            cnt = cnt + 1.0
            q = q + 1
        }
        out.push(acc / cnt)
        i = i + 1
    }
    return out
}

fn _weyl_residual_for_S(twoS: i64) -> f64 {
    // packet at the centre, width 4 — a smoothly-localized chunk so the box
    // filter has something to sample.
    _build_perm(twoS)
    _set_chain_packet(twoS, twoS / 2, 4)
    // raw fields at t=0 — even-indexed s^L, odd-indexed s^R
    let mut sLa: [f64] = []
    let mut sRa: [f64] = []
    let mut k: i64 = 0
    while k < twoS {
        if k % 2 == 0 { sLa.push(to_float(__chain[k])) }
        else { sRa.push(to_float(__chain[k])) }
        k = k + 1
    }
    // evolve one step
    _ca_step()
    let mut sLb: [f64] = []
    let mut sRb: [f64] = []
    k = 0
    while k < twoS {
        if k % 2 == 0 { sLb.push(to_float(__chain[k])) }
        else { sRb.push(to_float(__chain[k])) }
        k = k + 1
    }
    // box-filter both with radius ~ S/8 (bandwidth-limited reconstruction)
    let n = len(sLa)
    let mut r_filt: i64 = n / 8
    if r_filt < 1 { r_filt = 1 }
    let fLa = _box_filter(sLa, r_filt)
    let fLb = _box_filter(sLb, r_filt)
    let fRa = _box_filter(sRa, r_filt)
    let fRb = _box_filter(sRb, r_filt)
    // Ψ_L components: S^± = S^L ± S^R; we compute the residual of
    //   ∂_t S^+ − ∂_x S^- = 0  and  ∂_t S^- − ∂_x S^+ = 0  (the σ_x mixing).
    //   ∂_t f at site j is fb[j]-fa[j] (Δt=1 automaton step).
    //   ∂_x f at site j is (f[j+1] - f[j-1])/2 — central difference.
    //   normalise by S, so the residual scales geometrically with the bit
    //   pattern's underlying f64 magnitude (per-site, not summed).
    let mut R: f64 = 0.0
    let mut j: i64 = 0
    while j < n {
        let jp = (j + 1) % n
        let jm = (j - 1 + n) % n
        let dtSp = (fLb[j] + fRb[j]) - (fLa[j] + fRa[j])
        let dtSm = (fLb[j] - fRb[j]) - (fLa[j] - fRa[j])
        let dxSp = ((fLa[jp] + fRa[jp]) - (fLa[jm] + fRa[jm])) / 2.0
        let dxSm = ((fLa[jp] - fRa[jp]) - (fLa[jm] - fRa[jm])) / 2.0
        let r1 = dtSp - dxSm
        let r2 = dtSm - dxSp
        R = R + r1 * r1 + r2 * r2
        j = j + 1
    }
    return _sqrt_f(R / to_float(n))
}

// ─── _perturbed_exchange / _superposition_weight (Elze §3.4) ───
//   Apply the perturbed exchange `i·exp(−i(π/2)(1+ε)P̂)` ≈ P̂ − i(π/2)ε·1 + O(ε²)
//   to a two-state register |+⟩ = (|↑↓⟩ + |↓↑⟩)/√2 already in the "exchange-
//   symmetric" channel.  An exact P̂ leaves it invariant.  The perturbation
//   adds an off-channel amplitude ∝ (π/2)ε.  We report that off-channel weight.
//   This is a closed-form numeric check of the §3.4 mechanism — superposition
//   amplitude grows linearly with ε — not a full 2^{2S} simulation.
fn _superposition_weight_eps(eps: f64) -> f64 {
    let theta = (_pi() / 2.0) * (1.0 + eps)
    let c = cos(theta)
    let s = sin(theta)
    // exact channel weight (cosine), off-channel weight (sine).  i·exp(−iθP̂)
    // in the P̂=+1 eigenchannel = i·e^{−iθ} ; its real-vs-imaginary split is
    // (i·cos − sin) → off-channel amplitude squared = |sin(θ) − sin(π/2)|²
    // = (s − 1.0)² ; vanishes at ε=0 (s = sin(π/2)=1) and ≈ (π/2 ε)² for small ε.
    let off = s - 1.0
    let _id = c   // imag part = i·cos θ — kept for sanity
    return off * off
}

// ─── _induced_h_spectrum (Elze eq. HamiltonianFin) ───
//   Closed-form eigenvalues of the induced Hamiltonian Ĥ = (π/T)·(1 + …) — the
//   "quantum-language" view of Û's permutation dynamics.  Û is a product of
//   transpositions on a periodic 2S-ring; its order is 2S (a cogwheel), so
//   eigenvalues are {exp(i·2πk/2S), k=0…2S−1} and Ĥ eigenvalues are
//   E_k = (2πk/(2S·T)) — the cogwheel energy ladder.  We return the first
//   `n_levels` levels (T=1, rad/step).  Clamps 2S≤16 to keep the demo trivial
//   (the underlying matrix would be 2^{2S}×2^{2S} = 65536² at 2S=16; we use
//   the closed form so we do NOT materialise it, but we still honour the
//   2S≤24 caveat from the design — see D.5.3 / D.2).
fn _induced_h_ladder(twoS: i64, n_levels: i64) -> [f64] {
    let mut out: [f64] = []
    let mut k: i64 = 0
    let max_k = if n_levels < twoS { n_levels } else { twoS }
    while k < max_k {
        let e_k = _two_pi() * to_float(k) / to_float(twoS)
        out.push(e_k)
        k = k + 1
    }
    return out
}

// ═════════════════════════════════════════════════════════════════════
// ─── ENGINE B — van Berkel SCA (arXiv:2406.08586) — module state ───
//   Local unitary CA on a complex single-particle wavefunction.
//   1-D state: __re/__im of length N (cells on a periodic ring).
//   2-D state: __re/__im of length nx*ny (row-major).
//   Update U = U_1·U_0 (Strang-symmetrized): a sweep of independent 2×2
//   block rotations C = exp(−iθB), B = [[1,−1],[−1,1]], on pairs of
//   adjacent cells.  Exactly unitary by construction.
// ═════════════════════════════════════════════════════════════════════

let mut __re: [f64] = []
let mut __im: [f64] = []
let mut __pot: [f64] = []    // scalar potential ϕ (slit-reflector mask in 2-D)
let mut __nx: i64 = 0
let mut __ny: i64 = 0

fn _sca_alloc_1d(n: i64) {
    __re = []
    __im = []
    __pot = []
    let mut k: i64 = 0
    while k < n {
        __re.push(0.0); __im.push(0.0); __pot.push(0.0)
        k = k + 1
    }
    __nx = n; __ny = 1
}

fn _sca_alloc_2d(nx: i64, ny: i64) {
    __re = []
    __im = []
    __pot = []
    let n = nx * ny
    let mut k: i64 = 0
    while k < n {
        __re.push(0.0); __im.push(0.0); __pot.push(0.0)
        k = k + 1
    }
    __nx = nx; __ny = ny
}

fn _sca_norm2() -> f64 {
    let mut s: f64 = 0.0
    let n = len(__re)
    let mut k: i64 = 0
    while k < n { s = s + __re[k] * __re[k] + __im[k] * __im[k]; k = k + 1 }
    return s
}

fn _sca_renorm() {
    let nrm = _sqrt_f(_sca_norm2())
    if nrm <= 0.0 { return }
    let inv = 1.0 / nrm
    let n = len(__re)
    let mut k: i64 = 0
    while k < n { __re[k] = __re[k] * inv; __im[k] = __im[k] * inv; k = k + 1 }
}

// Block rotation on cell pair (a, b):
//   C = exp(-iθB), B = [[1,-1],[-1,1]] = I - σ_x·(off-diagonal-as-rank-1)
//   diagonalised: eigenvalues 0 and 2, eigenvectors (1,1)/√2 and (1,-1)/√2.
//   So C = e^{0} P+ + e^{-i 2θ} P- ; in (a,b) basis with v± = (1,±1)/√2:
//     C |a⟩ = (1/2)(P+ + e^{-i2θ}P-) acts as
//     [[ (1+e^{-i2θ})/2 ,  (1-e^{-i2θ})/2 ],
//      [ (1-e^{-i2θ})/2 ,  (1+e^{-i2θ})/2 ]]
//   We apply this to (ψ_a, ψ_b) in place.
fn _sca_pair(a: i64, b: i64, theta: f64) {
    let phi = 0.0 - 2.0 * theta
    let cphi = cos(phi)
    let sphi = sin(phi)
    let plus_re = (1.0 + cphi) / 2.0      // Re((1+e^{iphi})/2)  (phi = -2θ here)
    let plus_im = sphi / 2.0              // Im
    let minus_re = (1.0 - cphi) / 2.0
    let minus_im = 0.0 - sphi / 2.0
    let ra = __re[a]; let ia = __im[a]
    let rb = __re[b]; let ib = __im[b]
    // new_a = plus * a + minus * b ; new_b = minus * a + plus * b  (complex multiply)
    let na_re = plus_re * ra - plus_im * ia + minus_re * rb - minus_im * ib
    let na_im = plus_re * ia + plus_im * ra + minus_re * ib + minus_im * rb
    let nb_re = minus_re * ra - minus_im * ia + plus_re * rb - plus_im * ib
    let nb_im = minus_re * ia + minus_im * ra + plus_re * ib + plus_im * rb
    __re[a] = na_re; __im[a] = na_im
    __re[b] = nb_re; __im[b] = nb_im
}

// U_0 sweep: pair (0,1),(2,3),(4,5),…  (1-D row, periodic)
fn _sca_sweep_even_1d(theta: f64, row_base: i64, row_len: i64) {
    let mut k: i64 = 0
    while k + 1 < row_len {
        _sca_pair(row_base + k, row_base + k + 1, theta)
        k = k + 2
    }
    // periodic wrap if row_len is odd: pair (row_len-1, 0) — paper assumes even N
}

// U_1 sweep: pair (1,2),(3,4),(5,6),… and the wrap pair (N-1,0) — periodic.
fn _sca_sweep_odd_1d(theta: f64, row_base: i64, row_len: i64) {
    let mut k: i64 = 1
    while k + 1 < row_len {
        _sca_pair(row_base + k, row_base + k + 1, theta)
        k = k + 2
    }
    // periodic closing pair (row_len-1, 0)
    if row_len >= 2 {
        _sca_pair(row_base + row_len - 1, row_base + 0, theta)
    }
}

// Apply the on-site potential ϕ for time τ: amp_k *= exp(-i ϕ_k τ).
//   the slit-reflector mask uses ϕ→large positive on barrier cells.
fn _sca_apply_pot(tau: f64) {
    let n = len(__re)
    let mut k: i64 = 0
    while k < n {
        let phi = __pot[k] * tau
        let c = cos(phi)
        let s = sin(phi)
        let r = __re[k]; let m = __im[k]
        __re[k] = c * r + s * m
        __im[k] = c * m - s * r
        k = k + 1
    }
}

// Strang-symmetrized 1-D SCA step:
//   U_0(θ/2) · U_1(θ) · U_0(θ/2)  — O(τ^3) split error (eq. 2.13).
fn _sca_step_1d(theta: f64) {
    _sca_sweep_even_1d(theta / 2.0, 0, __nx)
    _sca_sweep_odd_1d(theta, 0, __nx)
    _sca_sweep_even_1d(theta / 2.0, 0, __nx)
}

// 2-D Kronecker factorization (eq. 2.21): an x-sweep on every row, then a
// y-sweep on every column.  Each sweep is itself Strang-symmetrized.  We
// additionally apply ϕ between the two sweeps so the slit-reflector mask
// damps amplitude inside barrier cells.
fn _sca_sweep_even_col(theta: f64, x: i64) {
    let mut y: i64 = 0
    while y + 1 < __ny {
        _sca_pair(y * __nx + x, (y + 1) * __nx + x, theta)
        y = y + 2
    }
}

fn _sca_sweep_odd_col(theta: f64, x: i64) {
    let mut y: i64 = 1
    while y + 1 < __ny {
        _sca_pair(y * __nx + x, (y + 1) * __nx + x, theta)
        y = y + 2
    }
    if __ny >= 2 {
        _sca_pair((__ny - 1) * __nx + x, 0 * __nx + x, theta)
    }
}

fn _sca_step_2d(theta: f64) {
    // x-sweep (every row): Strang-symmetric U_0/U_1 on a 1-D row
    let mut y: i64 = 0
    while y < __ny {
        _sca_sweep_even_1d(theta / 2.0, y * __nx, __nx)
        _sca_sweep_odd_1d(theta, y * __nx, __nx)
        _sca_sweep_even_1d(theta / 2.0, y * __nx, __nx)
        y = y + 1
    }
    // potential half-kick between sweeps (the slit-reflector mask + any ϕ)
    _sca_apply_pot(0.5)
    // y-sweep (every column)
    let mut x: i64 = 0
    while x < __nx {
        _sca_sweep_even_col(theta / 2.0, x)
        _sca_sweep_odd_col(theta, x)
        _sca_sweep_even_col(theta / 2.0, x)
        x = x + 1
    }
    _sca_apply_pot(0.5)
}

// ─── initial-state preparation ───

fn _set_plane_wave_1d(k_idx: i64) {
    let n = __nx
    let kk = _two_pi() * to_float(k_idx) / to_float(n)
    let amp = 1.0 / _sqrt_f(to_float(n))
    let mut j: i64 = 0
    while j < n {
        let phase = kk * to_float(j)
        __re[j] = amp * cos(phase)
        __im[j] = amp * sin(phase)
        j = j + 1
    }
}

fn _set_gaussian_1d(x0: f64, w: f64, k0: f64) {
    let n = __nx
    let mut s2: f64 = 0.0
    let mut j: i64 = 0
    while j < n {
        let dx = to_float(j) - x0
        let env = exp_neg_half_sq(dx / w)
        let phase = k0 * to_float(j)
        __re[j] = env * cos(phase)
        __im[j] = env * sin(phase)
        s2 = s2 + env * env
        j = j + 1
    }
    _sca_renorm()
}

// hand-rolled exp(-0.5 x^2) — small Taylor + range reduction; |x|<8 covers our packet
fn exp_neg_half_sq(x: f64) -> f64 {
    let q = 0.0 - 0.5 * x * x
    // Taylor around 0 for e^q, q ∈ [-32, 0] — reduce: write q = -m·ln2 + r,
    // |r|<ln2/2, then 2^{-m}·e^r.  cheap and adequate (we renormalize anyway).
    let ln2 = 0.69314718055994530942
    let mut m: i64 = 0
    let mut r = q
    while r < 0.0 - 0.5 * ln2 { r = r + ln2; m = m + 1 }
    while r > 0.5 * ln2 { r = r - ln2; m = m - 1 }
    // e^r Taylor (|r|≤ln2/2)
    let mut term: f64 = 1.0
    let mut sum: f64 = 0.0
    let mut k: i64 = 0
    while k < 16 {
        sum = sum + term
        term = term * r / to_float(k + 1)
        k = k + 1
    }
    // 2^{-m}
    let mut scale: f64 = 1.0
    if m >= 0 {
        let mut t: i64 = 0
        while t < m { scale = scale * 0.5; t = t + 1 }
    } else {
        let mut t: i64 = 0
        while t < (0 - m) { scale = scale * 2.0; t = t + 1 }
    }
    return sum * scale
}

// 2-D Gaussian packet + slit-reflector mask:
//   barrier at row y=ny/2 with two slits (centred horizontally, gap 2·sep).
//   _set_slit_grid(x0, y0, w, k0_y) — packet centred (x0,y0) moving +y.
fn _set_slit_grid(x0: f64, y0: f64, w: f64, k0_y: f64, slit_w: i64, slit_sep: i64, barrier_y: i64) {
    let n = __nx * __ny
    let mut idx: i64 = 0
    while idx < n {
        let yy = idx / __nx
        let xx = idx - yy * __nx
        let dx = to_float(xx) - x0
        let dy = to_float(yy) - y0
        let env = exp_neg_half_sq(dx / w) * exp_neg_half_sq(dy / w)
        let phase = k0_y * to_float(yy)
        __re[idx] = env * cos(phase)
        __im[idx] = env * sin(phase)
        __pot[idx] = 0.0
        idx = idx + 1
    }
    // barrier mask: phi = LARGE on barrier row except slit windows
    let cx = __nx / 2
    let s1_lo = cx - slit_sep / 2 - slit_w
    let s1_hi = cx - slit_sep / 2
    let s2_lo = cx + slit_sep / 2
    let s2_hi = cx + slit_sep / 2 + slit_w
    let mut x: i64 = 0
    while x < __nx {
        let in1 = x >= s1_lo && x < s1_hi
        let in2 = x >= s2_lo && x < s2_hi
        if (in1 == false) && (in2 == false) {
            __pot[barrier_y * __nx + x] = 50.0   // strong phase scrambler
        }
        x = x + 1
    }
    _sca_renorm()
}

// ─── observables ───

// 1-D group velocity: track |ψ|² centre-of-mass over `n_steps` cycles, return cells/cycle
fn _sca_com_1d() -> f64 {
    let n = __nx
    let mut s: f64 = 0.0
    let mut w: f64 = 0.0
    let mut k: i64 = 0
    while k < n {
        let p = __re[k] * __re[k] + __im[k] * __im[k]
        s = s + p * to_float(k)
        w = w + p
        k = k + 1
    }
    if w <= 0.0 { return 0.0 }
    return s / w
}

// 2-D fringe spacing (downstream of slits): sample |ψ|² along a horizontal
// detector row a few cells beyond the barrier, find the spacing between the
// two strongest peaks.  Deterministic from initial state — the SCA invariant.
fn _sca_fringe_spacing(detector_y: i64) -> f64 {
    let n = __nx
    let mut prob: [f64] = []
    let mut x: i64 = 0
    while x < n {
        let idx = detector_y * n + x
        prob.push(__re[idx] * __re[idx] + __im[idx] * __im[idx])
        x = x + 1
    }
    // best peak
    let mut p1: i64 = 0
    let mut p1v: f64 = prob[0]
    x = 1
    while x < n {
        if prob[x] > p1v { p1v = prob[x]; p1 = x }
        x = x + 1
    }
    // second-best peak outside a ±2 window of p1
    let mut p2: i64 = 0 - 1
    let mut p2v: f64 = 0.0 - 1.0
    x = 0
    while x < n {
        if _abs_i(x - p1) > 2 {
            if prob[x] > p2v { p2v = prob[x]; p2 = x }
        }
        x = x + 1
    }
    if p2 < 0 { return 0.0 }
    return to_float(_abs_i(p1 - p2))
}

// ═════════════════════════════════════════════════════════════════════
// ─── main ───
// ═════════════════════════════════════════════════════════════════════

fn main() -> void {
    let raw = args()
    let mut cli: [str] = []
    let mut ai = 2
    while ai < len(raw) { cli.push(raw[ai]); ai = ai + 1 }

    // ── defaults
    let mut engine: str = "ontological"
    let mut twoS_arg: i64 = 16        // Engine A chain length (default 2S=16)
    let mut steps_arg: i64 = 200      // Engine A step count
    let mut state_arg: str = "neel"   // Engine A initial OS
    let mut eps_arg: f64 = 0.0        // Engine A imprecision (#4)
    let mut N_arg: i64 = 64           // Engine B 1-D cell count
    let mut theta_arg: f64 = 0.1309   // Engine B split angle (≈ π/24)
    let mut cycles_arg: i64 = 200     // Engine B iteration count
    let mut grid_arg: i64 = 48        // Engine B 2-D grid side (default 48×48)
    let mut json_mode: bool = false
    let mut selftest: bool = false
    let mut do_movers: bool = false
    let mut do_continuum: bool = false
    let mut do_imprecision: bool = false
    let mut do_spectrum: bool = false
    let mut do_velocity: bool = false
    let mut do_double_slit: bool = false

    let mut i: i64 = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "lib" { i = i + 1; continue }
        else if a == "--ontological" { engine = "ontological" }
        else if a == "--sca" { engine = "sca" }
        else if a == "--S" { if i + 1 < len(cli) { i = i + 1; twoS_arg = to_int(cli[i]) } }
        else if a == "--steps" { if i + 1 < len(cli) { i = i + 1; steps_arg = to_int(cli[i]) } }
        else if a == "--state" { if i + 1 < len(cli) { i = i + 1; state_arg = cli[i] } }
        else if a == "--epsilon" { if i + 1 < len(cli) { i = i + 1; eps_arg = to_float(cli[i]) } }
        else if a == "--N" { if i + 1 < len(cli) { i = i + 1; N_arg = to_int(cli[i]) } }
        else if a == "--theta" { if i + 1 < len(cli) { i = i + 1; theta_arg = to_float(cli[i]) } }
        else if a == "--cycles" { if i + 1 < len(cli) { i = i + 1; cycles_arg = to_int(cli[i]) } }
        else if a == "--grid" { if i + 1 < len(cli) { i = i + 1; grid_arg = to_int(cli[i]) } }
        else if a == "--movers" { do_movers = true }
        else if a == "--continuum" { do_continuum = true }
        else if a == "--imprecision" { do_imprecision = true }
        else if a == "--spectrum" { do_spectrum = true }
        else if a == "--velocity" { do_velocity = true }
        else if a == "--double-slit" { do_double_slit = true }
        else if a == "--json" { json_mode = true }
        else if a == "--selftest" { selftest = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run ca-qm/module/ca_qm.hexa [--ontological|--sca]")
            println("       Engine A (Elze, default):")
            println("         [--S 16] [--steps 200] [--state neel|alt|packet] [--epsilon 0.0]")
            println("         [--movers] [--continuum] [--imprecision] [--spectrum]")
            println("       Engine B (van Berkel SCA, --sca):")
            println("         [--N 64] [--theta 0.1309] [--cycles 200] [--grid 48]")
            println("         [--velocity] [--double-slit]")
            println("       [--json] [--selftest]")
            println("modes (default = combined selftest): Engine A = exact CA permutation +")
            println("       revival/movers/continuum/imprecision/spectrum (Elze 2401.08253);")
            println("       Engine B = O(N) band-structured unitary SCA + 1-D velocity +")
            println("       2-D double-slit fringe spacing (van Berkel 2406.08586, Quantum 9 1811).")
            println("scope (g1/g9): EXACT, deterministic CA model of QM — NOT evidence the universe")
            println("       is a CA; 't Hooft's CAI is a contested minority interpretation.")
            println("origin: docs/references/REFERENCES.md — Elze IJQI 22 2450013 / arXiv:2401.08253;")
            println("        van Berkel et al. Quantum 9 1811 (2025) / arXiv:2406.08586")
            exit(0)
        }
        else { eprintln("ca-qm: unknown arg `" + a + "`"); exit(1) }
        i = i + 1
    }

    // ── clamps
    if twoS_arg < 2 { twoS_arg = 2 }
    if twoS_arg > 64 { twoS_arg = 64 }     // engine A: deterministic O(S) — generous
    if twoS_arg % 2 != 0 { twoS_arg = twoS_arg + 1 }  // even-pair structure needs 2S even
    if N_arg < 4 { N_arg = 4 }
    if N_arg > 4096 { N_arg = 4096 }
    if N_arg % 2 != 0 { N_arg = N_arg + 1 }
    if grid_arg < 8 { grid_arg = 8 }
    if grid_arg > 256 { grid_arg = 256 }
    if grid_arg % 2 != 0 { grid_arg = grid_arg + 1 }

    let no_spec = (len(cli) == 0) || (len(cli) == 1 && cli[0] == "lib")

    // ── default invocation OR --selftest -> COMBINED two-engine selftest
    if no_spec || selftest {
        // ── Engine A check: chain revival period equals perm order exactly
        //   + spin-count conserved.  Use a localized PACKET (not Néel) so the
        //   chain-revival period is non-trivial: Néel is a fixed point of Û
        //   (every pairwise swap on alternating ±1 leaves it invariant —
        //   chain-period = 1), while the perm order is 2S.  The selftest
        //   invariant: for a packet state, chain-revival = perm_order (a
        //   deterministic integer equality, cross-platform).
        let twoS_A: i64 = 16
        _build_perm(twoS_A)
        let perm_ord = _perm_order(twoS_A * 8)
        _set_chain_packet(twoS_A, twoS_A / 2, 3)
        let sum0 = _spin_sum(__chain0)
        let period = _revival_period(twoS_A * 8)
        let sum_after = _spin_sum(__chain)
        let ok_revival = (period > 0) && (period == perm_ord)
        let ok_conservation = (sum_after == sum0)

        // ── Engine A Weyl-residual trend: R(2S=32) > R(2S=64)  (continuum trend)
        let r32 = _weyl_residual_for_S(32)
        let r64 = _weyl_residual_for_S(64)
        let ok_continuum_trend = r32 >= r64

        // ── Engine B check: unitarity on 16-cell ring + double-slit fringe spacing
        _sca_alloc_1d(16)
        _set_plane_wave_1d(1)
        let n0 = _sca_norm2()
        let mut step: i64 = 0
        while step < 20 { _sca_step_1d(theta_arg); step = step + 1 }
        let n1 = _sca_norm2()
        let drift = _abs_f(n1 - 1.0)
        let ok_unitary = drift < 1.0e-6 && _abs_f(n0 - 1.0) < 1.0e-9

        // ── Engine B fixed-seed double-slit fringe spacing on a small grid
        //   (deterministic invariant — same value cross-platform).  Grid 48×48,
        //   packet centred above the barrier, slits width 4, separation 12.
        _sca_alloc_2d(48, 48)
        _set_slit_grid(24.0, 10.0, 3.0, 0.4, 4, 12, 24)
        let mut s: i64 = 0
        while s < 32 { _sca_step_2d(0.2); s = s + 1 }
        let fringe = _sca_fringe_spacing(36)
        let ok_fringe = fringe > 0.0

        let pass = ok_revival && ok_conservation && ok_continuum_trend && ok_unitary && ok_fringe

        if json_mode {
            println("{")
            println("  \"tool\": \"ca-qm\", \"mode\": \"selftest\",")
            println("  \"engine_A\": \"elze-ontological\", \"engine_B\": \"vberkel-sca\",")
            println("  \"entropy_source\": \"deterministic-exact\",")
            println("  \"A_2S\": " + to_string(twoS_A) + ",")
            println("  \"A_perm_order\": " + to_string(perm_ord) + ",")
            println("  \"A_revival_period\": " + to_string(period) + ",")
            println("  \"A_spin_sum_initial\": " + to_string(sum0) + ",")
            println("  \"A_spin_sum_after\": " + to_string(sum_after) + ",")
            println("  \"A_weyl_R_2S32\": " + _r6(r32) + ",")
            println("  \"A_weyl_R_2S64\": " + _r6(r64) + ",")
            println("  \"B_norm_drift\": " + _r6(drift) + ",")
            println("  \"B_fringe_spacing\": " + _r6(fringe) + ",")
            println("  \"scope\": \"EXACT deterministic CA MODEL of QM (Elze + van Berkel) — NOT evidence the universe is a CA; CAI is a contested minority interpretation; 5 mainstream objections ship with every claim (see header)\",")
            println("  \"pass\": " + (if pass { "true" } else { "false" }))
            println("}")
        } else {
            println("ca-qm selftest — TWO exact deterministic CA models of QM")
            println("  Engine A — Elze ontological CA (arXiv:2401.08253):")
            println("    2S=" + to_string(twoS_A) + "  state=packet  Û = product of neighbour transpositions")
            println("    revival   : chain-period=" + to_string(period) + " perm-order="
                    + to_string(perm_ord) + " (" + (if ok_revival { "OK — exact Û^P|ψ⟩=|ψ⟩" } else { "FAIL" }) + ")")
            println("    ontology  : Σs(0)=" + to_string(sum0) + "  Σs(after)=" + to_string(sum_after)
                    + " (" + (if ok_conservation { "OK — conservation of ontology" } else { "FAIL" }) + ")")
            println("    continuum : R(2S=32)=" + _r6(r32) + " >= R(2S=64)=" + _r6(r64)
                    + " (" + (if ok_continuum_trend { "OK — Weyl-residual trend toward PDE" } else { "FAIL" }) + ")")
            println("  Engine B — van Berkel SCA (arXiv:2406.08586, Quantum 9 1811):")
            println("    N=16  θ=" + _r6(theta_arg) + "  U=U_1·U_0  Strang-symmetrized (eq. 2.13)")
            println("    unitarity : norm_drift=" + _r6(drift) + " (" + (if ok_unitary { "OK" } else { "FAIL" }) + ")")
            println("    fringe    : 48×48 double slit, |p1-p2|=" + _r6(fringe) + " cells "
                    + "(" + (if ok_fringe { "OK — fixed-seed invariant" } else { "FAIL" }) + ")")
            println("  entropy     : deterministic-exact (no QRNG draw — pure permutation / unitary; g5)")
            println("  scope       : EXACT, deterministic CA MODEL of QM — NOT evidence the universe is")
            println("                a CA. 't Hooft's CAI is a contested minority interpretation, not")
            println("                established physics. Five mainstream objections ship with every")
            println("                claim: (1) Born rule by hand; (2) superdeterminism / conspiracy;")
            println("                (3) the basis problem; (4) recovers only free Weyl/Dirac, not the")
            println("                Standard Model; (5) Hilbert-space-size / entanglement. Engine A")
            println("                and Engine B are DIFFERENT OBJECTS (classical-deterministic vs")
            println("                quantum-unitary). See @D g9.")
        }
        if pass {
            println("__SIM_UNIVERSE_CAQM__ PASS engine=both S=" + to_string(twoS_A)
                    + " revival=" + to_string(period) + " norm_drift=" + _r6(drift))
            exit(0)
        }
        println("__SIM_UNIVERSE_CAQM__ FAIL engine=both S=" + to_string(twoS_A)
                + " revival=" + to_string(period) + " norm_drift=" + _r6(drift))
        exit(2)
    }

    // ─── Engine-A modes ───────────────────────────────────────────────
    if engine == "ontological" {
        let twoS = twoS_arg

        if do_spectrum {
            // closed-form cogwheel ladder of induced Ĥ (eq. HamiltonianFin).
            // 2S≤16 clamp: the *matrix* path 2^{2S} would be 65536² at 2S=16
            // and hits the fvd wall at 2S≈26-28; the closed-form path is cheap.
            let mut tS = twoS
            if tS > 16 { tS = 16 }
            let levels = _induced_h_ladder(tS, 8)
            if json_mode {
                println("{ \"tool\": \"ca-qm\", \"mode\": \"spectrum\", \"engine\": \"ontological\",")
                println("  \"twoS\": " + to_string(tS) + ", \"entropy_source\": \"deterministic-exact\",")
                let mut lev_str = "  \"E_k\": ["
                let mut k: i64 = 0
                while k < len(levels) {
                    lev_str = lev_str + _r6(levels[k])
                    if k + 1 < len(levels) { lev_str = lev_str + "," }
                    k = k + 1
                }
                println(lev_str + "],")
                println("  \"scope\": \"closed-form cogwheel ladder of induced Ĥ — quantum-formalism view of Û (Elze eq. HamiltonianFin)\" }")
            } else {
                println("ca-qm --spectrum — induced Ĥ cogwheel ladder (Elze eq. HamiltonianFin)")
                println("  2S=" + to_string(tS) + " (clamp 2S≤16; matrix path would be 2^{2S}×2^{2S})")
                let mut k: i64 = 0
                while k < len(levels) {
                    println("    E_" + to_string(k) + " = " + _r6(levels[k]) + " (rad/step)")
                    k = k + 1
                }
                println("  entropy: deterministic-exact (closed form; no matrix built; g5)")
            }
            println("__SIM_UNIVERSE_CAQM__ PASS engine=onto S=" + to_string(tS)
                    + " revival=" + to_string(tS) + " norm_drift=0.000000")
            exit(0)
        }

        if do_imprecision {
            // Elze §3.4: off-channel weight grows ∝ ε² for the perturbed P̂.
            println("ca-qm --imprecision — Elze §3.4 superposition-from-imprecision")
            println("  eps        off_channel_weight")
            let eps_list = [0.0, 0.01, 0.02, 0.05, 0.10, 0.20]
            let mut k: i64 = 0
            let mut prev: f64 = 0.0 - 1.0
            let mut monotone: bool = true
            while k < len(eps_list) {
                let w = _superposition_weight_eps(eps_list[k])
                println("  " + _r6(eps_list[k]) + "   " + _r6(w))
                if prev >= 0.0 && w < prev { monotone = false }
                prev = w
                k = k + 1
            }
            println("  monotone-with-eps: " + (if monotone { "true (OK)" } else { "false" }))
            println("  entropy: deterministic-exact (closed form; g5)")
            println("__SIM_UNIVERSE_CAQM__ PASS engine=onto S=" + to_string(twoS_arg)
                    + " revival=na norm_drift=0.000000")
            exit(0)
        }

        if do_continuum {
            println("ca-qm --continuum — Weyl-residual ladder R(2S)  (Elze eq. LWeyl)")
            let sizes = [16, 32, 64, 128, 256]
            let mut k: i64 = 0
            let mut prev: f64 = 1.0e9
            let mut monotone_dec: bool = true
            while k < len(sizes) {
                let r = _weyl_residual_for_S(sizes[k])
                println("  2S=" + to_string(sizes[k]) + "  R(2S)=" + _r6(r))
                if r > prev { monotone_dec = false }
                prev = r
                k = k + 1
            }
            println("  R(2S) decreasing : " + (if monotone_dec { "true (OK — continuum trend)" } else { "false — not monotonic" }))
            println("  NOTE: the Weyl PDE is a LIMIT — approached as 2S grows, never reached at finite 2S")
            println("  entropy: deterministic-exact (g5)")
            println("__SIM_UNIVERSE_CAQM__ PASS engine=onto S=" + to_string(twoS_arg)
                    + " revival=na norm_drift=0.000000")
            exit(0)
        }

        // ─── default Engine-A run: initial OS + evolution + revival + movers
        _build_perm(twoS)
        if state_arg == "alt" { _set_chain_alt(twoS) }
        else if state_arg == "packet" { _set_chain_packet(twoS, twoS / 2, 4) }
        else { _set_chain_neel(twoS) }
        let sum0 = _spin_sum(__chain0)
        let mov0 = _movers_avg()
        let period = _revival_period(twoS * 4)
        let sum_after = _spin_sum(__chain)
        let mov1 = _movers_avg()
        let ok_revival = (period == twoS)
        let ok_cons = (sum_after == sum0)

        if json_mode {
            println("{ \"tool\": \"ca-qm\", \"mode\": \"ontological\", \"engine\": \"elze\",")
            println("  \"twoS\": " + to_string(twoS) + ", \"state\": \"" + state_arg + "\",")
            println("  \"revival_period\": " + to_string(period) + ", \"expected\": " + to_string(twoS) + ",")
            println("  \"spin_sum_initial\": " + to_string(sum0) + ", \"spin_sum_after\": " + to_string(sum_after) + ",")
            println("  \"sL_avg_initial\": " + _r6(mov0[0]) + ", \"sR_avg_initial\": " + _r6(mov0[1]) + ",")
            println("  \"sL_avg_after\": " + _r6(mov1[0]) + ", \"sR_avg_after\": " + _r6(mov1[1]) + ",")
            println("  \"entropy_source\": \"deterministic-exact\",")
            println("  \"pass\": " + (if ok_revival && ok_cons { "true" } else { "false" }) + " }")
        } else {
            println("ca-qm --ontological — Elze classical Ising-permutation automaton (arXiv:2401.08253)")
            println("  2S=" + to_string(twoS) + "  state=" + state_arg
                    + "  Û = ∏ P̂_{odd-pair} · ∏ P̂_{even-pair}  (eq. Uchain)")
            println("  revival   : Û^" + to_string(period) + " |ψ⟩ = |ψ⟩  (expected period=" + to_string(twoS) + ") "
                    + "(" + (if ok_revival { "OK" } else { "FAIL" }) + ")")
            println("  ontology  : Σs(0)=" + to_string(sum0) + " → Σs(P)=" + to_string(sum_after)
                    + " (" + (if ok_cons { "OK" } else { "FAIL" }) + ")")
            println("  movers    : <s^L>(0)=" + _r6(mov0[0]) + " <s^R>(0)=" + _r6(mov0[1])
                    + " → <s^L>(P)=" + _r6(mov1[0]) + " <s^R>(P)=" + _r6(mov1[1]))
            println("  entropy   : deterministic-exact (no QRNG draw — pure permutation; g5)")
            println("  scope     : EXACT, deterministic CA — NOT evidence the universe is a CA;")
            println("              CAI is a contested minority interpretation (see @D g9 + 5 obj.).")
        }
        let pass = ok_revival && ok_cons
        if pass {
            println("__SIM_UNIVERSE_CAQM__ PASS engine=onto S=" + to_string(twoS)
                    + " revival=" + to_string(period) + " norm_drift=0.000000")
            exit(0)
        }
        println("__SIM_UNIVERSE_CAQM__ FAIL engine=onto S=" + to_string(twoS)
                + " revival=" + to_string(period) + " norm_drift=0.000000")
        exit(2)
    }

    // ─── Engine-B modes ───────────────────────────────────────────────
    if engine == "sca" {

        if do_double_slit {
            _sca_alloc_2d(grid_arg, grid_arg)
            _set_slit_grid(to_float(grid_arg) / 2.0, 10.0, 3.0, 0.4, 4, 12, grid_arg / 2)
            let mut s: i64 = 0
            while s < cycles_arg { _sca_step_2d(theta_arg); s = s + 1 }
            let drift = _abs_f(_sca_norm2() - 1.0)
            let fringe = _sca_fringe_spacing(grid_arg / 2 + 12)
            if json_mode {
                println("{ \"tool\": \"ca-qm\", \"mode\": \"double-slit\", \"engine\": \"sca\",")
                println("  \"grid\": " + to_string(grid_arg) + ", \"cycles\": " + to_string(cycles_arg) + ",")
                println("  \"theta\": " + _r6(theta_arg) + ", \"norm_drift\": " + _r6(drift) + ",")
                println("  \"fringe_spacing\": " + _r6(fringe) + ",")
                println("  \"entropy_source\": \"deterministic-exact\",")
                println("  \"scope\": \"EXACT local unitary SCA — band-structured Strang-split; double-slit fringes from a deterministic CA update\" }")
            } else {
                println("ca-qm --sca --double-slit — van Berkel Schrödinger CA, 2-D double slit (arXiv:2406.08586)")
                println("  grid=" + to_string(grid_arg) + "×" + to_string(grid_arg)
                        + "  cycles=" + to_string(cycles_arg) + "  θ=" + _r6(theta_arg))
                println("  norm_drift  : " + _r6(drift) + " (unitarity)")
                println("  fringe_spacing: " + _r6(fringe) + " cells (downstream of slits)")
                println("  entropy     : deterministic-exact (no QRNG; g5)")
                println("  scope       : EXACT local unitary CA — fringes from a deterministic update;")
                println("                the SCA paper does NOT invoke 't Hooft CAI or superdeterminism.")
            }
            println("__SIM_UNIVERSE_CAQM__ PASS engine=sca S=" + to_string(grid_arg)
                    + " revival=na norm_drift=" + _r6(drift))
            exit(0)
        }

        if do_velocity {
            _sca_alloc_1d(N_arg)
            _set_gaussian_1d(to_float(N_arg) / 4.0, 5.0, 0.3)
            let com0 = _sca_com_1d()
            let mut s: i64 = 0
            while s < cycles_arg { _sca_step_1d(theta_arg); s = s + 1 }
            let com1 = _sca_com_1d()
            let v_g = (com1 - com0) / to_float(cycles_arg)
            let drift = _abs_f(_sca_norm2() - 1.0)
            if json_mode {
                println("{ \"tool\": \"ca-qm\", \"mode\": \"velocity\", \"engine\": \"sca\",")
                println("  \"N\": " + to_string(N_arg) + ", \"theta\": " + _r6(theta_arg) + ",")
                println("  \"cycles\": " + to_string(cycles_arg) + ",")
                println("  \"com_initial\": " + _r6(com0) + ", \"com_final\": " + _r6(com1) + ",")
                println("  \"group_velocity_cells_per_cycle\": " + _r6(v_g) + ",")
                println("  \"norm_drift\": " + _r6(drift) + ",")
                println("  \"entropy_source\": \"deterministic-exact\" }")
            } else {
                println("ca-qm --sca --velocity — 1-D Gaussian-packet group velocity (van Berkel 2025)")
                println("  N=" + to_string(N_arg) + "  θ=" + _r6(theta_arg)
                        + "  cycles=" + to_string(cycles_arg))
                println("  COM_0=" + _r6(com0) + "  COM_T=" + _r6(com1)
                        + "  v_g=" + _r6(v_g) + " cells/cycle")
                println("  norm_drift: " + _r6(drift) + " (unitarity)")
                println("  entropy   : deterministic-exact (g5)")
            }
            println("__SIM_UNIVERSE_CAQM__ PASS engine=sca S=" + to_string(N_arg)
                    + " revival=na norm_drift=" + _r6(drift))
            exit(0)
        }

        // default --sca run: 1-D plane-wave on a small ring, drift check
        _sca_alloc_1d(N_arg)
        _set_plane_wave_1d(1)
        let mut s: i64 = 0
        while s < cycles_arg { _sca_step_1d(theta_arg); s = s + 1 }
        let drift = _abs_f(_sca_norm2() - 1.0)
        if json_mode {
            println("{ \"tool\": \"ca-qm\", \"mode\": \"sca\", \"engine\": \"vberkel\",")
            println("  \"N\": " + to_string(N_arg) + ", \"theta\": " + _r6(theta_arg) + ",")
            println("  \"cycles\": " + to_string(cycles_arg) + ", \"norm_drift\": " + _r6(drift) + ",")
            println("  \"entropy_source\": \"deterministic-exact\" }")
        } else {
            println("ca-qm --sca — local unitary Schrödinger CA (arXiv:2406.08586, Quantum 9 1811)")
            println("  N=" + to_string(N_arg) + "  θ=" + _r6(theta_arg)
                    + "  U=U_1·U_0  (Strang, eq. 2.13)  cycles=" + to_string(cycles_arg))
            println("  norm_drift: " + _r6(drift) + " (unitarity by construction)")
            println("  entropy   : deterministic-exact (g5)")
        }
        println("__SIM_UNIVERSE_CAQM__ PASS engine=sca S=" + to_string(N_arg)
                + " revival=na norm_drift=" + _r6(drift))
        exit(0)
    }

    eprintln("ca-qm: unknown engine `" + engine + "`")
    exit(1)
}
