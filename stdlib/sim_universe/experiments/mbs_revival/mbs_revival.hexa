#!hexa strict
// mbs-revival/module/mbs_revival.hexa — exact small-N quantum information
// collapse-and-revival module (Xiang 2024 Rydberg-PXP scar dynamics).
//
// @tool(slug="mbs", desc="Exact 2^N state-vector Schrodinger evolution of the Xiang-2024 PXP-Rydberg array: spatio-temporal collapse-and-revival of quantum information from Néel-state scar dynamics — fidelity revival at Omega T_rev~4.785, ZZ-OTOC light-cone + revival, Holevo information backflow, N<=22 (full Rydberg) / N<=22 storage ceiling (strict PXP), hexa native (builtin sin/cos/sqrt, no numpy/qutip)")
// @usage(hexa run mbs-revival/module/mbs_revival.hexa [--N 12] [--omega 1.21] [--vnn 7.3] [--vnnn 0.11] [--delta 0.22] [--state z2|z2flip|zero] [--tmax 1.6] [--dt 0.01] [--pxp] [--fidelity] [--otoc] [--holevo] [--lightcone] [--json] [--selftest])  // exact 2^N, N<=22
// @exit_codes(0=PASS selftest/run ok, 1=usage error, 2=physics acceptance FAIL)
// @sentinel(__SIM_UNIVERSE_MBS__ PASS|FAIL N=<n> state=<s> mode=<m> Ftrev=<f> norm_drift=<x>)
// @origin(docs/references/REFERENCES.md — [mbs] Xiang et al., arXiv:2410.15455 (2024); theory anchor Kerschbaumer et al., PRL 2025 / arXiv:2410.18913; PXP scars Turner et al., Nat. Phys. 14, 745 (2018) / arXiv:1711.03528)
// @abstraction(pure-hexa exact 2^N complex state vector + 2nd-order Strang-Trotter exp(-iHt); no python bridge)
// @paradigm(structural — diagonal sigma^z energies precomputed (or strict-PXP gated to zero); transverse field via exact 2-level rotations (raw σ^x or blockade-projected PXP))
// @idempotence(deterministic float output, 6-digit decimal emission for byte-eq seal)
//
// Hamiltonian (Xiang 2024, OTOC_for_arxiv.tex L196), H/hbar in rad/us:
//   H = (Omega/2) Sum_i sigma^x_i  -  Delta Sum_i n_i  +  Sum_{i<j} V_{ij} n_i n_j
//   n_i = Rydberg occupation |up><up|_i = bit i of basis index ; sigma^x_i = spin flip.
//   V_{ij} = C_6 / R^6_{ij}. Experiment keeps only V_{i,i+1} (NN) and V_{i,i+2} (NNN);
//   higher-range terms are <0.5% and dropped (paper rationale: V_NN/V_NNN ~ 64 fixed
//   by 1D geometry; Omega = V_NN/6 strikes the PXP-approx balance).
//   Paper parameters (Methods, line 363): Omega/2pi = 1.21 MHz, V_NN/2pi = 7.3 MHz,
//     V_NNN/2pi = 0.11 MHz, Delta/2pi = 0.22 MHz (chosen as 2 V_NNN to cancel
//     residual NNN level shift), ratio V_NN/Omega = 6, V_NN/V_NNN ≈ 64.
//
// In the strong-blockade limit Omega << V_NN, the dynamics is approximately
// confined to the no-adjacent-Rydberg subspace and reduces to the PXP model
// (OTOC_for_arxiv.tex Eq:PXP, L113):
//   H_PXP = Sum_i P_{i-1} sigma^x_i P_{i+1} ,   P_i = 1 - n_i = |down><down|_i .
// --pxp uses this strict form (no Delta, no V_NNN, no V_NN diagonal — the blockade
// is enforced operationally rather than energetically; the dynamics stays inside
// the Fibonacci-dim subspace). The full Rydberg engine reproduces this only
// approximately at V_NN ~ 6 Omega, exactly as the paper does in hardware.
//
// Initial states (paper §OTOC dynamics, L239 + §Holevo, L298):
//   |Z2>      = |down up down up ...>          (Néel; high overlap with scar manifold)
//   |Z2flip>  = sigma^x_c |Z2>                 (central spin flipped — 1-bit encoded info)
//   |0>       = |down down down ...>           (trivial product; thermal-bath state)
// Convention: bit b_i = 1 <-> |up_i> (Rydberg). |Z2> has bit pattern 010101... (LSB=site 0).
// "Central" site c = N/2 for even N (used for the σ^x_c flip and the OTOC butterfly).
//
// Observables:
//   1. fidelity (return probability):  F(t) = |<psi_0 | psi(t)>|^2
//        scar physics ⇒ revival peaks at integer multiples of T_rev_wf ≈ 9.57/Omega
//        (Turner et al. 2018: scar oscillation period T_sigma ≈ 4.78/Omega for the
//        local <sigma^z> observable; the |Z2> wavefunction returns after TWO sigma-
//        periods, T_rev_wf = 2 T_sigma ≈ 9.57/Omega. Xiang reports local-observable
//        revival intervals 0.6-0.7 us at Omega/2pi=1.21 MHz, i.e. T_sigma ≈ 0.63 us
//        ≈ 4.78/Omega — the fidelity-return peak is at ~1.26 us ≈ 9.57/Omega.)
//   2. ZZ-OTOC (paper Eq. L232):
//        F_{c,j}(t) = Re <psi| sigma^z_c(t) sigma^z_j sigma^z_c(t) sigma^z_j |psi>
//        with W_c = sigma^z_c (butterfly), V_j = sigma^z_j (probe), realized as
//        a 5-step forward-evolve-perturb-backward sequence. We work directly with
//        the unitary U = exp(-iHt) (no time-reversal hardware trick).
//   3. Holevo information (paper Eq. L301):
//        X_j(t) = S((rho_j + rho'_j)/2) - (S(rho_j) + S(rho'_j))/2
//        with rho_j  = Tr_{!j} |psi(t)><psi(t)|         (evolved from |Z2>)
//             rho'_j = Tr_{!j} |psi'(t)><psi'(t)|       (evolved from sigma^x_c|Z2>)
//        S(rho) = -Tr rho log rho (natural log). X_j(0) = ln 2 at j=c (full
//        distinguishability of |down> vs |up>) and decays/revives with the
//        light-cone — Xiang's central headline.
//
// HONEST SCOPE (governance @D g1/g11 honest-caveat-first · lattice-as-tool):
//   This is an EXACT 2^N-state UNITARY quantum simulation of the *PXP-Rydberg
//   spin model* of Xiang et al. 2024 — NOT the lab device, NOT decoherent.
//   - UNITARY only: no atomic state loss, no laser dephasing, no Raman scatter
//     (real device T2* ~ 11 us, Methods L365). The observed experimental decay
//     of OTOC/fidelity amplitudes — which the paper itself attributes mostly
//     to coherence loss (L258, L301) — is NOT reproduced here.
//   - FINITE SIZE, not the thermodynamic limit. PXP scar revivals are slow but
//     they DO decay as N→∞ (the scarred eigenstate is approximate, not exact;
//     revivals have an asymptotic decoherence floor). Finite-N revivals are
//     NOT proof that scars survive the L→∞ limit — they strictly don't, they
//     decay slowly.
//   - genuine ceiling: full 2^N Rydberg engine reaches N≈22 comfortably (4M
//     amplitudes, ~64 MB working set); the strict --pxp path stays in the
//     blockade subspace (Fibonacci dim ~ phi^N ~ 1.618^N) and would push the
//     reach to N≈26-28 with a constrained-basis encoder — we implement it as
//     a 2^N projector here (no encoder) so its ceiling is the same N≈22.
//     The genuine wall is 2^N memory at N≳26-28 + the L→∞ scar decay —
//     stated, never faked (lattice-as-tool).
// QRNG disclosure (governance @D g5): the core evolution is fully deterministic
//   unitary propagation — NO entropy is drawn. entropy_source = "deterministic-exact".

// ─── constants / scalar helpers ───────────────────────────────────────

fn _pi() -> f64 { return 3.14159265358979323846 }
fn _two_pi() -> f64 { return 6.28318530717958647692 }
fn _abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }
fn _abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }

fn _sqrt_f(x: f64) -> f64 { if x <= 0.0 { return 0.0 } return sqrt(x) }

// natural log via mantissa-split series (mirrors fvd.hexa _ln)
fn _ln(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1.0e9 }
    let mut m = x
    let mut e: i64 = 0
    while m >= 2.0 { m = m / 2.0; e = e + 1 }
    while m < 1.0 { m = m * 2.0; e = e - 1 }
    let y = m - 1.0
    let mut s = 0.0
    let mut sign = 1.0
    let mut yk = y
    let mut k: i64 = 1
    while k <= 24 {
        s = s + sign * yk / to_float(k)
        yk = yk * y
        sign = 0.0 - sign
        k = k + 1
    }
    return s + to_float(e) * 0.69314718055994530942
}

// 6-decimal fixed emission for idempotent byte-eq output (mirrors fvd _r6)
fn _r6(x: f64) -> string {
    let scaled = x * 1000000.0
    let rounded = if scaled >= 0.0 { to_int(scaled + 0.5) } else { to_int(scaled - 0.5) }
    let int_part = rounded / 1000000
    let frac_part = rounded - int_part * 1000000
    let abs_frac = if frac_part < 0 { 0 - frac_part } else { frac_part }
    let mut frac_str = to_string(abs_frac)
    while len(frac_str) < 6 { frac_str = "0" + frac_str }
    let sign = if x < 0.0 && int_part == 0 { "-" } else { "" }
    return sign + to_string(int_part) + "." + frac_str
}

// ─── module state (mirrors fvd.hexa global-state idiom) ───────────────

let mut __N: i64 = 12            // number of qubits
let mut __D: i64 = 4096          // 2^N Hilbert dimension
let mut __p2: [i64] = []         // pow2 table, length N+1
let mut __re: [f64] = []         // state real part, length D
let mut __im: [f64] = []         // state imag part, length D
let mut __diag: [f64] = []       // precomputed diagonal energies D(b), rad/us, length D
let mut __pxp: bool = false      // strict-PXP mode (project σ^x onto blockade)
let mut __c: i64 = 6             // central qubit index = N/2

// scratch buffers for OTOC / Holevo (alloc-free hot loops)
let mut __re2: [f64] = []
let mut __im2: [f64] = []
let mut __re3: [f64] = []
let mut __im3: [f64] = []

// ─── bit helpers ──────────────────────────────────────────────────────

fn _build_pow2(n: i64) {
    __p2 = []
    let mut v: i64 = 1
    let mut k: i64 = 0
    while k <= n { __p2.push(v); v = v * 2; k = k + 1 }
}

fn _bit(b: i64, j: i64) -> i64 { return (b / __p2[j]) % 2 }

// ─── diagonal energy D(b) — full Rydberg only (PXP has D=0) ───────────
//   H_diag = - Delta * Sum n_i  +  V_NN Sum_<i,i+1> n_i n_{i+1}
//                                + V_NNN Sum_<i,i+2> n_i n_{i+2}
//   Higher-range vdW dropped: V_{i,i+3} / V_NN ~ 1/729 (negligible).

fn _diag_energy_full(b: i64, delta: f64, vnn: f64, vnnn: f64) -> f64 {
    let n = __N
    let mut e: f64 = 0.0
    let mut j: i64 = 0
    while j < n {
        if _bit(b, j) == 1 {
            e = e - delta
            if j + 1 < n && _bit(b, j + 1) == 1 { e = e + vnn }
            if j + 2 < n && _bit(b, j + 2) == 1 { e = e + vnnn }
        }
        j = j + 1
    }
    return e
}

fn _build_diag(delta: f64, vnn: f64, vnnn: f64) {
    __diag = []
    let mut b: i64 = 0
    while b < __D {
        if __pxp { __diag.push(0.0) }
        else { __diag.push(_diag_energy_full(b, delta, vnn, vnnn)) }
        b = b + 1
    }
}

// ─── state-vector ops ─────────────────────────────────────────────────

fn _zero_state() {
    __re = []
    __im = []
    let mut b: i64 = 0
    while b < __D { __re.push(0.0); __im.push(0.0); b = b + 1 }
}

fn _set_basis(idx: i64) {
    _zero_state()
    __re[idx] = 1.0
}

// |Z2> = |down up down up ...> ; bit i = 1 (Rydberg/up) iff i is odd.
fn _z2_index() -> i64 {
    let mut idx: i64 = 0
    let mut j: i64 = 1
    while j < __N { idx = idx + __p2[j]; j = j + 2 }
    return idx
}

fn _zero_index() -> i64 { return 0 }

// |Z2flip> = sigma^x_c |Z2> : flip bit at the central site c = N/2.
fn _z2flip_index() -> i64 {
    let z = _z2_index()
    let c = __c
    if _bit(z, c) == 1 { return z - __p2[c] }
    return z + __p2[c]
}

fn _prep_state(name: str) -> i64 {
    if name == "z2flip" { let i = _z2flip_index(); _set_basis(i); return i }
    if name == "zero" { _set_basis(0); return 0 }
    let i = _z2_index(); _set_basis(i); return i   // default "z2"
}

fn _norm2() -> f64 {
    let mut s: f64 = 0.0
    let mut b: i64 = 0
    while b < __D { s = s + __re[b] * __re[b] + __im[b] * __im[b]; b = b + 1 }
    return s
}

fn _renorm() {
    let nrm = _sqrt_f(_norm2())
    if nrm <= 0.0 { return }
    let inv = 1.0 / nrm
    let mut b: i64 = 0
    while b < __D { __re[b] = __re[b] * inv; __im[b] = __im[b] * inv; b = b + 1 }
}

// in-place save / load of the state into scratch slots 2 / 3.
fn _save_to_2() {
    __re2 = []; __im2 = []
    let mut b: i64 = 0
    while b < __D { __re2.push(__re[b]); __im2.push(__im[b]); b = b + 1 }
}
fn _save_to_3() {
    __re3 = []; __im3 = []
    let mut b: i64 = 0
    while b < __D { __re3.push(__re[b]); __im3.push(__im[b]); b = b + 1 }
}

// Real / imag parts of <a|b> using the (ar,ai),(br,bi) arrays.
fn _inner_re(ar: [f64], ai: [f64], br: [f64], bi: [f64]) -> f64 {
    let mut s: f64 = 0.0
    let mut b: i64 = 0
    while b < __D { s = s + ar[b] * br[b] + ai[b] * bi[b]; b = b + 1 }
    return s
}
fn _inner_im(ar: [f64], ai: [f64], br: [f64], bi: [f64]) -> f64 {
    let mut s: f64 = 0.0
    let mut b: i64 = 0
    while b < __D { s = s + ar[b] * bi[b] - ai[b] * br[b]; b = b + 1 }
    return s
}

// ─── propagators ──────────────────────────────────────────────────────

// U_diag(tau): amp_b *= exp(-i diag[b] tau)
fn _apply_diag(tau: f64) {
    if __pxp { return }   // strict PXP has no diagonal energy
    let mut b: i64 = 0
    while b < __D {
        let phi = __diag[b] * tau
        let c = cos(phi)
        let sgn = sin(phi)
        let r = __re[b]
        let m = __im[b]
        __re[b] = c * r + sgn * m
        __im[b] = c * m - sgn * r
        b = b + 1
    }
}

// U_x(dt) for full Rydberg: per site, exact 2-level σ^x rotation
//   M = [[c, -is],[-is, c]],  theta = (Omega/2) dt
// For strict PXP: skip the move if either neighbour of site j is in |up>
// (PXP projector P_{j-1} σ^x_j P_{j+1}); that keeps the dynamics exactly
// inside the blockade subspace and yields H_PXP.
fn _apply_transverse(omega: f64, dt: f64) {
    let theta = (omega / 2.0) * dt
    let c = cos(theta)
    let sgn = sin(theta)
    let mut j: i64 = 0
    while j < __N {
        let pj = __p2[j]
        let has_left  = j > 0
        let has_right = j < __N - 1
        let pl = if has_left  { __p2[j - 1] } else { 0 }
        let pr = if has_right { __p2[j + 1] } else { 0 }
        let mut b: i64 = 0
        while b < __D {
            if (b / pj) % 2 == 0 {
                let q = b + pj
                let mut ok = true
                if __pxp {
                    if has_left && ((b / pl) % 2 == 1) { ok = false }
                    if has_right && ((b / pr) % 2 == 1) { ok = false }
                }
                if ok {
                    let rp = __re[b]
                    let ip = __im[b]
                    let rq = __re[q]
                    let iq = __im[q]
                    __re[b] = c * rp + sgn * iq
                    __im[b] = c * ip - sgn * rq
                    __re[q] = sgn * ip + c * rq
                    __im[q] = (0.0 - sgn) * rp + c * iq
                }
            }
            b = b + 1
        }
        j = j + 1
    }
}

// 2nd-order Strang Trotter step exp(-iH dt) = diag(dt/2) X(dt) diag(dt/2).
fn _trotter_step(omega: f64, dt: f64) {
    _apply_diag(dt / 2.0)
    _apply_transverse(omega, dt)
    _apply_diag(dt / 2.0)
}

// Forward evolution by tdur >= 0; backward by passing dts < 0 to _trotter_step.
fn _evolve_fwd(omega: f64, tdur: f64, dt: f64) {
    if tdur <= 0.0 { return }
    let nsteps = to_int(tdur / dt + 0.5)
    let mut s: i64 = 0
    while s < nsteps { _trotter_step(omega, dt); s = s + 1 }
}
fn _evolve_bwd(omega: f64, tdur: f64, dt: f64) {
    if tdur <= 0.0 { return }
    let nsteps = to_int(tdur / dt + 0.5)
    let mut s: i64 = 0
    while s < nsteps { _trotter_step(omega, 0.0 - dt); s = s + 1 }
}

// Apply sigma^z at site j (in place):  amp_b *= +1 if bit j = 1 else -1.
// (paper convention W = sigma^z, eigenvalues ±1 on |up>/|down>.)
fn _apply_sz(j: i64) {
    let pj = __p2[j]
    let mut b: i64 = 0
    while b < __D {
        if (b / pj) % 2 == 0 {
            __re[b] = 0.0 - __re[b]
            __im[b] = 0.0 - __im[b]
        }
        b = b + 1
    }
}

// ─── observable: fidelity (return probability) ────────────────────────
//   F(t) = |<psi_0 | psi(t)>|^2  ; psi_0 is the saved initial state in slot 2.
fn _fidelity_to_2() -> f64 {
    let re = _inner_re(__re2, __im2, __re, __im)
    let im = _inner_im(__re2, __im2, __re, __im)
    return re * re + im * im
}

// ─── observable: ZZ-OTOC F_{c,j}(t) ───────────────────────────────────
//   F_{c,j}(t) = Re <psi| W^†(t) V^† W(t) V |psi> ,   W = σ^z_c, V = σ^z_j
//   Build R = W(t) V W(t) V |psi> by:
//     R := V|psi>  ;  R := W(t) R = U^† W U R = U^† W U V|psi>
//                  ;  R := V R                = V U^† W U V|psi>
//                  ;  R := W(t) R             = U^† W U V U^† W U V|psi>
//   then F = Re<psi|R>. Each W(t) := U(t)^† W U(t) uses 2 evolutions (fwd, bwd).
//   Cost per (c,j,t) ~ 4 evolutions of length t. (σ^z is Hermitian so V^†=V, W^†=W.)
fn _otoc_zz_cj(c: i64, j: i64, omega: f64, tdur: f64, dt: f64,
               init_re: [f64], init_im: [f64]) -> f64 {
    // load |psi>
    let mut b: i64 = 0
    while b < __D { __re[b] = init_re[b]; __im[b] = init_im[b]; b = b + 1 }
    // 1. R = V|psi>
    _apply_sz(j)
    // 2. R = W(t) R = U^†(t) σ^z_c U(t) R
    _evolve_fwd(omega, tdur, dt)
    _apply_sz(c)
    _evolve_bwd(omega, tdur, dt)
    // 3. R = V R
    _apply_sz(j)
    // 4. R = W(t) R
    _evolve_fwd(omega, tdur, dt)
    _apply_sz(c)
    _evolve_bwd(omega, tdur, dt)
    // 5. F = Re<psi|R>
    return _inner_re(init_re, init_im, __re, __im)
}

// One-shot ZZ-OTOC F_{c,j}(t) starting from a named initial state.
fn _otoc_zz_single(name: str, c: i64, j: i64, omega: f64, tdur: f64, dt: f64) -> f64 {
    _prep_state(name)
    let mut ir: [f64] = []
    let mut ii: [f64] = []
    let mut b: i64 = 0
    while b < __D { ir.push(__re[b]); ii.push(__im[b]); b = b + 1 }
    return _otoc_zz_cj(c, j, omega, tdur, dt, ir, ii)
}

// ─── observable: Holevo information X_j(t) ────────────────────────────
//   For a state |psi> = sum_b a_b |b>, the j-block reduced density matrix:
//     rho_{00} = sum_{bit_j(b)=0} |a_b|^2
//     rho_{11} = sum_{bit_j(b)=1} |a_b|^2
//     rho_{01} = sum_{bit_j(b)=0} a_b * conj(a_{b XOR pj})
//   (Hermitian conjugate gives rho_{10}.) 2x2 eigenvalues:
//     lambda_± = (p0+p1)/2 ± sqrt( (p0-p1)^2/4 + |rho_01|^2 )
//   so S(rho) = -lambda_+ ln lambda_+  -lambda_- ln lambda_-.
//   The averaged matrix (rho + rho') / 2 has the same closed-form 2x2 spectrum.

fn _reduced_2x2(j: i64, rr: [f64], ii: [f64]) -> [f64] {
    // returns [p0, p1, off_re, off_im]
    let pj = __p2[j]
    let mut p0: f64 = 0.0
    let mut p1: f64 = 0.0
    let mut oR: f64 = 0.0
    let mut oI: f64 = 0.0
    let mut b: i64 = 0
    while b < __D {
        let a_re = rr[b]
        let a_im = ii[b]
        let p = a_re * a_re + a_im * a_im
        if (b / pj) % 2 == 0 {
            p0 = p0 + p
            let q = b + pj
            let bre = rr[q]; let bim = ii[q]
            // off-diag = sum_{bit_j=0} a_b * conj(a_{b XOR pj})
            //   conj(a_q) = bre - i bim ; a_b = a_re + i a_im
            //   a_b * conj(a_q) = (a_re bre + a_im bim) + i (a_im bre - a_re bim)
            oR = oR + a_re * bre + a_im * bim
            oI = oI + a_im * bre - a_re * bim
        } else { p1 = p1 + p }
        b = b + 1
    }
    return [p0, p1, oR, oI]
}

fn _entropy_2x2(p0: f64, p1: f64, oR: f64, oI: f64) -> f64 {
    let dlt = (p0 - p1) / 2.0
    let off2 = oR * oR + oI * oI
    let rad = _sqrt_f(dlt * dlt + off2)
    let half = (p0 + p1) / 2.0
    let lp = half + rad
    let lm = half - rad
    let mut s: f64 = 0.0
    if lp > 1.0e-15 { s = s - lp * _ln(lp) }
    if lm > 1.0e-15 { s = s - lm * _ln(lm) }
    return s
}

fn _holevo_j(j: i64) -> f64 {
    // rho from (__re,__im), rho' from (__re3,__im3).
    let a = _reduced_2x2(j, __re, __im)
    let b = _reduced_2x2(j, __re3, __im3)
    let p0a = a[0]; let p1a = a[1]; let oRa = a[2]; let oIa = a[3]
    let p0b = b[0]; let p1b = b[1]; let oRb = b[2]; let oIb = b[3]
    let p0m = (p0a + p0b) / 2.0
    let p1m = (p1a + p1b) / 2.0
    let oRm = (oRa + oRb) / 2.0
    let oIm = (oIa + oIb) / 2.0
    let Sm = _entropy_2x2(p0m, p1m, oRm, oIm)
    let Sa = _entropy_2x2(p0a, p1a, oRa, oIa)
    let Sb = _entropy_2x2(p0b, p1b, oRb, oIb)
    return Sm - 0.5 * (Sa + Sb)
}

// Holevo X_j at t=0 closed-form: rho_c = |down><down|, rho'_c = |up><up|,
// both pure ⇒ S(rho)=S(rho')=0 and (rho+rho')/2 = I/2 ⇒ S = ln 2.
// All other sites have rho = rho' ⇒ X_j = 0.
fn _holevo_t0() -> [f64] {
    let mut out: [f64] = []
    let mut j: i64 = 0
    while j < __N {
        if j == __c { out.push(_ln(2.0)) } else { out.push(0.0) }
        j = j + 1
    }
    return out
}

// ─── high-level mode helpers ──────────────────────────────────────────

// fidelity trajectory F(t) for state `name`. samples at multiples of `sample_every`.
// emits "t <t> F <f>" lines if verbose; returns [peak_F, t_peak, T_rev_us].
fn _run_fidelity(name: str, omega: f64, tmax: f64, dt: f64,
                 sample_every: i64, verbose: bool) -> [f64] {
    _prep_state(name)
    _save_to_2()
    let nsteps = to_int(tmax / dt + 0.5)
    let mut step: i64 = 0
    let mut peak: f64 = 0.0
    let mut tpeak: f64 = 0.0
    // Wavefunction return period: 2 × the local-observable period 4.785/Omega.
    // |Z2> oscillates between |Z2> and Z2' under PXP-scar dynamics; return-prob
    // back to |Z2> peaks every T_rev_wf = 2 · 4.785/Omega ≈ 9.57/Omega.
    let trev = 9.57 / omega
    let tlo = 0.5 * trev
    let thi = 1.5 * trev
    if verbose { println("  t " + _r6(0.0) + " F " + _r6(1.0)) }
    while step < nsteps {
        _trotter_step(omega, dt)
        step = step + 1
        if step % sample_every == 0 {
            let t = to_float(step) * dt
            let f = _fidelity_to_2()
            if verbose { println("  t " + _r6(t) + " F " + _r6(f)) }
            if t >= tlo && t <= thi {
                if f > peak { peak = f; tpeak = t }
            }
        }
    }
    return [peak, tpeak, trev]
}

// ZZ-OTOC F_{c,j}(t) at fixed t over all sites j. Returns length-N array.
fn _run_otoc(name: str, omega: f64, tdur: f64, dt: f64) -> [f64] {
    _prep_state(name)
    let mut ir: [f64] = []
    let mut ii: [f64] = []
    let mut b: i64 = 0
    while b < __D { ir.push(__re[b]); ii.push(__im[b]); b = b + 1 }
    let c = __c
    let mut out: [f64] = []
    let mut j: i64 = 0
    while j < __N {
        out.push(_otoc_zz_cj(c, j, omega, tdur, dt, ir, ii))
        j = j + 1
    }
    return out
}

// Holevo information X_j(t) at fixed t over all sites j.
fn _run_holevo(omega: f64, tdur: f64, dt: f64) -> [f64] {
    if tdur <= 0.0 { return _holevo_t0() }
    // 1. evolve sigma^x_c|Z2> -> save to slot 3
    _prep_state("z2flip")
    _evolve_fwd(omega, tdur, dt)
    _save_to_3()
    // 2. evolve |Z2> -> leave in (__re,__im)
    _prep_state("z2")
    _evolve_fwd(omega, tdur, dt)
    // 3. compute X_j for j = 0..N-1
    let mut out: [f64] = []
    let mut j: i64 = 0
    while j < __N {
        out.push(_holevo_j(j))
        j = j + 1
    }
    return out
}

// ─── main ─────────────────────────────────────────────────────────────

fn main() -> void {
    let raw = args()
    let mut cli: [str] = []
    let mut ai = 2
    while ai < len(raw) { cli.push(raw[ai]); ai = ai + 1 }

    // defaults (paper Methods L363; angular freq = 2pi * MHz, time in us)
    let mut nN: i64 = 12
    let mut omega_mhz: f64 = 1.21        // Omega/2pi MHz
    let mut vnn_mhz: f64 = 7.3
    let mut vnnn_mhz: f64 = 0.11
    let mut delta_mhz: f64 = 0.22
    let mut tmax: f64 = 1.6              // ~2.5 T_rev at paper params
    let mut dt: f64 = 0.01
    let mut st: str = "z2"
    let mut do_pxp: bool = false
    let mut do_fidelity: bool = false
    let mut do_otoc: bool = false
    let mut do_holevo: bool = false
    let mut do_lightcone: bool = false
    let mut json_mode: bool = false
    let mut selftest: bool = false
    let mut tprobe: f64 = 0.0            // for --otoc / --holevo single-t

    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "lib" { i = i + 1; continue }
        else if a == "--N" { if i + 1 < len(cli) { i = i + 1; nN = to_int(cli[i]) } }
        else if a == "--omega" { if i + 1 < len(cli) { i = i + 1; omega_mhz = to_float(cli[i]) } }
        else if a == "--vnn" { if i + 1 < len(cli) { i = i + 1; vnn_mhz = to_float(cli[i]) } }
        else if a == "--vnnn" { if i + 1 < len(cli) { i = i + 1; vnnn_mhz = to_float(cli[i]) } }
        else if a == "--delta" { if i + 1 < len(cli) { i = i + 1; delta_mhz = to_float(cli[i]) } }
        else if a == "--tmax" { if i + 1 < len(cli) { i = i + 1; tmax = to_float(cli[i]) } }
        else if a == "--dt" { if i + 1 < len(cli) { i = i + 1; dt = to_float(cli[i]) } }
        else if a == "--state" { if i + 1 < len(cli) { i = i + 1; st = cli[i] } }
        else if a == "--tprobe" { if i + 1 < len(cli) { i = i + 1; tprobe = to_float(cli[i]) } }
        else if a == "--pxp" { do_pxp = true }
        else if a == "--fidelity" { do_fidelity = true }
        else if a == "--otoc" { do_otoc = true }
        else if a == "--holevo" { do_holevo = true }
        else if a == "--lightcone" { do_lightcone = true }
        else if a == "--json" { json_mode = true }
        else if a == "--selftest" { selftest = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run mbs-revival/module/mbs_revival.hexa [--N 12] [--omega 1.21]")
            println("       [--vnn 7.3] [--vnnn 0.11] [--delta 0.22] [--state z2|z2flip|zero]")
            println("       [--tmax 1.6] [--dt 0.01] [--pxp] [--fidelity] [--otoc] [--holevo]")
            println("       [--lightcone] [--tprobe 0.63] [--json] [--selftest]")
            println("modes: (default) selftest · single trajectory · --fidelity F(t) revival ·")
            println("       --otoc ZZ-OTOC F_{c,j}(t) at t=tprobe · --holevo X_j(t) at t=tprobe ·")
            println("       --lightcone Holevo X_j on a coarse (j,t) grid")
            println("note: full Rydberg engine = exact 2^N state vector, N<=22 comfortable (~64 MB).")
            println("      --pxp = strict PXP projector (no Delta, no V_NNN, no V_NN diagonal);")
            println("            blockade enforced operationally; same 2^N storage ceiling.")
            println("origin: docs/references/REFERENCES.md [mbs] Xiang et al., arXiv:2410.15455 (2024)")
            exit(0)
        }
        else { eprintln("mbs: unknown arg `" + a + "`"); exit(1) }
        i = i + 1
    }

    if nN < 4 { nN = 4 }
    // Exact 2^N state vector. N≤22 fits ~64 MB working set; Holevo/OTOC modes
    // need up to 3 state-slots simultaneously, so we clamp at N=22 for them.
    // The genuine ceiling is the 2^N memory wall N≳26-28 — stated, never faked.
    if nN > 22 { nN = 22 }
    __N = nN
    __D = 1
    let mut kk: i64 = 0
    while kk < __N { __D = __D * 2; kk = kk + 1 }
    _build_pow2(__N)
    __c = __N / 2
    __pxp = do_pxp

    let tp = _two_pi()
    let omega = omega_mhz * tp
    let vnn = vnn_mhz * tp
    let vnnn = vnnn_mhz * tp
    let delta = delta_mhz * tp
    _build_diag(delta, vnn, vnnn)

    // default invocation (no run-spec args) → compact selftest
    let no_spec = (len(cli) == 0) || (len(cli) == 1 && cli[0] == "lib")
    let any_mode = do_fidelity || do_otoc || do_holevo || do_lightcone
    if (no_spec || selftest) && !any_mode {
        // ── selftest: small N=8, strict PXP for clean revivals ─────────
        __N = 8; __D = 256; _build_pow2(8); __c = 4; __pxp = true
        _build_diag(0.0, 0.0, 0.0)
        let omega_st = omega          // keep user omega (default 1.21 * 2pi)
        let tre = 9.57 / omega_st     // wavefunction return period
        let tmax_st = 1.5 * tre       // covers first revival peak
        let dt_st = tre / 400.0       // 400 Trotter steps per revival (cheap)

        // (1) fidelity revival under strict PXP from |Z2>
        let fres = _run_fidelity("z2", omega_st, tmax_st, dt_st, 4, false)
        let f_peak = fres[0]
        let t_peak = fres[1]
        let drift = _abs_f(_norm2() - 1.0)

        // (2) <Z2|σ^x_c Z2> = 0 by construction (state-prep sanity)
        _prep_state("z2flip")
        _save_to_2()
        _prep_state("z2")
        let init_overlap = _fidelity_to_2()

        // (3) ZZ-OTOC F_{c,c}(t): F_{c,c}(0)=1 trivially; check the
        //    PXP scar refocus invariant F_{c,c}(T_rev) > F_{c,c}(T_rev/2).
        let t_use = if t_peak > 0.0 { t_peak } else { tre }
        let otoc_rev = _otoc_zz_single("z2", __c, __c, omega_st, t_use, dt_st)
        let otoc_half = _otoc_zz_single("z2", __c, __c, omega_st, t_use / 2.0, dt_st)

        // (4) Holevo: X_c(0)=ln 2 closed form; X_c dips below the revival
        //     value (information delocalized at T_rev/2, refocused at T_rev).
        let xc0 = _ln(2.0)
        let xc_dip_arr = _run_holevo(omega_st, t_use / 2.0, dt_st)
        let xc_rev_arr = _run_holevo(omega_st, t_use, dt_st)
        let xc_dip = xc_dip_arr[__c]
        let xc_rev = xc_rev_arr[__c]

        let ok_unitary = drift < 1.0e-3
        let ok_revival = f_peak > 0.5            // PXP scar refocus invariant
        let ok_orth = init_overlap < 0.1         // <Z2|σ^x_c Z2> = 0 strictly
        let ok_otoc_dip = otoc_half < otoc_rev   // OTOC dip-then-revive
        let ok_holevo_t0 = _abs_f(xc0 - _ln(2.0)) < 1.0e-9
        let ok_holevo_dip = xc_dip < xc_rev + 0.05
        let pass = ok_unitary && ok_revival && ok_orth && ok_otoc_dip
                   && ok_holevo_t0 && ok_holevo_dip

        if json_mode {
            println("{")
            println("  \"tool\": \"mbs\", \"mode\": \"selftest\",")
            println("  \"N\": 8, \"pxp\": true,")
            println("  \"entropy_source\": \"deterministic-exact\",")
            println("  \"omega_2pi_MHz\": " + _r6(omega_mhz) + ",")
            println("  \"T_rev_us\": " + _r6(tre) + ",")
            println("  \"norm_drift\": " + _r6(drift) + ",")
            println("  \"F_peak_revival\": " + _r6(f_peak) + ",")
            println("  \"t_peak_us\": " + _r6(t_peak) + ",")
            println("  \"init_overlap_z2_z2flip\": " + _r6(init_overlap) + ",")
            println("  \"OTOC_cc_at_Trev\": " + _r6(otoc_rev) + ",")
            println("  \"OTOC_cc_at_Trev_half\": " + _r6(otoc_half) + ",")
            println("  \"Holevo_c_t0\": " + _r6(xc0) + ", \"ln2\": " + _r6(_ln(2.0)) + ",")
            println("  \"Holevo_c_dip\": " + _r6(xc_dip) + ",")
            println("  \"Holevo_c_revival\": " + _r6(xc_rev) + ",")
            println("  \"scope\": \"EXACT 2^N PXP scar revival of Xiang-2024 Rydberg array — NOT decoherent, NOT lab device\",")
            println("  \"pass\": " + (if pass { "true" } else { "false" }))
            println("}")
        } else {
            println("mbs selftest — exact small-N quantum information collapse-and-revival (Xiang 2024)")
            println("  N=8 strict-PXP  Omega/2pi=" + _r6(omega_mhz) + " MHz  T_rev=" + _r6(tre) + " us")
            println("  unitarity     : norm_drift=" + _r6(drift) + " (" + (if ok_unitary { "OK" } else { "FAIL" }) + ")")
            println("  PXP revival   : F(T_rev)=" + _r6(f_peak) + " at t=" + _r6(t_peak)
                    + " us (need >0.5; " + (if ok_revival { "OK" } else { "FAIL" }) + ")")
            println("  <Z2|σ^x_c Z2> : " + _r6(init_overlap) + " (need <0.1; "
                    + (if ok_orth { "OK" } else { "FAIL" }) + ")")
            println("  OTOC dip/rev  : F_{c,c}(T_rev/2)=" + _r6(otoc_half) + " < F_{c,c}(T_rev)="
                    + _r6(otoc_rev) + " (" + (if ok_otoc_dip { "OK" } else { "FAIL" }) + ")")
            println("  Holevo X_c(0) : " + _r6(xc0) + " (== ln 2=" + _r6(_ln(2.0)) + "; "
                    + (if ok_holevo_t0 { "OK" } else { "FAIL" }) + ")")
            println("  Holevo dip/rv : X_c(T_rev/2)=" + _r6(xc_dip) + ", X_c(T_rev)=" + _r6(xc_rev)
                    + " (" + (if ok_holevo_dip { "OK" } else { "FAIL" }) + ")")
            println("  entropy       : deterministic-exact (no QRNG — unitary evolution; g5)")
            println("  scope         : EXACT 2^N PXP scar revival of Xiang-2024 Rydberg array —")
            println("                  NOT decoherent, NOT lab device. Revivals decay as N→∞ —")
            println("                  finite-N revival is NOT proof of L→∞ scar survival (g11).")
        }
        if pass {
            println("__SIM_UNIVERSE_MBS__ PASS N=8 state=selftest mode=selftest Ftrev="
                    + _r6(f_peak) + " norm_drift=" + _r6(drift))
            exit(0)
        }
        println("__SIM_UNIVERSE_MBS__ FAIL N=8 state=selftest mode=selftest Ftrev="
                + _r6(f_peak) + " norm_drift=" + _r6(drift))
        exit(2)
    }

    if do_fidelity {
        println("mbs fidelity — quantum-information revival F(t)=|<psi_0|psi(t)>|^2")
        println("  N=" + to_string(__N) + " state=" + st + " engine="
                + (if __pxp { "strict-PXP" } else { "full-Rydberg" })
                + " Omega/2pi=" + _r6(omega_mhz) + " MHz, tmax=" + _r6(tmax) + " us")
        let r = _run_fidelity(st, omega, tmax, dt, 4, true)
        let f_peak = r[0]; let t_peak = r[1]; let trev = r[2]
        let drift = _abs_f(_norm2() - 1.0)
        if json_mode {
            println("{ \"tool\": \"mbs\", \"mode\": \"fidelity\", \"N\": " + to_string(__N)
                    + ", \"state\": \"" + st + "\", \"T_rev_us\": " + _r6(trev)
                    + ", \"F_peak_revival\": " + _r6(f_peak) + ", \"t_peak_us\": " + _r6(t_peak)
                    + ", \"norm_drift\": " + _r6(drift)
                    + ", \"entropy_source\": \"deterministic-exact\" }")
        } else {
            println("  T_rev=" + _r6(trev) + " us   F_peak=" + _r6(f_peak)
                    + " at t=" + _r6(t_peak) + " us   norm_drift=" + _r6(drift))
            println("  entropy: deterministic-exact (no QRNG — unitary evolution; g5)")
        }
        println("__SIM_UNIVERSE_MBS__ PASS N=" + to_string(__N) + " state=" + st
                + " mode=fidelity Ftrev=" + _r6(f_peak) + " norm_drift=" + _r6(drift))
        exit(0)
    }

    if do_otoc {
        let t_probe = if tprobe > 0.0 { tprobe } else { 9.57 / omega }
        println("mbs otoc — ZZ-OTOC F_{c,j}(t) with butterfly W=σ^z_c, probe V=σ^z_j")
        println("  N=" + to_string(__N) + " state=" + st + " engine="
                + (if __pxp { "strict-PXP" } else { "full-Rydberg" })
                + " c=" + to_string(__c) + " t=" + _r6(t_probe) + " us")
        let vals = _run_otoc(st, omega, t_probe, dt)
        let drift = _abs_f(_norm2() - 1.0)
        if json_mode {
            print("{ \"tool\": \"mbs\", \"mode\": \"otoc\", \"N\": " + to_string(__N)
                    + ", \"state\": \"" + st + "\", \"c\": " + to_string(__c)
                    + ", \"t_us\": " + _r6(t_probe) + ", \"OTOC\": [")
            let mut j: i64 = 0
            while j < __N {
                if j > 0 { print(",") }
                print(_r6(vals[j]))
                j = j + 1
            }
            println("], \"norm_drift\": " + _r6(drift) + ", \"entropy_source\": \"deterministic-exact\" }")
        } else {
            println("  j   F_{c,j}(t)")
            let mut j: i64 = 0
            while j < __N {
                println("  " + to_string(j) + "   " + _r6(vals[j]))
                j = j + 1
            }
            println("  norm_drift=" + _r6(drift))
            println("  entropy: deterministic-exact (no QRNG; g5)")
        }
        println("__SIM_UNIVERSE_MBS__ PASS N=" + to_string(__N) + " state=" + st
                + " mode=otoc Ftrev=" + _r6(vals[__c]) + " norm_drift=" + _r6(drift))
        exit(0)
    }

    if do_holevo {
        let t_probe = if tprobe > 0.0 { tprobe } else { 9.57 / omega }
        println("mbs holevo — Holevo information X_j(t) between |Z2> and σ^x_c|Z2>")
        println("  N=" + to_string(__N) + " engine="
                + (if __pxp { "strict-PXP" } else { "full-Rydberg" })
                + " c=" + to_string(__c) + " t=" + _r6(t_probe) + " us")
        let xs = _run_holevo(omega, t_probe, dt)
        let drift = _abs_f(_norm2() - 1.0)
        if json_mode {
            print("{ \"tool\": \"mbs\", \"mode\": \"holevo\", \"N\": " + to_string(__N)
                    + ", \"c\": " + to_string(__c) + ", \"t_us\": " + _r6(t_probe)
                    + ", \"Holevo\": [")
            let mut j: i64 = 0
            while j < __N {
                if j > 0 { print(",") }
                print(_r6(xs[j]))
                j = j + 1
            }
            println("], \"norm_drift\": " + _r6(drift) + ", \"entropy_source\": \"deterministic-exact\" }")
        } else {
            println("  j   X_j(t) (nats)")
            let mut j: i64 = 0
            while j < __N {
                println("  " + to_string(j) + "   " + _r6(xs[j]))
                j = j + 1
            }
            println("  norm_drift=" + _r6(drift))
            println("  entropy: deterministic-exact (no QRNG; g5)")
        }
        println("__SIM_UNIVERSE_MBS__ PASS N=" + to_string(__N) + " state=holevo"
                + " mode=holevo Ftrev=" + _r6(xs[__c]) + " norm_drift=" + _r6(drift))
        exit(0)
    }

    if do_lightcone {
        // emit Holevo X_j on a coarse (j, t) grid → reproduces the paper's
        // Fig. 4b/c heatmap pattern (linear light cone + collapse-and-revival).
        let trev = 9.57 / omega
        let ts = [0.0, 0.25 * trev, 0.5 * trev, 0.75 * trev, 1.0 * trev,
                  1.25 * trev, 1.5 * trev, 1.75 * trev, 2.0 * trev]
        println("mbs lightcone — Holevo X_j(t) on a (j,t) grid (Xiang Fig. 4)")
        println("  N=" + to_string(__N) + " c=" + to_string(__c)
                + " T_rev=" + _r6(trev) + " us  (t in units of T_rev)")
        let mut hdr = "  t/T_rev "
        let mut hj: i64 = 0
        while hj < __N { hdr = hdr + "  j=" + to_string(hj); hj = hj + 1 }
        println(hdr)
        let mut ti: i64 = 0
        while ti < len(ts) {
            let tv = ts[ti]
            let xs = _run_holevo(omega, tv, dt)
            let mut line = "  " + _r6(tv / trev)
            let mut j2: i64 = 0
            while j2 < __N {
                line = line + "  " + _r6(xs[j2])
                j2 = j2 + 1
            }
            println(line)
            ti = ti + 1
        }
        println("  entropy: deterministic-exact (no QRNG; g5)")
        println("__SIM_UNIVERSE_MBS__ PASS N=" + to_string(__N) + " state=lightcone"
                + " mode=lightcone Ftrev=0.000000 norm_drift=0.000000")
        exit(0)
    }

    // single parametric run (verbose fidelity trajectory)
    println("mbs run — single trajectory")
    println("  N=" + to_string(__N) + " state=" + st + " engine="
            + (if __pxp { "strict-PXP" } else { "full-Rydberg" })
            + " Omega/2pi=" + _r6(omega_mhz) + " MHz")
    let r = _run_fidelity(st, omega, tmax, dt, 4, true)
    let drift = _abs_f(_norm2() - 1.0)
    println("  F_peak=" + _r6(r[0]) + " at t=" + _r6(r[1]) + " us, T_rev=" + _r6(r[2]))
    println("__SIM_UNIVERSE_MBS__ PASS N=" + to_string(__N) + " state=" + st
            + " mode=run Ftrev=" + _r6(r[0]) + " norm_drift=" + _r6(drift))
    exit(0)
}
