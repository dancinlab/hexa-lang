#!hexa strict
// fock-prethermal-dtc/module/dtc.hexa — exact small-N quantum Fock-space
// prethermalization + time-crystalline order module.
//
// @tool(slug="dtc", desc="Exact 2^N state-vector stroboscopic evolution of the Bao-2025 kicked-Ising Floquet ring: Fock-space prethermalization + discrete time-crystalline (period-doubled) order, conserved domain-wall number quantum number, N<=22, hexa native (builtin sin/cos/sqrt, no numpy/qutip)")
// @usage(hexa run fock-prethermal-dtc/module/dtc.hexa [--N 12] [--lambda1 0.1] [--lambda2 0.05] [--phi1 0.7] [--phi2 0.3] [--J 1.0] [--cycles 120] [--state 1FM|2FM|AFM|random] [--autocorr] [--hamming] [--dw] [--fft] [--sweep] [--json] [--selftest])  // exact 2^N, N<=22
// @exit_codes(0=PASS selftest/run ok, 1=usage error, 2=physics acceptance FAIL)
// @sentinel(__SIM_UNIVERSE_DTC__ PASS|FAIL N=<n> state=<s> sub_peak=<p> dw_drift=<d> norm_drift=<x>)
// @origin(docs/references/REFERENCES.md — Bao et al. arXiv:2510.24059 (2025), Fock space prethermalization and time-crystalline order on a quantum processor; main.tex L189: U_F = e^{-iJ Σ σ̃^z σ̃^z} U_p(φ₁,λ₁,φ₂) e^{-iπ/2 Σ σ^x})
// @abstraction(pure-hexa exact 2^N complex state vector + EXACT one-period Floquet unitary — single-qubit ops + diagonal-Ising bond phases in rotated frame; no Trotter error)
// @paradigm(structural — π/2 σ^x kick & U_p applied site-by-site as exact 2x2; Ising bonds diagonalized in σ^y-rotated frame, applied as diagonal phases between two global R^y(±2λ₂) rotations)
// @idempotence(deterministic float output, 6-digit decimal emission for byte-eq seal)
//
// Floquet Hamiltonian / one drive cycle T=1 (Bao 2025, main.tex L189):
//   U_F = exp(-i J Σ_j σ̃^z_j(λ₂) σ̃^z_{j+1}(λ₂))  ·  U_p(φ₁,λ₁,φ₂)  ·  exp(-i π/2 Σ_j σ^x_j)
//   U_p(φ₁,λ₁,φ₂) = ∏_j  exp(-i φ₁/2 σ^z_j) · exp(+i λ₁/2 σ^y_j) · exp(-i φ₂/2 σ^z_j)
//   σ̃^z_j(λ₂) = cos(λ₂) σ^z_j + sin(λ₂) σ^x_j   (= R^y_j(2λ₂) σ^z_j R^y_j(-2λ₂))
//   Drive period T=1, Ising coupling J=1, λ₁/λ₂ = 2 (fixed ratio in paper).
// Approximately-conserved DW number (main.tex L199):
//   W(s) = 2 Σ_j s^j (1 - s^{j+1})   (ring PBC; counts 01 transitions x 2)
// Fock-space regimes (paper Fig.~1d / Fig.~4):
//   λ₁ = 0.1  -> FSP regime  (DW well-conserved, period-doubling persists >120T)
//   λ₁ = 0.4  -> critical    (DW sector mixing)
//   λ₁ = 1.2  -> thermal     (DW immediately thermalizes to L/2, no DTC)
//
// HONEST SCOPE (governance @D g1/g12 honest-caveat-first · lattice-as-tool):
//   This is an EXACT 2^N-state UNITARY quantum simulation of the *Bao-2025
//   kicked-Ising Floquet model* — NOT decoherent, NOT the lab 72-qubit device.
//   - UNITARY only: no T1/T2, no dephasing, no readout error, no gate
//     infidelity. The lab's finite-coherence physics — which ultimately
//     bounds DTC lifetime on hardware via Floquet heating + decoherence —
//     is NOT modelled. Finite-N exact sim shows period-doubling persists
//     INDEFINITELY at λ₁=0.1, since no irreversible heating channel exists.
//   - FINITE SIZE, not the thermodynamic limit. Fock-space prethermalization
//     is a finite-time prethermal regime; at infinite N + infinite time it
//     would EVENTUALLY heat to infinite temperature (Floquet ETH).
//     This sim cannot settle DTC stability in the L->infinity limit.
//   - Reachable N is reached: N<=22 fits in ~2x70 MB working set on the
//     full 2^N state vector (no Trotter — single-qubit ops + rotated-frame
//     Ising bonds are EXACT to floating-point round-off).
//   - genuine ceiling: N>=22-24 (2^N memory wall: 2^22 ~ 4.2M complex amps
//     ~ 70 MB; 2^24 ~ 17M ~ 270 MB) + the strict L->infinity thermodynamic
//     limit. Stated, not faked (principle lattice-as-tool); reachable N is
//     not down-played either. The paper's 72-qubit device is beyond ANY
//     exact-state-vector engine — that's a real ceiling, not a guess.
// QRNG disclosure (governance @D g5): the core Floquet evolution is fully
//   deterministic unitary propagation — NO entropy is drawn. The "random"
//   initial-state pattern uses a fixed-seed deterministic LCG, NOT the ANU
//   QRNG. entropy_source = "deterministic-exact".

// ─── constants / scalar helpers ───

fn _pi() -> f64 { return 3.14159265358979323846 }
fn _two_pi() -> f64 { return 6.28318530717958647692 }
fn _abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }
fn _abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }

fn _sqrt_f(x: f64) -> f64 { if x <= 0.0 { return 0.0 } return sqrt(x) }

// natural log via mantissa-split series (mirrors fvd.hexa _ln)
fn _ln(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1.0e9 }
    let mut m = x
    let mut e: i64 = 0
    while m >= 2.0 { m = m / 2.0; e = e + 1 }
    while m < 1.0 { m = m * 2.0; e = e - 1 }
    let y = m - 1.0
    let mut s = 0.0
    let mut sign = 1.0
    let mut yk = y
    let mut k: i64 = 1
    while k <= 24 {
        s = s + sign * yk / to_float(k)
        yk = yk * y
        sign = 0.0 - sign
        k = k + 1
    }
    return s + to_float(e) * 0.69314718055994530942
}

// 6-decimal fixed emission for idempotent byte-eq output (mirrors fvd _r6)
fn _r6(x: f64) -> string {
    let scaled = x * 1000000.0
    let rounded = if scaled >= 0.0 { to_int(scaled + 0.5) } else { to_int(scaled - 0.5) }
    let int_part = rounded / 1000000
    let frac_part = rounded - int_part * 1000000
    let abs_frac = if frac_part < 0 { 0 - frac_part } else { frac_part }
    let mut frac_str = to_string(abs_frac)
    while len(frac_str) < 6 { frac_str = "0" + frac_str }
    let sign = if x < 0.0 && int_part == 0 { "-" } else { "" }
    return sign + to_string(int_part) + "." + frac_str
}

// ─── module state (mirrors fvd.hexa / stark_frag.hexa global-state idiom) ───

let mut __N: i64 = 12           // number of qubits (ring)
let mut __D: i64 = 4096         // 2^N Hilbert dimension
let mut __p2: [i64] = []        // pow2 table, length N+1
let mut __re: [f64] = []        // state vector real part, length D
let mut __im: [f64] = []        // state vector imag part, length D
// snapshot of initial state for stroboscopic autocorrelator <σ^z_j(0)>:
let mut __s0: [f64] = []        // per-site +1/-1 sign of |ψ₀⟩ (product state)
let mut __init_b: i64 = 0       // basis index of |ψ₀⟩
let mut __dw0: f64 = 0.0        // DW number of |ψ₀⟩ (= W(s₀), exact)
// per-basis cached DW number table (built once per N, used for <w>(t)):
let mut __dw_tab: [f64] = []    // length D, __dw_tab[b] = W(b)
let mut __hd_tab: [i64] = []    // length D, Hamming distance D(b, s₀)

// ─── bit / lattice helpers ───

fn _build_pow2(n: i64) {
    __p2 = []
    let mut v: i64 = 1
    let mut k: i64 = 0
    while k <= n { __p2.push(v); v = v * 2; k = k + 1 }
}

fn _bit(b: i64, j: i64) -> i64 { return (b / __p2[j]) % 2 }

// Domain-wall number of basis state b (ring PBC, paper main.tex L199):
//   W(s) = 2 Σ_j s^j (1 - s^{j+1})  with s^{L+1} = s^1.
//   Equivalently 2 x (number of "10" adjacencies on the ring) — same as the
//   total number of domain walls (parity-doubled). For an AFM Néel pattern
//   on even L: W = L (every bond is a DW). For an FM pattern: W = 0.
fn _dw_number(b: i64) -> f64 {
    let mut w: i64 = 0
    let mut j: i64 = 0
    while j < __N {
        let s_j = _bit(b, j)
        let s_jp = _bit(b, (j + 1) % __N)
        if s_j == 1 && s_jp == 0 { w = w + 1 }
        j = j + 1
    }
    return to_float(2 * w)
}

// Hamming distance D(b, s₀) — Bao Eq. (1) for radial wave packet Π(d, nT).
fn _hamming_to_init(b: i64) -> i64 {
    let mut d: i64 = 0
    let mut j: i64 = 0
    while j < __N {
        if _bit(b, j) != _bit(__init_b, j) { d = d + 1 }
        j = j + 1
    }
    return d
}

fn _build_dw_table() {
    __dw_tab = []
    let mut b: i64 = 0
    while b < __D {
        __dw_tab.push(_dw_number(b))
        b = b + 1
    }
}

fn _build_hd_table() {
    __hd_tab = []
    let mut b: i64 = 0
    while b < __D {
        __hd_tab.push(_hamming_to_init(b))
        b = b + 1
    }
}

// ─── state-vector ops ───

fn _zero_state() {
    __re = []
    __im = []
    let mut b: i64 = 0
    while b < __D { __re.push(0.0); __im.push(0.0); b = b + 1 }
}

fn _set_basis(idx: i64) {
    _zero_state()
    __re[idx] = 1.0
}

fn _norm2() -> f64 {
    let mut s: f64 = 0.0
    let mut b: i64 = 0
    while b < __D { s = s + __re[b] * __re[b] + __im[b] * __im[b]; b = b + 1 }
    return s
}

fn _renorm() {
    let nrm = _sqrt_f(_norm2())
    if nrm <= 0.0 { return }
    let inv = 1.0 / nrm
    let mut b: i64 = 0
    while b < __D { __re[b] = __re[b] * inv; __im[b] = __im[b] * inv; b = b + 1 }
}

// ─── single-qubit unitary primitives ─────────────────────────────────────
// Each primitive applies a 2x2 unitary to qubit j EXACTLY — no Trotter.
// Hot-loop pattern: stride __p2[j] over the bit-j=0 basis states, paired
// with their bit-j=1 partner. All single-qubit ops on different sites
// commute; ordering within U_p / kick is exact per the paper definition.

// exp(-i θ/2 σ^x_j):  c = cos(θ/2), s = sin(θ/2)
//   M = [[c, -i s],[-i s, c]]
//   amp_0' =  c amp_0 - i s amp_1
//   amp_1' = -i s amp_0 + c amp_1
fn _apply_rx_j(j: i64, theta: f64) {
    let half = theta * 0.5
    let c = cos(half)
    let sg = sin(half)
    let pj = __p2[j]
    let mut b: i64 = 0
    while b < __D {
        if (b / pj) % 2 == 0 {
            let q = b + pj
            let r0 = __re[b]
            let i0 = __im[b]
            let r1 = __re[q]
            let i1 = __im[q]
            // amp_0' = c amp_0 - i s amp_1
            __re[b] = c * r0 + sg * i1
            __im[b] = c * i0 - sg * r1
            // amp_1' = -i s amp_0 + c amp_1
            __re[q] = c * r1 + sg * i0
            __im[q] = c * i1 - sg * r0
        }
        b = b + 1
    }
}

// exp(-i θ/2 σ^y_j):  c = cos(θ/2), s = sin(θ/2)
//   M = [[c, -s],[s, c]]   (real, no i)
//   amp_0' = c amp_0 - s amp_1
//   amp_1' = s amp_0 + c amp_1
fn _apply_ry_j(j: i64, theta: f64) {
    let half = theta * 0.5
    let c = cos(half)
    let sg = sin(half)
    let pj = __p2[j]
    let mut b: i64 = 0
    while b < __D {
        if (b / pj) % 2 == 0 {
            let q = b + pj
            let r0 = __re[b]
            let i0 = __im[b]
            let r1 = __re[q]
            let i1 = __im[q]
            __re[b] = c * r0 - sg * r1
            __im[b] = c * i0 - sg * i1
            __re[q] = sg * r0 + c * r1
            __im[q] = sg * i0 + c * i1
        }
        b = b + 1
    }
}

// exp(-i θ/2 σ^z_j): diagonal in computational basis.
//   bit_j = 0 -> phase exp(-i θ/2);  bit_j = 1 -> phase exp(+i θ/2)
fn _apply_rz_j(j: i64, theta: f64) {
    let half = theta * 0.5
    let c0 = cos(half)             // e^{-i θ/2} = c - i s
    let s0 = sin(half)
    let pj = __p2[j]
    let mut b: i64 = 0
    while b < __D {
        let bit = (b / pj) % 2
        let r = __re[b]
        let im = __im[b]
        if bit == 0 {
            // multiply by (c0 - i s0)
            __re[b] = c0 * r + s0 * im
            __im[b] = c0 * im - s0 * r
        } else {
            // multiply by (c0 + i s0)
            __re[b] = c0 * r - s0 * im
            __im[b] = c0 * im + s0 * r
        }
        b = b + 1
    }
}

// All-site global single-qubit ops — each is exact, all sites commute.
fn _apply_global_rx(theta: f64) {
    let mut j: i64 = 0
    while j < __N { _apply_rx_j(j, theta); j = j + 1 }
}
fn _apply_global_ry(theta: f64) {
    let mut j: i64 = 0
    while j < __N { _apply_ry_j(j, theta); j = j + 1 }
}
fn _apply_global_rz(theta: f64) {
    let mut j: i64 = 0
    while j < __N { _apply_rz_j(j, theta); j = j + 1 }
}

// ─── Ising bond phases on the ring ──────────────────────────────────────
// exp(-i J σ^z_j σ^z_{j+1}) is DIAGONAL in the computational basis.
// Eigenvalue on basis state b:
//   σ^z_j σ^z_{j+1} = (1 - 2 s_j)(1 - 2 s_{j+1}) = +1 if parallel, -1 anti.
// Apply as a phase: amp *= exp(-i J z_j z_{j+1}).
// All bond terms COMMUTE (each σ^z is diagonal & they all share a common
// eigenbasis), so the product over bonds is EXACT — no Trotter error.
// One scan over the D basis states sums the bond eigenvalues at each b.
fn _apply_ising_diag(jc: f64) {
    let mut b: i64 = 0
    while b < __D {
        let mut sum_zz: i64 = 0
        let mut k: i64 = 0
        while k < __N {
            let s_k = 2 * _bit(b, k) - 1            // ±1
            let s_kp = 2 * _bit(b, (k + 1) % __N) - 1
            sum_zz = sum_zz + s_k * s_kp
            k = k + 1
        }
        let phi = jc * to_float(sum_zz)
        let c = cos(phi)
        let s = sin(phi)
        let r = __re[b]
        let im = __im[b]
        // multiply by exp(-i phi) = c - i s
        __re[b] = c * r + s * im
        __im[b] = c * im - s * r
        b = b + 1
    }
}

// exp(-i J Σ_j σ̃^z_j σ̃^z_{j+1}) with σ̃^z_j(λ₂) = R^y_j(2λ₂) σ^z_j R^y_j(-2λ₂):
//   = [⊗_j R^y_j(2λ₂)] · exp(-i J Σ_j σ^z_j σ^z_{j+1}) · [⊗_j R^y_j(-2λ₂)]
// All R^y_j(·) on different sites commute and commute with the global
// rotation as one block. The middle factor is diagonal: _apply_ising_diag.
// EXACT — no Trotter; same accuracy as the single-qubit primitives.
fn _apply_ising_perturbed(jc: f64, lam2: f64) {
    // basis rotation: σ̃^z = R^y(2λ₂) σ^z R^y(-2λ₂)
    //   apply R^y(-2λ₂) first (right factor), then diagonal, then R^y(2λ₂).
    _apply_global_ry(0.0 - 2.0 * lam2)
    _apply_ising_diag(jc)
    _apply_global_ry(2.0 * lam2)
}

// ─── U_p(φ₁,λ₁,φ₂) — single-qubit perturbed kicker ──────────────────────
// U_p = ∏_j exp(-i φ₁/2 σ^z_j) exp(+i λ₁/2 σ^y_j) exp(-i φ₂/2 σ^z_j)
// Note paper sign convention: σ^y has POSITIVE i in main.tex L193 ("e^{+i λ₁/2 σ^y}"),
// so the angle for _apply_ry_j (which uses exp(-i θ/2 σ^y)) is -λ₁.
fn _apply_Up(phi1: f64, lam1: f64, phi2: f64) {
    // applied right-to-left: φ₂ Rz first, then +λ₁ Ry, then φ₁ Rz.
    _apply_global_rz(phi2)
    _apply_global_ry(0.0 - lam1)
    _apply_global_rz(phi1)
}

// ─── one Floquet step U_F |ψ⟩  ──────────────────────────────────────────
// U_F = U_Ising(J, λ₂) · U_p(φ₁, λ₁, φ₂) · U_kick(π/2)
// Apply right-to-left: kick first, then U_p, then U_Ising.
fn _floquet_step(jc: f64, phi1: f64, lam1: f64, phi2: f64, lam2: f64) {
    _apply_global_rx(_pi())                   // exp(-i π/2 Σ σ^x) ; theta = π
    _apply_Up(phi1, lam1, phi2)
    _apply_ising_perturbed(jc, lam2)
}

// ─── initial-state prep (paper Fig. 2e patterns) ────────────────────────
// AFM Néel pattern: s_j = j mod 2  ->  W = L (every bond is a DW).
// "1FM" pattern: AFM with ONE qubit flipped in the bulk -> creates one
//   3-qubit mini-FM region. W = L - 4 (two DWs destroyed by the flip).
// "2FM": two flipped qubits, well separated -> W = L - 8.
// "random": deterministic-LCG-sampled pattern (no QRNG), kept reproducible.
fn _build_state_AFM() -> i64 {
    let mut idx: i64 = 0
    let mut j: i64 = 0
    while j < __N {
        if j % 2 == 1 { idx = idx + __p2[j] }
        j = j + 1
    }
    return idx
}

fn _build_state_1FM() -> i64 {
    // AFM with the center qubit (rung __N/2) flipped to match its neighbour.
    let afm = _build_state_AFM()
    let center: i64 = __N / 2
    // toggle bit center
    let bit_c = _bit(afm, center)
    let mut idx = afm
    if bit_c == 1 { idx = idx - __p2[center] } else { idx = idx + __p2[center] }
    return idx
}

fn _build_state_2FM() -> i64 {
    // AFM with TWO well-separated qubits flipped: positions L/4 and 3L/4.
    let afm = _build_state_AFM()
    let p1: i64 = __N / 4
    let p2: i64 = (3 * __N) / 4
    let mut idx = afm
    if _bit(idx, p1) == 1 { idx = idx - __p2[p1] } else { idx = idx + __p2[p1] }
    if _bit(idx, p2) == 1 { idx = idx - __p2[p2] } else { idx = idx + __p2[p2] }
    return idx
}

// fixed-seed LCG (Numerical Recipes constants) — deterministic, NOT QRNG.
fn _build_state_random() -> i64 {
    let mut seed: i64 = 1664525    // fixed deterministic seed
    let mut idx: i64 = 0
    let mut j: i64 = 0
    while j < __N {
        seed = seed * 1103515245 + 12345
        // mask to 31 bits to avoid sign issues in modulo
        let positive = if seed < 0 { 0 - seed } else { seed }
        let bit = positive % 2
        if bit == 1 { idx = idx + __p2[j] }
        j = j + 1
    }
    return idx
}

fn _prepare_state(name: str) -> i64 {
    if name == "AFM" { return _build_state_AFM() }
    if name == "1FM" { return _build_state_1FM() }
    if name == "2FM" { return _build_state_2FM() }
    if name == "random" { return _build_state_random() }
    return _build_state_1FM()
}

fn _set_initial(name: str) {
    let idx = _prepare_state(name)
    __init_b = idx
    _set_basis(idx)
    __s0 = []
    let mut j: i64 = 0
    while j < __N {
        if _bit(idx, j) == 1 { __s0.push(1.0) } else { __s0.push(0.0 - 1.0) }
        j = j + 1
    }
    __dw0 = _dw_number(idx)
}

// ─── observables ─────────────────────────────────────────────────────────

// <σ^z_j>(t) for ALL sites in ONE sweep (O(D·N) once, vs N calls of O(D·N)).
// Writes __sz_cache[j]; caller reads.
let mut __sz_cache: [f64] = []
fn _compute_sz_all() {
    __sz_cache = []
    let mut s: i64 = 0
    while s < __N { __sz_cache.push(0.0); s = s + 1 }
    let mut b: i64 = 0
    while b < __D {
        let p = __re[b] * __re[b] + __im[b] * __im[b]
        if p > 1.0e-18 {
            let mut site: i64 = 0
            while site < __N {
                let sz = to_float(2 * ((b / __p2[site]) % 2) - 1)
                __sz_cache[site] = __sz_cache[site] + p * sz
                site = site + 1
            }
        }
        b = b + 1
    }
}

// Stroboscopic autocorrelator: A(nT) = (1/N) Σ_j s0_j · <σ^z_j>(nT)
// At t=0 this equals 1 (product state). For a perfect DTC: A(nT) ≈ +/-1
// alternating with n (period-doubling). Fourier-transformed over n it
// peaks at ω = π/T = π (subharmonic of the drive frequency 2π/T).
fn _autocorr() -> f64 {
    _compute_sz_all()
    let mut s: f64 = 0.0
    let mut j: i64 = 0
    while j < __N {
        s = s + __s0[j] * __sz_cache[j]
        j = j + 1
    }
    return s / to_float(__N)
}

// Mean Hamming distance <x>(nT) = Σ_d d · Π(d, nT)
//   = Σ_b |amp_b|^2 · D(b, s₀)
// (Bao main.tex L223 / L232; equivalently Σ_j ⟨1 - σ^z_j s0_j⟩/2 =
//   ½ (N - Σ_j s0_j ⟨σ^z_j⟩) = ½ N (1 - A(t)).)
fn _hamming_mean() -> f64 {
    let mut s: f64 = 0.0
    let mut b: i64 = 0
    while b < __D {
        let p = __re[b] * __re[b] + __im[b] * __im[b]
        if p > 1.0e-18 { s = s + p * to_float(__hd_tab[b]) }
        b = b + 1
    }
    return s
}

// <w>(nT) — expectation of DW number, exact via __dw_tab.
fn _dw_mean() -> f64 {
    let mut s: f64 = 0.0
    let mut b: i64 = 0
    while b < __D {
        let p = __re[b] * __re[b] + __im[b] * __im[b]
        if p > 1.0e-18 { s = s + p * __dw_tab[b] }
        b = b + 1
    }
    return s
}

// ─── subharmonic-peak diagnostic (Bao Fig. 2c, Fig. 4c) ────────────────
// Period-doubling shows up as a single sharp peak of the stroboscopic
// autocorrelator A(nT) at ω = π/T = π in its DFT over n=0..M-1.
//   F(ω) = (1/M) Σ_n A(nT) exp(-i ω n T)
// We compute |F(π)| (subharmonic) and max_{ω≠π} |F(ω)| (background) and
// return the ratio as a clean PASS/FAIL gate.
fn _fft_subharmonic_ratio(a: [f64]) -> f64 {
    let m = len(a)
    if m < 4 { return 0.0 }
    // F(π) = (1/M) Σ_n a_n (-1)^n   (cos(π n) = (-1)^n, sin = 0).
    let mut fsub: f64 = 0.0
    let mut n: i64 = 0
    while n < m {
        let sign = if n % 2 == 0 { 1.0 } else { 0.0 - 1.0 }
        fsub = fsub + sign * a[n]
        n = n + 1
    }
    let fpi = _abs_f(fsub / to_float(m))
    // background: max |F(ω_k)| over ω_k = 2π k / M, k = 1..M/2-1, excluding M/2 (= π).
    let mut bg: f64 = 0.0
    let halfm: i64 = m / 2
    let mut k: i64 = 1
    while k < halfm {
        let w = _two_pi() * to_float(k) / to_float(m)
        let mut re_sum: f64 = 0.0
        let mut im_sum: f64 = 0.0
        n = 0
        while n < m {
            let phi = w * to_float(n)
            re_sum = re_sum + a[n] * cos(phi)
            im_sum = im_sum - a[n] * sin(phi)
            n = n + 1
        }
        let mag = _sqrt_f(re_sum * re_sum + im_sum * im_sum) / to_float(m)
        if mag > bg { bg = mag }
        k = k + 1
    }
    if bg < 1.0e-12 { return fpi / 1.0e-12 }
    return fpi / bg
}

// ─── one trajectory: prepare, evolve `cycles` Floquet steps, sample
//   stroboscopically. Returns the autocorrelator series a[0..cycles].
fn _run_trajectory(state_name: str, jc: f64, phi1: f64, lam1: f64,
                   phi2: f64, lam2: f64, cycles: i64, verbose: bool) -> [f64] {
    _set_initial(state_name)
    _build_dw_table()
    _build_hd_table()
    let mut a: [f64] = []
    a.push(_autocorr())
    if verbose {
        println("  n 0 A " + _r6(a[0]) + " w " + _r6(_dw_mean()) + " x " + _r6(_hamming_mean()))
    }
    let mut n: i64 = 1
    while n <= cycles {
        _floquet_step(jc, phi1, lam1, phi2, lam2)
        let av = _autocorr()
        a.push(av)
        if verbose {
            println("  n " + to_string(n) + " A " + _r6(av) + " w " + _r6(_dw_mean()) + " x " + _r6(_hamming_mean()))
        }
        n = n + 1
    }
    return a
}

// ─── main ───

fn main() -> void {
    let raw = args()
    let mut cli: [str] = []
    let mut ai = 2
    while ai < len(raw) { cli.push(raw[ai]); ai = ai + 1 }

    // defaults (paper FSP regime: λ₁ = 0.1, λ₂ = 0.05; J = 1; T = 1).
    let mut nN: i64 = 12
    let mut lam1: f64 = 0.1
    let mut lam2: f64 = 0.05
    // longitudinal-field samples φ₁, φ₂ : the paper averages over 10 random
    // pairs in (0, 2π). We use a FIXED deterministic pair so output is
    // byte-stable; --sweep-phi (not exposed) could rotate them later.
    let mut phi1: f64 = 0.7
    let mut phi2: f64 = 0.3
    let mut jc: f64 = 1.0
    let mut cycles: i64 = 120
    let mut state_name: str = "1FM"
    let mut do_auto: bool = false
    let mut do_hamming: bool = false
    let mut do_dw: bool = false
    let mut do_fft: bool = false
    let mut do_sweep: bool = false
    let mut json_mode: bool = false
    let mut selftest: bool = false

    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "lib" { i = i + 1; continue }
        else if a == "--N" { if i + 1 < len(cli) { i = i + 1; nN = to_int(cli[i]) } }
        else if a == "--lambda1" { if i + 1 < len(cli) { i = i + 1; lam1 = to_float(cli[i]) } }
        else if a == "--lambda2" { if i + 1 < len(cli) { i = i + 1; lam2 = to_float(cli[i]) } }
        else if a == "--phi1" { if i + 1 < len(cli) { i = i + 1; phi1 = to_float(cli[i]) } }
        else if a == "--phi2" { if i + 1 < len(cli) { i = i + 1; phi2 = to_float(cli[i]) } }
        else if a == "--J" { if i + 1 < len(cli) { i = i + 1; jc = to_float(cli[i]) } }
        else if a == "--cycles" { if i + 1 < len(cli) { i = i + 1; cycles = to_int(cli[i]) } }
        else if a == "--state" { if i + 1 < len(cli) { i = i + 1; state_name = cli[i] } }
        else if a == "--autocorr" { do_auto = true }
        else if a == "--hamming" { do_hamming = true }
        else if a == "--dw" { do_dw = true }
        else if a == "--fft" { do_fft = true }
        else if a == "--sweep" { do_sweep = true }
        else if a == "--json" { json_mode = true }
        else if a == "--selftest" { selftest = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run fock-prethermal-dtc/module/dtc.hexa [--N 12] [--lambda1 0.1]")
            println("       [--lambda2 0.05] [--phi1 0.7] [--phi2 0.3] [--J 1.0] [--cycles 120]")
            println("       [--state 1FM|2FM|AFM|random]")
            println("       [--autocorr] [--hamming] [--dw] [--fft] [--sweep] [--json] [--selftest]")
            println("modes: (default) selftest · --autocorr A(nT) trajectory · --hamming <x>(nT) ·")
            println("       --dw <w>(nT) (approximate-DW-conservation witness) ·")
            println("       --fft subharmonic-peak diagnostic at ω=π/T ·")
            println("       --sweep DTC subharmonic ratio across λ₁ regimes (FSP/critical/thermal)")
            println("note: EXACT 2^N state vector, N≤22 (compiled); no Trotter — single-qubit ops +")
            println("      diagonal Ising bonds in σ^y-rotated frame are EXACT to machine precision.")
            println("origin: docs/references/REFERENCES.md — Bao et al. arXiv:2510.24059 (2025)")
            exit(0)
        }
        else { eprintln("dtc: unknown arg `" + a + "`"); exit(1) }
        i = i + 1
    }

    if nN < 4 { nN = 4 }
    // Exact 2^N state vector. 2^22 ≈ 4.2 M amplitudes (~70 MB; __re+__im
    // f64). 2^24 ≈ 17 M (~270 MB) is heroic; we clamp default ceiling at 22
    // for safety. Paper's 72-qubit device is beyond ANY exact-state-vector
    // engine — that's a real ceiling, not a guess (governance @D g12).
    if nN > 22 { nN = 22 }
    // ring DW number is even — force N even for clean AFM patterns.
    if nN % 2 == 1 { nN = nN + 1 }
    __N = nN
    __D = 1
    let mut kk: i64 = 0
    while kk < __N { __D = __D * 2; kk = kk + 1 }
    _build_pow2(__N)

    // default invocation -> compact selftest (mirror fvd/stark pattern).
    let no_spec = (len(cli) == 0) || (len(cli) == 1 && cli[0] == "lib")
    if no_spec || selftest {
        // Small fast config: N=8 (D=256), 40 Floquet cycles, FSP λ₁=0.1.
        // Verify (a) unitarity (norm_drift ≈ 0), (b) DW conservation
        // (|<w>(40) − <w>(0)| small at λ₁=0.1), (c) period-doubling: A(nT)
        // flips sign each cycle in FSP -> FFT subharmonic peak at ω=π
        // dominant over background by ≥ 5x.
        __N = 8; __D = 256; _build_pow2(8)
        let a_fsp = _run_trajectory("1FM", jc, phi1, 0.1, phi2, 0.05, 40, false)
        let drift = _abs_f(_norm2() - 1.0)
        let w_end_fsp = _dw_mean()
        let dw_drift_fsp = _abs_f(w_end_fsp - __dw0)
        let sub_ratio_fsp = _fft_subharmonic_ratio(a_fsp)

        // Critical / thermal counter-check: at λ₁=1.2 the autocorrelator
        // should rapidly decay so the subharmonic peak is far weaker than
        // in the FSP regime. (Same N, same φ₁/φ₂ for byte-stability.)
        let a_th = _run_trajectory("1FM", jc, phi1, 1.2, phi2, 0.6, 40, false)
        let sub_ratio_th = _fft_subharmonic_ratio(a_th)

        let ok_unitary = drift < 1.0e-3
        let ok_dw = dw_drift_fsp < 2.0           // |w_end - w_0| < 2 DWs at λ₁=0.1
        let ok_dtc = sub_ratio_fsp >= 5.0        // FSP -> clear period-doubling
        let ok_thermal = sub_ratio_fsp > sub_ratio_th  // ordering: FSP > thermal
        let pass = ok_unitary && ok_dw && ok_dtc && ok_thermal

        if json_mode {
            println("{")
            println("  \"tool\": \"dtc\", \"mode\": \"selftest\",")
            println("  \"N\": 8, \"cycles\": 40, \"state\": \"1FM\",")
            println("  \"entropy_source\": \"deterministic-exact\",")
            println("  \"norm_drift\": " + _r6(drift) + ",")
            println("  \"dw_initial\": " + _r6(__dw0) + ", \"dw_end_fsp\": " + _r6(w_end_fsp) + ",")
            println("  \"dw_drift_fsp\": " + _r6(dw_drift_fsp) + ",")
            println("  \"sub_ratio_fsp\": " + _r6(sub_ratio_fsp) + ",")
            println("  \"sub_ratio_thermal\": " + _r6(sub_ratio_th) + ",")
            println("  \"scope\": \"EXACT 2^N state-vector UNITARY sim of Bao-2025 kicked-Ising Floquet model — NOT the 72q device, NOT decoherent, finite N\",")
            println("  \"pass\": " + (if pass { "true" } else { "false" }))
            println("}")
        } else {
            println("dtc selftest — exact small-N Fock-space prethermal DTC (Bao 2025, kicked-Ising Floquet)")
            println("  N=8  cycles=40  state=1FM  J=" + _r6(jc) + "  λ₁(FSP)=0.1  λ₂=0.05  λ₁(thermal)=1.2  λ₂=0.6")
            println("  unitarity   : norm_drift=" + _r6(drift) + " (" + (if ok_unitary { "OK" } else { "FAIL" }) + ")")
            println("  DW conserve : w(0)=" + _r6(__dw0) + " w(40T)=" + _r6(w_end_fsp)
                    + " |Δw|=" + _r6(dw_drift_fsp) + " (" + (if ok_dw { "OK — DW well-conserved at λ₁=0.1" } else { "FAIL" }) + ")")
            println("  DTC peak    : FFT subharmonic ratio @ ω=π/T = " + _r6(sub_ratio_fsp)
                    + " (" + (if ok_dtc { "OK — period-doubling present" } else { "FAIL" }) + ")")
            println("  regime ord  : FSP(λ₁=0.1)=" + _r6(sub_ratio_fsp) + " > thermal(λ₁=1.2)=" + _r6(sub_ratio_th)
                    + " (" + (if ok_thermal { "OK — FSP-induced DTC, thermal washes out" } else { "FAIL" }) + ")")
            println("  entropy     : deterministic-exact (no QRNG draw — unitary evolution; g5)")
            println("  scope       : EXACT 2^N state-vector UNITARY sim of the Bao-2025 kicked-Ising")
            println("                Floquet model. NOT the 72-qubit lab device, NOT decoherent;")
            println("                finite N. Period-doubling persists indefinitely here because no")
            println("                irreversible heating channel exists — see @D g12.")
        }
        if pass {
            println("__SIM_UNIVERSE_DTC__ PASS N=8 state=1FM sub_peak=" + _r6(sub_ratio_fsp)
                    + " dw_drift=" + _r6(dw_drift_fsp) + " norm_drift=" + _r6(drift))
            exit(0)
        }
        println("__SIM_UNIVERSE_DTC__ FAIL N=8 state=1FM sub_peak=" + _r6(sub_ratio_fsp)
                + " dw_drift=" + _r6(dw_drift_fsp) + " norm_drift=" + _r6(drift))
        exit(2)
    }

    if do_sweep {
        // λ₁ sweep across FSP/critical/thermal — paper Fig. 2c / Fig. 4c.
        // Emits subharmonic ratio at ω=π and DW drift |w(end)-w(0)| for each
        // λ₁ ∈ {0.1, 0.2, 0.3, 0.4, 0.6, 0.9, 1.2}. λ₂ = λ₁/2 always.
        println("dtc sweep — subharmonic peak (ω=π) + DW drift across λ₁ regimes (Bao Fig. 2c / 4c)")
        println("  N=" + to_string(__N) + " cycles=" + to_string(cycles) + " state=" + state_name + " J=" + _r6(jc))
        println("  λ₁     λ₂      sub_ratio    dw_drift   regime")
        let lams = [0.1, 0.2, 0.3, 0.4, 0.6, 0.9, 1.2]
        let mut idx = 0
        while idx < len(lams) {
            let l1 = lams[idx]
            let l2 = l1 * 0.5
            let a = _run_trajectory(state_name, jc, phi1, l1, phi2, l2, cycles, false)
            let sr = _fft_subharmonic_ratio(a)
            let w_end = _dw_mean()
            let dwd = _abs_f(w_end - __dw0)
            let reg = if l1 <= 0.2 { "FSP" } else { if l1 >= 0.9 { "thermal" } else { "critical" } }
            println("  " + _r6(l1) + "  " + _r6(l2) + "  " + _r6(sr) + "   " + _r6(dwd) + "    " + reg)
            idx = idx + 1
        }
        println("  entropy: deterministic-exact (no QRNG draw; g5)")
        println("__SIM_UNIVERSE_DTC__ PASS N=" + to_string(__N) + " state=" + state_name + " sub_peak=sweep dw_drift=sweep norm_drift=0.000000")
        exit(0)
    }

    // single parametric run
    println("dtc run — exact Floquet trajectory (Bao 2025 kicked-Ising)")
    println("  N=" + to_string(__N) + " state=" + state_name + " J=" + _r6(jc)
            + " λ₁=" + _r6(lam1) + " λ₂=" + _r6(lam2)
            + " φ₁=" + _r6(phi1) + " φ₂=" + _r6(phi2)
            + " cycles=" + to_string(cycles))
    let verbose = do_auto || do_hamming || do_dw
    let a = _run_trajectory(state_name, jc, phi1, lam1, phi2, lam2, cycles, verbose)
    let drift = _abs_f(_norm2() - 1.0)
    let w_end = _dw_mean()
    let dw_drift = _abs_f(w_end - __dw0)
    let sub_ratio = if do_fft { _fft_subharmonic_ratio(a) } else { 0.0 }
    let x_end = _hamming_mean()
    let a_end = a[len(a) - 1]
    if json_mode {
        println("{ \"tool\": \"dtc\", \"mode\": \"run\", \"N\": " + to_string(__N)
                + ", \"state\": \"" + state_name + "\", \"cycles\": " + to_string(cycles)
                + ", \"lambda1\": " + _r6(lam1) + ", \"lambda2\": " + _r6(lam2)
                + ", \"A_end\": " + _r6(a_end)
                + ", \"x_mean_end\": " + _r6(x_end)
                + ", \"dw_initial\": " + _r6(__dw0) + ", \"dw_end\": " + _r6(w_end)
                + ", \"dw_drift\": " + _r6(dw_drift)
                + ", \"sub_ratio\": " + _r6(sub_ratio)
                + ", \"norm_drift\": " + _r6(drift)
                + ", \"entropy_source\": \"deterministic-exact\" }")
    } else {
        println("  A(end)=" + _r6(a_end) + "  <x>(end)=" + _r6(x_end))
        println("  <w>(0)=" + _r6(__dw0) + "  <w>(end)=" + _r6(w_end) + "  |Δw|=" + _r6(dw_drift))
        if do_fft { println("  FFT subharmonic ratio @ ω=π/T = " + _r6(sub_ratio)) }
        println("  norm_drift=" + _r6(drift))
        println("  entropy: deterministic-exact (no QRNG draw — unitary evolution; g5)")
    }
    println("__SIM_UNIVERSE_DTC__ PASS N=" + to_string(__N) + " state=" + state_name
            + " sub_peak=" + _r6(sub_ratio) + " dw_drift=" + _r6(dw_drift)
            + " norm_drift=" + _r6(drift))
    exit(0)
}
