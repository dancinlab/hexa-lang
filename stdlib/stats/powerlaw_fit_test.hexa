// stdlib/stats/powerlaw_fit_test — self-test for powerlaw_fit.
//
// Oracles (4):
//   1. n < 3                          → α = 0
//   2. uniform distribution           → α ≈ 0 (flat log-log)
//   3. powerlaw α=2.5 sample          → α_est positive, well above 0
//   4. spread invariant: powerlaw α > uniform α (the key directional signal
//      the INFO-MEASURE-TRIAD orthogonality test relied on)
//
// Self-contained, deterministic LCG sampler.

import "stdlib/stats/powerlaw_fit.hexa"

extern fn pow(base: float, exp: float) -> float

fn _fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

fn _lcg(seed: int, n: int) -> array {
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    let mut s = seed
    let mut out = []
    let mut i = 0
    while i < n {
        s = (a * s + c) % m
        if s < 0 { s = s + m }
        out = append(out, (s + 0.0) / (m + 0.0))
        i = i + 1
    }
    return out
}

// Inverse-CDF sampler for p(k) ∝ k^(-α) on [1, kmax].
fn _powerlaw_sample(n: int, alpha: float, seed: int) -> array {
    let kmax = 100
    let u = _lcg(seed, n)
    let mut out = []
    let mut i = 0
    while i < n {
        let one_minus_a = 1.0 - alpha
        let mut k = 1.0
        if one_minus_a != 0.0 {
            let base = 1.0 - u[i] * (1.0 - pow(kmax + 0.0, one_minus_a))
            if base > 0.0 {
                k = pow(base, 1.0 / one_minus_a)
            }
        }
        out = append(out, k)
        i = i + 1
    }
    return out
}

fn _uniform_sample(n: int, lo: float, hi: float, seed: int) -> array {
    let u = _lcg(seed, n)
    let mut out = []
    let mut i = 0
    while i < n {
        out = append(out, lo + u[i] * (hi - lo))
        i = i + 1
    }
    return out
}

fn main() {
    let mut fails = 0

    // 1. n < 3 → 0
    let a_empty = powerlaw_fit([])
    if a_empty == 0.0 {
        println("PASS empty α=0")
    } else {
        println("FAIL empty α=" + to_string(a_empty))
        fails = fails + 1
    }
    let a_two = powerlaw_fit([1.0, 2.0])
    if a_two == 0.0 {
        println("PASS n=2 α=0")
    } else {
        println("FAIL n=2 α=" + to_string(a_two))
        fails = fails + 1
    }

    // 2. Uniform → α near 0 (flat log-log)
    let unif = _uniform_sample(500, 1.0, 50.0, 9012)
    let a_unif = powerlaw_fit(unif)
    if _fabs(a_unif) < 1.0 {
        println("PASS uniform α near 0: " + to_string(a_unif))
    } else {
        println("FAIL uniform α far from 0: " + to_string(a_unif))
        fails = fails + 1
    }

    // 3. Powerlaw α=2.5 → α_est positive
    let pl = _powerlaw_sample(500, 2.5, 1234)
    let a_pl = powerlaw_fit(pl)
    if a_pl > 0.5 {
        println("PASS powerlaw α positive: " + to_string(a_pl))
    } else {
        println("FAIL powerlaw α too small: " + to_string(a_pl))
        fails = fails + 1
    }

    // 4. Directional invariant: powerlaw α ≫ uniform α (the orthogonality signal)
    if a_pl > a_unif + 0.5 {
        println("PASS spread invariant: powerlaw(" + to_string(a_pl) + ") > uniform(" + to_string(a_unif) + ") + 0.5")
    } else {
        println("FAIL spread invariant: powerlaw=" + to_string(a_pl) + " uniform=" + to_string(a_unif))
        fails = fails + 1
    }

    if fails == 0 {
        println("ALL PASS — stdlib/stats/powerlaw_fit")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
