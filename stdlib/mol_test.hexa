// HEXA Standard Library — mol Stage-2 tests (explicit-atom descriptors)
// Self-validating vs known molecular weights / Lipinski counts.

import "stdlib/mol/mod.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: string, cond: bool) {
    total_count = total_count + 1
    if cond { pass_count = pass_count + 1 }
    else { if failed == "" { failed = name } }
}

fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }

fn main() {
    // Stage-1 surface still intact.
    let m0 = mol_new(["C", "O", "H"], [[0, 1, 2], [0, 2, 1]], 0)
    check("mol_num_atoms == 3", mol_num_atoms(m0) == 3)
    check("mol_charge == 0", mol_charge(m0) == 0)

    // Water O-H-H: atoms idx 0=O,1=H,2=H; bonds O-H, O-H.
    let water = mol_new(["O", "H", "H"], [[0, 1, 1], [0, 2, 1]], 0)
    check("water MolWt == 18.015", fabs(mol_weight(water) - 18.015) < 0.0001)
    check("water HBA == 1", mol_hba(water) == 1)
    check("water HBD == 2", mol_hbd(water) == 2)

    // Ethanol CH3CH2OH: 0=C 1=C 2=O 3..8=H; O-H at (2,8).
    let eth_atoms = ["C", "C", "O", "H", "H", "H", "H", "H", "H"]
    let eth_bonds = [[0, 1, 1], [1, 2, 1], [0, 3, 1], [0, 4, 1],
                     [0, 5, 1], [1, 6, 1], [1, 7, 1], [2, 8, 1]]
    let eth = mol_new(eth_atoms, eth_bonds, 0)
    check("ethanol MolWt == 46.069", fabs(mol_weight(eth) - 46.069) < 0.0001)
    check("ethanol HBA == 1", mol_hba(eth) == 1)
    check("ethanol HBD == 1 (one O-H)", mol_hbd(eth) == 1)

    // Methylamine CH3NH2: 0=C 1=N 2..6=H; N-H at (1,5),(1,6).
    let ma_atoms = ["C", "N", "H", "H", "H", "H", "H"]
    let ma_bonds = [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1],
                    [1, 5, 1], [1, 6, 1]]
    let ma = mol_new(ma_atoms, ma_bonds, 0)
    check("methylamine HBA == 1 (N)", mol_hba(ma) == 1)
    check("methylamine HBD == 2 (N-H x2)", mol_hbd(ma) == 2)
    // C 12.011 + N 14.007 + 5 H (5*1.008=5.04) = 31.058
    check("methylamine MolWt == 31.058", fabs(mol_weight(ma) - 31.058) < 0.0001)

    // Chloromethane CH3Cl: no N/O -> HBA 0, HBD 0; weight check.
    let cm = mol_new(["C", "Cl", "H", "H", "H"],
                     [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1]], 0)
    check("CH3Cl HBA == 0", mol_hba(cm) == 0)
    check("CH3Cl HBD == 0", mol_hbd(cm) == 0)
    // C 12.011 + Cl 35.45 + 3*1.008 = 50.485
    check("CH3Cl MolWt == 50.485", fabs(mol_weight(cm) - 50.485) < 0.0001)

    println("mol: " + mol_status())
    if pass_count == total_count {
        println("__MOL_STAGE2_TEST__ PASS (" + str(pass_count) + "/" + str(total_count) + ")")
    } else {
        println("__MOL_STAGE2_TEST__ FAIL (" + str(pass_count) + "/" + str(total_count) + " first-fail=" + failed + ")")
        exit(1)
    }
}
