#!hexa strict
// qmirror/stabilizer/module/stabilizer.hexa — Stabilizer-measurement primitive (cond.11 / F-QM-2-STAB-11)
// STANDALONE: pure-hexa kernel (Phase 5a absorption, 2026-05-12 —
// PARALLEL_SUBAGENT_FIRING_ROADMAP_2026_05_12.md Round 1). All circuit
// execution + sampling now goes through stabilizer_native.hexa, which
// builds on engine_aer's pure-hexa state vector kernel. No subprocess,
// no python, no qiskit dependency.
//
// @tool(slug="qmirror_stabilizer", desc="Ancilla-mediated non-destructive Z⊗Z + X⊗X stabilizer measurement on a 2-qubit Bell state |Φ+>=(|00>+|11>)/sqrt(2). 4 qubits total = 2 data + 2 ancilla; ancillas prepared in |+>, CNOT-coupled to data via Z (data->ancilla) and X (ancilla->data) gadgets, then measured in X-basis to read syndromes. Post-measurement state tomographically verified against |Φ+> via 3-Pauli Bell-witness F = (1+<ZZ>+<XX>-<YY>)/4. Default: n_trials=1024 syndrome shots + ~256 per-basis post-tomography shots. Pure-hexa kernel — stabilizer_native_run drives the engine_aer state-vector primitives in-process; no python bridge, no qiskit.")
// @usage(hexa run qmirror/stabilizer/module/stabilizer.hexa --selftest)
// @sentinel(__QMIRROR_STABILIZER__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest exercises the pure-hexa stabilizer_native kernel (no qiskit, no python bridge).")
//
// Spec ref: anima/docs/qmirror_2_axes_spec_2026_05_03.md §2 (axis 3, cond.11)
// Plan ref: PARALLEL_SUBAGENT_FIRING_ROADMAP_2026_05_12.md §4 Round 1 (Phase 5a stabilizer)
// Falsifier: F-QM-2-STAB-11 — syndrome_plus_ratio >= 0.99 AND post_fidelity >= 0.99 over 1024 trials
//
// Protocol (4 qubits = q0,q1 data + q2,q3 ancillas):
//   1. Prepare |Φ+>_{q0,q1} via H(q0); CNOT(q0,q1)
//   2. Z⊗Z syndrome via a0=q2: H(q2); CNOT(q0,q2); CNOT(q1,q2); H(q2); measure q2 -> s_zz
//   3. X⊗X syndrome via a1=q3: H(q3); CNOT(q3,q0); CNOT(q3,q1); H(q3); measure q3 -> s_xx
//   4. Post-state tomography: per-lane choose basis ∈ {ZZ,XX,YY}, append rotation+readout
//   5. Aggregate: F(|Φ+>) = (1 + <ZZ> + <XX> - <YY>) / 4   (Bell-witness)
//
// Analytic: |Φ+> is +1 eigenstate of both Z⊗Z and X⊗X (commuting stabilizers);
// pure-hexa kernel reproduces F=1.0, syndrome_plus_ratio=1.0 exactly.

use "./stabilizer_native.hexa"

struct StabilizerVerdict {
    ok:                      int,
    verdict:                 str,        // "PASS" | "FAIL"
    syndrome_plus_ratio:     float,      // joint (+1,+1) over total trials
    syndrome_zz_plus_ratio:  float,
    syndrome_xx_plus_ratio:  float,
    post_fidelity:           float,
    E_ZZ:                    float,
    E_XX:                    float,
    E_YY:                    float,
    n_trials:                int,
    n_qubits_total:          int,
    engine:                  str,
    message:                 str
}

fn stab_verdict_fail(reason: str) -> StabilizerVerdict {
    return StabilizerVerdict {
        ok: 0, verdict: "FAIL",
        syndrome_plus_ratio: 0.0,
        syndrome_zz_plus_ratio: 0.0,
        syndrome_xx_plus_ratio: 0.0,
        post_fidelity: 0.0,
        E_ZZ: 0.0, E_XX: 0.0, E_YY: 0.0,
        n_trials: 0, n_qubits_total: 4, engine: "none",
        message: reason
    }
}

// Public: run the stabilizer-measurement protocol with n_trials shots.
// Returns StabilizerVerdict { syndrome_plus_ratio, post_fidelity, ..., verdict, ok }.
// Phase 5a migration: replaced python bridge with direct stabilizer_native_run
// call (pure-hexa kernel; no subprocess).
fn stabilizer_run(n_trials: int, seed: int) -> StabilizerVerdict {
    if n_trials < 1 {
        return stab_verdict_fail("stabilizer: n_trials >= 1 required")
    }

    let r = stabilizer_native_run(n_trials, seed)
    if r.ok != 1 {
        return stab_verdict_fail("stabilizer: native kernel fail: " + r.message)
    }

    return StabilizerVerdict {
        ok: 1, verdict: r.verdict,
        syndrome_plus_ratio: r.syndrome_plus_ratio,
        syndrome_zz_plus_ratio: r.syndrome_zz_plus_ratio,
        syndrome_xx_plus_ratio: r.syndrome_xx_plus_ratio,
        post_fidelity: r.post_fidelity,
        E_ZZ: r.E_ZZ, E_XX: r.E_XX, E_YY: r.E_YY,
        n_trials: r.n_trials, n_qubits_total: r.n_qubits_total,
        engine: r.engine,
        message: r.message
    }
}

fn _selftest() -> int {
    // F-QM-2-STAB-11: stabilizer_run(1024, seed) returns
    //   syndrome_plus_ratio >= 0.99 AND post_fidelity >= 0.99
    let v = stabilizer_run(1024, 20260504)
    if v.ok != 1 { return 0 }
    if v.verdict != "PASS" { return 0 }
    if v.syndrome_plus_ratio < 0.99 { return 0 }
    if v.post_fidelity < 0.99 { return 0 }
    return 1
}

fn main() {
    println("[qmirror/stabilizer] Ancilla-mediated stabilizer-measurement primitive")
    println("  spec: F-QM-2-STAB-11  syndrome_plus_ratio>=0.99 AND post_fidelity>=0.99")
    println("  state: |Phi+>_{q0,q1}; ancillas q2 (Z⊗Z), q3 (X⊗X); 4 qubits total")
    let v = stabilizer_run(1024, 20260504)
    println("  engine                = " + v.engine)
    println("  syndrome_plus_ratio   = " + str(v.syndrome_plus_ratio) + "   (analytic 1.0)")
    println("  syndrome_zz_plus      = " + str(v.syndrome_zz_plus_ratio))
    println("  syndrome_xx_plus      = " + str(v.syndrome_xx_plus_ratio))
    println("  post_fidelity         = " + str(v.post_fidelity) + "   (analytic 1.0)")
    println("  E[ZZ]                 = " + str(v.E_ZZ) + "   (analytic +1)")
    println("  E[XX]                 = " + str(v.E_XX) + "   (analytic +1)")
    println("  E[YY]                 = " + str(v.E_YY) + "   (analytic -1)")
    println("  verdict               = " + v.verdict)
    println("  message               = " + v.message)
    if _selftest() == 1 {
        println("[qmirror/stabilizer] SELFTEST PASS (F-QM-2-STAB-11 cleared)")
        println("__QMIRROR_STABILIZER__ PASS")
    } else {
        println("[qmirror/stabilizer] SELFTEST FAIL (F-QM-2-STAB-11 falsifier triggered)")
        println("__QMIRROR_STABILIZER__ FAIL")
    }
}
