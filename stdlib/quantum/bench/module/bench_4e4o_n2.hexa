#!hexa strict
// qmirror/bench/module/bench_4e4o_n2.hexa
//
// chem-vqe-bench suite — 4e/4o vendored VQE replay for N2.
// N≡N at N 0 0 0; N 0 0 1.0977; basis=sto-3g; AS=(4,4); 6 qubits.
//
// Vendored data (offline-extracted 2026-05-13 via pyscf+qiskit-nature):
//   - Hamiltonian: 75 Pauli terms on 6 qubits (ParityMapper((2,2)) + 2q reduction)
//   - constant_shift, CASCI(4,4) reference
//   - UCCSD-converged statevector psi-star (64 complex amps, SLSQP from zeros)
//
// CCSD(T) literature reference (sanity-check, NOT the direct comparator):
//   E = -109.40195 Ha (CCSD(T)/aug-cc-pVQZ at experimental Re=1.0977 Å)
//   source: NIST CCCBDB; W4-17 reference set (Karton et al. 2017).
//
// @tool(slug="qmirror_bench_4e4o_n2", desc="chem-vqe-bench 4e/4o vendored VQE replay for N2.")
// @usage(hexa run qmirror/bench/module/bench_4e4o_n2.hexa --selftest)
// @sentinel(__QMIRROR_BENCH_CHEM_VQE_N2_4E4O__ <PASS|FAIL>)

