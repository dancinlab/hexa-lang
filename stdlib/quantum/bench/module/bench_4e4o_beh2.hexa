#!hexa strict
// qmirror/bench/module/bench_4e4o_beh2.hexa
//
// chem-vqe-bench suite — 4e/4o vendored VQE replay for BeH2.
// H-Be-H at Be 0 0 0; H 0 0 1.3264; H 0 0 -1.3264; basis=sto-3g; AS=(4,4); 6 qubits.
//
// Vendored data (offline-extracted 2026-05-13 via pyscf+qiskit-nature):
//   - Hamiltonian: 55 Pauli terms on 6 qubits (ParityMapper((2,2)) + 2q reduction)
//   - constant_shift, CASCI(4,4) reference
//   - UCCSD-converged statevector psi-star (64 complex amps, SLSQP from zeros)
//
// CCSD(T) literature reference (sanity-check, NOT the direct comparator):
//   E = -15.83074 Ha (CCSD(T)/cc-pVTZ, linear D∞h, Re=1.3264 Å)
//   source: NIST CCCBDB experimental Re; CCSD(T) electronic energy from Karton & Martin, J. Chem. Phys. 136, 124114 (2012) (W4 reference set).
//
// @tool(slug="qmirror_bench_4e4o_beh2", desc="chem-vqe-bench 4e/4o vendored VQE replay for BeH2.")
// @usage(hexa run qmirror/bench/module/bench_4e4o_beh2.hexa --selftest)
// @sentinel(__QMIRROR_BENCH_CHEM_VQE_BEH2_4E4O__ <PASS|FAIL>)

