#!hexa strict
// qmirror/surface_code_d3/module/surface_code_d3.hexa — distance-3 surface code TOY (cond.12 / F-QM-2-SURF-12)
// STANDALONE: lives under qmirror/surface_code_d3/module/ (canonical layout 2026-05-05).
//
// @usage(hexa run qmirror/surface_code_d3/module/surface_code_d3.hexa --selftest)
// @sentinel(__QMIRROR_SURFACE_D3__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest exercises the pure-hexa state-vector kernel (three dim=8 GHZ-3 blocks); no python bridge, no qiskit.")
//
// Spec ref: anima/docs/qmirror_2_axes_spec_2026_05_03.md §cond.12
// Falsifier: F-QM-2-SURF-12 — logical_zero_ratio >= 0.99 AND min_stab_plus_ratio >= 0.99 (n_shots=1024, noiseless)
//
// Phase 7 absorption (2026-05-12, FINAL python bridge): the qiskit+aer bridge
// (_python_bridge/module/surface_code_d3_runner.py) is retired.  All stabilizer
// + logical readout evaluation goes through surface_code_d3_native.hexa
// against engine_aer's pure-hexa state_vector kernel.  Zero subprocess, zero
// python, zero qiskit.
//
// Structural factorization (path b): |0_L> = |GHZ_3>^⊗3 is a product state
// across the 3 data blocks, every stabilizer is a +1 eigenstate operator on
// that product (intra-block ZZ are +1 by GHZ even-parity; inter-block X^⊗6
// factors as (X^⊗3 on left block)(X^⊗3 on right block) = (+1)(+1) = +1),
// and the logical Z_L = X0X1X2 readout reduces to parity of H^⊗3 |GHZ_3>
// which is even-parity supported.  See native kernel header for the
// full eigenstate derivation.
//
// Layout (Shor [[9,1,3]] CSS code; same parameters as the standard rotated
// d=3 surface code but with cleanly-commuting CSS structure):
//   9 data qubits in 3 blocks of 3 (D0..D8)
//   8 ancillae: 6 Z-stab (weight-2 intra-block) + 2 X-stab (weight-6 inter-block)
//   Logical Z_L = X0 X1 X2 (Shor convention)

use "./surface_code_d3_native.hexa"

struct SurfaceD3Verdict {
    ok:                    int,
    verdict:               str,        // "PASS" | "FAIL"
    logical_zero_count:    int,
    logical_zero_ratio:    float,
    min_stab_plus_ratio:   float,
    max_stab_plus_ratio:   float,
    trivial_syndrome_ratio:float,
    n_shots:               int,
    n_qubits:              int,
    n_data:                int,
    n_ancilla:             int,
    engine:                str,
    message:               str
}

fn surface_d3_verdict_fail(reason: str) -> SurfaceD3Verdict {
    return SurfaceD3Verdict {
        ok: 0, verdict: "FAIL",
        logical_zero_count: 0, logical_zero_ratio: 0.0,
        min_stab_plus_ratio: 0.0, max_stab_plus_ratio: 0.0,
        trivial_syndrome_ratio: 0.0,
        n_shots: 0, n_qubits: 17, n_data: 9, n_ancilla: 8,
        engine: "none",
        message: reason
    }
}

// Public: run d=3 surface-code toy with n_shots samples; return verdict.
// Phase 7 migration: drives the pure-hexa native kernel (no subprocess,
// no python, no qiskit).  Returns the same SurfaceD3Verdict struct that
// the previous python-bridge wrapper returned (drop-in compatible).
fn surface_d3_run(n_shots: int, seed: int) -> SurfaceD3Verdict {
    if n_shots < 1 {
        return surface_d3_verdict_fail("surface_d3: n_shots >= 1 required")
    }

    let n = surface_d3_native_run(n_shots, seed)
    if n.ok != 1 {
        return surface_d3_verdict_fail("surface_d3: native: " + n.message)
    }

    return SurfaceD3Verdict {
        ok: 1,
        verdict: n.verdict,
        logical_zero_count: n.logical_zero_count,
        logical_zero_ratio: n.logical_zero_ratio,
        min_stab_plus_ratio: n.min_stab_plus_ratio,
        max_stab_plus_ratio: n.max_stab_plus_ratio,
        trivial_syndrome_ratio: n.trivial_syndrome_ratio,
        n_shots: n.n_shots,
        n_qubits: n.n_qubits,
        n_data: n.n_data,
        n_ancilla: n.n_ancilla,
        engine: n.engine,
        message: n.message
    }
}

fn _selftest() -> int {
    // F-QM-2-SURF-12: surface_d3_run(1024, seed) returns logical_zero_ratio
    // >= 0.99 AND min_stab_plus_ratio >= 0.99 on noiseless single-round.
    let v = surface_d3_run(1024, 20260504)
    if v.ok != 1 { return 0 }
    if v.verdict != "PASS" { return 0 }
    if v.logical_zero_ratio < 0.99 { return 0 }
    if v.min_stab_plus_ratio < 0.99 { return 0 }
    if v.n_qubits != 17 { return 0 }
    if v.n_data != 9 { return 0 }
    if v.n_ancilla != 8 { return 0 }
    return 1
}

fn main() {
    println("[qmirror/surface_code_d3] d=3 [[9,1,3]] CSS surface-code TOY")
    println("  spec: F-QM-2-SURF-12  logical_zero_ratio >= 0.99 AND min_stab+1_ratio >= 0.99")
    println("  layout: 17 logical qubits = 9 data + 8 ancilla (6 Z-stab + 2 X-stab); Shor [[9,1,3]] CSS variant")
    println("  engine: hexa_native (pure-hexa state-vector kernel; Phase 7 absorption, FINAL bridge)")
    let v = surface_d3_run(1024, 20260504)
    println("  engine               = " + v.engine)
    println("  n_qubits             = " + str(v.n_qubits) + " (data=" + str(v.n_data) + ", ancilla=" + str(v.n_ancilla) + ")")
    println("  n_shots              = " + str(v.n_shots))
    println("  logical_zero_count   = " + str(v.logical_zero_count))
    println("  logical_zero_ratio   = " + str(v.logical_zero_ratio) + "   (spec >= 0.99)")
    println("  min_stab_plus_ratio  = " + str(v.min_stab_plus_ratio) + "   (spec >= 0.99)")
    println("  max_stab_plus_ratio  = " + str(v.max_stab_plus_ratio))
    println("  trivial_syndrome     = " + str(v.trivial_syndrome_ratio))
    println("  verdict              = " + v.verdict)
    if _selftest() == 1 {
        println("[qmirror/surface_code_d3] SELFTEST PASS (F-QM-2-SURF-12 cleared)")
        println("__QMIRROR_SURFACE_D3__ PASS")
    } else {
        println("[qmirror/surface_code_d3] SELFTEST FAIL (F-QM-2-SURF-12 falsifier triggered)")
        println("__QMIRROR_SURFACE_D3__ FAIL")
    }
}
