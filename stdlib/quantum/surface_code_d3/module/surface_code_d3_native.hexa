#!hexa strict
// qmirror/surface_code_d3/module/surface_code_d3_native.hexa
//
// Pure-hexa Shor [[9,1,3]] CSS surface-code d=3 TOY kernel — Phase 7 of the
// full-repo hexa-only absorption (PARALLEL_SUBAGENT_FIRING_ROADMAP_2026_05_12.md
// §4 Round 4, FINAL python bridge).  Replaces the qiskit+aer bridge that
// previously lived in _python_bridge/module/surface_code_d3_runner.py
// (now deleted).
//
// STRUCTURAL FACTORIZATION (path b) — analytic eigenstate observations
// --------------------------------------------------------------------
//
// The naive 17-qubit dim=131072 state vector is unnecessary here.  The
// noiseless single-round Shor-CSS protocol has a strong analytic structure
// that the kernel exploits:
//
//   1. Encoded |0_L> is a PRODUCT STATE across the three data blocks
//      (q0..q2, q3..q5, q6..q8):
//
//         |0_L>  =  |GHZ_3>_b1  ⊗  |GHZ_3>_b2  ⊗  |GHZ_3>_b3
//                   where  |GHZ_3>_b = (|000>+|111>)/sqrt(2)
//
//      Encoder per block:  H(3b) ; CNOT(3b, 3b+1) ; CNOT(3b+1, 3b+2)
//      So we simulate three independent dim=8 state vectors, never the
//      dim=131072 full system.
//
//   2. Each |GHZ_3>_b is a +1 eigenstate of:
//        - every weight-2 Z-pair on adjacent qubits within the block
//          (Z0Z1, Z1Z2, Z0Z2): (|000>+|111>) has even Z-parity, eigval +1.
//        - the weight-3 X-string X⊗X⊗X on the block:
//          X^⊗3 |000> = |111>;  X^⊗3 |111> = |000>;  sum is invariant.
//      Therefore:
//        - All 6 weight-2 intra-block Z-stabilizers measure +1 deterministically.
//        - Both weight-6 inter-block X-stabilizers (X0X1X2X3X4X5 and
//          X3X4X5X6X7X8) measure +1 deterministically:
//            <ψ_full|X^⊗6|ψ_full> = <ψ_b_left|X^⊗3|ψ_b_left>
//                                 · <ψ_b_right|X^⊗3|ψ_b_right>
//                                 = (+1) · (+1) = +1.
//
//   3. Logical Z_L = X0 X1 X2  (Shor convention: logical Z is X^⊗3 on the
//      first block — see runner.py header).  Readout:
//        - Apply H to q0, q1, q2 of block 1.
//        - Measure all 3 data qubits in Z basis.
//        - Logical bit = parity(d0 ⊕ d1 ⊕ d2).
//      Applying H^⊗3 to (|000>+|111>)/sqrt(2) gives (|+++>+|--->)/sqrt(2)
//      = (1/2)(|000>+|011>+|101>+|110>) — pure even-parity superposition.
//      So parity is deterministically 0, logical_zero_ratio = 1.0.
//
// Verdict (F-QM-2-SURF-12):
//   PASS iff logical_zero_ratio >= 0.99 AND min_stab_plus_ratio >= 0.99.
//   Under noiseless single-round all three ratios are 1.0 by the analytic
//   eigenstate properties above.  The kernel STILL runs the per-block
//   state-vector simulation (dim=8 per block) to verify the protocol —
//   it is not a hardcoded constant.
//
// hexa-lang notes:
//   - state_vector.hexa's apply_single mutates state.re / state.im IN PLACE
//     (aliasing of array references).  We therefore rebuild a fresh
//     |GHZ_3> at every callsite that needs to apply a rotation before
//     measurement (matches ghz_mermin_native.hexa header note).
//   - `>=` / `<=` are lint-banned; we use `<` / `>` / `==` only.
//   - 3-qubit per-block dim=8 amplitudes are trivially under the 768MB cap.
//
// @resolver-bypass(reason="Selftest is pure-hexa state-vector — three dim=8 GHZ-3 simulations, no python, no qiskit.")

use "../../engine_aer/module/state_vector.hexa"
use "../../engine_aer/module/gates.hexa"

// ── Result struct ───────────────────────────────────────────────────────

struct SurfaceD3Native {
    ok:                     int,
    verdict:                str,    // "PASS" | "FAIL"
    logical_zero_count:     int,
    logical_zero_ratio:     float,
    min_stab_plus_ratio:    float,
    max_stab_plus_ratio:    float,
    trivial_syndrome_ratio: float,
    n_shots:                int,
    n_qubits:               int,
    n_data:                 int,
    n_ancilla:              int,
    engine:                 str,
    message:                str
}

fn _surface_d3_native_fail(reason: str) -> SurfaceD3Native {
    return SurfaceD3Native {
        ok: 0, verdict: "FAIL",
        logical_zero_count: 0, logical_zero_ratio: 0.0,
        min_stab_plus_ratio: 0.0, max_stab_plus_ratio: 0.0,
        trivial_syndrome_ratio: 0.0,
        n_shots: 0, n_qubits: 17, n_data: 9, n_ancilla: 8,
        engine: "hexa_native",
        message: reason
    }
}

// ── Per-block builders ─────────────────────────────────────────────────

// Build a fresh dim=8 |GHZ_3> = (|000>+|111>)/sqrt(2) via the Shor
// per-block encoder: state_zero(3) ; H(0) ; CNOT(0,1) ; CNOT(1,2).
fn _surface_d3_make_ghz3() -> StateVector {
    let n = 3
    let h = gate_h()
    let s0 = state_zero(n)
    let s1 = apply_single(s0, h.re, h.im, 0, n)   // H on q0
    let s2 = apply_cnot(s1, 0, 1, n)              // CNOT(0,1)
    let s3 = apply_cnot(s2, 1, 2, n)              // CNOT(1,2)
    return s3
}

// ── Z-stabilizer eigenvalue probe (intra-block, weight-2) ──────────────
//
// <ψ_block | Z_i Z_j | ψ_block>  on the per-block state.  Computed in the
// computational basis: each amplitude k contributes sign · |amp[k]|^2 with
// sign = +1 if bit_i(k) XOR bit_j(k) == 0, else -1.
fn _surface_d3_zstab_eigval(state: StateVector, i: int, j: int) -> float {
    let dim = state_dim(state)
    let bi = 1 << i
    let bj = 1 << j
    let mut acc = 0.0
    let mut k = 0
    while k < dim {
        let par = ((k & bi) >> i) ^ ((k & bj) >> j)
        let r = amp_re_at(state, k)
        let im_k = amp_im_at(state, k)
        let p = r * r + im_k * im_k
        if par == 0 {
            acc = acc + p
        } else {
            acc = acc - p
        }
        k = k + 1
    }
    return acc
}

// Probability that the ancilla for a Z-stab reads 0 (i.e. +1 eigenspace
// projection probability) = (1 + <ZZ>) / 2.
fn _surface_d3_zstab_plus_prob(state: StateVector, i: int, j: int) -> float {
    let ev = _surface_d3_zstab_eigval(state, i, j)
    return (1.0 + ev) / 2.0
}

// ── X-stabilizer eigenvalue probe (intra-block, weight-3) ──────────────
//
// <ψ_block | X_0 X_1 X_2 | ψ_block>.  Applied via the identity
//   <ψ | X^⊗3 | ψ> = <H^⊗3 ψ | Z^⊗3 | H^⊗3 ψ>
// since H · X · H = Z.  So rotate-then-Z-parity expectation.
fn _surface_d3_xxx_eigval(state: StateVector) -> float {
    let n = 3
    let h = gate_h()
    // Clone state to avoid in-place mutation of caller's GHZ
    // (apply_single mutates state.re_h / state.im_h via the farr backend).
    let dim = state_dim(state)
    let mut sv = state_clone(state)
    sv = apply_single(sv, h.re, h.im, 0, n)
    sv = apply_single(sv, h.re, h.im, 1, n)
    sv = apply_single(sv, h.re, h.im, 2, n)
    // <Z_0 Z_1 Z_2> = sum_k (-1)^popcount(k) · |amp[k]|^2  (popcount over 3 bits)
    let mut acc = 0.0
    let mut k = 0
    while k < dim {
        let b0 = k & 1
        let b1 = (k >> 1) & 1
        let b2 = (k >> 2) & 1
        let par = (b0 + b1 + b2) % 2
        let r = amp_re_at(sv, k)
        let im_k = amp_im_at(sv, k)
        let p = r * r + im_k * im_k
        if par == 0 {
            acc = acc + p
        } else {
            acc = acc - p
        }
        k = k + 1
    }
    let _ = state_free(sv)
    return acc
}

// ── Logical Z destructive readout probability ──────────────────────────
//
// Z_L = X0 X1 X2 on block 1.  Apply H to all 3 qubits, then sum over
// computational-basis outcomes with even d0⊕d1⊕d2 parity.  Should be 1.0.
fn _surface_d3_logical_zero_prob(state: StateVector) -> float {
    let n = 3
    let h = gate_h()
    // Clone to preserve caller's state.
    let dim = state_dim(state)
    let mut sv = state_clone(state)
    sv = apply_single(sv, h.re, h.im, 0, n)
    sv = apply_single(sv, h.re, h.im, 1, n)
    sv = apply_single(sv, h.re, h.im, 2, n)
    let mut acc = 0.0
    let mut k = 0
    while k < dim {
        let b0 = k & 1
        let b1 = (k >> 1) & 1
        let b2 = (k >> 2) & 1
        let par = (b0 + b1 + b2) % 2
        if par == 0 {
            let r = amp_re_at(sv, k)
            let im_k = amp_im_at(sv, k)
            acc = acc + r * r + im_k * im_k
        }
        k = k + 1
    }
    let _ = state_free(sv)
    return acc
}

// ── Top-level kernel ───────────────────────────────────────────────────
//
// For Shor [[9,1,3]] CSS in noiseless single-round operation, every
// per-shot outcome equals the analytic eigenstate value:
//   - 6 Z-stabilizers (intra-block):  +1  (ancilla = 0)
//   - 2 X-stabilizers (inter-block, weight-6): +1 (ancilla = 0)
//   - logical Z_L = X0X1X2 readout parity: 0  (logical |0_L>)
// We *compute* the per-block <ZZ> / <XXX> / logical-zero-prob via dim=8
// state vectors and verify the eigenvalue is +1 (or prob is 1.0) to
// floating-point precision before declaring PASS.  If any block deviates
// beyond a tiny float tolerance, the verdict is FAIL — the kernel is a
// real verifier, not a hardcoded constant.
fn surface_d3_native_run(n_shots: int, seed: int) -> SurfaceD3Native {
    if n_shots < 1 {
        return _surface_d3_native_fail("surface_d3: n_shots >= 1 required")
    }
    // seed is echoed in the verdict for provenance — the verdict itself
    // is shot-count-independent on noiseless single-round (analytic
    // eigenstate properties).  Touch it to satisfy hexa-strict.
    let _seed_echo = seed

    // ----------------------------------------------------------------
    // (1) Build the three per-block |GHZ_3> states.
    // ----------------------------------------------------------------
    let blk1 = _surface_d3_make_ghz3()
    let blk2 = _surface_d3_make_ghz3()
    let blk3 = _surface_d3_make_ghz3()

    // ----------------------------------------------------------------
    // (2) Z-stabilizer eigenvalue probes (6 total, weight-2 intra-block).
    //
    //   Z_1 = Z0 Z1   ; Z_2 = Z1 Z2   (block 1)
    //   Z_3 = Z3 Z4   ; Z_4 = Z4 Z5   (block 2  -> qubits (0,1)/(1,2) of blk2)
    //   Z_5 = Z6 Z7   ; Z_6 = Z7 Z8   (block 3  -> qubits (0,1)/(1,2) of blk3)
    //
    // Each should evaluate to <ZZ> = +1 exactly.
    // ----------------------------------------------------------------
    let ev_z1 = _surface_d3_zstab_eigval(blk1, 0, 1)
    let ev_z2 = _surface_d3_zstab_eigval(blk1, 1, 2)
    let ev_z3 = _surface_d3_zstab_eigval(blk2, 0, 1)
    let ev_z4 = _surface_d3_zstab_eigval(blk2, 1, 2)
    let ev_z5 = _surface_d3_zstab_eigval(blk3, 0, 1)
    let ev_z6 = _surface_d3_zstab_eigval(blk3, 1, 2)

    // P(ancilla = 0) for each Z-stab = (1 + <ZZ>)/2.
    let p_z1 = (1.0 + ev_z1) / 2.0
    let p_z2 = (1.0 + ev_z2) / 2.0
    let p_z3 = (1.0 + ev_z3) / 2.0
    let p_z4 = (1.0 + ev_z4) / 2.0
    let p_z5 = (1.0 + ev_z5) / 2.0
    let p_z6 = (1.0 + ev_z6) / 2.0

    // ----------------------------------------------------------------
    // (3) X-stabilizer eigenvalue probes (2 total, weight-6 inter-block).
    //
    //   X_1 = X0..X5 = (X_blk1) ⊗ (X_blk2) — product factorizes.
    //   X_2 = X3..X8 = (X_blk2) ⊗ (X_blk3).
    //
    //   <ψ_full | X^⊗6 | ψ_full> = <ψ_left | X^⊗3 | ψ_left>
    //                            · <ψ_right| X^⊗3 | ψ_right>
    //
    // We compute the per-block <X^⊗3> factor explicitly (rotate to Z via
    // H^⊗3, then Z-parity expectation).  Should be +1 each.
    // ----------------------------------------------------------------
    let xxx_blk1 = _surface_d3_xxx_eigval(blk1)
    let xxx_blk2 = _surface_d3_xxx_eigval(blk2)
    let xxx_blk3 = _surface_d3_xxx_eigval(blk3)
    let ev_x1 = xxx_blk1 * xxx_blk2
    let ev_x2 = xxx_blk2 * xxx_blk3
    let p_x1 = (1.0 + ev_x1) / 2.0
    let p_x2 = (1.0 + ev_x2) / 2.0

    // ----------------------------------------------------------------
    // (4) Logical Z readout probability: parity(d0 ⊕ d1 ⊕ d2) = 0 on
    //     H^⊗3 |GHZ_3>_b1.  Should be 1.0.
    // ----------------------------------------------------------------
    let p_logical_zero = _surface_d3_logical_zero_prob(blk1)

    // ----------------------------------------------------------------
    // (5) Verify per-shot outcome is fully deterministic.  Every stab
    //     plus probability should be 1.0 to float-noise; logical-zero
    //     probability should be 1.0.  Trivial syndrome ratio = the
    //     joint probability that ALL 8 stabilizers read 0; under
    //     independence of the deterministic +1 outcomes this is the
    //     product = 1.0.
    // ----------------------------------------------------------------
    let tol = 0.000001

    // helper inline (no fn call to avoid hexa-strict needs): check each
    // probability is within tol of 1.0.
    let p_list = [p_z1, p_z2, p_z3, p_z4, p_z5, p_z6, p_x1, p_x2]
    let mut min_stab = 1.0
    let mut max_stab = 0.0
    let mut all_ok = 1
    let mut idx = 0
    while idx < len(p_list) {
        let p = p_list[idx]
        if p < min_stab { min_stab = p }
        if max_stab < p { max_stab = p }
        // Deviation from 1.0 beyond float tol → bug in eigenstate computation.
        let dev = if p < 1.0 { 1.0 - p } else { p - 1.0 }
        if tol < dev { all_ok = 0 }
        idx = idx + 1
    }

    let dev_log = if p_logical_zero < 1.0 { 1.0 - p_logical_zero } else { p_logical_zero - 1.0 }
    if tol < dev_log { all_ok = 0 }

    if all_ok == 0 {
        return _surface_d3_native_fail(
            "surface_d3: eigenstate-probe deviation > tol; protocol may have drifted")
    }

    // ----------------------------------------------------------------
    // (6) Assemble verdict.  Every shot returns the deterministic
    //     outcome, so ratios = probabilities = 1.0 exactly.
    // ----------------------------------------------------------------
    let logical_zero_ratio = p_logical_zero
    let min_stab_plus_ratio = min_stab
    let max_stab_plus_ratio = max_stab
    let trivial_syndrome_ratio = p_z1 * p_z2 * p_z3 * p_z4 * p_z5 * p_z6 * p_x1 * p_x2
    // Round-to-nearest (analytic prob = 1.0 modulo float-noise → every shot
    // returns the deterministic outcome, so count = n_shots exactly).
    let logical_zero_count = to_int(to_float(n_shots) * logical_zero_ratio + 0.5)

    // F-QM-2-SURF-12 verdict: logical_zero_ratio > 0.989999 AND min_stab_plus_ratio > 0.989999.
    // (>= 0.99 expressed via strict < to dodge the relop lint.)
    let pass_log = 0.989999 < logical_zero_ratio    // @allow-relop-banned
    let pass_stab = 0.989999 < min_stab_plus_ratio  // @allow-relop-banned
    let verdict_str = if pass_log {
        if pass_stab { "PASS" } else { "FAIL" }
    } else { "FAIL" }

    let msg = "surface_d3_native: " + verdict_str +
              " (logical_zero=" + str(logical_zero_ratio) +
              ", min_stab+=" + str(min_stab_plus_ratio) +
              ", n_shots=" + str(n_shots) +
              ", engine=hexa_native)"

    return SurfaceD3Native {
        ok: 1, verdict: verdict_str,
        logical_zero_count: logical_zero_count,
        logical_zero_ratio: logical_zero_ratio,
        min_stab_plus_ratio: min_stab_plus_ratio,
        max_stab_plus_ratio: max_stab_plus_ratio,
        trivial_syndrome_ratio: trivial_syndrome_ratio,
        n_shots: n_shots,
        n_qubits: 17, n_data: 9, n_ancilla: 8,
        engine: "hexa_native",
        message: msg
    }
}
