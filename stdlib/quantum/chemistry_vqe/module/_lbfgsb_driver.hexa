#!hexa strict
//
// _lbfgsb_driver.hexa — hexa-native L-BFGS-B prototype (RFC 039 / §3 ladder).
//
// Pure-hexa L-BFGS quasi-Newton optimizer with bound constraints and a
// strong-Wolfe line search. Designed to drop into chemistry-VQE on top
// of `farr_parameter_shift_grad` (RFC 039), but validated TODAY on a
// known-min quadratic surface with FINITE-DIFFERENCE gradients
// (h = 1e-5). When RFC 039's C kernel lands, the single
// `_lbfgsb_fd_grad` call inside `_lbfgsb_minimize` is swapped for
// `farr_parameter_shift_grad` — the optimizer core is unchanged.
//
// Design constraints:
//   - PURE HEXA (no C kernel beyond the existing `farr_*` zeros/get/set).
//   - State held on farr handles so future RFC 039 wire-up is a 1-line swap.
//   - The cost-function call site is a hard-coded function name
//     (`_lbfgsb_cost_quadratic`) — hexa does not have closures here, so
//     each molecule will need a copy of `_lbfgsb_minimize` that calls
//     into its own `*_energy_h`. That's the same pattern the NM drivers
//     follow (cv_uccsd_cmt_*_nm_h variants for each cache shape).
//   - Two-loop recursion (Nocedal-Wright Alg 7.4), m=10 history default.
//   - Strong-Wolfe line search (c1=1e-4, c2=0.9), max 20 trials.
//   - Bound constraints applied as a hard clip on the trial step
//     (sufficient for our box `[-pi, pi]^N` on UCCSD theta). For the
//     quadratic-bowl test, bounds are wide enough never to bind.
//   - 완성도: this prototype RUNS and CONVERGES on the smoke-test
//     quadratic; it is not a stub.
//
// Public surface used by the smoke test (`_lbfgsb_smoke.hexa`):
//   fn _lbfgsb_minimize(n: int, x0: [float], lower: [float], upper: [float],
//                       m: int, max_iter: int, g_tol: float,
//                       f_tol: float, problem_id: int) -> map
//
// The `problem_id` is a small integer enumerating which built-in cost
// function the driver should call:
//   0 = quadratic bowl  f(x) = sum_i (x_i - target_i)^2     (smoke test)
//   1 = rosenbrock 2D   (reserved; future tests)
//   ≥ 2 reserved.
//
// The returned map has keys:
//   "x"          : [float], best parameter vector found
//   "f"          : float, cost at "x"
//   "n_iter"     : int
//   "n_feval"    : int, total cost-function evaluations
//   "n_geval"    : int, total gradient evaluations
//   "converged"  : int (1 if |grad|_inf < g_tol OR |Δf| < f_tol; 0 otherwise)
//   "status"     : str — human-readable verdict
//
// ---------------------------------------------------------------------

// ─── cost-function bench (problem_id = 0: quadratic bowl) ──────────────

// Quadratic bowl: f(x) = sum_i (x_i - target_i)^2 ; gradient is analytic
// (2*(x_i - target_i)) but the driver uses finite-difference gradients
// to verify the FD path is correct; once that converges, swapping to
// the analytic / parameter-shift gradient is a one-line edit.
//
// The "target" is hard-coded as a fixed cyclic pattern so the smoke
// test can check the recovered x ≈ target to high precision.

fn _lbfgsb_target_quadratic(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n {
        // Cyclic [0.5, -0.3, 1.1, -0.7] pattern; chosen to give a non-
        // trivial bowl center (not all-zeros, not all-one-sign).
        let r = i - 4 * (i / 4)
        let v = if r == 0 { 0.5 } else { if r == 1 { 0.0 - 0.3 } else { if r == 2 { 1.1 } else { 0.0 - 0.7 } } }
        out = out.push(v)
        i = i + 1
    }
    return out
}

fn _lbfgsb_cost_quadratic(x_h: int, n: int) -> float {
    let target = _lbfgsb_target_quadratic(n)
    let mut acc = 0.0
    let mut i = 0
    while i < n {
        let xi = farr_get(x_h, i)
        let d  = xi - target[i]
        acc = acc + d * d
        i = i + 1
    }
    return acc
}

// Single-dispatch: route problem_id → cost call. Hexa has no first-
// class callbacks here, so dispatch is explicit.
fn _lbfgsb_cost(problem_id: int, x_h: int, n: int) -> float {
    if problem_id == 0 { return _lbfgsb_cost_quadratic(x_h, n) }
    // Other problem_ids reserved.
    return 1e308
}

// ─── finite-difference gradient (stand-in for RFC 039) ─────────────────
//
// grad[k] = (f(x + h*e_k) - f(x - h*e_k)) / (2*h)
// h = 1e-5 by default; for the quadratic this gives ~1e-10 relative
// accuracy (round-off dominates beyond that).
//
// One forward + one backward eval per parameter → 2*N total cost
// evals, exactly matching the parameter-shift count. The replacement
// at the RFC 039 apply commit is:
//
//     let _ = farr_parameter_shift_grad(re_h, im_h, x_h, grad_h,
//                                       n, ham_h, ansatz_h, n_q)
//
// in place of the loop below.

fn _lbfgsb_fd_grad(problem_id: int, x_h: int, grad_h: int, n: int, h: float) -> int {
    let inv_2h = 1.0 / (2.0 * h)
    let mut k = 0
    while k < n {
        let xk = farr_get(x_h, k)
        let _ = farr_set(x_h, k, xk + h)
        let f_plus  = _lbfgsb_cost(problem_id, x_h, n)
        let _ = farr_set(x_h, k, xk - h)
        let f_minus = _lbfgsb_cost(problem_id, x_h, n)
        let _ = farr_set(x_h, k, xk)
        let _ = farr_set(grad_h, k, (f_plus - f_minus) * inv_2h)
        k = k + 1
    }
    return 0
}

// ─── parameter-shift gradient hook (RFC 039) ───────────────────────────
//
// `_lbfgsb_grad` is the single gradient entry point used by the driver.
// Behaviour switches on `use_param_shift`:
//   0 → FD-grad (the original, quadratic-bowl-validated path).
//   1 → invoke the C kernel `farr_parameter_shift_grad`, given pre-built
//       ham_h / ansatz_h descriptors and pre-allocated state scratch
//       (re_h / im_h, length 2^n_qubits each). For the quadratic
//       problem_id=0 these handles are unused (the cost function does
//       not need them); the param-shift branch is only meaningful when
//       problem_id corresponds to a chemistry-VQE energy that the C
//       kernel can replay from `ansatz_h`.
//
// All buffers are caller-supplied / pre-allocated. On success returns 0;
// on kernel-rejected (e.g. invalid handle) returns -1 — caller must
// fall back to FD-grad to avoid stalling the optimizer.
fn _lbfgsb_grad(problem_id: int, use_param_shift: int,
                x_h: int, grad_h: int, n: int, h: float,
                re_h: int, im_h: int,
                ham_h: int, ansatz_h: int, n_qubits: int) -> int {
    if use_param_shift == 1 {
        // RFC 039 kernel call: returns 0 on success, -1 on error.
        // grad_h is filled with ∂E/∂θ_k for all k (two energy replays
        // each, ±π/2 shifts, in a single C-side loop).
        let rc = farr_parameter_shift_grad(re_h, im_h, x_h, grad_h,
                                            n, ham_h, ansatz_h, n_qubits)
        return rc
    }
    return _lbfgsb_fd_grad(problem_id, x_h, grad_h, n, h)
}

// ─── small linear-algebra helpers (farr-handle ops) ────────────────────

fn _lbfgsb_dot(a_h: int, b_h: int, n: int) -> float {
    let mut acc = 0.0
    let mut i = 0
    while i < n {
        acc = acc + farr_get(a_h, i) * farr_get(b_h, i)
        i = i + 1
    }
    return acc
}

fn _lbfgsb_inf_norm(v_h: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let v = farr_get(v_h, i)
        let av = if v < 0.0 { 0.0 - v } else { v }
        if av > m { m = av }
        i = i + 1
    }
    return m
}

fn _lbfgsb_copy(dst_h: int, src_h: int, n: int) -> int {
    let mut i = 0
    while i < n {
        let _ = farr_set(dst_h, i, farr_get(src_h, i))
        i = i + 1
    }
    return 0
}

// dst = a + scale * b
fn _lbfgsb_axpy(dst_h: int, a_h: int, scale: float, b_h: int, n: int) -> int {
    let mut i = 0
    while i < n {
        let v = farr_get(a_h, i) + scale * farr_get(b_h, i)
        let _ = farr_set(dst_h, i, v)
        i = i + 1
    }
    return 0
}

// in-place clip: x = clip(x, lower, upper)
fn _lbfgsb_clip(x_h: int, lower: [float], upper: [float], n: int) -> int {
    let mut i = 0
    while i < n {
        let v = farr_get(x_h, i)
        let lo = lower[i]
        let hi = upper[i]
        let clipped = if v < lo { lo } else { if v > hi { hi } else { v } }
        let _ = farr_set(x_h, i, clipped)
        i = i + 1
    }
    return 0
}

// ─── L-BFGS two-loop recursion ─────────────────────────────────────────
//
// Given m past (s_k, y_k) pairs in the s_hist / y_hist farrs (each
// length m*n), and the current gradient g in g_h, compute the search
// direction d = -H_k · g where H_k is the L-BFGS approximation.
//
// Layout:
//   s_hist[i * n + j]  = s_i[j]   for i in 0..m_used
//   y_hist[i * n + j]  = y_i[j]   for i in 0..m_used
//   rho_arr[i]         = 1 / (y_i · s_i)
// Oldest history at index 0; newest at index m_used - 1.

fn _lbfgsb_hist_get(hist_h: int, i: int, j: int, n: int) -> float {
    return farr_get(hist_h, i * n + j)
}

fn _lbfgsb_hist_dot(hist_h: int, i: int, n: int, vec_h: int) -> float {
    let mut acc = 0.0
    let mut j = 0
    while j < n {
        acc = acc + farr_get(hist_h, i * n + j) * farr_get(vec_h, j)
        j = j + 1
    }
    return acc
}

// q = -g; for i = m_used-1 .. 0:  alpha_i = rho_i * s_i · q ; q -= alpha_i * y_i
// then  r = gamma * q ; for i = 0 .. m_used-1:  beta = rho_i * y_i · r ; r += (alpha_i - beta) * s_i
// final direction d = r (since q was seeded with -g and the recursion
// gives r = H · (-g) which is exactly the search direction).
fn _lbfgsb_two_loop(s_hist_h: int, y_hist_h: int, rho_arr: [float],
                     m_used: int, n: int, g_h: int, gamma: float,
                     d_h: int, alpha_h: int, q_h: int) -> int {
    // q = -g
    let mut i = 0
    while i < n {
        let _ = farr_set(q_h, i, 0.0 - farr_get(g_h, i))
        i = i + 1
    }
    // backward sweep: newest-first
    let mut k = m_used - 1
    while k >= 0 {
        let sq = _lbfgsb_hist_dot(s_hist_h, k, n, q_h)
        let a  = rho_arr[k] * sq
        let _ = farr_set(alpha_h, k, a)
        let mut j = 0
        while j < n {
            let qj = farr_get(q_h, j)
            let yj = farr_get(y_hist_h, k * n + j)
            let _ = farr_set(q_h, j, qj - a * yj)
            j = j + 1
        }
        k = k - 1
    }
    // r = gamma * q (stored back into q_h to save a buffer; this is
    // exactly the L-BFGS initial Hessian-vector product H_0 · q with
    // H_0 = gamma * I).
    let mut jj = 0
    while jj < n {
        let _ = farr_set(q_h, jj, gamma * farr_get(q_h, jj))
        jj = jj + 1
    }
    // forward sweep: oldest-first
    let mut kk = 0
    while kk < m_used {
        let yr = _lbfgsb_hist_dot(y_hist_h, kk, n, q_h)
        let b = rho_arr[kk] * yr
        let a_kk = farr_get(alpha_h, kk)
        let mut j2 = 0
        while j2 < n {
            let qj = farr_get(q_h, j2)
            let sj = farr_get(s_hist_h, kk * n + j2)
            let _ = farr_set(q_h, j2, qj + (a_kk - b) * sj)
            j2 = j2 + 1
        }
        kk = kk + 1
    }
    // d = q
    let _ = _lbfgsb_copy(d_h, q_h, n)
    return 0
}

// ─── strong-Wolfe line search (backtracking with curvature check) ──────
//
// Find step length t > 0 along d_h such that:
//   (Armijo)    f(x + t*d) ≤ f(x) + c1 * t * g·d
//   (curvature) |∇f(x + t*d) · d| ≤ c2 * |g·d|
// c1 = 1e-4, c2 = 0.9, t_init = 1.0, shrink factor = 0.5, max 20 trials.
// On failure → return the best (smallest-f) trial seen.
//
// Side-effects: x_h is updated to x + t_chosen * d (with clip applied);
// returns the cost at the chosen step. Writes the gradient at the new
// point into grad_h (so the outer loop doesn't need to re-eval).

fn _lbfgsb_line_search(problem_id: int, n: int,
                       x_h: int, d_h: int, g_h: int,
                       f_curr: float, gd_curr: float,
                       lower: [float], upper: [float],
                       x_trial_h: int, grad_h: int,
                       fd_h: float,
                       max_trials: int,
                       use_param_shift: int,
                       re_h: int, im_h: int,
                       ham_h: int, ansatz_h: int, n_qubits: int) -> map {
    let c1 = 0.0001
    let c2 = 0.9
    let mut t = 1.0
    let mut trials = 0
    let mut best_f = 1e308
    let mut best_t = 0.0
    let mut best_grad_inf = 1e308
    let mut accepted = 0
    let mut n_feval_ls = 0
    let mut n_geval_ls = 0
    let abs_gd = if gd_curr < 0.0 { 0.0 - gd_curr } else { gd_curr }
    while trials < max_trials && accepted == 0 {
        // x_trial = clip(x + t*d, lower, upper)
        let _ = _lbfgsb_axpy(x_trial_h, x_h, t, d_h, n)
        let _ = _lbfgsb_clip(x_trial_h, lower, upper, n)
        let f_t = _lbfgsb_cost(problem_id, x_trial_h, n)
        n_feval_ls = n_feval_ls + 1
        if f_t < best_f {
            best_f = f_t
            best_t = t
        }
        // Armijo check
        let armijo_rhs = f_curr + c1 * t * gd_curr
        if f_t <= armijo_rhs {
            // Curvature: eval grad at trial, check |grad·d| <= c2*|g·d|
            let _ = _lbfgsb_grad(problem_id, use_param_shift,
                                  x_trial_h, grad_h, n, fd_h,
                                  re_h, im_h, ham_h, ansatz_h, n_qubits)
            n_geval_ls = n_geval_ls + 1
            let gd_new = _lbfgsb_dot(grad_h, d_h, n)
            let abs_gd_new = if gd_new < 0.0 { 0.0 - gd_new } else { gd_new }
            if abs_gd_new <= c2 * abs_gd {
                accepted = 1
            } else {
                // Curvature failed — keep contracting. We could try
                // an expansion (Nocedal-Wright Alg 3.5), but for the
                // smooth convex bowl test, monotone contraction is
                // sufficient and ~10× simpler.
                t = t * 0.5
                trials = trials + 1
            }
        } else {
            t = t * 0.5
            trials = trials + 1
        }
    }
    let chosen_t = if accepted == 1 { t } else { best_t }
    let chosen_f = if accepted == 1 {
        let f_acc = _lbfgsb_cost(problem_id, x_trial_h, n)
        f_acc  // already at the right point
    } else {
        // Fall back to best_t — recompute x_trial and grad at that point.
        let _ = _lbfgsb_axpy(x_trial_h, x_h, best_t, d_h, n)
        let _ = _lbfgsb_clip(x_trial_h, lower, upper, n)
        let f_bt = _lbfgsb_cost(problem_id, x_trial_h, n)
        let _ = _lbfgsb_grad(problem_id, use_param_shift,
                              x_trial_h, grad_h, n, fd_h,
                              re_h, im_h, ham_h, ansatz_h, n_qubits)
        n_feval_ls = n_feval_ls + 2
        n_geval_ls = n_geval_ls + 1
        f_bt
    }
    let _ = _lbfgsb_copy(x_h, x_trial_h, n)
    let out = json_parse("{}")
    out["f"] = chosen_f
    out["t"] = chosen_t
    out["accepted"] = accepted
    out["n_feval_ls"] = n_feval_ls
    out["n_geval_ls"] = n_geval_ls
    return out
}

// ─── main driver ───────────────────────────────────────────────────────

// `_lbfgsb_minimize` keeps the original 9-arg surface (FD-grad path); the
// new `_lbfgsb_minimize_psgrad` variant below threads RFC 039
// `farr_parameter_shift_grad` through `_lbfgsb_grad`/`_lbfgsb_line_search`.
fn _lbfgsb_minimize(n: int, x0: [float], lower: [float], upper: [float],
                    m: int, max_iter: int, g_tol: float, f_tol: float,
                    problem_id: int) -> map {
    return _lbfgsb_minimize_ex(n, x0, lower, upper, m, max_iter, g_tol, f_tol,
                                problem_id, 0,
                                0 - 1, 0 - 1, 0 - 1, 0 - 1, 0)
}

// Same as `_lbfgsb_minimize` but exposes the RFC 039 parameter-shift
// gradient hook + state-buffer / handle inputs. When `use_param_shift=1`,
// every `_lbfgsb_grad` call inside the optimizer routes through the
// `farr_parameter_shift_grad` C kernel using the supplied
// `(re_h, im_h, ham_h, ansatz_h, n_qubits)` context. When 0, behaviour
// is identical to `_lbfgsb_minimize` (FD-grad).
fn _lbfgsb_minimize_psgrad(n: int, x0: [float], lower: [float], upper: [float],
                           m: int, max_iter: int, g_tol: float, f_tol: float,
                           problem_id: int,
                           re_h: int, im_h: int,
                           ham_h: int, ansatz_h: int, n_qubits: int) -> map {
    return _lbfgsb_minimize_ex(n, x0, lower, upper, m, max_iter, g_tol, f_tol,
                                problem_id, 1,
                                re_h, im_h, ham_h, ansatz_h, n_qubits)
}

fn _lbfgsb_minimize_ex(n: int, x0: [float], lower: [float], upper: [float],
                       m: int, max_iter: int, g_tol: float, f_tol: float,
                       problem_id: int, use_param_shift: int,
                       re_h: int, im_h: int,
                       ham_h: int, ansatz_h: int, n_qubits: int) -> map {
    // farr scratch — pre-allocated, reused across iters.
    let x_h        = farr_zeros(n)
    let x_trial_h  = farr_zeros(n)
    let g_h        = farr_zeros(n)
    let g_prev_h   = farr_zeros(n)
    let d_h        = farr_zeros(n)
    let q_h        = farr_zeros(n)         // two-loop scratch
    let alpha_h    = farr_zeros(m)         // two-loop alpha cache
    let s_hist_h   = farr_zeros(m * n)
    let y_hist_h   = farr_zeros(m * n)

    // Init x = x0 (clipped to bounds).
    let mut ii = 0
    while ii < n {
        let _ = farr_set(x_h, ii, x0[ii])
        ii = ii + 1
    }
    let _ = _lbfgsb_clip(x_h, lower, upper, n)

    let mut n_feval = 0
    let mut n_geval = 0

    // f0, g0
    let mut f_curr = _lbfgsb_cost(problem_id, x_h, n)
    n_feval = n_feval + 1
    let _ = _lbfgsb_grad(problem_id, use_param_shift,
                         x_h, g_h, n, 0.00001,
                         re_h, im_h, ham_h, ansatz_h, n_qubits)
    n_geval = n_geval + 1

    // History bookkeeping.
    let mut rho_arr = []
    let mut h_init = 0
    while h_init < m { rho_arr = rho_arr.push(0.0); h_init = h_init + 1 }
    let mut m_used = 0
    let mut gamma = 1.0
    let mut converged = 0
    let mut status = "running"

    let mut it = 0
    let mut done = 0
    while done == 0 {
        if it >= max_iter { status = "max_iter"; done = 1 }
        if done == 0 {
            let g_inf = _lbfgsb_inf_norm(g_h, n)
            if g_inf < g_tol {
                converged = 1
                status = "g_tol"
                done = 1
            }
        }
        if done == 0 {
            // Search direction d via two-loop recursion (or steepest
            // descent on iter 0 when no history exists).
            if m_used == 0 {
                let mut j = 0
                while j < n {
                    let _ = farr_set(d_h, j, 0.0 - farr_get(g_h, j))
                    j = j + 1
                }
            } else {
                let _ = _lbfgsb_two_loop(s_hist_h, y_hist_h, rho_arr,
                                          m_used, n, g_h, gamma,
                                          d_h, alpha_h, q_h)
            }
            // Directional derivative.
            let gd = _lbfgsb_dot(g_h, d_h, n)
            // If d is not a descent direction (numerical glitch), reset to -g.
            if gd >= 0.0 {
                let mut j2 = 0
                while j2 < n {
                    let _ = farr_set(d_h, j2, 0.0 - farr_get(g_h, j2))
                    j2 = j2 + 1
                }
                m_used = 0
            }
            let gd2 = _lbfgsb_dot(g_h, d_h, n)
            // Cache prev grad for the curvature pair update.
            let _ = _lbfgsb_copy(g_prev_h, g_h, n)

            // Cache current x → use d_h scratch's neighbour? We need x_prev
            // implicitly: s = x_new - x_old. We'll compute s = t * d (since
            // line search returns x_new = x_old + t*d after clipping). But
            // clipping may have moved x_new — so compute s after the fact
            // from x_h_before and x_h_after.
            let mut x_before = []
            let mut p = 0
            while p < n { x_before = x_before.push(farr_get(x_h, p)); p = p + 1 }

            // Line search updates x_h in place, writes new grad to g_h.
            let ls = _lbfgsb_line_search(problem_id, n,
                                          x_h, d_h, g_h,
                                          f_curr, gd2,
                                          lower, upper,
                                          x_trial_h, g_h,
                                          0.00001, 20,
                                          use_param_shift,
                                          re_h, im_h, ham_h, ansatz_h, n_qubits)
            let f_new = to_float(ls["f"])
            n_feval = n_feval + to_int(ls["n_feval_ls"])
            n_geval = n_geval + to_int(ls["n_geval_ls"])

            // f-tol convergence: relative or absolute change below f_tol.
            let df = f_curr - f_new
            let abs_df = if df < 0.0 { 0.0 - df } else { df }
            let denom = if f_curr < 0.0 { 0.0 - f_curr } else { f_curr }
            let scale = if denom > 1.0 { denom } else { 1.0 }
            if abs_df < f_tol * scale {
                converged = 1
                status = "f_tol"
                done = 1
            }

            // History update: s = x_new - x_before ; y = g_new - g_prev.
            // If sy = s·y > 0 (curvature positive), push to history;
            // else skip (preserves L-BFGS PD property).
            // We use the trailing slot of the m-array; oldest gets shifted out.
            if done == 0 {
                // Build s, y in scratch (reuse q_h for s; d_h is consumed).
                let mut sy = 0.0
                let mut s_scratch = []
                let mut y_scratch = []
                let mut k2 = 0
                while k2 < n {
                    let s_k = farr_get(x_h, k2) - x_before[k2]
                    let y_k = farr_get(g_h, k2) - farr_get(g_prev_h, k2)
                    sy = sy + s_k * y_k
                    s_scratch = s_scratch.push(s_k)
                    y_scratch = y_scratch.push(y_k)
                    k2 = k2 + 1
                }
                if sy > 0.000000000001 {
                    // Compute y·y for the gamma update.
                    let mut yy = 0.0
                    let mut kk2 = 0
                    while kk2 < n {
                        yy = yy + y_scratch[kk2] * y_scratch[kk2]
                        kk2 = kk2 + 1
                    }
                    if yy > 0.0 { gamma = sy / yy }
                    // Shift history if full: drop slot 0, slide everything down.
                    if m_used == m {
                        let mut sh = 1
                        while sh < m {
                            let mut col = 0
                            while col < n {
                                let v_s = farr_get(s_hist_h, sh * n + col)
                                let v_y = farr_get(y_hist_h, sh * n + col)
                                let _ = farr_set(s_hist_h, (sh - 1) * n + col, v_s)
                                let _ = farr_set(y_hist_h, (sh - 1) * n + col, v_y)
                                col = col + 1
                            }
                            rho_arr[sh - 1] = rho_arr[sh]
                            sh = sh + 1
                        }
                        m_used = m - 1
                    }
                    // Write new s, y, rho into slot m_used.
                    let mut wj = 0
                    while wj < n {
                        let _ = farr_set(s_hist_h, m_used * n + wj, s_scratch[wj])
                        let _ = farr_set(y_hist_h, m_used * n + wj, y_scratch[wj])
                        wj = wj + 1
                    }
                    rho_arr[m_used] = 1.0 / sy
                    m_used = m_used + 1
                }
                // else: curvature failed; preserve previous history,
                //       hope next step recovers PD.
                f_curr = f_new
                it = it + 1
            }
        }
    }

    // Final results — copy x_h to a [float] for the return map.
    let mut x_out = []
    let mut rp = 0
    while rp < n {
        x_out = x_out.push(farr_get(x_h, rp))
        rp = rp + 1
    }
    let final_g_inf = _lbfgsb_inf_norm(g_h, n)

    let _ = farr_free(x_h)
    let _ = farr_free(x_trial_h)
    let _ = farr_free(g_h)
    let _ = farr_free(g_prev_h)
    let _ = farr_free(d_h)
    let _ = farr_free(q_h)
    let _ = farr_free(alpha_h)
    let _ = farr_free(s_hist_h)
    let _ = farr_free(y_hist_h)

    let out = json_parse("{}")
    out["x"] = x_out
    out["f"] = f_curr
    out["n_iter"] = it
    out["n_feval"] = n_feval
    out["n_geval"] = n_geval
    out["converged"] = converged
    out["status"] = status
    out["grad_inf"] = final_g_inf
    return out
}
