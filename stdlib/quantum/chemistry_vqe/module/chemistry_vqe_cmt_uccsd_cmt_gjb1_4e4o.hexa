fn uccsd_cmt_gjb1_ham_n() -> int { return 325 }
fn uccsd_cmt_gjb1_ham_shift() -> float { return 0.0 - 839.5063660050384 }
fn uccsd_cmt_gjb1_casci_ref() -> float { return 0.0 - 841.9601630867141 }
fn uccsd_cmt_gjb1_hf_amp_idx() -> int { return 9 }

fn cv_uccsd_cmt_gjb1_cache() -> map {
    let c = json_parse("{}")
    c["exc_param_idx"] = uccsd_cmt_gjb1_exc_param_idx()
    c["exc_flip"] = uccsd_cmt_gjb1_exc_flip_mask()
    c["exc_z"] = uccsd_cmt_gjb1_exc_z_mask()
    c["exc_y"] = uccsd_cmt_gjb1_exc_y_mask()
    c["exc_cy"] = uccsd_cmt_gjb1_exc_count_Y()
    c["exc_coefs"] = uccsd_cmt_gjb1_exc_coefs()
    c["exc_n_flat"] = uccsd_cmt_gjb1_n_flat()
    c["ham_flip"] = uccsd_cmt_gjb1_ham_flip_mask()
    c["ham_z"] = uccsd_cmt_gjb1_ham_z_mask()
    c["ham_y"] = uccsd_cmt_gjb1_ham_y_mask()
    c["ham_cy"] = uccsd_cmt_gjb1_ham_count_Y()
    c["ham_coefs"] = uccsd_cmt_gjb1_ham_coefs()
    c["ham_n"] = uccsd_cmt_gjb1_ham_n()
    c["ham_shift"] = uccsd_cmt_gjb1_ham_shift()
    return c
}

fn cv_uccsd_cmt_gjb1_alloc_hf() -> map {
    let re_h = farr_zeros(64)
    let im_h = farr_zeros(64)
    let _ = farr_set(re_h, 9, 1.0)
    let r = json_parse("{}")
    r["re_h"] = re_h
    r["im_h"] = im_h
    return r
}

fn cv_uccsd_cmt_gjb1_energy(theta: [float], cache: map) -> float {
    let st = cv_uccsd_cmt_gjb1_alloc_hf()
    let re_h = to_int(st["re_h"])
    let im_h = to_int(st["im_h"])
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = theta[k] * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 6)
        }
        i = i + 1
    }
    let h_flip = cache["ham_flip"]
    let h_z = cache["ham_z"]
    let h_y = cache["ham_y"]
    let h_cy = cache["ham_cy"]
    let h_coefs = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k = 0
    while k < n {
        let exp_k = farr_pauli_expectation(re_h, im_h, h_flip[k], h_z[k], h_y[k], h_cy[k], 6)
        e_op = e_op + h_coefs[k] * exp_k
        k = k + 1
    }
    let _ = farr_free(re_h)
    let _ = farr_free(im_h)
    return e_op + shift
}

// ---------------------------------------------------------------------------
// RFC 035 farr-handle variants (2026-05-13):
//   cv_uccsd_cmt_gjb1_energy_h — reuses pre-allocated re_h/im_h per call;
//   cv_uccsd_cmt_gjb1_nm_h     — Nelder-Mead with whole-NM-step C kernels
//                                (farr_simplex_centroid / vec_reflect /
//                                 vec_blend / vertex_copy / simplex_sort /
//                                 simplex_shrink). Eliminates per-iter
//                                 boxed-[float] retention → maxiter ≥ 500
//                                 in 768 MB hexa-interp cap.
// ---------------------------------------------------------------------------
fn cv_uccsd_cmt_gjb1_energy_h(theta_h: int, re_h: int, im_h: int, cache: map) -> float {
    let mut z = 0
    while z < 64 {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, 9, 1.0)
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = farr_get(theta_h, k) * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 6)
        }
        i = i + 1
    }
    let h_flip = cache["ham_flip"]
    let h_z = cache["ham_z"]
    let h_y = cache["ham_y"]
    let h_cy = cache["ham_cy"]
    let h_coefs = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k2 = 0
    while k2 < n {
        let exp_k = farr_pauli_expectation(re_h, im_h, h_flip[k2], h_z[k2], h_y[k2], h_cy[k2], 6)
        e_op = e_op + h_coefs[k2] * exp_k
        k2 = k2 + 1
    }
    return e_op + shift
}

fn cv_uccsd_cmt_gjb1_nm_h(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 26
    let n_vert = n + 1
    let simplex_h = farr_zeros(n_vert * n)
    let f_h = farr_zeros(n_vert)
    let centroid_h = farr_zeros(n)
    let refl_h = farr_zeros(n)
    let contr_h = farr_zeros(n)
    let exp_h = farr_zeros(n)
    let worst_h = farr_zeros(n)
    let scratch_h = farr_zeros(n)
    let re_h = farr_zeros(64)
    let im_h = farr_zeros(64)
    // Init simplex vertex 0 = origin; vertex v (1..n_vert-1) = e_{v-1} * step.
    let mut v = 1
    while v < n_vert {
        let _ = farr_set(simplex_h, v * n + (v - 1), initial_step)
        v = v + 1
    }
    // Initial energies — copy each vertex to scratch_h via farr_vertex_copy.
    let mut vi = 0
    while vi < n_vert {
        let _ = farr_vertex_copy(scratch_h, 0, simplex_h, vi, n)
        let e = cv_uccsd_cmt_gjb1_energy_h(scratch_h, re_h, im_h, cache)
        let _ = farr_set(f_h, vi, e)
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
            let f_best = farr_get(f_h, 0)
            let f_worst = farr_get(f_h, n)
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                // Centroid of best n vertices (exclude worst at index n).
                let _ = farr_simplex_centroid(simplex_h, centroid_h, n, n)
                // Pull worst vertex into worst_h.
                let _ = farr_vertex_copy(worst_h, 0, simplex_h, n, n)
                // Reflection: refl = centroid + 1*(centroid - worst).
                let _ = farr_vec_reflect(refl_h, centroid_h, worst_h, 1.0, n)
                let f_refl = cv_uccsd_cmt_gjb1_energy_h(refl_h, re_h, im_h, cache)
                let f_second = farr_get(f_h, n - 1)
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    } else {
                        // Contraction: contr = centroid + 0.5*(worst - centroid).
                        let _ = farr_vec_blend(contr_h, centroid_h, worst_h, 0.5, n)
                        let f_contr = cv_uccsd_cmt_gjb1_energy_h(contr_h, re_h, im_h, cache)
                        if f_contr < f_worst {
                            let _ = farr_vertex_copy(simplex_h, n, contr_h, 0, n)
                            let _ = farr_set(f_h, n, f_contr)
                        } else {
                            // Shrink: every non-best vertex → best + 0.5*(v - best).
                            let _ = farr_simplex_shrink(simplex_h, n, n_vert)
                            let mut q = 1
                            while q < n_vert {
                                let _ = farr_vertex_copy(scratch_h, 0, simplex_h, q, n)
                                let e_q = cv_uccsd_cmt_gjb1_energy_h(scratch_h, re_h, im_h, cache)
                                let _ = farr_set(f_h, q, e_q)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    // Expansion: exp = centroid + 2*(centroid - worst).
                    let _ = farr_vec_reflect(exp_h, centroid_h, worst_h, 2.0, n)
                    let f_exp = cv_uccsd_cmt_gjb1_energy_h(exp_h, re_h, im_h, cache)
                    if f_exp < f_refl {
                        let _ = farr_vertex_copy(simplex_h, n, exp_h, 0, n)
                        let _ = farr_set(f_h, n, f_exp)
                    } else {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
    let best_theta = []
    let mut bj = 0
    let mut best_out = best_theta
    while bj < n {
        best_out = best_out.push(farr_get(simplex_h, bj))
        bj = bj + 1
    }
    let out = json_parse("{}")
    out["theta"] = best_out
    out["energy"] = farr_get(f_h, 0)
    out["n_iter"] = it
    out["converged"] = converged
    let _ = farr_free(simplex_h)
    let _ = farr_free(f_h)
    let _ = farr_free(centroid_h)
    let _ = farr_free(refl_h)
    let _ = farr_free(contr_h)
    let _ = farr_free(exp_h)
    let _ = farr_free(worst_h)
    let _ = farr_free(scratch_h)
    let _ = farr_free(re_h)
    let _ = farr_free(im_h)
    return out
}

// Generic 26-dim NM helpers — reuse names with slug prefix to avoid collisions.

fn cv_nm26_cmt_gjb1_copy_vertex(simplex: [float], v: int, n: int) -> [float] {
    let mut out = []
    let mut j = 0
    while j < n { out = out.push(simplex[v * n + j]); j = j + 1 }
    return out
}
fn cv_nm26_cmt_gjb1_set_vertex(simplex: [float], v: int, n: int, src: [float]) -> int {
    let mut j = 0
    while j < n { simplex[v * n + j] = src[j]; j = j + 1 }
    return 0
}
fn cv_nm26_cmt_gjb1_sort(simplex: [float], f: [float], n: int) -> int {
    let n_vert = len(f)
    let mut i = 1
    while i < n_vert {
        let key_f = f[i]
        let key_v = cv_nm26_cmt_gjb1_copy_vertex(simplex, i, n)
        let mut j = i - 1
        let mut stop = 0
        while stop == 0 {
            if j < 0 { stop = 1 } else {
                if f[j] > key_f {
                    f[j + 1] = f[j]
                    let prev_v = cv_nm26_cmt_gjb1_copy_vertex(simplex, j, n)
                    let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, j + 1, n, prev_v)
                    j = j - 1
                } else { stop = 1 }
            }
        }
        f[j + 1] = key_f
        let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, j + 1, n, key_v)
        i = i + 1
    }
    return 0
}

fn cv_uccsd_cmt_gjb1_nm(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 26
    let n_vert = n + 1
    let mut simplex = []
    let mut z = 0
    while z < n_vert * n { simplex = simplex.push(0.0); z = z + 1 }
    let mut v = 1
    while v < n_vert { simplex[v * n + (v - 1)] = initial_step; v = v + 1 }
    let mut f = []
    let mut vi = 0
    while vi < n_vert {
        let vert = cv_nm26_cmt_gjb1_copy_vertex(simplex, vi, n)
        f = f.push(cv_uccsd_cmt_gjb1_energy(vert, cache))
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = cv_nm26_cmt_gjb1_sort(simplex, f, n)
            let f_best = f[0]
            let f_worst = f[n]
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                let mut centroid = []
                let mut j = 0
                while j < n {
                    let mut acc = 0.0
                    let mut vv = 0
                    while vv < n { acc = acc + simplex[vv * n + j]; vv = vv + 1 }
                    centroid = centroid.push(acc / to_float(n))
                    j = j + 1
                }
                let worst_v = cv_nm26_cmt_gjb1_copy_vertex(simplex, n, n)
                let mut refl = []
                let mut j2 = 0
                while j2 < n { refl = refl.push(centroid[j2] + (centroid[j2] - worst_v[j2])); j2 = j2 + 1 }
                let f_refl = cv_uccsd_cmt_gjb1_energy(refl, cache)
                let f_second = f[n - 1]
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, n, n, refl)
                        f[n] = f_refl
                    } else {
                        let mut contr = []
                        let mut j3 = 0
                        while j3 < n { contr = contr.push(centroid[j3] + 0.5 * (worst_v[j3] - centroid[j3])); j3 = j3 + 1 }
                        let f_contr = cv_uccsd_cmt_gjb1_energy(contr, cache)
                        if f_contr < f_worst {
                            let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, n, n, contr)
                            f[n] = f_contr
                        } else {
                            let best_v = cv_nm26_cmt_gjb1_copy_vertex(simplex, 0, n)
                            let mut q = 1
                            while q < n_vert {
                                let mut nv = []
                                let mut j4 = 0
                                while j4 < n { nv = nv.push(best_v[j4] + 0.5 * (simplex[q * n + j4] - best_v[j4])); j4 = j4 + 1 }
                                let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, q, n, nv)
                                f[q] = cv_uccsd_cmt_gjb1_energy(nv, cache)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    let mut exp_v = []
                    let mut j5 = 0
                    while j5 < n { exp_v = exp_v.push(centroid[j5] + 2.0 * (centroid[j5] - worst_v[j5])); j5 = j5 + 1 }
                    let f_exp = cv_uccsd_cmt_gjb1_energy(exp_v, cache)
                    if f_exp < f_refl {
                        let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, n, n, exp_v)
                        f[n] = f_exp
                    } else {
                        let _ = cv_nm26_cmt_gjb1_set_vertex(simplex, n, n, refl)
                        f[n] = f_refl
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = cv_nm26_cmt_gjb1_sort(simplex, f, n)
    let best_theta = cv_nm26_cmt_gjb1_copy_vertex(simplex, 0, n)
    let out = json_parse("{}")
    out["theta"] = best_theta
    out["energy"] = f[0]
    out["n_iter"] = it
    out["converged"] = converged
    return out
}

fn main() {
    println("[qmirror/chemistry_vqe] cmt-gjb1 IN-PROCESS pure-hexa UCCSD-at-4e/4o NM (Ramp B)")
    let cache = cv_uccsd_cmt_gjb1_cache()
    let casci = uccsd_cmt_gjb1_casci_ref()
    println("  CASCI(4,4) ref = " + str(casci) + " Ha")
    // RFC 035 farr-NM (maxiter=500). At maxiter=200 the [float] NM stalls
    // around 1.9 mHa (just over chemical accuracy); RFC 035 kernels lift the
    // per-iter boxed-float retention so >200 iters fit in the 768 MB cap.
    println("  starting RFC-035 farr-NM (maxiter=500, tol=1e-9 Ha)...")
    let t0 = exec("date +%s").trim()
    let t0_i = to_int(t0)
    let r = cv_uccsd_cmt_gjb1_nm_h(cache, 0.05, 500, 0.000000001)
    let t1 = exec("date +%s").trim()
    let wall = to_float(to_int(t1) - t0_i)
    let e = to_float(r["energy"])
    let n_iter = to_int(r["n_iter"])
    let conv = to_int(r["converged"])
    let d_uha = (e - casci) * 1000000.0
    let abs_d = if d_uha < 0.0 { 0.0 - d_uha } else { d_uha }
    println("  done: " + str(n_iter) + " iter, converged=" + str(conv) + ", wall=" + str(wall) + "s")
    println("  E_VQE = " + str(e) + " Ha   |delta| = " + str(abs_d) + " uHa")
    if abs_d < 1600.0 {
        println("  -> within chemical accuracy (1.6 mHa)")
        println("__QMIRROR_CHEM_CMT_UCCSD_CMT_GJB1_4E4O_INPROC_NM__ PASS")
        return
    }
    println("__QMIRROR_CHEM_CMT_UCCSD_CMT_GJB1_4E4O_INPROC_NM__ FAIL")
}
