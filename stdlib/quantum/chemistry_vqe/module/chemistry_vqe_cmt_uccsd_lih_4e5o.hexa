fn uccsd_lih4e5o_ham_n() -> int { return 276 }
fn uccsd_lih4e5o_ham_shift() -> float { return 1.0259348796432726 }
fn uccsd_lih4e5o_casci_ref() -> float { return 0.0 - 7.865141830310413 }

fn cv_uccsd_lih4e5o_cache() -> map {
    let c = json_parse("{}")
    c["exc_param_idx"] = uccsd_lih4e5o_exc_param_idx()
    c["exc_flip"] = uccsd_lih4e5o_exc_flip_mask()
    c["exc_z"] = uccsd_lih4e5o_exc_z_mask()
    c["exc_y"] = uccsd_lih4e5o_exc_y_mask()
    c["exc_cy"] = uccsd_lih4e5o_exc_count_Y()
    c["exc_coefs"] = uccsd_lih4e5o_exc_coefs()
    c["exc_n_flat"] = uccsd_lih4e5o_n_flat()
    c["ham_flip"] = uccsd_lih4e5o_ham_flip_mask()
    c["ham_z"] = uccsd_lih4e5o_ham_z_mask()
    c["ham_y"] = uccsd_lih4e5o_ham_y_mask()
    c["ham_cy"] = uccsd_lih4e5o_ham_count_Y()
    c["ham_coefs"] = uccsd_lih4e5o_ham_coefs()
    c["ham_n"] = uccsd_lih4e5o_ham_n()
    c["ham_shift"] = uccsd_lih4e5o_ham_shift()
    return c
}

fn cv_uccsd_lih4e5o_alloc_hf() -> map {
    let re_h = farr_zeros(256)
    let im_h = farr_zeros(256)
    let _ = farr_set(re_h, 17, 1.0)
    let r = json_parse("{}")
    r["re_h"] = re_h
    r["im_h"] = im_h
    return r
}

fn cv_uccsd_lih4e5o_energy(theta: [float], cache: map) -> float {
    let st = cv_uccsd_lih4e5o_alloc_hf()
    let re_h = to_int(st["re_h"])
    let im_h = to_int(st["im_h"])
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = theta[k] * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 8)
        }
        i = i + 1
    }
    let h_flip = cache["ham_flip"]
    let h_z = cache["ham_z"]
    let h_y = cache["ham_y"]
    let h_cy = cache["ham_cy"]
    let h_coefs = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k = 0
    while k < n {
        let exp_k = farr_pauli_expectation(re_h, im_h, h_flip[k], h_z[k], h_y[k], h_cy[k], 8)
        e_op = e_op + h_coefs[k] * exp_k
        k = k + 1
    }
    let _ = farr_free(re_h)
    let _ = farr_free(im_h)
    return e_op + shift
}

// ---------------------------------------------------------------------------
// RFC 035 farr-handle variants for 4e/5o (54 params, 8-qubit, 276 Pauli):
//   cv_uccsd_lih4e5o_energy_h — reuses pre-allocated re_h/im_h (256-amp);
//   cv_uccsd_lih4e5o_nm_h     — RFC 035 farr-NM at 54-param simplex.
// ---------------------------------------------------------------------------
fn cv_uccsd_lih4e5o_energy_h(theta_h: int, re_h: int, im_h: int, cache: map) -> float {
    // Reset to HF (|00010001> on 8 qubits; idx 17 in 256-amp — matches
    // cv_uccsd_lih4e5o_alloc_hf and the module-header reference state).
    let mut z = 0
    while z < 256 {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, 17, 1.0)
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = farr_get(theta_h, k) * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 8)
        }
        i = i + 1
    }
    let h_flip = cache["ham_flip"]
    let h_z = cache["ham_z"]
    let h_y = cache["ham_y"]
    let h_cy = cache["ham_cy"]
    let h_coefs = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k2 = 0
    while k2 < n {
        let exp_k = farr_pauli_expectation(re_h, im_h, h_flip[k2], h_z[k2], h_y[k2], h_cy[k2], 8)
        e_op = e_op + h_coefs[k2] * exp_k
        k2 = k2 + 1
    }
    return e_op + shift
}

fn cv_uccsd_lih4e5o_nm_h(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 54
    let n_vert = n + 1
    let simplex_h = farr_zeros(n_vert * n)
    let f_h = farr_zeros(n_vert)
    let centroid_h = farr_zeros(n)
    let refl_h = farr_zeros(n)
    let contr_h = farr_zeros(n)
    let exp_h = farr_zeros(n)
    let worst_h = farr_zeros(n)
    let scratch_h = farr_zeros(n)
    let re_h = farr_zeros(256)
    let im_h = farr_zeros(256)
    let mut v = 1
    while v < n_vert {
        let _ = farr_set(simplex_h, v * n + (v - 1), initial_step)
        v = v + 1
    }
    let mut vi = 0
    while vi < n_vert {
        let _ = farr_vertex_copy(scratch_h, 0, simplex_h, vi, n)
        let e = cv_uccsd_lih4e5o_energy_h(scratch_h, re_h, im_h, cache)
        let _ = farr_set(f_h, vi, e)
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
            let f_best = farr_get(f_h, 0)
            let f_worst = farr_get(f_h, n)
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                let _ = farr_simplex_centroid(simplex_h, centroid_h, n, n)
                let _ = farr_vertex_copy(worst_h, 0, simplex_h, n, n)
                let _ = farr_vec_reflect(refl_h, centroid_h, worst_h, 1.0, n)
                let f_refl = cv_uccsd_lih4e5o_energy_h(refl_h, re_h, im_h, cache)
                let f_second = farr_get(f_h, n - 1)
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    } else {
                        let _ = farr_vec_blend(contr_h, centroid_h, worst_h, 0.5, n)
                        let f_contr = cv_uccsd_lih4e5o_energy_h(contr_h, re_h, im_h, cache)
                        if f_contr < f_worst {
                            let _ = farr_vertex_copy(simplex_h, n, contr_h, 0, n)
                            let _ = farr_set(f_h, n, f_contr)
                        } else {
                            let _ = farr_simplex_shrink(simplex_h, n, n_vert)
                            let mut q = 1
                            while q < n_vert {
                                let _ = farr_vertex_copy(scratch_h, 0, simplex_h, q, n)
                                let e_q = cv_uccsd_lih4e5o_energy_h(scratch_h, re_h, im_h, cache)
                                let _ = farr_set(f_h, q, e_q)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    let _ = farr_vec_reflect(exp_h, centroid_h, worst_h, 2.0, n)
                    let f_exp = cv_uccsd_lih4e5o_energy_h(exp_h, re_h, im_h, cache)
                    if f_exp < f_refl {
                        let _ = farr_vertex_copy(simplex_h, n, exp_h, 0, n)
                        let _ = farr_set(f_h, n, f_exp)
                    } else {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
    let out = json_parse("{}")
    out["energy"] = farr_get(f_h, 0)
    out["n_iter"] = it
    out["converged"] = converged
    let _ = farr_free(simplex_h); let _ = farr_free(f_h)
    let _ = farr_free(centroid_h); let _ = farr_free(refl_h)
    let _ = farr_free(contr_h); let _ = farr_free(exp_h)
    let _ = farr_free(worst_h); let _ = farr_free(scratch_h)
    let _ = farr_free(re_h); let _ = farr_free(im_h)
    return out
}

fn main() {
    println("[qmirror/chemistry_vqe] LiH 4e/5o (8-qubit) IN-PROCESS NM via RFC 034+035 (Ramp B-2 closure)")
    let cache = cv_uccsd_lih4e5o_cache()
    let casci = uccsd_lih4e5o_casci_ref()
    println("  CASCI(4,5) ref = " + str(casci) + " Ha")
    println("  starting RFC-034+035 farr-NM (n=54, maxiter=200, tol=1e-9 Ha)...")
    let t0 = exec("date +%s").trim()
    let t0_i = to_int(t0)
    let r = cv_uccsd_lih4e5o_nm_h(cache, 0.05, 200, 0.000000001)
    let t1 = exec("date +%s").trim()
    let wall = to_float(to_int(t1) - t0_i)
    let e = to_float(r["energy"])
    let n_iter = to_int(r["n_iter"])
    let conv = to_int(r["converged"])
    let d_uha = (e - casci) * 1000000.0
    let abs_d = if d_uha < 0.0 { 0.0 - d_uha } else { d_uha }
    println("  done: " + str(n_iter) + " iter, converged=" + str(conv) + ", wall=" + str(wall) + "s")
    println("  E_VQE = " + str(e) + " Ha   |delta| = " + str(abs_d) + " uHa")
    if abs_d < 1600.0 {
        println("  -> within chemical accuracy (1.6 mHa)")
        println("__QMIRROR_CHEM_CMT_UCCSD_LIH_4E5O_INPROC_NM__ PASS")
        return
    }
    println("__QMIRROR_CHEM_CMT_UCCSD_LIH_4E5O_INPROC_NM__ FAIL")
}
