fn main() {
    println("[qmirror/chemistry_vqe] 4e/4o replay — lih-validation")
    let v = chemistry_vqe_native_run_named_4e4o(
        "lih-validation", "Li 0 0 0; H 0 0 1.5474",
        lih_validation_pauli_labels(), lih_validation_pauli_coeffs(),
        lih_validation_constant_shift(), lih_validation_casci_ref(),
        lih_validation_psi_re(), lih_validation_psi_im())
    let tag = if v.verdict == "PASS" { "  ✓" } else { "  ✗" }
    println(tag + " " + v.molecule + "  " + v.verdict +
            "  n_qubits=" + str(v.n_qubits) + "  n_pauli=" + str(v.n_pauli_terms))
    println("      E_replay=" + str(v.energy_Ha) + " Ha   E_CASCI(4,4)=" + str(v.ref_energy_Ha) + " Ha")
    let abs_d = if v.delta_uHa < 0.0 { 0.0 - v.delta_uHa } else { v.delta_uHa }
    println("      |delta|=" + str(abs_d) + " uHa   wall=" + str(v.wall_seconds) + "s")
    println("      " + v.message)
    if v.verdict == "PASS" {
        println("__QMIRROR_CHEM_CMT_VQE_4E4O_LIH_VALIDATION__ PASS")
        return
    }
    println("__QMIRROR_CHEM_CMT_VQE_4E4O_LIH_VALIDATION__ FAIL")
}
