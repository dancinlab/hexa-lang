#!hexa strict
// qmirror/chemistry_vqe/module/_rfc038_smoke.hexa
//
// RFC 038 (farr_uccsd_apply) acceptance smoke — emits
//   __QMIRROR_RFC038_UCCSD_APPLY_SMOKE__ <PASS|FAIL>
// sentinel; marker on |max amp diff| <= 1e-13.
//
// Status: this harness is the acceptance test for the RFC 038 apply
// commit. It calls the `farr_uccsd_apply` builtin and the existing
// flat-Pauli loop on the same H2-STO-3G UCCSD ansatz pack with a fixed
// theta vector, and asserts per-amplitude equivalence to <= 1e-13.
//
// Pre-apply (today, hexa-lang b0a4f146): `farr_uccsd_apply` is not in
// the runtime, so the call returns -1 / crashes at codegen — smoke
// FAILs as expected. Apply RFC 038's runtime.c patch + hexa-side
// dispatch entry → smoke PASSes. The post-apply re-run is the
// kernel-vs-loop equivalence proof.
//
// Pre-requisites (already landed at hexa-lang b0a4f146):
//   - RFC 030: farr_zeros / farr_get / farr_set / farr_free        (statevec)
//   - RFC 034: farr_pauli_exp_inplace                             (loop ref)
//   - RFC 036: farr_int_array (farr_int_zeros/..)                  (NOT used here)
//   - RFC 039: ham_pack / ansatz_pack / ansatz_free                (descriptors)
//
// Test plan:
//   T1: build the H2 STO-3G UCCSD ansatz pack (4-qubit JW, 4 params,
//       1 nontrivial + 3 zero-coef params, n_flat=8 Pauli rotations).
//   T2: pack via `ansatz_pack` → ansatz_h.
//   T3: theta seed = (0.10, 0.20, 0.30, 0.40); replay via hexa-side loop.
//   T4: theta seed = (0.10, 0.20, 0.30, 0.40); replay via `farr_uccsd_apply`.
//   T5: per-amplitude diff: |re_kernel[a]-re_hexa[a]| + |im_kernel[a]-im_hexa[a]|
//       <= 1e-13 for all a in 0..15.
//   T6: random seed sweep (LCG, seed=42, 10 draws in [-pi, pi]^4):
//       each draw must pass T5.
//   T7: theta=0 sanity: kernel output must equal |HF> = |0011> = amp idx 3.
//       (HF index 3 in 4-qubit JW with 2 electrons; standard JW ordering.)
//
// @sentinel(__QMIRROR_RFC038_UCCSD_APPLY_SMOKE__ <PASS|FAIL>)

// ─── H2 STO-3G UCCSD flat-Pauli ansatz pack ──────────────────────────
//
// JW(H2 STO-3G, parity=0, spin=0) — 4 spin-orbitals → 4 qubits, 2
// electrons in |0011>. The UCCSD generator family for H2 has 1 double
// excitation T_0123 = (a†_2 a†_3 a_0 a_1 - h.c.).
// JW expansion → 8 Pauli rotations with coefficients ±0.125, on Pauli
// strings YXXX, XYXX, XXYX, XXXY, YYYX, YYXY, YXYY, XYYY (in qiskit
// little-endian label order).
//
// We pad to 4 params for the smoke (3 single-excitation parameters
// with zero coefs, just to exercise the param_idx path).
//
// The descriptors below follow the canonical mask layout used by
// `farr_pauli_exp_inplace` (RFC 034) and `ansatz_pack` (RFC 039):
//   flip  = bitmask of qubits where the Pauli is X or Y
//   z     = bitmask of qubits where the Pauli is Y or Z
//   y     = flip & z  (qubits where Pauli is Y)
//   cy    = popcount(y)
// Phase convention matches the hexa-side loop verbatim.

fn _r38_h2_param_idx() -> [int] {
    // All 8 Pauli rotations apply parameter 0 (the double excitation
    // amplitude). Params 1,2,3 are stand-ins with zero-coef rotations
    // appended below.
    return [0, 0, 0, 0, 0, 0, 0, 0,
            1, 2, 3]   // 3 zero-coef rotations to exercise the param_idx path
}

fn _r38_h2_coefs() -> [float] {
    // The 8 JW-decomposed Pauli rotations for the double excitation.
    // Standard derivation (qiskit_nature TruncatedUCC / openfermion
    // jordan_wigner) gives ±0.125 with the signs below for the
    // generator (a†_2 a†_3 a_0 a_1 - h.c.).
    return [0.125,
            0.0 - 0.125,
            0.125,
            0.0 - 0.125,
            0.0 - 0.125,
            0.125,
            0.0 - 0.125,
            0.125,
            0.0,             // zero-coef stand-in (param 1)
            0.0,             // zero-coef stand-in (param 2)
            0.0]             // zero-coef stand-in (param 3)
}

// Pauli string layouts (4-qubit, qiskit little-endian bit ordering:
// bit 0 = q0 = rightmost label char).
//
// Term 0: YXXX  → flip=1111=15  z=0001=1   y=0001=1   cy=1
// Term 1: XYXX  → flip=1111=15  z=0010=2   y=0010=2   cy=1
// Term 2: XXYX  → flip=1111=15  z=0100=4   y=0100=4   cy=1
// Term 3: XXXY  → flip=1111=15  z=1000=8   y=1000=8   cy=1
// Term 4: YYYX  → flip=1111=15  z=0111=7   y=0111=7   cy=3
// Term 5: YYXY  → flip=1111=15  z=1011=11  y=1011=11  cy=3
// Term 6: YXYY  → flip=1111=15  z=1101=13  y=1101=13  cy=3
// Term 7: XYYY  → flip=1111=15  z=1110=14  y=1110=14  cy=3
// (single-Y terms have cy=1; triple-Y terms have cy=3.)

fn _r38_h2_flip() -> [int] {
    return [15, 15, 15, 15, 15, 15, 15, 15,
            0, 0, 0]   // identity (cy=0, flip=0, z=0) for zero-coef stand-ins
}

fn _r38_h2_z() -> [int] {
    return [1, 2, 4, 8, 7, 11, 13, 14,
            0, 0, 0]
}

fn _r38_h2_y() -> [int] {
    return [1, 2, 4, 8, 7, 11, 13, 14,
            0, 0, 0]
}

fn _r38_h2_cy() -> [int] {
    return [1, 1, 1, 1, 3, 3, 3, 3,
            0, 0, 0]
}

fn _r38_h2_n_flat() -> int { return 11 }
fn _r38_h2_n_qubits() -> int { return 4 }
fn _r38_h2_n_params() -> int { return 4 }
fn _r38_h2_hf_idx() -> int { return 3 }  // |0011> (q0,q1 occupied)
fn _r38_h2_dim() -> int { return 16 }     // 2^4

// ─── Helpers ─────────────────────────────────────────────────────────

fn _r38_set_hf(re_h: int, im_h: int, dim: int, hf_idx: int) -> int {
    let mut z = 0
    while z < dim {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, hf_idx, 1.0)
    return 0
}

// Hexa-side flat-Pauli ansatz replay (the loop RFC 038 replaces).
// Mirrors cv_uccsd_lih_ansatz_h / cv_uccsd_lih4e5o_energy etc.
fn _r38_hexa_replay(re_h: int, im_h: int, theta_h: int,
                    param_idx: [int], coefs: [float],
                    flip_arr: [int], z_arr: [int], y_arr: [int], cy_arr: [int],
                    n_flat: int, n_q: int) -> int {
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = farr_get(theta_h, k) * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha,
                flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], n_q)
        }
        i = i + 1
    }
    return 0
}

// Max |re_a - re_b| + |im_a - im_b| over all amplitudes.
fn _r38_max_amp_diff(re_a: int, im_a: int, re_b: int, im_b: int, dim: int) -> float {
    let mut m = 0.0
    let mut k = 0
    while k < dim {
        let dr = farr_get(re_a, k) - farr_get(re_b, k)
        let di = farr_get(im_a, k) - farr_get(im_b, k)
        let abs_dr = if dr < 0.0 { 0.0 - dr } else { dr }
        let abs_di = if di < 0.0 { 0.0 - di } else { di }
        let s = abs_dr + abs_di
        if s > m { m = s }
        k = k + 1
    }
    return m
}

// Deterministic LCG (Numerical Recipes constants), maps to [-pi, pi].
fn _r38_lcg_next(state: int) -> int {
    return (state * 1664525 + 1013904223) % 2147483648
}

fn _r38_lcg_to_pi(state: int) -> float {
    // [0, 2^31) → [-pi, pi]
    let f = to_float(state) / 2147483648.0
    return 6.283185307179586 * f - 3.141592653589793
}

fn _r38_assert(cond: int, label: str, fail_h: int) -> int {
    if cond == 1 {
        println("  [ok] " + label)
        return 0
    }
    println("  [FAIL] " + label)
    let cur = farr_int_get(fail_h, 0)
    let _ = farr_int_set(fail_h, 0, cur + 1)
    return 1
}

// ─── Test bodies ──────────────────────────────────────────────────────

// T5 core: given a populated theta_h, compare hexa-replay vs C-kernel
// per-amplitude. Returns max diff.
fn _r38_compare_one(theta_h: int, ansatz_h: int,
                    param_idx: [int], coefs: [float],
                    flip_arr: [int], z_arr: [int], y_arr: [int], cy_arr: [int],
                    n_flat: int, n_q: int, dim: int, hf_idx: int) -> float {
    let re_a = farr_zeros(dim)
    let im_a = farr_zeros(dim)
    let re_b = farr_zeros(dim)
    let im_b = farr_zeros(dim)
    // Path A: hexa-side loop.
    let _ = _r38_set_hf(re_a, im_a, dim, hf_idx)
    let _ = _r38_hexa_replay(re_a, im_a, theta_h,
                              param_idx, coefs, flip_arr, z_arr, y_arr, cy_arr,
                              n_flat, n_q)
    // Path B: C kernel (RFC 038).
    let _ = _r38_set_hf(re_b, im_b, dim, hf_idx)
    let r = farr_uccsd_apply(re_b, im_b, theta_h, ansatz_h, n_q)
    // r should be 0 on success; if it returns -1 the kernel rejected the
    // call (pre-apply, this happens because the builtin doesn't exist
    // and codegen catches it; if codegen lets it through and it returns
    // -1, the comparison below will surface the mismatch).
    let m = _r38_max_amp_diff(re_a, im_a, re_b, im_b, dim)
    let _ = farr_free(re_a)
    let _ = farr_free(im_a)
    let _ = farr_free(re_b)
    let _ = farr_free(im_b)
    if r != 0 {
        // surface the -1 path via an obviously-FAIL diff value
        return 1.0e30
    }
    return m
}

fn _r38_t5_fixed_seed(ansatz_h: int,
                      param_idx: [int], coefs: [float],
                      flip_arr: [int], z_arr: [int], y_arr: [int], cy_arr: [int],
                      n_flat: int, n_q: int, dim: int, hf_idx: int,
                      fail_h: int) -> int {
    let theta_h = farr_zeros(4)
    let _ = farr_set(theta_h, 0, 0.10)
    let _ = farr_set(theta_h, 1, 0.20)
    let _ = farr_set(theta_h, 2, 0.30)
    let _ = farr_set(theta_h, 3, 0.40)
    let m = _r38_compare_one(theta_h, ansatz_h,
                              param_idx, coefs, flip_arr, z_arr, y_arr, cy_arr,
                              n_flat, n_q, dim, hf_idx)
    println("  T5 max_amp_diff = " + str(m))
    let ok = if m < 0.00000000000001 { 1 } else { 0 }
    // 1e-14 bound — 10× tighter than the 1e-13 acceptance criterion
    // because both paths share `_hx_pauli_exp_raw` so the diff should
    // be exactly 0 modulo any pre-coefficient reordering.
    let _ = _r38_assert(ok, "T5: kernel vs hexa-loop per-amp diff <= 1e-14 @ fixed seed", fail_h)
    let _ = farr_free(theta_h)
    return 0
}

fn _r38_t6_random_sweep(ansatz_h: int,
                        param_idx: [int], coefs: [float],
                        flip_arr: [int], z_arr: [int], y_arr: [int], cy_arr: [int],
                        n_flat: int, n_q: int, dim: int, hf_idx: int,
                        fail_h: int) -> int {
    let mut state = 42
    let theta_h = farr_zeros(4)
    let mut draw = 0
    let mut worst = 0.0
    while draw < 10 {
        let mut j = 0
        while j < 4 {
            state = _r38_lcg_next(state)
            let _ = farr_set(theta_h, j, _r38_lcg_to_pi(state))
            j = j + 1
        }
        let m = _r38_compare_one(theta_h, ansatz_h,
                                  param_idx, coefs, flip_arr, z_arr, y_arr, cy_arr,
                                  n_flat, n_q, dim, hf_idx)
        if m > worst { worst = m }
        draw = draw + 1
    }
    println("  T6 random-sweep worst max_amp_diff (10 draws) = " + str(worst))
    let ok = if worst < 0.0000000000001 { 1 } else { 0 }   // 1e-13
    let _ = _r38_assert(ok, "T6: kernel vs hexa-loop diff <= 1e-13 across 10 random seeds", fail_h)
    let _ = farr_free(theta_h)
    return 0
}

fn _r38_t7_zero_theta_sanity(ansatz_h: int,
                             n_q: int, dim: int, hf_idx: int,
                             fail_h: int) -> int {
    let theta_h = farr_zeros(4)
    // theta_h is already all-zero from farr_zeros; explicit set to be loud.
    let _ = farr_set(theta_h, 0, 0.0)
    let _ = farr_set(theta_h, 1, 0.0)
    let _ = farr_set(theta_h, 2, 0.0)
    let _ = farr_set(theta_h, 3, 0.0)
    let re_h = farr_zeros(dim)
    let im_h = farr_zeros(dim)
    let _ = _r38_set_hf(re_h, im_h, dim, hf_idx)
    let r = farr_uccsd_apply(re_h, im_h, theta_h, ansatz_h, n_q)
    // Result must still be exactly |HF>: re[hf_idx]=1, all others 0.
    let v_hf = farr_get(re_h, hf_idx)
    let abs_dev_hf = if v_hf - 1.0 < 0.0 { 1.0 - v_hf } else { v_hf - 1.0 }
    let ok_hf = if abs_dev_hf < 0.000000000000001 { 1 } else { 0 }  // 1e-15
    // Spot-check that other amps are zero.
    let mut k = 0
    let mut max_other = 0.0
    while k < dim {
        if k != hf_idx {
            let rv = farr_get(re_h, k)
            let iv = farr_get(im_h, k)
            let arv = if rv < 0.0 { 0.0 - rv } else { rv }
            let aiv = if iv < 0.0 { 0.0 - iv } else { iv }
            if arv > max_other { max_other = arv }
            if aiv > max_other { max_other = aiv }
        }
        k = k + 1
    }
    let ok_other = if max_other < 0.000000000000001 { 1 } else { 0 }  // 1e-15
    println("  T7 |re[hf]-1| = " + str(abs_dev_hf) + "  max_other_amp = " + str(max_other))
    let kernel_ok = if r == 0 { 1 } else { 0 }
    let _ = _r38_assert(kernel_ok, "T7a: farr_uccsd_apply returned 0 (success)", fail_h)
    let _ = _r38_assert(ok_hf, "T7b: theta=0 → re[hf_idx] == 1.0 (within 1e-15)", fail_h)
    let _ = _r38_assert(ok_other, "T7c: theta=0 → all non-HF amps == 0 (within 1e-15)", fail_h)
    let _ = farr_free(re_h)
    let _ = farr_free(im_h)
    let _ = farr_free(theta_h)
    return 0
}

fn _r38_emit_marker(passed: int) -> int {
    // Match the chemistry_vqe runner convention: shell `date +%s` + touch.
    let ts = exec("date +%s").trim()
    let suffix = if passed == 1 { ".marker" } else { "_FAILED.marker" }
    let path = "state/markers/_rfc038_smoke_" + ts + suffix
    let _ = exec("mkdir -p state/markers && touch '" + path + "'")
    return 0
}

fn main() -> void {
    println("__QMIRROR_RFC038_UCCSD_APPLY_SMOKE__ start")
    let fail_h = farr_int_zeros(1)

    // T1: pull the H2 STO-3G UCCSD ansatz pack descriptors.
    let param_idx = _r38_h2_param_idx()
    let coefs     = _r38_h2_coefs()
    let flip_arr  = _r38_h2_flip()
    let z_arr     = _r38_h2_z()
    let y_arr     = _r38_h2_y()
    let cy_arr    = _r38_h2_cy()
    let n_flat    = _r38_h2_n_flat()
    let n_q       = _r38_h2_n_qubits()
    let dim       = _r38_h2_dim()
    let hf_idx    = _r38_h2_hf_idx()
    let _ = _r38_assert(1, "T1: H2 STO-3G ansatz pack built (n_flat=11, n_q=4, hf_idx=3)", fail_h)

    // T2: pack via RFC 039 ansatz_pack — required pre-req for RFC 038 kernel.
    let ansatz_h = ansatz_pack(param_idx, coefs, flip_arr, z_arr, y_arr, cy_arr, hf_idx, n_q)
    let ok_pack = if ansatz_h >= 0 { 1 } else { 0 }
    let _ = _r38_assert(ok_pack, "T2: ansatz_pack returned non-neg handle (RFC 039 dep)", fail_h)

    if ok_pack == 1 {
        let _ = _r38_t5_fixed_seed(ansatz_h, param_idx, coefs,
                                    flip_arr, z_arr, y_arr, cy_arr,
                                    n_flat, n_q, dim, hf_idx, fail_h)
        let _ = _r38_t6_random_sweep(ansatz_h, param_idx, coefs,
                                      flip_arr, z_arr, y_arr, cy_arr,
                                      n_flat, n_q, dim, hf_idx, fail_h)
        let _ = _r38_t7_zero_theta_sanity(ansatz_h, n_q, dim, hf_idx, fail_h)
        let _ = ansatz_free(ansatz_h)
    } else {
        println("  [skip] T5/T6/T7 — ansatz_pack failed; RFC 039 not landed?")
    }

    let fail_count = farr_int_get(fail_h, 0)
    let _ = farr_int_free(fail_h)
    if fail_count == 0 {
        let _ = _r38_emit_marker(1)
        println("__QMIRROR_RFC038_UCCSD_APPLY_SMOKE__ PASS")
        return
    }
    let _ = _r38_emit_marker(0)
    println("  total failures: " + str(fail_count))
    println("__QMIRROR_RFC038_UCCSD_APPLY_SMOKE__ FAIL")
}
