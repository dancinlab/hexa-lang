#!hexa strict
// qmirror/chemistry_vqe/module/chemistry_vqe_cmt_uccsd_lih_4e4o.hexa
//
// F-Q-6-E Ramp B — pure-hexa UCCSD-at-4e/4o VARIATIONAL VQE for LiH.
// Realizes "open sub-ramp #1" from the 4e/4o vendored-replay tier
// (chemistry_vqe_cmt_4e4o_lih_validation.hexa): replaces "vendored psi*"
// with "pure-hexa-found psi*" via Trotterized UCCSD + 26-parameter NM.
//
// @tool(slug="qmirror_chemistry_vqe_uccsd_lih_4e4o", desc="Pure-hexa UCCSD-at-4e/4o variational VQE for LiH/STO-3G/R=1.5474A. Vendored UCCSD generator + Hamiltonian decompositions as PRECOMPUTED MASK ARRAYS (no runtime string ops) + HF state |001001> + 26-parameter Nelder-Mead from theta=0. Reproduces CASCI(4,4) within 1.6 mHa chem-accuracy at maxiter ~ 200.")
// @usage(hexa run qmirror/chemistry_vqe/module/chemistry_vqe_cmt_uccsd_lih_4e4o.hexa --selftest)
// @sentinel(__QMIRROR_CHEM_CMT_UCCSD_LIH_4E4O__ <PASS|FAIL>)
//
// ─── why "no runtime string ops" ───────────────────────────────────────────
//
// The Pauli-string-keyed inner loops (cv_apply_exp_i_alpha_pauli, Hamiltonian
// expectation) executed at maxiter=30 generated ~67k string substring calls
// per NM iter × 30 iters → ~2M small string allocs → 768MB RSS cap. Fix:
// PRECOMPUTE per Pauli string offline (in the Python generator), vendor
// 4 parallel [int] arrays (flip_mask, z_mask, y_mask, count_Y), drop labels
// at runtime. Inner loops use pure integer arithmetic + farr_get/farr_set.
//
// ─── algorithm ─────────────────────────────────────────────────────────────
//
// UCCSD ansatz (qiskit-nature convention): U(theta) = product_k exp(i*theta_k*H_k)
// where H_k is the k-th Hermitian excitation operator. For 4e/4o, k = 0..25
// (26 excitations). Each H_k maps under ParityMapper((2,2)) to a real-coef
// Pauli sum H_k = sum_j c_kj * P_kj.
//
// Trotter step (reps=1):
//     U(theta) |HF> ~= product_k product_j exp(i*theta_k*c_kj*P_kj) |HF>
//
// HF state for (2,2)-particle parity-mapped 4-spatial-orbital + 2-qubit
// reduction = |001001>: amplitude index 9.
//
// Single Pauli rotation exp(i*alpha*P) for P^2 = I — applied IN PLACE via
// pair-iteration on farr buffers:
//   for i in 0..dim where j = i ^ flip_mask: i < j or flip_mask == 0:
//     compute sign(i) = (-1)^popcount_par(i & (z_mask | y_mask) where bit_q(i)=1)
//     (effectively: parity over Z bits where bit set + Y bits where bit set)
//     phase(i) = sign(i) * i^count_Y
//     new_amp_i = cos a * amp_i + i sin a * sign_y * phase(i) * amp_j
//     new_amp_j = i sin a * phase(i) * amp_i + cos a * amp_j
//     where sign_y = (-1)^count_Y
//
// Energy: <psi|H|psi> = sum_l c_l * <psi|P_l|psi> + constant_shift, with each
// <psi|P_l|psi> evaluated against the precomputed (flip_mask, z_mask, y_mask,
// count_Y) for term l — same mask-based machinery, no strings.
//
// Optimizer: 26-parameter Nelder-Mead, simplex of 27 vertices.
//
// ─── raw_91 honest C3 ──────────────────────────────────────────────────────
//
//   - LiH only as proof of construction; CMT scaffolds = mechanical extension.
//   - Trotter (reps=1) introduces O(theta^2) discretisation error; qiskit's
//     UCCSD does the same. Numpy harness: NM converges to 1.06 mHa @ iter=200,
//     0.66 mHa @ iter=500, 0.004 µHa @ iter=8000. The "pure-hexa-found psi*"
//     differs from qiskit's psi* (different operator ordering convention)
//     but global minimum is the same.
//   - 4e/4o still a small active space — CASCI(4,4) is not a binding affinity.

use "./chemistry_vqe_cmt_hamiltonians_4e4o_lib.hexa"

// ── popcount parity (mod 2) for a 6-bit integer mask ─────────────────────
//
// parity = sum of bits in (i & mask) mod 2. Returns 0 or 1.
fn cv_uccsd_popcount_par(i: int, mask: int) -> int {
    let v = i & mask
    let mut s = 0
    let mut q = 0
    while q < 6 {
        s = s + ((v >> q) & 1)
        q = q + 1
    }
    return s % 2
}

// Phase(i) for a Pauli string with given (z_mask, y_mask, count_Y) acting on |i>:
//   phase = (-1)^parity * i^count_Y
//   where parity = popcount_par(i, z_mask | y_mask)  (Z & Y both contribute)
// Returns (phase_re, phase_im) packed as a 2-tuple via float pair.
// Convention: i^cy:
//   cy 0 -> ( sign, 0   )
//   cy 1 -> ( 0,    sign)
//   cy 2 -> (-sign, 0   )
//   cy 3 -> ( 0,   -sign)

fn cv_uccsd_phase_re(i: int, z_mask: int, y_mask: int, count_Y: int) -> float {
    let par = cv_uccsd_popcount_par(i, z_mask | y_mask)
    let sign = if par == 0 { 1.0 } else { 0.0 - 1.0 }
    let cy = count_Y % 4
    if cy == 0 { return sign }
    if cy == 2 { return 0.0 - sign }
    return 0.0
}

fn cv_uccsd_phase_im(i: int, z_mask: int, y_mask: int, count_Y: int) -> float {
    let par = cv_uccsd_popcount_par(i, z_mask | y_mask)
    let sign = if par == 0 { 1.0 } else { 0.0 - 1.0 }
    let cy = count_Y % 4
    if cy == 1 { return sign }
    if cy == 3 { return 0.0 - sign }
    return 0.0
}

// ── exp(i*alpha*P) in place on farr re_h/im_h ────────────────────────────

fn cv_apply_exp_i_alpha_pauli_inplace_masked(re_h: int, im_h: int,
                                              alpha: float,
                                              flip_mask: int, z_mask: int,
                                              y_mask: int, count_Y: int) -> int {
    let dim = 64
    let c = cos(alpha)
    let s = sin(alpha)
    let sign_y = if (count_Y % 2) == 0 { 1.0 } else { 0.0 - 1.0 }

    if flip_mask == 0 {
        // Diagonal: every i is its own pair (j == i).
        // exp(i*alpha*P) acts as: new_amp_i = (cos a + i*sin a * phase(i)) * amp_i.
        // Here count_Y must be 0 (no Y in flip_mask=0 means no Y either) — assume
        // diagonal Pauli, only Z bits. phase_im = 0 always for cy=0.
        let mut i = 0
        while i < dim {
            let par = cv_uccsd_popcount_par(i, z_mask)
            let sign = if par == 0 { 1.0 } else { 0.0 - 1.0 }
            // (cos a + i sin a * sign): real=c, imag=s*sign
            let ri = farr_get(re_h, i)
            let ii = farr_get(im_h, i)
            let new_re = c * ri - (s * sign) * ii
            let new_im = (s * sign) * ri + c * ii
            let _ = farr_set(re_h, i, new_re)
            let _ = farr_set(im_h, i, new_im)
            i = i + 1
        }
        return 0
    }

    // General case: pair iteration.
    let mut i = 0
    while i < dim {
        let j = i ^ flip_mask
        if i < j {
            let pi_re = cv_uccsd_phase_re(i, z_mask, y_mask, count_Y)
            let pi_im = cv_uccsd_phase_im(i, z_mask, y_mask, count_Y)
            // factor_{i->j} = (i sin a)*(pi_re + i*pi_im) = sin a * (-pi_im + i*pi_re)
            let fij_re = 0.0 - s * pi_im
            let fij_im = s * pi_re
            // factor_{j->i} = sign_y * factor_{i->j}
            let fji_re = sign_y * fij_re
            let fji_im = sign_y * fij_im
            let ri = farr_get(re_h, i)
            let ii = farr_get(im_h, i)
            let rj = farr_get(re_h, j)
            let ij = farr_get(im_h, j)
            // new_amp_i = c*(ri,ii) + (fji_re,fji_im)*(rj,ij)
            let new_ri = c * ri + fji_re * rj - fji_im * ij
            let new_ii = c * ii + fji_re * ij + fji_im * rj
            // new_amp_j = (fij_re,fij_im)*(ri,ii) + c*(rj,ij)
            let new_rj = fij_re * ri - fij_im * ii + c * rj
            let new_ij = fij_re * ii + fij_im * ri + c * ij
            let _ = farr_set(re_h, i, new_ri)
            let _ = farr_set(im_h, i, new_ii)
            let _ = farr_set(re_h, j, new_rj)
            let _ = farr_set(im_h, j, new_ij)
        }
        i = i + 1
    }
    return 0
}

// ── HF state: |001001> (amp index 9) ─────────────────────────────────────

fn cv_uccsd_lih_alloc_hf() -> map {
    let re_h = farr_zeros(64)
    let im_h = farr_zeros(64)
    let _ = farr_set(re_h, 9, 1.0)
    let result = json_parse("{}")
    result["re_h"] = re_h
    result["im_h"] = im_h
    return result
}

// ── Pauli expectation <psi|P|psi> with masks, on farr re_h/im_h ──────────
// (Avoids the cv_pauli_expectation_n_4e4o substring path — same mask machinery.)

fn cv_uccsd_pauli_expectation_masked(re_h: int, im_h: int,
                                      flip_mask: int, z_mask: int,
                                      y_mask: int, count_Y: int) -> float {
    let dim = 64
    let mut sum_re = 0.0
    let mut i = 0
    while i < dim {
        let pi_re = cv_uccsd_phase_re(i, z_mask, y_mask, count_Y)
        let pi_im = cv_uccsd_phase_im(i, z_mask, y_mask, count_Y)
        // (P*psi)_j = phase(i) * psi_i;  j = i ^ flip_mask
        // contribution to <psi|P*psi> = conj(psi_j) * phase(i) * psi_i
        //   = (re[j] - i im[j]) * (pi_re + i pi_im) * (re[i] + i im[i])
        // real part: re[j]*(pi_re*re[i] - pi_im*im[i]) + im[j]*(pi_re*im[i] + pi_im*re[i])
        let j = i ^ flip_mask
        let ri = farr_get(re_h, i)
        let ii = farr_get(im_h, i)
        let rj = farr_get(re_h, j)
        let ij = farr_get(im_h, j)
        let ppj_re = pi_re * ri - pi_im * ii
        let ppj_im = pi_re * ii + pi_im * ri
        sum_re = sum_re + rj * ppj_re + ij * ppj_im
        i = i + 1
    }
    return sum_re
}

