#!hexa strict
//
// _lbfgsb_smoke.hexa — falsifier smoke for the L-BFGS-B prototype.
//
// Drives `_lbfgsb_minimize` on a 10D quadratic bowl with known minimum
// at target = (0.5, -0.3, 1.1, -0.7, 0.5, -0.3, 1.1, -0.7, 0.5, -0.3).
//
// Acceptance:
//   |x_final - target|_inf < 1e-4   (parameter recovery)
//   f_final              < 1e-8    (cost at minimum)
//   converged            == 1
//
// On PASS  → emits state/markers/_lbfgsb_smoke_<ts>.marker
// On FAIL  → emits state/markers/_lbfgsb_smoke_<ts>_FAILED.marker
//
// This is the "real implementation" sentinel for RFC 039's L-BFGS-B
// prototype: the driver MUST run and converge to the analytic minimum
// of a smooth strongly-convex function before we trust it on the
// chem-VQE landscape.
//
// Runtime budget: 10-dim quadratic, m=10 history, max_iter=200 — should
// converge in 1-3 L-BFGS iters (quadratic surface, exact Newton step
// after one curvature pair). Wall-clock: < 1s on M-series.

use "./_lbfgsb_driver.hexa"

fn _lbfgsb_smoke_assert_lt(label: str, value: float, bound: float) -> int {
    if value < bound {
        println("    [PASS] " + label + " = " + str(value) + " < " + str(bound))
        return 0
    }
    println("    [FAIL] " + label + " = " + str(value) + " >= " + str(bound))
    return 1
}

fn main() {
    println("[qmirror/chemistry_vqe] L-BFGS-B smoke — 10D quadratic bowl (RFC 039 prototype)")
    let n = 10
    let target = _lbfgsb_target_quadratic(n)
    println("  target: " + str(target))

    // Start from x0 = (1.0, 1.0, ..., 1.0) — well away from target.
    let mut x0 = []
    let mut lower = []
    let mut upper = []
    let mut k = 0
    while k < n {
        x0 = x0.push(1.0)
        lower = lower.push(0.0 - 10.0)
        upper = upper.push(10.0)
        k = k + 1
    }

    let t_start = exec("date +%s").trim()
    let t_start_i = to_int(t_start)

    let result = _lbfgsb_minimize(n, x0, lower, upper,
                                   10,             // m (history)
                                   200,            // max_iter
                                   0.0000001,      // g_tol = 1e-7
                                   0.000000001,    // f_tol = 1e-9
                                   0)              // problem_id = quadratic

    let t_end = exec("date +%s").trim()
    let wall = to_float(to_int(t_end) - t_start_i)

    let x_final = result["x"]
    let f_final = to_float(result["f"])
    let n_iter = to_int(result["n_iter"])
    let n_feval = to_int(result["n_feval"])
    let n_geval = to_int(result["n_geval"])
    let converged = to_int(result["converged"])
    let grad_inf = to_float(result["grad_inf"])
    let status_str = result["status"]

    println("")
    println("  result:")
    println("    status     = " + str(status_str))
    println("    n_iter     = " + str(n_iter))
    println("    n_feval    = " + str(n_feval))
    println("    n_geval    = " + str(n_geval))
    println("    converged  = " + str(converged))
    println("    grad_inf   = " + str(grad_inf))
    println("    f_final    = " + str(f_final))
    println("    wall       = " + str(wall) + "s")
    println("    x_final    = " + str(x_final))

    // Compute |x_final - target|_inf
    let mut diff_inf = 0.0
    let mut i = 0
    while i < n {
        let d = x_final[i] - target[i]
        let ad = if d < 0.0 { 0.0 - d } else { d }
        if ad > diff_inf { diff_inf = ad }
        i = i + 1
    }
    println("    |x - target|_inf = " + str(diff_inf))

    let mut fail_count = 0
    fail_count = fail_count + _lbfgsb_smoke_assert_lt("|x - target|_inf", diff_inf, 0.0001)
    fail_count = fail_count + _lbfgsb_smoke_assert_lt("f_final",          f_final,  0.00000001)
    if converged == 1 {
        println("    [PASS] converged == 1")
    } else {
        println("    [FAIL] converged != 1 (status=" + str(status_str) + ")")
        fail_count = fail_count + 1
    }

    let ts = exec("date +%s").trim()
    let qm_root = env("QMIRROR_ROOT")
    let root = if qm_root.len() > 0 { qm_root } else {
        exec("pwd").trim()
    }
    let marker_dir = root + "/state/markers"
    exec("mkdir -p " + marker_dir + " 2>/dev/null")
    let marker_name = if fail_count == 0 {
        "_lbfgsb_smoke_" + ts + ".marker"
    } else {
        "_lbfgsb_smoke_" + ts + "_FAILED.marker"
    }
    let marker_path = marker_dir + "/" + marker_name
    let body = "[qmirror/chemistry_vqe/_lbfgsb_smoke] " +
               "status=" + str(status_str) +
               " converged=" + str(converged) +
               " f_final=" + str(f_final) +
               " grad_inf=" + str(grad_inf) +
               " diff_inf=" + str(diff_inf) +
               " n_iter=" + str(n_iter) +
               " n_feval=" + str(n_feval) +
               " n_geval=" + str(n_geval) +
               " wall=" + str(wall) + "s"
    let _w = exec("echo '" + body + "' > '" + marker_path + "'")
    println("")
    if fail_count == 0 {
        println("  marker:   " + marker_path)
        println("__QMIRROR_LBFGSB_SMOKE__ PASS")
    } else {
        println("  marker:   " + marker_path)
        println("__QMIRROR_LBFGSB_SMOKE__ FAIL (" + str(fail_count) + " failures)")
    }
}
