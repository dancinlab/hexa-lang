fn uccsd_lih_4e6o_ham_n() -> int { return 631 }
fn uccsd_lih_4e6o_ham_shift() -> float { return 1.0259348796432726 }
fn uccsd_lih_4e6o_casci_ref() -> float { return 0.0 - 7.882762236781015 }

fn _uccsd_lih_4e6o_pack(h: int, src: [int], n: int) -> int {
    let mut k = 0
    while k < n {
        let _ = farr_int_set(h, k, src[k])
        k = k + 1
    }
    return n
}

fn cv_uccsd_lih_4e6o_cache() -> map {
    let m = json_parse("{}")
    m["exc_param_idx"] = uccsd_lih_4e6o_exc_param_idx()
    m["exc_flip"]      = uccsd_lih_4e6o_exc_flip_mask()
    m["exc_z"]         = uccsd_lih_4e6o_exc_z_mask()
    m["exc_y"]         = uccsd_lih_4e6o_exc_y_mask()
    m["exc_cy"]        = uccsd_lih_4e6o_exc_count_Y()
    m["exc_coefs"]     = uccsd_lih_4e6o_exc_coefs()
    m["exc_n_flat"]    = uccsd_lih_4e6o_n_flat()
    let n = uccsd_lih_4e6o_ham_n()
    let ham_flip_h = farr_int_zeros(n)
    let ham_z_h    = farr_int_zeros(n)
    let ham_y_h    = farr_int_zeros(n)
    let ham_cy_h   = farr_int_zeros(n)
    let _ = _uccsd_lih_4e6o_pack(ham_flip_h, uccsd_lih_4e6o_ham_flip_mask(), n)
    let _ = _uccsd_lih_4e6o_pack(ham_z_h,    uccsd_lih_4e6o_ham_z_mask(), n)
    let _ = _uccsd_lih_4e6o_pack(ham_y_h,    uccsd_lih_4e6o_ham_y_mask(), n)
    let _ = _uccsd_lih_4e6o_pack(ham_cy_h,   uccsd_lih_4e6o_ham_count_Y(), n)
    let exp_buf_h  = farr_zeros(n)
    m["ham_flip_h"]   = ham_flip_h
    m["ham_z_h"]      = ham_z_h
    m["ham_y_h"]      = ham_y_h
    m["ham_cy_h"]     = ham_cy_h
    m["ham_exp_buf"]  = exp_buf_h
    m["ham_coefs"]    = uccsd_lih_4e6o_ham_coefs()
    m["ham_n"]        = n
    m["ham_shift"]    = uccsd_lih_4e6o_ham_shift()
    return m
}

fn cv_uccsd_lih_4e6o_cache_free(c: map) -> int {
    let _ = farr_int_free(to_int(c["ham_flip_h"]))
    let _ = farr_int_free(to_int(c["ham_z_h"]))
    let _ = farr_int_free(to_int(c["ham_y_h"]))
    let _ = farr_int_free(to_int(c["ham_cy_h"]))
    let _ = farr_free(to_int(c["ham_exp_buf"]))
    return 0
}

fn cv_uccsd_lih_4e6o_energy_h(theta_h: int, re_h: int, im_h: int, cache: map) -> float {
    let mut z = 0
    while z < 1024 {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, 33, 1.0)
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = farr_get(theta_h, k) * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 10)
        }
        i = i + 1
    }
    // RFC 036 packed-handle + RFC 037 batch — collapses the N-term
    // Hamiltonian expectation into ONE C call.
    let ham_flip_h = to_int(cache["ham_flip_h"])
    let ham_z_h    = to_int(cache["ham_z_h"])
    let ham_y_h    = to_int(cache["ham_y_h"])
    let ham_cy_h   = to_int(cache["ham_cy_h"])
    let exp_buf_h  = to_int(cache["ham_exp_buf"])
    let h_coefs    = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let _ = farr_pauli_expectation_batch(re_h, im_h,
                                          ham_flip_h, ham_z_h, ham_y_h, ham_cy_h,
                                          n, exp_buf_h, 10)
    let mut e_op = 0.0
    let mut k2 = 0
    while k2 < n {
        e_op = e_op + h_coefs[k2] * farr_get(exp_buf_h, k2)
        k2 = k2 + 1
    }
    return e_op + shift
}

fn cv_uccsd_lih_4e6o_nm_h(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 92
    let n_vert = n + 1
    let simplex_h = farr_zeros(n_vert * n)
    let f_h = farr_zeros(n_vert)
    let centroid_h = farr_zeros(n)
    let refl_h = farr_zeros(n)
    let contr_h = farr_zeros(n)
    let exp_h = farr_zeros(n)
    let worst_h = farr_zeros(n)
    let scratch_h = farr_zeros(n)
    let re_h = farr_zeros(1024)
    let im_h = farr_zeros(1024)
    let mut v = 1
    while v < n_vert {
        let _ = farr_set(simplex_h, v * n + (v - 1), initial_step)
        v = v + 1
    }
    let mut vi = 0
    while vi < n_vert {
        let _ = farr_vertex_copy(scratch_h, 0, simplex_h, vi, n)
        let e = cv_uccsd_lih_4e6o_energy_h(scratch_h, re_h, im_h, cache)
        let _ = farr_set(f_h, vi, e)
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
            let f_best = farr_get(f_h, 0)
            let f_worst = farr_get(f_h, n)
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                let _ = farr_simplex_centroid(simplex_h, centroid_h, n, n)
                let _ = farr_vertex_copy(worst_h, 0, simplex_h, n, n)
                let _ = farr_vec_reflect(refl_h, centroid_h, worst_h, 1.0, n)
                let f_refl = cv_uccsd_lih_4e6o_energy_h(refl_h, re_h, im_h, cache)
                let f_second = farr_get(f_h, n - 1)
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    } else {
                        let _ = farr_vec_blend(contr_h, centroid_h, worst_h, 0.5, n)
                        let f_contr = cv_uccsd_lih_4e6o_energy_h(contr_h, re_h, im_h, cache)
                        if f_contr < f_worst {
                            let _ = farr_vertex_copy(simplex_h, n, contr_h, 0, n)
                            let _ = farr_set(f_h, n, f_contr)
                        } else {
                            let _ = farr_simplex_shrink(simplex_h, n, n_vert)
                            let mut q = 1
                            while q < n_vert {
                                let _ = farr_vertex_copy(scratch_h, 0, simplex_h, q, n)
                                let e_q = cv_uccsd_lih_4e6o_energy_h(scratch_h, re_h, im_h, cache)
                                let _ = farr_set(f_h, q, e_q)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    let _ = farr_vec_reflect(exp_h, centroid_h, worst_h, 2.0, n)
                    let f_exp = cv_uccsd_lih_4e6o_energy_h(exp_h, re_h, im_h, cache)
                    if f_exp < f_refl {
                        let _ = farr_vertex_copy(simplex_h, n, exp_h, 0, n)
                        let _ = farr_set(f_h, n, f_exp)
                    } else {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
    let out = json_parse("{}")
    out["energy"] = farr_get(f_h, 0)
    out["n_iter"] = it
    out["converged"] = converged
    let _ = farr_free(simplex_h); let _ = farr_free(f_h)
    let _ = farr_free(centroid_h); let _ = farr_free(refl_h)
    let _ = farr_free(contr_h); let _ = farr_free(exp_h)
    let _ = farr_free(worst_h); let _ = farr_free(scratch_h)
    let _ = farr_free(re_h); let _ = farr_free(im_h)
    return out
}

fn main() {
    println("[qmirror/chemistry_vqe] lih 4e/6o (10-qubit) IN-PROCESS NM via RFC 034+035+036+037 (Ramp B-3)")
    let cache = cv_uccsd_lih_4e6o_cache()
    let casci = uccsd_lih_4e6o_casci_ref()
    println("  CASCI(4,6) ref = " + str(casci) + " Ha")
    println("  starting farr-NM (n=92, maxiter=2000, tol=1e-9 Ha)...")
    println("  note: needs HEXA_MEM_CAP_MB=2048 (or higher) at this iter")
    let t0 = exec("date +%s").trim()
    let t0_i = to_int(t0)
    let r = cv_uccsd_lih_4e6o_nm_h(cache, 0.05, 2000, 0.000000001)
    let t1 = exec("date +%s").trim()
    let wall = to_float(to_int(t1) - t0_i)
    let e = to_float(r["energy"])
    let n_iter = to_int(r["n_iter"])
    let conv = to_int(r["converged"])
    let d_uha = (e - casci) * 1000000.0
    let abs_d = if d_uha < 0.0 { 0.0 - d_uha } else { d_uha }
    println("  done: " + str(n_iter) + " iter, converged=" + str(conv) + ", wall=" + str(wall) + "s")
    println("  E_VQE = " + str(e) + " Ha   |delta| = " + str(abs_d) + " uHa")
    let _ = cv_uccsd_lih_4e6o_cache_free(cache)
    if abs_d < 1600.0 {
        println("  -> within chemical accuracy (1.6 mHa)")
        println("__QMIRROR_CHEM_CMT_UCCSD_LIH_4E6O_INPROC_NM__ PASS")
        return
    }
    println("__QMIRROR_CHEM_CMT_UCCSD_LIH_4E6O_INPROC_NM__ FAIL")
}
