#!hexa strict
//
// _adapt_vqe_driver_4e5o.hexa — pure-hexa ADAPT-VQE driver for 4e/5o tier.
//
// Sister module to `_adapt_vqe_driver.hexa` (the 4e/4o driver). Same
// algorithm — greedy Grimsley-2019 ADAPT-VQE with FD-gradient pool
// screening and inner L-BFGS-B re-optimization — but specialized to
// 4e/5o geometry:
//
//   - n_q       = 8 qubits  (vs 6 for 4e/4o)
//   - dim       = 256 amps  (vs 64 for 4e/4o)
//   - hf_idx    = 17        (|00010001>; matches cv_uccsd_*4e5o_alloc_hf)
//   - pool_size = 54 ops    (UCCSD 4e/5o pool; vs 26 for 4e/4o)
//   - n_flat    = 360       (vs 152 for 4e/4o; ~7 factors per op)
//   - n_ham     = 276 (LiH) / 876 (CMT) Pauli terms
//
// The 4e/5o tier holds for LiH 4e/5o AND all 5 CMT scaffolds (clc1, sar1,
// mfn2, hd6, gjb1) — they all share (n_q, dim, hf_idx, n_params,
// n_flat). Only the cache contents (Hamiltonian coefficients + excitation
// masks) differ. So `adapt_vqe_4e5o(cache, ...)` is cache-polymorphic:
// each per-molecule scaffold passes its own `cv_uccsd_<name>4e5o_cache()`.
//
// Public surface:
//   fn adapt_vqe_4e5o(cache, max_ops, grad_tol, energy_tol) -> map
//     returns {
//       "energy"        : float,   final E_VQE (Ha)
//       "n_ops_selected": int,     # operators picked
//       "selected_ops"  : [int],   pool indices of picked ops, in order
//       "iters_per_step": [int],   inner-L-BFGS-B iter count per step
//       "grad_at_pick"  : [float], |g_k| of the picked op at each step
//       "energy_per_step":[float], E after re-optimizing each step
//     }
//
// Why a parallel module instead of generalizing `_adapt_vqe_driver`?
// The 4e/4o driver hard-codes (dim=64, hf_idx=9) inside cv_adapt_reset_hf
// and reuses the `_4e4o.hexa` cache import. Replicating with 4e/5o
// constants is a 3-character delta in `cv_adapt_reset_hf_4e5o` plus
// renamed entry points — straightforward, keeps the 4e/4o closure
// (LiH K=10, |Δ|=0.043 µHa, 17s) bit-stable, and avoids any "did we
// regress the proven case?" question. The driver factoring (single
// generic with dim/hf_idx args) is a future refactor.
//
// Notes on the FD vs PS-grad swap:
//   FD (central, h=1e-4) drives ADAPT operator selection to ~1e-8
//   precision — accurate enough since ADAPT only needs gradient sign
//   and rough magnitude. PS-grad via RFC 039 requires dynamic
//   `ansatz_pack` rebuilds after every op selection (see the TODO note
//   in `_adapt_vqe_driver.hexa` lines 18-45). Closure-first: FD here.

use "./chemistry_vqe_cmt_uccsd_lih_4e5o.hexa"

// ─── ADAPT ansatz application (selected ops only, in-place) ────────────
//
// Applies operators in the order they appear in `selected_ops`. For
// each selected op s (a pool index 0..pool_size-1), runs through the
// flat-factor arrays and applies every factor with param_idx == s,
// scaling by theta_sel[i] (theta_sel[i] is the param for the i-th
// selected op). n_q passed through (8 for 4e/5o).

fn cv_adapt_ansatz_h_4e5o(re_h: int, im_h: int,
                          selected_h: int, n_sel: int,
                          theta_h: int, cache: map, n_q: int) -> int {
    let param_idx = cache["exc_param_idx"]
    let flip_arr  = cache["exc_flip"]
    let z_arr     = cache["exc_z"]
    let y_arr     = cache["exc_y"]
    let cy_arr    = cache["exc_cy"]
    let coefs     = cache["exc_coefs"]
    let n_flat    = to_int(cache["exc_n_flat"])
    let mut s = 0
    while s < n_sel {
        let op_idx = to_int(farr_get(selected_h, s))
        let theta_s = farr_get(theta_h, s)
        let mut i = 0
        while i < n_flat {
            if param_idx[i] == op_idx {
                let alpha = theta_s * coefs[i]
                let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
                if abs_a < 0.0000000000001 {
                    // skip identity
                } else {
                    let _ = farr_pauli_exp_inplace(re_h, im_h, alpha,
                        flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], n_q)
                }
            }
            i = i + 1
        }
        s = s + 1
    }
    return 0
}

// ─── Reset state to HF |00010001> (4e/5o; amp idx 17, dim 256) ─────────
//
// Hard-coded to (dim=256, hf_amp_idx=17) — the 4e/5o convention used by
// cv_uccsd_*4e5o_alloc_hf and cv_uccsd_*4e5o_energy_h across all 6 4e/5o
// caches (LiH + 5 CMT scaffolds). All share this HF on 8 qubits with
// 4 electrons in 5 orbitals under ParityMapper((2,2)) encoding.

fn cv_adapt_reset_hf_4e5o(re_h: int, im_h: int, cache: map) -> int {
    let dim = 256
    let hf_idx = 17
    let mut z = 0
    while z < dim {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, hf_idx, 1.0)
    return 0
}

// ─── Energy E(theta_sel) with current `selected` operator list ─────────

fn cv_adapt_energy_h_4e5o(theta_h: int, selected_h: int, n_sel: int,
                          state_re_h: int, state_im_h: int,
                          cache: map, n_q: int) -> float {
    let _ = cv_adapt_reset_hf_4e5o(state_re_h, state_im_h, cache)
    let _ = cv_adapt_ansatz_h_4e5o(state_re_h, state_im_h, selected_h, n_sel, theta_h, cache, n_q)
    let flip_arr = cache["ham_flip"]
    let z_arr    = cache["ham_z"]
    let y_arr    = cache["ham_y"]
    let cy_arr   = cache["ham_cy"]
    let coefs    = cache["ham_coefs"]
    let shift    = to_float(cache["ham_shift"])
    let n_h      = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k = 0
    while k < n_h {
        let exp_k = farr_pauli_expectation(state_re_h, state_im_h,
            flip_arr[k], z_arr[k], y_arr[k], cy_arr[k], n_q)
        e_op = e_op + coefs[k] * exp_k
        k = k + 1
    }
    return e_op + shift
}

// ─── pool-gradient screen ──────────────────────────────────────────────

fn cv_adapt_pool_screen_4e5o(theta_h: int, selected_h: int, n_sel: int,
                             max_ops: int, pool_size: int,
                             state_re_h: int, state_im_h: int,
                             theta_aug_h: int, selected_aug_h: int,
                             out_g_h: int,
                             cache: map, n_q: int, h: float) -> int {
    let mut i = 0
    while i < n_sel {
        let _ = farr_set(theta_aug_h, i, farr_get(theta_h, i))
        i = i + 1
    }
    let mut j = 0
    while j < n_sel {
        let _ = farr_set(selected_aug_h, j, farr_get(selected_h, j))
        j = j + 1
    }
    let mut best_op = 0 - 1
    let mut best_abs_g = 0.0 - 1.0
    let mut k = 0
    while k < pool_size {
        let mut already = 0
        let mut s = 0
        while s < n_sel {
            if to_int(farr_get(selected_h, s)) == k {
                already = 1
            }
            s = s + 1
        }
        if already == 0 {
            let _ = farr_set(selected_aug_h, n_sel, to_float(k))
            let _ = farr_set(theta_aug_h, n_sel, h)
            let e_plus = cv_adapt_energy_h_4e5o(theta_aug_h, selected_aug_h, n_sel + 1,
                                                 state_re_h, state_im_h, cache, n_q)
            let _ = farr_set(theta_aug_h, n_sel, 0.0 - h)
            let e_minus = cv_adapt_energy_h_4e5o(theta_aug_h, selected_aug_h, n_sel + 1,
                                                  state_re_h, state_im_h, cache, n_q)
            let g_k = (e_plus - e_minus) / (2.0 * h)
            let abs_g = if g_k < 0.0 { 0.0 - g_k } else { g_k }
            if abs_g > best_abs_g {
                best_abs_g = abs_g
                best_op = k
            }
        }
        k = k + 1
    }
    let _ = farr_set(out_g_h, 0, best_abs_g)
    return best_op
}

// ─── Inner L-BFGS-B helpers ────────────────────────────────────────────

fn cv_adapt_fd_grad_4e5o(theta_h: int, grad_h: int, n: int, h: float,
                         selected_h: int, n_sel: int,
                         state_re_h: int, state_im_h: int,
                         cache: map, n_q: int) -> int {
    let inv_2h = 1.0 / (2.0 * h)
    let mut k = 0
    while k < n {
        let xk = farr_get(theta_h, k)
        let _ = farr_set(theta_h, k, xk + h)
        let f_plus = cv_adapt_energy_h_4e5o(theta_h, selected_h, n_sel,
                                             state_re_h, state_im_h, cache, n_q)
        let _ = farr_set(theta_h, k, xk - h)
        let f_minus = cv_adapt_energy_h_4e5o(theta_h, selected_h, n_sel,
                                              state_re_h, state_im_h, cache, n_q)
        let _ = farr_set(theta_h, k, xk)
        let _ = farr_set(grad_h, k, (f_plus - f_minus) * inv_2h)
        k = k + 1
    }
    return 0
}

fn cv_adapt_dot_h_4e5o(a_h: int, b_h: int, n: int) -> float {
    let mut acc = 0.0
    let mut i = 0
    while i < n {
        acc = acc + farr_get(a_h, i) * farr_get(b_h, i)
        i = i + 1
    }
    return acc
}

fn cv_adapt_inf_norm_h_4e5o(v_h: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let v = farr_get(v_h, i)
        let av = if v < 0.0 { 0.0 - v } else { v }
        if av > m { m = av }
        i = i + 1
    }
    return m
}

fn cv_adapt_copy_h_4e5o(dst_h: int, src_h: int, n: int) -> int {
    let mut i = 0
    while i < n {
        let _ = farr_set(dst_h, i, farr_get(src_h, i))
        i = i + 1
    }
    return 0
}

fn cv_adapt_axpy_h_4e5o(dst_h: int, a_h: int, scale: float, b_h: int, n: int) -> int {
    let mut i = 0
    while i < n {
        let v = farr_get(a_h, i) + scale * farr_get(b_h, i)
        let _ = farr_set(dst_h, i, v)
        i = i + 1
    }
    return 0
}

fn cv_adapt_clip_h_4e5o(x_h: int, lo: float, hi: float, n: int) -> int {
    let mut i = 0
    while i < n {
        let v = farr_get(x_h, i)
        let c = if v < lo { lo } else { if v > hi { hi } else { v } }
        let _ = farr_set(x_h, i, c)
        i = i + 1
    }
    return 0
}

fn cv_adapt_two_loop_4e5o(s_hist_h: int, y_hist_h: int, rho_arr: [float],
                          m_used: int, n: int, g_h: int, gamma: float,
                          d_h: int, alpha_h: int, q_h: int) -> int {
    let mut i = 0
    while i < n {
        let _ = farr_set(q_h, i, 0.0 - farr_get(g_h, i))
        i = i + 1
    }
    let mut k = m_used - 1
    while k >= 0 {
        let mut sq = 0.0
        let mut jj = 0
        while jj < n {
            sq = sq + farr_get(s_hist_h, k * n + jj) * farr_get(q_h, jj)
            jj = jj + 1
        }
        let a = rho_arr[k] * sq
        let _ = farr_set(alpha_h, k, a)
        let mut j = 0
        while j < n {
            let qj = farr_get(q_h, j)
            let yj = farr_get(y_hist_h, k * n + j)
            let _ = farr_set(q_h, j, qj - a * yj)
            j = j + 1
        }
        k = k - 1
    }
    let mut jj2 = 0
    while jj2 < n {
        let _ = farr_set(q_h, jj2, gamma * farr_get(q_h, jj2))
        jj2 = jj2 + 1
    }
    let mut kk = 0
    while kk < m_used {
        let mut yr = 0.0
        let mut jj3 = 0
        while jj3 < n {
            yr = yr + farr_get(y_hist_h, kk * n + jj3) * farr_get(q_h, jj3)
            jj3 = jj3 + 1
        }
        let b = rho_arr[kk] * yr
        let a_kk = farr_get(alpha_h, kk)
        let mut j2 = 0
        while j2 < n {
            let qj = farr_get(q_h, j2)
            let sj = farr_get(s_hist_h, kk * n + j2)
            let _ = farr_set(q_h, j2, qj + (a_kk - b) * sj)
            j2 = j2 + 1
        }
        kk = kk + 1
    }
    let _ = cv_adapt_copy_h_4e5o(d_h, q_h, n)
    return 0
}

fn cv_adapt_line_search_4e5o(theta_h: int, d_h: int, g_h: int,
                             f_curr: float, gd_curr: float,
                             n: int,
                             x_trial_h: int, grad_h: int,
                             h_fd: float, max_trials: int,
                             selected_h: int, n_sel: int,
                             state_re_h: int, state_im_h: int,
                             cache: map, n_q: int) -> map {
    let c1 = 0.0001
    let mut t = 1.0
    let mut trials = 0
    let mut best_f = 1e308
    let mut best_t = 0.0
    let mut accepted = 0
    let mut n_feval = 0
    while trials < max_trials && accepted == 0 {
        let _ = cv_adapt_axpy_h_4e5o(x_trial_h, theta_h, t, d_h, n)
        let _ = cv_adapt_clip_h_4e5o(x_trial_h, 0.0 - 3.141592653589793, 3.141592653589793, n)
        let f_t = cv_adapt_energy_h_4e5o(x_trial_h, selected_h, n_sel,
                                          state_re_h, state_im_h, cache, n_q)
        n_feval = n_feval + 1
        if f_t < best_f { best_f = f_t; best_t = t }
        let armijo_rhs = f_curr + c1 * t * gd_curr
        if f_t <= armijo_rhs {
            accepted = 1
        } else {
            t = t * 0.5
            trials = trials + 1
        }
    }
    let chosen_t = if accepted == 1 { t } else { best_t }
    let _ = cv_adapt_axpy_h_4e5o(x_trial_h, theta_h, chosen_t, d_h, n)
    let _ = cv_adapt_clip_h_4e5o(x_trial_h, 0.0 - 3.141592653589793, 3.141592653589793, n)
    let f_new = cv_adapt_energy_h_4e5o(x_trial_h, selected_h, n_sel,
                                        state_re_h, state_im_h, cache, n_q)
    n_feval = n_feval + 1
    let _ = cv_adapt_copy_h_4e5o(theta_h, x_trial_h, n)
    let _ = cv_adapt_fd_grad_4e5o(theta_h, grad_h, n, h_fd,
                                   selected_h, n_sel,
                                   state_re_h, state_im_h, cache, n_q)
    let out = json_parse("{}")
    out["f"] = f_new
    out["t"] = chosen_t
    out["accepted"] = accepted
    out["n_feval"] = n_feval
    return out
}

fn cv_adapt_lbfgsb_minimize_4e5o(theta_h: int, n: int,
                                  m: int, max_iter: int,
                                  g_tol: float, f_tol: float,
                                  selected_h: int, n_sel: int,
                                  state_re_h: int, state_im_h: int,
                                  cache: map, n_q: int) -> map {
    let g_h        = farr_zeros(n)
    let g_prev_h   = farr_zeros(n)
    let d_h        = farr_zeros(n)
    let q_h        = farr_zeros(n)
    let alpha_h    = farr_zeros(m)
    let s_hist_h   = farr_zeros(m * n)
    let y_hist_h   = farr_zeros(m * n)
    let x_trial_h  = farr_zeros(n)
    let x_before_h = farr_zeros(n)

    let _ = cv_adapt_clip_h_4e5o(theta_h, 0.0 - 3.141592653589793, 3.141592653589793, n)
    let mut f_curr = cv_adapt_energy_h_4e5o(theta_h, selected_h, n_sel,
                                             state_re_h, state_im_h, cache, n_q)
    let _ = cv_adapt_fd_grad_4e5o(theta_h, g_h, n, 0.00001,
                                   selected_h, n_sel,
                                   state_re_h, state_im_h, cache, n_q)

    let mut rho_arr = []
    let mut h_init = 0
    while h_init < m { rho_arr = rho_arr.push(0.0); h_init = h_init + 1 }
    let mut m_used = 0
    let mut gamma = 1.0
    let mut converged = 0
    let mut it = 0
    let mut done = 0
    while done == 0 {
        if it >= max_iter { done = 1 }
        if done == 0 {
            let g_inf = cv_adapt_inf_norm_h_4e5o(g_h, n)
            if g_inf < g_tol { converged = 1; done = 1 }
        }
        if done == 0 {
            if m_used == 0 {
                let mut j = 0
                while j < n {
                    let _ = farr_set(d_h, j, 0.0 - farr_get(g_h, j))
                    j = j + 1
                }
            } else {
                let _ = cv_adapt_two_loop_4e5o(s_hist_h, y_hist_h, rho_arr,
                                                m_used, n, g_h, gamma,
                                                d_h, alpha_h, q_h)
            }
            let gd0 = cv_adapt_dot_h_4e5o(g_h, d_h, n)
            if gd0 >= 0.0 {
                let mut j2 = 0
                while j2 < n {
                    let _ = farr_set(d_h, j2, 0.0 - farr_get(g_h, j2))
                    j2 = j2 + 1
                }
                m_used = 0
            }
            let gd = cv_adapt_dot_h_4e5o(g_h, d_h, n)
            let _ = cv_adapt_copy_h_4e5o(g_prev_h, g_h, n)
            let _ = cv_adapt_copy_h_4e5o(x_before_h, theta_h, n)
            let ls = cv_adapt_line_search_4e5o(theta_h, d_h, g_h,
                                                f_curr, gd, n,
                                                x_trial_h, g_h,
                                                0.00001, 20,
                                                selected_h, n_sel,
                                                state_re_h, state_im_h, cache, n_q)
            let f_new = to_float(ls["f"])
            let df = f_curr - f_new
            let abs_df = if df < 0.0 { 0.0 - df } else { df }
            let denom = if f_curr < 0.0 { 0.0 - f_curr } else { f_curr }
            let scale = if denom > 1.0 { denom } else { 1.0 }
            if abs_df < f_tol * scale {
                converged = 1
                done = 1
            }
            if done == 0 {
                let mut sy = 0.0
                let mut s_scratch = []
                let mut y_scratch = []
                let mut kk = 0
                while kk < n {
                    let s_k = farr_get(theta_h, kk) - farr_get(x_before_h, kk)
                    let y_k = farr_get(g_h, kk) - farr_get(g_prev_h, kk)
                    sy = sy + s_k * y_k
                    s_scratch = s_scratch.push(s_k)
                    y_scratch = y_scratch.push(y_k)
                    kk = kk + 1
                }
                if sy > 0.000000000001 {
                    let mut yy = 0.0
                    let mut kk2 = 0
                    while kk2 < n {
                        yy = yy + y_scratch[kk2] * y_scratch[kk2]
                        kk2 = kk2 + 1
                    }
                    if yy > 0.0 { gamma = sy / yy }
                    if m_used == m {
                        let mut sh = 1
                        while sh < m {
                            let mut col = 0
                            while col < n {
                                let v_s = farr_get(s_hist_h, sh * n + col)
                                let v_y = farr_get(y_hist_h, sh * n + col)
                                let _ = farr_set(s_hist_h, (sh - 1) * n + col, v_s)
                                let _ = farr_set(y_hist_h, (sh - 1) * n + col, v_y)
                                col = col + 1
                            }
                            rho_arr[sh - 1] = rho_arr[sh]
                            sh = sh + 1
                        }
                        m_used = m - 1
                    }
                    let mut wj = 0
                    while wj < n {
                        let _ = farr_set(s_hist_h, m_used * n + wj, s_scratch[wj])
                        let _ = farr_set(y_hist_h, m_used * n + wj, y_scratch[wj])
                        wj = wj + 1
                    }
                    rho_arr[m_used] = 1.0 / sy
                    m_used = m_used + 1
                }
                f_curr = f_new
                it = it + 1
            }
        }
    }
    let _ = farr_free(g_h)
    let _ = farr_free(g_prev_h)
    let _ = farr_free(d_h)
    let _ = farr_free(q_h)
    let _ = farr_free(alpha_h)
    let _ = farr_free(s_hist_h)
    let _ = farr_free(y_hist_h)
    let _ = farr_free(x_trial_h)
    let _ = farr_free(x_before_h)
    let out = json_parse("{}")
    out["f"] = f_curr
    out["n_iter"] = it
    out["converged"] = converged
    return out
}

// ─── pool-size inference + outer adapt loop ────────────────────────────

fn cv_adapt_pool_size_4e5o(cache: map) -> int {
    let param_idx = cache["exc_param_idx"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut max_k = 0
    let mut i = 0
    while i < n_flat {
        if param_idx[i] > max_k { max_k = param_idx[i] }
        i = i + 1
    }
    return max_k + 1
}

fn adapt_vqe_4e5o(cache: map, max_ops: int, grad_tol: float, energy_tol: float) -> map {
    // 4e/5o: 8 qubits, dim=256, hf_idx=17 (encoded in cv_adapt_reset_hf_4e5o).
    let n_q = 8
    let dim = 256
    let pool_size = cv_adapt_pool_size_4e5o(cache)

    let state_re_h = farr_zeros(dim)
    let state_im_h = farr_zeros(dim)
    let selected_h = farr_zeros(max_ops)
    let theta_h    = farr_zeros(max_ops)
    let theta_aug_h    = farr_zeros(max_ops)
    let selected_aug_h = farr_zeros(max_ops)
    let out_g_h = farr_zeros(1)

    let mut n_sel = 0
    let mut selected_list = []
    let mut iters_list = []
    let mut grad_list = []
    let mut energy_list = []

    let e_hf = cv_adapt_energy_h_4e5o(theta_h, selected_h, 0,
                                       state_re_h, state_im_h, cache, n_q)
    println("  ADAPT init: E(HF) = " + str(e_hf) + " Ha, pool_size = " + str(pool_size))

    let mut final_energy = e_hf
    let mut stop = 0
    while stop == 0 {
        if n_sel >= max_ops { stop = 1 }
        if n_sel >= pool_size { stop = 1 }
        if stop == 0 {
            let pick = cv_adapt_pool_screen_4e5o(theta_h, selected_h, n_sel,
                                                  max_ops, pool_size,
                                                  state_re_h, state_im_h,
                                                  theta_aug_h, selected_aug_h,
                                                  out_g_h, cache, n_q, 0.0001)
            let max_g = farr_get(out_g_h, 0)
            println("    step " + str(n_sel + 1) + ": max |g_k| = " + str(max_g) + " on pool[" + str(pick) + "]")
            if pick < 0 { stop = 1 }
            if stop == 0 {
                if max_g < grad_tol {
                    println("    → max |g| < grad_tol=" + str(grad_tol) + " — converged.")
                    stop = 1
                }
            }
            if stop == 0 {
                let _ = farr_set(selected_h, n_sel, to_float(pick))
                let _ = farr_set(theta_h, n_sel, 0.0)
                n_sel = n_sel + 1
                selected_list = selected_list.push(pick)
                grad_list = grad_list.push(max_g)
                let res = cv_adapt_lbfgsb_minimize_4e5o(theta_h, n_sel,
                                                        10, 50,
                                                        0.000001, 0.000000001,
                                                        selected_h, n_sel,
                                                        state_re_h, state_im_h,
                                                        cache, n_q)
                let e_new = to_float(res["f"])
                let it_new = to_int(res["n_iter"])
                let conv_new = to_int(res["converged"])
                iters_list = iters_list.push(it_new)
                energy_list = energy_list.push(e_new)
                let de = final_energy - e_new
                let abs_de = if de < 0.0 { 0.0 - de } else { de }
                println("      L-BFGS-B: iter=" + str(it_new) + " conv=" + str(conv_new) +
                        " E=" + str(e_new) + " ΔE=" + str(abs_de * 1000000.0) + " uHa")
                final_energy = e_new
                if abs_de < energy_tol {
                    println("    → ΔE < energy_tol=" + str(energy_tol) + " — converged.")
                    stop = 1
                }
            }
        }
    }

    let mut sel_out = selected_list

    let _ = farr_free(state_re_h)
    let _ = farr_free(state_im_h)
    let _ = farr_free(selected_h)
    let _ = farr_free(theta_h)
    let _ = farr_free(theta_aug_h)
    let _ = farr_free(selected_aug_h)
    let _ = farr_free(out_g_h)

    let out = json_parse("{}")
    out["energy"] = final_energy
    out["n_ops_selected"] = n_sel
    out["selected_ops"] = sel_out
    out["iters_per_step"] = iters_list
    out["grad_at_pick"] = grad_list
    out["energy_per_step"] = energy_list
    return out
}
