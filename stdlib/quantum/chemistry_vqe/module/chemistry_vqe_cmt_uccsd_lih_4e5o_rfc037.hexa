fn _lih5o_ham_n() -> int { return 276 }
fn _lih5o_ham_shift() -> float { return 1.0259348796432726 }
fn _lih5o_casci_ref() -> float { return 0.0 - 7.865141830310413 }

// ─── Cache (legacy + RFC 037 batch pack) ──────────────────────────────

// Legacy cache (per-term Pauli loop reference path — unchanged from
// chemistry_vqe_cmt_uccsd_lih_4e5o.hexa). Used by the in-module
// reference energy fn for the sentinel comparison.
fn cv_lih5o_cache_legacy() -> map {
    let c = json_parse("{}")
    c["exc_param_idx"] = _lih5o_exc_param_idx()
    c["exc_flip"] = _lih5o_exc_flip_mask()
    c["exc_z"]    = _lih5o_exc_z_mask()
    c["exc_y"]    = _lih5o_exc_y_mask()
    c["exc_cy"]   = _lih5o_exc_count_Y()
    c["exc_coefs"] = _lih5o_exc_coefs()
    c["exc_n_flat"] = _lih5o_n_flat()
    c["ham_flip"] = _lih5o_ham_flip_mask()
    c["ham_z"]    = _lih5o_ham_z_mask()
    c["ham_y"]    = _lih5o_ham_y_mask()
    c["ham_cy"]   = _lih5o_ham_count_Y()
    c["ham_coefs"] = _lih5o_ham_coefs()
    c["ham_n"]    = _lih5o_ham_n()
    c["ham_shift"] = _lih5o_ham_shift()
    return c
}

// Populate a farr_int handle from an [int] literal using set-loop. The
// runtime's `farr_int_fill_from_array` builtin is currently broken on
// the running hexa interp (per `_rfc036_smoke.hexa::T5` — `arr_v.tag=10`
// the array is shadowed as a valstruct), so we bypass it with a manual
// set-loop. Cost: paid ONCE per cache build, not per energy eval.
fn _lih5o_fill_farr_int(h: int, src: [int], n: int) -> int {
    let mut k = 0
    while k < n {
        let _ = farr_int_set(h, k, src[k])
        k = k + 1
    }
    return n
}

// RFC 037 cache — same content as legacy, but the 4 Hamiltonian mask
// tables are pre-packed into farr_int handles + a reusable
// `ham_exp_buf` (farr of length n_ham) is allocated for the batch
// kernel's output. Built ONCE per NM run; the per-eval cost amortizes.
//
// Caller MUST eventually `cv_lih5o_cache_rfc037_free` to release the 5
// farr handles, or just leak them at process exit (acceptable for a
// single-shot in-process NM run).
fn cv_lih5o_cache_rfc037() -> map {
    let c = cv_lih5o_cache_legacy()
    let n = _lih5o_ham_n()
    let ham_flip_h = farr_int_zeros(n)
    let ham_z_h    = farr_int_zeros(n)
    let ham_y_h    = farr_int_zeros(n)
    let ham_cy_h   = farr_int_zeros(n)
    let _ = _lih5o_fill_farr_int(ham_flip_h, _lih5o_ham_flip_mask(), n)
    let _ = _lih5o_fill_farr_int(ham_z_h,    _lih5o_ham_z_mask(), n)
    let _ = _lih5o_fill_farr_int(ham_y_h,    _lih5o_ham_y_mask(), n)
    let _ = _lih5o_fill_farr_int(ham_cy_h,   _lih5o_ham_count_Y(), n)
    let exp_buf_h = farr_zeros(n)
    c["ham_flip_h"] = ham_flip_h
    c["ham_z_h"]    = ham_z_h
    c["ham_y_h"]    = ham_y_h
    c["ham_cy_h"]   = ham_cy_h
    c["ham_exp_buf"] = exp_buf_h
    return c
}

fn cv_lih5o_cache_rfc037_free(c: map) -> int {
    let _ = farr_int_free(to_int(c["ham_flip_h"]))
    let _ = farr_int_free(to_int(c["ham_z_h"]))
    let _ = farr_int_free(to_int(c["ham_y_h"]))
    let _ = farr_int_free(to_int(c["ham_cy_h"]))
    let _ = farr_free(to_int(c["ham_exp_buf"]))
    return 0
}

// ─── Energy functions ────────────────────────────────────────────────

// LEGACY: per-term `farr_pauli_expectation` loop (276 boxed kernel
// calls per eval). Carbon-copy of `cv_uccsd_lih4e5o_energy_h` from
// the parent module — preserved as the comparison oracle.
fn cv_lih5o_energy_legacy_h(theta_h: int, re_h: int, im_h: int, cache: map) -> float {
    let mut z = 0
    while z < 256 {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, 17, 1.0)
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = farr_get(theta_h, k) * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 8)
        }
        i = i + 1
    }
    let h_flip = cache["ham_flip"]
    let h_z = cache["ham_z"]
    let h_y = cache["ham_y"]
    let h_cy = cache["ham_cy"]
    let h_coefs = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k2 = 0
    while k2 < n {
        let exp_k = farr_pauli_expectation(re_h, im_h, h_flip[k2], h_z[k2], h_y[k2], h_cy[k2], 8)
        e_op = e_op + h_coefs[k2] * exp_k
        k2 = k2 + 1
    }
    return e_op + shift
}

// MIGRATED (RFC 037 hybrid): identical UCCSD ansatz loop (the ansatz
// migration is deferred until RFC 038 ansatz_pack is unblocked), but
// the Hamiltonian expectation step is collapsed into ONE
// `farr_pauli_expectation_batch` C call.
//
// Per-eval call count:
//   legacy : 276 boxed `farr_pauli_expectation` + 276 boxed coef/get
//   batch  :   1 boxed `farr_pauli_expectation_batch`
//            + 276 boxed `farr_get` (still a hexa-side accumulator)
//            + 276 `coefs[k]` reads (boxed [float] index — unchanged)
//
// The 276→1 collapse on the Pauli-kernel dispatch side is the
// dominant win.
fn cv_lih5o_energy_rfc037_h(theta_h: int, re_h: int, im_h: int, cache: map) -> float {
    let mut z = 0
    while z < 256 {
        let _ = farr_set(re_h, z, 0.0)
        let _ = farr_set(im_h, z, 0.0)
        z = z + 1
    }
    let _ = farr_set(re_h, 17, 1.0)
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = farr_get(theta_h, k) * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 8)
        }
        i = i + 1
    }
    // RFC 037 batch Hamiltonian expectation — ONE C call replaces
    // the legacy 276-iter while loop.
    let ham_flip_h = to_int(cache["ham_flip_h"])
    let ham_z_h    = to_int(cache["ham_z_h"])
    let ham_y_h    = to_int(cache["ham_y_h"])
    let ham_cy_h   = to_int(cache["ham_cy_h"])
    let exp_buf_h  = to_int(cache["ham_exp_buf"])
    let h_coefs    = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let _ = farr_pauli_expectation_batch(re_h, im_h,
                                          ham_flip_h, ham_z_h, ham_y_h, ham_cy_h,
                                          n, exp_buf_h, 8)
    let mut e_op = 0.0
    let mut k2 = 0
    while k2 < n {
        e_op = e_op + h_coefs[k2] * farr_get(exp_buf_h, k2)
        k2 = k2 + 1
    }
    return e_op + shift
}

// ─── Sentinel comparison harness ─────────────────────────────────────

// Deterministic LCG used to draw theta points in [-pi/8, pi/8]^54 for
// the agreement check. Keep amplitudes modest so the ansatz produces
// a meaningfully-rotated state without pathological cancellation.
fn _lih5o_lcg_next(state: int) -> int {
    return (state * 1664525 + 1013904223) % 2147483648
}

fn _lih5o_lcg_to_small(state: int) -> float {
    // [0, 2^31) → [-pi/8, pi/8]  (pi/4 wide window, ample for sanity)
    let f = to_float(state) / 2147483648.0
    return 0.7853981633974483 * f - 0.39269908169872414
}

fn _lih5o_fill_theta(theta_h: int, seed0: int) -> int {
    let mut state = seed0
    let mut j = 0
    while j < 54 {
        state = _lih5o_lcg_next(state)
        let v = _lih5o_lcg_to_small(state)
        let _ = farr_set(theta_h, j, v)
        j = j + 1
    }
    return state
}

// Run both fns at the same theta point; return |E_rfc037 - E_legacy|.
fn _lih5o_compare_one(theta_h: int, cache_legacy: map, cache_rfc037: map) -> float {
    let re_h = farr_zeros(256)
    let im_h = farr_zeros(256)
    let e_old = cv_lih5o_energy_legacy_h(theta_h, re_h, im_h, cache_legacy)
    let e_new = cv_lih5o_energy_rfc037_h(theta_h, re_h, im_h, cache_rfc037)
    let _ = farr_free(re_h)
    let _ = farr_free(im_h)
    let d = e_new - e_old
    return if d < 0.0 { 0.0 - d } else { d }
}

fn cv_lih5o_compare_harness(cache_legacy: map, cache_rfc037: map) -> float {
    let theta_h = farr_zeros(54)
    let mut worst = 0.0
    // Probe 1: theta = 0 → energy = <HF|H|HF> + shift
    let d0 = _lih5o_compare_one(theta_h, cache_legacy, cache_rfc037)
    if d0 > worst { worst = d0 }
    println("    theta=0:   |E_rfc037 - E_legacy| = " + str(d0) + " Ha")
    // Probes 2-4: random seeds 7, 13, 42 (LCG).
    let _ = _lih5o_fill_theta(theta_h, 7)
    let d1 = _lih5o_compare_one(theta_h, cache_legacy, cache_rfc037)
    if d1 > worst { worst = d1 }
    println("    seed=7:    |E_rfc037 - E_legacy| = " + str(d1) + " Ha")
    let _ = _lih5o_fill_theta(theta_h, 13)
    let d2 = _lih5o_compare_one(theta_h, cache_legacy, cache_rfc037)
    if d2 > worst { worst = d2 }
    println("    seed=13:   |E_rfc037 - E_legacy| = " + str(d2) + " Ha")
    let _ = _lih5o_fill_theta(theta_h, 42)
    let d3 = _lih5o_compare_one(theta_h, cache_legacy, cache_rfc037)
    if d3 > worst { worst = d3 }
    println("    seed=42:   |E_rfc037 - E_legacy| = " + str(d3) + " Ha")
    let _ = farr_free(theta_h)
    return worst
}

// ─── NM driver (RFC 035 farr-NM, energy fn = RFC 037 hybrid) ─────────

fn cv_lih5o_nm_rfc037_h(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 54
    let n_vert = n + 1
    let simplex_h = farr_zeros(n_vert * n)
    let f_h = farr_zeros(n_vert)
    let centroid_h = farr_zeros(n)
    let refl_h = farr_zeros(n)
    let contr_h = farr_zeros(n)
    let exp_h = farr_zeros(n)
    let worst_h = farr_zeros(n)
    let scratch_h = farr_zeros(n)
    let re_h = farr_zeros(256)
    let im_h = farr_zeros(256)
    let mut v = 1
    while v < n_vert {
        let _ = farr_set(simplex_h, v * n + (v - 1), initial_step)
        v = v + 1
    }
    let mut vi = 0
    while vi < n_vert {
        let _ = farr_vertex_copy(scratch_h, 0, simplex_h, vi, n)
        let e = cv_lih5o_energy_rfc037_h(scratch_h, re_h, im_h, cache)
        let _ = farr_set(f_h, vi, e)
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
            let f_best = farr_get(f_h, 0)
            let f_worst = farr_get(f_h, n)
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                let _ = farr_simplex_centroid(simplex_h, centroid_h, n, n)
                let _ = farr_vertex_copy(worst_h, 0, simplex_h, n, n)
                let _ = farr_vec_reflect(refl_h, centroid_h, worst_h, 1.0, n)
                let f_refl = cv_lih5o_energy_rfc037_h(refl_h, re_h, im_h, cache)
                let f_second = farr_get(f_h, n - 1)
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    } else {
                        let _ = farr_vec_blend(contr_h, centroid_h, worst_h, 0.5, n)
                        let f_contr = cv_lih5o_energy_rfc037_h(contr_h, re_h, im_h, cache)
                        if f_contr < f_worst {
                            let _ = farr_vertex_copy(simplex_h, n, contr_h, 0, n)
                            let _ = farr_set(f_h, n, f_contr)
                        } else {
                            let _ = farr_simplex_shrink(simplex_h, n, n_vert)
                            let mut q = 1
                            while q < n_vert {
                                let _ = farr_vertex_copy(scratch_h, 0, simplex_h, q, n)
                                let e_q = cv_lih5o_energy_rfc037_h(scratch_h, re_h, im_h, cache)
                                let _ = farr_set(f_h, q, e_q)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    let _ = farr_vec_reflect(exp_h, centroid_h, worst_h, 2.0, n)
                    let f_exp = cv_lih5o_energy_rfc037_h(exp_h, re_h, im_h, cache)
                    if f_exp < f_refl {
                        let _ = farr_vertex_copy(simplex_h, n, exp_h, 0, n)
                        let _ = farr_set(f_h, n, f_exp)
                    } else {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
    let out = json_parse("{}")
    out["energy"] = farr_get(f_h, 0)
    out["n_iter"] = it
    out["converged"] = converged
    let _ = farr_free(simplex_h); let _ = farr_free(f_h)
    let _ = farr_free(centroid_h); let _ = farr_free(refl_h)
    let _ = farr_free(contr_h); let _ = farr_free(exp_h)
    let _ = farr_free(worst_h); let _ = farr_free(scratch_h)
    let _ = farr_free(re_h); let _ = farr_free(im_h)
    return out
}

// Legacy NM driver — same structure, uses `cv_lih5o_energy_legacy_h`
// for the per-eval cost. Lets us measure the wall delta apples-to-apples.
fn cv_lih5o_nm_legacy_h(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 54
    let n_vert = n + 1
    let simplex_h = farr_zeros(n_vert * n)
    let f_h = farr_zeros(n_vert)
    let centroid_h = farr_zeros(n)
    let refl_h = farr_zeros(n)
    let contr_h = farr_zeros(n)
    let exp_h = farr_zeros(n)
    let worst_h = farr_zeros(n)
    let scratch_h = farr_zeros(n)
    let re_h = farr_zeros(256)
    let im_h = farr_zeros(256)
    let mut v = 1
    while v < n_vert {
        let _ = farr_set(simplex_h, v * n + (v - 1), initial_step)
        v = v + 1
    }
    let mut vi = 0
    while vi < n_vert {
        let _ = farr_vertex_copy(scratch_h, 0, simplex_h, vi, n)
        let e = cv_lih5o_energy_legacy_h(scratch_h, re_h, im_h, cache)
        let _ = farr_set(f_h, vi, e)
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
            let f_best = farr_get(f_h, 0)
            let f_worst = farr_get(f_h, n)
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                let _ = farr_simplex_centroid(simplex_h, centroid_h, n, n)
                let _ = farr_vertex_copy(worst_h, 0, simplex_h, n, n)
                let _ = farr_vec_reflect(refl_h, centroid_h, worst_h, 1.0, n)
                let f_refl = cv_lih5o_energy_legacy_h(refl_h, re_h, im_h, cache)
                let f_second = farr_get(f_h, n - 1)
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    } else {
                        let _ = farr_vec_blend(contr_h, centroid_h, worst_h, 0.5, n)
                        let f_contr = cv_lih5o_energy_legacy_h(contr_h, re_h, im_h, cache)
                        if f_contr < f_worst {
                            let _ = farr_vertex_copy(simplex_h, n, contr_h, 0, n)
                            let _ = farr_set(f_h, n, f_contr)
                        } else {
                            let _ = farr_simplex_shrink(simplex_h, n, n_vert)
                            let mut q = 1
                            while q < n_vert {
                                let _ = farr_vertex_copy(scratch_h, 0, simplex_h, q, n)
                                let e_q = cv_lih5o_energy_legacy_h(scratch_h, re_h, im_h, cache)
                                let _ = farr_set(f_h, q, e_q)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    let _ = farr_vec_reflect(exp_h, centroid_h, worst_h, 2.0, n)
                    let f_exp = cv_lih5o_energy_legacy_h(exp_h, re_h, im_h, cache)
                    if f_exp < f_refl {
                        let _ = farr_vertex_copy(simplex_h, n, exp_h, 0, n)
                        let _ = farr_set(f_h, n, f_exp)
                    } else {
                        let _ = farr_vertex_copy(simplex_h, n, refl_h, 0, n)
                        let _ = farr_set(f_h, n, f_refl)
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = farr_simplex_sort(simplex_h, f_h, n, n_vert)
    let out = json_parse("{}")
    out["energy"] = farr_get(f_h, 0)
    out["n_iter"] = it
    out["converged"] = converged
    let _ = farr_free(simplex_h); let _ = farr_free(f_h)
    let _ = farr_free(centroid_h); let _ = farr_free(refl_h)
    let _ = farr_free(contr_h); let _ = farr_free(exp_h)
    let _ = farr_free(worst_h); let _ = farr_free(scratch_h)
    let _ = farr_free(re_h); let _ = farr_free(im_h)
    return out
}

// ─── Marker emission ────────────────────────────────────────────────

fn _lih5o_emit_marker(passed: int, label: str) -> int {
    let ts = exec("date +%s").trim()
    let suffix = if passed == 1 { ".marker" } else { "_FAILED.marker" }
    let path = "state/markers/" + label + "_" + ts + suffix
    let _ = exec("mkdir -p state/markers && touch '" + path + "'")
    return 0
}

// ─── Main entry: A/B benchmark + sentinel comparison ────────────────

fn main() -> void {
    println("__QMIRROR_BATCH_MIGRATION_LIH_4E5O__ start")
    println("  hybrid migration: RFC 037 batch Hamiltonian-expectation;")
    println("  UCCSD ansatz loop unchanged (RFC 038 ansatz_pack blocked)")
    println("")
    // Build caches.
    let cache_legacy = cv_lih5o_cache_legacy()
    let cache_rfc037 = cv_lih5o_cache_rfc037()
    let casci = _lih5o_casci_ref()
    println("  CASCI(4,5) ref     = " + str(casci) + " Ha")
    println("  n_qubits=8 dim=256 n_params=54 n_flat=360 n_ham=276")
    println("")
    // --- Step 1: sentinel comparison harness -------------------------
    println("  [step 1] RFC 037 vs legacy energy agreement (4 theta points):")
    let worst_d = cv_lih5o_compare_harness(cache_legacy, cache_rfc037)
    let ok_compare = if worst_d < 0.000000000001 { 1 } else { 0 }
    println("    worst |E_rfc037 - E_legacy| = " + str(worst_d) + " Ha (tol = 1e-12)")
    if ok_compare == 0 {
        println("  [FAIL] energy-comparison sentinel failed (>1e-12 drift)")
        let _ = cv_lih5o_cache_rfc037_free(cache_rfc037)
        let _ = _lih5o_emit_marker(0, "_batch_migration_lih_4e5o")
        println("__QMIRROR_BATCH_MIGRATION_LIH_4E5O__ FAIL")
        return
    }
    println("    -> agreement < 1e-12 Ha: PASS")
    println("")
    // --- Step 2: full NM (legacy) ------------------------------------
    println("  [step 2] NM (legacy, per-term Pauli loop), maxiter=500, tol=1e-9")
    let t0_legacy = exec("date +%s").trim()
    let t0l = to_int(t0_legacy)
    let r_legacy = cv_lih5o_nm_legacy_h(cache_legacy, 0.05, 500, 0.000000001)
    let t1l = to_int(exec("date +%s").trim())
    let wall_legacy = to_float(t1l - t0l)
    let e_legacy = to_float(r_legacy["energy"])
    let it_legacy = to_int(r_legacy["n_iter"])
    let d_legacy = (e_legacy - casci) * 1000000.0
    let abs_dl = if d_legacy < 0.0 { 0.0 - d_legacy } else { d_legacy }
    println("    legacy: " + str(it_legacy) + " iter, wall=" + str(wall_legacy) + "s, E=" + str(e_legacy)
        + " Ha, |dE_CASCI|=" + str(abs_dl) + " uHa")
    // --- Step 3: full NM (RFC 037 hybrid) ----------------------------
    println("  [step 3] NM (RFC 037 batch H-expectation), maxiter=500, tol=1e-9")
    let t0_new = to_int(exec("date +%s").trim())
    let r_new = cv_lih5o_nm_rfc037_h(cache_rfc037, 0.05, 500, 0.000000001)
    let t1n = to_int(exec("date +%s").trim())
    let wall_new = to_float(t1n - t0_new)
    let e_new = to_float(r_new["energy"])
    let it_new = to_int(r_new["n_iter"])
    let d_new = (e_new - casci) * 1000000.0
    let abs_dn = if d_new < 0.0 { 0.0 - d_new } else { d_new }
    println("    rfc037: " + str(it_new) + " iter, wall=" + str(wall_new) + "s, E=" + str(e_new)
        + " Ha, |dE_CASCI|=" + str(abs_dn) + " uHa")
    // --- Step 4: speedup ratio + ΔE between drivers -----------------
    let speedup = if wall_new > 0.0 { wall_legacy / wall_new } else { 0.0 - 1.0 }
    let dE = e_new - e_legacy
    let abs_dE_uha = if dE < 0.0 { (0.0 - dE) * 1000000.0 } else { dE * 1000000.0 }
    println("")
    println("  [summary] speedup = " + str(speedup) + "x  (legacy " + str(wall_legacy)
        + "s -> rfc037 " + str(wall_new) + "s)")
    println("  [summary] |E_rfc037_NM - E_legacy_NM| = " + str(abs_dE_uha) + " uHa")
    // PASS criteria:
    //   - sentinel agreement < 1e-12 (already checked)
    //   - both NM runs land within chemical accuracy of CASCI (1.6 mHa)
    //   - the two NM drivers agree to < 0.1 uHa (NM convergence is
    //     deterministic when energy fns agree to 1e-12 Ha; this is a
    //     loose belt-and-suspenders bound)
    let ok_legacy_acc = if abs_dl < 1600.0 { 1 } else { 0 }
    let ok_new_acc    = if abs_dn < 1600.0 { 1 } else { 0 }
    let ok_drivers_match = if abs_dE_uha < 0.1 { 1 } else { 0 }
    let all_ok = if ok_compare == 1 {
        if ok_legacy_acc == 1 {
            if ok_new_acc == 1 {
                if ok_drivers_match == 1 { 1 } else { 0 }
            } else { 0 }
        } else { 0 }
    } else { 0 }
    let _ = cv_lih5o_cache_rfc037_free(cache_rfc037)
    if all_ok == 1 {
        let _ = _lih5o_emit_marker(1, "_batch_migration_lih_4e5o")
        println("  marker: state/markers/_batch_migration_lih_4e5o_<ts>.marker")
        println("  PASS new_wall=" + str(wall_new) + "s old_wall=" + str(wall_legacy)
            + "s speedup=" + str(speedup) + "x delta_uHa=" + str(abs_dE_uha))
        println("__QMIRROR_BATCH_MIGRATION_LIH_4E5O__ PASS new_wall=" + str(wall_new)
            + "s old_wall=" + str(wall_legacy) + "s speedup=" + str(speedup)
            + "x delta_uHa=" + str(abs_dE_uha))
        return
    }
    let _ = _lih5o_emit_marker(0, "_batch_migration_lih_4e5o")
    println("__QMIRROR_BATCH_MIGRATION_LIH_4E5O__ FAIL")
}
