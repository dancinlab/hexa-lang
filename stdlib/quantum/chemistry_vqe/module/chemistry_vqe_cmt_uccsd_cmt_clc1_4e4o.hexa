fn uccsd_cmt_clc1_ham_n() -> int { return 325 }
fn uccsd_cmt_clc1_ham_shift() -> float { return 0.0 - 1135.8497196382755 }
fn uccsd_cmt_clc1_casci_ref() -> float { return 0.0 - 1138.2320415869617 }
fn uccsd_cmt_clc1_hf_amp_idx() -> int { return 9 }

fn cv_uccsd_cmt_clc1_cache() -> map {
    let c = json_parse("{}")
    c["exc_param_idx"] = uccsd_cmt_clc1_exc_param_idx()
    c["exc_flip"] = uccsd_cmt_clc1_exc_flip_mask()
    c["exc_z"] = uccsd_cmt_clc1_exc_z_mask()
    c["exc_y"] = uccsd_cmt_clc1_exc_y_mask()
    c["exc_cy"] = uccsd_cmt_clc1_exc_count_Y()
    c["exc_coefs"] = uccsd_cmt_clc1_exc_coefs()
    c["exc_n_flat"] = uccsd_cmt_clc1_n_flat()
    c["ham_flip"] = uccsd_cmt_clc1_ham_flip_mask()
    c["ham_z"] = uccsd_cmt_clc1_ham_z_mask()
    c["ham_y"] = uccsd_cmt_clc1_ham_y_mask()
    c["ham_cy"] = uccsd_cmt_clc1_ham_count_Y()
    c["ham_coefs"] = uccsd_cmt_clc1_ham_coefs()
    c["ham_n"] = uccsd_cmt_clc1_ham_n()
    c["ham_shift"] = uccsd_cmt_clc1_ham_shift()
    return c
}

fn cv_uccsd_cmt_clc1_alloc_hf() -> map {
    let re_h = farr_zeros(64)
    let im_h = farr_zeros(64)
    let _ = farr_set(re_h, 9, 1.0)
    let r = json_parse("{}")
    r["re_h"] = re_h
    r["im_h"] = im_h
    return r
}

fn cv_uccsd_cmt_clc1_energy(theta: [float], cache: map) -> float {
    let st = cv_uccsd_cmt_clc1_alloc_hf()
    let re_h = to_int(st["re_h"])
    let im_h = to_int(st["im_h"])
    let param_idx = cache["exc_param_idx"]
    let flip_arr = cache["exc_flip"]
    let z_arr = cache["exc_z"]
    let y_arr = cache["exc_y"]
    let cy_arr = cache["exc_cy"]
    let coefs = cache["exc_coefs"]
    let n_flat = to_int(cache["exc_n_flat"])
    let mut i = 0
    while i < n_flat {
        let k = param_idx[i]
        let alpha = theta[k] * coefs[i]
        let abs_a = if alpha < 0.0 { 0.0 - alpha } else { alpha }
        if abs_a > 0.0000000000001 {
            let _ = farr_pauli_exp_inplace(re_h, im_h, alpha, flip_arr[i], z_arr[i], y_arr[i], cy_arr[i], 6)
        }
        i = i + 1
    }
    let h_flip = cache["ham_flip"]
    let h_z = cache["ham_z"]
    let h_y = cache["ham_y"]
    let h_cy = cache["ham_cy"]
    let h_coefs = cache["ham_coefs"]
    let shift = to_float(cache["ham_shift"])
    let n = to_int(cache["ham_n"])
    let mut e_op = 0.0
    let mut k = 0
    while k < n {
        let exp_k = farr_pauli_expectation(re_h, im_h, h_flip[k], h_z[k], h_y[k], h_cy[k], 6)
        e_op = e_op + h_coefs[k] * exp_k
        k = k + 1
    }
    let _ = farr_free(re_h)
    let _ = farr_free(im_h)
    return e_op + shift
}

// Generic 26-dim NM helpers — reuse names with slug prefix to avoid collisions.

fn cv_nm26_cmt_clc1_copy_vertex(simplex: [float], v: int, n: int) -> [float] {
    let mut out = []
    let mut j = 0
    while j < n { out = out.push(simplex[v * n + j]); j = j + 1 }
    return out
}
fn cv_nm26_cmt_clc1_set_vertex(simplex: [float], v: int, n: int, src: [float]) -> int {
    let mut j = 0
    while j < n { simplex[v * n + j] = src[j]; j = j + 1 }
    return 0
}
fn cv_nm26_cmt_clc1_sort(simplex: [float], f: [float], n: int) -> int {
    let n_vert = len(f)
    let mut i = 1
    while i < n_vert {
        let key_f = f[i]
        let key_v = cv_nm26_cmt_clc1_copy_vertex(simplex, i, n)
        let mut j = i - 1
        let mut stop = 0
        while stop == 0 {
            if j < 0 { stop = 1 } else {
                if f[j] > key_f {
                    f[j + 1] = f[j]
                    let prev_v = cv_nm26_cmt_clc1_copy_vertex(simplex, j, n)
                    let _ = cv_nm26_cmt_clc1_set_vertex(simplex, j + 1, n, prev_v)
                    j = j - 1
                } else { stop = 1 }
            }
        }
        f[j + 1] = key_f
        let _ = cv_nm26_cmt_clc1_set_vertex(simplex, j + 1, n, key_v)
        i = i + 1
    }
    return 0
}

fn cv_uccsd_cmt_clc1_nm(cache: map, initial_step: float, max_iter: int, tol: float) -> map {
    let n = 26
    let n_vert = n + 1
    let mut simplex = []
    let mut z = 0
    while z < n_vert * n { simplex = simplex.push(0.0); z = z + 1 }
    let mut v = 1
    while v < n_vert { simplex[v * n + (v - 1)] = initial_step; v = v + 1 }
    let mut f = []
    let mut vi = 0
    while vi < n_vert {
        let vert = cv_nm26_cmt_clc1_copy_vertex(simplex, vi, n)
        f = f.push(cv_uccsd_cmt_clc1_energy(vert, cache))
        vi = vi + 1
    }
    let mut it = 0
    let mut converged = 0
    let mut done = 0
    while done == 0 {
        if it < max_iter { /* ok */ } else { done = 1 }
        if done == 0 {
            let _ = cv_nm26_cmt_clc1_sort(simplex, f, n)
            let f_best = f[0]
            let f_worst = f[n]
            let spread = if (f_worst - f_best) < 0.0 { 0.0 - (f_worst - f_best) } else { f_worst - f_best }
            if spread < tol { converged = 1; done = 1 }
            if done == 0 {
                let mut centroid = []
                let mut j = 0
                while j < n {
                    let mut acc = 0.0
                    let mut vv = 0
                    while vv < n { acc = acc + simplex[vv * n + j]; vv = vv + 1 }
                    centroid = centroid.push(acc / to_float(n))
                    j = j + 1
                }
                let worst_v = cv_nm26_cmt_clc1_copy_vertex(simplex, n, n)
                let mut refl = []
                let mut j2 = 0
                while j2 < n { refl = refl.push(centroid[j2] + (centroid[j2] - worst_v[j2])); j2 = j2 + 1 }
                let f_refl = cv_uccsd_cmt_clc1_energy(refl, cache)
                let f_second = f[n - 1]
                if f_best < f_refl + 0.0 || f_best == f_refl {
                    if f_refl < f_second {
                        let _ = cv_nm26_cmt_clc1_set_vertex(simplex, n, n, refl)
                        f[n] = f_refl
                    } else {
                        let mut contr = []
                        let mut j3 = 0
                        while j3 < n { contr = contr.push(centroid[j3] + 0.5 * (worst_v[j3] - centroid[j3])); j3 = j3 + 1 }
                        let f_contr = cv_uccsd_cmt_clc1_energy(contr, cache)
                        if f_contr < f_worst {
                            let _ = cv_nm26_cmt_clc1_set_vertex(simplex, n, n, contr)
                            f[n] = f_contr
                        } else {
                            let best_v = cv_nm26_cmt_clc1_copy_vertex(simplex, 0, n)
                            let mut q = 1
                            while q < n_vert {
                                let mut nv = []
                                let mut j4 = 0
                                while j4 < n { nv = nv.push(best_v[j4] + 0.5 * (simplex[q * n + j4] - best_v[j4])); j4 = j4 + 1 }
                                let _ = cv_nm26_cmt_clc1_set_vertex(simplex, q, n, nv)
                                f[q] = cv_uccsd_cmt_clc1_energy(nv, cache)
                                q = q + 1
                            }
                        }
                    }
                } else {
                    let mut exp_v = []
                    let mut j5 = 0
                    while j5 < n { exp_v = exp_v.push(centroid[j5] + 2.0 * (centroid[j5] - worst_v[j5])); j5 = j5 + 1 }
                    let f_exp = cv_uccsd_cmt_clc1_energy(exp_v, cache)
                    if f_exp < f_refl {
                        let _ = cv_nm26_cmt_clc1_set_vertex(simplex, n, n, exp_v)
                        f[n] = f_exp
                    } else {
                        let _ = cv_nm26_cmt_clc1_set_vertex(simplex, n, n, refl)
                        f[n] = f_refl
                    }
                }
                it = it + 1
            }
        }
    }
    let _ = cv_nm26_cmt_clc1_sort(simplex, f, n)
    let best_theta = cv_nm26_cmt_clc1_copy_vertex(simplex, 0, n)
    let out = json_parse("{}")
    out["theta"] = best_theta
    out["energy"] = f[0]
    out["n_iter"] = it
    out["converged"] = converged
    return out
}

fn main() {
    println("[qmirror/chemistry_vqe] cmt-clc1 IN-PROCESS pure-hexa UCCSD-at-4e/4o NM (Ramp B)")
    let cache = cv_uccsd_cmt_clc1_cache()
    let casci = uccsd_cmt_clc1_casci_ref()
    println("  CASCI(4,4) ref = " + str(casci) + " Ha")
    println("  starting NM (maxiter=200, tol=1e-9 Ha)...")
    let t0 = exec("date +%s").trim()
    let t0_i = to_int(t0)
    let r = cv_uccsd_cmt_clc1_nm(cache, 0.05, 200, 0.000000001)
    let t1 = exec("date +%s").trim()
    let wall = to_float(to_int(t1) - t0_i)
    let e = to_float(r["energy"])
    let n_iter = to_int(r["n_iter"])
    let conv = to_int(r["converged"])
    let d_uha = (e - casci) * 1000000.0
    let abs_d = if d_uha < 0.0 { 0.0 - d_uha } else { d_uha }
    println("  done: " + str(n_iter) + " iter, converged=" + str(conv) + ", wall=" + str(wall) + "s")
    println("  E_VQE = " + str(e) + " Ha   |delta| = " + str(abs_d) + " uHa")
    if abs_d < 1600.0 {
        println("  -> within chemical accuracy (1.6 mHa)")
        println("__QMIRROR_CHEM_CMT_UCCSD_CMT_CLC1_4E4O_INPROC_NM__ PASS")
        return
    }
    println("__QMIRROR_CHEM_CMT_UCCSD_CMT_CLC1_4E4O_INPROC_NM__ FAIL")
}
