fn uccsd_cmt_clc1_4e6o_ham_shift() -> float { return 0.0 - 1135.8497196382755 }
fn uccsd_cmt_clc1_4e6o_casci_ref() -> float { return 0.0 - 1138.2427469500265 }

fn _uccsd_cmt_clc1_4e6o_pack(h: int, src: [int], n: int) -> int {
    let mut k = 0
    while k < n {
        let _ = farr_int_set(h, k, src[k])
        k = k + 1
    }
    return n
}

