    let _ = _uccsd_cmt_clc1_4e6o_pack(ham_z_h,    uccsd_cmt_clc1_4e6o_ham_z_mask(), n)
    let _ = _uccsd_cmt_clc1_4e6o_pack(ham_y_h,    uccsd_cmt_clc1_4e6o_ham_y_mask(), n)
    let _ = _uccsd_cmt_clc1_4e6o_pack(ham_cy_h,   uccsd_cmt_clc1_4e6o_ham_count_Y(), n)
