#!hexa strict
//
// _adapt_vqe_lih_4e5o.hexa — ADAPT-VQE runner on LiH 4e/5o (8-qubit).
//
// Reuses the UCCSD LiH 4e/5o cache (vendored Hamiltonian + 54-op
// excitation pool from chemistry_vqe_cmt_uccsd_lih_4e5o.hexa) and
// drives the pure-hexa ADAPT-VQE outer loop from
// _adapt_vqe_driver_4e5o.hexa.
//
// Closure target (raw_91 honest C3):
//   |Δ| < 1.6 mHa vs CASCI(4,5) reference   AND   K < 54 (fewer ops than UCCSD)
//
// @tool(slug="qmirror_chemistry_vqe_adapt_vqe_lih_4e5o", desc="Pure-hexa ADAPT-VQE on LiH/STO-3G/4e5o — grows ansatz one op at a time via FD-gradient screening, joint re-opt via inner L-BFGS-B. Target: chem-acc with K<54.")
// @usage(hexa run qmirror/chemistry_vqe/module/_adapt_vqe_lih_4e5o.hexa --selftest)
// @sentinel(__QMIRROR_CHEM_ADAPT_VQE_LIH_4E5O__ <PASS|FAIL>)

use "./_adapt_vqe_driver_4e5o.hexa"

fn main() {
    println("[qmirror/chemistry_vqe] ADAPT-VQE — LiH/STO-3G/4e5o (8-qubit)")
    println("  pool:       UCCSD 54 ops (vendored masks from chemistry_vqe_cmt_uccsd_lih_4e5o)")
    println("  gradient:   finite-difference (h=1e-4); param-shift swap pending RFC 039 binding")
    println("  inner opt:  pure-hexa L-BFGS-B (m=10) with strong-Wolfe-lite line search")
    println("")

    let cache = cv_uccsd_lih4e5o_cache()
    let casci = uccsd_lih4e5o_casci_ref()
    println("  CASCI(4,5) ref: " + str(casci) + " Ha")
    println("")

    let t_start = exec("date +%s").trim()
    let t_start_i = to_int(t_start)

    let result = adapt_vqe_4e5o(cache,
                                 25,            // max_ops (<54 = UCCSD pool)
                                 0.001,         // grad_tol = 1e-3 Ha
                                 0.000000001)   // energy_tol = 1e-9 Ha

    let t_end = exec("date +%s").trim()
    let wall = to_float(to_int(t_end) - t_start_i)

    let energy = to_float(result["energy"])
    let n_ops = to_int(result["n_ops_selected"])
    let selected_ops = result["selected_ops"]
    let iters_per_step = result["iters_per_step"]
    let grad_at_pick = result["grad_at_pick"]

    let delta_uha = (energy - casci) * 1000000.0
    let abs_delta = if delta_uha < 0.0 { 0.0 - delta_uha } else { delta_uha }

    println("")
    println("  ADAPT-VQE done:")
    println("    n_ops_selected = " + str(n_ops) + " (UCCSD baseline = 54)")
    println("    selected_ops   = " + str(selected_ops))
    println("    grad_at_pick   = " + str(grad_at_pick))
    println("    iters_per_step = " + str(iters_per_step))
    println("    E_VQE          = " + str(energy) + " Ha")
    println("    E_CASCI(4,5)   = " + str(casci) + " Ha")
    println("    |delta|        = " + str(abs_delta) + " uHa")
    println("    wall           = " + str(wall) + "s")
    println("")

    let chem_acc = abs_delta < 1600.0
    let fewer = n_ops < 54
    let pass = chem_acc && fewer

    if chem_acc {
        println("    ✓ |delta| < 1.6 mHa = 1600 uHa")
    } else {
        println("    ✗ |delta| = " + str(abs_delta) + " uHa > 1600 uHa")
    }
    if fewer {
        println("    ✓ K = " + str(n_ops) + " < 54 (UCCSD baseline)")
    } else {
        println("    ✗ K = " + str(n_ops) + " >= 54 — no parameter reduction")
    }

    // Emit marker.
    let ts = exec("date +%s").trim()
    let qm_root = env("QMIRROR_ROOT")
    let root = if qm_root.len() > 0 { qm_root } else { exec("pwd").trim() }
    let marker_dir = root + "/state/markers"
    let _md = exec("mkdir -p " + marker_dir + " 2>/dev/null")
    let marker_name = if pass {
        "_adapt_vqe_lih_4e5o_" + ts + ".marker"
    } else {
        "_adapt_vqe_lih_4e5o_" + ts + "_FAILED.marker"
    }
    let marker_path = marker_dir + "/" + marker_name
    let body = "[qmirror/chemistry_vqe/_adapt_vqe_lih_4e5o]" +
               " n_ops=" + str(n_ops) +
               " delta_uHa=" + str(abs_delta) +
               " wall=" + str(wall) + "s" +
               " E_VQE=" + str(energy) +
               " E_CASCI=" + str(casci) +
               " chem_acc=" + str(chem_acc) +
               " fewer_than_uccsd=" + str(fewer)
    let _w = exec("echo '" + body + "' > '" + marker_path + "'")
    println("  marker: " + marker_path)
    println("")

    if pass {
        println("__QMIRROR_CHEM_ADAPT_VQE_LIH_4E5O__ PASS n_ops=" + str(n_ops) +
                " delta_uHa=" + str(abs_delta) +
                " wall=" + str(wall) + "s")
        return
    }
    println("__QMIRROR_CHEM_ADAPT_VQE_LIH_4E5O__ FAIL n_ops=" + str(n_ops) +
            " delta_uHa=" + str(abs_delta) +
            " wall=" + str(wall) + "s")
}
