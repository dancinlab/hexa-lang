#!hexa strict
// qmirror/phi/module/phi.hexa — anima_phi_v3_canonical port (pure-hexa kernel)
//
// Pure-hexa φ★ kernel (Phase 6 of the full-repo hexa-only absorption,
// PARALLEL_SUBAGENT_FIRING_ROADMAP_2026_05_12.md §4). Replaces the
// numpy-backed json bridge that previously lived in
// _python_bridge/module/phi_runner.py (now deleted).
//
// No subprocess, no python, no qiskit/numpy. The recipe (verbatim port of
// warmup_probe_real.compute_phi_star, anima_phi_v3_canonical, lines
// 203-253) needs three numeric primitives that hexa's stdlib does not ship
// as matrix ops, so they are implemented inline here:
//
//   (1) slogdet(M)  — signed log|det(M)| via LU decomposition with partial
//                     pivoting (sign tracks row swaps + diagonal signs;
//                     log|det| = Σ log|U_ii|).  natural log = stdlib `log`.
//   (2) cov(rows, cols) — sample covariance (ddof=1) of the selected
//                     columns of `rows`, i.e. numpy.cov(X[:, cols].T).
//   (3) argsort_desc(v) — STABLE descending argsort (insertion sort on
//                     indices; ties keep original order).  Column ordering
//                     after this is irrelevant for φ (det is invariant to a
//                     symmetric row+column permutation of the covariance).
//
// hexa-lang notes: `log` is natural log, `exp` is e^x, both in the stdlib
// (verified IEEE-754 double).  `>=`/`<=` are lint-banned; this file uses
// only `<` / `>` / `==`.  No exec / exit / time → no file-scope lint
// escapes needed.
//
// Spec ref: docs/nexus_qmirror_spec_2026_05_03.md §3.6 (qmirror.phi)
// @tool(slug="qmirror_phi", desc="Sample-partition log|Cov| φ★ over arbitrary complex state vector. Pure-hexa port of anima_phi_v3_canonical (warmup_probe_real.py:200-260) — LU-based slogdet + ddof=1 covariance + stable descending argsort, no python bridge. Default HID_TRUNC = N//2, K = 8 partitions.")
// @usage(hexa run qmirror/phi/module/phi.hexa --selftest)
// @sentinel(__QMIRROR_PHI__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest builds an N_CALIB synthetic hidden-state matrix and runs the pure-hexa φ kernel; no engine_aer / python / qiskit dep.")
//
//   (1) Reference recipe (anima_phi_v3_canonical, warmup_probe_real.py:203-253):
//         X      = stack of N_CALIB hidden-state mean-pooled vectors (N, D)
//         var    = X.var(axis=0)                       # ddof=0
//         top_k  = argsort(var)[::-1][:HID_TRUNC]
//         Xt     = X[:, top_k]
//         I_full = log|Cov(Xt) + ridge·I|              # safe slogdet, ddof=1
//         for k in K_PARTS:
//             idx   = rng.permutation(N)
//             s1,s2 = idx[:HALF], idx[HALF:]
//             I1, I2 = log|Cov(Xt[s1])|, log|Cov(Xt[s2])|
//             phi_k  = I_full - (I1 + I2)
//         return min(phi_k), mean(phi_k)
//   (2) qmirror.phi adapts this for COMPLEX AMPLITUDE vectors: build N_CALIB
//       hidden rows by perturbing the outcome-probability vector p_i = |ψ_i|²
//       through fresh draws; selftest path uses seed-deterministic synthetic
//       perturbations to keep the sampler dep loose-coupled.
//   (3) HID_TRUNC default = N // 2.
//   (4) K = 8 partitions default.
//   (5) Output schema MUST match trajectory.json phi_star block:
//       {phi_min, phi_mean, partitions_tested}.

// ── Structs ───────────────────────────────────────────────────────────────────

struct Complex {
    re: float,
    im: float
}

struct PhiResult {
    ok:                  int,
    phi_min:             float,
    phi_mean:            float,
    partitions_tested:   int,
    hid_trunc_used:      int,
    n_calib:             int,
    ridge:               float,
    seed:                int,
    engine:              str,
    message:             str
}

struct SlogdetResult {
    sign:       int,     // -1, 0, +1   (0 ⇒ singular / numerically zero pivot)
    logabsdet:  float    // log|det|, only meaningful when sign != 0
}

// ── Constructors ──────────────────────────────────────────────────────────────

fn complex_make(re: float, im: float) -> Complex {
    return Complex { re: re, im: im }
}

fn phi_fail(reason: str) -> PhiResult {
    return PhiResult {
        ok: 0, phi_min: 0.0, phi_mean: 0.0, partitions_tested: 0,
        hid_trunc_used: 0, n_calib: 0, ridge: 0.0, seed: 0,
        engine: "hexa_native", message: reason
    }
}

fn phi_ok(phi_min: float, phi_mean: float, parts: int, hid: int, n_calib: int, ridge: float, seed: int, msg: str) -> PhiResult {
    return PhiResult {
        ok: 1, phi_min: phi_min, phi_mean: phi_mean,
        partitions_tested: parts, hid_trunc_used: hid,
        n_calib: n_calib, ridge: ridge, seed: seed,
        engine: "hexa_native", message: msg
    }
}

// ── Numeric primitive #1: slogdet via LU with partial pivoting ────────────────
//
// For an n×n real matrix M, factor P·M = L·U with row swaps tracked in
// `pivot_sign`.  det(M) = pivot_sign · Π U_ii, so
//     sign(det)   = pivot_sign · Π sign(U_ii)
//     log|det(M)| = Σ log|U_ii|
// A zero (or sub-tiny) pivot ⇒ matrix is singular ⇒ sign 0.
//
// `tiny` mirrors numpy's "is this numerically zero" intuition; the φ recipe
// always feeds Cov + ridge·I (ridge default 1e-3) so the matrix is SPD and
// the pivots are comfortably positive in practice.

fn _phi_mat_copy(M: [[float]]) -> [[float]] {
    let n = len(M)
    let mut out = []
    let mut i = 0
    while i < n {
        let row = M[i]
        let m = len(row)
        let mut nr = []
        let mut j = 0
        while j < m {
            nr = nr.push(row[j])
            j = j + 1
        }
        out = out.push(nr)
        i = i + 1
    }
    return out
}

fn _phi_slogdet(M0: [[float]]) -> SlogdetResult {
    let n = len(M0)
    if n < 1 { return SlogdetResult { sign: 0, logabsdet: 0.0 } }
    // square check
    let mut chk = 0
    while chk < n {
        if len(M0[chk]) != n { return SlogdetResult { sign: 0, logabsdet: 0.0 } }
        chk = chk + 1
    }
    let mut A = _phi_mat_copy(M0)
    let mut pivot_sign = 1
    let mut k = 0
    while k < n {
        // partial pivot: largest |A[i][k]| over i in [k, n)
        let mut p = k
        let mut best = abs(A[k][k])
        let mut i = k + 1
        while i < n {
            let v = abs(A[i][k])
            if best < v { best = v; p = i }
            i = i + 1
        }
        // tiny pivot ⇒ singular
        let tiny = 0.000000000001  // 1e-12
        if best < tiny { return SlogdetResult { sign: 0, logabsdet: 0.0 } }
        if p != k {
            let tmp = A[p]
            A[p] = A[k]
            A[k] = tmp
            pivot_sign = 0 - pivot_sign
        }
        // eliminate below
        let akk = A[k][k]
        let mut r = k + 1
        while r < n {
            let factor = A[r][k] / akk
            let mut c = k
            while c < n {
                A[r][c] = A[r][c] - factor * A[k][c]
                c = c + 1
            }
            r = r + 1
        }
        k = k + 1
    }
    // accumulate diagonal
    let mut sign = pivot_sign
    let mut logabs = 0.0
    let mut d = 0
    while d < n {
        let u = A[d][d]
        if u == 0.0 { return SlogdetResult { sign: 0, logabsdet: 0.0 } }
        if u < 0.0 { sign = 0 - sign }
        logabs = logabs + log(abs(u))
        d = d + 1
    }
    return SlogdetResult { sign: sign, logabsdet: logabs }
}

// log|det(C + ridge·I)| when the result is positive-definite (sign +1),
// matching phi_runner._safe_logdet (sign <= 0 ⇒ "no value", returned as
// SlogdetResult.sign == 0 here so callers can skip the partition).
fn _phi_safe_logdet(C: [[float]], ridge: float) -> SlogdetResult {
    let n = len(C)
    let mut Cs = _phi_mat_copy(C)
    let mut i = 0
    while i < n {
        Cs[i][i] = Cs[i][i] + ridge
        i = i + 1
    }
    let sd = _phi_slogdet(Cs)
    if sd.sign < 1 { return SlogdetResult { sign: 0, logabsdet: 0.0 } }  // sign <= 0 ⇒ reject
    return sd
}

// ── Numeric primitive #2: covariance (ddof=1) of selected columns ─────────────
//
// Equivalent to numpy.cov(X[row_idx][:, cols].T) with the numpy default
// ddof=1 (divide by N-1).  `row_idx` selects which rows of `rows` enter the
// estimate (the half-partitions s1/s2 of the recipe); pass the full index
// list for the I_full computation.  Returns an len(cols)×len(cols) matrix;
// caller must guarantee len(row_idx) > 1.
fn _phi_cov_selected(rows: [[float]], row_idx: [int], cols: [int]) -> [[float]] {
    let nobs = len(row_idx)
    let d = len(cols)
    // column means over the selected rows
    let mut means = []
    let mut a = 0
    while a < d {
        let cidx = cols[a]
        let mut s = 0.0
        let mut r = 0
        while r < nobs {
            s = s + rows[row_idx[r]][cidx]
            r = r + 1
        }
        means = means.push(s / to_float(nobs))
        a = a + 1
    }
    // C[i][j] = Σ_r (X[r][ci]-mean_i)(X[r][cj]-mean_j) / (nobs - 1)
    let denom = to_float(nobs - 1)
    let mut C = []
    let mut ii = 0
    while ii < d {
        let mut crow = []
        let mut jj = 0
        while jj < d {
            let ci = cols[ii]
            let cj = cols[jj]
            let mi = means[ii]
            let mj = means[jj]
            let mut acc = 0.0
            let mut r2 = 0
            while r2 < nobs {
                let xr = rows[row_idx[r2]]
                acc = acc + (xr[ci] - mi) * (xr[cj] - mj)
                r2 = r2 + 1
            }
            crow = crow.push(acc / denom)
            jj = jj + 1
        }
        C = C.push(crow)
        ii = ii + 1
    }
    return C
}

// ── Numeric primitive #3: stable descending argsort ───────────────────────────
//
// Returns the indices of `vals` ordered by descending value, stable on ties
// (insertion sort ⇒ equal keys keep their original relative order).  This is
// the hexa equivalent of numpy.argsort(vals)[::-1] except the tie order is
// well-defined; for φ the column order is irrelevant anyway (det of Cov is
// invariant under a simultaneous row+column permutation).
fn _phi_argsort_desc(vals: [float]) -> [int] {
    let n = len(vals)
    let mut idx = []
    let mut i = 0
    while i < n {
        idx = idx.push(i)
        i = i + 1
    }
    // insertion sort by vals[idx[k]] descending; stable on equality
    let mut k = 1
    while k < n {
        let cur = idx[k]
        let curv = vals[cur]
        let mut j = k - 1
        let mut placed = 0
        while placed == 0 {
            if j < 0 {
                idx[0] = cur
                placed = 1
            } else {
                // shift right while the slot's value is strictly less than curv
                if vals[idx[j]] < curv {
                    idx[j + 1] = idx[j]
                    j = j - 1
                } else {
                    idx[j + 1] = cur
                    placed = 1
                }
            }
        }
        k = k + 1
    }
    return idx
}

// Population variance (ddof=0) of column `cidx` over all rows — numpy
// X.var(axis=0) semantics.
fn _phi_column_var(rows: [[float]], cidx: int) -> float {
    let n = len(rows)
    if n < 1 { return 0.0 }
    let mut s = 0.0
    let mut r = 0
    while r < n {
        s = s + rows[r][cidx]
        r = r + 1
    }
    let mean = s / to_float(n)
    let mut acc = 0.0
    let mut r2 = 0
    while r2 < n {
        let dv = rows[r2][cidx] - mean
        acc = acc + dv * dv
        r2 = r2 + 1
    }
    return acc / to_float(n)
}

// ── PRNG: deterministic 32-bit LCG (Numerical-Recipes constants) ──────────────
//
// Used only to generate the K random half-partitions (Fisher-Yates shuffle of
// [0, n)).  Need not match numpy.default_rng bit-for-bit — the φ verdict is
// "finite, in-band" for the same seed, mirroring stabilizer_native.hexa.
fn _phi_lcg_next(s: int) -> int {
    return (1664525 * s + 1013904223) % 4294967296
}

// Fisher-Yates permutation of [0, n) driven by an LCG seeded from `seed`.
fn _phi_permutation(n: int, seed: int) -> [int] {
    let mut perm = []
    let mut i = 0
    while i < n {
        perm = perm.push(i)
        i = i + 1
    }
    let mut s = if seed > 0 { seed } else { 1 }
    // iterate j from n-1 down to 1, swap perm[j] with perm[rand(0..j)]
    let mut j = n - 1
    while j > 0 {
        s = _phi_lcg_next(s)
        let r = s % (j + 1)
        let tmp = perm[j]
        perm[j] = perm[r]
        perm[r] = tmp
        j = j - 1
    }
    return perm
}

// ── Hidden-row synthesis (loose-coupled stand-in for the M-shot sampler) ──────
//
// Build N_CALIB hidden rows from a single |ψ⟩ amplitude vector by perturbing
// the outcome-probability vector p_i = |ψ_i|² with seed-deterministic LCG
// noise in [-noise_amp/2, +noise_amp/2].
fn _phi_synth_rows(amps_re: [float], amps_im: [float], n_calib: int, noise_amp: float, seed: int) -> [[float]] {
    let dim = len(amps_re)
    let mut rows = []
    let mut s = if seed > 0 { seed } else { 42 }
    let mut row_i = 0
    while row_i < n_calib {
        let mut row = []
        let mut jj = 0
        while jj < dim {
            let p = amps_re[jj] * amps_re[jj] + amps_im[jj] * amps_im[jj]
            s = _phi_lcg_next(s)
            let u = to_float(s % 1000000) / 1000000.0
            let pert = noise_amp * (u - 0.5)
            row = row.push(p + pert)
            jj = jj + 1
        }
        rows = rows.push(row)
        row_i = row_i + 1
    }
    return rows
}

// ── Public API ────────────────────────────────────────────────────────────────
//
//   phi_measure_matrix(X, hid_trunc, k_partitions, ridge, seed) -> PhiResult
//       The canonical kernel — verbatim port of phi_runner._phi_measure /
//       warmup_probe_real.compute_phi_star.  This is the entry point a future
//       caller (Phase 9 iit_mip switch) should bind to: takes a raw
//       (N_calib × D) calibration matrix and returns the φ★ summary.
//         hid_trunc   <= 0 ⇒ D // 2 (≥ 1), then clamped to D
//         k_partitions<= 0 ⇒ 8
//         ridge       <= 0 ⇒ 1e-3
//         seed        <  1 ⇒ 42
//       φ_k = log|Cov(Xt)+ridge·I| - (log|Cov(Xt[s1])+ridge·I| +
//             log|Cov(Xt[s2])+ridge·I|) over K random 50/50 partitions;
//       returns (phi_min, phi_mean, partitions_tested) plus the resolved
//       parameters.  ok == 0 with a `message` on any failure
//       (n_calib < 2, all-singular covariances, etc.).
//
//   phi_measure(state_vector, hid_trunc, k_partitions) -> PhiResult
//       State-vector convenience wrapper: synthesises N_CALIB = 32 hidden
//       rows from |ψ|² (noise_amp 0.05, seed 42) and delegates to
//       phi_measure_matrix with ridge 1e-3.  hid_trunc default = N // 2 over
//       the state-vector dim.

fn phi_measure_matrix(X: [[float]], hid_trunc: int, k_partitions: int, ridge_in: float, seed_in: int) -> PhiResult {
    let n_calib = len(X)
    if n_calib < 1 {
        return phi_fail("phi_measure_matrix: empty X")
    }
    let d = len(X[0])
    if d < 1 {
        return phi_fail("phi_measure_matrix: X has zero-width rows")
    }
    // rectangular check
    let mut rc = 0
    while rc < n_calib {
        if len(X[rc]) != d {
            return phi_fail("phi_measure_matrix: X is not rectangular at row " + str(rc))
        }
        rc = rc + 1
    }
    if n_calib < 2 {
        return phi_fail("phi_measure_matrix: need n_calib > 1")
    }

    let ridge = if ridge_in < 0.0 || ridge_in == 0.0 { 0.001 } else { ridge_in }
    let seed = if seed_in < 1 { 42 } else { seed_in }

    let mut hid_eff = if hid_trunc < 1 { let h = d / 2; if h < 1 { 1 } else { h } } else { hid_trunc }
    if d < hid_eff { hid_eff = d }

    let k_eff = if k_partitions < 1 { 8 } else { k_partitions }

    let half = n_calib / 2
    if half < 1 {
        return phi_fail("phi_measure_matrix: half-partition is empty")
    }

    // per-column population variance, then descending argsort → top hid_eff
    let mut var = []
    let mut c = 0
    while c < d {
        var = var.push(_phi_column_var(X, c))
        c = c + 1
    }
    let order = _phi_argsort_desc(var)
    let mut top_cols = []
    let mut t = 0
    while t < hid_eff {
        top_cols = top_cols.push(order[t])
        t = t + 1
    }

    // full-index list [0, n_calib)
    let mut all_idx = []
    let mut ai = 0
    while ai < n_calib {
        all_idx = all_idx.push(ai)
        ai = ai + 1
    }

    // I_full = log|Cov(Xt) + ridge·I|
    let C_full = _phi_cov_selected(X, all_idx, top_cols)
    let sd_full = _phi_safe_logdet(C_full, ridge)
    if sd_full.sign < 1 {
        return phi_fail("phi_measure_matrix: I_full slogdet sign <= 0")
    }
    let i_full = sd_full.logabsdet

    // K random half-partitions
    let mut phi_sum = 0.0
    let mut phi_min = 0.0
    let mut have_min = 0
    let mut tested = 0
    let mut kk = 0
    while kk < k_eff {
        // decorrelate the K streams (seed + k·7919), mirroring the
        // stabilizer_native PRNG stride convention.
        let perm = _phi_permutation(n_calib, seed + kk * 7919)
        let mut s1 = []
        let mut s2 = []
        let mut pi = 0
        while pi < n_calib {
            if pi < half {
                s1 = s1.push(perm[pi])
            } else {
                s2 = s2.push(perm[pi])
            }
            pi = pi + 1
        }
        if len(s1) < 2 || len(s2) < 2 {
            kk = kk + 1
        } else {
            let C1 = _phi_cov_selected(X, s1, top_cols)
            let C2 = _phi_cov_selected(X, s2, top_cols)
            let sd1 = _phi_safe_logdet(C1, ridge)
            let sd2 = _phi_safe_logdet(C2, ridge)
            if sd1.sign < 1 || sd2.sign < 1 {
                kk = kk + 1
            } else {
                let phi_k = i_full - (sd1.logabsdet + sd2.logabsdet)
                phi_sum = phi_sum + phi_k
                if have_min == 0 {
                    phi_min = phi_k
                    have_min = 1
                } else {
                    if phi_k < phi_min { phi_min = phi_k }
                }
                tested = tested + 1
                kk = kk + 1
            }
        }
    }

    if tested < 1 {
        return phi_fail("phi_measure_matrix: all K partitions failed slogdet")
    }
    let phi_mean = phi_sum / to_float(tested)
    return phi_ok(phi_min, phi_mean, tested, hid_eff, n_calib, ridge, seed,
                  "phi_measure_matrix: ok engine=hexa_native")
}

fn phi_measure(state_vector: [Complex], hid_trunc: int, k_partitions: int) -> PhiResult {
    let n = len(state_vector)
    if n < 2 {
        return phi_fail("phi_measure: state_vector dim < 2")
    }

    // Split Complex list into amps_re / amps_im.
    let mut amps_re = []
    let mut amps_im = []
    let mut i = 0
    while i < n {
        amps_re = amps_re.push(state_vector[i].re)
        amps_im = amps_im.push(state_vector[i].im)
        i = i + 1
    }

    // Synthesise N_CALIB = 32 hidden rows (loose-coupled sampler stand-in).
    let n_calib = 32
    let noise_amp = 0.05
    let seed = 42
    let X = _phi_synth_rows(amps_re, amps_im, n_calib, noise_amp, seed)

    // pass it explicitly so phi_measure_matrix's own D//2 default (D == n
    // here) coincides exactly.
    let hid_eff = if hid_trunc < 1 { let h = n / 2; if h < 1 { 1 } else { h } } else { hid_trunc }
    return phi_measure_matrix(X, hid_eff, k_partitions, 0.001, seed)
}

fn phi_measure_from_circuit(qasm3: str, n_qubits: int, n_calib: int, hid_trunc: int, k_partitions: int) -> PhiResult {
    // Not wired to engine_aer for arbitrary qasm in this module — caller
    // should drive engine_aer separately and pass the amplitude vector to
    // phi_measure([Complex]) (or the raw calibration matrix to
    // phi_measure_matrix([[float]])).
    return phi_fail("phi_measure_from_circuit: drive engine_aer separately, then call phi_measure([Complex]) / phi_measure_matrix([[float]])")
}

// ── Selftest (falsifier F4: phi pipeline finite + defaults honored) ───────────

fn _abs_p(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _selftest() -> int {
    // (a) Struct constructors round-trip.
    let psi_0 = complex_make(0.7071067811865475, 0.0)
    let psi_3 = complex_make(0.7071067811865475, 0.0)
    let bell = [psi_0, complex_make(0.0, 0.0), complex_make(0.0, 0.0), psi_3]
    if len(bell) != 4 { return 0 }

    // (b) phi_measure on a Bell |ψ⟩ should return ok=1, finite phi_min/mean,
    //     and respect default HID_TRUNC = N//2 = 2, K = 8.
    let r = phi_measure(bell, 0, 0)
    if r.ok != 1 { return 0 }
    if r.partitions_tested < 1 { return 0 }
    if r.hid_trunc_used != 2 { return 0 }
    if r.n_calib != 32 { return 0 }
    if r.engine != "hexa_native" { return 0 }
    // Sanity range: synthetic-noise hidden rows give finite φ.
    if _abs_p(r.phi_min) > 1000.0 { return 0 }
    if _abs_p(r.phi_mean) > 1000.0 { return 0 }

    // (c) Explicit hid_trunc + k_partitions overrides honored.
    let r2 = phi_measure(bell, 3, 4)
    if r2.ok != 1 { return 0 }
    if r2.hid_trunc_used != 3 { return 0 }
    if r2.partitions_tested > 4 { return 0 }   // upper-bounded by request

    // (d) Reject too-small state vector.
    let tiny = [psi_0]
    let rt = phi_measure(tiny, 0, 0)
    if rt.ok != 0 { return 0 }
    if !rt.message.contains("dim < 2") { return 0 }

    // (e) Direct kernel path: X = 4×3, distinct column variances → top-2
    //     well-defined; covariance + ridge is SPD ⇒ ok=1.
    let row_a = [1.0, 0.0, 5.0]
    let row_b = [2.0, 0.0, 1.0]
    let row_c = [3.0, 0.0, 9.0]
    let row_d = [4.0, 0.0, 2.0]
    let rm = phi_measure_matrix([row_a, row_b, row_c, row_d], 2, 2, 0.001, 7)
    if rm.ok != 1 { return 0 }
    if rm.hid_trunc_used != 2 { return 0 }
    if rm.n_calib != 4 { return 0 }
    if _abs_p(rm.phi_min) > 1000.0 { return 0 }

    // (f) slogdet of a known matrix: det([[2,0],[0,3]]) = 6 ⇒ sign +1, log 6.
    let sd = _phi_slogdet([[2.0, 0.0], [0.0, 3.0]])
    if sd.sign != 1 { return 0 }
    if _abs_p(sd.logabsdet - log(6.0)) > 0.000001 { return 0 }
    // Negative determinant: det([[0,1],[1,0]]) = -1 ⇒ sign -1, log 0.
    let sd2 = _phi_slogdet([[0.0, 1.0], [1.0, 0.0]])
    if sd2.sign != (0 - 1) { return 0 }
    if _abs_p(sd2.logabsdet) > 0.000001 { return 0 }
    // Singular: det([[1,2],[2,4]]) = 0 ⇒ sign 0.
    let sd3 = _phi_slogdet([[1.0, 2.0], [2.0, 4.0]])
    if sd3.sign != 0 { return 0 }
    // 3×3 with a row swap: det([[0,1,0],[2,0,0],[0,0,3]]) = -6 ⇒ sign -1, log 6.
    let sd4 = _phi_slogdet([[0.0, 1.0, 0.0], [2.0, 0.0, 0.0], [0.0, 0.0, 3.0]])
    if sd4.sign != (0 - 1) { return 0 }
    if _abs_p(sd4.logabsdet - log(6.0)) > 0.000001 { return 0 }

    // (g) argsort_desc stable on ties: [3, 1, 3, 2] → [0, 2, 3, 1].
    let ord = _phi_argsort_desc([3.0, 1.0, 3.0, 2.0])
    if len(ord) != 4 { return 0 }
    if ord[0] != 0 { return 0 }
    if ord[1] != 2 { return 0 }
    if ord[2] != 3 { return 0 }
    if ord[3] != 1 { return 0 }

    return 1
}

fn main() {
    println("[qmirror/phi] anima_phi_v3_canonical port (pure-hexa kernel — slogdet/cov/argsort)")
    if _selftest() == 1 {
        // numeric verdict line for the report
        let bell = [complex_make(0.7071067811865475, 0.0),
                    complex_make(0.0, 0.0),
                    complex_make(0.0, 0.0),
                    complex_make(0.7071067811865475, 0.0)]
        let r = phi_measure(bell, 0, 0)
        println("[qmirror/phi] verdict: phi_min=" + str(r.phi_min) +
                " phi_mean=" + str(r.phi_mean) +
                " partitions_tested=" + str(r.partitions_tested) +
                " hid_trunc_used=" + str(r.hid_trunc_used) +
                " n_calib=" + str(r.n_calib) +
                " band=|phi|<1000 (PASS)")
        println("[qmirror/phi] SELFTEST PASS (F4: phi_measure(Bell) finite + defaults honored; slogdet/cov/argsort kernels verified)")
        println("__QMIRROR_PHI__ PASS")
    } else {
        println("[qmirror/phi] SELFTEST FAIL (F4 falsifier triggered)")
        println("__QMIRROR_PHI__ FAIL")
    }
}
