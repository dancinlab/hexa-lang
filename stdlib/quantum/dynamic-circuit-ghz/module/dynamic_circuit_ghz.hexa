#!hexa strict
// qmirror/dynamic-circuit-ghz/module/dynamic_circuit_ghz.hexa
//
// Constant-depth long-range entanglement via DYNAMIC CIRCUITS — exact
// ≤24-qubit pure-state-vector reproduction of the ideal protocol of
//   Bäumer, Tripathi, Wang, Rall, Chen, Majumder, Seif, Minev,
//   "Efficient Long-Range Entanglement using Dynamic Circuits",
//   arXiv:2308.13065, PRX Quantum 5, 030339 (2024).
//
// @tool(slug="qmirror_dynamic_circuit_ghz", desc="Dynamic-circuit constant-depth GHZ + long-range (teleported) CNOT on the pure-hexa engine_aer kernel. Mid-circuit measurement is implemented IN THIS MODULE as a projector + renormalization on the 2^n state vector (engine_aer external signature is untouched, @D g7). Feed-forward = classically-controlled Pauli conditioned on XOR-parity of recorded mid-circuit outcomes. Falsifier enumerates ALL 2^k measurement-outcome branches; PASS requires post-feed-forward GHZ parity = +1 and fidelity to ideal GHZ >= 1-1e-9 for EVERY branch.")
// @usage(hexa run qmirror/dynamic-circuit-ghz/module/dynamic_circuit_ghz.hexa --selftest)
// @sentinel(__QMIRROR_DYNAMIC_CIRCUIT_GHZ__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest exercises the pure-hexa state-vector kernel only (projector+renorm on the 2^n vector); no qiskit, no python bridge, no subprocess for the physics.")
//
// Paper ref: arXiv:2308.13065 §II (long-range CNOT gate teleportation),
//            §III + App. A.2 (constant-depth GHZ via mid-circuit measure
//            + classically-conditioned Pauli feed-forward).
// Governance: AGENTS.tape @D g1 (≤30q exact SV, A5 gates, Aer-equiv) ·
//             @D g5 (pure hexa, no .py/qiskit) · @D g6 (falsifier-first) ·
//             @D g7 (engine_aer/qrng/chsh/iit_mip sigs untouched) ·
//             @D g3/@F f1 (no n=6 lattice-fit; honest caveat below).
//
// ── HONEST CAVEAT (@D g3 / @F f1) ──────────────────────────────────────
// This is an EXACT classical ≤24-qubit state-vector simulation of the
// IDEAL dynamic-circuit protocol. Mid-circuit measurement here is a
// PERFECT projective collapse + renormalization; feed-forward is PERFECT
// classical control with ZERO latency. The simulation therefore has NO
// measurement latency, NO mid-circuit decoherence, NO classical-control
// error, NO readout error. The paper's headline "dynamic circuit beats
// the equivalent-depth unitary circuit" is a *hardware-noise* claim about
// real IBM devices (idle-time decoherence in the O(n)-depth unitary) and
// CANNOT be reproduced by this noiseless exact sim. What this module
// verifies is strictly the IDEAL-protocol correctness: that the dynamic
// circuit prepares EXACTLY the GHZ state (up to a deterministic,
// measurement-outcome-determined Pauli frame) on EVERY measurement
// branch. No n=6 lattice-fit is applied to IBM/Qiskit or any external
// entity (@F f1) — the construction is the paper's own.

use "../../engine_aer/module/state_vector.hexa"
use "../../engine_aer/module/gates.hexa"

// ── Verdict struct ─────────────────────────────────────────────────────

struct DynGhzVerdict {
    ok:              int,
    verdict:         str,        // "PASS" | "FAIL"
    n_qubits:        int,
    n_mid_meas:      int,        // # mid-circuit measurements (junctions)
    n_branches:      int,        // 2^n_mid_meas enumerated branches
    branches_ok:     int,        // # branches with parity +1 AND fidelity >= 1-1e-9
    min_fidelity:    float,      // worst-case fidelity over all branches
    min_parity:      float,      // worst-case GHZ parity <Z_0 Z_1...Z_{n-1}>
    cnot_tele_ok:    int,        // long-range teleported-CNOT primitive all-branch ok
    cnot_branches:   int,
    engine:          str,
    message:         str
}

fn _dg_fail(reason: str) -> DynGhzVerdict {
    return DynGhzVerdict {
        ok: 0, verdict: "FAIL", n_qubits: 0, n_mid_meas: 0,
        n_branches: 0, branches_ok: 0, min_fidelity: 0.0, min_parity: 0.0,
        cnot_tele_ok: 0, cnot_branches: 0, engine: "none", message: reason
    }
}

fn _abs_dg(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ── State-vector helpers (mid-circuit measurement primitive) ───────────
//
// engine_aer exposes ONLY unitary named/QASM circuits (no mid-circuit
// measurement) and its external signature is closure-bound (@D g7). So
// the projective-measurement + renormalization primitive lives HERE,
// operating on the farr-backed StateVector via the public accessors
// (amp_re_at / amp_im_at / state_set_re / state_set_im / state_dim).

// Apply Pauli-X on `q` (amplitude-index bit flip), in place.
fn _dg_apply_x(st: StateVector, q: int, n: int) -> StateVector {
    let g = gate_x()
    return apply_single(st, g.re, g.im, q, n)
}

// Apply Pauli-Z on `q`, in place.
fn _dg_apply_z(st: StateVector, q: int, n: int) -> StateVector {
    let g = gate_z()
    return apply_single(st, g.re, g.im, q, n)
}

// Apply Hadamard on `q`, in place.
fn _dg_apply_h(st: StateVector, q: int, n: int) -> StateVector {
    let g = gate_h()
    return apply_single(st, g.re, g.im, q, n)
}

// Probability that a Z-basis measurement of qubit `q` yields bit `b`.
// p = sum over amplitude indices i with ((i>>q)&1)==b of |amp_i|^2.
fn _dg_prob_bit(st: StateVector, q: int, b: int, n: int) -> float {
    let dim = state_dim(st)
    let mut p = 0.0
    let mut i = 0
    while i < dim {
        let bit = (i / _dg_pow2(q)) % 2
        if bit == b {
            let re = amp_re_at(st, i)
            let im = amp_im_at(st, i)
            p = p + re * re + im * im
        }
        i = i + 1
    }
    return p
}

fn _dg_pow2(k: int) -> int {
    let mut v = 1
    let mut j = 0
    while j < k {
        v = v * 2
        j = j + 1
    }
    return v
}

// PROJECTIVE mid-circuit measurement of qubit `q` onto outcome `b`,
// followed by RENORMALIZATION ( exact projector P_b / ||P_b psi|| ).
// Returns ok=0 if branch probability is ~0 (impossible outcome — caller
// skips that branch). Mutates the farr buffers in place.
fn _dg_project(st: StateVector, q: int, b: int, n: int) -> int {
    let dim = state_dim(st)
    let p = _dg_prob_bit(st, q, b, n)
    if p < 0.000000000001 {
        return 0   // impossible branch — zero-probability projector
    }
    let inv = 1.0 / sqrt(p)
    let mut i = 0
    while i < dim {
        let bit = (i / _dg_pow2(q)) % 2
        if bit == b {
            let _ra = state_set_re(st, i, amp_re_at(st, i) * inv)
            let _ia = state_set_im(st, i, amp_im_at(st, i) * inv)
        } else {
            let _rz = state_set_re(st, i, 0.0)
            let _iz = state_set_im(st, i, 0.0)
        }
        i = i + 1
    }
    return 1
}

// Ideal-GHZ reference vectors are built inline at each call site (the
// long-range-CNOT check and the GHZ-staircase check) because each needs
// a *branch-specific* ancilla product-state offset tensored onto the GHZ
// — a single fixed-register helper cannot express the recorded-outcome
// ancilla bits, so it was intentionally not factored out.

// |<phi|psi>|^2 for two same-dim state vectors (state fidelity for pure
// states). Both assumed normalized.
fn _dg_fidelity(a: StateVector, b: StateVector) -> float {
    let dim = state_dim(a)
    if state_dim(b) != dim { return 0.0 }
    let mut ip_re = 0.0
    let mut ip_im = 0.0
    let mut i = 0
    while i < dim {
        let ar = amp_re_at(a, i)
        let ai = amp_im_at(a, i)
        let br = amp_re_at(b, i)
        let bi = amp_im_at(b, i)
        // <a|b> = sum conj(a_i) b_i
        ip_re = ip_re + ar * br + ai * bi
        ip_im = ip_im + ar * bi - ai * br
        i = i + 1
    }
    return ip_re * ip_re + ip_im * ip_im
}

// GHZ correlation witness: the MINIMUM pairwise <Z_{reg[0]} Z_{reg[k]}>
// over k = 1..m-1. For a perfect GHZ on `reg` every two-body ZZ
// correlator is exactly +1 (all register bits are perfectly correlated),
// so this returns +1.0; any deviation pulls it below +1. (The full
// n-body <Z^{⊗m}> is 0 for even m and ±1 for odd m, so it is NOT a size-
// generic GHZ witness — pairwise ZZ + the X-basis fidelity below is.)
fn _dg_ghz_parity(st: StateVector, reg: [int], n: int) -> float {
    let dim = state_dim(st)
    let q0 = reg[0]
    let mut worst = 2.0
    let mut k = 1
    while k < len(reg) {
        let qk = reg[k]
        let mut corr = 0.0
        let mut i = 0
        while i < dim {
            let re = amp_re_at(st, i)
            let im = amp_im_at(st, i)
            let w = re * re + im * im
            if w > 0.0 {
                let b0 = (i / _dg_pow2(q0)) % 2
                let bk = (i / _dg_pow2(qk)) % 2
                if b0 == bk { corr = corr + w } else { corr = corr - w }
            }
            i = i + 1
        }
        if corr < worst { worst = corr }
        k = k + 1
    }
    return worst
}

// ── Long-range CNOT via gate teleportation — all-branch check ──────────
//
// (The reusable primitive `_dg_tele_cnot_inplace` is defined below, just
// before the GHZ staircase that composes it.) Here we verify the
// long-range CNOT in isolation: on input |+>_c |0>_t, an ideal
// CNOT(c -> t) produces the Bell pair (|00> + |11>)/sqrt2 on (c,t). The
// teleported implementation must reproduce that EXACTLY (fidelity 1, up
// to an unobservable global phase) on ALL 4 ancilla-measurement branches
// (x, z) in {0,1}^2 — the data qubits c,t are retained (NOT consumed).
// Register: c=0, t=1, ancilla pair (a,b)=(2,3).
fn _dg_cnot_tele_branch_fid(mx: int, mz: int) -> float {
    let n = 4
    let st = state_zero(n)
    let mut s = _dg_apply_h(st, 0, n)             // |+>_c on q0
    s = _dg_tele_cnot_inplace(s, 0, 1, 2, 3, mx, mz, n)
    if s.n_qubits < 0 {
        let _f = state_free(s)
        return 0.0 - 1.0
    }
    // ideal: CNOT(c->t)|+>|0> = (|00>+|11>)/sqrt2 on (c,t), ancillas in
    // |x>,|z> (product). Reference register {0,1}; ancillas a=mx,b=mz.
    let ideal = state_zero(n)
    let sct = 1.0 / sqrt(2.0)
    let base = mx * 4 + mz * 8                     // a=bit2, b=bit3
    let _r0 = state_set_re(ideal, base, sct)       // c=0,t=0
    let _r1 = state_set_re(ideal, base + 1 + 2, sct)   // c=1,t=1
    let fid = _dg_fidelity(s, ideal)
    let _f1 = state_free(s)
    let _f2 = state_free(ideal)
    return fid
}

// Returns # of the 4 (x,z) branches whose teleported long-range CNOT is
// exact (fidelity >= 1-1e-9). Expect 4/4.
fn _dg_cnot_tele_allbranch() -> int {
    let mut good = 0
    let mut mx = 0
    while mx < 2 {
        let mut mz = 0
        while mz < 2 {
            let fid = _dg_cnot_tele_branch_fid(mx, mz)
            if fid > 0.999999999 {
                good = good + 1
            }
            mz = mz + 1
        }
        mx = mx + 1
    }
    return good
}

// ── Long-range CNOT via gate teleportation (Gottesman–Chuang) ──────────
//
// In-place teleported CNOT(control c -> target t) consuming a fresh Bell
// resource ancilla pair (a,b). This is the paper's §II constant-depth
// long-range CNOT primitive (the GHZ circuit, §III / App. A.2, is built
// from a staircase of these). Standard identity (Gottesman–Chuang 1999):
//
//   resource Bell pair |Phi+>_{ab}            (H a ; CNOT a->b)
//   CNOT(c -> a)                              (entangle control)
//   CNOT(b -> t)                              (entangle target)
//   measure a in Z basis  -> x  (mid-circuit, projector + renorm)
//   measure b in X basis  -> z  (H b ; project ; mid-circuit)
//   feed-forward:  X on t  iff x == 1         (XOR-parity byproduct)
//                  Z on c  iff z == 1
//
// Net effect on the (c,t) data qubits: exactly CNOT(c -> t), for EVERY
// (x,z) measurement-outcome branch. `mx`,`mz` are the FORCED outcomes
// (the enumerator drives all 4). Returns ok=1, or 0 if the forced branch
// has zero probability (caller treats as non-applicable).
// NOTE: `apply_cnot` frees its input farr buffers and returns a FRESH
// StateVector struct, so this op MUST return the updated state (an `int`
// return would leave the caller holding a dangling handle). A failed
// (zero-probability) forced branch is signalled by returning a state
// whose `n_qubits` field is set to -1.
fn _dg_tele_cnot_inplace(s: StateVector, c: int, t: int,
                         a: int, b: int, mx: int, mz: int,
                         n: int) -> StateVector {
    // resource Bell pair on (a,b)  (ancillas start in |0>)
    let mut st = _dg_apply_h(s, a, n)
    st = apply_cnot(st, a, b, n)
    // entangle data into the resource
    st = apply_cnot(st, c, a, n)
    st = apply_cnot(st, b, t, n)
    // mid-circuit measurement of ancilla a in Z basis -> x
    let okA = _dg_project(st, a, mx, n)
    if okA != 1 { return StateVector { n_qubits: 0 - 1, re_h: st.re_h, im_h: st.im_h } }
    // mid-circuit measurement of ancilla b in X basis -> z
    //   (rotate b to Z with H, then projective Z-measure)
    st = _dg_apply_h(st, b, n)
    let okB = _dg_project(st, b, mz, n)
    if okB != 1 { return StateVector { n_qubits: 0 - 1, re_h: st.re_h, im_h: st.im_h } }
    // classically-conditioned Pauli feed-forward (deterministic frame):
    if mx == 1 { st = _dg_apply_x(st, t, n) }   // X on target  iff x==1
    if mz == 1 { st = _dg_apply_z(st, c, n) }   // Z on control iff z==1
    return st
}

// ── Constant-depth GHZ via a teleported-CNOT staircase ─────────────────
//
// Paper §III / App. A.2: the constant-depth GHZ is a staircase of the
// constant-depth long-range CNOTs above:
//
//   H(d_0) ; for k = 0..m-2 :  teleported-CNOT(d_k -> d_{k+1})
//
// which is exactly the GHZ "CNOT ladder", every rung gate-teleported
// through a fresh 2-ancilla Bell resource measured mid-circuit. Each
// rung contributes 2 mid-circuit measurement bits (x_k, z_k); the
// exhaustive falsifier enumerates ALL 2^(2(m-1)) outcome branches.
//
// Register layout (n = m + 2(m-1) = 3m-2):
//   data qubits     d_k = k                       (k = 0 .. m-1)
//   ancilla pair k  (a_k, b_k) = (m+2k, m+2k+1)   (k = 0 .. m-2)
//
// `branch` bit (2k)   = forced x_k (ancilla a_k, Z-basis)
// `branch` bit (2k+1) = forced z_k (ancilla b_k, X-basis)
//
// Returns [fidelity, parity] of the post-feed-forward DATA state vs the
// ideal GHZ on the data register {0,1,...,m-1}.
fn _dg_ghz_fusion_branch(m: int, branch: int) -> [float] {
    let n = 3 * m - 2
    let surv = _dg_surviving_reg(m)
    let st0 = state_zero(n)

    // H on data qubit 0  ->  (|0> + |1>)/sqrt2 on d_0
    let mut s = _dg_apply_h(st0, 0, n)

    // teleported-CNOT staircase: d_k -> d_{k+1}
    let mut k = 0
    while k < m - 1 {
        let c  = k                  // control data qubit
        let t  = k + 1              // target  data qubit
        let aa = m + 2 * k          // ancilla a_k
        let bb = m + 2 * k + 1      // ancilla b_k
        let mx = (branch / _dg_pow2(2 * k))     % 2   // x_k (Z-basis a_k)
        let mz = (branch / _dg_pow2(2 * k + 1)) % 2   // z_k (X-basis b_k)
        s = _dg_tele_cnot_inplace(s, c, t, aa, bb, mx, mz, n)
        if s.n_qubits < 0 {
            let _ff = state_free(s)
            return [0.0 - 1.0, 0.0 - 1.0]
        }
        k = k + 1
    }

    // Branch-correct ideal reference: GHZ on the data register {0..m-1}
    // TENSORED with the deterministic post-measurement ancilla product
    // state |x_0 z_0 x_1 z_1 ...> (ancilla a_k=m+2k holds x_k, b_k=m+2k+1
    // holds z_k). The data fidelity must be 1 against THIS reference on
    // every branch (the ancilla outcomes are recorded classical bits,
    // exactly the feed-forward inputs — not an error).
    let mut anc_off = 0
    let mut kk = 0
    while kk < m - 1 {
        let xk = (branch / _dg_pow2(2 * kk))     % 2
        let zk = (branch / _dg_pow2(2 * kk + 1)) % 2
        anc_off = anc_off + xk * _dg_pow2(m + 2 * kk)
        anc_off = anc_off + zk * _dg_pow2(m + 2 * kk + 1)
        kk = kk + 1
    }
    let ideal = state_zero(n)
    let sgh = 1.0 / sqrt(2.0)
    // data all-0 (+ ancilla offset)  and  data all-1 (+ ancilla offset)
    let mut data_all1 = 0
    let mut dq = 0
    while dq < m {
        data_all1 = data_all1 + _dg_pow2(dq)
        dq = dq + 1
    }
    let _r0 = state_set_re(ideal, anc_off, sgh)
    let _r1 = state_set_re(ideal, anc_off + data_all1, sgh)
    let fid = _dg_fidelity(s, ideal)
    let par = _dg_ghz_parity(s, surv, n)
    let _f1 = state_free(s)
    let _f2 = state_free(ideal)
    return [fid, par]
}

// data / surviving GHZ register = qubits 0,1,...,m-1.
fn _dg_surviving_reg(m: int) -> [int] {
    let mut reg = []
    let mut k = 0
    while k < m {
        reg = reg.push(k)
        k = k + 1
    }
    return reg
}

// Enumerate ALL 2^(m-1) measurement-outcome branches of the m-qubit
// dynamic-circuit GHZ. PASS requires, for EVERY branch, GHZ parity == +1
// and fidelity to the ideal GHZ >= 1 - 1e-9.
fn dyn_ghz_run(m: int) -> DynGhzVerdict {
    if m < 2 {
        return _dg_fail("dynamic_circuit_ghz: m >= 2 required")
    }
    let n = 3 * m - 2
    if n > 24 {
        return _dg_fail("dynamic_circuit_ghz: n=" + str(n) + " > 24 (@D g1 exact-SV envelope)")
    }
    let n_mid = 2 * (m - 1)          // 2 mid-circuit measures per rung
    let n_branches = _dg_pow2(n_mid)

    let mut branches_ok = 0
    let mut min_fid = 2.0
    let mut min_par = 2.0
    let mut br = 0
    while br < n_branches {
        let res = _dg_ghz_fusion_branch(m, br)
        let fid = res[0]
        let par = res[1]
        if fid < min_fid { min_fid = fid }
        if par < min_par { min_par = par }
        // falsifier-first criterion (per branch):
        //   parity == +1 (within 1e-9) AND fidelity >= 1 - 1e-9
        let par_ok = _abs_dg(par - 1.0) < 0.000000001
        let fid_ok = fid > 0.999999999          // >= 1 - 1e-9
        if par_ok && fid_ok {
            branches_ok = branches_ok + 1
        }
        br = br + 1
    }

    // Long-range teleported-CNOT primitive (paper §II), all 4 branches.
    let cnot_good = _dg_cnot_tele_allbranch()

    let all_ghz_ok = branches_ok == n_branches
    let all_cnot_ok = cnot_good == 4
    let pass = all_ghz_ok && all_cnot_ok

    return DynGhzVerdict {
        ok: 1,
        verdict: if pass { "PASS" } else { "FAIL" },
        n_qubits: n,
        n_mid_meas: n_mid,
        n_branches: n_branches,
        branches_ok: branches_ok,
        min_fidelity: min_fid,
        min_parity: min_par,
        cnot_tele_ok: if all_cnot_ok { 1 } else { 0 },
        cnot_branches: cnot_good,
        engine: "hexa_native",
        message: "dyn-ghz m=" + str(m) + " n=" + str(n) +
                 " branches " + str(branches_ok) + "/" + str(n_branches) +
                 " ok; min_fid=" + str(min_fid) + " min_par=" + str(min_par) +
                 " ; tele-CNOT " + str(cnot_good) + "/4"
    }
}

// ── Falsifier-first selftest ───────────────────────────────────────────
//
// FAILED branch (must exist & be testable BEFORE the pass branch, @D g6):
// for ANY enumerated measurement-outcome branch, if the post-feed-forward
// GHZ parity != +1 OR fidelity to ideal GHZ < 1-1e-9, the run is FAIL and
// a `dynamic_circuit_ghz_<ts>_FAILED.marker` is emitted.

fn _dg_selftest_ok(v: DynGhzVerdict) -> int {
    if v.ok != 1 { return 0 }
    if v.verdict != "PASS" { return 0 }
    if v.branches_ok != v.n_branches { return 0 }
    if v.min_fidelity < 0.999999999 { return 0 }
    if _abs_dg(v.min_parity - 1.0) > 0.000000001 { return 0 }
    if v.cnot_tele_ok != 1 { return 0 }
    if v.cnot_branches != 4 { return 0 }
    return 1
}

fn _dg_emit_marker(v: DynGhzVerdict, pass: int) {
    let ts = exec("date +%s").trim()
    let qm_root = env("QMIRROR_ROOT")
    let root = if qm_root.len() > 0 { qm_root } else { exec("pwd").trim() }
    let marker_dir = root + "/state/markers"
    let _md = exec("mkdir -p " + marker_dir + " 2>/dev/null")
    let marker_name = if pass == 1 {
        "dynamic_circuit_ghz_" + ts + ".marker"
    } else {
        "dynamic_circuit_ghz_" + ts + "_FAILED.marker"
    }
    let marker_path = marker_dir + "/" + marker_name
    let body = "[qmirror/dynamic-circuit-ghz]" +
               " n_qubits=" + str(v.n_qubits) +
               " n_mid_meas=" + str(v.n_mid_meas) +
               " branches_ok=" + str(v.branches_ok) + "/" + str(v.n_branches) +
               " min_fid=" + str(v.min_fidelity) +
               " min_par=" + str(v.min_parity) +
               " tele_cnot=" + str(v.cnot_branches) + "/4" +
               " verdict=" + v.verdict
    let _w = exec("echo '" + body + "' > '" + marker_path + "'")
    println("  marker: " + marker_path)
}

fn main() {
    println("[qmirror/dynamic-circuit-ghz] constant-depth GHZ + long-range CNOT")
    println("  paper: Baeumer et al., arXiv:2308.13065 (PRX Quantum 5, 030339)")
    println("  caveat: EXACT noiseless ideal-protocol sim — perfect projective")
    println("          mid-circuit measure + zero-latency feed-forward; the")
    println("          paper's dynamic-beats-unitary claim is HARDWARE noise")
    println("          (NOT reproducible here). Verifies ideal correctness only.")
    println("")

    // Headline: 3 data GHZ qubits -> n = 3*3-2 = 7 qubits total,
    // n_mid = 2*(3-1) = 4 mid-circuit measurements, 2^4 = 16 branches
    // (every branch enumerated; the `hexa run` interpreter has no
    // loop-temporary GC, so n is kept small — the construction is
    // size-generic and the exact ceiling is the 2^24 envelope of @D g1).
    let m = 3
    let v = dyn_ghz_run(m)
    if v.ok != 1 {
        println("  ERROR: " + v.message)
        _dg_emit_marker(v, 0)
        println("[qmirror/dynamic-circuit-ghz] SELFTEST FAIL (run error)")
        println("__QMIRROR_DYNAMIC_CIRCUIT_GHZ__ FAIL")
        return
    }

    println("  GHZ surviving qubits      = " + str(m))
    println("  total register (n)        = " + str(v.n_qubits))
    println("  mid-circuit measurements  = " + str(v.n_mid_meas))
    println("  enumerated branches       = " + str(v.n_branches) + " (= 2^" + str(v.n_mid_meas) + ")")
    println("  branches GHZ-correct      = " + str(v.branches_ok) + "/" + str(v.n_branches))
    println("  min fidelity (all branch) = " + str(v.min_fidelity) + "  (ideal 1.0)")
    println("  min GHZ parity (all br.)  = " + str(v.min_parity) + "  (ideal +1.0)")
    println("  long-range tele-CNOT      = " + str(v.cnot_branches) + "/4 branches ok")
    println("  verdict                   = " + v.verdict)
    println("")

    let ok = _dg_selftest_ok(v)
    _dg_emit_marker(v, ok)
    if ok == 1 {
        println("[qmirror/dynamic-circuit-ghz] SELFTEST PASS")
        println("  (all " + str(v.n_branches) + " measurement branches: GHZ fidelity=1, parity=+1;")
        println("   long-range teleported CNOT exact on all 4 branches)")
        println("__QMIRROR_DYNAMIC_CIRCUIT_GHZ__ PASS")
    } else {
        println("[qmirror/dynamic-circuit-ghz] SELFTEST FAIL (falsifier triggered)")
        println("__QMIRROR_DYNAMIC_CIRCUIT_GHZ__ FAIL")
    }
}
