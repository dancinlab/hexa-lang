fn cmd_dispatch(sub: str, args: [str]) {
    let path = _module_path(sub)
    if len(path) == 0 {
        println("hexa qmirror: unknown subcommand '" + sub + "'")
        println("run 'hexa qmirror --help' for usage")
        exit(2)
    }
    println("[qmirror/" + sub + "] running " + path)
    let raw = _run_module(path, args)
    println(raw)
}

fn main() {
    let argv = args()
    let n = len(argv)
    let mut subcmd_idx = -1
    let mut i = 0
    while i < n {
        if argv[i].ends_with(".hexa") { subcmd_idx = i + 1; break }
        i = i + 1
    }
    if subcmd_idx < 0 { subcmd_idx = 2 }

    if subcmd_idx >= n {
        cmd_status()
        return
    }

    let sub = argv[subcmd_idx]
    let mut sub_args = []
    let mut j = subcmd_idx + 1
    while j < n {
        sub_args.push(argv[j])
        j = j + 1
    }

    if sub == "--help" || sub == "-h" || sub == "help" {
        cmd_help()
    } else if sub == "--version" || sub == "-v" || sub == "version" {
        cmd_version()
    } else if sub == "status" {
        cmd_status()
    } else {
        cmd_dispatch(sub, sub_args)
    }
}
