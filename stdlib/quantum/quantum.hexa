#!hexa strict
// stdlib/quantum/quantum.hexa — qmirror stdlib CLI dispatcher
//
// @version 2.6.0
// @capabilities [quantum, simulation, dispatch, cli, subprocess]
// @stability stable
// @since 2026-05-16
//
// Runnable entrypoint dispatched by `hexa qmirror <subcmd>` (see self/main.hexa
// `else if sub == "qmirror"` branch).
//
// qmirror — laptop-grade drop-in replacement for IBM Cloud / Braket QPU rental
// for the ≤30-qubit low-noise envelope. Pure-hexa Aer-compatible state-vector
// kernel + 27 quantum algorithm modules. RFC 045 absorbed dancinlab/qmirror
// v2.6.0 (62,402 LoC, 38 module dirs); original SSOT frozen as the
// dancinlab/qmirror GitHub private repo (헌법 v2 룰 3).
//
// Modules are standalone programs (each has main + sentinel). chemistry_vqe
// + bench use relative imports (./ and ../../<feature>/module/) — the
// <feature>/module/ structure is preserved verbatim under stdlib/quantum/
// so all relative imports resolve unchanged.
//
// Source: RFC 045 — absorbs ~/core/qmirror/cli/qmirror.hexa v2.6.0.

let VERSION = "2.6.0"

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _run_module(rel_path: str, extra: [str]) -> str {
    let hexa_bin = exec("command -v hexa 2>/dev/null || echo hexa").trim()
    let mut cmd = _shq(hexa_bin) + " run " + _shq(rel_path)
    let mut i = 0
    while i < len(extra) {
        cmd = cmd + " " + _shq(extra[i])
        i = i + 1
    }
    return exec(cmd + " 2>&1")
}

fn _module_path(sub: str) -> str {
    if sub == "chsh" { return "stdlib/quantum/chsh/module/chsh.hexa" }
    if sub == "nist" { return "stdlib/quantum/chsh/module/chsh.hexa" }
    if sub == "qrng" { return "stdlib/quantum/qrng/module/qrng.hexa" }
    if sub == "iit" { return "stdlib/quantum/iit_mip/module/iit_mip.hexa" }
    if sub == "selftest" { return "stdlib/quantum/selftest/module/selftest.hexa" }
    if sub == "rqaoa" { return "stdlib/quantum/recursive-qaoa-maxcut/module/recursive_qaoa_maxcut.hexa" }
    if sub == "ctx" { return "stdlib/quantum/contextuality-peres-mermin/module/contextuality_peres_mermin.hexa" }
    if sub == "dynghz" { return "stdlib/quantum/dynamic-circuit-ghz/module/dynamic_circuit_ghz.hexa" }
    if sub == "vqd" { return "stdlib/quantum/vqd-excited-cs/module/vqd_excited_cs.hexa" }
    if sub == "stab-ext" { return "stdlib/quantum/stabilizer-extent/module/stabilizer_extent.hexa" }
    if sub == "overlap-vqe" { return "stdlib/quantum/overlap-adapt-vqe/module/overlap_adapt_vqe.hexa" }
    if sub == "sre" { return "stdlib/quantum/magic-stabilizer-renyi/module/magic_stabilizer_renyi.hexa" }
    if sub == "lg" { return "stdlib/quantum/leggett-garg-superunitary/module/leggett_garg_superunitary.hexa" }
    if sub == "pseudo-tel" { return "stdlib/quantum/pseudo-telepathy-doily/module/pseudo_telepathy_doily.hexa" }
    if sub == "rpe" { return "stdlib/quantum/rpe-gate-calib/module/rpe_gate_calib.hexa" }
    if sub == "sym-shadow" { return "stdlib/quantum/symmetry-adjusted-shadows/module/symmetry_adjusted_shadows.hexa" }
    if sub == "hardy" { return "stdlib/quantum/hardy-multipartite/module/hardy_multipartite.hexa" }
    if sub == "page-curve" { return "stdlib/quantum/page-curve-scrambler/module/page_curve_scrambler.hexa" }
    if sub == "qdrift" { return "stdlib/quantum/qdrift-hamiltonian-sim/module/qdrift_hamiltonian_sim.hexa" }
    if sub == "cdr" { return "stdlib/quantum/clifford-data-regression/module/clifford_data_regression.hexa" }
    if sub == "wigner" { return "stdlib/quantum/wigner-negativity-discrete/module/wigner_negativity_discrete.hexa" }
    if sub == "qfi" { return "stdlib/quantum/qfi-spin-motion/module/qfi_spin_motion.hexa" }
    if sub == "shallow" { return "stdlib/quantum/shallow-shadows/module/shallow_shadows.hexa" }
    if sub == "gme-steer" { return "stdlib/quantum/steering-gme-minimal/module/steering_gme_minimal.hexa" }
    if sub == "mabk" { return "stdlib/quantum/mabk-ardehali/module/mabk_ardehali.hexa" }
    if sub == "mirror-bench" { return "stdlib/quantum/mirror-fidelity-bench/module/mirror_fidelity_bench.hexa" }
    return ""
}

