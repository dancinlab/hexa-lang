fn cmd_version() {
    println("hexa qmirror " + VERSION)
    println("stdlib/quantum — RFC 045 absorption of dancinlab/qmirror v2.6.0")
    println("license: Apache-2.0  |  DOI: 10.5281/zenodo.20102964")
}

fn cmd_status() {
    println("hexa qmirror " + VERSION + " status")
    println("")
    println("Quantum Mirror substrate — 38 module dirs · 62,402 LoC · ≤30-qubit laptop-grade")
    println("")
    println("  CORE")
    println("    engine_aer     2,170 LoC  Aer-compatible pure-hexa state-vector kernel + QASM3")
    println("    circuit · sampler · stabilizer · entropy · qrng · selftest")
    println("    chsh           CHSH Bell test   ·   iit_mip / phi   IIT 4.0 phi-star")
    println("")
    println("  ALGORITHMS (27 modules, each @D-governed vs a published reference)")
    println("    rqaoa · ctx · dynghz · vqd · stab-ext · overlap-vqe · sre · lg · pseudo-tel")
    println("    rpe · sym-shadow · hardy · page-curve · qdrift · cdr · wigner · qfi · shallow")
