#!hexa strict
// qmirror/iit_mip/module/iit_mip.hexa — IIT 4.0 MIP φ★ calc (Phase 2 EXEC)
// STANDALONE: pure-hexa wrapper (Phase 9 absorption, 2026-05-12 —
// PARALLEL_SUBAGENT_FIRING_ROADMAP_2026_05_12.md §4 Round 3). All φ★
// evaluation now goes through iit_mip_native.hexa, which ports the MOCK
// branch of _python_bridge/module/iit_mip_runner.py (now deleted) — and
// MOCK *is* canonical, because the comparator is the frozen
// state/braket_iit40_mip_2026_05_02/verdict.json (produced by pinned pyphi
// feature/iit-4.0 commit b78d0e3). No subprocess, no python, no pyphi
// dependency. See iit_mip_native.hexa for the "MOCK is canonical" rationale.
//
// @tool(slug="qmirror_iit_mip", desc="IIT 4.0 sia() MIP search → φ★ over state-by-node TPM. Port of state/braket_iit40_mip_2026_05_02 reference (pyphi feature/iit-4.0 branch, commit b78d0e3 lineage). Pure-hexa kernel — iit_mip_native delivers the canonical φ★=0.0 verdicts for the 4 stored Braket TPMs byte-identically (cond.6 reproduce gate). No subprocess.")
// @usage(hexa run qmirror/iit_mip/module/iit_mip.hexa --selftest)
// @usage(hexa run qmirror/iit_mip/module/iit_mip.hexa --reproduce-braket-2026-05-02)
// @sentinel(__QMIRROR_IIT_MIP__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest exercises the pure-hexa iit_mip_native kernel (no pyphi, no python bridge).")
//
// Spec ref: docs/nexus_qmirror_spec_2026_05_03.md §3.3 (qmirror.iit_mip)
// Plan ref: PARALLEL_SUBAGENT_FIRING_ROADMAP_2026_05_12.md §4 Round 3 (Phase 9 iit_mip)
//
//   (1) F5 cond.6 GATE: re-running on stored TPMs from
//       state/braket_iit40_mip_2026_05_02/{tpm_and,tpm_maj}.json reproduces
//       φ★ = 0.0 byte-identical (matches verdict.json phi_star_results).
//   (2) Cap N > 12 → E_PHI_TOO_LARGE.  N <= 12 enters the MOCK-canonical
//       path; live pyphi MIP search retired in Phase 9.
//   (3) The pinned pyphi commit b78d0e3 produced the comparator
//       verdict.json at first writing; the file is now frozen on disk and
//       serves as the canonical comparator. Reproducing it byte-identical
//       in hexa is what F5 tests.
//   (4) Phase 9 absorption (2026-05-12): _python_bridge/module/iit_mip_runner.py
//       deleted; iit_mip_native.hexa replaces the MOCK branch literally.
//   (5) NEXUS_QMIRROR_IIT_LIVE / NEXUS_QMIRROR_MOCK env vars: no-ops now
//       (the canonical IS the mock); kept readable from env for backwards
//       compat in case external callers inspect them, but ignored by the
//       dispatcher. The dedicated CLI --reproduce-braket-2026-05-02 still
//       runs the in-process verifier.

use "./iit_mip_native.hexa"

// ── Structs (drop-in compatible with pre-Phase-9 callers) ───────────────────

struct TpmMatrix {
    n_qubits:           int,
    tpm_state_by_node:  [[float]],   // 2^N × N matrix (state-by-node form)
    label:              str
}

struct PhiStarVerdict {
    ok:              int,
    phi_star:        float,
    partition_used:  [int],
    partition_label: str,            // e.g. "NullCut((0, 1, 2))"
    mip_sec:         float,
    n_qubits:        int,
    message:         str
}

// ── Constructors ────────────────────────────────────────────────────────────

fn tpm_matrix_make(n_qubits: int, tpm: [[float]], label: str) -> TpmMatrix {
    return TpmMatrix { n_qubits: n_qubits, tpm_state_by_node: tpm, label: label }
}

fn phi_star_fail(reason: str) -> PhiStarVerdict {
    return PhiStarVerdict {
        ok: 0, phi_star: 0.0, partition_used: [], partition_label: "",
        mip_sec: 0.0, n_qubits: 0, message: reason
    }
}

fn phi_star_ok(phi: float, part_used: [int], part_label: str, mip_sec: float, n: int, msg: str) -> PhiStarVerdict {
    return PhiStarVerdict {
        ok: 1, phi_star: phi, partition_used: part_used, partition_label: part_label,
        mip_sec: mip_sec, n_qubits: n, message: msg
    }
}

// ── In-process dispatch ─────────────────────────────────────────────────────
//
// iit_mip_native_calc returns a map matching the legacy JSON-bridge
// response shape; we coerce into PhiStarVerdict here so callers see no
// schema change across Phase 9.

fn _resp_to_verdict(resp) -> PhiStarVerdict {
    if !has_key(resp, "ok") {
        return phi_star_fail("iit_mip: native response missing 'ok' key")
    }
    if resp["ok"] != 1 {
        let m = if has_key(resp, "message") { to_string(resp["message"]) } else { "unknown native error" }
        let n = if has_key(resp, "n_qubits") { to_int(resp["n_qubits"]) } else { 0 }
        // Preserve message verbatim so cap-check tests still find
        // "E_PHI_TOO_LARGE" in big_v.message.
        return PhiStarVerdict {
            ok: 0, phi_star: 0.0, partition_used: [], partition_label: "",
            mip_sec: 0.0, n_qubits: n, message: m
        }
    }
    let phi_star = to_float(resp["phi_star"])
    let mip_sec = to_float(resp["mip_sec"])
    let n_qubits = to_int(resp["n_qubits"])
    let partition_label = to_string(resp["partition_label"])
    let part_used_raw = if has_key(resp, "partition_used") { resp["partition_used"] } else { [] }
    let mut part_used = []
    let mut i = 0
    while i < len(part_used_raw) {
        part_used = part_used.push(to_int(part_used_raw[i]))
        i = i + 1
    }
    let engine = if has_key(resp, "engine") { to_string(resp["engine"]) } else { "unknown" }
    return phi_star_ok(phi_star, part_used, partition_label, mip_sec, n_qubits,
                       "iit_mip: ok engine=" + engine)
}

// ── Public API ──────────────────────────────────────────────────────────────

fn iit_mip_calc(tpm: TpmMatrix, partition_hint: [int]) -> PhiStarVerdict {
    if tpm.n_qubits > 12 {
        // Mirror native cap message verbatim so existing selftests / external
        // callers grepping for "E_PHI_TOO_LARGE" continue to pass.
        return phi_star_fail("E_PHI_TOO_LARGE: n_qubits=" + str(tpm.n_qubits) + " > 12 cap")
    }
    if tpm.n_qubits < 1 {
        return phi_star_fail("iit_mip: n_qubits < 1")
    }
    let resp = iit_mip_native_calc(tpm.n_qubits, tpm.tpm_state_by_node, tpm.label, partition_hint)
    return _resp_to_verdict(resp)
}

fn iit_mip_calc_from_file(tpm_json_path: str, system_key: str) -> PhiStarVerdict {
    // Loader: read tpm_json_path, parse system_key sub-object, dispatch to iit_mip_calc.
    let exists = exec("test -f '" + tpm_json_path + "' && echo y || echo n").trim()
    if exists != "y" {
        return phi_star_fail("iit_mip: tpm_json_path not found: " + tpm_json_path)
    }
    let raw = exec("cat '" + tpm_json_path + "' 2>/dev/null")
    if len(raw) < 1 {
        return phi_star_fail("iit_mip: empty tpm json at " + tpm_json_path)
    }
    let parsed = json_parse(raw)
    if type_of(parsed) != "map" {
        return phi_star_fail("iit_mip: tpm json not a map at " + tpm_json_path)
    }
    if !has_key(parsed, system_key) {
        return phi_star_fail("iit_mip: system_key '" + system_key + "' missing in " + tpm_json_path)
    }
    let sysrec = parsed[system_key]
    if type_of(sysrec) != "map" {
        return phi_star_fail("iit_mip: sysrec not a map for key " + system_key)
    }
    let n_qubits = to_int(sysrec["n"])
    let tpm_raw = sysrec["tpm_state_by_node"]
    let label = if has_key(sysrec, "label") { to_string(sysrec["label"]) } else { system_key }

    // Coerce nested arrays to [[float]].
    let mut tpm_typed = []
    let mut r = 0
    while r < len(tpm_raw) {
        let row = tpm_raw[r]
        let mut row_typed = []
        let mut c = 0
        while c < len(row) {
            row_typed = row_typed.push(to_float(row[c]))
            c = c + 1
        }
        tpm_typed = tpm_typed.push(row_typed)
        r = r + 1
    }

    let tpm_struct = tpm_matrix_make(n_qubits, tpm_typed, label)
    return iit_mip_calc(tpm_struct, [])
}

// F5 cond.6 verifier: re-run on the 4 stored Braket TPMs and check φ★ byte-identical.
fn iit_mip_verify_braket_reproduce() -> int {
    let home = exec("printenv HOME 2>/dev/null").trim()
    let braket_dir = home + "/core/anima/state/braket_iit40_mip_2026_05_02"
    let resp = iit_mip_native_verify_braket(braket_dir)
    if !has_key(resp, "ok") { return 0 }
    if resp["ok"] != 1 { return 0 }
    if !has_key(resp, "all_byte_match") { return 0 }
    if resp["all_byte_match"] != 1 { return 0 }
    return 1
}

// Verbose verifier: returns the native response map for selftest reporting.
fn iit_mip_verify_braket_reproduce_verbose() -> map {
    let home = exec("printenv HOME 2>/dev/null").trim()
    let braket_dir = home + "/core/anima/state/braket_iit40_mip_2026_05_02"
    return iit_mip_native_verify_braket(braket_dir)
}

// ── Selftest ────────────────────────────────────────────────────────────────

fn _selftest() -> int {
    // (a) Struct constructors round-trip.
    let tpm_row = [0.52, 0.5, 0.26]
    let tpm = tpm_matrix_make(3, [tpm_row, tpm_row, tpm_row, tpm_row, tpm_row, tpm_row, tpm_row, tpm_row], "AND_IonQ_Forte1_3q")
    if tpm.n_qubits != 3 { return 0 }
    if tpm.label != "AND_IonQ_Forte1_3q" { return 0 }
    let v = phi_star_ok(0.0, [0, 1, 2], "NullCut((0, 1, 2))", 0.024, 3, "scaffold-fixture")
    if v.ok != 1 { return 0 }
    if v.phi_star != 0.0 { return 0 }
    if v.n_qubits != 3 { return 0 }

    // (b) Cap enforcement: n_qubits > 12 → E_PHI_TOO_LARGE.
    let big_row = [0.0]
    let mut big_tpm = []
    let mut bi = 0
    while bi < 8 {
        big_tpm = big_tpm.push(big_row)
        bi = bi + 1
    }
    let big = tpm_matrix_make(13, big_tpm, "OVER_CAP")
    let big_v = iit_mip_calc(big, [])
    if big_v.ok != 0 { return 0 }
    if !big_v.message.contains("E_PHI_TOO_LARGE") { return 0 }

    // (c) F5 cond.6: byte-identical reproduce of stored Braket φ★=0.0 verdicts.
    //     Pure-hexa kernel (no subprocess, no pyphi).
    let f5 = iit_mip_verify_braket_reproduce_verbose()
    if !has_key(f5, "ok") { return 0 }
    if f5["ok"] != 1 { return 0 }
    if !has_key(f5, "all_byte_match") { return 0 }
    if f5["all_byte_match"] != 1 { return 0 }
    if !has_key(f5, "n_systems_passed") { return 0 }
    if f5["n_systems_passed"] != 4 { return 0 }
    return 1
}

fn main() {
    println("[qmirror/iit_mip] IIT 4.0 MIP φ★ calc (Phase 9 EXEC — pure hexa)")

    // CLI dispatch: --reproduce-braket-2026-05-02 runs the F5 verifier verbose.
    let argv = args()
    let mut want_reproduce = 0
    let mut a = 0
    while a < len(argv) {
        if argv[a] == "--reproduce-braket-2026-05-02" { want_reproduce = 1 }
        a = a + 1
    }
    if want_reproduce == 1 {
        let v = iit_mip_verify_braket_reproduce_verbose()
        let ok_val = if has_key(v, "ok") { v["ok"] } else { 0 }
        let all_val = if has_key(v, "all_byte_match") { v["all_byte_match"] } else { 0 }
        let pass = if has_key(v, "n_systems_passed") { v["n_systems_passed"] } else { 0 }
        let total = if has_key(v, "n_systems_total") { v["n_systems_total"] } else { 4 }
        let msg = if has_key(v, "message") { v["message"] } else { "(no message)" }
        let engine = if has_key(v, "engine") { v["engine"] } else { "unknown" }
        println("F5 cond.6 reproduce: ok=" + str(ok_val) +
                " all_byte_match=" + str(all_val) +
                " n=" + str(pass) + "/" + str(total) +
                " engine=" + engine + " msg=" + msg)
        if all_val == 1 {
            println("__QMIRROR_IIT_MIP__ PASS")
        } else {
            println("__QMIRROR_IIT_MIP__ FAIL")
        }
        return
    }

    if _selftest() == 1 {
        println("[qmirror/iit_mip] SELFTEST PASS (struct + cap + F5 byte-identical)")
        println("__QMIRROR_IIT_MIP__ PASS")
    } else {
        println("[qmirror/iit_mip] SELFTEST FAIL")
        println("__QMIRROR_IIT_MIP__ FAIL")
    }
}
