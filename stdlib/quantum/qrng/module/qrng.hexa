#!hexa strict
// qmirror/qrng/module/qrng.hexa - public QRNG API (drop-in for HMAC-DRBG path)
//
// @tool(slug="qmirror_qrng", desc="Public QRNG service: qrng_bits / qrng_uint64 / qrng_choice. Drop-in replacement for the existing HMAC-DRBG path in nexus_qrng_integration spec. Sources entropy from qmirror.entropy (ANU live, mock LCG fallback).")
// @usage(hexa run qmirror/qrng/module/qrng.hexa --selftest)
// @sentinel(__QMIRROR_QRNG__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest uses mock entropy fixture (NEXUS_QMIRROR_MOCK=1 default).")
//
// Spec ref: docs/nexus_qmirror_spec_2026_05_03.md §3.1 (qmirror.qrng)
//
// Drop-in shape:
//   qrng_bits(n_bytes)        -> QmirrorBytes
//   qrng_uint64()             -> int       (single q-random 64-bit int)
//   qrng_choice(seq)          -> any       (q-random pick from list)
//
// NEXUS_QMIRROR_QRNG_DIRECT=1 -> each draw is fresh entropy (no DRBG fan-out).
// Otherwise behaves like existing hybrid_default mode.

struct QmirrorBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    provenance:   str,
    request_id:   str,
    message:      str
}

// Inlined entropy fixture (LCG matches qrng/mock_qrng.hexa byte-identical).
fn _qrng_lcg_bytes(n_bytes: int, seed: int) -> [int] {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return bytes_
}

fn _qrng_env(name: str) -> str {
    return exec("printenv " + name + " 2>/dev/null || true").trim()
}

// Single-exec mode dispatch. Reads NEXUS_QMIRROR_MOCK / NEXUS_QRNG_MOCK /
// ANIMA_QRNG_MOCK / NEXUS_QMIRROR_LIVE in one shell roundtrip and returns
// "mock" | "live" | "default". Replaces 4 separate _qrng_env() exec()s,
// keeping qrng_bits's per-call hexa-runtime fork footprint to 1.
fn _qrng_mode() -> str {
    let script = "if [ \"$NEXUS_QMIRROR_MOCK\" = \"1\" ] || [ \"$NEXUS_QRNG_MOCK\" = \"1\" ] || [ \"$ANIMA_QRNG_MOCK\" = \"1\" ]; then echo mock; elif [ \"$NEXUS_QMIRROR_LIVE\" = \"1\" ]; then echo live; else echo default; fi"
    return exec("bash -c '" + script + "'").trim()
}

// Secret retrieval chain (mirrors entropy.hexa::_qmirror_secret).
// Order: `secret` CLI → 1Password CLI → macOS Keychain → AWS Secrets Manager
//        → printenv.
// Single bash -c invocation collapses 5 potential exec() calls to 1, keeping
// well under the hexa_interp fork-storm cap (HEXA_FORK_CAP=32 default).
// Caller must pass [A-Z0-9_]+ literals (all current call sites do).
fn _qrng_secret(name: str) -> str {
    let script = "v=$(secret get \"$1\" 2>/dev/null); [ -n \"$v\" ] && { echo \"$v\"; exit; }; " +
                 "v=$(op read \"op://Private/$1/credential\" 2>/dev/null); [ -n \"$v\" ] && { echo \"$v\"; exit; }; " +
                 "v=$(security find-generic-password -a \"$USER\" -s \"$1\" -w 2>/dev/null); [ -n \"$v\" ] && { echo \"$v\"; exit; }; " +
                 "v=$(aws secretsmanager get-secret-value --secret-id \"$1\" --query SecretString --output text 2>/dev/null); [ -n \"$v\" ] && { echo \"$v\"; exit; }; " +
                 "printenv \"$1\" 2>/dev/null"
    return exec("bash -c '" + script + "' _ '" + name + "'").trim()
}

// ANU REST live paths.  Inlined here to keep qrng.hexa standalone for selftest.
// Production install routes through entropy.hexa::entropy_pull (same 3-tier).
//
// 3-tier chain (mirrors entropy.hexa::_anu_live_4tier_n):
//   T1.c paid    : ANU_KEY_PAID    (100 req/sec, $0.005/req)
//   T1.b direct  : ANU_KEY_FREE    (100 req/min, free, key-gated)
//   T1.a legacy  : keyless qrng.anu.edu.au (1 req/min)
// Each tier returns [] on failure so the caller can fall through.
// Keys are resolved through _qrng_secret() chain (secret/op/keychain/aws-sm/env).
// (No T1.d "trial" — ANU's keyless free path is T1.a; no separate trial key.)

// Parse new-endpoint ANU JSON: extract bytes from "data":[ ... ].
// Accepts both compact ("data":[..]) and pretty ("data": [..]) wire formats —
// the AWS Marketplace paid endpoint serves the latter, the legacy direct
// endpoint serves the former. Mirrors entropy.hexa::_anu_parse_v2.
fn _qrng_anu_parse(body: str, n_bytes: int) -> [int] {
    if body.contains("\"success\":true") == false { if body.contains("\"success\": true") == false { return [] } }
    let mut sep = "\"data\":["
    if body.contains(sep) == false {
        sep = "\"data\": ["
        if body.contains(sep) == false { return [] }
    }
    let after = body.split(sep)
    if len(after) < 2 { return [] }
    let arr_parts = after[1].split("]")
    if len(arr_parts) < 1 { return [] }
    let toks = arr_parts[0].split(",")
    let mut out = []
    let mut i = 0
    while i < len(toks) {
        let t = toks[i].trim()
        if len(t) > 0 {
            let v = to_int(t)
            if v >= 0 { if v <= 255 { out = out.push(v) } }
        }
        i = i + 1
    }
    if len(out) != n_bytes { return [] }
    return out
}

// Generic ANU keyed GET (new endpoint, used by T1.b/c/d).
fn _qrng_anu_keyed_get(n_bytes: int, key: str) -> [int] {
    if n_bytes < 1 { return [] }
    if n_bytes > 1024 { return [] }
    if len(key) < 1 { return [] }
    let url = "https://api.quantumnumbers.anu.edu.au/?length=" + str(n_bytes) + "&type=uint8"
    let cmd = "curl -sS --max-time 10 -H 'x-api-key: " + key + "' '" + url + "' 2>&1"
    let body = exec(cmd).trim()
    return _qrng_anu_parse(body, n_bytes)
}

// T1.c — AWS Marketplace paid (default if ANU_KEY_PAID resolves).
fn _qrng_anu_paid(n_bytes: int) -> [int] {
    let key = _qrng_secret("ANU_KEY_PAID")
    return _qrng_anu_keyed_get(n_bytes, key)
}

// T1.b — Direct keyed (ANU_KEY_FREE; free, 100 req/min).
fn _qrng_anu_direct(n_bytes: int) -> [int] {
    let key = _qrng_secret("ANU_KEY_FREE")
    return _qrng_anu_keyed_get(n_bytes, key)
}

// T1.a — Legacy keyless (qrng.anu.edu.au/API/jsonI.php, 1 req/min).
fn _qrng_anu_legacy(n_bytes: int) -> [int] {
    if n_bytes < 1 { return [] }
    if n_bytes > 1024 { return [] }
    let url = "https://qrng.anu.edu.au/API/jsonI.php?length=" + str(n_bytes) + "&type=uint8"
    let cmd = "curl -sS --max-time 30 '" + url + "' 2>&1"
    let body = exec(cmd).trim()
    return _qrng_anu_parse(body, n_bytes)
}

// Back-compat shim: existing callers of _qrng_anu_live get T1.b (direct keyed).
fn _qrng_anu_live(n_bytes: int) -> [int] {
    return _qrng_anu_direct(n_bytes)
}

// Public: pull n bytes of quantum-grade entropy.
fn qrng_bits(n_bytes: int) -> QmirrorBytes {
    if n_bytes < 1 {
        return QmirrorBytes {
            ok: 0, n_bytes: 0, bytes_: [], provenance: "none",
            request_id: "", message: "qrng_bits: n_bytes >= 1 required"
        }
    }
    let mode = _qrng_mode()
    if mode == "mock" {
        let bs = _qrng_lcg_bytes(n_bytes, 12345)
        return QmirrorBytes {
            ok: 1, n_bytes: len(bs), bytes_: bs, provenance: "mock",
            request_id: "lcg12345",
            message: "qrng_bits: mock fixture (NEXUS_QMIRROR_MOCK=1) - WARN no quantum entropy"
        }
    }
    if mode == "live" {
        let ts = exec("date +%s").trim()
        // 3-tier walk: paid → direct → legacy.  First tier returning
        // n_bytes wins.  Each helper returns [] on failure (missing key,
        // rate-limit, network) so we naturally fall through.
        let bs_p = _qrng_anu_paid(n_bytes)
        if len(bs_p) == n_bytes {
            return QmirrorBytes {
                ok: 1, n_bytes: n_bytes, bytes_: bs_p, provenance: "anu_aws_paid",
                request_id: "anu_aws_paid_" + ts,
                message: "qrng_bits: ANU live tier=anu_aws_paid (vacuum-fluctuation)"
            }
        }
        let bs_d = _qrng_anu_direct(n_bytes)
        if len(bs_d) == n_bytes {
            return QmirrorBytes {
                ok: 1, n_bytes: n_bytes, bytes_: bs_d, provenance: "anu_direct",
                request_id: "anu_direct_" + ts,
                message: "qrng_bits: ANU live tier=anu_direct (vacuum-fluctuation)"
            }
        }
        let bs_l = _qrng_anu_legacy(n_bytes)
        if len(bs_l) == n_bytes {
            return QmirrorBytes {
                ok: 1, n_bytes: n_bytes, bytes_: bs_l, provenance: "anu_legacy",
                request_id: "anu_legacy_" + ts,
                message: "qrng_bits: ANU live tier=anu_legacy (vacuum-fluctuation, rate-throttled)"
            }
        }
        return QmirrorBytes {
            ok: 0, n_bytes: 0, bytes_: [], provenance: "none",
            request_id: "",
            message: "qrng_bits: all 3 ANU tiers failed (no keys / rate-limit / network)"
        }
    }
    // Default: mock with WARN.
    let bs = _qrng_lcg_bytes(n_bytes, 42)
    return QmirrorBytes {
        ok: 1, n_bytes: len(bs), bytes_: bs, provenance: "mock",
        request_id: "lcg42",
        message: "qrng_bits: default mock (set NEXUS_QMIRROR_LIVE=1 + NEXUS_QMIRROR_ANU_KEY for live)"
    }
}

// Single 64-bit q-random int. As with the spec, returned via float
// fractional accumulation -> scaled int; fits in signed int64 because we
// throttle to 63 bits to avoid overflow.
fn qrng_uint64() -> int {
    let r = qrng_bits(8)
    if r.ok != 1 { return 0 }
    // Use 7 bytes (56 bits) to stay well within signed int64. Caller
    // wanting full 64-bit width should consume bytes_ directly.
    let mut v = 0
    let mut p = 1
    let mut i = 0
    while i < 7 {
        v = v + r.bytes_[i] * p
        p = p * 256
        i = i + 1
    }
    return v
}

// Q-random selection from a list.
fn qrng_choice(seq) {
    let n = len(seq)
    if n < 1 { return void }
    let r = qrng_bits(8)
    if r.ok != 1 { return seq[0] }
    // Map first byte modulo n. For n <= 64 this is fine; larger n has
    // mild bias (not corrected here, matches existing nexus practice).
    let idx = r.bytes_[0] % n
    return seq[idx]
}

fn _selftest() -> int {
    // 1. qrng_bits returns requested count.
    let r1 = qrng_bits(8)
    if r1.ok != 1 { return 0 }
    if r1.n_bytes != 8 { return 0 }
    if r1.provenance != "mock" {
        // Default install in CI must NOT silently use live ANU.  Accept any
        // 3-tier provenance label if NEXUS_QMIRROR_LIVE=1 was set in the env.
        let mut live_ok = 0
        if r1.provenance == "anu_aws_paid"  { live_ok = 1 }
        if r1.provenance == "anu_direct"    { live_ok = 1 }
        if r1.provenance == "anu_legacy"    { live_ok = 1 }
        if live_ok != 1 { return 0 }
    }
    // 2. qrng_uint64 in non-trivial range.
    let u = qrng_uint64()
    if u < 0 { return 0 }
    // 3. qrng_choice picks an element from the list.
    let pick = qrng_choice(["alpha", "beta", "gamma", "delta"])
    let mut found = 0
    if pick == "alpha" { found = 1 }
    if pick == "beta"  { found = 1 }
    if pick == "gamma" { found = 1 }
    if pick == "delta" { found = 1 }
    if found != 1 { return 0 }
    // 4. n_bytes < 1 -> ok=0.
    let r4 = qrng_bits(0)
    if r4.ok != 0 { return 0 }
    // 5. Determinism: with mock env, two calls give identical bytes
    //    (LCG is deterministic, which is the CI expectation).
    let r5a = qrng_bits(8)
    let r5b = qrng_bits(8)
    if r5a.bytes_[0] != r5b.bytes_[0] { return 0 }
    return 1
}

fn main() {
    println("[qmirror/qrng] public QRNG drop-in (HMAC-DRBG replacement)")
    if _selftest() == 1 {
        println("[qmirror/qrng] SELFTEST PASS")
        println("__QMIRROR_QRNG__ PASS")
    } else {
        println("[qmirror/qrng] SELFTEST FAIL")
        println("__QMIRROR_QRNG__ FAIL")
    }
}
