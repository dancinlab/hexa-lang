// HEXA Standard Library — deck/bio
//
// @version 0.1.0
// @capabilities [pure]
//
// BEST-EFFORT bio deck emitter — emits a minimal PDB file (HEADER +
// ATOM records) and a minimal mmCIF from a biomolecule spec.
//
// SPEC schema (DeckSpec keys / list-keys):
//   pdb_id                   — 4-char identifier (default "XXXX")
//   title                    — title line (default "untitled")
//   classification           — HEADER classification, default "DE NOVO"
//   deposition_date          — DD-MMM-YY (default "01-JAN-26")
//   sequence                 — single-letter AA sequence (e.g. "MKTAYIA...")
//                              Used to emit SEQRES records.
//   chain_id                 — single-char chain (default "A")
//   atoms (list)             — pre-formatted ATOM rows (caller-provided).
//                              Each row should be a complete PDB ATOM line
//                              MINUS the trailing newline. If empty AND
//                              sequence is set, the emitter generates one
//                              CA-only stub per residue (placeholder coords).
//   structure                — "linear_ca_stub" (default if atoms empty) |
//                              "caller_atoms" (atoms list verbatim)
//
// TODO(d6 honest):
//   - Does NOT predict 3D structure (no AlphaFold / Rosetta).
//   - CA-only stub places residues along the x-axis at 3.8 Å spacing
//     (the C-α adjacent-residue mean) — NOT a physically valid backbone.
//     Use for FORMAT-validation only; real coords must come from a
//     prediction pipeline (stdlib/bio/protein-fold or experimental input).
//   - mmCIF emission is the minimal atom_site loop only; full mmCIF
//     dictionary categories (entity, struct, refln…) are out of scope.

import "stdlib/deck/gen.hexa"

pub fn emit_bio(spec: DeckSpec) -> [DeckFile] {
    let files: [DeckFile] = []
    let pdb_id = spec_get_or(spec, "pdb_id", "XXXX")
    let prefix = _lower(pdb_id)
    deck_push(files, prefix + ".pdb", _bio_pdb(spec))
    deck_push(files, prefix + ".cif", _bio_mmcif(spec))
    return files
}

fn _bio_pdb(spec: DeckSpec) -> string {
    let pdb_id     = spec_get_or(spec, "pdb_id", "XXXX")
    let title      = spec_get_or(spec, "title", "untitled")
    let cls        = spec_get_or(spec, "classification", "DE NOVO")
    let dep_date   = spec_get_or(spec, "deposition_date", "01-JAN-26")
    let sequence   = spec_get_or(spec, "sequence", "")
    let chain      = spec_get_or(spec, "chain_id", "A")
    let atoms      = spec_get_list(spec, "atoms")
    let structure  = spec_get_or(spec, "structure",
        if len(atoms) > 0 { "caller_atoms" } else { "linear_ca_stub" })

    let mut s = ""
    s = s + _pdb_header(cls, dep_date, pdb_id)
    s = s + _pdb_title(title)
    if len(sequence) > 0 { s = s + _pdb_seqres(sequence, chain) }

    if structure == "caller_atoms" {
        let mut i = 0
        while i < len(atoms) {
            s = s + atoms[i] + "\n"
            i = i + 1
        }
    } else {
        // linear CA stub: one C-α per residue along +x, 3.8 Å spacing.
        // TODO(d6 honest): geometrically invalid — for format check only.
        s = s + _pdb_linear_ca_stub(sequence, chain)
    }
    s = s + "END\n"
    return s
}

fn _bio_mmcif(spec: DeckSpec) -> string {
    let pdb_id   = spec_get_or(spec, "pdb_id", "XXXX")
    let title    = spec_get_or(spec, "title", "untitled")
    let sequence = spec_get_or(spec, "sequence", "")
    let chain    = spec_get_or(spec, "chain_id", "A")
    let atoms    = spec_get_list(spec, "atoms")

    let mut s = ""
    s = s + "data_" + pdb_id + "\n"
    s = s + "# mmCIF stub — generated by stdlib/deck/bio (d6 honest: atom_site loop only).\n"
    s = s + "_entry.id " + pdb_id + "\n"
    s = s + "_struct.title '" + title + "'\n"
    s = s + "\n"
    s = s + "loop_\n"
    s = s + "_atom_site.group_PDB\n"
    s = s + "_atom_site.id\n"
    s = s + "_atom_site.type_symbol\n"
    s = s + "_atom_site.label_atom_id\n"
    s = s + "_atom_site.label_comp_id\n"
    s = s + "_atom_site.label_asym_id\n"
    s = s + "_atom_site.label_seq_id\n"
    s = s + "_atom_site.Cartn_x\n"
    s = s + "_atom_site.Cartn_y\n"
    s = s + "_atom_site.Cartn_z\n"
    s = s + "_atom_site.occupancy\n"
    s = s + "_atom_site.B_iso_or_equiv\n"
    // Minimal stub — emit one CA per residue if no caller atoms.
    if len(atoms) > 0 {
        // TODO(d6 honest): caller atoms are PDB-format rows; mmCIF needs
        // tokenized fields. For now we emit a comment marker and trust the
        // .pdb companion for the geometry.
        s = s + "# (atom_site rows omitted — see " + _lower(pdb_id) + ".pdb for geometry)\n"
    } else if len(sequence) > 0 {
        let mut i = 0
        let n = len(sequence)
        while i < n {
            let aa1 = sequence.substring(i, i + 1)
            let res3 = _aa1_to_aa3(aa1)
            let x = _ca_x(i)
            s = s + "ATOM " + str(i + 1) + " C CA " + res3 + " " + chain + " " + str(i + 1) + " " + x + " 0.000 0.000 1.00 30.00\n"
            i = i + 1
        }
    }
    return s
}

// ── PDB record helpers ───────────────────────────────────────────────

fn _pdb_header(cls: string, dep_date: string, pdb_id: string) -> string {
    // HEADER columns (PDB v3.3): cols 11-50 classification, 51-59 date,
    // 63-66 ID. We approximate with space-padding (parsers tolerant).
    let mut h = "HEADER    "
    h = h + _pad_right(cls, 40)
    h = h + dep_date
    h = h + "   "
    h = h + pdb_id
    h = h + "\n"
    return h
}

fn _pdb_title(title: string) -> string {
    return "TITLE     " + title + "\n"
}

// SEQRES records — 13 residues per row, 3-letter codes.
fn _pdb_seqres(sequence: string, chain: string) -> string {
    let mut out = ""
    let total = len(sequence)
    let mut row = 1
    let mut i = 0
    while i < total {
        let mut line = "SEQRES " + _pad_left(str(row), 3) + " " + chain + " " + _pad_left(str(total), 4) + " "
        let mut j = 0
        while j < 13 && (i + j) < total {
            line = line + _aa1_to_aa3(sequence.substring(i + j, i + j + 1)) + " "
            j = j + 1
        }
        out = out + line + "\n"
        i = i + 13
        row = row + 1
    }
    return out
}

// Stub one CA atom per residue at (i * 3.8, 0, 0). Format-valid PDB
// ATOM line; geometrically invalid (caller knows — d6 honest).
fn _pdb_linear_ca_stub(sequence: string, chain: string) -> string {
    let mut out = ""
    let n = len(sequence)
    let mut i = 0
    while i < n {
        let aa1 = sequence.substring(i, i + 1)
        let res3 = _aa1_to_aa3(aa1)
        let serial = _pad_left(str(i + 1), 5)
        let res_num = _pad_left(str(i + 1), 4)
        let x = _pad_left(_ca_x(i), 8)
        // ATOM cols: 1-6 record, 7-11 serial, 13-16 atom name, 18-20 resName,
        // 22 chain, 23-26 resSeq, 31-38 x, 39-46 y, 47-54 z, 55-60 occ,
        // 61-66 bfactor, 77-78 element.
        let mut line = "ATOM  "
        line = line + serial + "  CA  " + res3 + " " + chain + res_num + "    "
        line = line + x + "   0.000   0.000  1.00 30.00           C"
        out = out + line + "\n"
        i = i + 1
    }
    return out
}

// CA x-coordinate at residue index i: i * 3.8 Å, formatted "%.3f".
// Pre-computed via integer arithmetic (3800 milli-Å steps) so the
// emitter doesn't depend on str(float) precision.
fn _ca_x(i: int) -> string {
    let milli = i * 3800
    let int_part = milli / 1000
    let frac = milli - int_part * 1000
    let frac_str = _pad_left(str(frac), 3)
    return str(int_part) + "." + frac_str
}

fn _pad_left(s: string, w: int) -> string {
    let pad = w - len(s)
    if pad <= 0 { return s }
    let mut out = ""
    let mut i = 0
    while i < pad { out = out + " "; i = i + 1 }
    return out + s
}

fn _pad_right(s: string, w: int) -> string {
    let pad = w - len(s)
    if pad <= 0 { return s }
    let mut out = s
    let mut i = 0
    while i < pad { out = out + " "; i = i + 1 }
    return out
}

fn _lower(s: string) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let ch = s.substring(i, i + 1)
        if ch >= "A" && ch <= "Z" {
            let lc = ord(ch) + 32
            out = out + from_char_code(lc)
        } else {
            out = out + ch
        }
        i = i + 1
    }
    return out
}

// Standard 20 amino-acid one-letter → three-letter mapping. Returns "UNK" for non-standard.
fn _aa1_to_aa3(aa: string) -> string {
    if aa == "A" { return "ALA" }
    if aa == "R" { return "ARG" }
    if aa == "N" { return "ASN" }
    if aa == "D" { return "ASP" }
    if aa == "C" { return "CYS" }
    if aa == "E" { return "GLU" }
    if aa == "Q" { return "GLN" }
    if aa == "G" { return "GLY" }
    if aa == "H" { return "HIS" }
    if aa == "I" { return "ILE" }
    if aa == "L" { return "LEU" }
    if aa == "K" { return "LYS" }
    if aa == "M" { return "MET" }
    if aa == "F" { return "PHE" }
    if aa == "P" { return "PRO" }
    if aa == "S" { return "SER" }
    if aa == "T" { return "THR" }
    if aa == "W" { return "TRP" }
    if aa == "Y" { return "TYR" }
    if aa == "V" { return "VAL" }
    return "UNK"
}
