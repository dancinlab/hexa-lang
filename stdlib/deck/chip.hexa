// HEXA Standard Library — deck/chip
//
// @version 0.1.0
// @capabilities [pure]
//
// BEST-EFFORT chip deck emitter — emits Verilog .v module skeleton plus
// a minimal Liberty .lib stub from a module spec.
//
// SPEC schema (DeckSpec keys / list-keys):
//   module_name        — Verilog module identifier (e.g. "adder8")
//   inputs (list)      — input ports, each as "name[:width]" (width=1 default)
//   outputs (list)     — output ports, each as "name[:width]"
//   inouts (list)      — bidirectional ports (optional)
//   params (list)      — parameters as "NAME=VALUE" (e.g. "WIDTH=8")
//   body               — module body Verilog text (default = empty TODO stub)
//   lib_cell_name      — Liberty cell name (default = module_name)
//   lib_area           — cell area, e.g. "12.0" (default "1.0")
//   lib_pg_pins (list) — power/ground pins, e.g. ["VDD","VSS"]
//
// TODO(d6 honest): does NOT synthesize, does NOT validate Verilog
// grammar. The `body` field is emitted verbatim. .lib is a structural
// stub only (mandatory keys + pg_pin block + one ff/cell entry). For
// full Liberty timing/power tables, extend per campaign.

import "stdlib/deck/gen.hexa"

pub fn emit_chip(spec: DeckSpec) -> [DeckFile] {
    let files: [DeckFile] = []
    let mod_name = spec_get_or(spec, "module_name", "untitled")
    deck_push(files, mod_name + ".v",   _chip_verilog(spec))
    deck_push(files, mod_name + ".lib", _chip_liberty(spec))
    return files
}

fn _chip_verilog(spec: DeckSpec) -> string {
    let mod_name = spec_get_or(spec, "module_name", "untitled")
    let inputs   = spec_get_list(spec, "inputs")
    let outputs  = spec_get_list(spec, "outputs")
    let inouts   = spec_get_list(spec, "inouts")
    let params   = spec_get_list(spec, "params")
    let body     = spec_get_or(spec, "body",
                               "  // TODO: module body — generated stub, fill in logic.\n")

    let mut s = ""
    s = s + "// Verilog module — generated by stdlib/deck/chip\n"
    s = s + "// d6 honest: structural skeleton; logic body is caller-provided.\n"
    s = s + "\n"
    s = s + "module " + mod_name
    if len(params) > 0 {
        s = s + " #(\n"
        let mut i = 0
        while i < len(params) {
            let tail = if i + 1 < len(params) { "," } else { "" }
            s = s + "  parameter " + params[i] + tail + "\n"
            i = i + 1
        }
        s = s + ")"
    }
    s = s + " (\n"
    // Collect port list — input then inout then output (per Verilog convention).
    let mut ports: [string] = []
    let mut i = 0
    while i < len(inputs)  { ports.push("input  " + _port_decl(inputs[i]));  i = i + 1 }
    i = 0
    while i < len(inouts)  { ports.push("inout  " + _port_decl(inouts[i]));  i = i + 1 }
    i = 0
    while i < len(outputs) { ports.push("output " + _port_decl(outputs[i])); i = i + 1 }

    i = 0
    while i < len(ports) {
        let tail = if i + 1 < len(ports) { "," } else { "" }
        s = s + "  " + ports[i] + tail + "\n"
        i = i + 1
    }
    s = s + ");\n"
    s = s + "\n"
    s = s + body
    if !_ends_with_nl(body) { s = s + "\n" }
    s = s + "\n"
    s = s + "endmodule\n"
    return s
}

fn _chip_liberty(spec: DeckSpec) -> string {
    let mod_name = spec_get_or(spec, "module_name", "untitled")
    let cell     = spec_get_or(spec, "lib_cell_name", mod_name)
    let area     = spec_get_or(spec, "lib_area", "1.0")
    let pg_pins  = spec_get_list(spec, "lib_pg_pins")

    let mut s = ""
    s = s + "/* Liberty .lib stub — generated by stdlib/deck/chip (d6 honest: structural only). */\n"
    s = s + "library (" + cell + "_lib) {\n"
    s = s + "  technology (cmos);\n"
    s = s + "  delay_model : table_lookup;\n"
    s = s + "  voltage_unit : \"1V\";\n"
    s = s + "  current_unit : \"1mA\";\n"
    s = s + "  pulling_resistance_unit : \"1kohm\";\n"
    s = s + "  capacitive_load_unit (1, ff);\n"
    s = s + "  time_unit : \"1ns\";\n"
    s = s + "\n"
    s = s + "  cell (" + cell + ") {\n"
    s = s + "    area : " + area + ";\n"
    let mut i = 0
    while i < len(pg_pins) {
        // Convention: first = VDD (power), rest = VSS / VBB (ground/bias).
        let pg_type = if i == 0 { "primary_power" } else { "primary_ground" }
        s = s + "    pg_pin (" + pg_pins[i] + ") { pg_type : " + pg_type + "; }\n"
        i = i + 1
    }
    // TODO(d6 honest): one functional pin block per port — caller
    // extends with timing tables. Stub omits per-pin timing arcs.
    s = s + "  }\n"
    s = s + "}\n"
    return s
}

// ── helpers ──────────────────────────────────────────────────────────

// Port decl: "name" -> "name" (1-bit); "name:8" -> "[7:0] name".
fn _port_decl(p: string) -> string {
    let mut i = 0
    while i < len(p) {
        if p.substring(i, i + 1) == ":" {
            let name = p.substring(0, i)
            let w    = p.substring(i + 1, len(p))
            // [w-1:0] name — use string-side arithmetic (caller-trusted width).
            return "[" + _w_minus_1(w) + ":0] " + name
        }
        i = i + 1
    }
    return p
}

// Compute "w - 1" lexically for common single-token widths (e.g. "8" -> "7").
// For composite/expr widths (e.g. "WIDTH"), emit "WIDTH-1" verbatim.
fn _w_minus_1(w: string) -> string {
    // Numeric path
    let mut i = 0
    let mut all_digit = true
    while i < len(w) {
        let ch = w.substring(i, i + 1)
        if ch < "0" || ch > "9" { all_digit = false }
        i = i + 1
    }
    if all_digit && len(w) > 0 {
        let mut n = 0
        let mut j = 0
        while j < len(w) {
            n = n * 10 + (ord(w.substring(j, j + 1)) - 48)
            j = j + 1
        }
        return str(n - 1)
    }
    return w + "-1"
}

fn _ends_with_nl(s: string) -> bool {
    if len(s) == 0 { return false }
    return s.substring(len(s) - 1, len(s)) == "\n"
}
