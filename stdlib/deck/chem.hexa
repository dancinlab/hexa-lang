// HEXA Standard Library — deck/chem
//
// @version 0.1.0
// @capabilities [pure]
//
// BEST-EFFORT chem deck emitter — emits NWChem .nw input + companion
// .xyz geometry from a molecular spec.
//
// SPEC schema (DeckSpec keys / list-keys):
//   prefix             — NWChem prefix (e.g. "molecule")
//   title              — title string
//   charge             — net charge int (default "0")
//   multiplicity       — spin multiplicity int (default "1")
//   geometry_units     — "angstroms" (default) | "bohr"
//   atoms (list)       — geometry rows "Sym x y z" (Å or Bohr per units)
//   basis              — e.g. "def2-svp" (default "6-31g*")
//   ecp                — optional ECP, e.g. "crenbl_ecp" (default omit)
//   method             — "dft" (default) | "scf" | "ccsd"
//   xc                 — for dft: "xpbe96 cpbe96" (default · per d14 pure PBE)
//   maxiter            — SCF maxiter (default "400" per d15)
//   convergence_damp   — default "70" (per d15)
//   convergence_lshift — default "0.5" (per d15 lshift, NOT levelshift, ref hexa-lang INBOX)
//   smear              — default "0.01" (per d15)
//   task               — "energy" (default) | "optimize" | "freq"
//
// d13/d14/d15 baked in: pure PBE (xpbe96 cpbe96) recommended first
// pass for metal-oxide clusters; SCF aids smear+damp+lshift+maxiter400.

import "stdlib/deck/types.hexa"

pub fn emit_chem(spec: DeckSpec) -> [DeckFile] {
    let files: [DeckFile] = []
    let prefix = spec_get_or(spec, "prefix", "molecule")
    deck_push(files, prefix + ".nw", _chem_nw(spec))
    deck_push(files, prefix + ".xyz", _chem_xyz(spec))
    return files
}

fn _chem_nw(spec: DeckSpec) -> string {
    let prefix = spec_get_or(spec, "prefix", "molecule")
    let title  = spec_get_or(spec, "title", "untitled")
    let charge = spec_get_or(spec, "charge", "0")
    let mult   = spec_get_or(spec, "multiplicity", "1")
    let units  = spec_get_or(spec, "geometry_units", "angstroms")
    let atoms  = spec_get_list(spec, "atoms")
    let basis  = spec_get_or(spec, "basis", "6-31g*")
    let ecp    = spec_get_or(spec, "ecp", "")
    let method = spec_get_or(spec, "method", "dft")
    let xc     = spec_get_or(spec, "xc", "xpbe96 cpbe96")
    let maxit  = spec_get_or(spec, "maxiter", "400")
    let damp   = spec_get_or(spec, "convergence_damp", "70")
    let lshift = spec_get_or(spec, "convergence_lshift", "0.5")
    let smear  = spec_get_or(spec, "smear", "0.01")
    let task   = spec_get_or(spec, "task", "energy")

    let mut s = ""
    s = s + "# NWChem deck — generated by stdlib/deck/chem (d13/d14/d15 baked in)\n"
    s = s + "title \"" + title + "\"\n"
    s = s + "start " + prefix + "\n"
    s = s + "charge " + charge + "\n"
    s = s + "\n"
    s = s + "geometry units " + units + " noautosym noautoz\n"
    let mut i = 0
    while i < len(atoms) {
        s = s + "  " + atoms[i] + "\n"
        i = i + 1
    }
    s = s + "end\n"
    s = s + "\n"
    s = s + "basis spherical\n"
    s = s + "  * library " + basis + "\n"
    s = s + "end\n"
    if len(ecp) > 0 {
        s = s + "\n"
        s = s + "ecp\n"
        s = s + "  * library " + ecp + "\n"
        s = s + "end\n"
    }
    s = s + "\n"
    if method == "dft" {
        s = s + "dft\n"
        s = s + "  mult " + mult + "\n"
        s = s + "  xc " + xc + "       # d14 pure PBE first pass (5-10x faster than hybrid)\n"
        s = s + "  smear " + smear + "        # d15 small-gap SCF aid\n"
        s = s + "  convergence damp " + damp + " lshift " + lshift + "  # d15 (NOTE: lshift, NOT levelshift — INBOX ref)\n"
        s = s + "  iterations " + maxit + "    # d15 maxiter\n"
        s = s + "end\n"
        s = s + "\n"
        s = s + "task dft " + task + "\n"
    } else {
        // SCF / CCSD fallback path
        s = s + "scf\n"
        s = s + "  nopen " + _scf_nopen_from_mult(mult) + "\n"
        s = s + "  maxiter " + maxit + "\n"
        s = s + "end\n"
        s = s + "\n"
        s = s + "task " + method + " " + task + "\n"
    }
    return s
}

fn _chem_xyz(spec: DeckSpec) -> string {
    let title = spec_get_or(spec, "title", "untitled")
    let atoms = spec_get_list(spec, "atoms")
    let mut s = ""
    s = s + str(len(atoms)) + "\n"
    s = s + title + "\n"
    let mut i = 0
    while i < len(atoms) {
        s = s + atoms[i] + "\n"
        i = i + 1
    }
    return s
}

// SCF nopen = (multiplicity - 1). Multiplicity "1" -> nopen "0", etc.
fn _scf_nopen_from_mult(mult: string) -> string {
    if mult == "1" { return "0" }
    if mult == "2" { return "1" }
    if mult == "3" { return "2" }
    if mult == "4" { return "3" }
    if mult == "5" { return "4" }
    // TODO(d6 honest): higher multiplicities — caller may need to set
    // nopen directly via spec_set("scf_nopen", "...") (not currently
    // wired through; mult <= 5 covers the campaign-relevant range).
    return "0"
}
