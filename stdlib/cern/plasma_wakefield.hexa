#!hexa strict
// stdlib/cern/plasma_wakefield.hexa — cold linear plasma-wakefield scalings (CLEAN-ROOM)
//
// @version 0.0.1
// @capabilities [analytic, plasma-wakefield, accelerator, oracle]
// @stability stage-2 — hexa-native first-principles re-derivation. There
//            is NO Python substrate; the body is closed-form cold-plasma
//            linear theory, so the hexa module is itself the Stage 1+2
//            deliverable (cf. bethe_bloch_stopping.hexa lineage).
// @since 2026-05-25
//
// SCOPE (demiurge CERN.md §1.5 — "가속 메커니즘" 축)
//   This is the FIRST `plasma-wakefield` cell of the CERN domain — the
//   "tabletop accelerator" (laser/beam-driven plasma wakefield, LWFA /
//   PWFA) acceleration mechanism, an axis VALUE inside CERN (not a
//   separate domain — lazy-split to LPA.md only once it outgrows CERN).
//
// CLEAN-ROOM PROVENANCE (demiurge design.md Decision 1)
//   *** NOT a WarpX / FBPIC / Smilei / OSIRIS re-derivation. ***
//   Re-derives the published textbook cold-plasma linear scalings — no
//   PIC source-code inspection. Three closed forms, all standard:
//     - plasma (angular) frequency     ω_p = sqrt(n_e e² / (ε₀ m_e))
//     - plasma wavelength              λ_p = 2π c / ω_p
//     - cold non-rel wave-breaking     E_0 = m_e c ω_p / e   (Dawson 1959)
//   external refs : J.M. Dawson, "Nonlinear electron oscillations in a
//                   cold plasma", Phys. Rev. 113 (1959) 383 (wave-break
//                   field E_0). E. Esarey, C.B. Schroeder, W.P. Leemans,
//                   "Physics of laser-driven plasma-based electron
//                   accelerators", Rev. Mod. Phys. 81 (2009) 1229
//                   (eqs. 1–3 — the ω_p / λ_p / E_0 engineering scalings).
//   external consts (SI 2019 / CODATA): e, ε₀, m_e, c — folded as
//                   compile-time constants (no run-time dependency).
//
// HONESTY (g3 — non-negotiable)
//   Cold LINEAR theory only. Omits: relativistic wave-breaking boost
//   (Akhiezer-Polovin √[2(γ_p−1)] factor), laser/beam driver envelope,
//   dephasing length, pump depletion, beam loading, ion motion, 2-D/3-D
//   blowout (bubble) regime. So this cell is a SCALING oracle, NOT a
//   tabletop-accelerator design. measurement_gate = GATE_OPEN /
//   absorbed = false — a PIC (WarpX) parity round + a sourced LWFA stage
//   spec are the downstream gates, out of scope here.
//
// Self-consistency cross-check (selftest): the engineering coefficients
// E_0[V/m] ≈ 96·sqrt(n_e[cm⁻³]) and λ_p[µm] ≈ 3.34e10/sqrt(n_e[cm⁻³])
// (the form quoted across the LWFA literature) are reproduced to <1e-4
// relative from the SI constants — an independent correctness anchor on
// top of the value pins.

use "stdlib/core/math/float"

// ─── public types ─────────────────────────────────────────────────────────

// One plasma-density operating point and its derived wakefield scalings.
struct WakefieldPoint {
    n_e_cm3:    float,   // electron density input  [cm⁻³]
    n_e_m3:     float,   // electron density in SI  [m⁻³]
    omega_p:    float,   // plasma angular frequency [rad/s]
    lambda_p_m: float,   // plasma wavelength        [m]
    e0_v_per_m: float,   // cold wave-breaking field [V/m]
}

// ─── constants (fn form — `pub let` is not AOT-stable, cf. math/float) ──────

// Elementary charge [C] (SI 2019 exact).
fn elem_charge() -> float { return 0.0000000000000000001602176634 }
// Vacuum permittivity [F/m] (CODATA).
fn vac_permittivity() -> float { return 0.0000000000088541878128 }
// Electron rest mass [kg] (CODATA).
fn electron_mass_kg() -> float { return 0.00000000000000000000000000000091093837015 }
// Speed of light [m/s] (SI 2019 exact).
fn speed_of_light() -> float { return 299792458.0 }

// ─── closed forms ───────────────────────────────────────────────────────────

// Plasma angular frequency ω_p = sqrt(n_e e² / (ε₀ m_e))  [rad/s], n_e in m⁻³.
fn plasma_omega(n_e_m3: float) -> float {
    let e = elem_charge()
    return sqrt(n_e_m3 * e * e / (vac_permittivity() * electron_mass_kg()))
}

// Plasma wavelength λ_p = 2π c / ω_p  [m].
fn plasma_wavelength(omega_p: float) -> float {
    return 2.0 * pi() * speed_of_light() / omega_p
}

// Cold non-relativistic wave-breaking field E_0 = m_e c ω_p / e  [V/m] (Dawson).
fn wavebreak_field(omega_p: float) -> float {
    return electron_mass_kg() * speed_of_light() * omega_p / elem_charge()
}

// Evaluate all scalings at a density given in cm⁻³ (the LWFA-literature unit).
fn evaluate(n_e_cm3: float) -> WakefieldPoint {
    let n_e_m3 = n_e_cm3 * 1000000.0      // cm⁻³ → m⁻³
    let w = plasma_omega(n_e_m3)
    return WakefieldPoint {
        n_e_cm3:    n_e_cm3,
        n_e_m3:     n_e_m3,
        omega_p:    w,
        lambda_p_m: plasma_wavelength(w),
        e0_v_per_m: wavebreak_field(w),
    }
}

// ─── selftest (Stage-3-style parity gate) ────────────────────────────────────

// Relative-error check; returns 1 on pass, 0 on fail.
fn check_point(label: str, got: float, want: float, tol: float) -> int {
    let mut d = (got - want) / want
    if d < 0.0 { d = 0.0 - d }
    if d <= tol {
        println("  PASS " + label + "  got=" + str(got) + " want=" + str(want))
        return 1
    }
    println("  FAIL " + label + "  got=" + str(got) + " want=" + str(want)
        + " relerr=" + str(d))
    return 0
}

// Anchors: (a) n=1e18 cm⁻³ value pins (independent float64 closed-form),
// (b) the literature engineering coefficients 96 V/m and 3.34e10 µm.
fn selftest() -> int {
    println("plasma_wakefield.hexa — cold linear wakefield scaling selftest")
    let tol = 0.0001

    let mut pass = 0
    let mut total = 0

    // (a) value pins at n_e = 1e18 cm⁻³ (typical LWFA density).
    let p = evaluate(1000000000000000000.0)
    pass = pass + check_point("omega_p@1e18", p.omega_p, 56414602311806.266, tol)
    total = total + 1
    pass = pass + check_point("lambda_um@1e18", p.lambda_p_m * 1000000.0, 33.38943270215429, tol)
    total = total + 1
    pass = pass + check_point("E0_GVm@1e18", p.e0_v_per_m / 1000000000.0, 96.15919872735485, tol)
    total = total + 1

    // (b) literature engineering-coefficient cross-check (sqrt(1e18)=1e9).
    let sqrt_ncm = 1000000000.0
    pass = pass + check_point("coeff_E0_per_sqrtn", p.e0_v_per_m / sqrt_ncm, 96.0, 0.005)
    total = total + 1
    pass = pass + check_point("coeff_lambda_x_sqrtn", p.lambda_p_m * 1000000.0 * sqrt_ncm, 33400000000.0, 0.005)
    total = total + 1

    println("plasma_wakefield.hexa selftest: " + str(pass) + "/" + str(total) + " PASS")
    if pass == total { return 1 }
    return 0
}

// ─── CLI entry ────────────────────────────────────────────────────────────

// `hexa run stdlib/cern/plasma_wakefield.hexa` — sweeps a density decade
// table (the GV/m-gradient regime that motivates tabletop accelerators),
// then runs the selftest. exit 0 = parity PASS, 90 = parity FAIL (g3).
fn main() {
    println("plasma_wakefield.hexa — cold linear wakefield scalings (CERN §1.5)")
    let densities = [
        100000000000000000.0,    // 1e17 cm⁻³
        1000000000000000000.0,   // 1e18 cm⁻³
        10000000000000000000.0,  // 1e19 cm⁻³
    ]
    let mut i = 0
    while i < len(densities) {
        let p = evaluate(densities[i])
        println("  n_e=" + str(p.n_e_cm3) + " cm^-3  lambda_p="
            + str(p.lambda_p_m * 1000000.0) + " um  E_0="
            + str(p.e0_v_per_m / 1000000000.0) + " GV/m")
        i = i + 1
    }

    let st = selftest()
    if st == 1 {
        println("STAGE-3 PARITY: GREEN")
    } else {
        println("STAGE-3 PARITY: RED — gate stays unmet (g3)")
    }
}
