// stdlib/plot/plot.hexa — minimal native SVG charting.
//
// Pure-text vector figure emitter. ZERO external dependency: every entry
// point builds an SVG document as a `string` and returns it. No rasterizer,
// no shellout, no Python. The output renders directly in any browser and
// embeds in LaTeX via `\includesvg` (svg package) or after a one-shot
// `rsvg-convert`/`inkscape` to PDF — covering the paper-figure use case
// that previously forced matplotlib `.py` scripts.
//
// Surface:
//   plot_line(series: [[float]], opts: PlotOpts)   -> string  // one polyline / series
//   plot_bar(labels: [string], values: [float], o) -> string  // vertical bars
//   plot_scatter(points: [[float]], opts: PlotOpts)-> string  // circles
//   plot_save(svg: string, path: string)           -> bool    // write_file passthrough
//   plot_opts(...) / plot_opts_default()           -> PlotOpts // config ctors
//
// Scope (g3/g33 minimal): axes + ticks + the data marks + title/labels.
// Data range auto-scales to fill the plot area. No legends / grids / themes.
// Raster PNG/PDF remains deferred (a multi-week rasterizer feature).
//
// Line-series input shape:
//   each series is a flat [[float]] row; if a row has an even length and
//   looks paired it is read as [x0,y0,x1,y1,...]; otherwise values are the
//   y's and x is the auto 0,1,2,... index. `plot_line_xy` forces paired
//   interpretation. The bare `plot_line` auto-detects via opts.paired.

// ── config ───────────────────────────────────────────────────────────

struct PlotOpts {
    width:   int,     // SVG canvas width  (px)
    height:  int,     // SVG canvas height (px)
    title:   string,  // top-centered title ("" = none)
    x_label: string,  // x-axis label      ("" = none)
    y_label: string,  // y-axis label      ("" = none)
    paired:  int      // 1 = treat line-series rows as [x,y,x,y,...]; 0 = y-only
}

// plot_opts_default — sensible 640x400 canvas, no labels.
pub fn plot_opts_default() -> PlotOpts {
    return PlotOpts { width: 640, height: 400, title: "", x_label: "", y_label: "", paired: 0 }
}

// plot_opts — full ctor.
pub fn plot_opts(width: int, height: int, title: string, x_label: string, y_label: string) -> PlotOpts {
    return PlotOpts { width: width, height: height, title: title, x_label: x_label, y_label: y_label, paired: 0 }
}

// ── XML / numeric helpers ──────────────────────────────────────────────

// _xml_escape — make a string safe inside SVG text/attribute content.
fn _xml_escape(s: string) -> string {
    let mut out = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "&" {
            out = out + "&amp;"
        } else if c == "<" {
            out = out + "&lt;"
        } else if c == ">" {
            out = out + "&gt;"
        } else if c == "\"" {
            out = out + "&quot;"
        } else if c == "'" {
            out = out + "&apos;"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out
}

// _fnum — float → compact coordinate string. Round to 2 decimals so the
// emitted SVG is stable and small; coordinates never need more precision
// than sub-pixel. Done with integer arithmetic on a *100 scale to avoid
// any libc %g formatting drift in the output.
fn _fnum(v: float) -> string {
    let mut neg = 0
    let mut x = v
    if x < 0.0 {
        neg = 1
        x = 0.0 - x
    }
    // round half-up at the 1/100 place
    let scaled = to_int(x * 100.0 + 0.5)
    let whole = scaled / 100
    let frac = scaled - whole * 100
    let mut s = to_string(whole)
    if frac != 0 {
        let mut fs = to_string(frac)
        if frac < 10 {
            fs = "0" + fs
        }
        // strip a trailing zero (e.g. 50 -> "5")
        if fs.substring(1, 2) == "0" {
            fs = fs.substring(0, 1)
        }
        s = s + "." + fs
    }
    if neg == 1 {
        s = "-" + s
    }
    return s
}

// ── data-range scan ────────────────────────────────────────────────────

struct Range {
    lo: float,
    hi: float
}

// _pad_range — guard against a zero-width span (all-equal data) so the
// data fills the plot area instead of collapsing to a line.
fn _pad_range(r: Range) -> Range {
    if r.hi > r.lo {
        return r
    }
    let c = r.lo
    return Range { lo: c - 1.0, hi: c + 1.0 }
}

// ── SVG frame ───────────────────────────────────────────────────────────

// margins (px): left holds the y-axis + label, bottom the x-axis + label,
// top the title.
fn _margin_left() -> int   { return 56 }
fn _margin_right() -> int  { return 16 }
fn _margin_top() -> int    { return 32 }
fn _margin_bottom() -> int { return 44 }

// _svg_header — open <svg> + white background rect.
fn _svg_header(opts: PlotOpts) -> string {
    let w = to_string(opts.width)
    let h = to_string(opts.height)
    let mut s = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    s = s + "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"" + w + "\" height=\"" + h
          + "\" viewBox=\"0 0 " + w + " " + h + "\">\n"
    s = s + "  <rect x=\"0\" y=\"0\" width=\"" + w + "\" height=\"" + h + "\" fill=\"white\"/>\n"
    return s
}

// _svg_axes — plot-area border (the L-shaped axes) + title + labels.
// Returns the partial SVG; coordinates of the plot box come from the
// margins. plot_x0/plot_y0 = top-left of the plot box.
fn _svg_axes(opts: PlotOpts) -> string {
    let x0 = _margin_left()
    let y0 = _margin_top()
    let x1 = opts.width - _margin_right()
    let y1 = opts.height - _margin_bottom()
    let mut s = ""
    // y-axis (left vertical) + x-axis (bottom horizontal)
    s = s + "  <line x1=\"" + to_string(x0) + "\" y1=\"" + to_string(y0)
          + "\" x2=\"" + to_string(x0) + "\" y2=\"" + to_string(y1)
          + "\" stroke=\"black\" stroke-width=\"1\"/>\n"
    s = s + "  <line x1=\"" + to_string(x0) + "\" y1=\"" + to_string(y1)
          + "\" x2=\"" + to_string(x1) + "\" y2=\"" + to_string(y1)
          + "\" stroke=\"black\" stroke-width=\"1\"/>\n"
    // title
    if len(opts.title) > 0 {
        let cx = (x0 + x1) / 2
        s = s + "  <text x=\"" + to_string(cx) + "\" y=\"20\" text-anchor=\"middle\""
              + " font-family=\"sans-serif\" font-size=\"15\" font-weight=\"bold\">"
              + _xml_escape(opts.title) + "</text>\n"
    }
    // x label (bottom centered)
    if len(opts.x_label) > 0 {
        let cx = (x0 + x1) / 2
        let ly = opts.height - 8
        s = s + "  <text x=\"" + to_string(cx) + "\" y=\"" + to_string(ly)
              + "\" text-anchor=\"middle\" font-family=\"sans-serif\" font-size=\"12\">"
              + _xml_escape(opts.x_label) + "</text>\n"
    }
    // y label (rotated, left centered)
    if len(opts.y_label) > 0 {
        let cy = (y0 + y1) / 2
        s = s + "  <text x=\"14\" y=\"" + to_string(cy)
              + "\" text-anchor=\"middle\" font-family=\"sans-serif\" font-size=\"12\""
              + " transform=\"rotate(-90 14 " + to_string(cy) + ")\">"
              + _xml_escape(opts.y_label) + "</text>\n"
    }
    return s
}

// _y_ticks — draw N+1 horizontal tick marks + value labels on the y-axis,
// mapping the data Range across the plot box.
fn _y_ticks(opts: PlotOpts, r: Range) -> string {
    let x0 = _margin_left()
    let y0 = _margin_top()
    let y1 = opts.height - _margin_bottom()
    let ph = y1 - y0
    let ticks = 4
    let mut s = ""
    let mut i = 0
    while i <= ticks {
        // value at this tick (bottom = lo, top = hi)
        let frac = to_float(i) / to_float(ticks)
        let val = r.lo + (r.hi - r.lo) * frac
        let py = to_float(y1) - to_float(ph) * frac
        let pys = _fnum(py)
        // tick mark
        s = s + "  <line x1=\"" + to_string(x0 - 4) + "\" y1=\"" + pys
              + "\" x2=\"" + to_string(x0) + "\" y2=\"" + pys
              + "\" stroke=\"black\" stroke-width=\"1\"/>\n"
        // label
        s = s + "  <text x=\"" + to_string(x0 - 7) + "\" y=\"" + _fnum(py + 4.0)
              + "\" text-anchor=\"end\" font-family=\"sans-serif\" font-size=\"10\">"
              + _xml_escape(_fnum(val)) + "</text>\n"
        i = i + 1
    }
    return s
}

// ── line chart ──────────────────────────────────────────────────────────

// _series_len — number of points in a flat row given the paired flag.
fn _series_len(row: [float], paired: int) -> int {
    if paired == 1 {
        return len(row) / 2
    }
    return len(row)
}

// _series_x / _series_y — extract the j-th point's x and y from a flat row.
fn _series_x(row: [float], j: int, paired: int) -> float {
    if paired == 1 {
        return row[j * 2]
    }
    return to_float(j)
}
fn _series_y(row: [float], j: int, paired: int) -> float {
    if paired == 1 {
        return row[j * 2 + 1]
    }
    return row[j]
}

// _line_color — cycle a small categorical palette by series index.
fn _line_color(i: int) -> string {
    let k = i - (i / 6) * 6
    if k == 0 { return "#1f77b4" }
    if k == 1 { return "#ff7f0e" }
    if k == 2 { return "#2ca02c" }
    if k == 3 { return "#d62728" }
    if k == 4 { return "#9467bd" }
    return "#8c564b"
}

// plot_line — line chart. One <polyline> per series. x is the auto index
// (0,1,2,...) unless opts.paired==1, in which case each row is read as
// [x0,y0,x1,y1,...].
pub fn plot_line(series: [[float]], opts: PlotOpts) -> string {
    let x0 = _margin_left()
    let y0 = _margin_top()
    let x1 = opts.width - _margin_right()
    let y1 = opts.height - _margin_bottom()
    let pw = x1 - x0
    let ph = y1 - y0

    // scan x and y ranges across all series
    let mut have = 0
    let mut xlo = 0.0
    let mut xhi = 0.0
    let mut ylo = 0.0
    let mut yhi = 0.0
    let mut si = 0
    while si < len(series) {
        let row = series[si]
        let m = _series_len(row, opts.paired)
        let mut j = 0
        while j < m {
            let xv = _series_x(row, j, opts.paired)
            let yv = _series_y(row, j, opts.paired)
            if have == 0 {
                xlo = xv; xhi = xv; ylo = yv; yhi = yv; have = 1
            } else {
                if xv < xlo { xlo = xv }
                if xv > xhi { xhi = xv }
                if yv < ylo { ylo = yv }
                if yv > yhi { yhi = yv }
            }
            j = j + 1
        }
        si = si + 1
    }
    let xr = _pad_range(Range { lo: xlo, hi: xhi })
    let yr = _pad_range(Range { lo: ylo, hi: yhi })

    let mut s = _svg_header(opts)
    s = s + _svg_axes(opts)
    s = s + _y_ticks(opts, yr)

    // each series → polyline
    si = 0
    while si < len(series) {
        let row = series[si]
        let m = _series_len(row, opts.paired)
        let color = _line_color(si)
        let mut pts = ""
        let mut j = 0
        while j < m {
            let xv = _series_x(row, j, opts.paired)
            let yv = _series_y(row, j, opts.paired)
            let fx = (xv - xr.lo) / (xr.hi - xr.lo)
            let fy = (yv - yr.lo) / (yr.hi - yr.lo)
            let px = to_float(x0) + to_float(pw) * fx
            let py = to_float(y1) - to_float(ph) * fy
            if j > 0 { pts = pts + " " }
            pts = pts + _fnum(px) + "," + _fnum(py)
            j = j + 1
        }
        s = s + "  <polyline fill=\"none\" stroke=\"" + color
              + "\" stroke-width=\"1.5\" points=\"" + pts + "\"/>\n"
        si = si + 1
    }
    s = s + "</svg>\n"
    return s
}

// ── bar chart ───────────────────────────────────────────────────────────

// plot_bar — vertical bars. Bar height is proportional to value; the y
// range is [min(0,minval), maxval] so a zero baseline shows when all
// values are positive.
pub fn plot_bar(labels: [string], values: [float], opts: PlotOpts) -> string {
    let x0 = _margin_left()
    let y0 = _margin_top()
    let x1 = opts.width - _margin_right()
    let y1 = opts.height - _margin_bottom()
    let pw = x1 - x0
    let ph = y1 - y0

    let n = len(values)
    // y range: include 0 as baseline
    let mut vlo = 0.0
    let mut vhi = 0.0
    let mut i = 0
    while i < n {
        let v = values[i]
        if v < vlo { vlo = v }
        if v > vhi { vhi = v }
        i = i + 1
    }
    let yr = _pad_range(Range { lo: vlo, hi: vhi })
    // pixel y of the value 0 (the baseline)
    let zero_frac = (0.0 - yr.lo) / (yr.hi - yr.lo)
    let zero_py = to_float(y1) - to_float(ph) * zero_frac

    let mut s = _svg_header(opts)
    s = s + _svg_axes(opts)
    s = s + _y_ticks(opts, yr)

    // baseline at value 0 (light) if 0 is inside the range
    if yr.lo < 0.0 {
        s = s + "  <line x1=\"" + to_string(x0) + "\" y1=\"" + _fnum(zero_py)
              + "\" x2=\"" + to_string(x1) + "\" y2=\"" + _fnum(zero_py)
              + "\" stroke=\"#999999\" stroke-width=\"1\"/>\n"
    }

    if n > 0 {
        // slot width per bar; bar occupies 70% of its slot, centered
        let slot = to_float(pw) / to_float(n)
        let bw = slot * 0.7
        let mut bi = 0
        while bi < n {
            let v = values[bi]
            let vfrac = (v - yr.lo) / (yr.hi - yr.lo)
            let vpy = to_float(y1) - to_float(ph) * vfrac
            let bx = to_float(x0) + slot * to_float(bi) + (slot - bw) / 2.0
            // rect spans from baseline (0) to the value
            let mut top = vpy
            let mut bot = zero_py
            if vpy > zero_py {
                top = zero_py
                bot = vpy
            }
            let rh = bot - top
            s = s + "  <rect x=\"" + _fnum(bx) + "\" y=\"" + _fnum(top)
                  + "\" width=\"" + _fnum(bw) + "\" height=\"" + _fnum(rh)
                  + "\" fill=\"#1f77b4\"/>\n"
            // label under the slot center
            if bi < len(labels) {
                let cx = to_float(x0) + slot * to_float(bi) + slot / 2.0
                s = s + "  <text x=\"" + _fnum(cx) + "\" y=\"" + to_string(y1 + 14)
                      + "\" text-anchor=\"middle\" font-family=\"sans-serif\" font-size=\"10\">"
                      + _xml_escape(labels[bi]) + "</text>\n"
            }
            bi = bi + 1
        }
    }
    s = s + "</svg>\n"
    return s
}

// ── scatter chart ───────────────────────────────────────────────────────

// plot_scatter — circles at each [x,y] point. `points` is [[x,y], ...].
pub fn plot_scatter(points: [[float]], opts: PlotOpts) -> string {
    let x0 = _margin_left()
    let y0 = _margin_top()
    let x1 = opts.width - _margin_right()
    let y1 = opts.height - _margin_bottom()
    let pw = x1 - x0
    let ph = y1 - y0

    let n = len(points)
    let mut have = 0
    let mut xlo = 0.0
    let mut xhi = 0.0
    let mut ylo = 0.0
    let mut yhi = 0.0
    let mut i = 0
    while i < n {
        let p = points[i]
        if len(p) >= 2 {
            let xv = p[0]
            let yv = p[1]
            if have == 0 {
                xlo = xv; xhi = xv; ylo = yv; yhi = yv; have = 1
            } else {
                if xv < xlo { xlo = xv }
                if xv > xhi { xhi = xv }
                if yv < ylo { ylo = yv }
                if yv > yhi { yhi = yv }
            }
        }
        i = i + 1
    }
    let xr = _pad_range(Range { lo: xlo, hi: xhi })
    let yr = _pad_range(Range { lo: ylo, hi: yhi })

    let mut s = _svg_header(opts)
    s = s + _svg_axes(opts)
    s = s + _y_ticks(opts, yr)

    i = 0
    while i < n {
        let p = points[i]
        if len(p) >= 2 {
            let xv = p[0]
            let yv = p[1]
            let fx = (xv - xr.lo) / (xr.hi - xr.lo)
            let fy = (yv - yr.lo) / (yr.hi - yr.lo)
            let px = to_float(x0) + to_float(pw) * fx
            let py = to_float(y1) - to_float(ph) * fy
            s = s + "  <circle cx=\"" + _fnum(px) + "\" cy=\"" + _fnum(py)
                  + "\" r=\"3\" fill=\"#d62728\"/>\n"
        }
        i = i + 1
    }
    s = s + "</svg>\n"
    return s
}

// ── save ─────────────────────────────────────────────────────────────────

// plot_save — write `svg` to `path`. Returns the write_file bool result:
// false on a bad path (e.g. unwritable directory), per the carry-flag fix.
pub fn plot_save(svg: string, path: string) -> bool {
    return write_file(path, svg)
}
