// stdlib/plot/mod.hexa — package entry point.
//
// Minimal native SVG charting. Re-exports the plot surface so applications
// can load it with a single import:
//
//     use "stdlib/plot/mod"          // or
//     import "stdlib/plot/plot.hexa"
//
// Surface: plot_line · plot_bar · plot_scatter · plot_save + PlotOpts ctors.
// Pure-text SVG emission, ZERO external dependency. See plot.hexa header.

import "./plot.hexa"
