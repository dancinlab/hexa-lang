// stdlib/hash/sha256.hexa — F1 (2026-05-10) backward-compat shim.
//
// Module relocated to stdlib/core/hash/sha256.hexa. SHA-256 wraps the
// runtime hexa_sha256 builtin (libc-free C reference impl); pure
// computation, target-agnostic. The sha256_file_hex helper requires
// runtime file I/O — firmware that lacks a filesystem must avoid it,
// but the symbol path itself stays in core.
//
// Sunset: removed after F4 absorptions complete.
// New canonical path: stdlib/core/hash/sha256.hexa

import "stdlib/core/hash/sha256.hexa"
