// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_d128_2L_smoke_test.hexa — Phase 4-D smoke (CPU-runnable)
//
// Scaled-up smoke test (CPU-feasible memory) intended as pre-flight
// sanity check before Phase 4-D GPU dispatch fire at d=768·12L. This
// config sits between d=32·3L (production verified, Phase 4-B SHIPPED)
// and d=768·12L (GPU dispatch target, F-RFC046-EAGER-PYTORCH-MATCH).
//
// config (smoke — 4× larger than d=32·3L, ~5× smaller than d=768·12L):
//   T=64, d=128, nh=8, nkv=2, h=512, V=256, n_layer=2
//   nsamp=4 windows · stride=256 · 10 AdamW steps · seed=42
//   from-scratch (no base_ckpt)
//
// Memory estimate (per layer):
//   bp_total: 2·128 + 2·128² + 2·32·128 + 3·512·128 = ~228K doubles ≈ 1.8MB
//   bc_total: 8·T·d + extras = 8·64·128 + ~32K = ~88K doubles ≈ 0.7MB
//   M (model): n_layer·bp + V·d + d + V·d = 2·228K + 33K + 128 + 33K ≈ 525K ≈ 4MB
//   Mc (cache): n_layer·bc + ... ≈ 200K ≈ 1.6MB
//   Mm + Mv + Mg + Mg_acc: 4 × M = 16MB
//   Total: ~25MB resident (well within M-Mac 16-32GB)
//
// Per-step cost estimate vs d=32·3L (commit 8012c15a 5.908s for 80 steps):
//   d=32·3L per-step:  5.908 / 80 = 74ms
//   d=128·2L scale:    (128/32)² · (2/3) · (64/16) = 16 · 0.67 · 4 = 43× per-step
//   d=128·2L per-step: ~3.2s  (10 steps → ~32s wall on M-Mac, A2+B FULL)
//
// Falsifiers (smoke-tier, no oracle):
//   F-RFC046-SMOKE-BUILD : compiles + runs without OOM
//   F-RFC046-SMOKE-CONVERGES : 10-step gn2 collapse ≥ 10× from init
//   F-RFC046-SMOKE-FINITE : all numerics finite (no NaN/Inf)
//
// CROSS-LINK:
//   - PHASE4D_GPU_DISPATCH_DESIGN.md (commit c5d49425) — Phase 4-D scope
//   - flame_d32_corpus_test.hexa (Phase 4-B verified config)
//   - Phase 4-D-3 acceptance gate before GPU fire (Phase 4-D-4)
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/decoder_lib"
use "stdlib/flame/decoder_block_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/train_lib"

fn _c_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("=== flame Phase 4-D smoke (d=128·2L scaled, CPU-runnable pre-flight) ===")

let T = 64
let d = 128
let nh = 8
let nkv = 2
let h = 512
let V = 256
let n_layer = 2
let nsamp = 4
let stride = 256
let n_steps = 10
let hd = d / nh

// Same corpus as d=32·3L (byte-level V=256 works as-is)
let path = "/Users/ghost/core/anima/training/corpus_consciousness_v1.jsonl"
let bytes_arr = read_file_bytes(path)
let n_bytes = len(bytes_arr)
print("  corpus: "); print(path); println("")
print("  size: "); print(n_bytes); println(" bytes")
print("  smoke config: T="); print(T); print(" d="); print(d); print(" nh="); print(nh)
print(" nkv="); print(nkv); print(" h="); print(h); print(" n_layer="); print(n_layer)
println("")

let IDS = t_zeros(nsamp * T)
let YS = t_zeros(nsamp)
let mut s = 0
while s < nsamp {
    let off = s * stride
    if off + T < n_bytes {
        let mut p = 0
        while p < T {
            t_set(IDS, s * T + p, to_float(bytes_arr[off + p]))
            p = p + 1
        }
        t_set(YS, s, to_float(bytes_arr[off + T]))
    }
    s = s + 1
}

// allocate model + optimizer
let m_size = m_total(d, nh, nkv, h, V, n_layer)
print("  model size: "); print(m_size); println(" doubles")
let M = t_zeros(m_size)
nn_decoder_init(M, 42, T, d, nh, nkv, h, V, n_layer)
let Mm = t_zeros(m_size)
let Mv = t_zeros(m_size)
let Mg = t_zeros(m_size)
let Mg_acc = t_zeros(m_size)
let mc_size = mc_total(T, d, nh, nkv, h, V, n_layer)
print("  cache size: "); print(mc_size); println(" doubles")
let Mc = t_zeros(mc_size)
let cos_tab = t_zeros(T * hd); let sin_tab = t_zeros(T * hd)
nn_rope_build_tables(T, hd, cos_tab, sin_tab)

let lr = 0.03
let b1 = 0.9
let b2 = 0.999
let eps_a = 0.00000001
let wd = 0.01

fn _window_ids(IDS: int, s: int, T: int, ids_out: int) {
    let mut p = 0
    while p < T {
        let _ = farr_set(ids_out, p, farr_get(IDS, s * T + p))
        p = p + 1
    }
}

// initial gn2 epoch
let ids_scratch = t_zeros(T)
let mut gn2_init_epoch = 0.0
let mut s_init = 0
while s_init < nsamp {
    _window_ids(IDS, s_init, T, ids_scratch)
    let target_t = to_int(t_get(YS, s_init))
    nn_decoder_fwd(ids_scratch, M, Mc, cos_tab, sin_tab,
                   T, d, nh, nkv, h, V, n_layer)
    let g = nn_decoder_gn2(Mc, target_t, T, d, nh, nkv, h, V, n_layer)
    gn2_init_epoch = gn2_init_epoch + g
    s_init = s_init + 1
}
print("  init epoch gn2: "); println(gn2_init_epoch)

// 10-step training loop (matches d_corpus_fire pattern, shorter for smoke).
// Uses fwd+grad+adamw decomposition (matches d32_corpus_test pattern).
let mut step = 1
let mut gn2_last = gn2_init_epoch
while step <= n_steps {
    let mut z = 0
    while z < m_size {
        let _ = farr_set(Mg_acc, z, 0.0)
        z = z + 1
    }
    let mut gn2_step_epoch = 0.0
    let mut s_e = 0
    while s_e < nsamp {
        _window_ids(IDS, s_e, T, ids_scratch)
        let tt = to_int(t_get(YS, s_e))
        nn_decoder_fwd(ids_scratch, M, Mc, cos_tab, sin_tab,
                       T, d, nh, nkv, h, V, n_layer)
        let g = nn_decoder_gn2(Mc, tt, T, d, nh, nkv, h, V, n_layer)
        gn2_step_epoch = gn2_step_epoch + g
        nn_decoder_grad(ids_scratch, tt, M, Mc, Mg, cos_tab, sin_tab,
                        T, d, nh, nkv, h, V, n_layer)
        let mut q = 0
        while q < m_size {
            let cur = farr_get(Mg_acc, q)
            let _ = farr_set(Mg_acc, q, cur + farr_get(Mg, q))
            q = q + 1
        }
        s_e = s_e + 1
    }
    nn_decoder_adamw_step(M, Mg_acc, Mm, Mv, lr, b1, b2, eps_a, wd, step, m_size)
    if step == 1 {
        print("  step 1 (pre-update) gn2: "); println(gn2_step_epoch)
    }
    if step == n_steps {
        print("  step "); print(step); print(" gn2: "); println(gn2_step_epoch)
        gn2_last = gn2_step_epoch
    }
    step = step + 1
}

// Falsifier checks
let collapse_ratio = gn2_init_epoch / gn2_last
print("  collapse ratio: "); print(collapse_ratio); println("×")

// finite-numerics check (any NaN in M will propagate to next gn2 read)
let m_sample_0 = farr_get(M, 0)
let m_finite = m_sample_0 == m_sample_0  // NaN != NaN
let mut all_pass = true

if collapse_ratio >= 10.0 {
    println("PASS  F-RFC046-SMOKE-CONVERGES  10-step gn2 collapse ≥ 10×")
} else {
    println("FAIL  F-RFC046-SMOKE-CONVERGES  insufficient collapse")
    all_pass = false
}
if m_finite {
    println("PASS  F-RFC046-SMOKE-FINITE  M[0] finite")
} else {
    println("FAIL  F-RFC046-SMOKE-FINITE  M[0] NaN/Inf — numerics broken")
    all_pass = false
}
// Build sanity: if we got here, F-RFC046-SMOKE-BUILD already PASS
println("PASS  F-RFC046-SMOKE-BUILD  test ran to completion")

if all_pass {
    println("=== flame Phase 4-D smoke 3/3 PASS — d=128·2L scaled config converges ===")
} else {
    println("=== flame Phase 4-D smoke FAIL — pre-flight gate failed ===")
}
