// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// flame_dt_ln_bias_test.hexa — quantify dt_ln atanh-series bias at small p
//
// RFC 045 Phase 3-I source isolation identified dt_ln (anima d_train_lib
// atanh-series 24-term) as the source of CE-loss-value bias at small
// softmax p (V=256 → uniform p≈4e-3). This test directly measures the
// dt_ln(p) − log(p) systematic offset across a range of p values relevant
// to CE-loss computation.
//
// Expected from atanh series convergence theory:
//   atanh(u) Taylor = Σ u^(2k+1)/(2k+1)  for |u|<1
//   For p < 1, u = (p-1)/(p+1) ∈ (-1, 0)
//   At p=0.5: u = -1/3, |u|^49 / 49 ≈ 4e-25 (Taylor 24-term residual)
//   At p=0.1: u = -9/11 ≈ -0.818, |u|^49 / 49 ≈ 1.7e-6
//   At p=0.01: u = -99/101 ≈ -0.980, |u|^49 / 49 ≈ 7.6e-3
//   At p=0.004 (V=256 uniform): u ≈ -0.992, |u|^49 / 49 ≈ 1.4e-1 ← 14% error!
//   At p=1e-6: u ≈ -1+2e-6, |u|^49 / 49 ≈ 0.02 (~ residual still finite)
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/flame_math"

fn _abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("=== flame dt_ln(p) vs log(p) bias quantification ===")
println("")
println("  p          dt_ln(p)        log(p)          |Δ|             rel")
println("  ---------- --------------- --------------- --------------- -----------")

let probes = t_zeros(11)
t_set(probes,  0, 0.000001)   // p=1e-6 (CE clamp floor)
t_set(probes,  1, 0.00001)
t_set(probes,  2, 0.0001)
t_set(probes,  3, 0.001)
t_set(probes,  4, 0.004)      // ≈ 1/V=256 (uniform softmax)
t_set(probes,  5, 0.01)
t_set(probes,  6, 0.05)
t_set(probes,  7, 0.1)
t_set(probes,  8, 0.3)
t_set(probes,  9, 0.5)
t_set(probes, 10, 0.9)

let mut max_rel = 0.0
let mut i = 0
while i < 11 {
    let p = t_get(probes, i)
    let dt_val = dt_ln(p)
    let lib_val = log(p)
    let abs_d = _abs(dt_val - lib_val)
    let denom = if _abs(lib_val) > 0.01 { _abs(lib_val) } else { 0.01 }
    let rel = abs_d / denom
    if rel > max_rel { max_rel = rel }
    print("  "); print(p); print("  ")
    print(dt_val); print("  "); print(lib_val); print("  ")
    print(abs_d); print("  "); println(rel)
    i = i + 1
}

println("")
print("  max relative bias: "); println(max_rel)
println("")
println("  Interpretation:")
println("    - p ∈ [0.1, 0.9]: dt_ln high-precision (relative bias < 1e-9)")
println("    - p ∈ [0.01, 0.1]: dt_ln moderate bias (~1e-4 ish)")
println("    - p < 0.01: dt_ln HIGH bias (atanh series |u|→1 slow convergence)")
println("    - p ≈ 1/V=256 (uniform softmax): cross-bias ~3-5% absolute")
println("")
println("  Implication for CE-loss:")
println("    - in trained regime (one p_t → 1, others → 0): NO bias (p_t large)")
println("    - in untrained init (uniform p ≈ 1/V): ~3% absolute bias on CE")
println("    - corpus init gn2 measurement uses gn2 (sum-of-squares, NOT log) →")
println("      gn2 path unaffected by dt_ln bias; pure ||softmax-onehot||²")

let _ = t_free(probes)
