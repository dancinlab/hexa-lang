// ════════════════════════════════════════════════════════════════════════════
//  conv_lib.hexa — flame causal-dilated Conv1d (fwd + bwd), hexa-native.
//
//  First of the 4 op families flame needs to port anima's CLM (CLMConvMoE)
//  production trainer (FLAME.tape n_clm_convmoe_port_gap · anima
//  a_train_flame_forge · CLM/P6_SCALE_LADDER_7B). CLM uses Conv1d in 5 places:
//    embed_conv (d->d, k=3) · trunk CausalDilatedConv1d (d->d, k=3, dilation) ·
//    ConvExpert (d->d, k=3) · router (d->E, k=1) · readout (d->V, k=1).
//
//  Layout (host farr, RFC 040; device routing = forge Phase 4 carve-out):
//    X  : [T · Cin]      input  (row-major, time-major)
//    W  : [Cout · Cin · K] weight
//    b  : [Cout]         bias
//    Y  : [T · Cout]     output
//  Causal: left-pad with zeros (no future leak). Tap index convention:
//    k = K-1  -> current step   (offset 0)
//    k = K-2  -> dilation steps back ... k = 0 -> (K-1)*dilation back.
//    y[t,co] = b[co] + Σ_ci Σ_k W[co,ci,k] · xin(t - dil·(K-1-k), ci)
//    xin(p,ci) = X[p,ci] if p>=0 else 0.
//
//  FWD = im2col + GEMM (host): unfold the causal-dilated receptive field into
//  x_col[T·(Cin·K)], one t_matmul (RFC 032 ikj FMA-fused GEMM) → Y, + bias —
//  replaces the naive O(T·Cout·Cin·K) quad-loop, 38–60× faster at CLM-trunk
//  shapes (.verdicts/flame-perf-im2col-gemm/roofline.txt). BWD stays the closed
//  vjp quad-loop (bwd im2col = follow-up). The fwd re-association is a re-order
//  of the SAME sum → bit-near-identical (max|Δ|≈1e-16; GRAD-EXACT held 5.2e-12).
//
//  Verified by F-FLAME-CONV1D-GRAD-EXACT (flame_conv_test.hexa, central-diff).
//  lib-split mandatory (FLAME.tape): conv lives here, selftest is a separate
//  entrypoint file. sibling: nn_lib.hexa · tensor_lib.hexa.
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"

// im2col host buffer build (offset-capable weight space is irrelevant here —
// the gather is over activations only). x_col[t, ci·K+k] = xin(p,ci),
// p = t − dil·(K−1−k), zero where p<0 (causal left-pad). Mirrors the forge
// im2col in clm_conv_gpu.hexa byte-for-byte (same gather → same re-association).
fn _conv1d_im2col(x: int, xcol: int, T: int, Cin: int, K: int, dil: int) {
    let Kdim = Cin * K
    let mut t = 0
    while t < T {
        let mut ci = 0
        while ci < Cin {
            let mut k = 0
            while k < K {
                let p = t - dil * (K - 1 - k)
                if p >= 0 { t_set(xcol, t * Kdim + ci * K + k, t_get(x, p * Cin + ci)) }
                k = k + 1
            }
            ci = ci + 1
        }
        t = t + 1
    }
}

// add bias b[boff+co] into Y[t·Cout+co] in place over the matmul result `mm`.
fn _conv1d_add_bias(mm: int, b: int, boff: int, y_out: int, T: int, Cout: int) {
    let mut t = 0
    while t < T {
        let mut co = 0
        while co < Cout {
            t_set(y_out, t * Cout + co, t_get(mm, t * Cout + co) + t_get(b, boff + co))
            co = co + 1
        }
        t = t + 1
    }
}

// Forward (HOST). im2col + GEMM: unfold the causal-dilated receptive field into
// x_col[T · (Cin·K)], transpose W[Cout, Cin·K] → Wt[Cin·K, Cout], then ONE
// t_matmul (RFC 032 ikj FMA-fused GEMM under -O2) → Y[T, Cout], + bias. This
// replaces the naive O(T·Cout·Cin·K) quad-loop; measured 38–60× faster on host
// at CLM-trunk shapes (see .verdicts/flame-perf-im2col-gemm/roofline.txt). The
// re-association is a re-order of the SAME sum → bit-near-identical (max|Δ|≈1e-16,
// GRAD-EXACT held at max_rel 5.2e-12). Caller allocates y_out (T·Cout).
pub fn nn_conv1d_fwd(x: int, w: int, b: int, y_out: int,
                     T: int, Cin: int, Cout: int, K: int, dil: int) {
    let Kdim = Cin * K
    let xcol = t_zeros(T * Kdim)
    _conv1d_im2col(x, xcol, T, Cin, K, dil)
    let Wt = t_zeros(Kdim * Cout)
    let mut co = 0
    while co < Cout {
        let mut j = 0
        while j < Kdim { t_set(Wt, j * Cout + co, t_get(w, co * Kdim + j)); j = j + 1 }
        co = co + 1
    }
    let mm = t_matmul(xcol, T, Kdim, Wt, Cout)
    _conv1d_add_bias(mm, b, 0, y_out, T, Cout)
    t_free(xcol)
    t_free(Wt)
    t_free(mm)
}

// Forward, offset-capable. Identical to nn_conv1d_fwd except weight reads come
// from w[woff + idx] and bias reads from b[boff + co]. Lets a caller hold a
// PACKED weight buffer ([N·Cout·Cin·K]) and select layer/expert n directly via
// woff = n·Cout·Cin·K (boff = n·Cout) — no per-call slice copy into a temp.
pub fn nn_conv1d_fwd_off(x: int, w: int, woff: int, b: int, boff: int, y_out: int,
                         T: int, Cin: int, Cout: int, K: int, dil: int) {
    let Kdim = Cin * K
    let xcol = t_zeros(T * Kdim)
    _conv1d_im2col(x, xcol, T, Cin, K, dil)
    // transpose the OFFSET weight slice w[woff + co·Kdim + j] → Wt[j·Cout + co]
    let Wt = t_zeros(Kdim * Cout)
    let mut co = 0
    while co < Cout {
        let mut j = 0
        while j < Kdim { t_set(Wt, j * Cout + co, t_get(w, woff + co * Kdim + j)); j = j + 1 }
        co = co + 1
    }
    let mm = t_matmul(xcol, T, Kdim, Wt, Cout)
    _conv1d_add_bias(mm, b, boff, y_out, T, Cout)
    t_free(xcol)
    t_free(Wt)
    t_free(mm)
}

// Backward — closed vjp. Caller allocates dW_out [Cout·Cin·K], dX_out [T·Cin],
// db_out [Cout]; this zeros them then accumulates:
//   dW[co,ci,k] = Σ_t dY[t,co] · xin(t-dil·(K-1-k), ci)
//   dX[p,ci]    = Σ_co Σ_k W[co,ci,k] · dY[t,co]   where t = p + dil·(K-1-k)
//   db[co]      = Σ_t dY[t,co]
pub fn nn_conv1d_bwd(x: int, w: int, dy: int,
                     dW_out: int, dX_out: int, db_out: int,
                     T: int, Cin: int, Cout: int, K: int, dil: int) {
    let mut iz = 0
    while iz < Cout * Cin * K {
        t_set(dW_out, iz, 0.0)
        iz = iz + 1
    }
    let mut ix = 0
    while ix < T * Cin {
        t_set(dX_out, ix, 0.0)
        ix = ix + 1
    }
    let mut ib = 0
    while ib < Cout {
        t_set(db_out, ib, 0.0)
        ib = ib + 1
    }
    let mut t = 0
    while t < T {
        let mut co = 0
        while co < Cout {
            let g = t_get(dy, t * Cout + co)
            t_set(db_out, co, t_get(db_out, co) + g)
            let mut ci = 0
            while ci < Cin {
                let mut k = 0
                while k < K {
                    let p = t - dil * (K - 1 - k)
                    if p >= 0 {
                        let widx = co * Cin * K + ci * K + k
                        let xidx = p * Cin + ci
                        let xv = t_get(x, xidx)
                        t_set(dW_out, widx, t_get(dW_out, widx) + g * xv)
                        t_set(dX_out, xidx, t_get(dX_out, xidx) + g * t_get(w, widx))
                    }
                    k = k + 1
                }
                ci = ci + 1
            }
            co = co + 1
        }
        t = t + 1
    }
}

// Backward, offset-capable. Identical to nn_conv1d_bwd except the WEIGHT-space
// buffers are addressed at an offset: weight reads from w[woff + idx], and the
// grads are zeroed + accumulated IN PLACE at dW_out[dWoff + idx] / db_out[dboff
// + co]. dX_out stays unoffset (activation space). Lets a caller accumulate the
// per-layer/per-expert grad slice straight into a PACKED grad buffer — no temp
// dW slice and no _cpback of the grad back into the pack.
pub fn nn_conv1d_bwd_off(x: int, w: int, woff: int, dy: int,
                         dW_out: int, dWoff: int, dX_out: int, db_out: int, dboff: int,
                         T: int, Cin: int, Cout: int, K: int, dil: int) {
    let mut iz = 0
    while iz < Cout * Cin * K {
        t_set(dW_out, dWoff + iz, 0.0)
        iz = iz + 1
    }
    let mut ix = 0
    while ix < T * Cin {
        t_set(dX_out, ix, 0.0)
        ix = ix + 1
    }
    let mut ib = 0
    while ib < Cout {
        t_set(db_out, dboff + ib, 0.0)
        ib = ib + 1
    }
    let mut t = 0
    while t < T {
        let mut co = 0
        while co < Cout {
            let g = t_get(dy, t * Cout + co)
            t_set(db_out, dboff + co, t_get(db_out, dboff + co) + g)
            let mut ci = 0
            while ci < Cin {
                let mut k = 0
                while k < K {
                    let p = t - dil * (K - 1 - k)
                    if p >= 0 {
                        let woidx = woff + co * Cin * K + ci * K + k
                        let dwidx = dWoff + co * Cin * K + ci * K + k
                        let xidx = p * Cin + ci
                        let xv = t_get(x, xidx)
                        t_set(dW_out, dwidx, t_get(dW_out, dwidx) + g * xv)
                        t_set(dX_out, xidx, t_get(dX_out, xidx) + g * t_get(w, woidx))
                    }
                    k = k + 1
                }
                ci = ci + 1
            }
            co = co + 1
        }
        t = t + 1
    }
}
