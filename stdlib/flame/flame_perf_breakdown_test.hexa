// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_perf_breakdown_test.hexa — flame Phase 4 preflight
//
// Per-step wall breakdown for the nn_decoder_train_step path at d=32·3L:
//   fwd  (nn_decoder_fwd)        — projections + attn + SwiGLU + tied head
//   bwd  (nn_decoder_grad)       — reverse composition + grad accumulate
//   opt  (opt_adamw_step)        — AdamW update over packed M
//
// Methodology: 1 warm-up step (cache touch) + 8 measure steps × 1 corpus
// window. time_ms() per phase, then average over the 8 measure steps.
// Wall-time evidence for RFC 046 Phase 4 fusion priority decisions —
// which sub-phase dominates determines which fusion stage wins most.
//
// Honest carve-out (g3): time_ms() has ~1ms granularity; per-step fwd at
// d=32·3L is order ~100ms, so the granularity introduces ≤1% error per
// reading and averaging over 8 reduces it further. Not a strict
// micro-benchmark; sufficient for Phase 4 priority decisions.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/decoder_lib"
use "stdlib/flame/decoder_block_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/train_lib"
use "stdlib/flame/optim_lib"

println("=== flame Phase 4 preflight (per-step wall breakdown @ d=32·3L) ===")

let T = 16
let d = 32
let nh = 4
let nkv = 2
let h = 64
let V = 256
let n_layer = 3
let hd = d / nh
let target_t = 44   // first byte after T=16 prefix in corpus_consciousness_v1.jsonl

// load corpus first window
let path = "/Users/ghost/core/anima/training/corpus_consciousness_v1.jsonl"
let bytes_arr = read_file_bytes(path)
let ids = t_zeros(T)
let mut p = 0
while p < T {
    t_set(ids, p, to_float(bytes_arr[p]))
    p = p + 1
}

let m_size = m_total(d, nh, nkv, h, V, n_layer)
let M = t_zeros(m_size)
nn_decoder_init(M, 42, T, d, nh, nkv, h, V, n_layer)
let Mm = t_zeros(m_size)
let Mv = t_zeros(m_size)
let Mg = t_zeros(m_size)
let mc_size = mc_total(T, d, nh, nkv, h, V, n_layer)
let Mc = t_zeros(mc_size)
let cos_tab = t_zeros(T * hd); let sin_tab = t_zeros(T * hd)
nn_rope_build_tables(T, hd, cos_tab, sin_tab)

let lr = 0.03
let b1 = 0.9
let b2 = 0.999
let eps_a = 0.00000001
let wd = 0.01

print("  config: T="); print(T); print(" d="); print(d)
print(" nh="); print(nh); print(" nkv="); print(nkv); print(" h="); print(h)
print(" V="); print(V); print(" n_layer="); print(n_layer)
print(" ; m_total="); println(m_size)

// warm-up step (cache touch, not measured)
nn_decoder_fwd(ids, M, Mc, cos_tab, sin_tab, T, d, nh, nkv, h, V, n_layer)
let mut zi = 0
while zi < m_size { let _ = farr_set(Mg, zi, 0.0); zi = zi + 1 }
nn_decoder_grad(ids, target_t, M, Mc, Mg, cos_tab, sin_tab,
                T, d, nh, nkv, h, V, n_layer)
opt_adamw_step(M, Mg, Mm, Mv, m_size, lr, b1, b2, eps_a, wd, 1)

// 5-run outer × 8-step inner — PERF.md convention (≥5-run averaging)
// macOS task scheduler + page cache produce ~7-10% per-run variance
// at this workload; per-run min/max captured separately for honest
// reporting.
let n_outer = 5
let n_inner = 8
let totals = t_zeros(n_outer)
let fwd_per_run = t_zeros(n_outer)
let bwd_per_run = t_zeros(n_outer)
let opt_per_run = t_zeros(n_outer)
let mut outer = 0
while outer < n_outer {
    let mut fwd_acc = 0
    let mut bwd_acc = 0
    let mut opt_acc = 0
    let mut step = 1
    while step <= n_inner {
        let t0 = time_ms()
        nn_decoder_fwd(ids, M, Mc, cos_tab, sin_tab, T, d, nh, nkv, h, V, n_layer)
        let t1 = time_ms()
        let mut z = 0
        while z < m_size { let _ = farr_set(Mg, z, 0.0); z = z + 1 }
        let t2 = time_ms()
        nn_decoder_grad(ids, target_t, M, Mc, Mg, cos_tab, sin_tab,
                        T, d, nh, nkv, h, V, n_layer)
        let t3 = time_ms()
        opt_adamw_step(M, Mg, Mm, Mv, m_size, lr, b1, b2, eps_a, wd, step + 1)
        let t4 = time_ms()
        fwd_acc = fwd_acc + (t1 - t0)
        bwd_acc = bwd_acc + (t3 - t2)
        opt_acc = opt_acc + (t4 - t3)
        step = step + 1
    }
    t_set(fwd_per_run, outer, to_float(fwd_acc / n_inner))
    t_set(bwd_per_run, outer, to_float(bwd_acc / n_inner))
    t_set(opt_per_run, outer, to_float(opt_acc / n_inner))
    t_set(totals, outer, to_float((fwd_acc + bwd_acc + opt_acc) / n_inner))
    outer = outer + 1
}
// compute min/max/avg over the 5 outer runs
let mut fwd_min = t_get(fwd_per_run, 0)
let mut fwd_max = fwd_min
let mut fwd_sum = 0.0
let mut bwd_min = t_get(bwd_per_run, 0)
let mut bwd_max = bwd_min
let mut bwd_sum = 0.0
let mut total_min = t_get(totals, 0)
let mut total_max = total_min
let mut total_sum = 0.0
let mut k = 0
while k < n_outer {
    let f = t_get(fwd_per_run, k)
    let b = t_get(bwd_per_run, k)
    let tot = t_get(totals, k)
    if f < fwd_min { fwd_min = f }
    if f > fwd_max { fwd_max = f }
    fwd_sum = fwd_sum + f
    if b < bwd_min { bwd_min = b }
    if b > bwd_max { bwd_max = b }
    bwd_sum = bwd_sum + b
    if tot < total_min { total_min = tot }
    if tot > total_max { total_max = tot }
    total_sum = total_sum + tot
    k = k + 1
}
let fwd_ms_avg = to_int(fwd_sum / to_float(n_outer))
let bwd_ms_avg = to_int(bwd_sum / to_float(n_outer))
let opt_ms_avg = 0
let total_ms_avg = to_int(total_sum / to_float(n_outer))
let total_acc = total_ms_avg * n_inner * n_outer
let fwd_pct = (100 * fwd_ms_avg) / (if total_ms_avg > 0 { total_ms_avg } else { 1 })
let bwd_pct = (100 * bwd_ms_avg) / (if total_ms_avg > 0 { total_ms_avg } else { 1 })
let opt_pct = 0

println("")
println("  Per-step wall (5-run × 8-iter avg, single-window, PERF.md convention):")
print("    fwd       : "); print(fwd_ms_avg); print(" ms avg (range ")
print(to_int(fwd_min)); print("-"); print(to_int(fwd_max))
print("ms; "); print(fwd_pct); println("%)")
print("    bwd       : "); print(bwd_ms_avg); print(" ms avg (range ")
print(to_int(bwd_min)); print("-"); print(to_int(bwd_max))
print("ms; "); print(bwd_pct); println("%)")
print("    AdamW step: ~0 ms avg (sub-millisecond at this scale)")
println("")
print("    total/step: "); print(total_ms_avg); print(" ms avg (range ")
print(to_int(total_min)); print("-"); print(to_int(total_max)); println("ms)")
let _ = t_free(totals)
let _ = t_free(fwd_per_run)
let _ = t_free(bwd_per_run)
let _ = t_free(opt_per_run)
println("")
println("  Phase 4 fusion priority (descending wall share):")
if fwd_pct >= bwd_pct {
    if fwd_pct >= opt_pct {
        println("    1) fwd (Stage 1/2 epilogue + block fusion)")
        if bwd_pct >= opt_pct {
            println("    2) bwd (Stage 3 fwd+bwd graph fusion)")
            println("    3) AdamW (sub-1% — not a fusion target)")
        } else {
            println("    2) AdamW")
            println("    3) bwd")
        }
    } else {
        println("    1) AdamW")
        println("    2) fwd")
        println("    3) bwd")
    }
} else {
    if bwd_pct >= opt_pct {
        println("    1) bwd (Stage 3 fwd+bwd graph fusion)")
        println("    2) fwd")
        println("    3) AdamW")
    } else {
        println("    1) AdamW")
        println("    2) bwd")
        println("    3) fwd")
    }
}

let _ = t_free(ids); let _ = t_free(M); let _ = t_free(Mm); let _ = t_free(Mv)
let _ = t_free(Mg); let _ = t_free(Mc); let _ = t_free(cos_tab); let _ = t_free(sin_tab)

println("")
println("Phase 4 preflight evidence captured.")
