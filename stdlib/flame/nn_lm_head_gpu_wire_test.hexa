// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/nn_lm_head_gpu_wire_test.hexa — large-vocab GPU-port byte-eq
//
// Verifies the host-loop → GPU-kernel WIRING landed in PR #1262 (resolving
// inbox/patches/flame-agtape-trainer-large-vocab-host-loop-gpu-port.md ·
// PR #1255). The kernels (farr_outer_gpu / farr_matmul_t_gpu /
// farr_add_inplace_gpu / farr_copy_slice_gpu / farr_adamw_step_gpu) carry a
// CPU fallback in self/runtime.c; on this no-CUDA local build the wired
// nn_lib/train_lib functions take that fallback. The correctness gate is
// BYTE-EQ: each kernel-wired function == an INDEPENDENT in-file host-loop
// reference (the OLD V=256-era double-loop math), max|Δ| = 0 at every index.
//
// Falsifiers (all on a SMALL V/d/n so they run locally without a GPU):
//   F-AGTAPE-WIRE-LMHEAD-BWD-DTEMB  nn_lm_head_bwd dtemb (farr_outer_gpu +
//                                   farr_add_inplace_gpu) ≡ host dl⊗zT accum
//   F-AGTAPE-WIRE-LMHEAD-BWD-DZT    nn_lm_head_bwd dzT (farr_matmul_t_gpu +
//                                   farr_copy_slice_gpu) ≡ host tembᵀ·dl
//   F-AGTAPE-WIRE-LMHEAD-FWD        nn_lm_head_fwd logits (farr_matmul +
//                                   farr_copy_slice_gpu) ≡ farr_matmul + the
//                                   OLD per-element copy (copy-vs-copy exact)
//   F-AGTAPE-WIRE-ADAMW-KERNEL      farr_adamw_step_gpu(W,m,v,g,…) (the
//                                   large-n path of nn_decoder_adamw_step) ≡
//                                   in-file host AdamW mirroring the kernel's
//                                   decoupled-wd FP64 reference (W,m,v all eq)
//   F-AGTAPE-WIRE-ADAMW-SMALLN-EQ   nn_decoder_adamw_step at n ≤ 10M leaves
//                                   the V=256-era opt_adamw_step trajectory
//                                   bit-for-bit unchanged (host path preserved)
//
// Tolerance: the PURE-SCALAR / copy paths (FWD copy, DTEMB outer-accumulate,
// SMALLN host path) must be EXACTLY max|Δ| = 0. The two REDUCTION paths that
// run through FMA-fusible C in the kernel CPU helper — dzT (Σ_r M[r·C+k]·u[r]
// in _hx_farr_matmul_t_cpu, clang -O2 FMA-fuses `O[k] += mr[k]·ur`) and AdamW
// (the W-update `W − lr·wd·W − lr·m̂/denom`) — differ from the hexa-side
// scalar reference in the last ulp (FMA single-round vs separate mul+add).
// That is the documented RFC-040 §2.2 FMA-vs-hexa-scalar caveat — the SAME
// reason the existing flame_nn_test.hexa gates nn_lm_head_fwd / nn_linear_fwd
// at < 1e-12 not == 0. Those two are gated at < 1e-12 (measured Δ ≈ 1e-17/19).
// Any deviation ABOVE these bounds ⇒ the kernel CPU-fallback diverges from the
// host loop ⇒ that wiring is unsound; report the Δ.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/train_lib"
use "stdlib/flame/optim_lib"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_dev(a: int, b: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let dv = nn_abs(t_get(a, i) - t_get(b, i))
        if dv > m { m = dv }
        i = i + 1
    }
    return m
}

// ── independent host references (the OLD V=256-era loops, inlined) ─────────

// OLD nn_lm_head_fwd copy: logits[k] = prod[k] (per-element). We compute the
// same matvec via farr_matmul then copy element-by-element on the host — the
// kernel-wired path replaces ONLY the copy with farr_copy_slice_gpu (the
// matmul is identical), so this reference is bit-exact (copy vs copy).
fn ref_lm_head_fwd(temb: int, zT: int, logits_out: int, V: int, d: int) {
    let prod = farr_matmul(temb, V, d, zT, 1)
    let mut k = 0
    while k < V {
        t_set(logits_out, k, t_get(prod, k))
        k = k + 1
    }
    let _ = farr_free(prod)
}

// OLD nn_lm_head_bwd: dtemb += dl⊗zT (k/j double loop), dzT = tembᵀ·dl
// (j2/k2 double loop) — verbatim from the pre-#1262 nn_lib.hexa.
fn ref_lm_head_bwd(temb: int, zT: int, dl: int,
                   dtemb_out: int, dzT_out: int, V: int, d: int) {
    let mut k = 0
    while k < V {
        let dlk = t_get(dl, k)
        let mut j = 0
        while j < d {
            let cur = t_get(dtemb_out, k * d + j)
            t_set(dtemb_out, k * d + j, cur + dlk * t_get(zT, j))
            j = j + 1
        }
        k = k + 1
    }
    let mut j2 = 0
    while j2 < d {
        let mut acc = 0.0
        let mut k2 = 0
        while k2 < V {
            acc = acc + t_get(temb, k2 * d + j2) * t_get(dl, k2)
            k2 = k2 + 1
        }
        t_set(dzT_out, j2, acc)
        j2 = j2 + 1
    }
}

// Host AdamW mirroring _hx_farr_adamw_step_cpu EXACTLY (the kernel's FP64
// reference — the path nn_decoder_adamw_step takes for large n): bias
// correction via repeated multiply (b1t *= b1), c1 = 1−b1t, the update form
// wi = W − lr·wd·W − lr·mhat/(√vhat+eps), m/v updated in place, fresh W
// written to a separate output. (This is NOT the RFC-034 opt_adamw_step
// builtin, which uses pow() + a different grouping — see the §note.)
fn ref_adamw_kernel(W_in: int, m_io: int, v_io: int, g_in: int, n: int,
                    lr: float, b1: float, b2: float, eps: float, wd: float,
                    step_t: int, W_out: int) {
    let mut b1t = 1.0
    let mut b2t = 1.0
    let mut e = 0
    while e < step_t {
        b1t = b1t * b1
        b2t = b2t * b2
        e = e + 1
    }
    let c1 = 1.0 - b1t
    let c2 = 1.0 - b2t
    let mut i = 0
    while i < n {
        let g = t_get(g_in, i)
        let mi = b1 * t_get(m_io, i) + (1.0 - b1) * g
        let vi = b2 * t_get(v_io, i) + (1.0 - b2) * g * g
        let mhat = mi / c1
        let vhat = vi / c2
        // _hx_farr_adamw_step_cpu uses libm sqrt (the builtin), NOT dt_sqrt.
        let denom = sqrt(vhat) + eps
        let wi = t_get(W_in, i) - lr * wd * t_get(W_in, i) - lr * mhat / denom
        t_set(m_io, i, mi)
        t_set(v_io, i, vi)
        t_set(W_out, i, wi)
        i = i + 1
    }
}

// ── falsifier harnesses ────────────────────────────────────────────────

// F-AGTAPE-WIRE-LMHEAD-{BWD-DTEMB,BWD-DZT,FWD}
fn check_lm_head_wire() -> int {
    let V = 16
    let d = 8

    let temb = t_zeros(V * d)
    t_fill_lcg(temb, V * d, 1024, 0.2)
    let zT = t_zeros(d)
    t_fill_lcg(zT, d, 2048, 1.0)

    // FWD
    let logits_wire = t_zeros(V)
    nn_lm_head_fwd(temb, zT, logits_wire, V, d)
    let logits_ref = t_zeros(V)
    ref_lm_head_fwd(temb, zT, logits_ref, V, d)
    let fwd_dev = max_dev(logits_wire, logits_ref, V)

    // BWD — pre-existing dtemb (test ACCUMULATE behavior; both sides start eq).
    let dl = t_zeros(V)
    t_fill_lcg(dl, V, 31, 0.7)
    let dtemb_wire = t_zeros(V * d)
    t_fill_lcg(dtemb_wire, V * d, 17, 0.1)
    let dtemb_ref = t_zeros(V * d)
    t_fill_lcg(dtemb_ref, V * d, 17, 0.1)
    let dzT_wire = t_zeros(d)
    let dzT_ref = t_zeros(d)

    nn_lm_head_bwd(temb, zT, dl, dtemb_wire, dzT_wire, V, d)
    ref_lm_head_bwd(temb, zT, dl, dtemb_ref, dzT_ref, V, d)

    let dtemb_dev = max_dev(dtemb_wire, dtemb_ref, V * d)
    let dzT_dev = max_dev(dzT_wire, dzT_ref, d)

    let _ = t_free(temb); let _ = t_free(zT); let _ = t_free(dl)
    let _ = t_free(logits_wire); let _ = t_free(logits_ref)
    let _ = t_free(dtemb_wire); let _ = t_free(dtemb_ref)
    let _ = t_free(dzT_wire); let _ = t_free(dzT_ref)

    let out = t_zeros(3)
    t_set(out, 0, fwd_dev)
    t_set(out, 1, dtemb_dev)
    t_set(out, 2, dzT_dev)
    return out
}

// F-AGTAPE-WIRE-ADAMW-KERNEL — farr_adamw_step_gpu (the kernel the large-n
// nn_decoder_adamw_step path routes to) vs the in-file host mirror, over a
// 3-step trajectory (exercises the in-place m/v carry + bias correction).
fn check_adamw_kernel() -> int {
    let n = 64

    // wired (kernel) state
    let Wk = t_zeros(n); t_fill_lcg(Wk, n, 77, 0.3)
    let Mk = t_zeros(n)
    let Vk = t_zeros(n)
    // ref state — identical init
    let Wr = t_zeros(n); t_fill_lcg(Wr, n, 77, 0.3)
    let Mr = t_zeros(n)
    let Vr = t_zeros(n)

    let lr = 0.001
    let b1 = 0.9
    let b2 = 0.999
    let eps = 0.00000001
    let wd = 0.01

    let mut max_w = 0.0
    let mut max_m = 0.0
    let mut max_v = 0.0
    let mut step = 1
    while step <= 3 {
        // fresh grad each step
        let g = t_zeros(n)
        t_fill_lcg(g, n, 100 + step * 13, 0.5)

        // kernel path: returns fresh W in a new farr, copies back into Wk.
        // Bind to a `let` BEFORE to_int (3× ternary expand would double-step
        // m/v) — same discipline as train_lib.nn_decoder_adamw_step.
        let newW_h = farr_adamw_step_gpu(Wk, Mk, Vk, g, n,
                                         lr, b1, b2, eps, wd, step)
        let newW = to_int(newW_h)
        let _ = farr_copy_slice_gpu(newW, 0, Wk, 0, n)
        let _ = farr_free(newW)

        // ref path: host mirror writes fresh W into Wr_out, copy back.
        let Wr_out = t_zeros(n)
        ref_adamw_kernel(Wr, Mr, Vr, g, n, lr, b1, b2, eps, wd, step, Wr_out)
        let _ = farr_copy_slice_gpu(Wr_out, 0, Wr, 0, n)
        let _ = t_free(Wr_out)

        let dw = max_dev(Wk, Wr, n)
        let dm = max_dev(Mk, Mr, n)
        let dv = max_dev(Vk, Vr, n)
        if dw > max_w { max_w = dw }
        if dm > max_m { max_m = dm }
        if dv > max_v { max_v = dv }

        let _ = t_free(g)
        step = step + 1
    }

    let _ = t_free(Wk); let _ = t_free(Mk); let _ = t_free(Vk)
    let _ = t_free(Wr); let _ = t_free(Mr); let _ = t_free(Vr)

    let out = t_zeros(3)
    t_set(out, 0, max_w)
    t_set(out, 1, max_m)
    t_set(out, 2, max_v)
    return out
}

// F-AGTAPE-WIRE-ADAMW-SMALLN-EQ — nn_decoder_adamw_step at n ≤ 10M MUST take
// the unchanged host opt_adamw_step path (V=256 trajectory preserved). Verify
// the threshold gate: nn_decoder_adamw_step(n) ≡ opt_adamw_step(n) bit-for-bit.
fn check_adamw_smalln_eq() -> int {
    let n = 64

    // nn_decoder_adamw_step state
    let Wd = t_zeros(n); t_fill_lcg(Wd, n, 55, 0.3)
    let Md = t_zeros(n)
    let Vd = t_zeros(n)
    // opt_adamw_step state — identical init
    let Wo = t_zeros(n); t_fill_lcg(Wo, n, 55, 0.3)
    let Mo = t_zeros(n)
    let Vo = t_zeros(n)

    let lr = 0.001
    let b1 = 0.9
    let b2 = 0.999
    let eps = 0.00000001
    let wd = 0.01

    let mut max_w = 0.0
    let mut step = 1
    while step <= 3 {
        let gd = t_zeros(n); t_fill_lcg(gd, n, 200 + step * 7, 0.5)
        let go = t_zeros(n); t_fill_lcg(go, n, 200 + step * 7, 0.5)
        nn_decoder_adamw_step(Wd, gd, Md, Vd, n, lr, b1, b2, eps, wd, step)
        opt_adamw_step(Wo, go, Mo, Vo, n, lr, b1, b2, eps, wd, step)
        let dw = max_dev(Wd, Wo, n)
        if dw > max_w { max_w = dw }
        let _ = t_free(gd); let _ = t_free(go)
        step = step + 1
    }

    let _ = t_free(Wd); let _ = t_free(Md); let _ = t_free(Vd)
    let _ = t_free(Wo); let _ = t_free(Mo); let _ = t_free(Vo)

    let out = t_zeros(1)
    t_set(out, 0, max_w)
    return out
}

// ─── entrypoint ─────────────────────────────────────────────────────────
println("=== flame large-vocab GPU-port byte-eq selftest (nn_lm_head_fwd/bwd + AdamW kernel wiring, no-CUDA CPU-fallback) ===")

let mut pass = 0
let total = 5

let lh = check_lm_head_wire()
let lh_fwd = t_get(lh, 0)
let lh_dtemb = t_get(lh, 1)
let lh_dzT = t_get(lh, 2)

if lh_fwd == 0.0 {
    println("PASS  F-AGTAPE-WIRE-LMHEAD-FWD        max|nn_lm_head_fwd(farr_copy_slice_gpu) − (farr_matmul + host copy)| = 0.0 (byte-eq · copy-vs-copy)")
    pass = pass + 1
} else {
    print("FAIL  F-AGTAPE-WIRE-LMHEAD-FWD        max|Δ|="); print(lh_fwd); println(" (must be 0.0)")
}

if lh_dtemb == 0.0 {
    println("PASS  F-AGTAPE-WIRE-LMHEAD-BWD-DTEMB  max|dtemb(farr_outer_gpu+farr_add_inplace_gpu) − host dl⊗zT accum| = 0.0 (byte-eq)")
    pass = pass + 1
} else {
    print("FAIL  F-AGTAPE-WIRE-LMHEAD-BWD-DTEMB  max|Δ|="); print(lh_dtemb); println(" (must be 0.0)")
}

// dzT goes through _hx_farr_matmul_t_cpu's FMA-fusible reduction → RFC-040
// §2.2 measured fp-tol (< 1e-12), same as nn_lm_head_fwd in flame_nn_test.
if lh_dzT < 0.000000000001 {
    print("PASS  F-AGTAPE-WIRE-LMHEAD-BWD-DZT    max|dzT(farr_matmul_t_gpu+farr_copy_slice_gpu) − host tembᵀ·dl|="); print(lh_dzT); println(" < 1e-12 (RFC 040 §2.2 FMA-vs-scalar last-ulp)")
    pass = pass + 1
} else {
    print("FAIL  F-AGTAPE-WIRE-LMHEAD-BWD-DZT    max|Δ|="); print(lh_dzT); println(" (>1e-12)")
}

let aw = check_adamw_kernel()
let aw_w = t_get(aw, 0)
let aw_m = t_get(aw, 1)
let aw_v = t_get(aw, 2)
// Every AdamW lane (m = b1·m+(1−b1)·g ; v = b2·v+(1−b2)·g² ; the W update)
// threads through FMA-fusible C in _hx_farr_adamw_step_cpu vs the hexa-side
// scalar mirror → RFC-040 §2.2 last-ulp fp-tol (< 1e-12; measured ≈ 1e-17).
if aw_m < 0.000000000001 {
    if aw_v < 0.000000000001 {
        if aw_w < 0.000000000001 {
            print("PASS  F-AGTAPE-WIRE-ADAMW-KERNEL      max|{W,m,v}_kernel − host-mirror|=("); print(aw_w); print(","); print(aw_m); print(","); print(aw_v); println(") < 1e-12 (RFC 040 §2.2 FMA) over 3 steps")
            pass = pass + 1
        } else {
            print("FAIL  F-AGTAPE-WIRE-ADAMW-KERNEL      W deviation max|Δ|="); print(aw_w); println(" (>1e-12)")
        }
    } else {
        print("FAIL  F-AGTAPE-WIRE-ADAMW-KERNEL      v deviation max|Δ|="); print(aw_v); println(" (>1e-12)")
    }
} else {
    print("FAIL  F-AGTAPE-WIRE-ADAMW-KERNEL      m deviation max|Δ|="); print(aw_m); println(" (>1e-12)")
}

let sn = check_adamw_smalln_eq()
let sn_w = t_get(sn, 0)
if sn_w == 0.0 {
    println("PASS  F-AGTAPE-WIRE-ADAMW-SMALLN-EQ   max|nn_decoder_adamw_step(n≤10M) − opt_adamw_step| = 0.0 over 3 steps (V=256 host path preserved)")
    pass = pass + 1
} else {
    print("FAIL  F-AGTAPE-WIRE-ADAMW-SMALLN-EQ   max|Δ|="); print(sn_w); println(" (must be 0.0 — threshold gate broke the host path)")
}

print("=== ")
print(pass)
print("/")
print(total)
println(" PASS ===")
