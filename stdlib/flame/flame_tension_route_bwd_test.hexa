// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_tension_route_bwd_test.hexa — RFC 059 §3 P1②-b (tension)
//
// L_route is a per-layer tension penalty on an activation `out`:
//   t = mean(out²) ; L_route = λ·t² .  Like cross/L_ψ it is a loss-LAYER
// (not a tape node): the new `ag_tension_route_seed` injects ∂L_route/∂out
// into the registry via ag_seed_grad on out_tid, so the upstream op's reverse
// arm picks it up and propagates to that op's inputs/params.
//
// (In V3 `out` is a purefield FFN output — but tension is substrate-agnostic.
//  To verify the SEED independently of purefield, this test routes it through
//  an existing `ag_linear` node: out = Linear(x); the seed then flows into
//  dx and dW via the linear reverse arm — F-RFC059B-TENSION-ROUTE-SEED.)
//
// Falsifier:
//
//   F-RFC059B-TENSION-ROUTE-SEED   out = x·W ; L = λ·mean(out²)². The
//                                  reverse-mode analytic grad ∂L/∂{x, W}
//                                  (seed → linear reverse) matches central
//                                  finite-diff at ε=1e-5. Gate: rel ≤ 1e-6.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/flame_math"
use "stdlib/flame/ag_tape"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// L_route(out) = λ·mean(out²)²  (host reference).
fn route_loss(out: int, N: int, lambda: float) -> float {
    let mut ss = 0.0
    let mut i = 0
    while i < N {
        let oi = t_get(out, i)
        ss = ss + oi * oi
        i = i + 1
    }
    let t = ss / to_float(N)
    return lambda * t * t
}

// L(x, W) = L_route( Linear(x, W) ).  out = x[1·D] · W[D·C] → out[1·C].
// (no bias — matches ag_linear's zero-bias matmul path)
fn loss_eval(x: int, W: int, bz: int, D: int, C: int, lambda: float) -> float {
    let out = nn_linear_fwd(x, W, bz, 1, D, C)
    let L = route_loss(out, C, lambda)
    t_free(out)
    return L
}

fn central_diff(x: int, W: int, bz: int, D: int, C: int, lambda: float,
                which: int, idx: int, eps: float) -> float {
    let p = if which == 0 { x } else { W }
    let saved = t_get(p, idx)
    t_set(p, idx, saved + eps)
    let lp = loss_eval(x, W, bz, D, C, lambda)
    t_set(p, idx, saved - eps)
    let lm = loss_eval(x, W, bz, D, C, lambda)
    t_set(p, idx, saved)
    return (lp - lm) / (2.0 * eps)
}

fn rel_err(analytic: float, fd: float) -> float {
    let atol = 0.000001
    let denom = if nn_abs(fd) > atol { nn_abs(fd) } else { atol }
    return nn_abs(analytic - fd) / denom
}

println("=== flame RFC 059 §3 P1②-b — tension/L_route seed backward selftest (CPU oracle) ===")

let mut pass = 0
let total = 1

let D = 4
let C = 5
let lambda = 1.3

let x = t_zeros(D)
let W = t_zeros(D * C)
let bz = t_zeros(C)        // zero bias (ag_linear zero-bias matmul path)
let mut e = 0
while e < D * C {
    t_set(W, e, to_float((e * 7) % 23 - 11) * 0.021 + 0.04)
    e = e + 1
}
let mut xi = 0
while xi < D {
    t_set(x, xi, to_float(xi - 1) * 0.037 + 0.06)
    xi = xi + 1
}

// analytic: forward out = Linear(x), seed L_route on out, walk.
let tp = ag_t_begin(2)
let out = ag_linear(tp, x, W, bz, 1, D, C)
let N = t_len(out)
let L = ag_tension_route_seed(tp, out, lambda, N)
ag_backward_reg(tp, out, t_zeros(N))
let g_x = ag_grad(tp, x)
let g_W = ag_grad(tp, W)
print("      L_route = λ·mean(out²)² = "); println(L)

let eps = 0.00001
let mut worst = 0.0

let fx0 = central_diff(x, W, bz, D, C, lambda, 0, 0, eps)
let fx2 = central_diff(x, W, bz, D, C, lambda, 0, 2, eps)
let fw3 = central_diff(x, W, bz, D, C, lambda, 1, 3, eps)
let fw11 = central_diff(x, W, bz, D, C, lambda, 1, 11, eps)
let r_x0 = rel_err(t_get(g_x, 0), fx0)
let r_x2 = rel_err(t_get(g_x, 2), fx2)
let r_w3 = rel_err(t_get(g_W, 3), fw3)
let r_w11 = rel_err(t_get(g_W, 11), fw11)
if r_x0 > worst { worst = r_x0 }
if r_x2 > worst { worst = r_x2 }
if r_w3 > worst { worst = r_w3 }
if r_w11 > worst { worst = r_w11 }
print("      x[0]  analytic="); print(t_get(g_x, 0));  print(" fd="); print(fx0); print(" rel="); println(r_x0)
print("      x[2]  analytic="); print(t_get(g_x, 2));  print(" fd="); print(fx2); print(" rel="); println(r_x2)
print("      W[3]  analytic="); print(t_get(g_W, 3));  print(" fd="); print(fw3); print(" rel="); println(r_w3)
print("      W[11] analytic="); print(t_get(g_W, 11)); print(" fd="); print(fw11); print(" rel="); println(r_w11)

print("      worst rel-error (x+W, 4 probes) = "); println(worst)
if worst <= 0.000001 {
    println("PASS  F-RFC059B-TENSION-ROUTE-SEED   tension seed → linear reverse rel ≤ 1e-6 (RFC 059 §3)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC059B-TENSION-ROUTE-SEED   worst rel="); print(worst); println(" (>1e-6)")
}
ag_t_free_state(tp); ag_t_free_reg(tp); ag_t_end(tp)

t_free(x); t_free(W); t_free(bz)

print("=== ")
print(pass)
print("/")
print(total)
println(" PASS ===")
