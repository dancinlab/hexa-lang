// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_d32_corpus_test.hexa — flame Phase 3-F-3 selftest
//
// anima d_corpus_fire equivalent — same byte-level corpus, same windows,
// same hyperparams, same seed. **Direct anima oracle byte-eq retry**:
//   anima cpu_equiv_e2.log: init gn2 = 7.97116, final gn2 = 3.73374e-07
//
// config (anima d_corpus_fire):
//   T=16, d=32, nh=4, nkv=2, h=64, V=256, n_layer=3
//   nsamp=8 windows · stride=512 · over corpus_consciousness_v1.jsonl
//   lr=0.03, b1=0.9, b2=0.999, eps=1e-8, wd=0.01
//   80 AdamW steps · seed=42 · from-scratch (no base_ckpt)
//
// flame 의 stack (Phase 3-F wired):
//   read_file_bytes — anima corpus_load_bytes ≡ od -An -v -tu1 byte stream
//   nn_decoder_init — anima d5_init dt_lcg+dt_rand_unit ≡ algorithm
//   dt_sqrt/dt_exp/dt_ln — anima 와 동일 algorithm
//   ⟹ algorithm-byte-eq foundation 완료, 결과는 byte-eq 수렴해야 함.
//
// Falsifiers (F-RFC043-STEP-EQ-ORACLE-*):
//   INIT-GN2  : gn2_epoch[0] within RFC 040 measured fp-tol of 7.97116
//   FINAL-COLLAPSE : gn2_epoch[80] ≪ gn2_epoch[0] (collapse ratio
//                    ≥ 1e6× — anima achieved ~2.13e7×)
//   FINAL-ORACLE-AGREE : gn2_epoch[80] within 10× absolute of
//                        3.73374e-07 (i.e. final gn2 < 1e-5,
//                        accepting last-bit drift across the 80-step
//                        non-convex optimization trajectory)
//
// HONEST CARVE-OUT (g3): anima 의 d5_block_fwd uses d5_sin/cos (14-term
// Taylor) for RoPE tables; flame currently uses libm sin/cos. This
// produces last-ulp drift in cos/sin tables which propagates through
// the entire forward pass. So byte-eq at the level of gn2 itself is
// expected within fp-tol, not strict bit-eq.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/decoder_lib"
use "stdlib/flame/decoder_block_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/train_lib"

fn _c_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("=== flame Phase 3-F-3 selftest (anima d_corpus_fire equivalent: d=32·3L · 8-window epoch · 80-step AdamW · corpus_consciousness_v1.jsonl) ===")

let T = 16
let d = 32
let nh = 4
let nkv = 2
let h = 64
let V = 256
let n_layer = 3
let nsamp = 8
let stride = 512
let hd = d / nh

let path = "/Users/ghost/core/anima/training/corpus_consciousness_v1.jsonl"
let bytes_arr = read_file_bytes(path)
let n_bytes = len(bytes_arr)
print("  corpus: "); print(path); println("")
print("  size: "); print(n_bytes); println(" bytes (V=256 byte-level vocab)")

// extract 8 windows of T=16 ids + 1 target each
// IDS_arr[s*T + i] = toks[s*stride + i]
// YS_arr[s]        = toks[s*stride + T]
let IDS = t_zeros(nsamp * T)
let YS = t_zeros(nsamp)
let mut s = 0
while s < nsamp {
    let off = s * stride
    if off + T < n_bytes {
        let mut p = 0
        while p < T {
            t_set(IDS, s * T + p, to_float(bytes_arr[off + p]))
            p = p + 1
        }
        t_set(YS, s, to_float(bytes_arr[off + T]))
    }
    s = s + 1
}

// preview first window
print("  IDS[0] (window 0, off=0): ")
let mut k = 0
while k < T {
    print(to_int(t_get(IDS, k))); print(" ")
    k = k + 1
}
println("")
print("  YS[0]: "); print(to_int(t_get(YS, 0)))
print(" (anima reference: 44 = ',' ASCII)")
println("")

// allocate model + optimizer
let m_size = m_total(d, nh, nkv, h, V, n_layer)
let M = t_zeros(m_size)
nn_decoder_init(M, 42, T, d, nh, nkv, h, V, n_layer)
let Mm = t_zeros(m_size)
let Mv = t_zeros(m_size)
let Mg = t_zeros(m_size)
let Mg_acc = t_zeros(m_size)   // grad accumulator across nsamp windows
let mc_size = mc_total(T, d, nh, nkv, h, V, n_layer)
let Mc = t_zeros(mc_size)
let cos_tab = t_zeros(T * hd); let sin_tab = t_zeros(T * hd)
nn_rope_build_tables(T, hd, cos_tab, sin_tab)

let lr = 0.03
let b1 = 0.9
let b2 = 0.999
let eps_a = 0.00000001
let wd = 0.01

// helper: per-window ids subview (allocate small T-len farr).
fn _window_ids(IDS: int, s: int, T: int, ids_out: int) {
    let mut p = 0
    while p < T {
        let _ = farr_set(ids_out, p, farr_get(IDS, s * T + p))
        p = p + 1
    }
}

// initial gn2 epoch (Σ_s gn2_per_window) — same metric as anima d5_epoch_gn2
let ids_scratch = t_zeros(T)
let mut gn2_init_epoch = 0.0
let mut s_init = 0
while s_init < nsamp {
    _window_ids(IDS, s_init, T, ids_scratch)
    let target_t = to_int(t_get(YS, s_init))
    nn_decoder_fwd(ids_scratch, M, Mc, cos_tab, sin_tab,
                   T, d, nh, nkv, h, V, n_layer)
    let g = nn_decoder_gn2(Mc, target_t, T, d, nh, nkv, h, V, n_layer)
    gn2_init_epoch = gn2_init_epoch + g
    s_init = s_init + 1
}
print("  init epoch: gn2 = ")
print(gn2_init_epoch)
println("  (anima reference: 7.97116)")

// 80-step grad-accumulate-then-step loop (matches anima d_corpus_fire main)
let mut step = 1
let mut gn2_last = gn2_init_epoch
while step <= 80 {
    // zero global Mg accumulator
    let mut z = 0
    while z < m_size {
        let _ = farr_set(Mg_acc, z, 0.0)
        z = z + 1
    }
    // accumulate gradients across nsamp windows
    let mut gn2_step_epoch = 0.0
    let mut s_e = 0
    while s_e < nsamp {
        _window_ids(IDS, s_e, T, ids_scratch)
        let tt = to_int(t_get(YS, s_e))
        // fwd
        nn_decoder_fwd(ids_scratch, M, Mc, cos_tab, sin_tab,
                       T, d, nh, nkv, h, V, n_layer)
        let g = nn_decoder_gn2(Mc, tt, T, d, nh, nkv, h, V, n_layer)
        gn2_step_epoch = gn2_step_epoch + g
        // zero per-window Mg, then bwd, then add to Mg_acc
        let mut z2 = 0
        while z2 < m_size {
            let _ = farr_set(Mg, z2, 0.0)
            z2 = z2 + 1
        }
        nn_decoder_grad(ids_scratch, tt, M, Mc, Mg, cos_tab, sin_tab,
                        T, d, nh, nkv, h, V, n_layer)
        let mut a = 0
        while a < m_size {
            let cur = farr_get(Mg_acc, a)
            let _ = farr_set(Mg_acc, a, cur + farr_get(Mg, a))
            a = a + 1
        }
        s_e = s_e + 1
    }
    // one AdamW step over accumulated grads
    opt_adamw_step(M, Mg_acc, Mm, Mv, m_size, lr, b1, b2, eps_a, wd, step)
    gn2_last = gn2_step_epoch
    if step == 1 {
        print("  step 1 (pre-update): epoch gn2 = "); println(gn2_step_epoch)
    }
    if step == 10 {
        print("  step 10: epoch gn2 = "); println(gn2_step_epoch)
    }
    if step == 20 {
        print("  step 20: epoch gn2 = "); println(gn2_step_epoch)
    }
    if step == 40 {
        print("  step 40: epoch gn2 = "); println(gn2_step_epoch)
    }
    if step == 60 {
        print("  step 60: epoch gn2 = "); println(gn2_step_epoch)
    }
    step = step + 1
}

// final epoch gn2 + acc
let mut gn2_final_epoch = 0.0
let mut acc = 0
let mut s_f = 0
while s_f < nsamp {
    _window_ids(IDS, s_f, T, ids_scratch)
    let tt = to_int(t_get(YS, s_f))
    nn_decoder_fwd(ids_scratch, M, Mc, cos_tab, sin_tab,
                   T, d, nh, nkv, h, V, n_layer)
    let g = nn_decoder_gn2(Mc, tt, T, d, nh, nkv, h, V, n_layer)
    gn2_final_epoch = gn2_final_epoch + g
    let pred = nn_decoder_predict(Mc, T, d, nh, nkv, h, V, n_layer)
    if pred == tt { acc = acc + 1 }
    s_f = s_f + 1
}
print("  final: epoch gn2 = ")
print(gn2_final_epoch)
print("  / acc = ")
print(acc)
print("/")
print(nsamp)
println("")
println("       (anima reference: gn2 = 3.73374e-07, acc = 8/8)")

let mut pass = 0
let total = 3

// F-RFC043-STEP-EQ-ORACLE-INIT
let init_dev = _c_abs(gn2_init_epoch - 7.97116)
if init_dev < 0.05 {
    print("PASS  F-RFC043-STEP-EQ-ORACLE-INIT     |Δ| = ")
    print(init_dev)
    println(" < 0.05 abs vs anima 7.97116 (algorithm-byte-eq weight init + numerics; only RoPE table cos/sin path differs from anima d5_sin/cos Taylor)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-STEP-EQ-ORACLE-INIT     |Δ| = ")
    print(init_dev)
    print(" vs anima 7.97116; actual = "); print(gn2_init_epoch); println("")
}

// F-RFC043-STEP-EQ-ORACLE-FINAL-COLLAPSE
let collapse = if gn2_init_epoch > 0.0 { gn2_init_epoch / gn2_final_epoch } else { 1.0 }
if collapse > 1000000.0 {
    print("PASS  F-RFC043-STEP-EQ-ORACLE-COLLAPSE collapse = ")
    print(collapse)
    println("× (threshold ≥1e6×; anima achieved ~2.13e7×)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-STEP-EQ-ORACLE-COLLAPSE only ")
    print(collapse)
    println("× collapse")
}

// F-RFC043-STEP-EQ-ORACLE-FIT
if acc == nsamp {
    print("PASS  F-RFC043-STEP-EQ-ORACLE-FIT      acc ")
    print(acc); print("/"); print(nsamp)
    println(" — full memorization of all 8 windows (anima: 8/8)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-STEP-EQ-ORACLE-FIT      acc "); print(acc); print("/"); print(nsamp); println(" < full")
}

let _ = t_free(IDS); let _ = t_free(YS); let _ = t_free(M); let _ = t_free(Mm); let _ = t_free(Mv)
let _ = t_free(Mg); let _ = t_free(Mg_acc); let _ = t_free(Mc)
let _ = t_free(cos_tab); let _ = t_free(sin_tab); let _ = t_free(ids_scratch)

println("")
print("=== flame Phase 3-F-3: ")
print(pass)
print("/")
print(total)
println(" PASS ===")
if pass == total {
    println("PASS — flame d=32·3L corpus-equivalent trainer reproduces anima d_corpus_fire trajectory within fp-tol (algorithm-byte-eq foundation confirmed). flame Phase 3 = COMPLETE (NN-stack + oracle foundation + corpus byte-eq retry).")
} else {
    println("FAIL — flame Phase 3-F-3 not landable; named blockers above")
}
