// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_nn_test.hexa — flame Phase 2-A selftest
//
// Falsifiers (RFC 043 §Verification + g_flame_api_fixed):
//   F-RFC043-LAYER-EQ-LINEAR-FWD   nn_linear_fwd y[i,j] ≡ closed sum
//                                  Σ_k x[i,k]·W[k,j] + b[j]  (byte-eq)
//   F-RFC043-LAYER-EQ-LINEAR-BWD   nn_linear_bwd {dW, dx, db} ≡ closed
//                                  analytic vjp  (byte-eq)
//   F-RFC043-LAYER-EQ-RMSNORM-FWD  nn_rmsnorm_fwd y_i ≡ c3_rmsnorm_fwd
//                                  algebra (g_i·x_i/sqrt(mean(x²)+ε))
//                                  (byte-eq within same sqrt impl)
//   F-RFC043-LAYER-EQ-RMSNORM-BWD  nn_rmsnorm_bwd {dx, dg} ≡
//                                  c3_rmsnorm_bwd closed vjp  (byte-eq)
//
// Each falsifier compares the flame wrapper to an INDEPENDENT in-file
// closed-form reference computation — proving the wrapper exactly
// implements the analytic formula. Cross-link to anima d_train3_lib.hexa
// c3_matvec / c3_rmsnorm_fwd / c3_rmsnorm_bwd: the analytic forms are
// IDENTICAL — flame's wrapper ≡ in-file ref ≡ c3_* (transitive).
//
// g_blue_closed_mandate: F-RFC043-LAYER-EQ is the connection-point closed
// check between flame's nn surface and the verified RFC-040 oracle —
// must be byte-equal (or RFC-040 measured fp-tol where reduction differs).
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ─── reference impls (independent of nn_lib wrappers) ──────────────────

// Reference linear fwd — `ikj` accumulation matching farr_matmul exactly
// (self/runtime.c hexa_farr_matmul: `for i { for k { for j { C[i,j] +=
// A[i,k]*B[k,j] } } }`). Different reduction order ⇒ different last-bit
// per fp-non-associativity (RFC 040 TOL_MATMUL caveat) — so the ref MUST
// match the wrapper's order to anchor a byte-equal check.
fn ref_linear_fwd(x: int, W: int, b: int, B: int, D: int, C: int) -> int {
    let y = t_zeros(B * C)
    // y starts zero — matmul accumulates into it in ikj order.
    let mut i = 0
    while i < B {
        let mut k = 0
        while k < D {
            let a_ik = t_get(x, i * D + k)
            let mut j = 0
            while j < C {
                let cur = t_get(y, i * C + j)
                t_set(y, i * C + j, cur + a_ik * t_get(W, k * C + j))
                j = j + 1
            }
            k = k + 1
        }
        // bias broadcast — same single-pass order as nn_linear_fwd.
        let mut jj = 0
        while jj < C {
            let cur = t_get(y, i * C + jj)
            t_set(y, i * C + jj, cur + t_get(b, jj))
            jj = jj + 1
        }
        i = i + 1
    }
    return y
}

fn ref_linear_bwd(x: int, W: int, dy: int,
                  dW_out: int, dx_out: int, db_out: int,
                  B: int, D: int, C: int) {
    let mut d = 0
    while d < D {
        let mut c = 0
        while c < C {
            let mut acc = 0.0
            let mut bi = 0
            while bi < B {
                acc = acc + t_get(x, bi * D + d) * t_get(dy, bi * C + c)
                bi = bi + 1
            }
            t_set(dW_out, d * C + c, acc)
            c = c + 1
        }
        d = d + 1
    }
    let mut bi2 = 0
    while bi2 < B {
        let mut d2 = 0
        while d2 < D {
            let mut acc2 = 0.0
            let mut c2 = 0
            while c2 < C {
                acc2 = acc2 + t_get(dy, bi2 * C + c2) * t_get(W, d2 * C + c2)
                c2 = c2 + 1
            }
            t_set(dx_out, bi2 * D + d2, acc2)
            d2 = d2 + 1
        }
        bi2 = bi2 + 1
    }
    let mut j = 0
    while j < C {
        let mut acc3 = 0.0
        let mut i3 = 0
        while i3 < B {
            acc3 = acc3 + t_get(dy, i3 * C + j)
            i3 = i3 + 1
        }
        t_set(db_out, j, acc3)
        j = j + 1
    }
}

// Reference RMSNorm fwd — c3_rmsnorm_fwd algebra (same eps + sqrt path).
fn ref_rmsnorm_fwd(x: int, g: int,
                   y_out: int, xn_out: int, inv_out: int, d: int) {
    let eps = 0.000001
    let mut ms = 0.0
    let mut i = 0
    while i < d {
        let xi = t_get(x, i)
        ms = ms + xi * xi
        i = i + 1
    }
    ms = ms / to_float(d)
    let inv = 1.0 / sqrt(ms + eps)
    t_set(inv_out, 0, inv)
    let mut j = 0
    while j < d {
        let xni = t_get(x, j) * inv
        t_set(xn_out, j, xni)
        t_set(y_out, j, t_get(g, j) * xni)
        j = j + 1
    }
}

// Reference embedding fwd — direct row copy from table.
fn ref_embedding_fwd(ids: int, table: int, X_out: int, T: int, d: int) {
    let mut i = 0
    while i < T {
        let tok = to_int(t_get(ids, i))
        let mut c = 0
        while c < d {
            t_set(X_out, i * d + c, t_get(table, tok * d + c))
            c = c + 1
        }
        i = i + 1
    }
}

fn ref_embedding_bwd_scatter(dX: int, ids: int, dtable_inout: int,
                             T: int, d: int) {
    let mut i = 0
    while i < T {
        let tok = to_int(t_get(ids, i))
        let mut c = 0
        while c < d {
            let cur = t_get(dtable_inout, tok * d + c)
            t_set(dtable_inout, tok * d + c, cur + t_get(dX, i * d + c))
            c = c + 1
        }
        i = i + 1
    }
}

// Reference tied LM head fwd — closed matvec.
fn ref_lm_head_fwd(temb: int, zT: int, logits_out: int, V: int, d: int) {
    let mut k = 0
    while k < V {
        let mut acc = 0.0
        let mut j = 0
        while j < d {
            acc = acc + t_get(temb, k * d + j) * t_get(zT, j)
            j = j + 1
        }
        t_set(logits_out, k, acc)
        k = k + 1
    }
}

fn ref_lm_head_bwd(temb: int, zT: int, dl: int,
                   dtemb_out: int, dzT_out: int, V: int, d: int) {
    let mut k = 0
    while k < V {
        let dlk = t_get(dl, k)
        let mut j = 0
        while j < d {
            let cur = t_get(dtemb_out, k * d + j)
            t_set(dtemb_out, k * d + j, cur + dlk * t_get(zT, j))
            j = j + 1
        }
        k = k + 1
    }
    let mut j2 = 0
    while j2 < d {
        let mut acc = 0.0
        let mut k2 = 0
        while k2 < V {
            acc = acc + t_get(temb, k2 * d + j2) * t_get(dl, k2)
            k2 = k2 + 1
        }
        t_set(dzT_out, j2, acc)
        j2 = j2 + 1
    }
}

fn ref_rmsnorm_bwd(x: int, g: int, xn: int, inv: float, dy: int,
                   dx_out: int, dg_out: int, d: int) {
    let mut dot = 0.0
    let mut i = 0
    while i < d {
        let dxn_i = t_get(dy, i) * t_get(g, i)
        t_set(dg_out, i, t_get(dy, i) * t_get(xn, i))
        dot = dot + dxn_i * t_get(x, i)
        t_set(dx_out, i, dxn_i)
        i = i + 1
    }
    let inv3 = inv * inv * inv
    let scale = (inv3 / to_float(d)) * dot
    let mut j = 0
    while j < d {
        let dxn_j = t_get(dx_out, j)
        let xj = t_get(x, j)
        t_set(dx_out, j, inv * dxn_j - scale * xj)
        j = j + 1
    }
}

// ─── falsifier harnesses ───────────────────────────────────────────────

fn max_dev_farr(a: int, b: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let d = nn_abs(t_get(a, i) - t_get(b, i))
        if d > m { m = d }
        i = i + 1
    }
    return m
}

// F-RFC043-LAYER-EQ-LINEAR-FWD + BWD
fn check_linear() -> int {
    let B = 4
    let D = 3
    let C = 5

    // deterministic fixed inputs (LCG, seed=42).
    let x = t_zeros(B * D)
    t_fill_lcg(x, B * D, 42 * 7 + 13, 1.0)
    let W = t_zeros(D * C)
    t_fill_lcg(W, D * C, 42, 0.5)
    let b = t_zeros(C)
    t_fill_lcg(b, C, 9001, 0.1)

    // forward
    let y_flame = nn_linear_fwd(x, W, b, B, D, C)
    let y_ref = ref_linear_fwd(x, W, b, B, D, C)
    let dev_fwd = max_dev_farr(y_flame, y_ref, B * C)

    // backward — seed dy with LCG.
    let dy = t_zeros(B * C)
    t_fill_lcg(dy, B * C, 31337, 1.0)

    let dW_flame = t_zeros(D * C)
    let dx_flame = t_zeros(B * D)
    let db_flame = t_zeros(C)
    nn_linear_bwd(x, W, dy, dW_flame, dx_flame, db_flame, B, D, C)

    let dW_ref = t_zeros(D * C)
    let dx_ref = t_zeros(B * D)
    let db_ref = t_zeros(C)
    ref_linear_bwd(x, W, dy, dW_ref, dx_ref, db_ref, B, D, C)

    let dW_dev = max_dev_farr(dW_flame, dW_ref, D * C)
    let dx_dev = max_dev_farr(dx_flame, dx_ref, B * D)
    let db_dev = max_dev_farr(db_flame, db_ref, C)

    // free intermediates
    let _ = t_free(y_flame); let _ = t_free(y_ref)
    let _ = t_free(dy)
    let _ = t_free(dW_flame); let _ = t_free(dx_flame); let _ = t_free(db_flame)
    let _ = t_free(dW_ref); let _ = t_free(dx_ref); let _ = t_free(db_ref)
    let _ = t_free(x); let _ = t_free(W); let _ = t_free(b)

    // pack [fwd, dW, dx, db] devs into a 4-len return farr.
    let out = t_zeros(4)
    t_set(out, 0, dev_fwd)
    t_set(out, 1, dW_dev)
    t_set(out, 2, dx_dev)
    t_set(out, 3, db_dev)
    return out
}

// F-RFC043-LAYER-EQ-RMSNORM-FWD + BWD
fn check_rmsnorm() -> int {
    let d = 8

    let x = t_zeros(d)
    t_fill_lcg(x, d, 7, 1.0)
    let g = t_zeros(d)
    t_fill_lcg(g, d, 13, 0.3)

    let y_flame = t_zeros(d); let xn_flame = t_zeros(d); let inv_flame = t_zeros(1)
    nn_rmsnorm_fwd(x, g, y_flame, xn_flame, inv_flame, d)

    let y_ref = t_zeros(d); let xn_ref = t_zeros(d); let inv_ref = t_zeros(1)
    ref_rmsnorm_fwd(x, g, y_ref, xn_ref, inv_ref, d)

    let dev_fwd_y = max_dev_farr(y_flame, y_ref, d)
    let dev_fwd_xn = max_dev_farr(xn_flame, xn_ref, d)
    let dev_fwd_inv = nn_abs(t_get(inv_flame, 0) - t_get(inv_ref, 0))

    // backward
    let dy = t_zeros(d)
    t_fill_lcg(dy, d, 999, 1.0)

    let dx_flame = t_zeros(d); let dg_flame = t_zeros(d)
    let inv_val = t_get(inv_flame, 0)
    nn_rmsnorm_bwd(x, g, xn_flame, inv_val, dy, dx_flame, dg_flame, d)

    let dx_ref = t_zeros(d); let dg_ref = t_zeros(d)
    ref_rmsnorm_bwd(x, g, xn_ref, inv_val, dy, dx_ref, dg_ref, d)

    let dx_dev = max_dev_farr(dx_flame, dx_ref, d)
    let dg_dev = max_dev_farr(dg_flame, dg_ref, d)

    // free
    let _ = t_free(x); let _ = t_free(g); let _ = t_free(dy)
    let _ = t_free(y_flame); let _ = t_free(xn_flame); let _ = t_free(inv_flame)
    let _ = t_free(y_ref);   let _ = t_free(xn_ref);   let _ = t_free(inv_ref)
    let _ = t_free(dx_flame); let _ = t_free(dg_flame)
    let _ = t_free(dx_ref);   let _ = t_free(dg_ref)

    let out = t_zeros(5)
    t_set(out, 0, dev_fwd_y)
    t_set(out, 1, dev_fwd_xn)
    t_set(out, 2, dev_fwd_inv)
    t_set(out, 3, dx_dev)
    t_set(out, 4, dg_dev)
    return out
}

// F-RFC043-LAYER-EQ-EMBED-{FWD,SCATTER}
fn check_embedding() -> int {
    let T = 5
    let d = 4
    let V = 7

    let ids = t_zeros(T)
    t_set(ids, 0, 2.0); t_set(ids, 1, 5.0); t_set(ids, 2, 0.0)
    t_set(ids, 3, 6.0); t_set(ids, 4, 3.0)
    let table = t_zeros(V * d)
    t_fill_lcg(table, V * d, 4242, 0.3)

    let X_flame = t_zeros(T * d)
    nn_embedding_fwd(ids, table, X_flame, T, d)
    let X_ref = t_zeros(T * d)
    ref_embedding_fwd(ids, table, X_ref, T, d)
    let fwd_dev = max_dev_farr(X_flame, X_ref, T * d)

    // scatter check — both paths receive the SAME pre-existing dtable
    // (to test accumulation behaviour, not just from-zero).
    let dX = t_zeros(T * d)
    t_fill_lcg(dX, T * d, 7777, 0.5)
    let dtable_flame = t_zeros(V * d)
    t_fill_lcg(dtable_flame, V * d, 99, 0.1)   // pre-fill
    let dtable_ref = t_zeros(V * d)
    t_fill_lcg(dtable_ref, V * d, 99, 0.1)     // same pre-fill

    nn_embedding_bwd_scatter(dX, ids, dtable_flame, T, d)
    ref_embedding_bwd_scatter(dX, ids, dtable_ref, T, d)
    let scatter_dev = max_dev_farr(dtable_flame, dtable_ref, V * d)

    let _ = t_free(ids); let _ = t_free(table); let _ = t_free(dX)
    let _ = t_free(X_flame); let _ = t_free(X_ref)
    let _ = t_free(dtable_flame); let _ = t_free(dtable_ref)

    let out = t_zeros(2)
    t_set(out, 0, fwd_dev)
    t_set(out, 1, scatter_dev)
    return out
}

// F-RFC043-LAYER-EQ-LMHEAD-{FWD,BWD}
fn check_lm_head() -> int {
    let V = 6
    let d = 4

    let temb = t_zeros(V * d)
    t_fill_lcg(temb, V * d, 1024, 0.2)
    let zT = t_zeros(d)
    t_fill_lcg(zT, d, 2048, 1.0)

    let logits_flame = t_zeros(V)
    nn_lm_head_fwd(temb, zT, logits_flame, V, d)
    let logits_ref = t_zeros(V)
    ref_lm_head_fwd(temb, zT, logits_ref, V, d)
    let fwd_dev = max_dev_farr(logits_flame, logits_ref, V)

    // bwd — use same pre-existing dtemb (test ACCUMULATE behavior).
    let dl = t_zeros(V)
    t_fill_lcg(dl, V, 31, 0.7)
    let dtemb_flame = t_zeros(V * d)
    t_fill_lcg(dtemb_flame, V * d, 17, 0.1)
    let dtemb_ref = t_zeros(V * d)
    t_fill_lcg(dtemb_ref, V * d, 17, 0.1)
    let dzT_flame = t_zeros(d)
    let dzT_ref = t_zeros(d)

    nn_lm_head_bwd(temb, zT, dl, dtemb_flame, dzT_flame, V, d)
    ref_lm_head_bwd(temb, zT, dl, dtemb_ref, dzT_ref, V, d)

    let bwd_dtemb_dev = max_dev_farr(dtemb_flame, dtemb_ref, V * d)
    let bwd_dzT_dev = max_dev_farr(dzT_flame, dzT_ref, d)

    let _ = t_free(temb); let _ = t_free(zT); let _ = t_free(dl)
    let _ = t_free(logits_flame); let _ = t_free(logits_ref)
    let _ = t_free(dtemb_flame); let _ = t_free(dtemb_ref)
    let _ = t_free(dzT_flame); let _ = t_free(dzT_ref)

    let out = t_zeros(3)
    t_set(out, 0, fwd_dev)
    t_set(out, 1, bwd_dtemb_dev)
    t_set(out, 2, bwd_dzT_dev)
    return out
}

// ─── entrypoint ────────────────────────────────────────────────────────
println("=== flame Phase 2 selftest (nn_lib: Linear + RMSNorm + Embedding + LMHead, compiled-native) ===")

let mut pass = 0
let total = 8

// ── Linear ─────────────────────────────────────────────────────────────
let lin = check_linear()
let lin_fwd = t_get(lin, 0)
let lin_dW = t_get(lin, 1)
let lin_dx = t_get(lin, 2)
let lin_db = t_get(lin, 3)

// RFC 040 measurement-calibrated tolerance — FMA fusion (clang -O2 over
// the C `farr_matmul`) vs hexa-side ref scalar mul-add differ in last
// ulps (fp-non-associativity / FMA single-round). Same RFC 040 §2.2
// honest caveat that justified `TOL_MATMUL ≈ 2e-9` for the cuBLAS oracle.
// For our small d=3 problem the drift is ≪ 1e-12 in practice; we
// document the bound and verify it.
if lin_fwd < 0.000000000001 {
    println("PASS  F-RFC043-LAYER-EQ-LINEAR-FWD   max|nn_linear_fwd − closed-ref| < 1e-12 (RFC 040 §2.2 measured fp-tol; FMA-vs-hexa-scalar last-ulp gap)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-LAYER-EQ-LINEAR-FWD   max|Δ|=")
    print(lin_fwd)
    println(" (>1e-12)")
}

if lin_dW == 0.0 {
    if lin_dx == 0.0 {
        if lin_db == 0.0 {
            println("PASS  F-RFC043-LAYER-EQ-LINEAR-BWD   max|{dW, dx, db}_flame − {dW, dx, db}_ref| = 0.0 (byte-eq · closed analytic vjp)")
            pass = pass + 1
        } else {
            println("FAIL  F-RFC043-LAYER-EQ-LINEAR-BWD   db deviation non-zero")
        }
    } else {
        println("FAIL  F-RFC043-LAYER-EQ-LINEAR-BWD   dx deviation non-zero")
    }
} else {
    println("FAIL  F-RFC043-LAYER-EQ-LINEAR-BWD   dW deviation non-zero")
}

// ── RMSNorm ────────────────────────────────────────────────────────────
let rn = check_rmsnorm()
let rn_y = t_get(rn, 0)
let rn_xn = t_get(rn, 1)
let rn_inv = t_get(rn, 2)
let rn_dx = t_get(rn, 3)
let rn_dg = t_get(rn, 4)

if rn_y == 0.0 {
    if rn_xn == 0.0 {
        if rn_inv == 0.0 {
            println("PASS  F-RFC043-LAYER-EQ-RMSNORM-FWD  max|{y, xn, inv}_flame − {y, xn, inv}_ref| = 0.0 (byte-eq · c3_rmsnorm_fwd algebra)")
            pass = pass + 1
        } else {
            println("FAIL  F-RFC043-LAYER-EQ-RMSNORM-FWD  inv deviation non-zero")
        }
    } else {
        println("FAIL  F-RFC043-LAYER-EQ-RMSNORM-FWD  xn deviation non-zero")
    }
} else {
    println("FAIL  F-RFC043-LAYER-EQ-RMSNORM-FWD  y deviation non-zero")
}

if rn_dx == 0.0 {
    if rn_dg == 0.0 {
        println("PASS  F-RFC043-LAYER-EQ-RMSNORM-BWD  max|{dx, dg}_flame − {dx, dg}_ref| = 0.0 (byte-eq · c3_rmsnorm_bwd closed vjp)")
        pass = pass + 1
    } else {
        println("FAIL  F-RFC043-LAYER-EQ-RMSNORM-BWD  dg deviation non-zero")
    }
} else {
    println("FAIL  F-RFC043-LAYER-EQ-RMSNORM-BWD  dx deviation non-zero")
}

// ── Embedding ──────────────────────────────────────────────────────────
let em = check_embedding()
let em_fwd = t_get(em, 0)
let em_scat = t_get(em, 1)
if em_fwd == 0.0 {
    println("PASS  F-RFC043-LAYER-EQ-EMBED-FWD     max|nn_embedding_fwd − closed-ref| = 0.0 (byte-eq · pure row copy)")
    pass = pass + 1
} else {
    println("FAIL  F-RFC043-LAYER-EQ-EMBED-FWD     fwd deviation non-zero")
}
if em_scat == 0.0 {
    println("PASS  F-RFC043-LAYER-EQ-EMBED-SCATTER max|nn_embedding_bwd_scatter − closed-ref| = 0.0 (byte-eq · scatter-add accumulation, d5_grad §(b) pattern)")
    pass = pass + 1
} else {
    println("FAIL  F-RFC043-LAYER-EQ-EMBED-SCATTER scatter deviation non-zero")
}

// ── Tied LM head ───────────────────────────────────────────────────────
let lh = check_lm_head()
let lh_fwd = t_get(lh, 0)
let lh_dtemb = t_get(lh, 1)
let lh_dzT = t_get(lh, 2)
// FWD uses farr_matmul (FMA-fused) vs hexa-scalar ref → RFC 040 fp-tol.
if lh_fwd < 0.000000000001 {
    println("PASS  F-RFC043-LAYER-EQ-LMHEAD-FWD    max|nn_lm_head_fwd − closed-ref| < 1e-12 (RFC 040 §2.2 fp-tol; matvec via farr_matmul(V·d · d·1))")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-LAYER-EQ-LMHEAD-FWD    max|Δ|="); print(lh_fwd); println(" (>1e-12)")
}
// BWD is pure hexa scalar loops both sides → byte-eq.
if lh_dtemb == 0.0 {
    if lh_dzT == 0.0 {
        println("PASS  F-RFC043-LAYER-EQ-LMHEAD-BWD    max|{dtemb_accum, dzT}_flame − {ref}_ref| = 0.0 (byte-eq · dl⊗zT + tembᵀ·dl closed)")
        pass = pass + 1
    } else {
        println("FAIL  F-RFC043-LAYER-EQ-LMHEAD-BWD    dzT deviation non-zero")
    }
} else {
    println("FAIL  F-RFC043-LAYER-EQ-LMHEAD-BWD    dtemb deviation non-zero")
}

println("")
print("=== flame Phase 2: ")
print(pass)
print("/")
print(total)
println(" PASS ===")

if pass == total {
    println("PASS — flame nn_lib Linear + RMSNorm + Embedding + LMHead (fwd+bwd) ≡ closed analytic ref; connection-point closed (g_blue_closed_mandate). Remaining Phase 2 layers (RoPE / GQA-attn / SwiGLU) follow.")
} else {
    println("FAIL — flame Phase 2 not landable")
}
