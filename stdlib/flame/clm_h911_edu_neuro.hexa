// ════════════════════════════════════════════════════════════════════════════
//  clm_h911_edu_neuro.hexa — CLM-KOSMOS H_911 EDU+NEU 20-hypothesis matrix
//
//  CONSTRUCT-VALID supersession of the bio line. Every hypothesis is measured on
//  the SHARED LEARNED cross-lingual embedding (clm_h911_shared_embed: real CLM,
//  full Adam backprop, mean-pooled learned hidden xt — NOT a fixed byte basis).
//
//  Four extractions are trained ONCE and reused by all 20 metrics (each metric is
//  a pure function of the extracted learned vectors):
//    LE_PL = parallel corpus, learned         (layout 0)
//    LE_CL = concat   corpus, learned         (layout 1)
//    LE_PN = parallel corpus, within-shuffle NULL
//    LE_CN = concat   corpus, within-shuffle NULL
//
//  Per hypothesis: per-concept effect[c] = metric(LE_PL,par) - metric(LE_CL,con)
//                  per-concept null[c]   = metric(LE_PN,par) - metric(LE_CN,con)
//  Paired bootstrap 95% CI (deterministic LCG, B=2000). se_report tiers:
//    🟢 iff LEARNED CI_lo>0 AND NULL CI_lo<=0 (effect is semantic, not order)
//    🔴 ARTIFACT-REJECTED iff LEARNED CI_lo>0 AND NULL CI_lo>0 (order artifact)
//    🔴 closed-negative iff LEARNED CI straddles/≤0
//  g63 honest: every tier recorded, no cherry-pick.
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/flame/clm_h911_shared_embed"

let EDU_EPOCHS = 16

// Compute per-concept effect + null for a metric mode, then report under id/name.
// mode: 0=within-XL 1=amodal 2=anchor 3=share/compress 4=transfer 5=phi 6=coherence
fn run_hyp(name: string, id: string, mode: int,
           LE_PL: int, LE_CL: int, LE_PN: int, LE_CN: int) {
    let eff = t_zeros(SE_NCONC)
    let nul = t_zeros(SE_NCONC)
    let mut c = 0
    while c < SE_NCONC {
        let pl = _metric(LE_PL, c, 0, mode)
        let cl = _metric(LE_CL, c, 1, mode)
        let pn = _metric(LE_PN, c, 0, mode)
        let cn = _metric(LE_CN, c, 1, mode)
        t_set(eff, c, pl - cl)
        t_set(nul, c, pn - cn)
        c = c + 1
    }
    print("=== "); print(name); print(" ("); print(id); println(") ===")
    se_report(name, id, eff, nul, SE_NCONC)
    println("")
}

fn _metric(LE: int, c: int, layout: int, mode: int) -> float {
    if mode == 0 { return se_within_concept_xl(LE, c, layout) }
    if mode == 1 { return se_amodal(LE, c, layout) }
    if mode == 2 { return se_anchor_align(LE, c, layout) }
    if mode == 3 { return se_share_compress(LE, c, layout) }
    if mode == 4 { return se_transfer(LE, c, layout) }
    if mode == 5 { return se_phi(LE, c, layout) }
    return se_coherence(LE, c, layout)
}

fn main() {
    println("clm_h911_EDU_NEURO — 20 hypotheses on the LEARNED cross-lingual embedding")
    println("(shared real-CLM backprop substrate · within-concept-shuffle NULL · paired bootstrap CI B=2000)")
    println("")
    let LE_PL = t_zeros(SE_NLINE * SE_D); let LE_CL = t_zeros(SE_NLINE * SE_D)
    let LE_PN = t_zeros(SE_NLINE * SE_D); let LE_CN = t_zeros(SE_NLINE * SE_D)
    let nPL = se_train_extract("stdlib/flame/testdata/clm_semantic_parallel.txt", EDU_EPOCHS, 0, LE_PL)
    let nCL = se_train_extract("stdlib/flame/testdata/clm_semantic_concat.txt",   EDU_EPOCHS, 0, LE_CL)
    let nPN = se_train_extract("stdlib/flame/testdata/clm_semantic_parallel.txt", EDU_EPOCHS, 1, LE_PN)
    let nCN = se_train_extract("stdlib/flame/testdata/clm_semantic_concat.txt",   EDU_EPOCHS, 1, LE_CN)
    print("extractions: nPL="); print(to_string(nPL)); print(" nCL="); print(to_string(nCL))
    print(" nPN="); print(to_string(nPN)); print(" nCN="); println(to_string(nCN))
    println("")

    // ── EDU (learning science) — each maps to a construct-valid learned-axis metric ──
    run_hyp("INTERLEAVE",  "F-CLM-H911-INTERLEAVE",  4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("SPACING",     "F-CLM-H911-SPACING",     4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("RETRIEVAL",   "F-CLM-H911-RETRIEVAL",   4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("DUALCODE",    "F-CLM-H911-DUALCODE",    1, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("IPLUS1",      "F-CLM-H911-IPLUS1",      0, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("DESDIFF",     "F-CLM-H911-DESDIFF",     1, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("TAP",         "F-CLM-H911-TAP",         4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("CHUNK",       "F-CLM-H911-CHUNK",       3, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("IMMERSION",   "F-CLM-H911-IMMERSION",   0, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("ELABORATE",   "F-CLM-H911-ELABORATE",   4, LE_PL, LE_CL, LE_PN, LE_CN)

    // ── NEU (neuroscience) ──
    run_hyp("ATLHUB",      "F-CLM-H911-ATLHUB",      1, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("GWT",         "F-CLM-H911-GWT",         5, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("REUSE",       "F-CLM-H911-REUSE",       3, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("PREDCODE",    "F-CLM-H911-PREDCODE",    4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("SYSCON",      "F-CLM-H911-SYSCON",      4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("L1L2OVERLAP", "F-CLM-H911-L1L2OVERLAP", 6, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("TRW",         "F-CLM-H911-TRW",         4, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("OSCILLATE",   "F-CLM-H911-OSCILLATE",   6, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("SEMCTRL",     "F-CLM-H911-SEMCTRL",     1, LE_PL, LE_CL, LE_PN, LE_CN)
    run_hyp("PHI",         "F-CLM-H911-PHI",         5, LE_PL, LE_CL, LE_PN, LE_CN)

    println("clm_h911_EDU_NEURO — matrix complete (20 hypotheses, g63 honest)")
}
