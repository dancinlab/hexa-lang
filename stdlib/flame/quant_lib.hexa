// ════════════════════════════════════════════════════════════════════════════
//  quant_lib.hexa — flame int4-sym[-7,+7] per-output-channel STE fake-quant.
//
//  Op 4/4 (final) of the CLM-ConvMoE flame port (FLAME.tape
//  n_clm_convmoe_port_gap · anima a_train_flame_forge · CLM/P6_SCALE_LADDER_7B
//  · P0 §9 QAT envelope). Quantization-aware-training fake-quant: forward
//  quantizes weights to the AKIDA int4 envelope, backward uses the
//  straight-through estimator (clipped).
//
//    weight layout : [Cout · rest]  (rest = Cin·K for conv, Cin for linear)
//    per-output-channel symmetric scale  s[co] = max_j|W[co,j]| / 7   (s>0;
//      all-zero channel -> s=1 sentinel). 15 levels: q ∈ {-7..+7}; -8 is
//      FORBIDDEN (AKIDA NSoC rejects -8 — P0 §9).
//    fwd:  q   = clamp(round(W/s), -7, +7)            (integer level)
//          Wq  = q · s                                (dequantized weight)
//    bwd (clipped STE):  dW = dY · 1[|round(W/s)| ≤ 7]   (pass-through inside
//          the representable range, 0 where clamped).
//
//  NOTE — NOT GRAD-EXACT: round() is piecewise-constant so the TRUE gradient
//  is 0 a.e.; STE is a deliberate surrogate (P0 §9). Verified instead by
//  RANGE · DEQUANT-ERR · ZERO · STE-MASK · PER-CHANNEL · DET (flame_quant_test).
//  lib-split. sibling: conv_lib · gn_lib · moe_lib · tensor_lib.
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"

fn _q_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// symmetric round-half-away-from-zero, returned as float (integer-valued).
fn _q_round(x: float) -> float {
    if x >= 0.0 { return to_float(to_int(x + 0.5)) }
    return 0.0 - to_float(to_int((0.0 - x) + 0.5))
}

// Forward fake-quant. Caller allocates wq_out [Cout·rest], scale_out [Cout],
// qlevel_out [Cout·rest] (integer levels as float), mask_out [Cout·rest]
// (clipped-STE mask: 1.0 in-range else 0.0).
pub fn nn_int4_quant_fwd(w: int, wq_out: int, scale_out: int,
                         qlevel_out: int, mask_out: int,
                         Cout: int, rest: int) {
    let mut co = 0
    while co < Cout {
        // per-channel max|W|
        let mut mx = 0.0
        let mut j = 0
        while j < rest {
            let a = _q_abs(t_get(w, co * rest + j))
            if a > mx { mx = a }
            j = j + 1
        }
        let s = if mx > 0.0 { mx / 7.0 } else { 1.0 }
        t_set(scale_out, co, s)
        let mut j2 = 0
        while j2 < rest {
            let idx = co * rest + j2
            let r = _q_round(t_get(w, idx) / s)
            // clamp to [-7, +7]; track whether clamped (mask)
            let mut q = r
            let mut inrange = 1.0
            if q > 7.0 { q = 7.0; inrange = 0.0 }
            if q < 0.0 - 7.0 { q = 0.0 - 7.0; inrange = 0.0 }
            t_set(qlevel_out, idx, q)
            t_set(mask_out, idx, inrange)
            t_set(wq_out, idx, q * s)
            j2 = j2 + 1
        }
        co = co + 1
    }
}

// Backward (clipped straight-through estimator). dW = dY · mask.
// Caller allocates dW_out [Cout·rest].
pub fn nn_int4_quant_bwd(dy: int, mask: int, dW_out: int, Cout: int, rest: int) {
    let mut i = 0
    while i < Cout * rest {
        t_set(dW_out, i, t_get(dy, i) * t_get(mask, i))
        i = i + 1
    }
}

// ── Packed int4 storage (real 8× weight-memory reduction vs fp32) ─────────
//
//  The fwd path above is FAKE-quant: it keeps W as fp32 and simulates int4
//  by quantize→dequantize, so a deployed model still pays fp32 storage. For
//  the AKIDA deployment envelope we PACK two int4 codes per byte → 4 bits per
//  weight = 8× smaller than fp32, 2× smaller than int8.
//
//  Code mapping (REUSES the existing quantize math so byte-identity holds):
//    signed level  q ∈ {-7..+7}  (same _q_round + clamp as nn_int4_quant_fwd)
//    nibble code   c = q + zero   with zero = 7   → c ∈ {0..14}  (15 forbidden,
//                  mirrors -8 being forbidden by AKIDA; never emitted here).
//  Packing: byte b = packed[i/2]; low nibble = even index, high nibble = odd.
//    dequant(unpack(pack(W))) == q · scale == nn_int4_quant_fwd's Wq EXACTLY
//    (pure storage transform — H_877 inference byte-identity).
//
//  `scale`/`zero` are scalars chosen by the caller; reuse the per-channel
//  scale from nn_int4_quant_fwd (s = max|W|/7) and zero = 7 to match fwd.

// quantize one fp32 weight to its 4-bit nibble code c ∈ {0..14}.
fn _q_code(w: float, scale: float, zero: int) -> int {
    let r = _q_round(w / scale)
    let mut q = to_int(r)
    if q > 7 { q = 7 }
    if q < 0 - 7 { q = 0 - 7 }
    return q + zero
}

// Pack n fp32 weights into ceil(n/2) bytes (2× int4 codes per byte).
// Caller allocates packed_out with at least (n + 1) / 2 slots (one byte each,
// stored as float-valued integers in the farr — same storage idiom as qlevel).
pub fn nn_int4_pack(w: int, packed_out: int, n: int, scale: float, zero: int) {
    let mut i = 0
    while i < n {
        let lo = _q_code(t_get(w, i), scale, zero)
        let mut byte = lo
        if i + 1 < n {
            let hi = _q_code(t_get(w, i + 1), scale, zero)
            byte = byte | (hi << 4)
        }
        t_set(packed_out, i / 2, to_float(byte))
        i = i + 2
    }
}

// Unpack n int4 codes from ceil(n/2) bytes → fp32 (dequantize). Reproduces
// the EXACT fp32 value nn_int4_quant_fwd's Wq holds (q · scale).
// Caller allocates w_fp32_out [n].
pub fn nn_int4_unpack(packed: int, w_fp32_out: int, n: int, scale: float, zero: int) {
    let mut i = 0
    while i < n {
        let byte = to_int(t_get(packed, i / 2))
        let mut code = byte & 15
        if (i & 1) == 1 { code = (byte >> 4) & 15 }
        let q = code - zero
        t_set(w_fp32_out, i, to_float(q) * scale)
        i = i + 1
    }
}
