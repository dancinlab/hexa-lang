// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/nn_lib.hexa — flame Phase 2-A (RFC 043)
//
// nn layers — Linear + RMSNorm (Phase 2-A; the simplest two layers
// with closed-form analytic vjp). Continuation in Phase 2-B: RoPE,
// GQA-attention, SwiGLU, embedding, tied LM head.
//
// Layer style: functional (RFC 040 Phase E / c3_*-style). Each fwd
// returns its outputs; each bwd takes upstream `dy` + saved fwd state
// and returns the closed-form ∂loss/∂{x, params}. This mirrors anima
// HEXAD/D/d_train3_lib.hexa (c3_matvec / c3_rmsnorm_fwd /
// c3_rmsnorm_bwd) — flame inherits the SAME closed algebra and
// preserves byte-equality (or RFC-040 measured fp-tol where a
// reduction differs).
//
// Verified reference (cross-repo, anima d_train3_lib.hexa):
//   c3_matvec(M, v, rows, cols) — linear fwd (single row)
//   c3_matvec_t(M, u, rows, cols) — transpose-matvec (input/W vjp)
//   c3_outer(u, v, R, C) — outer product (W-grad accumulator)
//   c3_rmsnorm_fwd(x, g, d) — RMSNorm fwd, returns [y, xn, inv]
//   c3_rmsnorm_bwd(x, g, xn, inv, dy, d) — RMSNorm bwd (closed vjp)
//
// Compiled-native — emit path:
//   - host CPU farr_matmul (RFC 032; codegen_c2 explicit-wired) is the
//     core 3-loop reduction; nn_linear_fwd/bwd compose it.
//   - hand loops over farr_get / farr_set for bias add and RMSNorm
//     scalar arithmetic — independent reference.
//   - Phase B2 farr_*_gpu ops accessible via generic hexa_callN —
//     C symbols defined in self/runtime.c (4-5 sites each, #ifdef
//     HEXA_CUDA branches), so substrate routing is available without
//     codegen edits. flame Phase 2-A uses host CPU (no _gpu) for the
//     correctness oracle; device routing = Phase 4.
//
// API stays fixed per g_flame_api_fixed — Phase 2-B/C add layer
// wrappers without changing existing signatures.
// ════════════════════════════════════════════════════════════════════════

// ── helpers (private) ──────────────────────────────────────────────────
fn _nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _nn_sqrt(x: float) -> float {
    // libm sqrt — exact double. c3_rmsnorm_fwd uses dt_sqrt (24-iter
    // Newton); for Phase 2-A in-flame correctness we use the SAME path
    // in BOTH wrapper and in-flame reference, so the closed-vjp identity
    // F-RFC043-LAYER-EQ-RMSNORM-* checks |Δ|=0.0 byte-equal (no cross-
    // implementation gap; the dt_sqrt comparison is Phase B2's job and
    // already 9/9 PASS for the AdamW op on this branch).
    return sqrt(x)
}

// ─── Linear layer ──────────────────────────────────────────────────────
// y = x · W + b ; shapes: x [B·D], W [D·C], b [C] → y [B·C].
// Forward (host CPU): farr_matmul + per-row bias broadcast.
// farr_matmul signature = (A_id, M=rows(A), K=cols(A), B_id, N=cols(B))
// so for y = x[B·D]·W[D·C] we call farr_matmul(x, B, D, W, C).
pub fn nn_linear_fwd(x: int, W: int, b: int, B: int, D: int, C: int) -> int {
    let y = farr_matmul(x, B, D, W, C)
    // bias broadcast: y[i,j] += b[j], same reduction order as c3_matvec
    // batched loop (no fp-non-assoc surprise — the bias is added in a
    // single pass, identical to a c3_matvec + scalar add).
    let mut i = 0
    while i < B {
        let mut j = 0
        while j < C {
            let cur = farr_get(y, i * C + j)
            let bj = farr_get(b, j)
            let _ = farr_set(y, i * C + j, cur + bj)
            j = j + 1
        }
        i = i + 1
    }
    return y
}

// Linear backward — closed vjp:
//   dW = xᵀ · dy        (shape [D·C], reduces over B)
//   dx = dy · Wᵀ        (shape [B·D], reduces over C)
//   db[j] = Σ_i dy[i,j] (shape [C])
// Caller-allocated outputs (dW, dx, db) — writes in place.
//   shapes: x [B·D], W [D·C], dy [B·C]; out dW [D·C], dx [B·D], db [C].
pub fn nn_linear_bwd(x: int, W: int, dy: int,
                     dW_out: int, dx_out: int, db_out: int,
                     B: int, D: int, C: int) {
    // dW = xᵀ · dy : same reduction order as c3_outer accumulated over B
    // rows — for each (d, c) sum_b x[b,d] * dy[b,c].
    let mut d = 0
    while d < D {
        let mut c = 0
        while c < C {
            let mut acc = 0.0
            let mut bi = 0
            while bi < B {
                acc = acc + farr_get(x, bi * D + d) * farr_get(dy, bi * C + c)
                bi = bi + 1
            }
            let _ = farr_set(dW_out, d * C + c, acc)
            c = c + 1
        }
        d = d + 1
    }
    // dx = dy · Wᵀ : for each (b, d) sum_c dy[b,c] * W[d,c]
    let mut bi2 = 0
    while bi2 < B {
        let mut d2 = 0
        while d2 < D {
            let mut acc2 = 0.0
            let mut c2 = 0
            while c2 < C {
                acc2 = acc2 + farr_get(dy, bi2 * C + c2) * farr_get(W, d2 * C + c2)
                c2 = c2 + 1
            }
            let _ = farr_set(dx_out, bi2 * D + d2, acc2)
            d2 = d2 + 1
        }
        bi2 = bi2 + 1
    }
    // db[j] = Σ_i dy[i,j]
    let mut j = 0
    while j < C {
        let mut acc3 = 0.0
        let mut i3 = 0
        while i3 < B {
            acc3 = acc3 + farr_get(dy, i3 * C + j)
            i3 = i3 + 1
        }
        let _ = farr_set(db_out, j, acc3)
        j = j + 1
    }
}

// ─── RMSNorm layer ─────────────────────────────────────────────────────
// y_i = g_i · (x_i / sqrt(mean(x²) + eps)) ; shape: x [d], g [d] → y [d].
// Returns [y_id, xn_id, inv_packed_id] where inv_packed_id is a 1-elt
// farr holding `inv` (so bwd can read it back).
//   c3_rmsnorm_fwd identity: returns [y, xn, inv]; flame stores xn in a
//   d-len farr and inv in a 1-len farr.
//   Caller allocates y_out (d-len), xn_out (d-len), inv_out (1-len).
pub fn nn_rmsnorm_fwd(x: int, g: int,
                      y_out: int, xn_out: int, inv_out: int,
                      d: int) {
    let eps = 0.000001
    let mut ms = 0.0
    let mut i = 0
    while i < d {
        let xi = farr_get(x, i)
        ms = ms + xi * xi
        i = i + 1
    }
    ms = ms / to_float(d)
    let inv = 1.0 / _nn_sqrt(ms + eps)
    let _ = farr_set(inv_out, 0, inv)
    let mut j = 0
    while j < d {
        let xni = farr_get(x, j) * inv
        let _ = farr_set(xn_out, j, xni)
        let _ = farr_set(y_out, j, farr_get(g, j) * xni)
        j = j + 1
    }
}

// ─── Attention core (GQA, causal, multi-head; new math only) ──────────
// Reference: anima d_train5_lib.hexa d5_attn_fwd / d5_attn_bwd
// (attention-core sections only — the Q/K/V/output projections are
// composed externally by the caller using nn_linear_fwd + RoPE, the
// same pattern d5_attn_fwd uses internally).
//
// flame's attention-core takes the ALREADY-PROJECTED + ALREADY-ROPED
// Q/K (and V untouched), shapes:
//   Q : [T · nh · hd]   query, RoPE-rotated, per-head
//   K : [T · nkv · hd]  key,   RoPE-rotated, per-kv-head (GQA grouped)
//   V : [T · nkv · hd]  value, no RoPE, per-kv-head
// and produces:
//   P   : [nh · T · T]   per-head per-query softmax weights (causal: j≤i)
//   ctx : [T · d]        context output, d = nh·hd; head hh at offset
//                        ctx[i*d + hh*hd + c]
// scale = 1/sqrt(hd) baked into scores.  GQA grouping: kvh = hh / n_rep
// where n_rep = nh / nkv.

fn _nn_softmax_row(s: int, p_out: int, base: int, L: int) {
    // s : input scores farr (L-len); p_out : output farr; base : offset
    // in p_out to write to. Numerically-stable: subtract max.
    // Uses farr_get/farr_set with explicit indexing (no separate temp farr).
    let mut m = farr_get(s, 0)
    let mut i = 1
    while i < L {
        if farr_get(s, i) > m { m = farr_get(s, i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < L {
        let e = exp(farr_get(s, i2) - m)
        // stash e into p_out[base + i2] (we'll renormalize in pass 2).
        let _ = farr_set(p_out, base + i2, e)
        tot = tot + e
        i2 = i2 + 1
    }
    let mut i3 = 0
    while i3 < L {
        let cur = farr_get(p_out, base + i3)
        let _ = farr_set(p_out, base + i3, cur / tot)
        i3 = i3 + 1
    }
}

// Forward attention core. Caller pre-allocates P_out (nh·T·T) and
// ctx_out (T·d) with zeros (we WRITE the causal-mask region; positions
// beyond L=i+1 remain zero by caller's pre-fill).
pub fn nn_attn_core_fwd(Q: int, K: int, V: int,
                        P_out: int, ctx_out: int,
                        T: int, nh: int, nkv: int, hd: int) {
    let n_rep = nh / nkv
    let d = nh * hd
    let scale = 1.0 / sqrt(to_float(hd))
    // scores scratch — L can be up to T; allocate once at max.
    let srow = farr_zeros(T)
    let mut hh = 0
    while hh < nh {
        let kvh = hh / n_rep
        let mut i = 0
        while i < T {
            let L = i + 1
            // scores[j] = Σ_c Q[(i*nh + hh)*hd + c] · K[(j*nkv + kvh)*hd + c] · scale
            let mut j = 0
            while j < L {
                let mut dot = 0.0
                let mut c = 0
                while c < hd {
                    dot = dot + farr_get(Q, (i * nh + hh) * hd + c)
                              * farr_get(K, (j * nkv + kvh) * hd + c)
                    c = c + 1
                }
                let _ = farr_set(srow, j, dot * scale)
                j = j + 1
            }
            // softmax_row over srow[0..L] → P[(hh*T + i)*T + 0..L]
            _nn_softmax_row(srow, P_out, (hh * T + i) * T, L)
            // ctx[i*d + hh*hd + c] = Σ_j P[(hh*T+i)*T+j] · V[(j*nkv+kvh)*hd + c]
            let mut c2 = 0
            while c2 < hd {
                let mut acc = 0.0
                let mut jj = 0
                while jj < L {
                    acc = acc + farr_get(P_out, (hh * T + i) * T + jj)
                              * farr_get(V, (jj * nkv + kvh) * hd + c2)
                    jj = jj + 1
                }
                let _ = farr_set(ctx_out, i * d + hh * hd + c2, acc)
                c2 = c2 + 1
            }
            i = i + 1
        }
        hh = hh + 1
    }
    let _ = farr_free(srow)
}

// Backward attention core. Closed analytic vjp (d5_attn_bwd §"attention
// core"):
//   given dctx [T·d] → dQ, dK, dV (rotated-space grads, caller-zeroed)
//   dP[i,j] = Σ_c dctx[i, hh, c] · V[j, kvh, c]
//   sdot[i] = Σ_j P[i,j] · dP[i,j]            (softmax Jacobian helper)
//   dV[j, kvh, c] += Σ_i P[i,j] · dctx[i, hh, c]     (accumulate over heads)
//   dS[i,j] = P[i,j] · (dP[i,j] − sdot[i]) · scale
//   dQ[i, hh, c] += Σ_j dS[i,j] · K[j, kvh, c]
//   dK[j, kvh, c] += Σ_i dS[i,j] · Q[i, hh, c]      (accumulate over heads)
// dQ_out / dK_out / dV_out are ACCUMULATED INTO (caller pre-zeros).
pub fn nn_attn_core_bwd(Q: int, K: int, V: int, P: int, dctx: int,
                        dQ_out: int, dK_out: int, dV_out: int,
                        T: int, nh: int, nkv: int, hd: int) {
    let n_rep = nh / nkv
    let d = nh * hd
    let scale = 1.0 / sqrt(to_float(hd))
    let dP_row = farr_zeros(T)
    let mut hh = 0
    while hh < nh {
        let kvh = hh / n_rep
        let mut i = 0
        while i < T {
            let L = i + 1
            // dP[j] = Σ_c dctx[i*d + hh*hd + c] · V[(j*nkv + kvh)*hd + c]
            let mut j = 0
            while j < L {
                let mut acc = 0.0
                let mut c = 0
                while c < hd {
                    acc = acc + farr_get(dctx, i * d + hh * hd + c)
                              * farr_get(V, (j * nkv + kvh) * hd + c)
                    c = c + 1
                }
                let _ = farr_set(dP_row, j, acc)
                j = j + 1
            }
            // sdot = Σ_j P[i,j] · dP[j]
            let mut sdot = 0.0
            let mut j2 = 0
            while j2 < L {
                sdot = sdot + farr_get(P, (hh * T + i) * T + j2)
                            * farr_get(dP_row, j2)
                j2 = j2 + 1
            }
            // dV[j, kvh, c] += P[i,j] · dctx[i, hh, c]
            let mut j3 = 0
            while j3 < L {
                let pij = farr_get(P, (hh * T + i) * T + j3)
                let mut c = 0
                while c < hd {
                    let dv_idx = (j3 * nkv + kvh) * hd + c
                    let cur = farr_get(dV_out, dv_idx)
                    let _ = farr_set(dV_out, dv_idx,
                                     cur + pij * farr_get(dctx, i * d + hh * hd + c))
                    c = c + 1
                }
                j3 = j3 + 1
            }
            // dS[i,j] = P[i,j] · (dP[j] − sdot) · scale
            // dQ[i,hh,c] += Σ_j dS · K[j,kvh,c]
            // dK[j,kvh,c] += dS · Q[i,hh,c]
            let mut j4 = 0
            while j4 < L {
                let dS = farr_get(P, (hh * T + i) * T + j4)
                       * (farr_get(dP_row, j4) - sdot) * scale
                let mut c2 = 0
                while c2 < hd {
                    let dq_idx = (i * nh + hh) * hd + c2
                    let dk_idx = (j4 * nkv + kvh) * hd + c2
                    let cur_q = farr_get(dQ_out, dq_idx)
                    let _ = farr_set(dQ_out, dq_idx,
                                     cur_q + dS * farr_get(K, (j4 * nkv + kvh) * hd + c2))
                    let cur_k = farr_get(dK_out, dk_idx)
                    let _ = farr_set(dK_out, dk_idx,
                                     cur_k + dS * farr_get(Q, (i * nh + hh) * hd + c2))
                    c2 = c2 + 1
                }
                j4 = j4 + 1
            }
            i = i + 1
        }
        hh = hh + 1
    }
    let _ = farr_free(dP_row)
}

// ─── SwiGLU (gated SiLU MLP block) ─────────────────────────────────────
// Reference: anima d_train3_lib.hexa c3_swiglu_fwd / c3_swiglu_bwd.
//   r:[d], Wg:[h·d], Wu:[h·d], Wd:[d·h]  →  o:[d]
//   forward: a = Wg·r ; b = Wu·r ; s[k] = silu(a[k])·b[k] ; o = Wd·s
//   backward (closed): given dout[d] →
//     dWd = dout ⊗ s  (d×h outer)
//     ds  = Wdᵀ·dout  (h-len, reduction over d)
//     da[k] = ds[k]·b[k]·silu'(a[k])
//     db[k] = ds[k]·silu(a[k])
//     dWg = da ⊗ r ; dWu = db ⊗ r ; dr = Wgᵀ·da + Wuᵀ·db

fn _nn_sigmoid(x: float) -> float {
    return 1.0 / (1.0 + exp(0.0 - x))
}
fn _nn_silu(x: float) -> float {
    return x * _nn_sigmoid(x)
}
fn _nn_silu_grad(x: float) -> float {
    let s = _nn_sigmoid(x)
    return s + x * s * (1.0 - s)
}

// Forward — caller allocates a_out/b_out/s_out (h-len each), o_out (d-len).
pub fn nn_swiglu_fwd(r: int, Wg: int, Wu: int, Wd: int,
                     a_out: int, b_out: int, s_out: int, o_out: int,
                     d: int, h: int) {
    // a = Wg · r : [h·d] · [d·1] → [h·1]
    let a_prod = farr_matmul(Wg, h, d, r, 1)
    let b_prod = farr_matmul(Wu, h, d, r, 1)
    let mut k = 0
    while k < h {
        let ak = farr_get(a_prod, k)
        let bk = farr_get(b_prod, k)
        let _ = farr_set(a_out, k, ak)
        let _ = farr_set(b_out, k, bk)
        let _ = farr_set(s_out, k, _nn_silu(ak) * bk)
        k = k + 1
    }
    let _ = farr_free(a_prod)
    let _ = farr_free(b_prod)
    // o = Wd · s : [d·h] · [h·1] → [d·1]
    let o_prod = farr_matmul(Wd, d, h, s_out, 1)
    let mut j = 0
    while j < d {
        let _ = farr_set(o_out, j, farr_get(o_prod, j))
        j = j + 1
    }
    let _ = farr_free(o_prod)
}

// Backward — caller allocates dr_out (d-len), dWg_out/dWu_out (h·d each),
// dWd_out (d·h). Outputs are OVERWRITTEN (no accumulation; if the caller
// wants accumulation the existing buffer copy happens outside).
pub fn nn_swiglu_bwd(r: int, Wg: int, Wu: int, Wd: int,
                     a: int, b: int, s: int, dout: int,
                     dr_out: int, dWg_out: int, dWu_out: int, dWd_out: int,
                     d: int, h: int) {
    // dWd[i, k] = dout[i] · s[k]   (d×h outer)
    let mut di = 0
    while di < d {
        let do_i = farr_get(dout, di)
        let mut hi = 0
        while hi < h {
            let _ = farr_set(dWd_out, di * h + hi, do_i * farr_get(s, hi))
            hi = hi + 1
        }
        di = di + 1
    }
    // ds[k] = Σ_i Wd[i·h + k] · dout[i]   (h-len, reduction over d)
    let ds = farr_zeros(h)
    let mut k = 0
    while k < h {
        let mut acc = 0.0
        let mut i = 0
        while i < d {
            acc = acc + farr_get(Wd, i * h + k) * farr_get(dout, i)
            i = i + 1
        }
        let _ = farr_set(ds, k, acc)
        k = k + 1
    }
    // da[k] = ds[k]·b[k]·silu'(a[k]) ;  db[k] = ds[k]·silu(a[k])
    let da = farr_zeros(h)
    let db = farr_zeros(h)
    let mut k2 = 0
    while k2 < h {
        let ak = farr_get(a, k2)
        let dsk = farr_get(ds, k2)
        let _ = farr_set(da, k2, dsk * farr_get(b, k2) * _nn_silu_grad(ak))
        let _ = farr_set(db, k2, dsk * _nn_silu(ak))
        k2 = k2 + 1
    }
    // dWg[h, d] = da ⊗ r   ;  dWu = db ⊗ r
    let mut hi3 = 0
    while hi3 < h {
        let da_h = farr_get(da, hi3)
        let db_h = farr_get(db, hi3)
        let mut di3 = 0
        while di3 < d {
            let rj = farr_get(r, di3)
            let _ = farr_set(dWg_out, hi3 * d + di3, da_h * rj)
            let _ = farr_set(dWu_out, hi3 * d + di3, db_h * rj)
            di3 = di3 + 1
        }
        hi3 = hi3 + 1
    }
    // dr[j] = Σ_k Wg[k·d + j]·da[k] + Wu[k·d + j]·db[k]
    let mut di5 = 0
    while di5 < d {
        let mut acc2 = 0.0
        let mut hi5 = 0
        while hi5 < h {
            acc2 = acc2
                + farr_get(Wg, hi5 * d + di5) * farr_get(da, hi5)
                + farr_get(Wu, hi5 * d + di5) * farr_get(db, hi5)
            hi5 = hi5 + 1
        }
        let _ = farr_set(dr_out, di5, acc2)
        di5 = di5 + 1
    }
    let _ = farr_free(ds)
    let _ = farr_free(da)
    let _ = farr_free(db)
}

// ─── RoPE (rotary position embedding) ──────────────────────────────────
// Reference: anima d_train5_lib.hexa d5_rope_tables / d5_rope_apply /
// d5_rope_bwd / d5_rotate_half / d5_rotate_half_t (RoFormer convention).
//   cos/sin tables [T·hd]: cos[p·hd + c] = cos(p · invf[c mod half])
//     invf[i] = base^(-2i/hd), base=10000, half=hd/2
//   forward (one head): q'[c] = q[c]·cos[p·hd+c] + rh(q)[c]·sin[p·hd+c]
//     rh : [x1, x2] (each half-len) → [-x2, x1]
//   backward (orthogonal — closed): dq[c] = dq'[c]·cos[p·hd+c]
//     + rh_T(dq'·sin_p)[c]   ; rh_T : [a1, a2] → [a2, -a1]   (Rᵀ = R(−θ))
//
// flame uses builtin sin/cos for tables (vs anima's d5_sin/cos 14-Taylor)
// — selftest both sides use the SAME path, so byte-equality holds.
// Comparison against anima d5_rope_tables would diverge in last ulps
// (d5_sin Taylor vs libm sin); cross-impl gap is documented but not
// flame's concern at this layer.

// Build cos/sin RoPE tables (caller-allocated [T·hd] each).
pub fn nn_rope_build_tables(T: int, hd: int,
                            cos_out: int, sin_out: int) {
    let half = hd / 2
    let base = 10000.0
    let lnb = ln(base)
    // invf[i] = exp(-(2i/hd)·ln(base))   for i in [0, half)
    // We compute inline (avoid allocating an extra farr).
    let mut p = 0
    while p < T {
        let mut c = 0
        while c < hd {
            let fi = if c < half { c } else { c - half }
            let ex = (to_float(2 * fi) / to_float(hd)) * lnb
            let invf = 1.0 / exp(ex)
            let ang = to_float(p) * invf
            let _ = farr_set(cos_out, p * hd + c, cos(ang))
            let _ = farr_set(sin_out, p * hd + c, sin(ang))
            c = c + 1
        }
        p = p + 1
    }
}

// RoPE forward (single head, single position):
//   q_out[c] = q[c]·cos[p·hd+c] + rh(q)[c]·sin[p·hd+c]
//   rh(q): first half = -q[half..hd], second half = q[0..half]
pub fn nn_rope_apply_fwd(q: int, cos_tab: int, sin_tab: int,
                         q_out: int, p: int, hd: int) {
    let half = hd / 2
    let bse = p * hd
    let mut c = 0
    while c < hd {
        // rh(q)[c] = if c < half: -q[half+c] ; else: q[c-half]
        let rh_c = if c < half {
            0.0 - farr_get(q, half + c)
        } else {
            farr_get(q, c - half)
        }
        let q_out_c = farr_get(q, c) * farr_get(cos_tab, bse + c)
                    + rh_c * farr_get(sin_tab, bse + c)
        let _ = farr_set(q_out, c, q_out_c)
        c = c + 1
    }
}

// RoPE backward (closed orthogonal vjp):
//   dq[c] = dq'[c]·cos[p·hd+c] + rh_T(dq'·sin_p)[c]
//   rh_T(v): first half = v[half..hd], second half = -v[0..half]
//   (i.e. Rᵀ = R(−θ); orthogonal rotation, no tape needed.)
pub fn nn_rope_apply_bwd(dqp: int, cos_tab: int, sin_tab: int,
                         dq_out: int, p: int, hd: int) {
    let half = hd / 2
    let bse = p * hd
    let mut c = 0
    while c < hd {
        // gs[c] = dqp[c]·sin[bse+c]
        // rh_T(gs)[c] = if c < half: gs[half+c] ; else: -gs[c-half]
        let gs_for_rht = if c < half {
            farr_get(dqp, half + c) * farr_get(sin_tab, bse + half + c)
        } else {
            0.0 - farr_get(dqp, c - half) * farr_get(sin_tab, bse + c - half)
        }
        let dq_c = farr_get(dqp, c) * farr_get(cos_tab, bse + c) + gs_for_rht
        let _ = farr_set(dq_out, c, dq_c)
        c = c + 1
    }
}

// ─── Embedding (tied with LM head) ─────────────────────────────────────
// table : [V·d] (one row per vocab id); ids : [T] (token indices,
// stored as floats in farr).
// Forward — for each position i, copy table[ids[i]·d : ids[i]·d + d]
// into X_out[i·d : i·d + d]. Mirrors anima d5_forward §"tok_emb embed
// lookup" (HEXAD/D/d_train5_lib.hexa).
pub fn nn_embedding_fwd(ids: int, table: int, X_out: int, T: int, d: int) {
    let mut i = 0
    while i < T {
        let tok = to_int(farr_get(ids, i))
        let mut c = 0
        while c < d {
            let _ = farr_set(X_out, i * d + c, farr_get(table, tok * d + c))
            c = c + 1
        }
        i = i + 1
    }
}

// Backward — scatter-add dX[i·d + c] → dtable[ids[i]·d + c] (accumulate
// in place). Mirrors d5_grad §"(b) embedding scatter-add". `dtable` is
// caller-pre-zeroed (or already holds the tied-head outer-product term
// from nn_lm_head_bwd).
pub fn nn_embedding_bwd_scatter(dX: int, ids: int, dtable_inout: int,
                                T: int, d: int) {
    let mut i = 0
    while i < T {
        let tok = to_int(farr_get(ids, i))
        let mut c = 0
        while c < d {
            let cur = farr_get(dtable_inout, tok * d + c)
            let _ = farr_set(dtable_inout, tok * d + c, cur + farr_get(dX, i * d + c))
            c = c + 1
        }
        i = i + 1
    }
}

// ─── Tied LM head ──────────────────────────────────────────────────────
// Forward — logits[k] = Σ_j temb[k·d + j] · zT[j]   (k = 0..V-1).
// Matvec / GEMV: temb [V·d] · zT [d] → logits [V]. We reuse farr_matmul
// with A=temb, M=V, K=d, B=zT (treated as [d·1]), N=1.  Identical to
// d5_matvec_g / GPU-routed path on no-CUDA build.
pub fn nn_lm_head_fwd(temb: int, zT: int, logits_out: int, V: int, d: int) {
    let prod = farr_matmul(temb, V, d, zT, 1)
    // copy prod (V-len) into logits_out (caller-allocated).
    let mut k = 0
    while k < V {
        let _ = farr_set(logits_out, k, farr_get(prod, k))
        k = k + 1
    }
    let _ = farr_free(prod)
}

// Backward — tied LM head:
//   dtemb[k, j] = dl[k] · zT[j]            (outer product, V·d)
//   dzT[j]      = Σ_k temb[k·d + j] · dl[k] (transpose-matvec, d-len)
// Caller controls whether dtemb_out is zero-init or already accumulates
// the embedding-scatter-add term (tied-weight; the d5_grad pattern).
//   We ACCUMULATE dtemb_out += dl ⊗ zT (so caller can pre-set or
//   subsequently add the scatter term).
//   dzT_out is overwritten (it has no other contributor).
pub fn nn_lm_head_bwd(temb: int, zT: int, dl: int,
                      dtemb_out: int, dzT_out: int, V: int, d: int) {
    // accumulate dtemb += dl ⊗ zT
    let mut k = 0
    while k < V {
        let dlk = farr_get(dl, k)
        let mut j = 0
        while j < d {
            let cur = farr_get(dtemb_out, k * d + j)
            let _ = farr_set(dtemb_out, k * d + j, cur + dlk * farr_get(zT, j))
            j = j + 1
        }
        k = k + 1
    }
    // dzT = tembᵀ · dl  ; loop order matches d5_matvec_t_g (rows=V, cols=d).
    let mut j2 = 0
    while j2 < d {
        let mut acc = 0.0
        let mut k2 = 0
        while k2 < V {
            acc = acc + farr_get(temb, k2 * d + j2) * farr_get(dl, k2)
            k2 = k2 + 1
        }
        let _ = farr_set(dzT_out, j2, acc)
        j2 = j2 + 1
    }
}

// RMSNorm backward — closed vjp (c3_rmsnorm_bwd identity):
//   dxn_i = dy_i · g_i
//   dg_i  = dy_i · xn_i
//   dot   = Σ_k dxn_k · x_k
//   dx_i  = inv · dxn_i − (inv³ · x_i / d) · dot
// Caller allocates dx_out, dg_out (d-len each).
pub fn nn_rmsnorm_bwd(x: int, g: int, xn: int, inv: float, dy: int,
                      dx_out: int, dg_out: int, d: int) {
    // pass 1: dxn (held implicit in dx_out as scratch; we overwrite below)
    // for clarity we compute dxn into a stack-free pattern by recomputing.
    let mut dot = 0.0
    let mut i = 0
    while i < d {
        let dxn_i = farr_get(dy, i) * farr_get(g, i)
        let _ = farr_set(dg_out, i, farr_get(dy, i) * farr_get(xn, i))
        dot = dot + dxn_i * farr_get(x, i)
        // stash dxn_i into dx_out temporarily — we finish the formula in
        // pass 2 (overwrites the stash with the final dx).
        let _ = farr_set(dx_out, i, dxn_i)
        i = i + 1
    }
    let inv3 = inv * inv * inv
    let scale = (inv3 / to_float(d)) * dot
    let mut j = 0
    while j < d {
        let dxn_j = farr_get(dx_out, j)
        let xj = farr_get(x, j)
        let _ = farr_set(dx_out, j, inv * dxn_j - scale * xj)
        j = j + 1
    }
}
