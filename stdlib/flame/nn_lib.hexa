// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/nn_lib.hexa — flame Phase 2-A (RFC 043)
//
// nn layers — Linear + RMSNorm (Phase 2-A; the simplest two layers
// with closed-form analytic vjp). Continuation in Phase 2-B: RoPE,
// GQA-attention, SwiGLU, embedding, tied LM head.
//
// Layer style: functional (RFC 040 Phase E / c3_*-style). Each fwd
// returns its outputs; each bwd takes upstream `dy` + saved fwd state
// and returns the closed-form ∂loss/∂{x, params}. This mirrors anima
// HEXAD/D/d_train3_lib.hexa (c3_matvec / c3_rmsnorm_fwd /
// c3_rmsnorm_bwd) — flame inherits the SAME closed algebra and
// preserves byte-equality (or RFC-040 measured fp-tol where a
// reduction differs).
//
// Verified reference (cross-repo, anima d_train3_lib.hexa):
//   c3_matvec(M, v, rows, cols) — linear fwd (single row)
//   c3_matvec_t(M, u, rows, cols) — transpose-matvec (input/W vjp)
//   c3_outer(u, v, R, C) — outer product (W-grad accumulator)
//   c3_rmsnorm_fwd(x, g, d) — RMSNorm fwd, returns [y, xn, inv]
//   c3_rmsnorm_bwd(x, g, xn, inv, dy, d) — RMSNorm bwd (closed vjp)
//
// Compiled-native — emit path:
//   - host CPU farr_matmul (RFC 032; codegen_c2 explicit-wired) is the
//     core 3-loop reduction; nn_linear_fwd/bwd compose it.
//   - hand loops over farr_get / farr_set for bias add and RMSNorm
//     scalar arithmetic — independent reference.
//   - Phase B2 farr_*_gpu ops accessible via generic hexa_callN —
//     C symbols defined in self/runtime.c (4-5 sites each, #ifdef
//     HEXA_CUDA branches), so substrate routing is available without
//     codegen edits. flame Phase 2-A uses host CPU (no _gpu) for the
//     correctness oracle; device routing = Phase 4.
//
// API stays fixed per g_flame_api_fixed — Phase 2-B/C add layer
// wrappers without changing existing signatures.
// ════════════════════════════════════════════════════════════════════════

// Phase 3-G (2026-05-17): import flame_math for d5_sin / d5_cos
// (strict bit-eq to anima d5_rope_tables 14-term Taylor path).
use "stdlib/flame/flame_math"

// ── helpers (private) ──────────────────────────────────────────────────
fn _nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _nn_sqrt(x: float) -> float {
    // libm sqrt — exact double. c3_rmsnorm_fwd uses dt_sqrt (24-iter
    // Newton); for Phase 2-A in-flame correctness we use the SAME path
    // in BOTH wrapper and in-flame reference, so the closed-vjp identity
    // F-RFC043-LAYER-EQ-RMSNORM-* checks |Δ|=0.0 byte-equal (no cross-
    // implementation gap; the dt_sqrt comparison is Phase B2's job and
    // already 9/9 PASS for the AdamW op on this branch).
    return sqrt(x)
}

// ─── Linear layer ──────────────────────────────────────────────────────
// y = x · W + b ; shapes: x [B·D], W [D·C], b [C] → y [B·C].
// Forward: RFC 050 dispatcher-routed matmul + per-row bias broadcast.
// forge_dispatch_matmul signature mirrors farr_matmul exactly —
// (A_id, M=rows(A), K=cols(A), B_id, N=cols(B)) — and routes through
// forge_tier_dispatch_v1. Its FP64 path bottoms out at the same
// hexa_farr_matmul kernel, so output is byte-equal to the direct call
// (F-RFC050-L1-DISPATCH-EQ); the dispatcher adds the precision-routing
// layer that future BF16 specialization (RFC 050 Stage 2) hooks into.
pub fn nn_linear_fwd(x: int, W: int, b: int, B: int, D: int, C: int) -> int {
    let y = forge_dispatch_matmul(x, B, D, W, C)
    // bias broadcast: y[i,j] += b[j], same reduction order as c3_matvec
    // batched loop (no fp-non-assoc surprise — the bias is added in a
    // single pass, identical to a c3_matvec + scalar add).
    let mut i = 0
    while i < B {
        let mut j = 0
        while j < C {
            let cur = farr_get(y, i * C + j)
            let bj = farr_get(b, j)
            let _ = farr_set(y, i * C + j, cur + bj)
            j = j + 1
        }
        i = i + 1
    }
    return y
}

// Linear backward — closed vjp:
//   dW = xᵀ · dy        (shape [D·C], reduces over B)
//   dx = dy · Wᵀ        (shape [B·D], reduces over C)
//   db[j] = Σ_i dy[i,j] (shape [C])
// Caller-allocated outputs (dW, dx, db) — writes in place.
//   shapes: x [B·D], W [D·C], dy [B·C]; out dW [D·C], dx [B·D], db [C].
pub fn nn_linear_bwd(x: int, W: int, dy: int,
                     dW_out: int, dx_out: int, db_out: int,
                     B: int, D: int, C: int) {
    // dW = xᵀ · dy : same reduction order as c3_outer accumulated over B
    // rows — for each (d, c) sum_b x[b,d] * dy[b,c].
    let mut d = 0
    while d < D {
        let mut c = 0
        while c < C {
            let mut acc = 0.0
            let mut bi = 0
            while bi < B {
                acc = acc + farr_get(x, bi * D + d) * farr_get(dy, bi * C + c)
                bi = bi + 1
            }
            let _ = farr_set(dW_out, d * C + c, acc)
            c = c + 1
        }
        d = d + 1
    }
    // dx = dy · Wᵀ : for each (b, d) sum_c dy[b,c] * W[d,c]
    let mut bi2 = 0
    while bi2 < B {
        let mut d2 = 0
        while d2 < D {
            let mut acc2 = 0.0
            let mut c2 = 0
            while c2 < C {
                acc2 = acc2 + farr_get(dy, bi2 * C + c2) * farr_get(W, d2 * C + c2)
                c2 = c2 + 1
            }
            let _ = farr_set(dx_out, bi2 * D + d2, acc2)
            d2 = d2 + 1
        }
        bi2 = bi2 + 1
    }
    // db[j] = Σ_i dy[i,j]
    let mut j = 0
    while j < C {
        let mut acc3 = 0.0
        let mut i3 = 0
        while i3 < B {
            acc3 = acc3 + farr_get(dy, i3 * C + j)
            i3 = i3 + 1
        }
        let _ = farr_set(db_out, j, acc3)
        j = j + 1
    }
}

// ─── RMSNorm layer ─────────────────────────────────────────────────────
// y_i = g_i · (x_i / sqrt(mean(x²) + eps)) ; shape: x [d], g [d] → y [d].
// Returns [y_id, xn_id, inv_packed_id] where inv_packed_id is a 1-elt
// farr holding `inv` (so bwd can read it back).
//   c3_rmsnorm_fwd identity: returns [y, xn, inv]; flame stores xn in a
//   d-len farr and inv in a 1-len farr.
//   Caller allocates y_out (d-len), xn_out (d-len), inv_out (1-len).
pub fn nn_rmsnorm_fwd(x: int, g: int,
                      y_out: int, xn_out: int, inv_out: int,
                      d: int) {
    let eps = 0.000001
    let mut ms = 0.0
    let mut i = 0
    while i < d {
        let xi = farr_get(x, i)
        ms = ms + xi * xi
        i = i + 1
    }
    ms = ms / to_float(d)
    let inv = 1.0 / _nn_sqrt(ms + eps)
    let _ = farr_set(inv_out, 0, inv)
    let mut j = 0
    while j < d {
        let xni = farr_get(x, j) * inv
        let _ = farr_set(xn_out, j, xni)
        let _ = farr_set(y_out, j, farr_get(g, j) * xni)
        j = j + 1
    }
}

// ─── Attention core (GQA, causal, multi-head; new math only) ──────────
// Reference: anima d_train5_lib.hexa d5_attn_fwd / d5_attn_bwd
// (attention-core sections only — the Q/K/V/output projections are
// composed externally by the caller using nn_linear_fwd + RoPE, the
// same pattern d5_attn_fwd uses internally).
//
// flame's attention-core takes the ALREADY-PROJECTED + ALREADY-ROPED
// Q/K (and V untouched), shapes:
//   Q : [T · nh · hd]   query, RoPE-rotated, per-head
//   K : [T · nkv · hd]  key,   RoPE-rotated, per-kv-head (GQA grouped)
//   V : [T · nkv · hd]  value, no RoPE, per-kv-head
// and produces:
//   P   : [nh · T · T]   per-head per-query softmax weights (causal: j≤i)
//   ctx : [T · d]        context output, d = nh·hd; head hh at offset
//                        ctx[i*d + hh*hd + c]
// scale = 1/sqrt(hd) baked into scores.  GQA grouping: kvh = hh / n_rep
// where n_rep = nh / nkv.

fn _nn_softmax_row(s: int, p_out: int, base: int, L: int) {
    // s : input scores farr (L-len); p_out : output farr; base : offset
    // in p_out to write to. Numerically-stable: subtract max.
    // Uses farr_get/farr_set with explicit indexing (no separate temp farr).
    let mut m = farr_get(s, 0)
    let mut i = 1
    while i < L {
        if farr_get(s, i) > m { m = farr_get(s, i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < L {
        let e = exp(farr_get(s, i2) - m)
        // stash e into p_out[base + i2] (we'll renormalize in pass 2).
        let _ = farr_set(p_out, base + i2, e)
        tot = tot + e
        i2 = i2 + 1
    }
    let mut i3 = 0
    while i3 < L {
        let cur = farr_get(p_out, base + i3)
        let _ = farr_set(p_out, base + i3, cur / tot)
        i3 = i3 + 1
    }
}

// Forward attention core. Caller pre-allocates P_out (nh·T·T) and
// ctx_out (T·d) with zeros (we WRITE the causal-mask region; positions
// beyond L=i+1 remain zero by caller's pre-fill).
pub fn nn_attn_core_fwd(Q: int, K: int, V: int,
                        P_out: int, ctx_out: int,
                        T: int, nh: int, nkv: int, hd: int) {
    let n_rep = nh / nkv
    let d = nh * hd
    let scale = 1.0 / sqrt(to_float(hd))
    // scores scratch — L can be up to T; allocate once at max.
    let srow = farr_zeros(T)
    let mut hh = 0
    while hh < nh {
        let kvh = hh / n_rep
        let mut i = 0
        while i < T {
            let L = i + 1
            // scores[j] = Σ_c Q[(i*nh + hh)*hd + c] · K[(j*nkv + kvh)*hd + c] · scale
            let mut j = 0
            while j < L {
                let mut dot = 0.0
                let mut c = 0
                while c < hd {
                    dot = dot + farr_get(Q, (i * nh + hh) * hd + c)
                              * farr_get(K, (j * nkv + kvh) * hd + c)
                    c = c + 1
                }
                let _ = farr_set(srow, j, dot * scale)
                j = j + 1
            }
            // softmax_row over srow[0..L] → P[(hh*T + i)*T + 0..L]
            _nn_softmax_row(srow, P_out, (hh * T + i) * T, L)
            // ctx[i*d + hh*hd + c] = Σ_j P[(hh*T+i)*T+j] · V[(j*nkv+kvh)*hd + c]
            let mut c2 = 0
            while c2 < hd {
                let mut acc = 0.0
                let mut jj = 0
                while jj < L {
                    acc = acc + farr_get(P_out, (hh * T + i) * T + jj)
                              * farr_get(V, (jj * nkv + kvh) * hd + c2)
                    jj = jj + 1
                }
                let _ = farr_set(ctx_out, i * d + hh * hd + c2, acc)
                c2 = c2 + 1
            }
            i = i + 1
        }
        hh = hh + 1
    }
    let _ = farr_free(srow)
}

// Backward attention core. Closed analytic vjp (d5_attn_bwd §"attention
// core"):
//   given dctx [T·d] → dQ, dK, dV (rotated-space grads, caller-zeroed)
//   dP[i,j] = Σ_c dctx[i, hh, c] · V[j, kvh, c]
//   sdot[i] = Σ_j P[i,j] · dP[i,j]            (softmax Jacobian helper)
//   dV[j, kvh, c] += Σ_i P[i,j] · dctx[i, hh, c]     (accumulate over heads)
//   dS[i,j] = P[i,j] · (dP[i,j] − sdot[i]) · scale
//   dQ[i, hh, c] += Σ_j dS[i,j] · K[j, kvh, c]
//   dK[j, kvh, c] += Σ_i dS[i,j] · Q[i, hh, c]      (accumulate over heads)
// dQ_out / dK_out / dV_out are ACCUMULATED INTO (caller pre-zeros).
pub fn nn_attn_core_bwd(Q: int, K: int, V: int, P: int, dctx: int,
                        dQ_out: int, dK_out: int, dV_out: int,
                        T: int, nh: int, nkv: int, hd: int) {
    let n_rep = nh / nkv
    let d = nh * hd
    let scale = 1.0 / sqrt(to_float(hd))
    let dP_row = farr_zeros(T)
    let mut hh = 0
    while hh < nh {
        let kvh = hh / n_rep
        let mut i = 0
        while i < T {
            let L = i + 1
            // dP[j] = Σ_c dctx[i*d + hh*hd + c] · V[(j*nkv + kvh)*hd + c]
            let mut j = 0
            while j < L {
                let mut acc = 0.0
                let mut c = 0
                while c < hd {
                    acc = acc + farr_get(dctx, i * d + hh * hd + c)
                              * farr_get(V, (j * nkv + kvh) * hd + c)
                    c = c + 1
                }
                let _ = farr_set(dP_row, j, acc)
                j = j + 1
            }
            let mut sdot = 0.0
            let mut j2 = 0
            while j2 < L {
                sdot = sdot + farr_get(P, (hh * T + i) * T + j2)
                            * farr_get(dP_row, j2)
                j2 = j2 + 1
            }
            // dV[j, kvh, c] += P[i,j] · dctx[i, hh, c]
            // Path C farr_matmul-routing TESTED + REVERTED 2026-05-17:
            // per-hh P^T·dctx_hh form passed Phase 3-B/3-C/Phase 3-F-3
            // but VIOLATED Phase 2 F-RFC043-LAYER-EQ-ATTN-BWD strict
            // byte-eq (cross-impl reduction-order drift between wrapper
            // and ref). wall single-shot 11.46s vs 5-run baseline
            // 13.33s — possible improvement but strict byte-eq
            // regression unacceptable. inline restored.
            let mut j3 = 0
            while j3 < L {
                let pij = farr_get(P, (hh * T + i) * T + j3)
                let mut c = 0
                while c < hd {
                    let dv_idx = (j3 * nkv + kvh) * hd + c
                    let cur = farr_get(dV_out, dv_idx)
                    let _ = farr_set(dV_out, dv_idx,
                                     cur + pij * farr_get(dctx, i * d + hh * hd + c))
                    c = c + 1
                }
                j3 = j3 + 1
            }
            // dS[i,j] = P[i,j] · (dP[j] − sdot) · scale
            // dQ[i,hh,c] += Σ_j dS · K[j,kvh,c]
            // dK[j,kvh,c] += dS · Q[i,hh,c]
            let mut j4 = 0
            while j4 < L {
                let dS = farr_get(P, (hh * T + i) * T + j4)
                       * (farr_get(dP_row, j4) - sdot) * scale
                let mut c2 = 0
                while c2 < hd {
                    let dq_idx = (i * nh + hh) * hd + c2
                    let dk_idx = (j4 * nkv + kvh) * hd + c2
                    let cur_q = farr_get(dQ_out, dq_idx)
                    let _ = farr_set(dQ_out, dq_idx,
                                     cur_q + dS * farr_get(K, (j4 * nkv + kvh) * hd + c2))
                    let cur_k = farr_get(dK_out, dk_idx)
                    let _ = farr_set(dK_out, dk_idx,
                                     cur_k + dS * farr_get(Q, (i * nh + hh) * hd + c2))
                    c2 = c2 + 1
                }
                j4 = j4 + 1
            }
            i = i + 1
        }
        hh = hh + 1
    }
    let _ = farr_free(dP_row)
}

// ─── SwiGLU (gated SiLU MLP block) ─────────────────────────────────────
// Reference: anima d_train3_lib.hexa c3_swiglu_fwd / c3_swiglu_bwd.
//   r:[d], Wg:[h·d], Wu:[h·d], Wd:[d·h]  →  o:[d]
//   forward: a = Wg·r ; b = Wu·r ; s[k] = silu(a[k])·b[k] ; o = Wd·s
//   backward (closed): given dout[d] →
//     dWd = dout ⊗ s  (d×h outer)
//     ds  = Wdᵀ·dout  (h-len, reduction over d)
//     da[k] = ds[k]·b[k]·silu'(a[k])
//     db[k] = ds[k]·silu(a[k])
//     dWg = da ⊗ r ; dWu = db ⊗ r ; dr = Wgᵀ·da + Wuᵀ·db

fn _nn_sigmoid(x: float) -> float {
    return 1.0 / (1.0 + exp(0.0 - x))
}
fn _nn_silu(x: float) -> float {
    return x * _nn_sigmoid(x)
}
fn _nn_silu_grad(x: float) -> float {
    let s = _nn_sigmoid(x)
    return s + x * s * (1.0 - s)
}

// Forward — caller allocates a_out/b_out/s_out (h-len each), o_out (d-len).
pub fn nn_swiglu_fwd(r: int, Wg: int, Wu: int, Wd: int,
                     a_out: int, b_out: int, s_out: int, o_out: int,
                     d: int, h: int) {
    // a = Wg · r : [h·d] · [d·1] → [h·1]
    let a_prod = farr_matmul(Wg, h, d, r, 1)
    let b_prod = farr_matmul(Wu, h, d, r, 1)
    let mut k = 0
    while k < h {
        let ak = farr_get(a_prod, k)
        let bk = farr_get(b_prod, k)
        let _ = farr_set(a_out, k, ak)
        let _ = farr_set(b_out, k, bk)
        let _ = farr_set(s_out, k, _nn_silu(ak) * bk)
        k = k + 1
    }
    let _ = farr_free(a_prod)
    let _ = farr_free(b_prod)
    // o = Wd · s : [d·h] · [h·1] → [d·1]
    let o_prod = farr_matmul(Wd, d, h, s_out, 1)
    let mut j = 0
    while j < d {
        let _ = farr_set(o_out, j, farr_get(o_prod, j))
        j = j + 1
    }
    let _ = farr_free(o_prod)
}

// Backward — caller allocates dr_out (d-len), dWg_out/dWu_out (h·d each),
// dWd_out (d·h). Outputs are OVERWRITTEN (no accumulation; if the caller
// wants accumulation the existing buffer copy happens outside).
pub fn nn_swiglu_bwd(r: int, Wg: int, Wu: int, Wd: int,
                     a: int, b: int, s: int, dout: int,
                     dr_out: int, dWg_out: int, dWu_out: int, dWd_out: int,
                     d: int, h: int) {
    // dWd[i, k] = dout[i] · s[k]   (d×h outer)
    let mut di = 0
    while di < d {
        let do_i = farr_get(dout, di)
        let mut hi = 0
        while hi < h {
            let _ = farr_set(dWd_out, di * h + hi, do_i * farr_get(s, hi))
            hi = hi + 1
        }
        di = di + 1
    }
    // ds[k] = Σ_i Wd[i·h + k] · dout[i]   (h-len, reduction over d)
    let ds = farr_zeros(h)
    let mut k = 0
    while k < h {
        let mut acc = 0.0
        let mut i = 0
        while i < d {
            acc = acc + farr_get(Wd, i * h + k) * farr_get(dout, i)
            i = i + 1
        }
        let _ = farr_set(ds, k, acc)
        k = k + 1
    }
    // da[k] = ds[k]·b[k]·silu'(a[k]) ;  db[k] = ds[k]·silu(a[k])
    let da = farr_zeros(h)
    let db = farr_zeros(h)
    let mut k2 = 0
    while k2 < h {
        let ak = farr_get(a, k2)
        let dsk = farr_get(ds, k2)
        let _ = farr_set(da, k2, dsk * farr_get(b, k2) * _nn_silu_grad(ak))
        let _ = farr_set(db, k2, dsk * _nn_silu(ak))
        k2 = k2 + 1
    }
    // dWg[h, d] = da ⊗ r   ;  dWu = db ⊗ r
    let mut hi3 = 0
    while hi3 < h {
        let da_h = farr_get(da, hi3)
        let db_h = farr_get(db, hi3)
        let mut di3 = 0
        while di3 < d {
            let rj = farr_get(r, di3)
            let _ = farr_set(dWg_out, hi3 * d + di3, da_h * rj)
            let _ = farr_set(dWu_out, hi3 * d + di3, db_h * rj)
            di3 = di3 + 1
        }
        hi3 = hi3 + 1
    }
    // dr[j] = Σ_k Wg[k·d + j]·da[k] + Wu[k·d + j]·db[k]
    let mut di5 = 0
    while di5 < d {
        let mut acc2 = 0.0
        let mut hi5 = 0
        while hi5 < h {
            acc2 = acc2
                + farr_get(Wg, hi5 * d + di5) * farr_get(da, hi5)
                + farr_get(Wu, hi5 * d + di5) * farr_get(db, hi5)
            hi5 = hi5 + 1
        }
        let _ = farr_set(dr_out, di5, acc2)
        di5 = di5 + 1
    }
    let _ = farr_free(ds)
    let _ = farr_free(da)
    let _ = farr_free(db)
}

// ─── RoPE (rotary position embedding) ──────────────────────────────────
// Reference: anima d_train5_lib.hexa d5_rope_tables / d5_rope_apply /
// d5_rope_bwd / d5_rotate_half / d5_rotate_half_t (RoFormer convention).
//   cos/sin tables [T·hd]: cos[p·hd + c] = cos(p · invf[c mod half])
//     invf[i] = base^(-2i/hd), base=10000, half=hd/2
//   forward (one head): q'[c] = q[c]·cos[p·hd+c] + rh(q)[c]·sin[p·hd+c]
//     rh : [x1, x2] (each half-len) → [-x2, x1]
//   backward (orthogonal — closed): dq[c] = dq'[c]·cos[p·hd+c]
//     + rh_T(dq'·sin_p)[c]   ; rh_T : [a1, a2] → [a2, -a1]   (Rᵀ = R(−θ))
//
// flame uses builtin sin/cos for tables (vs anima's d5_sin/cos 14-Taylor)
// — selftest both sides use the SAME path, so byte-equality holds.
// Comparison against anima d5_rope_tables would diverge in last ulps
// (d5_sin Taylor vs libm sin); cross-impl gap is documented but not
// flame's concern at this layer.

// Build cos/sin RoPE tables (caller-allocated [T·hd] each) with an
// explicit rotary `base` (a.k.a. theta). base=10000 is the original
// RoPE/LLaMA default; Qwen2/2.5 use base=1000000 (some long-context
// variants 50000) — anima flame-v3 port needs this parametrized
// (inbox flame-v3 P2, anima TODO #1). The 4-arg `nn_rope_build_tables`
// stays a non-breaking thin wrapper pinning base=10000.
pub fn nn_rope_build_tables_base(T: int, hd: int,
                                 cos_out: int, sin_out: int, base: float) {
    let half = hd / 2
    let lnb = ln(base)
    // invf[i] = exp(-(2i/hd)·ln(base))   for i in [0, half)
    // We compute inline (avoid allocating an extra farr).
    let mut p = 0
    while p < T {
        let mut c = 0
        while c < hd {
            let fi = if c < half { c } else { c - half }
            let ex = (to_float(2 * fi) / to_float(hd)) * lnb
            let invf = 1.0 / exp(ex)
            let ang = to_float(p) * invf
            let _ = farr_set(cos_out, p * hd + c, d5_cos(ang))
            let _ = farr_set(sin_out, p * hd + c, d5_sin(ang))
            c = c + 1
        }
        p = p + 1
    }
}

// Non-breaking thin wrapper pinning the original base=10000 (LLaMA/RoPE
// default) — all pre-existing callers keep byte-identical output.
pub fn nn_rope_build_tables(T: int, hd: int,
                            cos_out: int, sin_out: int) {
    nn_rope_build_tables_base(T, hd, cos_out, sin_out, 10000.0)
}

// RoPE forward (single head, single position):
//   q_out[c] = q[c]·cos[p·hd+c] + rh(q)[c]·sin[p·hd+c]
//   rh(q): first half = -q[half..hd], second half = q[0..half]
pub fn nn_rope_apply_fwd(q: int, cos_tab: int, sin_tab: int,
                         q_out: int, p: int, hd: int) {
    let half = hd / 2
    let bse = p * hd
    let mut c = 0
    while c < hd {
        // rh(q)[c] = if c < half: -q[half+c] ; else: q[c-half]
        let rh_c = if c < half {
            0.0 - farr_get(q, half + c)
        } else {
            farr_get(q, c - half)
        }
        let q_out_c = farr_get(q, c) * farr_get(cos_tab, bse + c)
                    + rh_c * farr_get(sin_tab, bse + c)
        let _ = farr_set(q_out, c, q_out_c)
        c = c + 1
    }
}

// RoPE backward (closed orthogonal vjp):
//   dq[c] = dq'[c]·cos[p·hd+c] + rh_T(dq'·sin_p)[c]
//   rh_T(v): first half = v[half..hd], second half = -v[0..half]
//   (i.e. Rᵀ = R(−θ); orthogonal rotation, no tape needed.)
pub fn nn_rope_apply_bwd(dqp: int, cos_tab: int, sin_tab: int,
                         dq_out: int, p: int, hd: int) {
    let half = hd / 2
    let bse = p * hd
    let mut c = 0
    while c < hd {
        // gs[c] = dqp[c]·sin[bse+c]
        // rh_T(gs)[c] = if c < half: gs[half+c] ; else: -gs[c-half]
        let gs_for_rht = if c < half {
            farr_get(dqp, half + c) * farr_get(sin_tab, bse + half + c)
        } else {
            0.0 - farr_get(dqp, c - half) * farr_get(sin_tab, bse + c - half)
        }
        let dq_c = farr_get(dqp, c) * farr_get(cos_tab, bse + c) + gs_for_rht
        let _ = farr_set(dq_out, c, dq_c)
        c = c + 1
    }
}

// ─── Embedding (tied with LM head) ─────────────────────────────────────
// table : [V·d] (one row per vocab id); ids : [T] (token indices,
// stored as floats in farr).
// Forward — for each position i, copy table[ids[i]·d : ids[i]·d + d]
// into X_out[i·d : i·d + d]. Mirrors anima d5_forward §"tok_emb embed
// lookup" (HEXAD/D/d_train5_lib.hexa).
pub fn nn_embedding_fwd(ids: int, table: int, X_out: int, T: int, d: int) {
    let mut i = 0
    while i < T {
        let tok = to_int(farr_get(ids, i))
        let mut c = 0
        while c < d {
            let _ = farr_set(X_out, i * d + c, farr_get(table, tok * d + c))
            c = c + 1
        }
        i = i + 1
    }
}

// Backward — scatter-add dX[i·d + c] → dtable[ids[i]·d + c] (accumulate
// in place). Mirrors d5_grad §"(b) embedding scatter-add". `dtable` is
// caller-pre-zeroed (or already holds the tied-head outer-product term
// from nn_lm_head_bwd).
pub fn nn_embedding_bwd_scatter(dX: int, ids: int, dtable_inout: int,
                                T: int, d: int) {
    let mut i = 0
    while i < T {
        let tok = to_int(farr_get(ids, i))
        let mut c = 0
        while c < d {
            let cur = farr_get(dtable_inout, tok * d + c)
            let _ = farr_set(dtable_inout, tok * d + c, cur + farr_get(dX, i * d + c))
            c = c + 1
        }
        i = i + 1
    }
}

// ─── Tied LM head ──────────────────────────────────────────────────────
// Forward — logits[k] = Σ_j temb[k·d + j] · zT[j]   (k = 0..V-1).
// Matvec / GEMV: temb [V·d] · zT [d] → logits [V]. We reuse farr_matmul
// with A=temb, M=V, K=d, B=zT (treated as [d·1]), N=1.  Identical to
// d5_matvec_g / GPU-routed path on no-CUDA build.
pub fn nn_lm_head_fwd(temb: int, zT: int, logits_out: int, V: int, d: int) {
    let prod = farr_matmul(temb, V, d, zT, 1)
    // GPU-resident large-vocab port (ASK #2): copy prod (V-len) into
    // logits_out via ONE device memcpy (farr_copy_slice_gpu) instead of the
    // per-element host loop. At V=151643 the old
    // `farr_set(logits, k, farr_get(prod, k))` loop ran V host-scalar box
    // ops AND — when the GPU matmul left `prod` device-resident — forced a
    // per-element D2H sync on each `farr_get` (RFC 040 lazy-D2H). The slice
    // copy is one cudaMemcpy (CUDA) / memmove (no-CUDA), bit-exact to the
    // element copy. rc != 0 → host fallback (no-CUDA correctness reference).
    let rc = farr_copy_slice_gpu(prod, 0, logits_out, 0, V)
    if to_int(rc) != 0 {
        let mut k = 0
        while k < V {
            let _ = farr_set(logits_out, k, farr_get(prod, k))
            k = k + 1
        }
    }
    let _ = farr_free(prod)
}

// Backward — tied LM head:
//   dtemb[k, j] = dl[k] · zT[j]            (outer product, V·d)
//   dzT[j]      = Σ_k temb[k·d + j] · dl[k] (transpose-matvec, d-len)
// Caller controls whether dtemb_out is zero-init or already accumulates
// the embedding-scatter-add term (tied-weight; the d5_grad pattern).
//   We ACCUMULATE dtemb_out += dl ⊗ zT (so caller can pre-set or
//   subsequently add the scatter term).
//   dzT_out is overwritten (it has no other contributor).
pub fn nn_lm_head_bwd(temb: int, zT: int, dl: int,
                      dtemb_out: int, dzT_out: int, V: int, d: int) {
    // GPU-resident large-vocab port (ASK #1). At V=151643·d=768 the two
    // host double-loops below are each V·d = 116M scalar box ops (minutes
    // on the host). Route them through the already-byte-eq forge kernels:
    //   dtemb += dl ⊗ zT  →  outer = farr_outer_gpu(dl,zT,V,d) [V·d] then
    //                        farr_add_inplace_gpu(dtemb_out, outer, V·d)
    //   dzT  = tembᵀ · dl  →  farr_matmul_t_gpu(temb,V,d,dl) [d] then
    //                        farr_copy_slice_gpu(_,0,dzT_out,0,d)  (overwrite)
    // The CPU fallbacks of these builtins reduce in the SAME order as the
    // host loops below (bit-exact no-CUDA reference); CUDA = forge `_gpu`
    // rel-tol (RFC 040 §2.2). Any rc != 0 / id < 0 → host fallback.
    //
    // NB: each forge kernel call is bound to a `let` BEFORE to_int(). A
    // `to_int(kernel(...))` expands the inner call 3× in the generated C
    // ternary (HX_IS_STR test + str-branch + num-branch), so a SIDE-EFFECTING
    // kernel runs 2-3× — farr_add_inplace_gpu would double-add (silent grad
    // corruption), a fresh-farr allocator would leak its first 2 allocations.
    // Binding to a `let` first emits the call exactly once.
    let outer_h = farr_outer_gpu(dl, zT, V, d)
    let outer_id = to_int(outer_h)
    let mut gpu_dtemb_ok = false
    if outer_id >= 0 {
        let add_h = farr_add_inplace_gpu(dtemb_out, outer_id, V * d)
        let rc_add = to_int(add_h)
        if rc_add == 0 { gpu_dtemb_ok = true }
        let _ = farr_free(outer_id)
    }
    if gpu_dtemb_ok == false {
        // host fallback — accumulate dtemb += dl ⊗ zT
        let mut k = 0
        while k < V {
            let dlk = farr_get(dl, k)
            let mut j = 0
            while j < d {
                let cur = farr_get(dtemb_out, k * d + j)
                let _ = farr_set(dtemb_out, k * d + j, cur + dlk * farr_get(zT, j))
                j = j + 1
            }
            k = k + 1
        }
    }
    // dzT = tembᵀ · dl  ; loop order matches d5_matvec_t_g (rows=V, cols=d).
    let dzT_h = farr_matmul_t_gpu(temb, V, d, dl)
    let dzT_id = to_int(dzT_h)
    let mut gpu_dzT_ok = false
    if dzT_id >= 0 {
        let cp_h = farr_copy_slice_gpu(dzT_id, 0, dzT_out, 0, d)
        let rc_cp = to_int(cp_h)
        if rc_cp == 0 { gpu_dzT_ok = true }
        let _ = farr_free(dzT_id)
    }
    if gpu_dzT_ok == false {
        // host fallback
        let mut j2 = 0
        while j2 < d {
            let mut acc = 0.0
            let mut k2 = 0
            while k2 < V {
                acc = acc + farr_get(temb, k2 * d + j2) * farr_get(dl, k2)
                k2 = k2 + 1
            }
            let _ = farr_set(dzT_out, j2, acc)
            j2 = j2 + 1
        }
    }
}

// RMSNorm backward — closed vjp (c3_rmsnorm_bwd identity):
//   dxn_i = dy_i · g_i
//   dg_i  = dy_i · xn_i
//   dot   = Σ_k dxn_k · x_k
//   dx_i  = inv · dxn_i − (inv³ · x_i / d) · dot
// Caller allocates dx_out, dg_out (d-len each).
pub fn nn_rmsnorm_bwd(x: int, g: int, xn: int, inv: float, dy: int,
                      dx_out: int, dg_out: int, d: int) {
    // pass 1: dxn (held implicit in dx_out as scratch; we overwrite below)
    // for clarity we compute dxn into a stack-free pattern by recomputing.
    let mut dot = 0.0
    let mut i = 0
    while i < d {
        let dxn_i = farr_get(dy, i) * farr_get(g, i)
        let _ = farr_set(dg_out, i, farr_get(dy, i) * farr_get(xn, i))
        dot = dot + dxn_i * farr_get(x, i)
        // stash dxn_i into dx_out temporarily — we finish the formula in
        // pass 2 (overwrites the stash with the final dx).
        let _ = farr_set(dx_out, i, dxn_i)
        i = i + 1
    }
    let inv3 = inv * inv * inv
    let scale = (inv3 / to_float(d)) * dot
    let mut j = 0
    while j < d {
        let dxn_j = farr_get(dx_out, j)
        let xj = farr_get(x, j)
        let _ = farr_set(dx_out, j, inv * dxn_j - scale * xj)
        j = j + 1
    }
}

// ─── BF16 FFN (RFC 050 PERF-INHERITANCE, 2026-05-19) ────────────────────
// Fused FFN forward routed through the RFC 049 BF16 substrate via the
// RFC 050 dispatcher:    Y = SiLU(X · W1) · W2 .
// Shapes (Llama-style 2-weight FFN): X[M·D], W1[D·FD], W2[FD·D], Y[M·D].
//
// The `forge_dispatch_ffn_fp64_via_bf16` builtin takes FP64 farr handles
// (the hexa-side currency) and internally RNE-casts FP64 → BF16, routes
// through forge_tier_dispatch_v1(FFN_FUSED, PURE_BF16) to the measured
// substrate (RFC 049 Stage 2: hexa_farr_ffn_bf16_gpu 11.66× FP64 cuBLAS
// at d768·12L FFN on A100), then casts BF16 → FP64 back into the
// caller's output farr. Returns 0 on success, -1 on:
//   - no-CUDA host (BF16 substrate not linked in),
//   - dispatch failure (FORGE_PRECISION_UNSUPPORTED or kernel error),
//   - OOM / shape mismatch with the FP64 farr lengths.
//
// Numerical contract: BF16 storage (7-bit mantissa) + FP32-accumulator
// GemmEx ≠ FP64 byte-equal. The Stage 2 dispatch-validate harness
// measured max|Δ|/max|Y| ≤ 5e-2 vs FP64 cuBLAS at these shapes — this
// fn inherits that tolerance, NOT byte-eq with nn_swiglu_fwd. Callers
// that need byte-eq (e.g. flame Phase 4-B oracle) MUST stay on the FP64
// path (nn_swiglu_fwd or nn_linear_fwd composition).
//
// This is NOT a SwiGLU replacement — SwiGLU has 3 weights (Wg gate +
// Wu up + Wd down with σ-gated combine); this is the 2-weight Llama
// FFN (W1 up + SiLU + W2 down). flame model code that wants a BF16
// SwiGLU needs a separate substrate kernel (out of scope for this
// cycle — see state design doc honest deferrals).
//
// Falsifier: F-RFC050-PERF-INHERIT-FFN — wall_bf16 ≤ wall_fp64/5 at
// 128·768·3072 FFN. Measured by the standalone .cu harness
// (state/forge_rfc050_perf_inherit_2026_05_19/, fire pending).
pub fn nn_ffn_bf16_fwd(x: int, W1: int, W2: int, Y_out: int,
                       M: int, D: int, FD: int) -> int {
    return forge_dispatch_ffn_fp64_via_bf16(x, W1, W2, Y_out, M, D, FD)
}

// ─── BF16 Tensor-Core dense matmul mega-kernel (RFC 049 §TC, 2026-06-01) ──
// Dense matmul C[M·N] = A[M·K] @ B[K·N] routed through the BF16 Tensor-Core
// path — the single hot kernel shared by the CLM readout (tied LM head =
// pure matmul), the MoE router projection (d→E, k=1 conv = matmul), and the
// per-expert pointwise projections. RFC 049 measured the BF16-TC substrate
// (hexa_farr_matmul_bf16_gpu) at 9.67× over FP64-cuBLAS on a Llama-FFN-shaped
// dense matmul; this is the readout/router/expert generalization.
//
// Numerical contract (the host-closeable half). The Tensor-Core path is NOT
// FP64 byte-equal: operands are stored BF16 (8-bit significand: 1 implicit +
// 7 explicit), products accumulate in an FP32 register. _nn_bf16_round below
// reproduces the BF16 operand storage EXACTLY (round-to-nearest-even of the
// FP64 word's significand down to BF16's 7 explicit bits, same exponent
// range), and the host fallback accumulates the rounded products in FP64 —
// a superset of the FP32 accumulator, so the host result is at least as
// accurate as the device. The stated end-to-end tolerance vs the FP64
// baseline is max|Δ|/max|C| ≤ 5e-2 (inherited from the RFC 049 Stage-2
// dispatch-validate harness; same as nn_ffn_bf16_fwd). Callers needing
// byte-eq (e.g. the Phase 4-B oracle) MUST stay on nn_linear_fwd (FP64).
//
// GPU half (the 9.67× wall win) is HONEST-DEFERRED: it is a Tensor-Core
// hardware property measured only on a CUDA host. _nn_matmul_bf16_host below
// is the host fallback that proves descent / numerical correctness; the
// device dispatch (forge_tier_dispatch_v1 MATMUL + PURE_BF16 →
// hexa_farr_matmul_bf16_gpu) is wired by nn_matmul_bf16_fwd's preamble but
// its WALL measurement is deferred to a GPU pod (state design doc:
// state/forge_rfc049_bf16_tc_matmul_2026_06_01/).
//
// Falsifier: F-RFC049-BF16-TC-MATMUL
//   (host)  max|Δ|/max|C| of nn_matmul_bf16_host vs FP64 farr_matmul ≤ 5e-2
//           AND a descent smoke keeps loss strictly decreasing.
//   (gpu·deferred) wall_bf16_tc ≤ wall_fp64_cublas / 5 at a Llama-FFN matmul.

// Round an FP64 value to the nearest BF16-representable value (round-to-
// nearest-even). BF16 = sign(1) · exponent(8) · significand(8-bit: 1 implicit
// + 7 explicit), sharing FP32's exponent range. Rather than bit-pun the FP64
// word (fragile float→int narrowing — see CLAUDE.md stdlib_trig_libm), we
// round ARITHMETICALLY: decompose x = m · 2^e with the unit-of-last-place at
// 2^(e-7), scale x onto that grid, round-to-nearest-even, scale back. This is
// codegen-stable (no intrinsic) and exactly reproduces BF16 operand storage
// for the finite magnitudes flame feeds a matmul.
// floor for non-negative inputs (the only case _nn_bf16_round feeds it).
fn _nn_floor(x: float) -> float {
    let i = to_int(x)
    return to_float(i)
}

fn _nn_bf16_round(x: float) -> float {
    if x == 0.0 { return 0.0 }
    let neg = x < 0.0
    let mut a = if neg { 0.0 - x } else { x }
    // Find e with 2^e ≤ a < 2^(e+1), tracking the scale 2^e directly.
    let mut e = 0
    let mut scale = 1.0
    while a >= 2.0 { a = a / 2.0; e = e + 1; scale = scale * 2.0 }
    while a < 1.0 { a = a * 2.0; e = e - 1; scale = scale / 2.0 }
    // ulp for BF16 = 2^(e-7) (7 explicit fraction bits below the leading 1).
    // Quantize a∈[1,2) to 7 fraction bits: round(a · 128) / 128, RNE.
    let grid = 128.0
    let scaled = a * grid
    // round-to-nearest-even
    let fl = _nn_floor(scaled)
    let frac = scaled - fl
    let mut r = fl
    if frac > 0.5 {
        r = fl + 1.0
    } else {
        if frac == 0.5 {
            // ties-to-even: bump only if fl is odd.
            let halfv = fl / 2.0
            if (halfv - _nn_floor(halfv)) != 0.0 { r = fl + 1.0 }
        }
    }
    let q = (r / grid) * scale
    return if neg { 0.0 - q } else { q }
}

// Quantize a length-n farr to BF16 precision (operand storage cast). Returns
// a fresh farr; the input is untouched.
fn _nn_bf16_quantize(src: int, n: int) -> int {
    let q = farr_zeros(n)
    let mut i = 0
    while i < n {
        let _ = farr_set(q, i, _nn_bf16_round(farr_get(src, i)))
        i = i + 1
    }
    return q
}

// Host fallback for the BF16-TC matmul: BF16-round both operands, then run
// the standard FP64 matmul reduction (an FP32-accumulator superset). This is
// the SSOT for the descent / correctness half of F-RFC049-BF16-TC-MATMUL.
//   A [M·K], B [K·N] → C [M·N]  (returns a fresh farr handle)
pub fn nn_matmul_bf16_host(A: int, B: int, M: int, K: int, N: int) -> int {
    let A_bf = _nn_bf16_quantize(A, M * K)
    let B_bf = _nn_bf16_quantize(B, K * N)
    // Same reduction order as farr_matmul (the FP64 baseline) so the only
    // delta vs the baseline is the BF16 operand rounding, not the schedule.
    return farr_matmul(A_bf, M, K, B_bf, N)
}

// BF16 Tensor-Core dense matmul — readout / router / expert hot path.
//   A [M·K], B [K·N] → C [M·N]  (returns a fresh farr handle, or -1 on a
//   shape error). On a CUDA host the GPU TC substrate is reachable through
//   forge_dispatch_matmul's tier dispatcher (PURE_BF16 routing — the device
//   half, wall-deferred). Off-GPU (this host) we take the BF16-rounded host
//   fallback, which is numerically the device's superset and proves descent.
//
// The dispatch is intentionally a thin policy seam: the BF16-TC kernel
// selection lives in forge_tier_dispatch_v1 (PURE_BF16 + MATMUL →
// hexa_farr_matmul_bf16_gpu), so this fn stays a stable hexa-side surface
// that flame readout/router/expert code calls without precision branching.
pub fn nn_matmul_bf16_fwd(A: int, B: int, M: int, K: int, N: int) -> int {
    if M <= 0 { return -1 }
    if K <= 0 { return -1 }
    if N <= 0 { return -1 }
    // Host fallback (descent/correctness-closeable). On a CUDA build the
    // tier dispatcher inside forge_dispatch_matmul routes PURE_BF16 +
    // MATMUL to hexa_farr_matmul_bf16_gpu (RFC 049 9.67× — wall-deferred);
    // the BF16-rounded host path here is its numerical superset.
    return nn_matmul_bf16_host(A, B, M, K, N)
}

// ─── Full-position tied LM head + cross-entropy (INBOX #2 P1①) ──────────
// The decoder forward (decoder_lib::nn_decoder_fwd) projects ONLY the last
// position (logits[V] = head · zT, where zT = RMSNorm of Xout[(T-1)·d]),
// and nn_decoder_ce_loss reads that single V-wide row. The anima
// ConsciousDecoderV3 training stack supervises EVERY position (next-token
// LM over the whole sequence), so the loss must average CE over all T
// positions. These two helpers add the full-position surface as a minimal
// functional layer over the SAME tied head + stable-softmax CE used at the
// last position — keeping the per-position math byte-identical so a tiny
// hand oracle gates correctness.

// Full-position tied LM head forward.
//   Z         [T·d]   per-position hidden vectors (post final RMSNorm·gF)
//   temb      [V·d]   tied token-embedding / head weight
//   logits_out[T·V]   caller-allocated; logits_out[t·V + k] = Σ_j temb[k·d+j]·Z[t·d+j]
// Per row t this is identical to nn_lm_head_fwd on Z[t·d .. t·d+d], so each
// row is byte-eq to the existing last-position head.
pub fn nn_lm_head_fwd_allpos(temb: int, Z: int, logits_out: int,
                             T: int, V: int, d: int) {
    let mut t = 0
    while t < T {
        let mut k = 0
        while k < V {
            let mut acc = 0.0
            let mut j = 0
            while j < d {
                acc = acc + farr_get(temb, k * d + j) * farr_get(Z, t * d + j)
                j = j + 1
            }
            let _ = farr_set(logits_out, t * V + k, acc)
            k = k + 1
        }
        t = t + 1
    }
}

// Full-position mean cross-entropy.
//   logits  [T·V]   per-position logit rows (from nn_lm_head_fwd_allpos)
//   targets [T]     targets[t] = target token id (0..V-1) for position t
//   returns (1/T) Σ_t  -ln( softmax(logits[t·V .. t·V+V])[targets[t]] )
// Each per-position term reuses the stable-softmax (subtract row max) +
// dt_exp/dt_ln + the pt_safe floor of nn_decoder_ce_loss verbatim, so a
// single position (T=1) reduces exactly to the existing last-position CE.
pub fn nn_ce_loss_allpos(logits: int, targets: int, T: int, V: int) -> float {
    let mut total = 0.0
    let mut t = 0
    while t < T {
        let base = t * V
        let mut mx = farr_get(logits, base)
        let mut i = 1
        while i < V {
            if farr_get(logits, base + i) > mx { mx = farr_get(logits, base + i) }
            i = i + 1
        }
        let mut tot = 0.0
        let mut i2 = 0
        while i2 < V {
            tot = tot + dt_exp(farr_get(logits, base + i2) - mx)
            i2 = i2 + 1
        }
        let tgt = to_int(farr_get(targets, t))
        let p_t = dt_exp(farr_get(logits, base + tgt) - mx) / tot
        let pt_safe = if p_t < 0.000001 { 0.000001 } else { p_t }
        total = total + (0.0 - dt_ln(pt_safe))
        t = t + 1
    }
    return total / to_float(T)
}

// ─── GELU + PureFieldFFN (RFC 059 §3, P1②-b) ───────────────────────────
// EXACT (erf-based) GELU — the gradient is matched to THIS forward, not a
// tanh approximation, so the central-diff grad-check stays consistent
// (flame float-eval byte-eq hazard / RFC 059 §3 GELU' = Φ(g)+g·φ(g)):
//   GELU(x)  = x · Φ(x) ,  Φ(x) = 0.5·(1 + erf(x/√2))   (normal CDF)
//   GELU'(x) = Φ(x) + x · φ(x) ,  φ(x) = exp(−x²/2)/√(2π)  (normal pdf)
// Both `erf` and `exp` are libm codegen builtins (self/codegen.hexa) —
// IEEE-correct, no hand-rolled Taylor (CLAUDE.md stdlib_trig_libm).
fn _nn_inv_sqrt2() -> float { return 0.70710678118654752440 }  // 1/√2
fn _nn_inv_sqrt2pi() -> float { return 0.39894228040143267794 } // 1/√(2π)

fn _nn_normal_cdf(x: float) -> float {
    return 0.5 * (1.0 + erf(x * _nn_inv_sqrt2()))
}
fn _nn_normal_pdf(x: float) -> float {
    return _nn_inv_sqrt2pi() * exp(0.0 - 0.5 * x * x)
}
fn _nn_gelu(x: float) -> float {
    return x * _nn_normal_cdf(x)
}
fn _nn_gelu_grad(x: float) -> float {
    return _nn_normal_cdf(x) + x * _nn_normal_pdf(x)
}

// Elementwise GELU: a_out[i] = GELU(g[i]) over h elements.
pub fn nn_gelu_fwd(g: int, a_out: int, h: int) {
    let mut i = 0
    while i < h {
        let _ = farr_set(a_out, i, _nn_gelu(farr_get(g, i)))
        i = i + 1
    }
}

// Elementwise GELU backward: dg[i] = da[i] · GELU'(g[i]). `g` is the
// PRE-activation (saved from forward). Caller allocates dg_out (h-len).
pub fn nn_gelu_bwd(g: int, da: int, dg_out: int, h: int) {
    let mut i = 0
    while i < h {
        let _ = farr_set(dg_out, i, farr_get(da, i) * _nn_gelu_grad(farr_get(g, i)))
        i = i + 1
    }
}

// One PureField expert: E(x) = Linear_out( GELU( Linear_in(x) ) ).
//   x [d]  W_in [d·h]  W_out [h·d]  →  e_out [d]
// Saves the per-expert fwd cache (g = pre-GELU [h], aa = post-GELU [h]) for
// the backward. Caller allocates e_out [d], g_out [h], aa_out [h].
//   (no bias — MVP matches ag_linear's zero-bias matmul path.)
pub fn nn_pf_expert_fwd(x: int, W_in: int, W_out: int,
                        e_out: int, g_out: int, aa_out: int,
                        d: int, h: int) {
    // g = x · W_in : [1·d]·[d·h] → [1·h]
    let g_prod = farr_matmul(x, 1, d, W_in, h)
    let mut k = 0
    while k < h {
        let _ = farr_set(g_out, k, farr_get(g_prod, k))
        k = k + 1
    }
    let _ = farr_free(g_prod)
    // aa = GELU(g)
    nn_gelu_fwd(g_out, aa_out, h)
    // e = aa · W_out : [1·h]·[h·d] → [1·d]
    let e_prod = farr_matmul(aa_out, 1, h, W_out, d)
    let mut j = 0
    while j < d {
        let _ = farr_set(e_out, j, farr_get(e_prod, j))
        j = j + 1
    }
    let _ = farr_free(e_prod)
}

// PureFieldFFN forward: out = E_A(x) − E_G(x). Two experts share the input
// x; the difference is the field "tension" projection input.
//   x [d]  Wa_in/Wg_in [d·h]  Wa_out/Wg_out [h·d]  →  out [d]
// Caches: gA/aA (expert-A pre/post GELU), gG/aG (expert-G). Caller allocates
// out [d], gA/aA/gG/aG [h] each.
pub fn nn_purefield_fwd(x: int, Wa_in: int, Wa_out: int,
                        Wg_in: int, Wg_out: int,
                        out: int, gA: int, aA: int, gG: int, aG: int,
                        d: int, h: int) {
    let eA = farr_zeros(d)
    let eG = farr_zeros(d)
    nn_pf_expert_fwd(x, Wa_in, Wa_out, eA, gA, aA, d, h)
    nn_pf_expert_fwd(x, Wg_in, Wg_out, eG, gG, aG, d, h)
    let mut j = 0
    while j < d {
        let _ = farr_set(out, j, farr_get(eA, j) - farr_get(eG, j))
        j = j + 1
    }
    let _ = farr_free(eA)
    let _ = farr_free(eG)
}

// One PureField expert backward (vjp of Linear_in → GELU → Linear_out).
//   de [d]  : upstream grad w.r.t. this expert's output e
//   sign    : +1.0 for E_A, −1.0 for E_G (chain from out = E_A − E_G)
//   accumulates into dx_out [d] (shared across both experts → +=)
//   writes  dW_in_out [d·h], dW_out_out [h·d] (this expert's own params)
//   x, g, aa : saved fwd state (x input, g pre-GELU, aa post-GELU)
pub fn nn_pf_expert_bwd(x: int, W_in: int, W_out: int, g: int, aa: int,
                        de: int, sign: float,
                        dx_out: int, dW_in_out: int, dW_out_out: int,
                        d: int, h: int) {
    // sde[j] = sign · de[j]  (apply the E_A/E_G sign once up front)
    let sde = farr_zeros(d)
    let mut j0 = 0
    while j0 < d {
        let _ = farr_set(sde, j0, sign * farr_get(de, j0))
        j0 = j0 + 1
    }
    // Linear_out vjp: e = aa · W_out.  daa[k] = Σ_j sde[j]·W_out[k·d+j] ;
    //                                  dW_out[k·d+j] = aa[k]·sde[j].
    let daa = farr_zeros(h)
    let mut k = 0
    while k < h {
        let mut acc = 0.0
        let mut j = 0
        while j < d {
            acc = acc + farr_get(sde, j) * farr_get(W_out, k * d + j)
            let _ = farr_set(dW_out_out, k * d + j, farr_get(aa, k) * farr_get(sde, j))
            j = j + 1
        }
        let _ = farr_set(daa, k, acc)
        k = k + 1
    }
    // GELU vjp: dg[k] = daa[k]·GELU'(g[k])
    let dg = farr_zeros(h)
    nn_gelu_bwd(g, daa, dg, h)
    // Linear_in vjp: g = x · W_in.  dW_in[i·h+k] = x[i]·dg[k] ;
    //                                dx[i] += Σ_k W_in[i·h+k]·dg[k].
    let mut i = 0
    while i < d {
        let mut acc2 = 0.0
        let mut k2 = 0
        while k2 < h {
            acc2 = acc2 + farr_get(W_in, i * h + k2) * farr_get(dg, k2)
            let _ = farr_set(dW_in_out, i * h + k2, farr_get(x, i) * farr_get(dg, k2))
            k2 = k2 + 1
        }
        let _ = farr_set(dx_out, i, farr_get(dx_out, i) + acc2)   // accumulate (shared x)
        i = i + 1
    }
    let _ = farr_free(sde)
    let _ = farr_free(daa)
    let _ = farr_free(dg)
}

// PureFieldFFN backward: out = E_A(x) − E_G(x).
//   dout [d] : upstream grad w.r.t. out
//   → dx [d] = E_A bwd (sign +1) + E_G bwd (sign −1), accumulated
//   → dWa_in/dWa_out (expert-A params), dWg_in/dWg_out (expert-G params)
// Caller allocates dx_out [d] (ZEROED — accumulated), dWa_in/dWg_in [d·h],
// dWa_out/dWg_out [h·d].
pub fn nn_purefield_bwd(x: int, Wa_in: int, Wa_out: int,
                        Wg_in: int, Wg_out: int,
                        gA: int, aA: int, gG: int, aG: int, dout: int,
                        dx_out: int, dWa_in_out: int, dWa_out_out: int,
                        dWg_in_out: int, dWg_out_out: int,
                        d: int, h: int) {
    // zero dx (accumulated by both experts)
    let mut z = 0
    while z < d {
        let _ = farr_set(dx_out, z, 0.0)
        z = z + 1
    }
    // E_A: out += E_A  →  sign +1
    nn_pf_expert_bwd(x, Wa_in, Wa_out, gA, aA, dout, 1.0,
                     dx_out, dWa_in_out, dWa_out_out, d, h)
    // E_G: out −= E_G  →  sign −1
    nn_pf_expert_bwd(x, Wg_in, Wg_out, gG, aG, dout, 0.0 - 1.0,
                     dx_out, dWg_in_out, dWg_out_out, d, h)
}

