// Shape constants — RFC 072 §2 spec (GPT-3 class).
//
// d_model = 4096 matches GPT-3 6.7B (Brown 2020 Table 2.1); n_layer = 24
// (vs 32) keeps single-GPU memory envelope feasible on RTX 5070 with
// gradient checkpoint. g3-honest: "GPT-3 class" by d_model axis, NOT an
// exact parameter-count reproduction.
fn d4096_d_model() -> int { return 4096 }
fn d4096_n_layer() -> int { return 24 }
fn d4096_seq_len() -> int { return 2048 }
fn d4096_batch() -> int { return 8 }

// Measurement protocol constants (RFC 072 §3).
fn d4096_warmup_steps() -> int { return 1 }
fn d4096_timed_steps()  -> int { return 3 }

