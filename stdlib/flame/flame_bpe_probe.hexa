// stdlib/flame/flame_bpe_probe.hexa — flame-P2b make-or-break probe
//
// Confirms the riskiest assumption for flame-P2b BPE wiring:
//   does `use "self/ml/tokenizer_bpe"` RESOLVE + COMPILE from the
//   stdlib/flame tier? (module loader is repo-root-relative, but
//   self/ml ↔ stdlib/flame cross-tier resolution was never exercised.)
//
// Lesson applied (MoE-toy #1032): parse-pass ≠ compile-pass for
// cross-module symbols — only a real `hexa run` settles it.
//
// Cheap path: byte_tokenize/byte_detokenize are pure (no vocab/merges
// files), so this probe needs no external Qwen artifacts. If it prints
// PROBE: PASS, the full BPE corpus loader (real Qwen vocab, V=151936)
// is a config swap on a confirmed wiring.
use "self/ml/tokenizer_bpe"

fn main() {
    println("=== flame-P2b probe: stdlib/flame -> self/ml cross-tree use ===")
    let text = "hello flame bpe"
    let ids = byte_tokenize(text)
    print("  byte_tokenize ids len = "); println(len(ids))
    let back = byte_detokenize(ids)
    print("  round-trip text       = "); println(back)
    if back == text {
        println("PROBE: PASS (use self/ml resolves + compiles + byte round-trip ok)")
    } else {
        println("PROBE: FAIL (round-trip mismatch)")
    }
}
