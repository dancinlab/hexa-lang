// F-CLM-H911-STDP driver — spike-timing plasticity vs rate-Hebbian.
// Paired over 5 concepts: diff[c] = stdp_binding(parallel,c) - stdp_binding(concat,c).
// Also reports the RATE-Hebbian control (order-insensitive) which should be ~0.
use "stdlib/flame/clm_h911_bc_mechanisms"

fn main() {
    println("clm_h911_B1 — F-CLM-H911-STDP (spike-timing vs rate-Hebbian)")
    let FP = t_zeros(NLINE * D); let FC = t_zeros(NLINE * D)
    build_feats("stdlib/flame/testdata/clm_semantic_parallel.txt", FP)
    build_feats("stdlib/flame/testdata/clm_semantic_concat.txt", FC)
    let tau = 2.0
    let diffs = t_zeros(NCONC)
    // rate-Hebbian control: order-insensitive cross-lingual sim sum (no STDP kernel)
    let mut rate_par = 0.0; let mut rate_con = 0.0
    let mut c = 0
    while c < NCONC {
        let bp = stdp_binding(FP, 0, c, tau)
        let bc = stdp_binding(FC, 1, c, tau)
        t_set(diffs, c, bp - bc)
        print("  concept "); print(to_string(c)); print(": STDP par="); print(to_string(bp))
        print(" con="); print(to_string(bc)); print(" diff="); println(to_string(bp - bc))
        // rate control: tau->inf (kern=1) on same features, both orderings identical set
        rate_par = rate_par + stdp_binding(FP, 0, c, 100000.0)
        rate_con = rate_con + stdp_binding(FC, 1, c, 100000.0)
        c = c + 1
    }
    print("  RATE-Hebbian control (tau->inf): par="); print(to_string(rate_par))
    print(" con="); print(to_string(rate_con)); print(" gap="); println(to_string(rate_par - rate_con))
    report("STDP", "F-CLM-H911-STDP", diffs, NCONC)
}
