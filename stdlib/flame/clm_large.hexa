// ════════════════════════════════════════════════════════════════════════════
//  clm_gen.hexa — GENERAL CLMConvMoE trainer (arbitrary L trunk · E experts).
//
//  Generalizes the proven tiny trainer (clm_step #2303 / clm_qat #2304, both
//  hardcoded L=1·E=2) to ANY depth/width via PACKED weights + L/E loops — the
//  step that lets the hexa-native trainer express the production rungs
//  (mid d512/L8/E8 · large d768/L12/E12 · P6_SCALE_LADDER_7B). Per-layer /
//  per-expert conv weights are packed contiguously ([L·d·d·K], [E·d·d·K]);
//  each conv call copies its slice into a fixed temp; AdamW updates the whole
//  pack elementwise. Trunk dilation = base^l.
//
//  fwd: embed → embed_conv → L×{x += gelu(GN(conv_dil(x)))} → MoE(router + E
//  experts) → GN(norm_out) → readout. bwd: full reverse chain with the trunk
//  residual loop reversed. Loss = CE; optimizer = AdamW.
//
//  F-FLAME-CLM-GEN-DESCENT: CE strictly descends at a non-trivial config
//  (d=16, L=3, E=4, V=64) — proves the loops generalize beyond the tiny proof.
//  int4 QAT (clm_qat #2304) is orthogonal and composes per-conv. lib-split.
//
//  PR4 wiring: the forward conv 5× (embed·trunk_dil·router·expert·readout) route
//  through conv1d_via_forge (im2col + forge_dispatch_matmul, byte-eq F-CLM-CONV-
//  GPU-EQ #2352) — so the 44.68M LARGE rung's matmul bulk rides cuBLAS on a CUDA
//  host. On a `-DHEXA_CUDA` H100 this is the large fire: F-RFC046-GPU-UTILIZATION
//  (nvidia-smi >50% during run).
//
//  Phase-4 wiring (this revision): the backward conv 5× (readout·router·expert·
//  trunk_dil·embed) route through conv1d_bwd_via_forge (col2im + forge GEMM,
//  byte-eq to nn_conv1d_bwd per F-CLM-CONV-BWD-FORGE-EQ #2383) — so the backward
//  GEMMs ride forge cuBLAS too (the prerequisite for util-GREEN; the H100 util
//  re-fire is the deferred measurement). GRAD-EXACT preserved (byte-eq descent).
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/conv_lib"
use "stdlib/flame/gn_lib"
use "stdlib/flame/moe_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/optim_lib"

// conv1d (causal dilated) via im2col + forge matmul — inlined from clm_conv_gpu
// (clm flame files cannot `use` one another). Mirrors nn_conv1d_fwd's gather
// exactly: p = t − dil·(K−1−k); rows below p<0 are zero (left causal pad). On a
// CUDA host the matmul rides cuBLAS; on CPU it is the identical farr_matmul, so
// the routed forward is byte-eq to the host baseline (F-CLM-CONV-GPU-EQ #2352).
// dilation-general → covers the trunk's _pow2(l) dilated convs unchanged.
fn conv1d_via_forge(x: int, w: int, b: int, y_out: int,
                    T: int, Cin: int, Cout: int, K: int, dil: int) {
    let Kdim = Cin * K
    let xcol = t_zeros(T * Kdim)
    let mut t = 0
    while t < T {
        let mut ci = 0
        while ci < Cin {
            let mut k = 0
            while k < K {
                let p = t - dil * (K - 1 - k)
                if p >= 0 { t_set(xcol, t * Kdim + ci * K + k, t_get(x, p * Cin + ci)) }
                k = k + 1
            }
            ci = ci + 1
        }
        t = t + 1
    }
    let Wt = t_zeros(Kdim * Cout)
    let mut co = 0
    while co < Cout {
        let mut j = 0
        while j < Kdim { t_set(Wt, j * Cout + co, t_get(w, co * Kdim + j)); j = j + 1 }
        co = co + 1
    }
    let mm = forge_dispatch_matmul(xcol, T, Kdim, Wt, Cout)
    let mut t2 = 0
    while t2 < T {
        let mut c2 = 0
        while c2 < Cout {
            t_set(y_out, t2 * Cout + c2, t_get(mm, t2 * Cout + c2) + t_get(b, c2))
            c2 = c2 + 1
        }
        t2 = t2 + 1
    }
}

// conv1d backward (causal dilated) via forge matmul + col2im — inlined from
// clm_conv_gpu (clm flame files cannot `use` one another). Expresses the two
// heavy gradients (dW, dX) as GEMMs routed through forge_dispatch_matmul
// (cuBLAS on a CUDA host, identical farr_matmul on CPU) so the backward stops
// being a host scalar loop. Byte-eq to nn_conv1d_bwd (dW 1.67e-16 / dX 8.3e-17
// / db 0.0 per F-CLM-CONV-BWD-FORGE-EQ #2383). col index j = ci*K + k.
// dilation-general → covers the trunk's _pow2(l) dilated conv backwards unchanged.
fn conv1d_bwd_via_forge(x: int, w: int, dy: int,
                        dW_out: int, dX_out: int, db_out: int,
                        T: int, Cin: int, Cout: int, K: int, dil: int) {
    let Kdim = Cin * K
    // im2col: xcolT[j, t] = (p>=0) ? x[p, ci] : 0, j = ci*K+k, p = t - dil*(K-1-k).
    let xcolT = t_zeros(Kdim * T)
    let mut t = 0
    while t < T {
        let mut ci = 0
        while ci < Cin {
            let mut k = 0
            while k < K {
                let p = t - dil * (K - 1 - k)
                if p >= 0 {
                    let j = ci * K + k
                    t_set(xcolT, j * T + t, t_get(x, p * Cin + ci))
                }
                k = k + 1
            }
            ci = ci + 1
        }
        t = t + 1
    }
    // dW: dW_flat[Kdim, Cout] = xcolT[Kdim,T] @ dy[T,Cout] (forge GEMM)
    let dW_flat = forge_dispatch_matmul(xcolT, Kdim, T, dy, Cout)
    let mut co = 0
    while co < Cout {
        let mut j = 0
        while j < Kdim {
            t_set(dW_out, co * Kdim + j, t_get(dW_flat, j * Cout + co))
            j = j + 1
        }
        co = co + 1
    }
    // dX: dXcol[T, Kdim] = dy[T,Cout] @ Wflat[Cout,Kdim] (forge GEMM), then col2im.
    let dXcol = forge_dispatch_matmul(dy, T, Cout, w, Kdim)
    let mut iz = 0
    while iz < T * Cin {
        t_set(dX_out, iz, 0.0)
        iz = iz + 1
    }
    let mut t2b = 0
    while t2b < T {
        let mut ci2 = 0
        while ci2 < Cin {
            let mut k2 = 0
            while k2 < K {
                let p = t2b - dil * (K - 1 - k2)
                if p >= 0 {
                    let j = ci2 * K + k2
                    let xidx = p * Cin + ci2
                    t_set(dX_out, xidx, t_get(dX_out, xidx) + t_get(dXcol, t2b * Kdim + j))
                }
                k2 = k2 + 1
            }
            ci2 = ci2 + 1
        }
        t2b = t2b + 1
    }
    // db: db_out[co] = Σ_t dy[t,co] (host reduction)
    let mut cb = 0
    while cb < Cout {
        let mut acc = 0.0
        let mut tb = 0
        while tb < T {
            acc = acc + t_get(dy, tb * Cout + cb)
            tb = tb + 1
        }
        t_set(db_out, cb, acc)
        cb = cb + 1
    }
}

fn _cp(src: int, soff: int, dst: int, n: int) {
    let mut i = 0
    while i < n { t_set(dst, i, t_get(src, soff + i)); i = i + 1 }
}
fn _cpback(src: int, dst: int, doff: int, n: int) {
    let mut i = 0
    while i < n { t_set(dst, doff + i, t_get(src, i)); i = i + 1 }
}
fn _pow2(e: int) -> int {
    let mut p = 1; let mut i = 0
    while i < e { p = p * 2; i = i + 1 }
    return p
}

// Forward. Packed: trunkW[L·dd] trunkB[L·d] trunkG[L·d] trunkBe[L·d];
// expW[E·dd] expB[E·d].
//
// ACTIVATION CHECKPOINTING — the trunk caches ONLY the per-layer INPUT
// tin[L·T·d] (the checkpoint boundary). The per-layer forward activations
// hn[L·T·d]/xh[L·T·d]/iv[L] are NOT cached: gen_bwd RECOMPUTES them from tin[l]
// by re-running this layer's forward (conv_dil + groupnorm, the SAME forward
// ops). Activation-cache memory for the trunk drops from 3·[L·T·d] (+[L·d]) to
// a single [L·T·d] — O(L) toward checkpoint-boundary only — at the cost of one
// extra forward conv+GN per layer in backward. Recompute is bit-identical to
// the cached value, so gradients stay exact.
//
// Caches: tin[L·T·d]; eo[E·T·d] probs[T·E] ex[E·T·d]; xe,xtrunk,yn,xhN,ivN.
fn gen_fwd(tokens: int, embed: int, ecW: int, ecB: int,
           trunkW: int, trunkB: int, trunkG: int, trunkBe: int,
           rW: int, rB: int, expW: int, expB: int, noG: int, noB: int, roW: int, roB: int,
           xe: int, xtrunk: int, tin: int,
           eo: int, probs: int, ex: int, yn: int, xhN: int, ivN: int,
           out_logits: int, T: int, d: int, E: int, V: int, K: int, L: int) {
    let dd = d * d * K
    nn_embedding_fwd(tokens, embed, xe, T, d)
    let x = t_zeros(T * d)
    conv1d_via_forge(xe, ecW, ecB, x, T, d, d, K, 1)   // embed_conv → x (trunk input)
    let wtmp = t_zeros(dd); let btmp = t_zeros(d); let gtmp = t_zeros(d); let getmp = t_zeros(d)
    let mut l = 0
    while l < L {
        _cpback(x, tin, l * T * d, T * d)            // cache trunk input (checkpoint boundary)
        _cp(trunkW, l * dd, wtmp, dd); _cp(trunkB, l * d, btmp, d)
        _cp(trunkG, l * d, gtmp, d);  _cp(trunkBe, l * d, getmp, d)
        let h = t_zeros(T * d)
        conv1d_via_forge(x, wtmp, btmp, h, T, d, d, K, _pow2(l))
        let hnl = t_zeros(T * d); let mean = t_zeros(1); let invl = t_zeros(1); let xhl = t_zeros(T * d)
        nn_groupnorm_fwd(h, gtmp, getmp, hnl, mean, invl, xhl, T, d, 1)
        // hn/xh/iv intentionally NOT cached — gen_bwd recomputes them from tin[l].
        let hg = t_zeros(T * d); nn_gelu_fwd(hnl, hg, T * d)
        let xn = t_zeros(T * d)
        let mut i = 0
        while i < T * d { t_set(xn, i, t_get(x, i) + t_get(hg, i)); i = i + 1 }
        let mut c = 0
        while c < T * d { t_set(x, c, t_get(xn, c)); c = c + 1 }
        l = l + 1
    }
    _cpback(x, xtrunk, 0, T * d)                      // trunk output
    // moe
    let logits_r = t_zeros(T * E)
    conv1d_via_forge(x, rW, rB, logits_r, T, d, E, 1, 1)
    let mut e = 0
    while e < E {
        _cp(expW, e * dd, wtmp, dd); _cp(expB, e * d, btmp, d)
        let eol = t_zeros(T * d); conv1d_via_forge(x, wtmp, btmp, eol, T, d, d, K, 1)
        _cpback(eol, eo, e * T * d, T * d)
        let exl = t_zeros(T * d); nn_gelu_fwd(eol, exl, T * d)
        _cpback(exl, ex, e * T * d, T * d)
        e = e + 1
    }
    let y = t_zeros(T * d)
    nn_moe_router_fwd(logits_r, ex, probs, y, T, E, d)
    let meanN = t_zeros(1)
    nn_groupnorm_fwd(y, noG, noB, yn, meanN, ivN, xhN, T, d, 1)
    conv1d_via_forge(yn, roW, roB, out_logits, T, d, V, 1, 1)
}

fn gen_ce_grad(logits: int, targets: int, dlogits: int, T: int, V: int) {
    let mut t = 0
    while t < T {
        let base = t * V
        let mut mx = t_get(logits, base); let mut i = 1
        while i < V { let v = t_get(logits, base + i); if v > mx { mx = v }; i = i + 1 }
        let mut sm = 0.0; let mut i2 = 0
        while i2 < V { sm = sm + exp(t_get(logits, base + i2) - mx); i2 = i2 + 1 }
        let invT = 1.0 / to_float(T); let mut v3 = 0
        while v3 < V { t_set(dlogits, base + v3, exp(t_get(logits, base + v3) - mx) / sm * invT); v3 = v3 + 1 }
        let tgt = to_int(t_get(targets, t))
        t_set(dlogits, base + tgt, t_get(dlogits, base + tgt) - invT)
        t = t + 1
    }
}

// Backward. Writes packed grads dtrunkW/dtrunkB/dtrunkG/dtrunkBe, dexpW/dexpB,
// + decW/decB/drW/drB/dnoG/dnoB/droW/droB/dembed.
fn gen_bwd(dlogits: int, tokens: int, embed: int, ecW: int,
           trunkW: int, trunkB: int, trunkG: int, trunkBe: int, rW: int, expW: int, noG: int, roW: int,
           xe: int, xtrunk: int, tin: int,
           eo: int, probs: int, ex: int, yn: int, xhN: int, ivN: int,
           dembed: int, decW: int, decB: int,
           dtrunkW: int, dtrunkB: int, dtrunkG: int, dtrunkBe: int,
           drW: int, drB: int, dexpW: int, dexpB: int, dnoG: int, dnoB: int, droW: int, droB: int,
           T: int, d: int, E: int, V: int, K: int, L: int) {
    let dd = d * d * K
    let dynorm = t_zeros(T * d)
    conv1d_bwd_via_forge(yn, roW, dlogits, droW, dynorm, droB, T, d, V, 1, 1)
    let dy = t_zeros(T * d)
    nn_groupnorm_bwd(xhN, ivN, noG, dynorm, dnoG, dnoB, dy, T, d, 1)
    let dlogits_r = t_zeros(T * E); let dex = t_zeros(E * T * d)
    nn_moe_router_bwd(probs, ex, dy, dlogits_r, dex, T, E, d)
    let dxr = t_zeros(T * d)
    conv1d_bwd_via_forge(xtrunk, rW, dlogits_r, drW, dxr, drB, T, d, E, 1, 1)
    // dx (grad wrt trunk output) = router + Σ experts
    let dx = t_zeros(T * d)
    let mut z = 0; while z < T * d { t_set(dx, z, t_get(dxr, z)); z = z + 1 }
    let wtmp = t_zeros(dd); let dwtmp = t_zeros(dd); let dexpe = t_zeros(T * d)
    let deo = t_zeros(T * d); let dxe_e = t_zeros(T * d); let dbtmp = t_zeros(d)
    let mut e = 0
    while e < E {
        let mut j = 0; while j < T * d { t_set(dexpe, j, t_get(dex, e * T * d + j)); j = j + 1 }
        _cp(eo, e * T * d, wtmp, T * d)              // reuse wtmp as eo-slice (size T*d ≤ dd ok? ensure)
        nn_gelu_bwd(wtmp, dexpe, deo, T * d)
        _cp(expW, e * dd, wtmp, dd)
        conv1d_bwd_via_forge(xtrunk, wtmp, deo, dwtmp, dxe_e, dbtmp, T, d, d, K, 1)
        _cpback(dwtmp, dexpW, e * dd, dd); _cpback(dbtmp, dexpB, e * d, d)
        let mut a = 0; while a < T * d { t_set(dx, a, t_get(dx, a) + t_get(dxe_e, a)); a = a + 1 }
        e = e + 1
    }
    // trunk reverse loop — ACTIVATION CHECKPOINTING.
    // The forward activations hn[l]/xh[l]/iv[l] are NOT cached. For each layer
    // we RECOMPUTE them from the cached layer input tin[l] (the checkpoint
    // boundary) by re-running the layer forward (conv_dil + groupnorm, the SAME
    // forward ops as gen_fwd), then feed the recomputed (hnl, xhl, invl) to the
    // existing bwd. Recompute is bit-identical to the forward value, so the
    // gradients are unchanged — only the [L·T·d] hn/xh and [L·d] iv caches go.
    let gtmp = t_zeros(d); let dgtmp = t_zeros(d); let dgetmp = t_zeros(d)
    let dhn = t_zeros(T * d); let dh = t_zeros(T * d); let hnl = t_zeros(T * d)
    let xhl = t_zeros(T * d); let invl = t_zeros(1); let tinl = t_zeros(T * d); let dconv_in = t_zeros(T * d)
    let btmp = t_zeros(d); let getmp = t_zeros(d)        // recompute param slices (conv bias, GN beta)
    let hrc = t_zeros(T * d); let meanrc = t_zeros(1)    // recompute scratch (conv out, GN mean)
    let mut l = L - 1
    while l >= 0 {
        _cp(tin, l * T * d, tinl, T * d)             // checkpoint: layer-l input
        // RECOMPUTE forward: conv_dil(tin[l]) → GN → (hnl=hn[l], xhl=xh[l], invl=iv[l]).
        _cp(trunkW, l * dd, wtmp, dd); _cp(trunkB, l * d, btmp, d)
        _cp(trunkG, l * d, gtmp, d);  _cp(trunkBe, l * d, getmp, d)
        conv1d_via_forge(tinl, wtmp, btmp, hrc, T, d, d, K, _pow2(l))
        nn_groupnorm_fwd(hrc, gtmp, getmp, hnl, meanrc, invl, xhl, T, d, 1)
        // now the original bwd chain, using the recomputed activations:
        // gelu_bwd(hn[l]) ; gn_bwd(xh[l],iv[l],trunkG[l]) ; conv_bwd(tin[l],trunkW[l])
        nn_gelu_bwd(hnl, dx, dhn, T * d)
        nn_groupnorm_bwd(xhl, invl, gtmp, dhn, dgtmp, dgetmp, dh, T, d, 1)
        _cpback(dgtmp, dtrunkG, l * d, d); _cpback(dgetmp, dtrunkBe, l * d, d)
        // forge backward (tinl/wtmp already prepared by the checkpoint recompute above)
        conv1d_bwd_via_forge(tinl, wtmp, dh, dwtmp, dconv_in, dbtmp, T, d, d, K, _pow2(l))
        _cpback(dwtmp, dtrunkW, l * dd, dd); _cpback(dbtmp, dtrunkB, l * d, d)
        // residual: dx(layer input) = dx(passthrough) + dconv_in
        let mut a = 0; while a < T * d { t_set(dx, a, t_get(dx, a) + t_get(dconv_in, a)); a = a + 1 }
        l = l - 1
    }
    // embed_conv bwd
    let dxe = t_zeros(T * d)
    conv1d_bwd_via_forge(xe, ecW, dx, decW, dxe, decB, T, d, d, K, 1)
    let mut zz = 0; while zz < V * d { t_set(dembed, zz, 0.0); zz = zz + 1 }
    nn_embedding_bwd_scatter(dxe, tokens, dembed, T, d)
}

fn _adam(W: int, gW: int, m: int, v: int, n: int, t: int) {
    opt_adamw_step(W, gW, m, v, n, 0.05, 0.9, 0.999, 0.00000001, 0.0, t)
}

fn main() {
    println("clm_large — CLMConvMoE LARGE rung d768/L12/E12 = 44.68M (real config run)")
    let T = 4; let d = 768; let E = 12; let V = 256; let K = 3; let L = 12
    let dd = d * d * K; let ed = E * d; let vd = V * d

    let tokens = t_zeros(T); t_set(tokens,0,3.0); t_set(tokens,1,14.0); t_set(tokens,2,59.0); t_set(tokens,3,26.0)
    let targets = t_zeros(T); t_set(targets,0,14.0); t_set(targets,1,59.0); t_set(targets,2,26.0); t_set(targets,3,7.0)

    let embed=t_zeros(vd); t_fill_lcg(embed, vd, 1, 0.3)
    let ecW=t_zeros(dd); t_fill_lcg(ecW, dd, 2, 0.2); let ecB=t_zeros(d); t_fill_lcg(ecB, d, 3, 0.1)
    let trunkW=t_zeros(L*dd); t_fill_lcg(trunkW, L*dd, 4, 0.2)
    let trunkB=t_zeros(L*d); t_fill_lcg(trunkB, L*d, 5, 0.1)
    let trunkG=t_zeros(L*d); t_fill_lcg(trunkG, L*d, 6, 0.5)
    let trunkBe=t_zeros(L*d); t_fill_lcg(trunkBe, L*d, 7, 0.1)
    let rW=t_zeros(ed); t_fill_lcg(rW, ed, 12, 0.2); let rB=t_zeros(E); t_fill_lcg(rB, E, 13, 0.1)
    let expW=t_zeros(E*dd); t_fill_lcg(expW, E*dd, 14, 0.2); let expB=t_zeros(E*d); t_fill_lcg(expB, E*d, 15, 0.1)
    let noG=t_zeros(d); t_fill_lcg(noG, d, 18, 0.5); let noB=t_zeros(d); t_fill_lcg(noB, d, 19, 0.1)
    let roW=t_zeros(vd); t_fill_lcg(roW, vd, 20, 0.2); let roB=t_zeros(V); t_fill_lcg(roB, V, 21, 0.1)

    // grads
    let dembed=t_zeros(vd); let decW=t_zeros(dd); let decB=t_zeros(d)
    let dtrunkW=t_zeros(L*dd); let dtrunkB=t_zeros(L*d); let dtrunkG=t_zeros(L*d); let dtrunkBe=t_zeros(L*d)
    let drW=t_zeros(ed); let drB=t_zeros(E); let dexpW=t_zeros(E*dd); let dexpB=t_zeros(E*d)
    let dnoG=t_zeros(d); let dnoB=t_zeros(d); let droW=t_zeros(vd); let droB=t_zeros(V)
    // adam state
    let m_embed=t_zeros(vd); let v_embed=t_zeros(vd); let m_ecW=t_zeros(dd); let v_ecW=t_zeros(dd)
    let m_ecB=t_zeros(d); let v_ecB=t_zeros(d)
    let m_tW=t_zeros(L*dd); let v_tW=t_zeros(L*dd); let m_tB=t_zeros(L*d); let v_tB=t_zeros(L*d)
    let m_tG=t_zeros(L*d); let v_tG=t_zeros(L*d); let m_tBe=t_zeros(L*d); let v_tBe=t_zeros(L*d)
    let m_rW=t_zeros(ed); let v_rW=t_zeros(ed); let m_rB=t_zeros(E); let v_rB=t_zeros(E)
    let m_eW=t_zeros(E*dd); let v_eW=t_zeros(E*dd); let m_eB=t_zeros(E*d); let v_eB=t_zeros(E*d)
    let m_noG=t_zeros(d); let v_noG=t_zeros(d); let m_noB=t_zeros(d); let v_noB=t_zeros(d)
    let m_roW=t_zeros(vd); let v_roW=t_zeros(vd); let m_roB=t_zeros(V); let v_roB=t_zeros(V)
    // caches — activation checkpointing: trunk keeps only tin[L·T·d] (the
    // per-layer input / checkpoint boundary). hn/xh/iv are NOT allocated;
    // gen_bwd recomputes them from tin[l]. Trunk activation cache: was
    // 2·[L·T·d] + [L·d] (hn,xh,iv) on top of tin → now just tin[L·T·d].
    let xe=t_zeros(T*d); let xtrunk=t_zeros(T*d); let tin=t_zeros(L*T*d)
    let eo=t_zeros(E*T*d); let probs=t_zeros(T*E)
    let ex=t_zeros(E*T*d); let yn=t_zeros(T*d); let xhN=t_zeros(T*d); let ivN=t_zeros(1)
    let logits=t_zeros(T*V); let dlogits=t_zeros(T*V)

    let nparams = V*d + dd + d + L*dd + L*d + L*d + L*d + ed + E + E*dd + E*d + d + d + vd + V
    println("  n_params = " + to_string(nparams) + " (expect 44,678,668 for d768/L12/E12)")
    // activation-cache memory delta report (the mem-Δ falsifier half):
    let trunk_cache_old = L*T*d + L*T*d + L*T*d + L   // tin + hn + xh + iv (pre-ckpt)
    let trunk_cache_new = L*T*d                       // tin only (post-ckpt)
    println("  trunk activation cache (floats): old=" + to_string(trunk_cache_old) + " new=" + to_string(trunk_cache_new) + " (L=" + to_string(L) + " T=" + to_string(T) + " d=" + to_string(d) + ")")
    println("  ACTIVATION-CKPT: trunk cache 3·[L·T·d]+[L·d] -> [L·T·d]  (O(L) hn/xh/iv dropped, recomputed from tin)")
    let steps = 4
    let mut loss0=0.0; let mut lossF=0.0; let mut step=1
    while step <= steps {
        gen_fwd(tokens, embed, ecW, ecB, trunkW, trunkB, trunkG, trunkBe, rW, rB, expW, expB, noG, noB, roW, roB,
                xe, xtrunk, tin, eo, probs, ex, yn, xhN, ivN, logits, T, d, E, V, K, L)
        let loss = nn_ce_loss_allpos(logits, targets, T, V)
        if step == 1 { loss0 = loss; println("  step 1  CE = " + to_string(loss)) }
        if step == 13 { println("  step 13 CE = " + to_string(loss)) }
        lossF = loss
        gen_ce_grad(logits, targets, dlogits, T, V)
        gen_bwd(dlogits, tokens, embed, ecW, trunkW, trunkB, trunkG, trunkBe, rW, expW, noG, roW,
                xe, xtrunk, tin, eo, probs, ex, yn, xhN, ivN,
                dembed, decW, decB, dtrunkW, dtrunkB, dtrunkG, dtrunkBe, drW, drB, dexpW, dexpB,
                dnoG, dnoB, droW, droB, T, d, E, V, K, L)
        _adam(embed, dembed, m_embed, v_embed, vd, step)
        _adam(ecW, decW, m_ecW, v_ecW, dd, step); _adam(ecB, decB, m_ecB, v_ecB, d, step)
        _adam(trunkW, dtrunkW, m_tW, v_tW, L*dd, step); _adam(trunkB, dtrunkB, m_tB, v_tB, L*d, step)
        _adam(trunkG, dtrunkG, m_tG, v_tG, L*d, step); _adam(trunkBe, dtrunkBe, m_tBe, v_tBe, L*d, step)
        _adam(rW, drW, m_rW, v_rW, ed, step); _adam(rB, drB, m_rB, v_rB, E, step)
        _adam(expW, dexpW, m_eW, v_eW, E*dd, step); _adam(expB, dexpB, m_eB, v_eB, E*d, step)
        _adam(noG, dnoG, m_noG, v_noG, d, step); _adam(noB, dnoB, m_noB, v_noB, d, step)
        _adam(roW, droW, m_roW, v_roW, vd, step); _adam(roB, droB, m_roB, v_roB, V, step)
        step = step + 1
    }
    println("  step " + to_string(steps) + " CE = " + to_string(lossF))
    println("  loss0 = " + to_string(loss0) + "  lossF = " + to_string(lossF))
    if lossF < loss0 * 0.95 {
        println("F-FLAME-CLM-LARGE-RUN = 1")
        println("PASS — LARGE rung (44.68M) builds + trains + descends on hexa-native stack")
        return
    }
    println("F-FLAME-CLM-LARGE-RUN = 0")
    println("FAIL")
}
