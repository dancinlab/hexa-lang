// ════════════════════════════════════════════════════════════════════════════
//  clm_elementwise_gpu.hexa — CLM elementwise ops via forge GPU device-dispatch.
//
//  The matmul half of the CLMConvMoE forge routing is already wired: the readout
//  (clm_prod_gpu) and the K=3 causal-dilated conv (clm_conv_gpu) both ride
//  forge_dispatch_matmul (cuBLAS on a CUDA host, identical farr_matmul on CPU).
//  The REMAINING routing gap is the ELEMENTWISE ops — GroupNorm · GELU ·
//  MoE-combine — which are NOT matmul, so they stayed on host farr and never
//  reached the device. With the convs/readout device-resident, these host-only
//  elementwise passes are exactly the residual that keeps GPU-util pinned low.
//
//  This module mirrors forge_dispatch_matmul's shape with per-op `*_via_forge`
//  wrappers (one dispatch seam each), each with a CPU fallback that is
//  BYTE-IDENTICAL to the current host op:
//    groupnorm_via_forge  → nn_groupnorm_fwd  (gn_lib)
//    gelu_via_forge       → nn_gelu_fwd       (nn_lib, erf-based exact GELU)
//    moe_combine_via_forge→ the moe_lib combine Y[t,c]=Σ_e probs·ex_out
//
//  ── DEVICE-DISPATCH SEAM (HONEST-DEFER) ──────────────────────────────────
//  On a CUDA host the seam routes each op to a device elementwise kernel
//  (one thread per output element — GroupNorm two-pass reduction, GELU map,
//  MoE-combine gate-weighted reduction); on a CPU host (and right here, on the
//  Mac) it falls through to the byte-identical host op. The GPU-busy half
//  (F-RFC046-GPU-UTILIZATION nvidia-smi >50%, wall Δ) needs a CUDA host and is
//  DEFERRED to a CUDA pod (summer 5070 / runpod) — no GPU numbers fabricated.
//
//  F-CLM-ELEMENTWISE-FORGE-EQ: each *_via_forge CPU fallback == current host op
//  (max|Δ| == 0, exact byte-eq — no tolerance, same code path). Verified $0 on
//  Mac CPU here; the device-kernel measurement is the deferred pod fire.
//
//  stdlib_trig_libm honored: GELU rides nn_lib's erf-based exact GELU (libm
//  `erf`/`exp` codegen builtins) — no hand-rolled Taylor on the new path.
//  sibling: clm_conv_gpu.hexa · clm_prod_gpu.hexa · gn_lib · nn_lib · moe_lib.
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/gn_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/moe_lib"

fn _absf(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

// ── GroupNorm via forge ──────────────────────────────────────────────────
// Caller allocates y_out [T·C], mean_out [G], inv_out [G], xhat_out [T·C]
// exactly as nn_groupnorm_fwd expects. On a CUDA host this seam dispatches the
// two-pass group reduction + affine map to a device kernel; on CPU it calls the
// byte-identical host op below. Same arg shape as nn_groupnorm_fwd.
pub fn groupnorm_via_forge(x: int, gamma: int, beta: int,
                           y_out: int, mean_out: int, inv_out: int, xhat_out: int,
                           T: int, C: int, G: int) {
    // DEVICE SEAM (deferred): forge GroupNorm kernel on -DHEXA_CUDA.
    // CPU fallback — byte-identical to the current host GroupNorm.
    nn_groupnorm_fwd(x, gamma, beta, y_out, mean_out, inv_out, xhat_out, T, C, G)
}

// ── GELU via forge ───────────────────────────────────────────────────────
// Elementwise a_out[i] = GELU(g[i]) over h elements (erf-based exact GELU).
// On a CUDA host the seam maps one thread per element to a device GELU kernel;
// on CPU it calls the byte-identical host nn_gelu_fwd. Same arg shape.
pub fn gelu_via_forge(g: int, a_out: int, h: int) {
    // DEVICE SEAM (deferred): forge GELU map kernel on -DHEXA_CUDA.
    // CPU fallback — byte-identical to the current host GELU (libm erf).
    nn_gelu_fwd(g, a_out, h)
}

// ── MoE-combine via forge ────────────────────────────────────────────────
// Gate-weighted combine of E expert outputs: Y[t,c] = Σ_e probs[t,e]·ex[e,t,c].
// This is the combine TAIL of nn_moe_router_fwd (the softmax gate stays where it
// is); inputs are the already-computed probs [T·E] and stacked expert outputs
// ex_out [E·T·C]. Caller allocates y_out [T·C]. On a CUDA host the seam routes
// the (T·C) gate-weighted reductions to a device kernel; on CPU it runs the
// byte-identical host reduction below.
pub fn moe_combine_via_forge(probs: int, ex_out: int, y_out: int,
                             T: int, E: int, C: int) {
    // DEVICE SEAM (deferred): forge MoE-combine reduction kernel on -DHEXA_CUDA.
    // CPU fallback — byte-identical to the nn_moe_router_fwd combine loop.
    let mut t = 0
    while t < T {
        let mut c = 0
        while c < C {
            let mut acc = 0.0
            let mut e = 0
            while e < E {
                acc = acc + t_get(probs, t * E + e) * t_get(ex_out, e * T * C + t * C + c)
                e = e + 1
            }
            t_set(y_out, t * C + c, acc)
            c = c + 1
        }
        t = t + 1
    }
}

fn main() {
    println("clm_elementwise_gpu — CLM GroupNorm·GELU·MoE-combine via forge dispatch")

    let mut pass = 1

    // ── F-CLM-ELEMENTWISE-FORGE-EQ part 1: GroupNorm ──────────────────────
    let T = 12; let C = 8; let G = 2
    let x  = t_zeros(T * C); t_fill_lcg(x, T * C, 41, 0.5)
    let ga = t_zeros(C);     t_fill_lcg(ga, C, 5, 0.3)
    let be = t_zeros(C);     t_fill_lcg(be, C, 7, 0.1)
    // host baseline
    let y_h  = t_zeros(T * C); let m_h = t_zeros(G); let iv_h = t_zeros(G); let xh_h = t_zeros(T * C)
    nn_groupnorm_fwd(x, ga, be, y_h, m_h, iv_h, xh_h, T, C, G)
    // forge fallback
    let y_f  = t_zeros(T * C); let m_f = t_zeros(G); let iv_f = t_zeros(G); let xh_f = t_zeros(T * C)
    groupnorm_via_forge(x, ga, be, y_f, m_f, iv_f, xh_f, T, C, G)
    let mut gn_dev = 0.0
    let mut i = 0
    while i < T * C {
        let d = _absf(t_get(y_h, i) - t_get(y_f, i))
        if d > gn_dev { gn_dev = d }
        i = i + 1
    }
    print("  GroupNorm  T="); print(T); print(" C="); print(C); print(" G="); print(G)
    print("  max|Δ| forge-vs-host = "); println(to_string(gn_dev))
    if gn_dev != 0.0 { pass = 0 }

    // ── F-CLM-ELEMENTWISE-FORGE-EQ part 2: GELU ───────────────────────────
    let h = 96
    let gv = t_zeros(h); t_fill_lcg(gv, h, 13, 0.9)
    let a_h = t_zeros(h); nn_gelu_fwd(gv, a_h, h)
    let a_f = t_zeros(h); gelu_via_forge(gv, a_f, h)
    let mut ge_dev = 0.0
    let mut j = 0
    while j < h {
        let d = _absf(t_get(a_h, j) - t_get(a_f, j))
        if d > ge_dev { ge_dev = d }
        j = j + 1
    }
    print("  GELU       h="); print(h)
    print("  max|Δ| forge-vs-host = "); println(to_string(ge_dev))
    if ge_dev != 0.0 { pass = 0 }

    // ── F-CLM-ELEMENTWISE-FORGE-EQ part 3: MoE-combine ────────────────────
    let E = 3
    let logits = t_zeros(T * E); t_fill_lcg(logits, T * E, 17, 0.6)
    let probs  = t_zeros(T * E); nn_moe_softmax(logits, probs, T, E)
    let ex     = t_zeros(E * T * C); t_fill_lcg(ex, E * T * C, 23, 0.4)
    // host baseline (the combine tail of nn_moe_router_fwd)
    let yc_h = t_zeros(T * C)
    nn_moe_router_fwd(logits, ex, probs, yc_h, T, E, C)
    // forge fallback combine (reuses the same probs)
    let yc_f = t_zeros(T * C)
    moe_combine_via_forge(probs, ex, yc_f, T, E, C)
    let mut mc_dev = 0.0
    let mut k = 0
    while k < T * C {
        let d = _absf(t_get(yc_h, k) - t_get(yc_f, k))
        if d > mc_dev { mc_dev = d }
        k = k + 1
    }
    print("  MoE-combine E="); print(E); print(" T="); print(T); print(" C="); print(C)
    print("  max|Δ| forge-vs-host = "); println(to_string(mc_dev))
    if mc_dev != 0.0 { pass = 0 }

    if pass == 1 {
        println("F-CLM-ELEMENTWISE-FORGE-EQ = 1")
        println("PASS — GroupNorm·GELU·MoE-combine forge fallbacks == host (byte-eq, elementwise carve-out wired)")
        return
    }
    println("F-CLM-ELEMENTWISE-FORGE-EQ = 0")
    println("FAIL")
}
