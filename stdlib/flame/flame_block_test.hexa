// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_block_test.hexa — flame Phase 3-B selftest
//
// Falsifiers (RFC 043 §Verification):
//   F-RFC043-BLOCK-DET     two seed-fixed fwd 의 Xout byte-identical
//                          (compiler-only determinism — Phase 1 와 동일
//                           anchor; functional layer 의 기본 sanity)
//   F-RFC043-BLOCK-GRAD-EXACT
//                          central finite-difference vs nn_decoder_
//                          block_bwd 의 analytic ∂L/∂θ. L = ½·Σ Xout².
//                          이건 캠페인의 d_corpus_fire 가 사용한 동일
//                          GRAD-EXACT(L0.Wg[5]) 패턴 — 모든 sub-piece
//                          (RMSNorm·Q/K/V proj·RoPE·attn-core·Wo·
//                           residual·RMSNorm·SwiGLU·residual)의 vjp
//                          composition 이 한 발에 검증된다. relative
//                          tolerance ~1e-3 (central-diff ε=1e-4 의
//                          typical floor).
//
// Test config (작지만 모든 dim 비대칭):
//   T=3, d=8, nh=2, nkv=1 → hd=4, kvd=4, n_rep=2, h=12
//   bp_total = 2·8 + 2·64 + 2·4·8 + 3·12·8 = 16+128+64+288 = 496
//   bc_total = 8·24 + 2·12 + 2·9 + 3·36 + 2·3 = 192+24+18+108+6 = 348
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/autograd_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/decoder_block_lib"

fn _bk_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_dev_farr_bk(a: int, b: int, n: int) -> float {
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let d = _bk_abs(t_get(a, i) - t_get(b, i))
        if d > m { m = d }
        i = i + 1
    }
    return m
}

// L(X, Bp) = ½ · Σ Xout²   (scalar loss after one block fwd)
// dL/dXout = Xout  (so analytic dXout = Xout)
fn _bk_loss_from_Xout(Bc: int, T: int, d: int, nh: int, nkv: int, h: int) -> float {
    let oXout = bc_off_Xout(T, d, nh, nkv, h)
    let mut s = 0.0
    let mut i = 0
    while i < T * d {
        let xo = farr_get(Bc, oXout + i)
        s = s + 0.5 * xo * xo
        i = i + 1
    }
    return s
}

// Build RoPE tables (T positions, head_dim hd). Same path as
// nn_rope_build_tables (already byte-eq verified in Phase 2).
fn _bk_rope_tables(T: int, hd: int, cos_out: int, sin_out: int) {
    nn_rope_build_tables(T, hd, cos_out, sin_out)
}

// Run one fwd + scalar loss; returns L = ½·Σ Xout².
fn _bk_fwd_loss(X: int, Bp: int, cos: int, sin: int,
                T: int, d: int, nh: int, nkv: int, h: int) -> float {
    let bc_size = bc_total(T, d, nh, nkv, h)
    let Bc = t_zeros(bc_size)
    nn_decoder_block_fwd(X, Bp, Bc, cos, sin, T, d, nh, nkv, h)
    let L = _bk_loss_from_Xout(Bc, T, d, nh, nkv, h)
    let _ = t_free(Bc)
    return L
}

// ── F-RFC043-BLOCK-DET ────────────────────────────────────────────────
fn check_block_determinism() -> float {
    let T = 3
    let d = 8
    let nh = 2
    let nkv = 1
    let h = 12
    let hd = d / nh

    let X = t_zeros(T * d);  t_fill_lcg(X, T*d, 42, 0.5)
    let bp_size = bp_total(d, nh, nkv, h)
    let Bp = t_zeros(bp_size); t_fill_lcg(Bp, bp_size, 1234, 0.2)
    let cos = t_zeros(T * hd); let sin = t_zeros(T * hd)
    _bk_rope_tables(T, hd, cos, sin)

    let bc_size = bc_total(T, d, nh, nkv, h)
    let Bc1 = t_zeros(bc_size); let Bc2 = t_zeros(bc_size)
    nn_decoder_block_fwd(X, Bp, Bc1, cos, sin, T, d, nh, nkv, h)
    nn_decoder_block_fwd(X, Bp, Bc2, cos, sin, T, d, nh, nkv, h)
    let oXout = bc_off_Xout(T, d, nh, nkv, h)
    // compare Xout slices only
    let mut m = 0.0
    let mut i = 0
    while i < T * d {
        let d_ = _bk_abs(t_get(Bc1, oXout + i) - t_get(Bc2, oXout + i))
        if d_ > m { m = d_ }
        i = i + 1
    }
    let _ = t_free(X); let _ = t_free(Bp); let _ = t_free(cos); let _ = t_free(sin)
    let _ = t_free(Bc1); let _ = t_free(Bc2)
    return m
}

// ── F-RFC043-BLOCK-GRAD-EXACT ─────────────────────────────────────────
// central diff for parameter Bp[probe_idx]:
//   ∂L/∂Bp[probe_idx] ≈ (L(Bp + ε·e) − L(Bp − ε·e)) / (2ε)
// analytic: nn_decoder_block_bwd with dXout = Xout (since L=½ Σ Xout²).
fn check_block_grad_exact() -> int {
    let T = 3
    let d = 8
    let nh = 2
    let nkv = 1
    let h = 12
    let hd = d / nh

    let X = t_zeros(T * d);  t_fill_lcg(X, T*d, 42, 0.5)
    let bp_size = bp_total(d, nh, nkv, h)
    let Bp = t_zeros(bp_size); t_fill_lcg(Bp, bp_size, 1234, 0.2)
    let cos = t_zeros(T * hd); let sin = t_zeros(T * hd)
    _bk_rope_tables(T, hd, cos, sin)

    // analytic gradient
    let bc_size = bc_total(T, d, nh, nkv, h)
    let Bc = t_zeros(bc_size)
    nn_decoder_block_fwd(X, Bp, Bc, cos, sin, T, d, nh, nkv, h)
    let oXout = bc_off_Xout(T, d, nh, nkv, h)
    // dXout = Xout
    let dXout = t_zeros(T * d)
    let mut i_dx = 0
    while i_dx < T * d {
        t_set(dXout, i_dx, t_get(Bc, oXout + i_dx))
        i_dx = i_dx + 1
    }
    let Bg = t_zeros(bp_size)
    let dX = t_zeros(T * d)
    nn_decoder_block_bwd(X, Bp, Bc, dXout, dX, Bg, cos, sin,
                         T, d, nh, nkv, h)

    // central-diff check at a handful of parameter indices spread across
    // every weight block (g1, Wq, Wk, Wv, Wo, g2, Wg, Wu, Wd).
    let probes = t_zeros(9)
    t_set(probes, 0, to_float(bp_off_g1(d, nh, nkv, h) + 3))
    t_set(probes, 1, to_float(bp_off_Wq(d, nh, nkv, h) + 17))
    t_set(probes, 2, to_float(bp_off_Wk(d, nh, nkv, h) + 5))
    t_set(probes, 3, to_float(bp_off_Wv(d, nh, nkv, h) + 11))
    t_set(probes, 4, to_float(bp_off_Wo(d, nh, nkv, h) + 23))
    t_set(probes, 5, to_float(bp_off_g2(d, nh, nkv, h) + 2))
    t_set(probes, 6, to_float(bp_off_Wg(d, nh, nkv, h) + 31))
    t_set(probes, 7, to_float(bp_off_Wu(d, nh, nkv, h) + 19))
    t_set(probes, 8, to_float(bp_off_Wd(d, nh, nkv, h) + 7))

    let eps = 0.0001
    let mut max_rel = 0.0
    let mut k = 0
    while k < 9 {
        let probe_idx = to_int(t_get(probes, k))
        let analytic = t_get(Bg, probe_idx)
        // L(Bp + ε·e)
        let orig = t_get(Bp, probe_idx)
        t_set(Bp, probe_idx, orig + eps)
        let L_plus = _bk_fwd_loss(X, Bp, cos, sin, T, d, nh, nkv, h)
        // L(Bp − ε·e)
        t_set(Bp, probe_idx, orig - eps)
        let L_minus = _bk_fwd_loss(X, Bp, cos, sin, T, d, nh, nkv, h)
        t_set(Bp, probe_idx, orig)
        let fd = (L_plus - L_minus) / (2.0 * eps)
        // relative deviation; if analytic is tiny, use absolute.
        let denom = if _bk_abs(analytic) > 0.01 { _bk_abs(analytic) } else { 0.01 }
        let rel = _bk_abs(analytic - fd) / denom
        if rel > max_rel { max_rel = rel }
        k = k + 1
    }

    let _ = t_free(X); let _ = t_free(Bp); let _ = t_free(cos); let _ = t_free(sin)
    let _ = t_free(Bc); let _ = t_free(dXout); let _ = t_free(Bg); let _ = t_free(dX)
    let _ = t_free(probes)

    let out = t_zeros(1)
    t_set(out, 0, max_rel)
    return out
}

// ── entrypoint ─────────────────────────────────────────────────────────
println("=== flame Phase 3-B selftest (decoder_block_lib: composed fwd+bwd, compiled-native) ===")

let mut pass = 0
let total = 2

// ── Determinism ────────────────────────────────────────────────────────
let det_dev = check_block_determinism()
if det_dev == 0.0 {
    println("PASS  F-RFC043-BLOCK-DET         two fwd Xout byte-identical (max|Δ| = 0.0; compiler-only determinism)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-BLOCK-DET         dev = "); print(det_dev); println("")
}

// ── GRAD-EXACT central-diff ───────────────────────────────────────────
let ge = check_block_grad_exact()
let ge_max_rel = t_get(ge, 0)
let _ = t_free(ge)
if ge_max_rel < 0.001 {
    print("PASS  F-RFC043-BLOCK-GRAD-EXACT  9 probes (g1·Wq·Wk·Wv·Wo·g2·Wg·Wu·Wd) max|analytic − fd|/scale = ")
    print(ge_max_rel)
    println(" < 1e-3 (closed composition vjp ≡ central-diff; ε=1e-4)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC043-BLOCK-GRAD-EXACT  max rel = "); print(ge_max_rel); println(" (>1e-3)")
}

println("")
print("=== flame Phase 3-B: ")
print(pass)
print("/")
print(total)
println(" PASS ===")
if pass == total {
    println("PASS — flame decoder_block_lib (single layer composition) GRAD-EXACT against central-diff at 9 probe sites covering every weight block. Phase 3-C (decoder_lib + train_lib + 80-step trajectory) next.")
} else {
    println("FAIL — flame Phase 3-B not landable")
}
