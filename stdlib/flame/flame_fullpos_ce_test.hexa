// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_fullpos_ce_test.hexa — INBOX #2 P1① full-position CE
//
// The decoder forward (decoder_lib::nn_decoder_fwd) projects ONLY the last
// position and nn_decoder_ce_loss reads that single V-wide logit row. The
// anima ConsciousDecoderV3 training stack supervises every position, so the
// loss must average CE over all T positions. nn_lib gains two minimal
// functional helpers:
//   nn_lm_head_fwd_allpos(temb, Z, logits_out, T, V, d)   [T·V] logits
//   nn_ce_loss_allpos(logits, targets, T, V)              mean CE over T
//
// Falsifiers (cheap CPU oracle, no GPU):
//
//   F-FLAME-FULLPOS-CE-HAND     nn_ce_loss_allpos on a hand-set [T·V=3·4]
//                               logit grid matches a BY-HAND mean-CE oracle.
//                               Config: T=3, V=4
//                                 t=0 logits [1,0,0,0] tgt 0
//                                 t=1 logits [0,2,0,0] tgt 1
//                                 t=2 logits [0,0,0,3] tgt 3
//                               libm oracle (python, FP_CONTRACT-free):
//                                 c0=ln(e+3)−1   = 0.743668380628679
//                                 c1=ln(e²+3)−2  = 0.340752953913131
//                                 c2=ln(e³+3)−3  = 0.139206314219457
//                                 mean           = 0.407875882920422
//                               flame uses dt_exp/dt_ln (NOT libm) — the
//                               byte-eq hazard means flame ≠ libm at the
//                               last ulps. Gate = |flame − libm| < 1e-6
//                               (dt_* series accuracy; documented tol).
//
//   F-FLAME-FULLPOS-HEAD-ROWEQ  each row t of nn_lm_head_fwd_allpos matches
//                               the existing single-position nn_lm_head_fwd
//                               applied to Z[t·d .. t·d+d]. The allpos head
//                               reduces hexa-scalar; nn_lm_head_fwd reduces
//                               via farr_matmul (FMA-fused C). Per RFC 040
//                               §2.2 these differ at the last ulp (the SAME
//                               FMA-vs-scalar gap flame_nn_test gates
//                               nn_lm_head_fwd at < 1e-12, not == 0). Gate =
//                               < 1e-12. Proves the full-position head is a
//                               faithful per-position replication.
//
//   F-FLAME-FULLPOS-CE-T1-EQ    with T=1 the full-position mean-CE reduces
//                               EXACTLY to the single-position CE formula
//                               (-ln(softmax(logits)[tgt]) with the same
//                               stable-softmax + pt_safe floor). byte-eq.
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/flame_math"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// In-file single-position CE reference (mirrors nn_decoder_ce_loss exactly,
// dt_exp/dt_ln + pt_safe floor). Reads logits[base .. base+V].
fn ref_ce_one(logits: int, base: int, V: int, tgt: int) -> float {
    let mut mx = farr_get(logits, base)
    let mut i = 1
    while i < V {
        if farr_get(logits, base + i) > mx { mx = farr_get(logits, base + i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < V {
        tot = tot + dt_exp(farr_get(logits, base + i2) - mx)
        i2 = i2 + 1
    }
    let p_t = dt_exp(farr_get(logits, base + tgt) - mx) / tot
    let pt_safe = if p_t < 0.000001 { 0.000001 } else { p_t }
    return 0.0 - dt_ln(pt_safe)
}

println("=== flame INBOX #2 P1① full-position CE selftest (CPU oracle, no GPU) ===")

let mut pass = 0
let total = 3

// ── F-FLAME-FULLPOS-CE-HAND ─────────────────────────────────────────────
// hand-set [T·V] grid, mean-CE vs by-hand libm oracle.
let T = 3
let V = 4
let logits = t_zeros(T * V)
// t=0 → [1,0,0,0]
t_set(logits, 0 * V + 0, 1.0)
// t=1 → [0,2,0,0]
t_set(logits, 1 * V + 1, 2.0)
// t=2 → [0,0,0,3]
t_set(logits, 2 * V + 3, 3.0)
let targets = t_zeros(T)
t_set(targets, 0, 0.0)
t_set(targets, 1, 1.0)
t_set(targets, 2, 3.0)

let ce_flame = nn_ce_loss_allpos(logits, targets, T, V)
let ce_libm_oracle = 0.407875882920422
let ce_dev = nn_abs(ce_flame - ce_libm_oracle)

print("      hand-oracle mean-CE (libm) = "); println(ce_libm_oracle)
print("      flame nn_ce_loss_allpos     = "); println(ce_flame)
print("      |flame − libm oracle|       = "); println(ce_dev)

if ce_dev < 0.000001 {
    println("PASS  F-FLAME-FULLPOS-CE-HAND       |nn_ce_loss_allpos − by-hand libm mean-CE| < 1e-6 (dt_exp/dt_ln series tol; T=3·V=4)")
    pass = pass + 1
} else {
    print("FAIL  F-FLAME-FULLPOS-CE-HAND       |Δ|="); print(ce_dev); println(" (>1e-6)")
}

// ── F-FLAME-FULLPOS-HEAD-ROWEQ ──────────────────────────────────────────
// nn_lm_head_fwd_allpos row t ≡ nn_lm_head_fwd on Z[t·d..].  byte-eq.
let Vh = 5
let dh = 3
let Th = 4
let temb = t_zeros(Vh * dh)
// deterministic fill (LCG-ish, in-file so test is self-contained)
let mut s = 1234567
let mut fi = 0
while fi < Vh * dh {
    s = (s * 1103515245 + 12345) % 2147483648
    t_set(temb, fi, (to_float(s) / 2147483648.0) - 0.5)
    fi = fi + 1
}
let Z = t_zeros(Th * dh)
let mut zi = 0
while zi < Th * dh {
    s = (s * 1103515245 + 12345) % 2147483648
    t_set(Z, zi, (to_float(s) / 2147483648.0) - 0.5)
    zi = zi + 1
}

let logits_all = t_zeros(Th * Vh)
nn_lm_head_fwd_allpos(temb, Z, logits_all, Th, Vh, dh)

// per-row reference: slice Z[t·d..] into a d-vec, run nn_lm_head_fwd.
let mut row_dev = 0.0
let mut t = 0
while t < Th {
    let zT = t_zeros(dh)
    let mut c = 0
    while c < dh {
        t_set(zT, c, t_get(Z, t * dh + c))
        c = c + 1
    }
    let row_ref = t_zeros(Vh)
    nn_lm_head_fwd(temb, zT, row_ref, Vh, dh)
    let mut k = 0
    while k < Vh {
        let dv = nn_abs(t_get(logits_all, t * Vh + k) - t_get(row_ref, k))
        if dv > row_dev { row_dev = dv }
        k = k + 1
    }
    t_free(zT)
    t_free(row_ref)
    t = t + 1
}
print("      max|allpos-head row − single-pos head| = "); println(row_dev)
// RFC 040 §2.2 fp-tol: allpos head reduces hexa-scalar, nn_lm_head_fwd
// reduces via FMA-fused farr_matmul — last-ulp gap, SAME tol flame_nn_test
// uses for nn_lm_head_fwd (< 1e-12).
if row_dev < 0.000000000001 {
    println("PASS  F-FLAME-FULLPOS-HEAD-ROWEQ    max|nn_lm_head_fwd_allpos[t] − nn_lm_head_fwd(Z[t])| < 1e-12 (RFC 040 §2.2 fp-tol; FMA-vs-scalar last-ulp)")
    pass = pass + 1
} else {
    print("FAIL  F-FLAME-FULLPOS-HEAD-ROWEQ    max|Δ|="); print(row_dev); println(" (>1e-12)")
}

// ── F-FLAME-FULLPOS-CE-T1-EQ ────────────────────────────────────────────
// T=1: full-position mean-CE ≡ single-position CE (byte-eq).
let V1 = 4
let logits1 = t_zeros(V1)
t_set(logits1, 0, 0.5)
t_set(logits1, 1, 1.5)
t_set(logits1, 2, 0.0 - 0.5)
t_set(logits1, 3, 0.25)
let targets1 = t_zeros(1)
t_set(targets1, 0, 2.0)
let ce_t1_allpos = nn_ce_loss_allpos(logits1, targets1, 1, V1)
let ce_t1_ref = ref_ce_one(logits1, 0, V1, 2)
let t1_dev = nn_abs(ce_t1_allpos - ce_t1_ref)
print("      T=1 allpos-CE = "); println(ce_t1_allpos)
print("      T=1 single-CE = "); println(ce_t1_ref)
if t1_dev == 0.0 {
    println("PASS  F-FLAME-FULLPOS-CE-T1-EQ      nn_ce_loss_allpos(T=1) ≡ single-position CE = 0.0 (byte-eq · reduces to last-pos)")
    pass = pass + 1
} else {
    print("FAIL  F-FLAME-FULLPOS-CE-T1-EQ      |Δ|="); print(t1_dev); println(" (≠0)")
}

t_free(logits); t_free(targets)
t_free(temb); t_free(Z); t_free(logits_all)
t_free(logits1); t_free(targets1)

print("=== ")
print(pass)
print("/")
print(total)
println(" PASS ===")
