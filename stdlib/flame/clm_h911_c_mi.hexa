// F-CLM-H911-MI driver — direct cross-lingual mutual information vs Φ-proxy.
use "stdlib/flame/clm_h911_bc_mechanisms"

fn main() {
    println("clm_h911_C — F-CLM-H911-MI (direct cross-lingual MI estimate)")
    let FP = t_zeros(NLINE * D); let FC = t_zeros(NLINE * D)
    build_feats("stdlib/flame/testdata/clm_semantic_parallel.txt", FP)
    build_feats("stdlib/flame/testdata/clm_semantic_concat.txt", FC)
    let lam = 0.5
    let diffs = t_zeros(NCONC)
    let mut c = 0
    while c < NCONC {
        let bp = mi_binding(FP, 0, c, lam)
        let bc = mi_binding(FC, 1, c, lam)
        t_set(diffs, c, bp - bc)
        print("  concept "); print(to_string(c)); print(": MI par="); print(to_string(bp))
        print(" con="); print(to_string(bc)); print(" diff="); println(to_string(bp - bc))
        c = c + 1
    }
    report("MI", "F-CLM-H911-MI", diffs, NCONC)
}
