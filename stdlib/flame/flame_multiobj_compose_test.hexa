// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_multiobj_compose_test.hexa — RFC 059 §5/§7 P1②-c
//
// Multi-objective backward COMPOSITION — the FINAL stage of P1② (the full
// V3-extension backward). P1②-a (#1489) wired full-position CE → head
// backward; P1②-b (#1491) added the 4-op backward (head_g / cross-L_ψ /
// tension-L_route / purefield). This stage COMPOSES them into ONE backward.
//
// Per RFC 059 §5 the composition needs ZERO new stdlib code (g0 / Occam):
// each loss-layer seed helper (ag_ce_*_seed, ag_cross_psi_seed,
// ag_tension_route_seed) ALREADY multiplies its own λ weight in AND calls
// ag_seed_grad to pre-seed the registry WITHOUT walking the tape. So a
// composite loss is built by calling each seed helper, then a SINGLE
// ag_backward_reg walk — backward's seed-linearity (vjp is linear in the
// seed) sums all pre-seeded grads into one pass. This test is the GATE
// that proves the composition is correct.
//
// Spine (tiny config d=4, V=5, h=6): a SHARED hidden z[d] feeds
//   head_a = ag_lmhead(Wa, z)              → logits_a   (CE supervision)
//   head_g = ag_lmhead(Wg, z)              → logits_g   (independent weight)
//   pf     = ag_purefield(z, Wa_in/out, Wg_in/out) → pf_out  (tension head)
// composite loss
//   L = w1·CE(logits_a, tgt)
//     + w2·L_ψ(cos(logits_a, logits_g))
//     + w3·L_route(mean(pf_out²)²)
// z's grad therefore ACCUMULATES from ALL THREE objectives (CE via head_a,
// L_ψ via BOTH heads, L_route via purefield) — the strongest registry-
// accumulation composition demonstration.
//
// Falsifiers:
//
//   F-RFC059B-MULTIOBJ-LINEARITY  composed Mg == (CE-only Mg) + (L_ψ-only Mg)
//                                 + (L_route-only Mg), AND each matches central
//                                 finite-diff of the TOTAL composite loss.
//                                 Probes z (shared, all 3 paths), Wa, Wg,
//                                 Wa_in, Wg_out. Gate: rel ≤ 1e-6 (RFC 059
//                                 §6.2/§7). This proves reverse-mode seed-
//                                 linearity composes the 4 heads correctly.
//
//   F-RFC059B-MULTIOBJ-DESCENT    5-step composite-loss gradient descent on
//                                 the same spine is monotone-decreasing
//                                 (sanity — NOT byte-eq).
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/flame_math"
use "stdlib/flame/ag_tape"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn rel_err(analytic: float, fd: float) -> float {
    let atol = 0.000001
    let denom = if nn_abs(fd) > atol { nn_abs(fd) } else { atol }
    return nn_abs(analytic - fd) / denom
}

// ── host references (used only for the finite-diff oracle) ──────────────

// single-position CE on logits[V] with gold target tgt (stable softmax).
fn ce_single(logits: int, tgt: int, V: int) -> float {
    let mut mx = t_get(logits, 0)
    let mut i = 1
    while i < V {
        if t_get(logits, i) > mx { mx = t_get(logits, i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < V {
        tot = tot + dt_exp(t_get(logits, i2) - mx)
        i2 = i2 + 1
    }
    let sm = dt_exp(t_get(logits, tgt) - mx) / tot
    return 0.0 - dt_ln(sm)
}

// cos-alignment loss L_ψ = c²/4, c = cos(a,b)  (host, matches ag_cross_psi_seed).
fn psi_loss(a: int, b: int, V: int) -> float {
    let mut na2 = 0.0
    let mut nb2 = 0.0
    let mut dot = 0.0
    let mut i = 0
    while i < V {
        let ai = t_get(a, i)
        let bi = t_get(b, i)
        na2 = na2 + ai * ai
        nb2 = nb2 + bi * bi
        dot = dot + ai * bi
        i = i + 1
    }
    let eps = 1e-12
    let na = dt_sqrt(na2)
    let nb = dt_sqrt(nb2)
    let na_safe = if na < eps { eps } else { na }
    let nb_safe = if nb < eps { eps } else { nb }
    let c = dot / (na_safe * nb_safe)
    return c * c / 4.0
}

// tension L_route = mean(out²)²  (host, matches ag_tension_route_seed unweighted).
fn route_loss(out: int, N: int) -> float {
    let mut ss = 0.0
    let mut i = 0
    while i < N {
        let oi = t_get(out, i)
        ss = ss + oi * oi
        i = i + 1
    }
    let t = ss / to_float(N)
    return t * t
}

// total composite loss L = w1·CE(head_a) + w2·L_ψ(a,g) + w3·L_route(pf_out)
// as a pure function of {z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out} (host fwd).
fn loss_eval(z: int, Wa: int, Wg: int,
             Wa_in: int, Wa_out: int, Wg_in: int, Wg_out: int,
             tgt: int, V: int, d: int, h: int,
             w1: float, w2: float, w3: float) -> float {
    let la = t_zeros(V)
    let lg = t_zeros(V)
    nn_lm_head_fwd(Wa, z, la, V, d)
    nn_lm_head_fwd(Wg, z, lg, V, d)
    let pf = t_zeros(d)
    let gA = t_zeros(h)
    let aA = t_zeros(h)
    let gG = t_zeros(h)
    let aG = t_zeros(h)
    nn_purefield_fwd(z, Wa_in, Wa_out, Wg_in, Wg_out, pf, gA, aA, gG, aG, d, h)
    let L = w1 * ce_single(la, tgt, V)
          + w2 * psi_loss(la, lg, V)
          + w3 * route_loss(pf, d)
    t_free(la); t_free(lg); t_free(pf)
    t_free(gA); t_free(aA); t_free(gG); t_free(aG)
    return L
}

// central diff of the TOTAL composite loss w.r.t. param[idx].
// which: 0=z, 1=Wa, 2=Wg, 3=Wa_in, 4=Wa_out, 5=Wg_in, 6=Wg_out
fn central_diff(z: int, Wa: int, Wg: int,
                Wa_in: int, Wa_out: int, Wg_in: int, Wg_out: int,
                tgt: int, V: int, d: int, h: int,
                w1: float, w2: float, w3: float,
                which: int, idx: int, eps: float) -> float {
    let p = if which == 0 { z }
            else if which == 1 { Wa }
            else if which == 2 { Wg }
            else if which == 3 { Wa_in }
            else if which == 4 { Wa_out }
            else if which == 5 { Wg_in }
            else { Wg_out }
    let saved = t_get(p, idx)
    t_set(p, idx, saved + eps)
    let lp = loss_eval(z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out,
                       tgt, V, d, h, w1, w2, w3)
    t_set(p, idx, saved - eps)
    let lm = loss_eval(z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out,
                       tgt, V, d, h, w1, w2, w3)
    t_set(p, idx, saved)
    return (lp - lm) / (2.0 * eps)
}

// weighted single-position CE seed: dl[k] = w1·(softmax[k] − [k==tgt]),
// pre-seeded into the registry via ag_seed_grad (CE term of composite loss).
fn ce_seed_weighted(tape: int, logits_tid: int, tgt: int, V: int, w1: float) -> float {
    let dl = t_zeros(V)
    let mut mx = t_get(logits_tid, 0)
    let mut i = 1
    while i < V {
        if t_get(logits_tid, i) > mx { mx = t_get(logits_tid, i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < V {
        tot = tot + dt_exp(t_get(logits_tid, i2) - mx)
        i2 = i2 + 1
    }
    let mut k = 0
    while k < V {
        let sm = dt_exp(t_get(logits_tid, k) - mx) / tot
        let mut g = sm
        if k == tgt { g = sm - 1.0 }
        t_set(dl, k, w1 * g)
        k = k + 1
    }
    ag_seed_grad(tape, logits_tid, dl)
    let L = w1 * ce_single(logits_tid, tgt, V)
    t_free(dl)
    return L
}

// ── build one tape spine and seed the requested subset of objectives ────
// mask bits: 1=CE, 2=L_ψ, 4=L_route. Returns the composite loss for the
// active subset; fills g_z/g_Wa/g_Wg/g_Wai/g_Wgo via ag_grad (caller frees
// nothing — tape owns its state; param grads live in the registry).
// This is the COMPOSITION DRIVER: forward record once, seed active heads,
// SINGLE ag_backward_reg walk.
fn run_spine(z: int, Wa: int, Wg: int,
             Wa_in: int, Wa_out: int, Wg_in: int, Wg_out: int,
             tgt: int, V: int, d: int, h: int,
             w1: float, w2: float, w3: float, mask: int,
             out_gz: int, out_gWa: int, out_gWg: int,
             out_gWai: int, out_gWgo: int) -> float {
    let tp = ag_t_begin(8)
    // forward record: shared z → head_a, head_g, purefield
    let la = ag_lmhead(tp, Wa, z, V, d)
    let lg = ag_lmhead(tp, Wg, z, V, d)
    let pf = ag_purefield(tp, z, Wa_in, Wa_out, Wg_in, Wg_out, d, h)

    let mut L = 0.0
    // ── multi-objective seed composition (each helper pre-seeds registry) ──
    if (mask % 2) == 1 {                       // bit 0: CE on head_a
        L = L + ce_seed_weighted(tp, la, tgt, V, w1)
    }
    if ((mask / 2) % 2) == 1 {                 // bit 1: L_ψ cross(a,g) — seeds BOTH
        L = L + ag_cross_psi_seed(tp, la, lg, V, w2)
    }
    if ((mask / 4) % 2) == 1 {                 // bit 2: L_route tension on pf_out
        L = L + ag_tension_route_seed(tp, pf, w3, t_len(pf))
    }

    // ── SINGLE reverse walk — all pre-seeds compose by seed-linearity ──────
    ag_backward_reg(tp, la, t_zeros(V))

    // read & copy grads out (tape state freed below)
    let gz  = ag_grad(tp, z)
    let gWa = ag_grad(tp, Wa)
    let gWg = ag_grad(tp, Wg)
    let gai = ag_grad(tp, Wa_in)
    let ggo = ag_grad(tp, Wg_out)
    let mut i = 0
    while i < d { t_set(out_gz, i, t_get(gz, i)); i = i + 1 }
    let mut j = 0
    while j < V * d {
        t_set(out_gWa, j, t_get(gWa, j))
        t_set(out_gWg, j, t_get(gWg, j))
        j = j + 1
    }
    let mut e = 0
    while e < d * h {
        t_set(out_gWai, e, t_get(gai, e))
        t_set(out_gWgo, e, t_get(ggo, e))
        e = e + 1
    }
    ag_t_free_state(tp); ag_t_free_reg(tp); ag_t_end(tp)
    return L
}

println("=== flame RFC 059 §5/§7 P1②-c — multi-objective backward composition (CPU oracle) ===")

let mut pass = 0
let total = 2

let V = 5
let d = 4
let h = 6
let tgt = 2
let w1 = 1.0      // CE weight
let w2 = 0.7      // L_ψ weight
let w3 = 50.0     // L_route weight (scaled so the tension term is a non-
                  // degenerate O(1e-2) fraction of the loss — keeps the
                  // purefield expert-weight grad-check probes well-
                  // conditioned vs central-diff, RFC §6.1 atol regime)

let z = t_zeros(d)
let Wa = t_zeros(V * d)
let Wg = t_zeros(V * d)
let Wa_in = t_zeros(d * h)
let Wa_out = t_zeros(h * d)
let Wg_in = t_zeros(d * h)
let Wg_out = t_zeros(h * d)

let mut e = 0
while e < V * d {
    t_set(Wa, e, to_float((e * 7) % 23 - 11) * 0.017 + 0.05)
    t_set(Wg, e, to_float((e * 5) % 19 - 9) * 0.013 - 0.02)
    e = e + 1
}
// NB: E_A and E_G are given DISTINCT scales (Wa_* ≈ 2× Wg_*) so the
// purefield output out = E_A(x) − E_G(x) is NON-degenerate (does not
// near-cancel to ~0). A near-zero out makes L_route = mean(out²)² ~ 1e-9,
// whose central-diff probes are dominated by O(ε²) truncation noise (the
// RFC §6.1 atol/near-zero hazard) — the linearity gate already proves the
// COMPOSITION is exact (rel ~1e-15); this just keeps the grad-check probes
// on a meaningful (non-cancelling) L_route signal.
let mut f = 0
while f < d * h {
    t_set(Wa_in, f, to_float((f * 7) % 23 - 11) * 0.062 + 0.11)
    t_set(Wa_out, f, to_float((f * 5) % 19 - 9) * 0.054 - 0.07)
    t_set(Wg_in, f, to_float((f * 11) % 29 - 14) * 0.023 + 0.02)
    t_set(Wg_out, f, to_float((f * 3) % 17 - 8) * 0.029 - 0.04)
    f = f + 1
}
// z given an O(0.5) magnitude so the purefield output (and hence the
// L_route tension signal) is non-degenerate — small z makes E_A−E_G and the
// downstream mean(out²)² collapse toward 0, pushing the L_route weight-grad
// probes into central-diff truncation noise (RFC §6.1).
let mut zi = 0
while zi < d {
    t_set(z, zi, to_float(zi - 1) * 0.22 + 0.41)
    zi = zi + 1
}

// grad buffers
let gz_all  = t_zeros(d)
let gWa_all = t_zeros(V * d)
let gWg_all = t_zeros(V * d)
let gai_all = t_zeros(d * h)
let ggo_all = t_zeros(d * h)

// per-objective grad buffers (for the linearity decomposition)
let gz_ce  = t_zeros(d);   let gz_psi  = t_zeros(d);   let gz_rt  = t_zeros(d)
let gWa_ce = t_zeros(V*d); let gWa_psi = t_zeros(V*d); let gWa_rt = t_zeros(V*d)
let gWg_ce = t_zeros(V*d); let gWg_psi = t_zeros(V*d); let gWg_rt = t_zeros(V*d)
let gai_ce = t_zeros(d*h); let gai_psi = t_zeros(d*h); let gai_rt = t_zeros(d*h)
let ggo_ce = t_zeros(d*h); let ggo_psi = t_zeros(d*h); let ggo_rt = t_zeros(d*h)

// COMPOSED backward (all 3 objectives, ONE walk)
let L_all = run_spine(z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h,
                      w1, w2, w3, 7, gz_all, gWa_all, gWg_all, gai_all, ggo_all)
// per-objective backwards (mask 1, 2, 4) — for the seed-linearity decomposition
let L_ce  = run_spine(z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h,
                      w1, w2, w3, 1, gz_ce, gWa_ce, gWg_ce, gai_ce, ggo_ce)
let L_psi = run_spine(z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h,
                      w1, w2, w3, 2, gz_psi, gWa_psi, gWg_psi, gai_psi, ggo_psi)
let L_rt  = run_spine(z, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h,
                      w1, w2, w3, 4, gz_rt, gWa_rt, gWg_rt, gai_rt, ggo_rt)

print("      composite L = w1·CE + w2·L_ψ + w3·L_route = "); println(L_all)
print("        decomposed: CE="); print(L_ce); print(" L_ψ="); print(L_psi); print(" L_route="); println(L_rt)

let eps = 0.00001
let mut worst = 0.0
let mut worst_lin = 0.0

// ── gate A: composed analytic vs central finite-diff of TOTAL loss ──────
// probes: z[0] (shared — ALL 3 paths), z[2], Wa[3] (CE+L_ψ), Wg[7] (L_ψ),
//         Wa_in[5] (L_route), Wg_out[3] (L_route)
let fz0 = central_diff(z,Wa,Wg,Wa_in,Wa_out,Wg_in,Wg_out, tgt,V,d,h,w1,w2,w3, 0, 0, eps)
let fz2 = central_diff(z,Wa,Wg,Wa_in,Wa_out,Wg_in,Wg_out, tgt,V,d,h,w1,w2,w3, 0, 2, eps)
let fwa = central_diff(z,Wa,Wg,Wa_in,Wa_out,Wg_in,Wg_out, tgt,V,d,h,w1,w2,w3, 1, 3, eps)
let fwg = central_diff(z,Wa,Wg,Wa_in,Wa_out,Wg_in,Wg_out, tgt,V,d,h,w1,w2,w3, 2, 7, eps)
let fai = central_diff(z,Wa,Wg,Wa_in,Wa_out,Wg_in,Wg_out, tgt,V,d,h,w1,w2,w3, 3, 5, eps)
let fgo = central_diff(z,Wa,Wg,Wa_in,Wa_out,Wg_in,Wg_out, tgt,V,d,h,w1,w2,w3, 6, 3, eps)

let r_z0 = rel_err(t_get(gz_all, 0), fz0)
let r_z2 = rel_err(t_get(gz_all, 2), fz2)
let r_wa = rel_err(t_get(gWa_all, 3), fwa)
let r_wg = rel_err(t_get(gWg_all, 7), fwg)
let r_ai = rel_err(t_get(gai_all, 5), fai)
let r_go = rel_err(t_get(ggo_all, 3), fgo)
if r_z0 > worst { worst = r_z0 }
if r_z2 > worst { worst = r_z2 }
if r_wa > worst { worst = r_wa }
if r_wg > worst { worst = r_wg }
if r_ai > worst { worst = r_ai }
if r_go > worst { worst = r_go }
println("  [composed analytic vs central-diff of TOTAL composite loss]")
print("      z[0]     analytic="); print(t_get(gz_all, 0)); print(" fd="); print(fz0); print(" rel="); println(r_z0)
print("        (z[0] SHARED — accumulates CE + L_ψ + L_route paths)")
print("      z[2]     analytic="); print(t_get(gz_all, 2)); print(" fd="); print(fz2); print(" rel="); println(r_z2)
print("      Wa[3]    analytic="); print(t_get(gWa_all, 3)); print(" fd="); print(fwa); print(" rel="); println(r_wa)
print("      Wg[7]    analytic="); print(t_get(gWg_all, 7)); print(" fd="); print(fwg); print(" rel="); println(r_wg)
print("      Wa_in[5] analytic="); print(t_get(gai_all, 5)); print(" fd="); print(fai); print(" rel="); println(r_ai)
print("      Wg_out[3] analytic="); print(t_get(ggo_all, 3)); print(" fd="); print(fgo); print(" rel="); println(r_go)

// ── gate B: seed-LINEARITY — composed grad == sum of per-objective grads ─
// (composed Mg) − (CE-only + L_ψ-only + L_route-only) must be ~0 everywhere.
let mut i = 0
while i < d {
    let s = t_get(gz_ce, i) + t_get(gz_psi, i) + t_get(gz_rt, i)
    let r = rel_err(t_get(gz_all, i), s)
    if r > worst_lin { worst_lin = r }
    i = i + 1
}
let mut j = 0
while j < V * d {
    let sa = t_get(gWa_ce, j) + t_get(gWa_psi, j) + t_get(gWa_rt, j)
    let sg = t_get(gWg_ce, j) + t_get(gWg_psi, j) + t_get(gWg_rt, j)
    let ra = rel_err(t_get(gWa_all, j), sa)
    let rg = rel_err(t_get(gWg_all, j), sg)
    if ra > worst_lin { worst_lin = ra }
    if rg > worst_lin { worst_lin = rg }
    j = j + 1
}
let mut k = 0
while k < d * h {
    let si = t_get(gai_ce, k) + t_get(gai_psi, k) + t_get(gai_rt, k)
    let so = t_get(ggo_ce, k) + t_get(ggo_psi, k) + t_get(ggo_rt, k)
    let ri = rel_err(t_get(gai_all, k), si)
    let ro = rel_err(t_get(ggo_all, k), so)
    if ri > worst_lin { worst_lin = ri }
    if ro > worst_lin { worst_lin = ro }
    k = k + 1
}
println("  [seed-linearity: composed Mg vs Σ per-objective Mg, all coords]")
print("      worst seed-linearity rel-error (all z+Wa+Wg+Wa_in+Wg_out coords) = "); println(worst_lin)

print("      worst grad-check rel-error (6 probes vs central-diff) = "); println(worst)
if worst <= 0.000001 && worst_lin <= 0.000001 {
    println("PASS  F-RFC059B-MULTIOBJ-LINEARITY   composed==Σ-per-obj AND vs central-diff, rel ≤ 1e-6 (RFC 059 §5/§7)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC059B-MULTIOBJ-LINEARITY   gradcheck worst="); print(worst)
    print(" linearity worst="); print(worst_lin); println(" (>1e-6)")
}

// ── gate C: F-RFC059B-MULTIOBJ-DESCENT — 5-step composite descent ───────
// SGD on z using the composed grad; composite loss must monotone-decrease.
let zd = t_zeros(d)
let mut zc = 0
while zc < d { t_set(zd, zc, t_get(z, zc)); zc = zc + 1 }
let lr = 0.05
let gz_step  = t_zeros(d)
let gWa_step = t_zeros(V * d)
let gWg_step = t_zeros(V * d)
let gai_step = t_zeros(d * h)
let ggo_step = t_zeros(d * h)
let mut prev = loss_eval(zd, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h, w1, w2, w3)
print("      descent L[0] = "); println(prev)
let mut monotone = 1
let mut step = 0
while step < 5 {
    let Ls = run_spine(zd, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h,
                       w1, w2, w3, 7, gz_step, gWa_step, gWg_step, gai_step, ggo_step)
    let mut s = 0
    while s < d {
        t_set(zd, s, t_get(zd, s) - lr * t_get(gz_step, s))
        s = s + 1
    }
    let Lnew = loss_eval(zd, Wa, Wg, Wa_in, Wa_out, Wg_in, Wg_out, tgt, V, d, h, w1, w2, w3)
    print("      descent L["); print(step + 1); print("] = "); println(Lnew)
    if Lnew >= prev { monotone = 0 }
    prev = Lnew
    step = step + 1
}
if monotone == 1 {
    println("PASS  F-RFC059B-MULTIOBJ-DESCENT   5-step composite-loss descent monotone-decreasing (RFC 059 §7)")
    pass = pass + 1
} else {
    println("FAIL  F-RFC059B-MULTIOBJ-DESCENT   composite loss NOT monotone-decreasing")
}

t_free(zd); t_free(gz_step); t_free(gWa_step); t_free(gWg_step); t_free(gai_step); t_free(ggo_step)
t_free(z); t_free(Wa); t_free(Wg); t_free(Wa_in); t_free(Wa_out); t_free(Wg_in); t_free(Wg_out)
t_free(gz_all); t_free(gWa_all); t_free(gWg_all); t_free(gai_all); t_free(ggo_all)
t_free(gz_ce); t_free(gz_psi); t_free(gz_rt)
t_free(gWa_ce); t_free(gWa_psi); t_free(gWa_rt)
t_free(gWg_ce); t_free(gWg_psi); t_free(gWg_rt)
t_free(gai_ce); t_free(gai_psi); t_free(gai_rt)
t_free(ggo_ce); t_free(ggo_psi); t_free(ggo_rt)

print("=== ")
print(pass)
print("/")
print(total)
println(" PASS ===")
