// ════════════════════════════════════════════════════════════════════════════
//  clm_prod.hexa — CLMConvMoE production corpus loop (PR1 of CLM_PROD_TRAINER_PLAN).
//
//  Lifts the assembly-3b smoke (clm_qat.hexa, one hard-coded 4-token sequence)
//  to a REAL-CORPUS, multi-window training loop — the measure-track production
//  trainer skeleton (PLASTI-SIM; anima learns on-chip per H_904). The int4-QAT
//  fwd/bwd chain is reused verbatim from clm_qat (clm flame files cannot `use`
//  one another — each carries its own main — so the verified chain is inlined).
//
//  What PR1 adds over clm_qat:
//    · corpus loader — read_file_bytes(byte-vocab V=256) → nsamp causal windows
//      (input = bytes[off..off+T], target = bytes[off+1..off+T+1]).
//    · round-robin multi-window loop — one window per step, epochs passes.
//    · honest descent measure — mean CE over the first epoch vs the last epoch.
//
//  PR3 wiring: the forward conv 6× (embed·trunk·router·2 experts·readout) route
//  through conv1d_via_forge (im2col + forge_dispatch_matmul, byte-eq per
//  F-CLM-CONV-GPU-EQ #2352) instead of host nn_conv1d_fwd — so on a CUDA host the
//  matmul bulk rides cuBLAS. Corpus = cross-lingual-semantic parallel fixture.
//
//  Phase-4 wiring (this revision): the backward conv 6× now route through
//  conv1d_bwd_via_forge (col2im + forge_dispatch_matmul, byte-eq to nn_conv1d_bwd
//  per F-CLM-CONV-BWD-FORGE-EQ #2383) instead of host nn_conv1d_bwd — so the
//  backward GEMMs ride forge cuBLAS too. GRAD-EXACT preserved (byte-eq, identical
//  CE descent); the GPU util-GREEN measurement itself is the next H100 fire.
//
//  F-CLM-PROD-DESCENT: real-corpus mean CE strictly descends (last_epoch <
//  first_epoch · finite). Corpus = stdlib/flame/testdata/clm_semantic_parallel.txt
//  (in-repo, machine-independent, repo-root relative). Config tiny (d=8) for $0
//  CPU verify; PR4 fires large d768/12L on H100 (forge=cuBLAS) with the real anima corpus.
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/conv_lib"
use "stdlib/flame/gn_lib"
use "stdlib/flame/moe_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/quant_lib"
use "stdlib/flame/optim_lib"

// conv1d (causal dilated) via im2col + forge matmul — inlined from clm_conv_gpu
// (clm flame files cannot `use` one another). Mirrors nn_conv1d_fwd's gather
// exactly: p = t − dil·(K−1−k); rows below p<0 are zero (left causal pad). On a
// CUDA host the matmul rides cuBLAS; on CPU it is the identical farr_matmul, so
// the routed forward is byte-eq to the host baseline (F-CLM-CONV-GPU-EQ #2352).
fn conv1d_via_forge(x: int, w: int, b: int, y_out: int,
                    T: int, Cin: int, Cout: int, K: int, dil: int) {
    let Kdim = Cin * K
    let xcol = t_zeros(T * Kdim)
    let mut t = 0
    while t < T {
        let mut ci = 0
        while ci < Cin {
            let mut k = 0
            while k < K {
                let p = t - dil * (K - 1 - k)
                if p >= 0 { t_set(xcol, t * Kdim + ci * K + k, t_get(x, p * Cin + ci)) }
                k = k + 1
            }
            ci = ci + 1
        }
        t = t + 1
    }
    let Wt = t_zeros(Kdim * Cout)
    let mut co = 0
    while co < Cout {
        let mut j = 0
        while j < Kdim { t_set(Wt, j * Cout + co, t_get(w, co * Kdim + j)); j = j + 1 }
        co = co + 1
    }
    let mm = forge_dispatch_matmul(xcol, T, Kdim, Wt, Cout)
    let mut t2 = 0
    while t2 < T {
        let mut c2 = 0
        while c2 < Cout {
            t_set(y_out, t2 * Cout + c2, t_get(mm, t2 * Cout + c2) + t_get(b, c2))
            c2 = c2 + 1
        }
        t2 = t2 + 1
    }
}

// conv1d backward (causal dilated) via forge matmul + col2im — inlined from
// clm_conv_gpu (clm flame files cannot `use` one another). Expresses the two
// heavy gradients (dW, dX) as GEMMs routed through forge_dispatch_matmul
// (cuBLAS on a CUDA host, identical farr_matmul on CPU) so the backward stops
// being a host scalar loop. Byte-eq to nn_conv1d_bwd (dW 1.67e-16 / dX 8.3e-17
// / db 0.0 per F-CLM-CONV-BWD-FORGE-EQ #2383). col index j = ci*K + k.
fn conv1d_bwd_via_forge(x: int, w: int, dy: int,
                        dW_out: int, dX_out: int, db_out: int,
                        T: int, Cin: int, Cout: int, K: int, dil: int) {
    let Kdim = Cin * K
    // im2col: xcolT[j, t] = (p>=0) ? x[p, ci] : 0, j = ci*K+k, p = t - dil*(K-1-k).
    let xcolT = t_zeros(Kdim * T)
    let mut t = 0
    while t < T {
        let mut ci = 0
        while ci < Cin {
            let mut k = 0
            while k < K {
                let p = t - dil * (K - 1 - k)
                if p >= 0 {
                    let j = ci * K + k
                    t_set(xcolT, j * T + t, t_get(x, p * Cin + ci))
                }
                k = k + 1
            }
            ci = ci + 1
        }
        t = t + 1
    }
    // dW: dW_flat[Kdim, Cout] = xcolT[Kdim,T] @ dy[T,Cout] (forge GEMM)
    let dW_flat = forge_dispatch_matmul(xcolT, Kdim, T, dy, Cout)
    let mut co = 0
    while co < Cout {
        let mut j = 0
        while j < Kdim {
            t_set(dW_out, co * Kdim + j, t_get(dW_flat, j * Cout + co))
            j = j + 1
        }
        co = co + 1
    }
    // dX: dXcol[T, Kdim] = dy[T,Cout] @ Wflat[Cout,Kdim] (forge GEMM), then col2im.
    let dXcol = forge_dispatch_matmul(dy, T, Cout, w, Kdim)
    let mut iz = 0
    while iz < T * Cin {
        t_set(dX_out, iz, 0.0)
        iz = iz + 1
    }
    let mut t2b = 0
    while t2b < T {
        let mut ci2 = 0
        while ci2 < Cin {
            let mut k2 = 0
            while k2 < K {
                let p = t2b - dil * (K - 1 - k2)
                if p >= 0 {
                    let j = ci2 * K + k2
                    let xidx = p * Cin + ci2
                    t_set(dX_out, xidx, t_get(dX_out, xidx) + t_get(dXcol, t2b * Kdim + j))
                }
                k2 = k2 + 1
            }
            ci2 = ci2 + 1
        }
        t2b = t2b + 1
    }
    // db: db_out[co] = Σ_t dy[t,co] (host reduction)
    let mut cb = 0
    while cb < Cout {
        let mut acc = 0.0
        let mut tb = 0
        while tb < T {
            acc = acc + t_get(dy, tb * Cout + cb)
            tb = tb + 1
        }
        t_set(db_out, cb, acc)
        cb = cb + 1
    }
}

// fake-quant a weight into wq (caller-allocated) + write the STE mask.
fn _fq(w: int, wq: int, mask: int, Cout: int, rest: int) {
    let sc = t_zeros(Cout); let ql = t_zeros(Cout * rest)
    nn_int4_quant_fwd(w, wq, sc, ql, mask, Cout, rest)
}

// Forward with weight-only int4 QAT (verbatim from clm_qat assembly-3b).
fn clm_prod_fwd(tokens: int,
               embed: int, ecW: int, ecB: int, tcW: int, tcB: int, tgG: int, tgB: int,
               rW: int, rB: int, e0W: int, e0B: int, e1W: int, e1B: int,
               noG: int, noB: int, roW: int, roB: int,
               ecWq: int, ecM: int, tcWq: int, tcM: int, e0Wq: int, e0M: int,
               e1Wq: int, e1M: int, rWq: int, rM: int, roWq: int, roM: int,
               xe: int, xec: int, xt: int, hn0: int, xhat0: int, inv0: int,
               eo0: int, eo1: int, probs: int, ex_out: int, yn: int, xhatN: int, invN: int,
               out_logits: int, T: int, d: int, E: int, V: int, K: int) {
    _fq(ecW, ecWq, ecM, d, d * K)
    _fq(tcW, tcWq, tcM, d, d * K)
    _fq(e0W, e0Wq, e0M, d, d * K)
    _fq(e1W, e1Wq, e1M, d, d * K)
    _fq(rW, rWq, rM, E, d)
    _fq(roW, roWq, roM, V, d)

    nn_embedding_fwd(tokens, embed, xe, T, d)
    conv1d_via_forge(xe, ecWq, ecB, xec, T, d, d, K, 1)
    let h0 = t_zeros(T * d)
    conv1d_via_forge(xec, tcWq, tcB, h0, T, d, d, K, 1)
    let mean0 = t_zeros(1)
    nn_groupnorm_fwd(h0, tgG, tgB, hn0, mean0, inv0, xhat0, T, d, 1)
    let hg0 = t_zeros(T * d); nn_gelu_fwd(hn0, hg0, T * d)
    let mut i = 0
    while i < T * d { t_set(xt, i, t_get(xec, i) + t_get(hg0, i)); i = i + 1 }
    let logits_r = t_zeros(T * E)
    conv1d_via_forge(xt, rWq, rB, logits_r, T, d, E, 1, 1)
    conv1d_via_forge(xt, e0Wq, e0B, eo0, T, d, d, K, 1)
    conv1d_via_forge(xt, e1Wq, e1B, eo1, T, d, d, K, 1)
    let ex0 = t_zeros(T * d); nn_gelu_fwd(eo0, ex0, T * d)
    let ex1 = t_zeros(T * d); nn_gelu_fwd(eo1, ex1, T * d)
    let mut j = 0
    while j < T * d {
        t_set(ex_out, 0 * T * d + j, t_get(ex0, j))
        t_set(ex_out, 1 * T * d + j, t_get(ex1, j))
        j = j + 1
    }
    let y = t_zeros(T * d)
    nn_moe_router_fwd(logits_r, ex_out, probs, y, T, E, d)
    let meanN = t_zeros(1)
    nn_groupnorm_fwd(y, noG, noB, yn, meanN, invN, xhatN, T, d, 1)
    conv1d_via_forge(yn, roWq, roB, out_logits, T, d, V, 1, 1)
}

fn clm_ce_grad(logits: int, targets: int, dlogits_out: int, T: int, V: int) {
    let mut t = 0
    while t < T {
        let base = t * V
        let mut mx = t_get(logits, base)
        let mut i = 1
        while i < V { let v = t_get(logits, base + i); if v > mx { mx = v }; i = i + 1 }
        let mut sm = 0.0
        let mut i2 = 0
        while i2 < V { sm = sm + exp(t_get(logits, base + i2) - mx); i2 = i2 + 1 }
        let invT = 1.0 / to_float(T)
        let mut v3 = 0
        while v3 < V {
            let p = exp(t_get(logits, base + v3) - mx) / sm
            t_set(dlogits_out, base + v3, p * invT)
            v3 = v3 + 1
        }
        let tgt = to_int(t_get(targets, t))
        t_set(dlogits_out, base + tgt, t_get(dlogits_out, base + tgt) - invT)
        t = t + 1
    }
}

// Backward with STE (verbatim from clm_qat assembly-3b).
fn clm_prod_bwd(dlogits: int, tokens: int,
               embed: int, ecWq: int, tcWq: int, tgG: int, rWq: int, e0Wq: int, e1Wq: int, noG: int, roWq: int,
               ecM: int, tcM: int, e0M: int, e1M: int, rM: int, roM: int,
               xe: int, xec: int, xt: int, hn0: int, xhat0: int, inv0: int,
               eo0: int, eo1: int, probs: int, ex_out: int, yn: int, xhatN: int, invN: int,
               dembed: int, decW: int, decB: int, dtcW: int, dtcB: int, dtgG: int, dtgB: int,
               drW: int, drB: int, de0W: int, de0B: int, de1W: int, de1B: int,
               dnoG: int, dnoB: int, droW: int, droB: int,
               T: int, d: int, E: int, V: int, K: int) {
    let dynorm = t_zeros(T * d)
    let droWq = t_zeros(V * d)
    conv1d_bwd_via_forge(yn, roWq, dlogits, droWq, dynorm, droB, T, d, V, 1, 1)
    nn_int4_quant_bwd(droWq, roM, droW, V, d)
    let dy = t_zeros(T * d)
    nn_groupnorm_bwd(xhatN, invN, noG, dynorm, dnoG, dnoB, dy, T, d, 1)
    let dlogits_r = t_zeros(T * E)
    let dex_out = t_zeros(E * T * d)
    nn_moe_router_bwd(probs, ex_out, dy, dlogits_r, dex_out, T, E, d)
    let dxt_r = t_zeros(T * d); let drWq = t_zeros(E * d)
    conv1d_bwd_via_forge(xt, rWq, dlogits_r, drWq, dxt_r, drB, T, d, E, 1, 1)
    nn_int4_quant_bwd(drWq, rM, drW, E, d)
    let dex0 = t_zeros(T * d); let dex1 = t_zeros(T * d)
    let mut ei = 0
    while ei < T * d {
        t_set(dex0, ei, t_get(dex_out, 0 * T * d + ei))
        t_set(dex1, ei, t_get(dex_out, 1 * T * d + ei))
        ei = ei + 1
    }
    let deo0 = t_zeros(T * d); nn_gelu_bwd(eo0, dex0, deo0, T * d)
    let deo1 = t_zeros(T * d); nn_gelu_bwd(eo1, dex1, deo1, T * d)
    let dxt_e0 = t_zeros(T * d); let de0Wq = t_zeros(d * d * K)
    conv1d_bwd_via_forge(xt, e0Wq, deo0, de0Wq, dxt_e0, de0B, T, d, d, K, 1)
    nn_int4_quant_bwd(de0Wq, e0M, de0W, d, d * K)
    let dxt_e1 = t_zeros(T * d); let de1Wq = t_zeros(d * d * K)
    conv1d_bwd_via_forge(xt, e1Wq, deo1, de1Wq, dxt_e1, de1B, T, d, d, K, 1)
    nn_int4_quant_bwd(de1Wq, e1M, de1W, d, d * K)
    let dxt = t_zeros(T * d)
    let mut xi = 0
    while xi < T * d {
        t_set(dxt, xi, t_get(dxt_r, xi) + t_get(dxt_e0, xi) + t_get(dxt_e1, xi))
        xi = xi + 1
    }
    let dhn0 = t_zeros(T * d); nn_gelu_bwd(hn0, dxt, dhn0, T * d)
    let dh0 = t_zeros(T * d)
    nn_groupnorm_bwd(xhat0, inv0, tgG, dhn0, dtgG, dtgB, dh0, T, d, 1)
    let dxec_b = t_zeros(T * d); let dtcWq = t_zeros(d * d * K)
    conv1d_bwd_via_forge(xec, tcWq, dh0, dtcWq, dxec_b, dtcB, T, d, d, K, 1)
    nn_int4_quant_bwd(dtcWq, tcM, dtcW, d, d * K)
    let dxec = t_zeros(T * d)
    let mut ci = 0
    while ci < T * d { t_set(dxec, ci, t_get(dxt, ci) + t_get(dxec_b, ci)); ci = ci + 1 }
    let dxe = t_zeros(T * d); let decWq = t_zeros(d * d * K)
    conv1d_bwd_via_forge(xe, ecWq, dxec, decWq, dxe, decB, T, d, d, K, 1)
    nn_int4_quant_bwd(decWq, ecM, decW, d, d * K)
    let mut zi = 0
    while zi < V * d { t_set(dembed, zi, 0.0); zi = zi + 1 }
    nn_embedding_bwd_scatter(dxe, tokens, dembed, T, d)
}

fn _adam(W: int, gW: int, m: int, v: int, n: int, t: int) {
    opt_adamw_step(W, gW, m, v, n, 0.05, 0.9, 0.999, 0.00000001, 0.0, t)
}

// Load nsamp causal windows of length T from a byte corpus into IDS/TGT.
// IDS[s*T+p] = byte[off+p], TGT[s*T+p] = byte[off+p+1]; off = s*stride.
// Returns the number of windows actually filled (<= nsamp if corpus is short).
fn clm_corpus_windows(bytes_arr: int, n_bytes: int, IDS: int, TGT: int,
                      nsamp: int, T: int, stride: int) -> int {
    let mut filled = 0
    let mut s = 0
    while s < nsamp {
        let off = s * stride
        if off + T + 1 <= n_bytes {
            let mut p = 0
            while p < T {
                t_set(IDS, s * T + p, to_float(bytes_arr[off + p]))
                t_set(TGT, s * T + p, to_float(bytes_arr[off + p + 1]))
                p = p + 1
            }
            filled = filled + 1
        }
        s = s + 1
    }
    return filled
}

fn main() {
    println("clm_prod — CLMConvMoE production corpus loop (PR1)")
    let T = 24; let d = 8; let E = 2; let V = 256; let K = 3
    let nsamp = 8
    let dd = d * d * K; let ed = E * d; let vd = V * d

    // ---- corpus → nsamp windows (in-repo fixture, repo-root relative) ----
    // cross-lingual-semantic corpus: 5 concept × 5 lang (en·zh·ru·ja·ko) PARALLEL-
    // aligned (Lab-11 / H_911 semantic-linkage; anima clm_p1.corpus.kosmos mirror).
    // stride spreads the nsamp windows across all 5 languages so the routed forge
    // forward learns the cross-lingual MEANING coupling, not a single-language head.
    let path = "stdlib/flame/testdata/clm_semantic_parallel.txt"
    let bytes_arr = read_file_bytes(path)
    let n_bytes = len(bytes_arr)
    // stride spans the WHOLE corpus so the nsamp windows are spread across every
    // language section (multilingual: en·zh·ru·ja·ko), not just the head.
    let mut stride = (n_bytes - T - 1) / nsamp
    if stride < 1 { stride = 1 }
    print("  corpus: "); print(path); print("  ("); print(n_bytes); println(" bytes, V=256)")
    let IDS = t_zeros(nsamp * T)
    let TGT = t_zeros(nsamp * T)
    let nwin = clm_corpus_windows(bytes_arr, n_bytes, IDS, TGT, nsamp, T, stride)
    print("  windows: "); print(nwin); print("/"); print(nsamp)
    print("  (T="); print(T); print(" stride="); print(stride); println(")")
    if nwin < 2 { println("F-CLM-PROD-DESCENT = 0"); println("FAIL — corpus too short"); return }

    // ---- weights (LCG init, same scheme as clm_qat) ----
    let embed=t_zeros(vd); t_fill_lcg(embed, vd, 1, 0.3)
    let ecW=t_zeros(dd); t_fill_lcg(ecW, dd, 2, 0.2); let ecB=t_zeros(d); t_fill_lcg(ecB, d, 3, 0.1)
    let tcW=t_zeros(dd); t_fill_lcg(tcW, dd, 4, 0.2); let tcB=t_zeros(d); t_fill_lcg(tcB, d, 5, 0.1)
    let tgG=t_zeros(d); t_fill_lcg(tgG, d, 6, 0.5); let tgB=t_zeros(d); t_fill_lcg(tgB, d, 7, 0.1)
    let rW=t_zeros(ed); t_fill_lcg(rW, ed, 12, 0.2); let rB=t_zeros(E); t_fill_lcg(rB, E, 13, 0.1)
    let e0W=t_zeros(dd); t_fill_lcg(e0W, dd, 14, 0.2); let e0B=t_zeros(d); t_fill_lcg(e0B, d, 15, 0.1)
    let e1W=t_zeros(dd); t_fill_lcg(e1W, dd, 16, 0.2); let e1B=t_zeros(d); t_fill_lcg(e1B, d, 17, 0.1)
    let noG=t_zeros(d); t_fill_lcg(noG, d, 18, 0.5); let noB=t_zeros(d); t_fill_lcg(noB, d, 19, 0.1)
    let roW=t_zeros(vd); t_fill_lcg(roW, vd, 20, 0.2); let roB=t_zeros(V); t_fill_lcg(roB, V, 21, 0.1)

    // grads
    let dembed=t_zeros(vd); let decW=t_zeros(dd); let decB=t_zeros(d)
    let dtcW=t_zeros(dd); let dtcB=t_zeros(d); let dtgG=t_zeros(d); let dtgB=t_zeros(d)
    let drW=t_zeros(ed); let drB=t_zeros(E)
    let de0W=t_zeros(dd); let de0B=t_zeros(d); let de1W=t_zeros(dd); let de1B=t_zeros(d)
    let dnoG=t_zeros(d); let dnoB=t_zeros(d); let droW=t_zeros(vd); let droB=t_zeros(V)
    // adam state
    let m_embed=t_zeros(vd); let v_embed=t_zeros(vd)
    let m_ecW=t_zeros(dd); let v_ecW=t_zeros(dd); let m_ecB=t_zeros(d); let v_ecB=t_zeros(d)
    let m_tcW=t_zeros(dd); let v_tcW=t_zeros(dd); let m_tcB=t_zeros(d); let v_tcB=t_zeros(d)
    let m_tgG=t_zeros(d); let v_tgG=t_zeros(d); let m_tgB=t_zeros(d); let v_tgB=t_zeros(d)
    let m_rW=t_zeros(ed); let v_rW=t_zeros(ed); let m_rB=t_zeros(E); let v_rB=t_zeros(E)
    let m_e0W=t_zeros(dd); let v_e0W=t_zeros(dd); let m_e0B=t_zeros(d); let v_e0B=t_zeros(d)
    let m_e1W=t_zeros(dd); let v_e1W=t_zeros(dd); let m_e1B=t_zeros(d); let v_e1B=t_zeros(d)
    let m_noG=t_zeros(d); let v_noG=t_zeros(d); let m_noB=t_zeros(d); let v_noB=t_zeros(d)
    let m_roW=t_zeros(vd); let v_roW=t_zeros(vd); let m_roB=t_zeros(V); let v_roB=t_zeros(V)
    // q-weight + mask caches
    let ecWq=t_zeros(dd); let ecM=t_zeros(dd); let tcWq=t_zeros(dd); let tcM=t_zeros(dd)
    let e0Wq=t_zeros(dd); let e0M=t_zeros(dd); let e1Wq=t_zeros(dd); let e1M=t_zeros(dd)
    let rWq=t_zeros(ed); let rM=t_zeros(ed); let roWq=t_zeros(vd); let roM=t_zeros(vd)
    // act caches (T-sized)
    let xe=t_zeros(T*d); let xec=t_zeros(T*d); let xt=t_zeros(T*d)
    let hn0=t_zeros(T*d); let xhat0=t_zeros(T*d); let inv0=t_zeros(1)
    let eo0=t_zeros(T*d); let eo1=t_zeros(T*d); let probs=t_zeros(T*E); let ex_out=t_zeros(E*T*d)
    let yn=t_zeros(T*d); let xhatN=t_zeros(T*d); let invN=t_zeros(1)
    let logits=t_zeros(T*V); let dlogits=t_zeros(T*V)
    // per-step window buffers
    let tok=t_zeros(T); let tgt=t_zeros(T)

    // ---- round-robin multi-window loop; epochs full passes over nwin ----
    let epochs = 12
    let steps = epochs * nwin
    let mut sum_first = 0.0
    let mut sum_last = 0.0
    let mut step = 1
    while step <= steps {
        let w = (step - 1) % nwin
        let mut p = 0
        while p < T {
            t_set(tok, p, t_get(IDS, w * T + p))
            t_set(tgt, p, t_get(TGT, w * T + p))
            p = p + 1
        }
        clm_prod_fwd(tok, embed, ecW, ecB, tcW, tcB, tgG, tgB, rW, rB,
                    e0W, e0B, e1W, e1B, noG, noB, roW, roB,
                    ecWq, ecM, tcWq, tcM, e0Wq, e0M, e1Wq, e1M, rWq, rM, roWq, roM,
                    xe, xec, xt, hn0, xhat0, inv0, eo0, eo1, probs, ex_out, yn, xhatN, invN,
                    logits, T, d, E, V, K)
        let loss = nn_ce_loss_allpos(logits, tgt, T, V)
        if step <= nwin { sum_first = sum_first + loss }
        if step > steps - nwin { sum_last = sum_last + loss }
        clm_ce_grad(logits, tgt, dlogits, T, V)
        clm_prod_bwd(dlogits, tok, embed, ecWq, tcWq, tgG, rWq, e0Wq, e1Wq, noG, roWq,
                    ecM, tcM, e0M, e1M, rM, roM,
                    xe, xec, xt, hn0, xhat0, inv0, eo0, eo1, probs, ex_out, yn, xhatN, invN,
                    dembed, decW, decB, dtcW, dtcB, dtgG, dtgB, drW, drB, de0W, de0B, de1W, de1B,
                    dnoG, dnoB, droW, droB, T, d, E, V, K)
        _adam(embed, dembed, m_embed, v_embed, vd, step)
        _adam(ecW, decW, m_ecW, v_ecW, dd, step); _adam(ecB, decB, m_ecB, v_ecB, d, step)
        _adam(tcW, dtcW, m_tcW, v_tcW, dd, step); _adam(tcB, dtcB, m_tcB, v_tcB, d, step)
        _adam(tgG, dtgG, m_tgG, v_tgG, d, step);  _adam(tgB, dtgB, m_tgB, v_tgB, d, step)
        _adam(rW, drW, m_rW, v_rW, ed, step);     _adam(rB, drB, m_rB, v_rB, E, step)
        _adam(e0W, de0W, m_e0W, v_e0W, dd, step); _adam(e0B, de0B, m_e0B, v_e0B, d, step)
        _adam(e1W, de1W, m_e1W, v_e1W, dd, step); _adam(e1B, de1B, m_e1B, v_e1B, d, step)
        _adam(noG, dnoG, m_noG, v_noG, d, step);  _adam(noB, dnoB, m_noB, v_noB, d, step)
        _adam(roW, droW, m_roW, v_roW, vd, step); _adam(roB, droB, m_roB, v_roB, V, step)
        step = step + 1
    }
    let first_ce = sum_first / to_float(nwin)
    let last_ce = sum_last / to_float(nwin)
    print("  epoch-1 mean CE = "); println(to_string(first_ce))
    print("  epoch-"); print(epochs); print(" mean CE = "); println(to_string(last_ce))
    if last_ce < first_ce {
        println("F-CLM-PROD-DESCENT = 1")
        println("PASS — real-corpus mean CE descends under int4 envelope")
        return
    }
    println("F-CLM-PROD-DESCENT = 0")
    println("FAIL")
}
