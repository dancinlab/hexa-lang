// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_cross_psi_bwd_test.hexa — RFC 059 §3 P1②-b (cross/L_ψ)
//
// L_ψ is the cosine-alignment loss between head_a and head_g logits:
//   c = cos(a,b) ; L_ψ = λ·c²/4 .  It is a loss-LAYER (not a tape node):
// the new `ag_cross_psi_seed` injects ∂L_ψ/∂a AND ∂L_ψ/∂b into the registry
// via ag_seed_grad, so the single reverse walk propagates BOTH seeds through
// the two lmhead nodes into dW_a, dW_g, and (accumulating) dz.
//
// Falsifier:
//
//   F-RFC059B-CROSS-PSI-SEED   L = L_ψ(logits_a, logits_g) with a = W_a·z,
//                              b = W_g·z. The reverse-mode analytic grad
//                              ∂L/∂{z, W_a, W_g} (from the seed propagating
//                              through both lmhead nodes) matches a central
//                              finite-difference of L_ψ at ε=1e-5. Gate:
//                              rel ≤ 1e-6 (RFC 059 §6.2). Probes both heads'
//                              weights + the SHARED z (accumulates a+b paths).
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/flame_math"
use "stdlib/flame/ag_tape"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// L_ψ(a, b) = λ·cos(a,b)²/4  (host reference for finite-diff).
fn psi_loss(a: int, b: int, V: int, lambda: float) -> float {
    let mut na2 = 0.0
    let mut nb2 = 0.0
    let mut dot = 0.0
    let mut i = 0
    while i < V {
        let ai = t_get(a, i)
        let bi = t_get(b, i)
        na2 = na2 + ai * ai
        nb2 = nb2 + bi * bi
        dot = dot + ai * bi
        i = i + 1
    }
    let na = dt_sqrt(na2)
    let nb = dt_sqrt(nb2)
    let eps = 1e-12
    let na_safe = if na < eps { eps } else { na }
    let nb_safe = if nb < eps { eps } else { nb }
    let c = dot / (na_safe * nb_safe)
    return lambda * c * c / 4.0
}

// L(W_a, W_g, z) = L_ψ(W_a·z, W_g·z)  (full chain through both heads).
fn loss_eval(Wa: int, Wg: int, z: int, V: int, d: int, lambda: float) -> float {
    let la = t_zeros(V)
    let lg = t_zeros(V)
    nn_lm_head_fwd(Wa, z, la, V, d)
    nn_lm_head_fwd(Wg, z, lg, V, d)
    let L = psi_loss(la, lg, V, lambda)
    t_free(la); t_free(lg)
    return L
}

fn central_diff(Wa: int, Wg: int, z: int, V: int, d: int, lambda: float,
                which: int, idx: int, eps: float) -> float {
    let p = if which == 0 { Wa } else if which == 1 { Wg } else { z }
    let saved = t_get(p, idx)
    t_set(p, idx, saved + eps)
    let lp = loss_eval(Wa, Wg, z, V, d, lambda)
    t_set(p, idx, saved - eps)
    let lm = loss_eval(Wa, Wg, z, V, d, lambda)
    t_set(p, idx, saved)
    return (lp - lm) / (2.0 * eps)
}

fn rel_err(analytic: float, fd: float) -> float {
    let atol = 0.000001
    let denom = if nn_abs(fd) > atol { nn_abs(fd) } else { atol }
    return nn_abs(analytic - fd) / denom
}

println("=== flame RFC 059 §3 P1②-b — cross/L_ψ seed backward selftest (CPU oracle) ===")

let mut pass = 0
let total = 1

let V = 5
let d = 4
let lambda = 0.7

let Wa = t_zeros(V * d)
let Wg = t_zeros(V * d)
let z = t_zeros(d)
let mut e = 0
while e < V * d {
    t_set(Wa, e, to_float((e * 7) % 23 - 11) * 0.017 + 0.05)
    t_set(Wg, e, to_float((e * 5) % 19 - 9) * 0.013 - 0.02)
    e = e + 1
}
let mut zi = 0
while zi < d {
    t_set(z, zi, to_float(zi - 1) * 0.031 + 0.07)
    zi = zi + 1
}

// analytic: forward both heads on shared z, seed L_ψ on both logits, walk.
let tp = ag_t_begin(4)
let lga = ag_lmhead(tp, Wa, z, V, d)
let lgg = ag_lmhead(tp, Wg, z, V, d)
let L = ag_cross_psi_seed(tp, lga, lgg, V, lambda)   // seeds BOTH a,b
ag_backward_reg(tp, lga, t_zeros(V))
let g_Wa = ag_grad(tp, Wa)
let g_Wg = ag_grad(tp, Wg)
let g_z  = ag_grad(tp, z)
print("      L_ψ = λ·c²/4 = "); println(L)

let eps = 0.00001
let mut worst = 0.0

let fa  = central_diff(Wa, Wg, z, V, d, lambda, 0, 3, eps)
let fg  = central_diff(Wa, Wg, z, V, d, lambda, 1, 7, eps)
let fz0 = central_diff(Wa, Wg, z, V, d, lambda, 2, 0, eps)
let fz3 = central_diff(Wa, Wg, z, V, d, lambda, 2, 3, eps)
let r_a  = rel_err(t_get(g_Wa, 3), fa)
let r_g  = rel_err(t_get(g_Wg, 7), fg)
let r_z0 = rel_err(t_get(g_z, 0), fz0)
let r_z3 = rel_err(t_get(g_z, 3), fz3)
if r_a  > worst { worst = r_a }
if r_g  > worst { worst = r_g }
if r_z0 > worst { worst = r_z0 }
if r_z3 > worst { worst = r_z3 }
print("      Wa[3] analytic="); print(t_get(g_Wa, 3)); print(" fd="); print(fa);  print(" rel="); println(r_a)
print("      Wg[7] analytic="); print(t_get(g_Wg, 7)); print(" fd="); print(fg);  print(" rel="); println(r_g)
print("      z[0]  analytic="); print(t_get(g_z, 0));  print(" fd="); print(fz0); print(" rel="); println(r_z0)
print("        (z is SHARED — analytic accumulates ∂L_ψ/∂a + ∂L_ψ/∂b paths)")
print("      z[3]  analytic="); print(t_get(g_z, 3));  print(" fd="); print(fz3); print(" rel="); println(r_z3)

print("      worst rel-error (Wa+Wg+z, 4 probes) = "); println(worst)
if worst <= 0.000001 {
    println("PASS  F-RFC059B-CROSS-PSI-SEED   L_ψ dual-seed propagates rel ≤ 1e-6 (RFC 059 §3)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC059B-CROSS-PSI-SEED   worst rel="); print(worst); println(" (>1e-6)")
}
ag_t_free_state(tp); ag_t_free_reg(tp); ag_t_end(tp)

t_free(Wa); t_free(Wg); t_free(z)

print("=== ")
print(pass)
print("/")
print(total)
println(" PASS ===")
