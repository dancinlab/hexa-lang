// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/flame/flame_headg_dual_bwd_test.hexa — RFC 059 §3 P1②-b (head_g)
//
// head_g is the SECOND, independent-weight LM head that SHARES the hidden
// `z` with head_a. Per RFC 059 §3 it needs ZERO new ag_tape code: calling
// the existing recorder `ag_lmhead` a second time appends a second
// `ag_k_lmhead` node, and the per-tensor grad registry (Decision 3)
// AUTOMATICALLY accumulates the two heads' contributions into dz when both
// CE-style seeds are present. This test PROVES that auto-accumulation.
//
// Falsifier:
//
//   F-RFC059B-HEADG-DUAL-GRADCHECK   composite L = CE(head_a) + CE(head_g)
//                                    over a SHARED hidden z. The reverse-mode
//                                    analytic grad ∂L/∂z (from registry
//                                    accumulation of BOTH lmhead nodes) and
//                                    ∂L/∂W_a, ∂L/∂W_g match a central finite-
//                                    difference at ε=1e-5. Gate: rel ≤ 1e-6
//                                    (RFC 059 §6.2). 4 probes: z (shared),
//                                    W_a (head_a weight), W_g (head_g weight).
// ════════════════════════════════════════════════════════════════════════

use "stdlib/flame/tensor_lib"
use "stdlib/flame/nn_lib"
use "stdlib/flame/flame_math"
use "stdlib/flame/ag_tape"

fn nn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// single-position CE on logits[V] with gold target `tgt`:
//   L = −ln softmax(logits)[tgt]  (stable row-max + dt_exp)
fn ce_single(logits: int, tgt: int, V: int) -> float {
    let mut mx = t_get(logits, 0)
    let mut i = 1
    while i < V {
        if t_get(logits, i) > mx { mx = t_get(logits, i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < V {
        tot = tot + dt_exp(t_get(logits, i2) - mx)
        i2 = i2 + 1
    }
    let sm = dt_exp(t_get(logits, tgt) - mx) / tot
    return 0.0 - dt_ln(sm)
}

// composite L(W_a, W_g, z) = CE(head_a) + CE(head_g) over shared z.
fn loss_eval(Wa: int, Wg: int, z: int, ta: int, tg: int, V: int, d: int) -> float {
    let la = t_zeros(V)
    let lg = t_zeros(V)
    nn_lm_head_fwd(Wa, z, la, V, d)
    nn_lm_head_fwd(Wg, z, lg, V, d)
    let L = ce_single(la, ta, V) + ce_single(lg, tg, V)
    t_free(la); t_free(lg)
    return L
}

// central diff of L w.r.t. param[idx]. which: 0=Wa, 1=Wg, 2=z.
fn central_diff(Wa: int, Wg: int, z: int, ta: int, tg: int, V: int, d: int,
                which: int, idx: int, eps: float) -> float {
    let p = if which == 0 { Wa } else if which == 1 { Wg } else { z }
    let saved = t_get(p, idx)
    t_set(p, idx, saved + eps)
    let lp = loss_eval(Wa, Wg, z, ta, tg, V, d)
    t_set(p, idx, saved - eps)
    let lm = loss_eval(Wa, Wg, z, ta, tg, V, d)
    t_set(p, idx, saved)
    return (lp - lm) / (2.0 * eps)
}

fn rel_err(analytic: float, fd: float) -> float {
    let atol = 0.000001
    let denom = if nn_abs(fd) > atol { nn_abs(fd) } else { atol }
    return nn_abs(analytic - fd) / denom
}

// CE seed helper for a single-position head: dl[k] = softmax[k] − [k==tgt],
// injected into the registry via ag_seed_grad so the lmhead reverse arm
// propagates it into dW and (accumulating) dz.
fn ce_seed_single(tape: int, logits_tid: int, tgt: int, V: int) -> float {
    let dl = t_zeros(V)
    let mut mx = t_get(logits_tid, 0)
    let mut i = 1
    while i < V {
        if t_get(logits_tid, i) > mx { mx = t_get(logits_tid, i) }
        i = i + 1
    }
    let mut tot = 0.0
    let mut i2 = 0
    while i2 < V {
        tot = tot + dt_exp(t_get(logits_tid, i2) - mx)
        i2 = i2 + 1
    }
    let mut k = 0
    while k < V {
        let sm = dt_exp(t_get(logits_tid, k) - mx) / tot
        let mut g = sm
        if k == tgt { g = sm - 1.0 }
        t_set(dl, k, g)
        k = k + 1
    }
    ag_seed_grad(tape, logits_tid, dl)
    let L = ce_single(logits_tid, tgt, V)
    t_free(dl)
    return L
}

println("=== flame RFC 059 §3 P1②-b — head_g dual-head backward selftest (CPU oracle) ===")

let mut pass = 0
let total = 1

let V = 5
let d = 4
let ta = 1
let tg = 3

let Wa = t_zeros(V * d)
let Wg = t_zeros(V * d)
let z = t_zeros(d)
let mut e = 0
while e < V * d {
    t_set(Wa, e, to_float((e * 7) % 23 - 11) * 0.017 + 0.05)
    t_set(Wg, e, to_float((e * 5) % 19 - 9) * 0.013 - 0.02)
    e = e + 1
}
let mut zi = 0
while zi < d {
    t_set(z, zi, to_float(zi - 1) * 0.031 + 0.07)
    zi = zi + 1
}

// analytic grad: shared-z dual head, single backward walk.
let tp = ag_t_begin(4)
let lga = ag_lmhead(tp, Wa, z, V, d)         // head_a node
let lgg = ag_lmhead(tp, Wg, z, V, d)         // head_g node (independent W, shared z)
let La = ce_seed_single(tp, lga, ta, V)      // seed head_a logits
let Lg = ce_seed_single(tp, lgg, tg, V)      // seed head_g logits
// walk once: both pre-seeds in registry → dz accumulates from BOTH heads.
ag_backward_reg(tp, lga, t_zeros(V))
let g_Wa = ag_grad(tp, Wa)
let g_Wg = ag_grad(tp, Wg)
let g_z  = ag_grad(tp, z)
let Ltot = La + Lg
print("      composite L = CE_a + CE_g = "); println(Ltot)

let eps = 0.00001
let mut worst = 0.0

// probe Wa[3], Wg[7], z[0] (shared — accumulates both heads), z[2]
let fa  = central_diff(Wa, Wg, z, ta, tg, V, d, 0, 3, eps)
let fg  = central_diff(Wa, Wg, z, ta, tg, V, d, 1, 7, eps)
let fz0 = central_diff(Wa, Wg, z, ta, tg, V, d, 2, 0, eps)
let fz2 = central_diff(Wa, Wg, z, ta, tg, V, d, 2, 2, eps)
let r_a  = rel_err(t_get(g_Wa, 3), fa)
let r_g  = rel_err(t_get(g_Wg, 7), fg)
let r_z0 = rel_err(t_get(g_z, 0), fz0)
let r_z2 = rel_err(t_get(g_z, 2), fz2)
if r_a  > worst { worst = r_a }
if r_g  > worst { worst = r_g }
if r_z0 > worst { worst = r_z0 }
if r_z2 > worst { worst = r_z2 }
print("      Wa[3] analytic="); print(t_get(g_Wa, 3)); print(" fd="); print(fa);  print(" rel="); println(r_a)
print("      Wg[7] analytic="); print(t_get(g_Wg, 7)); print(" fd="); print(fg);  print(" rel="); println(r_g)
print("      z[0]  analytic="); print(t_get(g_z, 0));  print(" fd="); print(fz0); print(" rel="); println(r_z0)
print("        (z[0] is SHARED — analytic must accumulate head_a + head_g dz)")
print("      z[2]  analytic="); print(t_get(g_z, 2));  print(" fd="); print(fz2); print(" rel="); println(r_z2)

print("      worst rel-error (Wa+Wg+z, 4 probes) = "); println(worst)
if worst <= 0.000001 {
    println("PASS  F-RFC059B-HEADG-DUAL-GRADCHECK   dual-head registry-accumulated grad rel ≤ 1e-6 (RFC 059 §3)")
    pass = pass + 1
} else {
    print("FAIL  F-RFC059B-HEADG-DUAL-GRADCHECK   worst rel="); print(worst); println(" (>1e-6)")
}
ag_t_free_state(tp); ag_t_free_reg(tp); ag_t_end(tp)

t_free(Wa); t_free(Wg); t_free(z)

print("=== ")
print(pass)
print("/")
print(total)
println(" PASS ===")
