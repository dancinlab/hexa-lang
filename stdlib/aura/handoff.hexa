#!hexa strict
// stdlib/aura/handoff.hexa — `aura + handoff` producer (hexa-native).
//
// LAYER: per-verb cell producer. Emits an aura_handoff_record-shaped
// sentinel carrying the regulatory + qualification handoff bundle
// skeleton — FDA 510(k) Class II submission + EU MDR Class IIa
// conformity assessment + Bluetooth SIG qualification + IEC 60601-1-2
// EMC testhouse package — TEMPLATE bundle, NOT a submitted dossier.
//
// CONTEXT: AURA = post-aural / temporal-bone clip wearable BCI.
// aura.demi [cell.handoff] wires substrate=hexa → this script.
//
// Citations (domains/aura.md §2 + §5):
//   * FDA 510(k) Premarket Notification (Class II · Substantial Equivalence)
//   * EU MDR 2017/745 Annex II/III/IX/X/XI conformity-assessment routes
//   * IEC 60601-1-2 4th edition EMC testhouse measurement
//   * Bluetooth SIG Qualification + Declaration ID + QDID
//   * ISO 13485 quality management system + ISO 14971 risk
//   * Sim4Life FDA MDDT (MRI-safety honest-gap pending · V6 reference)
//
// Honesty (g3 · @D d1 · aura.demi line 158-163):
//   * measurement_gate = GATE_OPEN permanently
//   * absorbed = false PERMANENTLY — handoff bundle is regulatory
//     scaffolding, NEVER a cleared / qualified / approved submission.
//     Accredited-lab gates (510(k) review · Notified Body audit ·
//     EMC testhouse · BT SIG qualification) are downstream of this map.
//   * MRI-safety labeling (ASTM F2182-19e2 + ISO 10974) = Sim4Life
//     FDA MDDT territory · honest-gap pending (V6 · G1 brk candidate).
//
// Sentinels:
//   __HEXA_AURA_HANDOFF__ PASS                 — dispatcher loaded
//   AURA_HANDOFF_OK gate=GATE_OPEN absorbed=false  — cellrun parse line
//
// Pattern: mirrors stdlib/aura/specify + structure + design + analyze +
//          synthesize + verify .hexa (V1-V6 PRs).

let VERSION       = "0.1.0"
let MODULE        = "aura-handoff"
let GEOMETRY_ID   = "aura_handoff_v1"
let RECORD_KIND   = "aura_handoff_record"

// ─── FDA 510(k) Class II submission block ─────────────────────────────

fn _fda_510k_block() -> [str] {
    return [
        "pathway: 510(k) Premarket Notification (Class II non-implantable)",
        "substantial equivalence: predicate device list + technological comparison",
        "intended use + IFU + labeling per 21 CFR 801 + 803",
        "performance bench testing: device-level + EMC + BLE radio",
        "biocompatibility: ISO 10993-1 skin-contact panel + cytotoxicity report",
        "software documentation: 21 CFR Part 11 + 62304 (moderate-to-major LOC)",
        "510(k) submission contents per FDA eSTAR template",
    ]
}

// ─── EU MDR conformity-assessment block ───────────────────────────────

fn _eu_mdr_block() -> [str] {
    return [
        "regulation: EU MDR 2017/745 (Class IIa non-implantable wearable)",
        "conformity route: Annex IX (QMS + technical documentation) baseline",
        "GSPR mapping: Annex I General Safety + Performance Requirements",
        "technical documentation: Annex II/III + post-market surveillance",
        "Notified Body engagement: ISO 13485 + MDR audit + design-dossier review",
        "UDI-DI + UDI-PI: GS1 issuing agency + UDI database registration",
        "EUDAMED registration: device + UDI + clinical investigation modules",
    ]
}

// ─── IEC 60601-1-2 EMC testhouse block ────────────────────────────────

fn _emc_testhouse_block() -> [str] {
    return [
        "standard: IEC 60601-1-2 Ed.4.1 (home-healthcare environment)",
        "emission test: CISPR 11 Group 1 Class B (conducted + radiated)",
        "immunity test: ESD + radiated RF + conducted RF + PFMF + proximity-field",
        "accredited testhouse engagement (ISO/IEC 17025)",
        "test plan + risk-analysis input + essential-performance criteria",
        "test report + uncertainty budget + remediation log",
    ]
}

// ─── Bluetooth SIG qualification block ────────────────────────────────

fn _bt_sig_block() -> [str] {
    return [
        "standard: Bluetooth SIG Core Specification v5.x (LE host + LL)",
        "qualification path: Declaration ID + Qualified Design ID (QDID)",
        "test categories: PHY + LL + HCI + GAP + GATT + SMP per BT SIG TCRL",
        "BQTF (Bluetooth Qualification Test Facility) engagement",
        "listing on launch studio + member fee + declaration submission",
        "profile dependencies: custom EEG service (UUID) + Battery + DIS",
    ]
}

// ─── quality + risk management block ──────────────────────────────────

fn _qms_risk_block() -> [str] {
    return [
        "QMS: ISO 13485:2016 medical device quality management system",
        "risk management: ISO 14971:2019 — hazard / risk analysis / control",
        "usability engineering: IEC 62366-1 + summative usability validation",
        "software lifecycle: IEC 62304 (Class B baseline · moderate LOC)",
        "post-market surveillance: vigilance reporting + CAPA process",
        "design history file (DHF) + device master record (DMR) + DHR",
    ]
}

fn _scope_caveats() -> [str] {
    return [
        "FDA 510(k) Class II submission dossier skeleton + EU MDR conformity-assessment template - TEMPLATE bundle.",
        "Bluetooth SIG qualification + Notified Body audit + EMC testhouse = accredited-lab gates separate from this map.",
        "MRI-safety labeling (ASTM F2182-19e2 + ISO 10974) = Sim4Life FDA MDDT territory - honest-gap, no open equivalent (V6 reference, G1 brk candidate).",
        "measurement_gate = GATE_OPEN permanently - handoff bundle is scaffolding, not an absorption claim (g3).",
        "absorbed=false PERMANENTLY (g3) - regulatory scaffolding, NEVER a cleared / qualified / approved submission.",
    ]
}

// ─── emit helpers ─────────────────────────────────────────────────────

fn _emit_block(label: str, lines: [str]) {
    print("# [" + label + "]")
    let n = lines.len()
    let mut i = 0
    while i < n {
        print("#   - " + lines[i])
        i = i + 1
    }
    print("#")
}

fn _emit_header() {
    print("# AURA HANDOFF — FDA 510(k) + EU MDR + BT SIG + EMC handoff bundle")
    print("# device_target = post-aural / temporal-bone clip BCI")
    print("# version = " + VERSION)
    print("#")
    _emit_block("fda_510k",       _fda_510k_block())
    _emit_block("eu_mdr",         _eu_mdr_block())
    _emit_block("emc_testhouse",  _emc_testhouse_block())
    _emit_block("bt_sig",         _bt_sig_block())
    _emit_block("qms_risk",       _qms_risk_block())
}

fn _emit_caveats() {
    let c = _scope_caveats()
    let n = c.len()
    let mut i = 0
    while i < n {
        print("# scope_caveat: " + c[i])
        i = i + 1
    }
}

// ─── main entry ───────────────────────────────────────────────────────

fn main() {
    _emit_header()
    _emit_caveats()

    print("AURA_HANDOFF_OK record_kind=" + RECORD_KIND
        + " geometry_id=" + GEOMETRY_ID
        + " gate=GATE_OPEN absorbed=false"
        + " version=" + VERSION)

    print("__HEXA_AURA_HANDOFF__ PASS")
}
