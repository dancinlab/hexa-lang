#!hexa strict
// stdlib/aura/a2_eu_mdr_nb_runbook.hexa — `aura + A2` EU MDR Notified
// Body engagement runbook emitter (hexa-native).
//
// LAYER: accredited-gate-readiness runbook. Emits an
// aura_a2_eu_mdr_nb_runbook_record sentinel carrying the EU MDR
// 2017/745 Class IIa conformity-assessment runbook — Annex IX QMS +
// technical documentation + Notified Body audit prep.
//
// CONTEXT: aura.md §"Accredited-lab gates" A2:
//   "EU MDR Notified Body audit — ISO 13485 QMS audit + MDR
//    design-dossier review + CE marking + EUDAMED registration"
//
// Honesty (g3 · @D d1):
//   * absorbed=false PERMANENTLY — runbook is NOT a CE-marked device.
//
// Sentinels:
//   __HEXA_AURA_A2_EU_MDR_NB_RUNBOOK__ PASS
//   AURA_A2_EU_MDR_NB_RUNBOOK_OK gate=GATE_OPEN absorbed=false

let VERSION       = "0.1.0"
let MODULE        = "aura-a2-eu-mdr-nb-runbook"
let GEOMETRY_ID   = "aura_a2_eu_mdr_nb_runbook_v1"
let RECORD_KIND   = "aura_a2_eu_mdr_nb_runbook_record"

fn _classification_block() -> [str] {
    return [
        "regulation: EU MDR 2017/745 (Regulation on Medical Devices)",
        "device_class: IIa (non-invasive · prolonged use · per MDCG 2021-24 rule 11)",
        "conformity_route: Annex IX (Full Quality Assurance · QMS audit)",
        "alternative_routes: Annex X (type examination) + Annex XI (production QA) - not chosen",
        "intended_use_alignment: aligns with EU MDR Article 2 definition of medical device",
        "rule_application: Rule 11 (software) + Rule 9 (active therapeutic) per MDCG 2019-11",
    ]
}

fn _gspr_block() -> [str] {
    return [
        "GSPR_coverage: Annex I General Safety + Performance Requirements (all applicable)",
        "GSPR_chapter_I: general requirements (Article 5-11 + Annex I 1-9)",
        "GSPR_chapter_II: design + manufacture (Annex I 10-22)",
        "GSPR_chapter_III: info supplied with device (Annex I 23) - labeling + IFU",
        "harmonized_standards_used: IEC 60601 family + IEC 62304 + ISO 13485 + ISO 14971 + ISO 10993",
        "GSPR_checklist: per-requirement rationale + applicable / not-applicable + evidence reference",
    ]
}

fn _technical_documentation_block() -> [str] {
    return [
        "Annex_II_TD: device description + IFU + design + manufacturing info + risk analysis",
        "Annex_III_PMS_TD: post-market surveillance plan + PSUR + vigilance + trend reporting",
        "design_history_file_DHF: per ISO 13485:2016 7.3 + 21 CFR 820.30 cross-reference",
        "clinical_evaluation: CER per MDCG 2020-13 + literature review + clinical evidence",
        "clinical_investigation: not required if SE + sufficient literature (CER demonstrates)",
        "summary_of_safety_and_clinical_performance_SSCP: per Article 32 (high-risk only · Class III/IIb implants)",
    ]
}

fn _qms_audit_block() -> [str] {
    return [
        "QMS_standard: ISO 13485:2016 medical device QMS",
        "QMS_scope: design + development + production + servicing of medical devices",
        "QMS_documentation: Quality Manual + Procedures + Work Instructions + Records",
        "MDSAP_alternative: Medical Device Single Audit Program (FDA + Health Canada + TGA + ANVISA + MHLW)",
        "pre_audit_assessment: gap analysis vs ISO 13485 + MDR audit-readiness",
        "internal_audit: per ISO 19011 + corrective actions",
        "management_review: per ISO 13485 5.6 + MDR Article 10",
    ]
}

fn _notified_body_engagement_block() -> [str] {
    return [
        "candidates: BSI Group (NB 0086 · UK) · TUV SUD (NB 0123 · DE) · DEKRA (NB 0124 · DE) · IMQ (NB 0051 · IT)",
        "selection_criteria: scope + lead time + technical expertise (medical electrical wearable)",
        "application_submission: device class + intended use + technical documentation + QMS evidence",
        "fee_estimate: €30K-100K initial + annual surveillance €15K-40K (NB-dependent)",
        "audit_phases: stage_1 documentation review · stage_2 on-site audit · surveillance audits",
        "CE_certificate: post-successful audit · Annex IX certificate valid 5 years",
    ]
}

fn _udi_eudamed_block() -> [str] {
    return [
        "UDI_DI: GS1 issuing agency (most common) OR HIBCC / ICCBBA",
        "UDI_PI: lot/batch + serial + manufacturing date + expiry",
        "UDI_carrier: data matrix barcode on label + UDI human-readable text",
        "EUDAMED_modules: Actor + UDI/Device + Notified Body + Clinical Investigation + Vigilance + Market Surveillance",
        "EUDAMED_registration: device + economic operators (manufacturer · importer · distributor)",
        "SRN: Single Registration Number assigned by EUDAMED upon manufacturer registration",
    ]
}

fn _pms_vigilance_block() -> [str] {
    return [
        "PMS_plan: per Article 84 + Annex III · proactive data gathering",
        "PMCF: Post-Market Clinical Follow-up plan + report per Annex XIV Part B",
        "PSUR: Periodic Safety Update Report (Class IIa = every 2 years to NB)",
        "vigilance_reporting: serious incidents within 15 days + FSCA + trend reporting",
        "EUDAMED_vigilance_module: incident reports + FSN/FSCA upload",
        "post_market_surveillance_report: PMSR Annex III 1.1 (Class IIa) per device",
    ]
}

fn _scope_caveats() -> [str] {
    return [
        "A2 EU MDR NB engagement runbook is a DRAFT process outline, NOT a CE-marked device.",
        "Actual engagement requires: signed contract with NB + paid fees + real audit cycles.",
        "Notified Body capacity is tight - typical engagement lead time 6-18 months.",
        "MDR transition deadlines (Article 120) may apply if pre-MDR products exist.",
        "absorbed=false PERMANENTLY (g3) - runbook outline, NEVER a CE certificate.",
    ]
}

fn _emit_block(label: str, lines: [str]) {
    print("# [" + label + "]")
    let n = lines.len()
    let mut i = 0
    while i < n {
        print("#   - " + lines[i])
        i = i + 1
    }
    print("#")
}

fn _emit_header() {
    print("# AURA A2 - EU MDR 2017/745 Class IIa NB engagement runbook")
    print("# device_target = post-aural / temporal-bone clip BCI")
    print("# version = " + VERSION)
    print("# ringfence: runbook outline - NOT a CE-marked device")
    print("#")
    _emit_block("classification",         _classification_block())
    _emit_block("gspr_coverage",          _gspr_block())
    _emit_block("technical_documentation",_technical_documentation_block())
    _emit_block("qms_audit",              _qms_audit_block())
    _emit_block("notified_body_engagement",_notified_body_engagement_block())
    _emit_block("udi_eudamed",            _udi_eudamed_block())
    _emit_block("pms_vigilance",          _pms_vigilance_block())
}

fn _emit_caveats() {
    let c = _scope_caveats()
    let n = c.len()
    let mut i = 0
    while i < n {
        print("# scope_caveat: " + c[i])
        i = i + 1
    }
}

fn main() {
    _emit_header()
    _emit_caveats()

    print("AURA_A2_EU_MDR_NB_RUNBOOK_OK record_kind=" + RECORD_KIND
        + " geometry_id=" + GEOMETRY_ID
        + " gate=GATE_OPEN absorbed=false"
        + " version=" + VERSION
        + " sections=7 nb_lead_time=6-18mo cert_validity=5y")

    print("__HEXA_AURA_A2_EU_MDR_NB_RUNBOOK__ PASS")
}
