#!hexa strict
// stdlib/aura/specify.hexa — `aura + specify` producer (hexa-native).
//
// LAYER: per-verb cell producer. Emits an aura_specify_record-shaped
// sentinel line carrying the FDA Class II Design Input dossier-skeleton
// header (21 CFR 820.30 + IEC 60601-1 + -1-2 EMC + Bluetooth SIG core
// spec mapping) — TEMPLATE scaffold, NOT a submitted dossier.
//
// CONTEXT: AURA = post-aural / temporal-bone clip wearable BCI domain.
// aura.demi [cell.specify] wires substrate=hexa → this script.
//
// Citations (domains/aura.md §5):
//   * 21 CFR 820.30 Design Controls (FDA Class II medical device)
//   * EU MDR 2017/745 General Safety + Performance Requirements
//   * IEC 60601-1 Ed.3.2 + Amd.2 — medical electrical equipment
//   * IEC 60601-1-2 Ed.4.1 — EMC requirements
//   * Bluetooth SIG Core Specification v5.x
//   * ISO 14971 — Risk management for medical devices
//   * ISO 10993-1 — Biological evaluation (skin-contact)
//
// Honesty (g3 · @D d1 · aura.demi line 75-79):
//   * measurement_gate = GATE_OPEN permanently
//   * absorbed = false PERMANENTLY — dossier skeleton is aspirational
//     scaffolding, NEVER an FDA-cleared submission. Accredited
//     clearance lives past Notified Body audit + 510(k) review which
//     are downstream of every verb-cell in this map.
//
// Sentinels:
//   __HEXA_AURA_SPECIFY__ PASS         — dispatcher loaded + emitted
//   AURA_SPECIFY_OK gate=GATE_OPEN absorbed=false  — cellrun parse line
//
// Usage:
//   hexa run stdlib/aura/specify.hexa
//
// Pattern: mirrors stdlib/bio/bio.hexa root-dispatcher sentinel style.

let VERSION         = "0.1.0"
let MODULE          = "aura-specify"
let GEOMETRY_ID     = "aura_specify_v1"
let RECORD_KIND     = "aura_specify_record"
let DEVICE_CLASS    = "II"           // FDA — non-implantable wearable
let DEVICE_CLASS_EU = "IIa"          // EU MDR 2017/745

// ─── design-input source register (provenance roll-up) ────────────────

fn _design_input_sources() -> [str] {
    return [
        "21 CFR 820.30 - FDA Design Controls",
        "EU MDR 2017/745 - General Safety and Performance Requirements",
        "IEC 60601-1 Ed.3.2 + Amd.2 - Medical electrical equipment",
        "IEC 60601-1-2 Ed.4.1 - EMC requirements",
        "Bluetooth SIG Core Specification v5.x",
        "ISO 14971 - Risk management for medical devices",
        "ISO 10993-1 - Biological evaluation (skin-contact)",
    ]
}

// ─── IEC 60601-1-2 immunity baseline (4th edition home-healthcare) ────

fn _emc_immunity_levels() -> [str] {
    return [
        "ESD +/-8 kV contact / +/-15 kV air (IEC 61000-4-2)",
        "Radiated RF 3-80 V/m (IEC 61000-4-3)",
        "Conducted RF 3-10 V (IEC 61000-4-6)",
        "PFMF 30 A/m (IEC 61000-4-8)",
        "Proximity-field 9-28 V/m wireless (IEC 61000-4-39)",
    ]
}

// ─── D1 substance: illustrative dossier values (NOT regulatory commitment) ─
//
// These reference targets fill the Design Input placeholders with
// ILLUSTRATIVE values intended to demonstrate the dossier shape. The
// actual values are driven by Voice-of-User capture, predicate-device
// research, and clinical priority review which all live upstream of
// this producer. absorbed=false stays PERMANENTLY (g3) even with
// substantive content — accredited closure requires accredited-lab
// gates (A1-A4 milestones), not template substance.

fn _intended_use_block() -> [str] {
    return [
        "device_name: AURA-100 (illustrative product name)",
        "intended_use_statement: Continuous post-aural EEG monitoring + alpha-band biofeedback for home-healthcare adult users",
        "form_factor: mastoid / temporal-bone clip · non-implantable wearable",
        "intended_use_environment: home-healthcare (IEC 60601-1-11 applicable)",
        "user_population: adult (18+) · self-administered · non-diagnostic wellness use",
    ]
}

fn _indications_for_use_block() -> [str] {
    return [
        "primary IFU: alpha-band neurofeedback for relaxation + meditation tracking",
        "secondary IFU: sleep-stage estimation (REM/NREM proxy via alpha + EOG) home-tracking",
        "exclusion: not intended for diagnosis of neurological disorders (epilepsy, seizure detection, etc.)",
        "exclusion: not intended for pediatric use (<18) absent dedicated pediatric pre-submission",
        "exclusion: not MRI-conditional pending V6 EM-side verify + A1 510(k) clearance",
    ]
}

fn _predicate_devices_block() -> [str] {
    return [
        "illustrative predicate: InteraXon Muse S — consumer EEG headband (510(k) cleared)",
        "illustrative predicate: Beacon Biosignals Dreem 3 — sleep EEG headband (510(k) cleared)",
        "illustrative predicate: NeuroSky MindWave — single-channel EEG (510(k) cleared)",
        "comparison axis: form factor (post-aural vs frontal) · channel count · BLE radio · battery topology",
        "Substantial Equivalence path: 510(k) per 21 CFR 807.92(a)(3) — D7 handoff territory",
    ]
}

fn _user_needs_block() -> [str] {
    return [
        "UN-01: ≥12 h continuous wear without skin irritation (ISO 10993-1)",
        "UN-02: <60 s pairing time (BLE 5.x) from cold boot",
        "UN-03: >10 m line-of-sight BLE range @ -60 dBm RSSI",
        "UN-04: alpha-band relative power resolution ≤ 5% rel error vs Welch oracle",
        "UN-05: charging interface (rechargeable variant) ≤ 90 min full charge",
        "UN-06: water-resistance IPX4 (splash) for daily home use",
        "UN-07: data privacy — no PHI uploaded without explicit user consent (HIPAA-aware)",
    ]
}

fn _performance_requirements_block() -> [str] {
    return [
        "PR-01: input-referred noise ≤ 1 uV-pp 0.5-50 Hz (AFE)",
        "PR-02: CMRR ≥ 80 dB @ 60 Hz (RLD-driven)",
        "PR-03: ADC resolution 24-bit (sigma-delta · ADS1299-class reference)",
        "PR-04: sample rate ≥ 250 Hz per channel (alpha-band Nyquist margin)",
        "PR-05: BLE throughput ≥ 8 kB/s sustained (raw stream per channel)",
        "PR-06: battery runtime ≥ 12 h continuous (250 Hz × 8 ch streaming)",
        "PR-07: weight ≤ 30 g per side (mastoid clip ergonomic ceiling)",
    ]
}

fn _safety_requirements_block() -> [str] {
    return [
        "SR-01: ISO 14971 risk analysis + risk control measures (DHF tracked)",
        "SR-02: IEC 60601-1 Type BF applied part classification (skin contact)",
        "SR-03: ISO 10993-1 biocompatibility (cytotoxicity + sensitization + irritation panel)",
        "SR-04: IEC 60601-1-2 Ed.4.1 EMC essential-performance maintenance under immunity stress",
        "SR-05: lithium-polymer battery safety per IEC 62133-2 (rechargeable variant)",
        "SR-06: software safety per IEC 62304 Class B (moderate-to-major LOC)",
        "SR-07: usability summative validation per IEC 62366-1 (15+ user formative study)",
    ]
}

// ─── header emit (announce-only + D1 substantive blocks) ──────────────

fn _emit_header() {
    print("# AURA SPECIFY — FDA Class II Design Input dossier skeleton")
    print("# device_class_fda = " + DEVICE_CLASS)
    print("# device_class_eu  = " + DEVICE_CLASS_EU)
    print("# regulatory_base  = 21 CFR 820.30 + EU MDR 2017/745")
    print("# safety_base      = IEC 60601-1 Ed.3.2")
    print("# emc_base         = IEC 60601-1-2 Ed.4.1")
    print("# radio_base       = Bluetooth SIG Core Spec v5.x")
    print("# risk_base        = ISO 14971")
    print("# biocompat_base   = ISO 10993-1 (skin-contact)")
    print("#")
    let src = _design_input_sources()
    let n = src.len()
    let mut i = 0
    while i < n {
        print("# source[" + i.str() + "] " + src[i])
        i = i + 1
    }
    print("#")
    let imm = _emc_immunity_levels()
    let m = imm.len()
    let mut j = 0
    while j < m {
        print("# immunity[" + j.str() + "] " + imm[j])
        j = j + 1
    }
    print("#")

    // ─── D1 substantive blocks (illustrative reference targets) ──
    _emit_block("intended_use",            _intended_use_block())
    _emit_block("indications_for_use",     _indications_for_use_block())
    _emit_block("predicate_devices",       _predicate_devices_block())
    _emit_block("user_needs",              _user_needs_block())
    _emit_block("performance_requirements", _performance_requirements_block())
    _emit_block("safety_requirements",     _safety_requirements_block())
}

fn _emit_block(label: str, lines: [str]) {
    print("# [" + label + "]")
    let n = lines.len()
    let mut k = 0
    while k < n {
        print("#   - " + lines[k])
        k = k + 1
    }
    print("#")
}

// ─── scope-caveats (g3 honesty floor — every claim ringfenced) ────────

fn _emit_caveats() {
    print("# scope_caveat: FDA Design Input (21 CFR 820.30) + IEC 60601-1 + -1-2 EMC dossier skeleton - TEMPLATE only, not a submitted dossier.")
    print("# scope_caveat: Bluetooth SIG qualification + EU MDR conformity assessment with a Notified Body = accredited-lab gates separate from this cell.")
    print("# scope_caveat: Class II classification (non-implantable wearable BCI) is the working assumption - final classification depends on FDA pre-submission feedback.")
    print("# scope_caveat: absorbed=false PERMANENTLY (g3) - dossier skeleton is aspirational scaffolding, NEVER an FDA-cleared submission.")
    print("# scope_caveat: D1 substantive blocks (intended_use / IFU / predicate / user_needs / performance / safety) are ILLUSTRATIVE reference targets, NOT regulatory commitments. Real values driven by VOU capture + predicate research + clinical priority review live upstream.")
}

// ─── main entry ───────────────────────────────────────────────────────

fn main() {
    _emit_header()
    _emit_caveats()

    // cellrun parse line — single-line summary the dispatcher consumes
    print("AURA_SPECIFY_OK record_kind=" + RECORD_KIND
        + " geometry_id=" + GEOMETRY_ID
        + " gate=GATE_OPEN absorbed=false"
        + " version=" + VERSION)

    // module sentinel (per bio.hexa convention)
    print("__HEXA_AURA_SPECIFY__ PASS")
}
