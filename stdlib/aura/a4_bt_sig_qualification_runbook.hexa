#!hexa strict
// stdlib/aura/a4_bt_sig_qualification_runbook.hexa — `aura + A4`
// Bluetooth SIG qualification runbook emitter (hexa-native).
//
// LAYER: accredited-gate-readiness runbook. Emits an
// aura_a4_bt_sig_qualification_runbook_record sentinel carrying the
// BT SIG qualification path - Declaration ID + Qualified Design ID
// + BQTF engagement + launch studio listing.
//
// CONTEXT: aura.md §"Accredited-lab gates" A4:
//   "Bluetooth SIG qualification — BQTF 테스트 + Declaration ID +
//    QDID + launch studio listing"
//
// Honesty (g3 · @D d1):
//   * absorbed=false PERMANENTLY — runbook is NOT a qualified design.
//
// Sentinels:
//   __HEXA_AURA_A4_BT_SIG_QUALIFICATION_RUNBOOK__ PASS
//   AURA_A4_BT_SIG_QUALIFICATION_RUNBOOK_OK gate=GATE_OPEN absorbed=false

let VERSION       = "0.1.0"
let MODULE        = "aura-a4-bt-sig-qualification-runbook"
let GEOMETRY_ID   = "aura_a4_bt_sig_qualification_runbook_v1"
let RECORD_KIND   = "aura_a4_bt_sig_qualification_runbook_record"

fn _membership_block() -> [str] {
    return [
        "BT_SIG_membership: Associate Member (default · low annual fee)",
        "promoter_adopter_associate: Associate (free for small companies · $0/y limit revenue)",
        "membership_required: yes - launch studio + qualified product listing access",
        "company_registration: legal entity name + address + tax/VAT ID + technical contact",
        "compliance_with_BT_SIG_IPR: trademark + patent license per BT SIG terms",
    ]
}

fn _qualification_strategy_block() -> [str] {
    return [
        "strategy: End Product Listing (EPL) reusing Nordic nRF5340 qualified component subsystem",
        "component_reuse_QDID: Nordic nRF5340 has SoC + BLE controller QDID (reusable)",
        "host_qualification: AURA-100 application-level host stack (Zephyr Bluetooth host)",
        "scope: BLE 5.x (LE 1M PHY + 2M PHY) · GAP + GATT + SMP profiles",
        "custom_GATT_service: AURA EEG streaming service (UUID assigned · vendor-specific)",
        "standard_GATT_services: Battery (0x180F) + Device Information (0x180A) + GAP/GATT (0x1800/0x1801)",
    ]
}

fn _test_categories_block() -> [str] {
    return [
        "TCRL_compliance: per current Bluetooth Test Case Reference List (TCRL)",
        "PHY_tests: not required (reused from Nordic nRF5340 component QDID)",
        "LL_tests: not required (controller reused from nRF5340)",
        "HCI_tests: host-controller interface (subset · if exposed)",
        "GAP_tests: General Access Profile - role + advertising + scanning + connection",
        "GATT_tests: ATT/GATT server + client + custom EEG service",
        "SMP_tests: Security Manager Protocol - pairing + bonding (LE Secure Connections)",
        "interoperability_test: IUT vs IUT (Implementation Under Test) cross-tests",
    ]
}

fn _bqtf_engagement_block() -> [str] {
    return [
        "BQTF_candidates: Element Materials Technology (UK/US) · Sporton International (TW)",
        "BQTF_alternative: TUV SUD · Cetecom · DEKRA · 7layers (DE)",
        "selection_criteria: scope + lead time + cost + remote-test support",
        "test_duration_estimate: 4-8 weeks (TCRL categories + retries)",
        "test_fee_estimate: $15-40K per testhouse (host-only · controller reused)",
        "EUT_delivery: 2+ production-build EUT samples + test fixtures",
        "test_report: BQTF compliance report per BT SIG Test Report template",
    ]
}

fn _declaration_qdid_block() -> [str] {
    return [
        "Declaration_fee: $8K per declaration (BT SIG member rate · 2024+)",
        "Declaration_submission: via BT SIG launch studio (online portal)",
        "Declaration_ID: assigned upon declaration submission completion",
        "QDID: Qualified Design ID assigned upon BQTF report acceptance",
        "launch_studio_listing: device name + tradename + qualified products listing",
        "trademark_use: 'Bluetooth' + logo + 'BLUETOOTH ENABLED' use per BT SIG trademark guide",
        "Declaration_validity: indefinite (no expiry · per spec version)",
    ]
}

fn _radio_certification_block() -> [str] {
    return [
        "FCC_15.247_DSSS_FHSS: required for US sale (separate from BT SIG)",
        "FCC_ID: assigned post-FCC certification (or DoC for some classes)",
        "ETSI_EN_300_328: required for EU sale (separate from BT SIG)",
        "RED_2014_53_EU: Radio Equipment Directive conformity (CE marking)",
        "ISED_RSS_247: required for Canada sale",
        "MIC_Japan: required for Japan sale (Type Approval)",
        "KC_Korea: required for Korea sale (KCC Type Registration)",
    ]
}

fn _scope_caveats() -> [str] {
    return [
        "A4 BT SIG qualification runbook is a DRAFT process outline, NOT a qualified design.",
        "Actual qualification requires: BT SIG membership + paid Declaration + BQTF cycles.",
        "Radio certification (FCC/ETSI/ISED/MIC/KC) is INDEPENDENT of BT SIG qualification.",
        "Each market entry requires separate radio cert + label compliance.",
        "absorbed=false PERMANENTLY (g3) - runbook outline, NEVER a BT SIG-qualified device.",
    ]
}

fn _emit_block(label: str, lines: [str]) {
    print("# [" + label + "]")
    let n = lines.len()
    let mut i = 0
    while i < n {
        print("#   - " + lines[i])
        i = i + 1
    }
    print("#")
}

fn _emit_header() {
    print("# AURA A4 - Bluetooth SIG qualification engagement runbook")
    print("# device_target = post-aural / temporal-bone clip BCI · BLE 5.x")
    print("# version = " + VERSION)
    print("# ringfence: runbook outline - NOT a qualified design")
    print("#")
    _emit_block("membership",            _membership_block())
    _emit_block("qualification_strategy",_qualification_strategy_block())
    _emit_block("test_categories",       _test_categories_block())
    _emit_block("bqtf_engagement",       _bqtf_engagement_block())
    _emit_block("declaration_qdid",      _declaration_qdid_block())
    _emit_block("radio_certification",   _radio_certification_block())
}

fn _emit_caveats() {
    let c = _scope_caveats()
    let n = c.len()
    let mut i = 0
    while i < n {
        print("# scope_caveat: " + c[i])
        i = i + 1
    }
}

fn main() {
    _emit_header()
    _emit_caveats()

    print("AURA_A4_BT_SIG_QUALIFICATION_RUNBOOK_OK record_kind=" + RECORD_KIND
        + " geometry_id=" + GEOMETRY_ID
        + " gate=GATE_OPEN absorbed=false"
        + " version=" + VERSION
        + " sections=6 declaration_fee=8K bqtf_duration=4-8wk")

    print("__HEXA_AURA_A4_BT_SIG_QUALIFICATION_RUNBOOK__ PASS")
}
