#!hexa strict
// stdlib/aura/n6_iec62304_traceability.hexa — `aura + N6` IEC 62304
// software traceability matrix (hexa-native).
//
// CONTEXT: IEC 62304:2006 + Amd.1:2015 medical device software lifecycle.
//   AURA-100 = Class B (moderate-LOC + non-serious-injury hazard).
//
// Honesty (g3 · @D d1):
//   * absorbed=false PERMANENTLY — traceability scaffold, NOT a passed DHF.
//
// Sentinels:
//   __HEXA_AURA_N6_IEC62304_TRACEABILITY__ PASS
//   AURA_N6_IEC62304_TRACEABILITY_OK gate=GATE_OPEN absorbed=false

let VERSION       = "0.1.0"
let MODULE        = "aura-n6-iec62304-traceability"
let GEOMETRY_ID   = "aura_n6_iec62304_traceability_v1"
let RECORD_KIND   = "aura_n6_iec62304_traceability_record"

fn _safety_classification_block() -> [str] {
    return [
        "standard: IEC 62304:2006 + Amd.1:2015 (Medical device software lifecycle)",
        "software_safety_class: B (moderate-LOC · non-serious-injury hazard)",
        "rationale: failure may delay biofeedback OR provide incorrect alpha estimate · non-life-critical",
        "Class_A: no injury possible (excluded - skin contact + EEG processing)",
        "Class_B: non-serious injury possible (selected)",
        "Class_C: serious injury OR death possible (excluded - not diagnostic/therapeutic)",
    ]
}

fn _development_process_block() -> [str] {
    return [
        "5.1_planning: software development plan + lifecycle model (V-model · agile-compatible)",
        "5.2_requirements: per IEC 62304 Class B (functional + interface + safety + cybersecurity)",
        "5.3_architecture: high-level component diagram + interfaces + SOUP identification",
        "5.4_detailed_design: Class B does NOT require detailed design (per 62304 5.4)",
        "5.5_implementation: coding standards (MISRA-C subset for embedded · PEP 8 for Python)",
        "5.6_integration_testing: per IEC 62304 Class B integration + system",
        "5.7_system_testing: black-box verification against requirements",
        "5.8_release: configuration management + version control + signed release",
    ]
}

fn _traceability_matrix_block() -> [str] {
    return [
        "row: requirement_id (e.g. SR-01, FR-01, PR-01)",
        "column_1: requirement_text + source (e.g. user need UN-01)",
        "column_2: architecture_component (which module implements)",
        "column_3: implementation_unit (which file/function)",
        "column_4: test_id (which integration + system test verifies)",
        "column_5: risk_control_link (ISO 14971 risk register entry)",
        "column_6: status (planned · implemented · verified · released)",
    ]
}

fn _soup_inventory_block() -> [str] {
    return [
        "SOUP_Software_Of_Unknown_Provenance: per IEC 62304 5.1.4",
        "Zephyr_RTOS_v3.5_plus: SOUP (open-source · evaluated per 5.3.3 + 5.3.4)",
        "Nordic_NCS_v2.5_plus: SOUP (vendor SDK · evaluated)",
        "NimBLE_BLE_stack: SOUP (Apache 2.0 · qualified by Nordic)",
        "MCUboot: SOUP (Apache 2.0 · used per IEC 62304 5.3 evaluation)",
        "MNE_Python: SOUP (BSD-3 · used in companion app · risk-evaluated)",
        "scipy_numpy: SOUP (BSD · ubiquitous · risk-evaluated)",
    ]
}

fn _risk_management_block() -> [str] {
    return [
        "ISO_14971_link: software hazards integrated with device-level risk file",
        "software_hazard_categories: incorrect output · data loss · auth bypass · BLE compromise",
        "risk_control_in_software: input validation + range check + watchdog + secure boot",
        "cybersecurity_per_62304_Amd1: threat model + vulnerability scan + SBOM",
        "software_item_classification: per item (not per project · Class B granular)",
        "risk_traceability: requirement → hazard → risk → control → V&V",
    ]
}

fn _release_documentation_block() -> [str] {
    return [
        "DHF_software_artifacts: SDP + SRS + SDD + STP + STR + RMR + CMR",
        "configuration_management: git + signed tags + SBOM per release",
        "release_authority: SW manager + QA + regulatory affairs sign-off",
        "change_control: per ISO 13485 7.3.9 + IEC 62304 8 (problem resolution + change)",
        "post_market_software_modification: per IEC 62304 9 + ISO 13485 7.3.9",
        "release_artifacts: signed firmware + SBOM + release notes + DHF update",
    ]
}

fn _scope_caveats() -> [str] {
    return [
        "N6 IEC 62304 traceability matrix is a SCAFFOLD, NOT a populated DHF.",
        "Actual DHF requires: real requirements + real impl + real tests + signed records.",
        "Class B downgrade or upgrade requires risk-analysis re-evaluation.",
        "absorbed=false PERMANENTLY (g3) - scaffold, NEVER a passed software audit.",
    ]
}

fn _emit_block(label: str, lines: [str]) {
    print("# [" + label + "]")
    let n = lines.len()
    let mut i = 0
    while i < n {
        print("#   - " + lines[i])
        i = i + 1
    }
    print("#")
}

fn _emit_header() {
    print("# AURA N6 - IEC 62304 software traceability matrix (Class B)")
    print("# device_target = AURA-100 home-healthcare wearable BCI")
    print("# version = " + VERSION)
    print("# ringfence: traceability scaffold - NOT a passed DHF")
    print("#")
    _emit_block("safety_classification",   _safety_classification_block())
    _emit_block("development_process",     _development_process_block())
    _emit_block("traceability_matrix",     _traceability_matrix_block())
    _emit_block("soup_inventory",          _soup_inventory_block())
    _emit_block("risk_management",         _risk_management_block())
    _emit_block("release_documentation",   _release_documentation_block())
}

fn _emit_caveats() {
    let c = _scope_caveats()
    let n = c.len()
    let mut i = 0
    while i < n {
        print("# scope_caveat: " + c[i])
        i = i + 1
    }
}

fn main() {
    _emit_header()
    _emit_caveats()

    print("AURA_N6_IEC62304_TRACEABILITY_OK record_kind=" + RECORD_KIND
        + " geometry_id=" + GEOMETRY_ID
        + " gate=GATE_OPEN absorbed=false"
        + " version=" + VERSION
        + " iec=62304 class=B")

    print("__HEXA_AURA_N6_IEC62304_TRACEABILITY__ PASS")
}
