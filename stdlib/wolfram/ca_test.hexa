// HEXA Standard Library — wolfram/ca tests
//
// Falsifiers for the elementary (Wolfram) cellular-automaton generator.
// All oracles are deterministic + computed by hand from the rule tables —
// no RNG, no I/O, byte-exact.
//
//   T1) wolfram_init_row determinism: rep-seeded pattern ((i+rep)%3 != 0).
//   T2) Rule 90 (Sierpinski / Pascal-mod-2) trajectory cells, rep=0 seed.
//   T3) Rule 30 (chaotic Class-III) trajectory cells, rep=0 seed.
//   T4) Degenerate rules: Rule 0 → all OFF, Rule 255 → all ON (after warmup).
//   T5) Output shape: returned handle holds exactly (n * dim) cells.
//
// NOTE: single-file `hexa build` does NOT flatten `import "stdlib/..."`; this
// test is import-based and runs under the stdlib test harness (which resolves
// the relative import), not a bare single-file build.

import "ca.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn cell(states: int, site: int, dim: int, t: int) -> int {
    let v = farr_get(states, site * dim + t)
    if v > 0.5 { return 1 }
    return 0
}

fn main() {
    // ── T1) init_row determinism ──────────────────────────────────────────
    // rep=0 over n=9: ON iff (i % 3) != 0  → 0 1 1 0 1 1 0 1 1
    let r0 = farr_zeros(9)
    let _ = wolfram_init_row(r0, 9, 0)
    let mut ok0 = true
    let mut i = 0
    while i < 9 {
        let want = 1
        if (i % 3) == 0 { let _w = 0; ok0 = ok0 && (farr_get(r0, i) < 0.5) }
        else { ok0 = ok0 && (farr_get(r0, i) > 0.5) }
        i = i + 1
    }
    check("T1a rep0 init_row pattern", ok0)
    let _ = farr_free(r0)

    // rep=1 over n=9: ON iff ((i+1) % 3) != 0  → 1 1 0 1 1 0 1 1 0
    let r1 = farr_zeros(9)
    let _ = wolfram_init_row(r1, 9, 1)
    let mut ok1 = true
    let mut j = 0
    while j < 9 {
        if ((j + 1) % 3) == 0 { ok1 = ok1 && (farr_get(r1, j) < 0.5) }
        else { ok1 = ok1 && (farr_get(r1, j) > 0.5) }
        j = j + 1
    }
    check("T1b rep1 init_row pattern", ok1)
    let _ = farr_free(r1)

    // ── T2) Rule 90 trajectory (n=6, dim=3, warm=0, rep=0) ─────────────────
    // oracle (states[site*dim+t], grouped by site):
    //   000 111 111 000 111 111
    let s90 = wolfram_run_ca(90, 6, 3, 0, 0)
    check("T2a rule90 site0 t0 = 0", cell(s90, 0, 3, 0) == 0)
    check("T2b rule90 site1 t0 = 1", cell(s90, 1, 3, 0) == 1)
    check("T2c rule90 site1 t2 = 1", cell(s90, 1, 3, 2) == 1)
    check("T2d rule90 site3 t1 = 0", cell(s90, 3, 3, 1) == 0)
    check("T2e rule90 site5 t2 = 1", cell(s90, 5, 3, 2) == 1)
    let _ = farr_free(s90)

    // ── T3) Rule 30 trajectory (n=6, dim=3, warm=0, rep=0) ─────────────────
    // oracle: 001 111 101 001 111 101
    let s30 = wolfram_run_ca(30, 6, 3, 0, 0)
    check("T3a rule30 site0 t0 = 0", cell(s30, 0, 3, 0) == 0)
    check("T3b rule30 site0 t2 = 1", cell(s30, 0, 3, 2) == 1)
    check("T3c rule30 site2 t1 = 0", cell(s30, 2, 3, 1) == 0)
    check("T3d rule30 site2 t2 = 1", cell(s30, 2, 3, 2) == 1)
    check("T3e rule30 site4 t0 = 1", cell(s30, 4, 3, 0) == 1)
    let _ = farr_free(s30)

    // ── T4) Degenerate rules (warm=1 lets the rule take over) ──────────────
    // Rule 0: nothing maps to 1 → all OFF after one step.
    let s0 = wolfram_run_ca(0, 6, 3, 1, 0)
    let mut all_off = true
    let mut k = 0
    while k < 18 { if farr_get(s0, k) > 0.5 { all_off = false }; k = k + 1 }
    check("T4a rule0 all OFF after warmup", all_off)
    let _ = farr_free(s0)

    // Rule 255: every neighborhood maps to 1 → all ON after one step.
    let s255 = wolfram_run_ca(255, 6, 3, 1, 0)
    let mut all_on = true
    let mut m = 0
    while m < 18 { if farr_get(s255, m) < 0.5 { all_on = false }; m = m + 1 }
    check("T4b rule255 all ON after warmup", all_on)
    let _ = farr_free(s255)

    // ── T5) Output shape: handle length == n * dim ─────────────────────────
    let sh = wolfram_run_ca(110, 7, 5, 2, 0)
    check("T5 run_ca handle length == n*dim", farr_len(sh) == 35)
    let _ = farr_free(sh)

    // ── summary ────────────────────────────────────────────────────────────
    println("wolfram/ca: " + to_string(pass_count) + "/" + to_string(total_count) + " passed")
    if pass_count == total_count {
        println("ALL PASS")
    } else {
        println("FAILED: " + failed_name)
    }
}
