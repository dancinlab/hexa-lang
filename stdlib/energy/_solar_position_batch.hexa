// stdlib/energy/_solar_position_batch.hexa — G31 G29-β batch wrapper
// for the hexa-native sun-position CLI.
//
// Sibling to `_solar_position_cli.hexa` (single-timestamp variant). This
// wrapper computes a regular minute-cadence sweep over one day in a
// single process invocation — the producer-side
// `nrel_midc_pyranometer.py` cuts ~1440 subprocess fork+exec calls down
// to ONE, which is the difference between a ~10-minute smoke test and
// a sub-second one.
//
// Usage:
//   hexa run stdlib/energy/_solar_position_batch.hexa \
//     <year> <doy> <utc_hour_start> <step_min> <n_steps> \
//     <lat_deg> <lon_deg> [<pressure_pa>] [<temp_c>]
//
// Defaults: pressure_pa = 101325.0, temp_c = 12.0 (pvlib defaults).
//
// Output: <n_steps> lines on stdout, one apparent_zenith_deg per line,
//         in step order (no header). One trailing newline per value.
//
// Exit: 0 on success, 2 on usage error.
//
// G31 G29-β scope (RFC 013 §6.11 reserved · ARCH §11.4 R8):
//   Producer integration follow-on to `_solar_position_cli.hexa` (G31a).
//   The single-shot variant remains for ad-hoc / point queries; this
//   batch variant is the producer's hot path.
//
// Implementation note (mirror of G31a): no `use "stdlib/sys"` — sys
// transitively references `read_line`, currently broken on the mac
// substrate. Uses global builtins `args()`, `exit()`, `println()`,
// `len()`, `str()` directly. The solar_kernel internal time math
// tolerates `utc_hour > 24` (linear time offset; gmst wraps via
// fmod_floor), so step-wise hour accumulation across the UTC day
// boundary is safe.

use "stdlib/kernels/solar/solar_kernel"

fn main() {
    let argv = args()
    // argv shape: [binary_path, year, doy, utc_hour_start, step_min,
    //              n_steps, lat_deg, lon_deg,
    //              [pressure_pa], [temp_c]]
    let n = len(argv)
    if n < 8 {
        println(
            "usage: hexa run _solar_position_batch.hexa "
            + "<year> <doy> <utc_hour_start> <step_min> <n_steps> "
            + "<lat_deg> <lon_deg> [<pressure_pa>] [<temp_c>]")
        exit(2)
    }

    let year           = argv[1].to_int()
    let doy            = argv[2].to_int()
    let utc_hour_start = argv[3].to_float()
    let step_min       = argv[4].to_float()
    let n_steps        = argv[5].to_int()
    let lat_deg        = argv[6].to_float()
    let lon_deg        = argv[7].to_float()

    let mut pressure_pa = 101325.0
    let mut temp_c = 12.0
    if n >= 9  { pressure_pa = argv[8].to_float() }
    if n >= 10 { temp_c      = argv[9].to_float() }

    let step_hour = step_min / 60.0

    for i in 0..n_steps {
        let utc_hour = utc_hour_start + to_float(i) * step_hour
        let z = apparent_zenith(year, doy, utc_hour, lat_deg, lon_deg,
                                pressure_pa, temp_c)
        println(str(z))
    }
}
