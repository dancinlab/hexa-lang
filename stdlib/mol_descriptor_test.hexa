// HEXA Standard Library — mol Stage-2.6 descriptor tests
//
// Self-validating gate for mol_logp (Wildman-Crippen 1999, JCICS
// 39:868) + mol_tpsa (Ertl 2000, JMC 43:3714).
//
// g3: rdkit is NOT installed → no .py golden. Validated against
// PUBLISHED reference values:
//   * logP anchors recomputed from the verbatim Wildman-Crippen 1999
//     atomic-contribution table (RDKit Data/Crippen.txt transcription):
//       methane  = 1*C1 + 4*H1 = 0.1441 + 4*0.123              = 0.6361
//       ethane   = 2*C1 + 6*H1 = 2*0.1441 + 6*0.123            = 1.0262
//       methanol = C3 + 3*H1 + O2 + H2
//                = -0.2035 + 3*0.123 - 0.2893 - 0.2677         = -0.3915
//       ethanol  = C1 + C3 + 5*H1 + O2 + H2
//                = 0.1441 - 0.2035 + 5*0.123 - 0.2893 - 0.2677 = -0.0014
//       benzene  = 6*C18 + 6*H1 = 6*0.1581 + 6*0.123           = 1.6866
//       CH3Cl    = C3 + 3*H1 + Cl
//                = -0.2035 + 3*0.123 + 0.6895                  =  0.855
//   * TPSA anchors are exact Ertl-2000 Table-1 fragment sums and match
//     RDKit Descriptors.TPSA published worked examples:
//       methanol      O[OH]-*                          = 20.23
//       acetic acid   O[O]=*  +  O[OH]-* = 17.07+20.23 = 37.30
//       methylamine   N[NH2]-*                         = 26.02
//       dimethylether O[O](-*)-*                       =  9.23
//       acetonitrile  N[N]#*                           = 23.79
//       trimethylamine N[N](-*)(-*)-*                  =  3.24
//       pyridine      n[n](:*):*                       = 12.89
//       benzene       (no N/O)                         =  0.00

import "stdlib/mol/mod.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed = ""

fn check(name: string, cond: bool) {
    total_count = total_count + 1
    if cond { pass_count = pass_count + 1 }
    else { if failed == "" { failed = name } }
}

fn fabs(x: float) -> float { if x < 0.0 { return -x } return x }
fn near(a: float, b: float) -> bool { return fabs(a - b) < 0.001 }

fn main() {
    // ── methane CH4 — atoms 0=C, 1..4=H ──
    let methane = mol_new(["C", "H", "H", "H", "H"],
                          [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1]], 0)
    check("methane logP == 0.6361", near(mol_logp(methane), 0.6361))
    check("methane TPSA == 0.0", near(mol_tpsa(methane), 0.0))

    // ── ethane C2H6 — 0,1=C; 2..7=H ──
    let ethane = mol_new(["C", "C", "H", "H", "H", "H", "H", "H"],
                         [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1],
                          [1, 5, 1], [1, 6, 1], [1, 7, 1]], 0)
    check("ethane logP == 1.0262", near(mol_logp(ethane), 1.0262))

    // ── methanol CH3OH — 0=C, 1=O, 2..4=H(on C), 5=H(on O) ──
    let methanol = mol_new(["C", "O", "H", "H", "H", "H"],
                           [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1],
                            [1, 5, 1]], 0)
    check("methanol logP == -0.3915", near(mol_logp(methanol), -0.3915))
    check("methanol TPSA == 20.23", near(mol_tpsa(methanol), 20.23))

    // ── ethanol CH3CH2OH — 0=C 1=C 2=O 3..8=H; O-H at (2,8) ──
    let ethanol = mol_new(["C", "C", "O", "H", "H", "H", "H", "H", "H"],
                          [[0, 1, 1], [1, 2, 1], [0, 3, 1], [0, 4, 1],
                           [0, 5, 1], [1, 6, 1], [1, 7, 1], [2, 8, 1]], 0)
    check("ethanol logP == -0.0014", near(mol_logp(ethanol), -0.0014))
    check("ethanol TPSA == 20.23", near(mol_tpsa(ethanol), 20.23))

    // ── chloromethane CH3Cl — 0=C 1=Cl 2..4=H ──
    let chlorom = mol_new(["C", "Cl", "H", "H", "H"],
                          [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1]], 0)
    check("CH3Cl logP == 0.855", near(mol_logp(chlorom), 0.855))
    check("CH3Cl TPSA == 0.0", near(mol_tpsa(chlorom), 0.0))

    // ── benzene c1ccccc1 + 6 H — 0..5=aromatic C, 6..11=H ──
    let bz_atoms = ["C", "C", "C", "C", "C", "C",
                    "H", "H", "H", "H", "H", "H"]
    let bz_bonds = [[0, 1, 1], [1, 2, 1], [2, 3, 1], [3, 4, 1],
                    [4, 5, 1], [5, 0, 1],
                    [0, 6, 1], [1, 7, 1], [2, 8, 1], [3, 9, 1],
                    [4, 10, 1], [5, 11, 1]]
    let bz_arom = [true, true, true, true, true, true,
                   false, false, false, false, false, false]
    let benzene = mol_new_arom(bz_atoms, bz_bonds, 0, bz_arom)
    check("benzene logP == 1.6866", near(mol_logp(benzene), 1.6866))
    check("benzene TPSA == 0.0", near(mol_tpsa(benzene), 0.0))

    // ── acetic acid CH3-C(=O)-OH ──
    // 0=C(methyl) 1=C(carbonyl) 2=O(=O) 3=O(H) 4,5,6=H(methyl) 7=H(O)
    let aa_atoms = ["C", "C", "O", "O", "H", "H", "H", "H"]
    let aa_bonds = [[0, 1, 1], [1, 2, 2], [1, 3, 1], [0, 4, 1],
                    [0, 5, 1], [0, 6, 1], [3, 7, 1]]
    let acetic = mol_new(aa_atoms, aa_bonds, 0)
    check("acetic acid TPSA == 37.30", near(mol_tpsa(acetic), 37.30))

    // ── methylamine CH3NH2 — 0=C 1=N 2..4=H(C) 5,6=H(N) ──
    let ma = mol_new(["C", "N", "H", "H", "H", "H", "H"],
                     [[0, 1, 1], [0, 2, 1], [0, 3, 1], [0, 4, 1],
                      [1, 5, 1], [1, 6, 1]], 0)
    check("methylamine TPSA == 26.02", near(mol_tpsa(ma), 26.02))

    // ── dimethyl ether CH3-O-CH3 — 0,2=C 1=O 3..8=H ──
    let dme = mol_new(["C", "O", "C", "H", "H", "H", "H", "H", "H"],
                      [[0, 1, 1], [1, 2, 1], [0, 3, 1], [0, 4, 1],
                       [0, 5, 1], [2, 6, 1], [2, 7, 1], [2, 8, 1]], 0)
    check("dimethyl ether TPSA == 9.23", near(mol_tpsa(dme), 9.23))

    // ── acetonitrile CH3-C#N — 0=C 1=C 2=N 3..5=H ──
    let acn = mol_new(["C", "C", "N", "H", "H", "H"],
                      [[0, 1, 1], [1, 2, 3], [0, 3, 1], [0, 4, 1],
                       [0, 5, 1]], 0)
    check("acetonitrile TPSA == 23.79", near(mol_tpsa(acn), 23.79))

    // ── trimethylamine N(CH3)3 — 0=N 1,2,3=C 4..12=H ──
    let tma_atoms = ["N", "C", "C", "C", "H", "H", "H",
                     "H", "H", "H", "H", "H", "H"]
    let tma_bonds = [[0, 1, 1], [0, 2, 1], [0, 3, 1],
                     [1, 4, 1], [1, 5, 1], [1, 6, 1],
                     [2, 7, 1], [2, 8, 1], [2, 9, 1],
                     [3, 10, 1], [3, 11, 1], [3, 12, 1]]
    let tma = mol_new(tma_atoms, tma_bonds, 0)
    check("trimethylamine TPSA == 3.24", near(mol_tpsa(tma), 3.24))

    // ── pyridine c1ccncc1 + 5 H — 0..4=arom C, 3rd ring atom=N(idx3),
    //    actually: 0,1,2=C 3=N 4,5=C; 6..10=H on the 5 carbons ──
    let py_atoms = ["C", "C", "C", "N", "C", "C",
                    "H", "H", "H", "H", "H"]
    let py_bonds = [[0, 1, 1], [1, 2, 1], [2, 3, 1], [3, 4, 1],
                    [4, 5, 1], [5, 0, 1],
                    [0, 6, 1], [1, 7, 1], [2, 8, 1], [4, 9, 1],
                    [5, 10, 1]]
    let py_arom = [true, true, true, true, true, true,
                   false, false, false, false, false]
    let pyridine = mol_new_arom(py_atoms, py_bonds, 0, py_arom)
    check("pyridine TPSA == 12.89", near(mol_tpsa(pyridine), 12.89))

    // ── regression: Stage-1/2 surface still intact after struct ext ──
    let water = mol_new(["O", "H", "H"], [[0, 1, 1], [0, 2, 1]], 0)
    check("water MolWt still 18.015", fabs(mol_weight(water) - 18.015) < 0.001)
    check("water HBD still 2", mol_hbd(water) == 2)

    println("mol: " + mol_status())
    if pass_count == total_count {
        println("__MOL_DESCRIPTOR_TEST__ PASS (" + str(pass_count) + "/" + str(total_count) + ")")
    } else {
        println("__MOL_DESCRIPTOR_TEST__ FAIL (" + str(pass_count) + "/" + str(total_count) + " first-fail=" + failed + ")")
        exit(1)
    }
}
