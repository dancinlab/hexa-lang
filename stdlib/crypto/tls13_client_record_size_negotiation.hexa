// HEXA Standard Library — crypto/tls13_client_record_size_negotiation
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 record_size_limit negotiation (RFC 8449) — pure hexa. Given a
// parsed ServerHello extensions block, extract the server's negotiated
// record_size_limit (extension type 28 / 0x001c) and provide a small
// helper for the send-side limit enforcement.
//
// RFC 8449 §4: peers advertise the largest record-plaintext fragment
// (including the TLS 1.3 inner content-type byte) they are willing to
// receive, in the range [64, 16385]. 16385 = 2^14 + 1 — the implicit
// default when the extension is absent (per RFC 8446 §5.1 plus the
// inner-content-type byte). A peer MUST NOT send a record-plaintext
// fragment larger than the receiver's advertised limit.
//
// Surface:
//   pub fn tls13_client_extract_record_size_limit(
//       record_bytes:  [int],
//       sh_ext_off:    int,
//       sh_ext_len:    int
//   ) -> Tls13RecordSizeNegotiated
//     Walk SH extensions. If record_size_limit is present, parse its
//     2-byte uint16 value via tls13_record_size_limit_parse and classify:
//       limit < 64       — kind="too-small"
//       64 ≤ limit       — kind="ok"
//     If absent:         — kind="ext-absent", limit defaults to 16385.
//
//   pub fn tls13_client_enforce_send_limit(
//       payload_len:        int,
//       negotiated_limit:   int
//   ) -> bool
//     Returns true iff (payload_len + 1) ≤ negotiated_limit. The +1
//     accounts for the TLS 1.3 inner content-type byte appended to the
//     plaintext before AEAD seal (RFC 8446 §5.2).
//
// Building blocks (all pre-LANDED):
//   - tls13_record_size_limit_parse  (stdlib/crypto/tls13_record_size_limit)
//   - tls13_ext_type / length / value_start / next (stdlib/crypto/tls13_extensions)

use "stdlib/crypto/tls13_record_size_limit"
use "stdlib/crypto/tls13_extensions"

let TLS_EXT_RECORD_SIZE_LIMIT: int = 28
let TLS13_DEFAULT_RECORD_SIZE_LIMIT: int = 16385
let TLS13_MIN_RECORD_SIZE_LIMIT: int = 64

// Result of the SH extensions walk for record_size_limit.
//   kind ∈ {"ok", "too-small", "ext-absent"}
//   limit       — the negotiated value (or default 16385 if absent)
//   ext_present — true iff the extension was found in SH
//   error_got   — when kind="too-small", the raw under-spec value the
//                 server sent; 0 otherwise. Lets the caller surface a
//                 precise diagnostic without re-walking the extensions.
struct Tls13RecordSizeNegotiated {
    kind:        str,
    limit:       int,
    ext_present: bool,
    error_got:   int
}

@pure
pub fn tls13_client_extract_record_size_limit(
    record_bytes: [int],
    sh_ext_off:   int,
    sh_ext_len:   int
) -> Tls13RecordSizeNegotiated {
    let end = sh_ext_off + sh_ext_len
    let mut o = sh_ext_off
    while o < end {
        let etype = tls13_ext_type(record_bytes, o)
        let elen = tls13_ext_length(record_bytes, o)
        let evstart = tls13_ext_value_start(record_bytes, o)
        if etype == TLS_EXT_RECORD_SIZE_LIMIT {
            // Build the extension VALUE slice (length = elen) for the parser.
            let mut ext_value: [int] = []
            let mut k = 0
            while k < elen {
                ext_value.push(record_bytes[evstart + k])
                k = k + 1
            }
            let parsed = tls13_record_size_limit_parse(ext_value)
            if parsed < TLS13_MIN_RECORD_SIZE_LIMIT {
                return Tls13RecordSizeNegotiated {
                    kind:        "too-small",
                    limit:       TLS13_DEFAULT_RECORD_SIZE_LIMIT,
                    ext_present: true,
                    error_got:   parsed
                }
            }
            return Tls13RecordSizeNegotiated {
                kind:        "ok",
                limit:       parsed,
                ext_present: true,
                error_got:   0
            }
        }
        o = tls13_ext_next(record_bytes, o)
    }
    return Tls13RecordSizeNegotiated {
        kind:        "ext-absent",
        limit:       TLS13_DEFAULT_RECORD_SIZE_LIMIT,
        ext_present: false,
        error_got:   0
    }
}

// Send-side enforcement: a record-plaintext fragment carries
// payload_len application bytes plus 1 inner-content-type byte
// (RFC 8446 §5.2) — both count toward the receiver's negotiated
// record_size_limit (RFC 8449 §4). Returns true if it fits.
@pure
pub fn tls13_client_enforce_send_limit(
    payload_len:      int,
    negotiated_limit: int
) -> bool {
    return (payload_len + 1) <= negotiated_limit
}
