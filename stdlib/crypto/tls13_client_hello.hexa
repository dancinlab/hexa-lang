// HEXA Standard Library — crypto/tls13_client_hello
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 ClientHello body builder (RFC 8446 §4.1.2) — pure hexa. Composes
// the leading legacy fields (version · random · session_id · cipher_suites
// · compression_methods) with a caller-supplied concatenation of extensions
// into the wire-format ClientHello body. Wrap with stdlib/crypto/tls13_wire
// for the 4-byte HandshakeMessage header. let-mut idiom (#1506).
//
// Structure (RFC 8446 §4.1.2):
//   ProtocolVersion legacy_version = 0x0303
//   Random random[32]
//   opaque legacy_session_id<0..32>
//   CipherSuite cipher_suites<2..2^16-2>
//   opaque legacy_compression_methods<1..2^8-1> = single 0 byte
//   Extension extensions<8..2^16-1>
//
// Surface:
//   pub fn tls13_client_hello_body(
//       random: [int],            — exactly 32 bytes
//       session_id: [int],        — 0..32 bytes (TLS 1.3 commonly 0 or 32)
//       cipher_suites: [int],     — list of uint16 suite codes
//       extensions_concat: [int]  — already concatenated; this fn wraps with uint16 length
//   ) -> [int]
//
// CipherSuite constants (RFC 8446 §B.4):
//   TLS_AES_128_GCM_SHA256       = 0x1301   (mandatory)
//   TLS_AES_256_GCM_SHA384       = 0x1302
//   TLS_CHACHA20_POLY1305_SHA256 = 0x1303
//   TLS_AES_128_CCM_SHA256       = 0x1304
//   TLS_AES_128_CCM_8_SHA256     = 0x1305

let TLS_AES_128_GCM_SHA256: int = 0x1301
let TLS_AES_256_GCM_SHA384: int = 0x1302
let TLS_CHACHA20_POLY1305_SHA256: int = 0x1303
let TLS_AES_128_CCM_SHA256: int = 0x1304
let TLS_AES_128_CCM_8_SHA256: int = 0x1305

@pure
pub fn tls13_client_hello_body(random: [int], session_id: [int], cipher_suites: [int], extensions_concat: [int]) -> [int] {
    let mut o: [int] = []
    // legacy_version = 0x0303 (TLS 1.2 placeholder; real version goes in supported_versions ext)
    o.push(0x03)
    o.push(0x03)
    // random — exactly 32 bytes
    let mut i = 0
    while i < 32 { o.push(if i < len(random) { random[i] } else { 0 }); i = i + 1 }
    // legacy_session_id — uint8 length + bytes
    let sl = len(session_id)
    o.push(sl & 0xFF)
    i = 0
    while i < sl { o.push(session_id[i]); i = i + 1 }
    // cipher_suites — uint16 list_len + uint16 codes
    let csn = len(cipher_suites)
    let cs_bytes = csn * 2
    o.push((cs_bytes >> 8) & 0xFF)
    o.push(cs_bytes & 0xFF)
    i = 0
    while i < csn {
        o.push((cipher_suites[i] >> 8) & 0xFF)
        o.push(cipher_suites[i] & 0xFF)
        i = i + 1
    }
    // legacy_compression_methods — single 0 byte ([0x01, 0x00] = length-1 vector with null)
    o.push(0x01)
    o.push(0x00)
    // extensions vector — uint16 length + extensions
    let en = len(extensions_concat)
    o.push((en >> 8) & 0xFF)
    o.push(en & 0xFF)
    i = 0
    while i < en { o.push(extensions_concat[i]); i = i + 1 }
    return o
}
