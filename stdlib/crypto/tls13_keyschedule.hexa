// HEXA Standard Library — crypto/tls13_keyschedule
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 key schedule (RFC 8446 §7.1) — pure hexa, building on the verified
// HMAC-SHA256 stack (stdlib/core/hash/hmac · #1514). This is the first
// self-contained, vector-verifiable unit of the TLS 1.3 leg: the HKDF
// Extract/Expand-Label/Derive-Secret primitives + the early→handshake→master
// secret chain. The record layer, handshake state machine, and X.509 path are
// separate (multi-session) units; the key schedule stands alone with KATs.
//
// Surface:
//   pub fn tls13_hkdf_extract(salt: [int], ikm: [int]) -> [int]            — HKDF-Extract = HMAC(salt, ikm)
//   pub fn tls13_hkdf_expand(prk: [int], info: [int], length: int) -> [int] — HKDF-Expand
//   pub fn tls13_expand_label(secret: [int], label: [int], context: [int], length: int) -> [int]
//   pub fn tls13_derive_secret(secret: [int], label: [int], thash: [int]) -> [int]
//   pub fn tls13_early_secret(psk: [int]) -> [int]                         — HKDF-Extract(0, PSK)
//   pub fn tls13_derive_handshake_secret(early: [int], ecdhe: [int]) -> [int]
//   pub fn tls13_derive_master_secret(handshake: [int]) -> [int]
//
// Verified vectors (RFC 8448 §3 "Simple 1-RTT Handshake", PSK absent):
//   early_secret  = HKDF-Extract(0[32], 0[32])
//                 = 33ad0a1c607ec03b09e6cd9893680ce210adf300aa1f2660e1b22e10f170f92a
//   derived       = Derive-Secret(early, "derived", "")
//                 = 6f2615a108c702c5678f54fc9dbab69716c076189c48250cebeac3576c3611ba
//   Expand-Label(early, "c e traffic", "", 16) = 8318ffbdf123497b961ecd3842d0043a
// Cross-checked byte-exact against an independent HKDF reference (python
// hmac/hashlib); both reproduce the RFC 8448 documented bytes.

use "stdlib/core/hash/hmac"

let _TLS_HASHLEN: int = 32

// HKDF-Extract(salt, IKM) = HMAC-Hash(salt, IKM). RFC 5869 §2.2.
@pure
pub fn tls13_hkdf_extract(salt: [int], ikm: [int]) -> [int] {
    return hmac_sha256_bytes(salt, ikm)
}

// HKDF-Expand(PRK, info, L) = first L bytes of T(1)|T(2)|…  RFC 5869 §2.3.
//   T(0) = empty ; T(i) = HMAC(PRK, T(i-1) || info || i)
@pure
pub fn tls13_hkdf_expand(prk: [int], info: [int], length: int) -> [int] {
    let mut okm: [int] = []
    let mut t: [int] = []
    let mut i = 1
    while len(okm) < length {
        // block = T(i-1) || info || single-byte counter i
        let mut block: [int] = []
        let mut j = 0
        while j < len(t) { block.push(t[j]); j = j + 1 }
        j = 0
        while j < len(info) { block.push(info[j]); j = j + 1 }
        block.push(i & 0xFF)
        t = hmac_sha256_bytes(prk, block)
        j = 0
        while j < len(t) { okm.push(t[j]); j = j + 1 }
        i = i + 1
    }
    // truncate to L
    let mut out: [int] = []
    i = 0
    while i < length { out.push(okm[i]); i = i + 1 }
    return out
}

// HKDF-Expand-Label(Secret, Label, Context, Length)  RFC 8446 §7.1.
//   HkdfLabel = uint16 length || opaque label<7..255>="tls13 "+Label || opaque context<0..255>
@pure
pub fn tls13_expand_label(secret: [int], label: [int], context: [int], length: int) -> [int] {
    // "tls13 " = 74 6c 73 31 33 20
    let prefix = [0x74, 0x6c, 0x73, 0x31, 0x33, 0x20]
    let mut full: [int] = []
    let mut j = 0
    while j < len(prefix) { full.push(prefix[j]); j = j + 1 }
    j = 0
    while j < len(label) { full.push(label[j]); j = j + 1 }
    // serialize HkdfLabel
    let mut hl: [int] = []
    hl.push((length >> 8) & 0xFF)   // uint16 length, big-endian
    hl.push(length & 0xFF)
    hl.push(len(full) & 0xFF)        // 1-byte label vector length
    j = 0
    while j < len(full) { hl.push(full[j]); j = j + 1 }
    hl.push(len(context) & 0xFF)     // 1-byte context vector length
    j = 0
    while j < len(context) { hl.push(context[j]); j = j + 1 }
    return tls13_hkdf_expand(secret, hl, length)
}

// Derive-Secret(Secret, Label, Messages) = Expand-Label(Secret, Label, Hash(Messages), Hash.length).
// Pass the already-computed transcript hash as `thash` (Hash(Messages)).  RFC 8446 §7.1.
@pure
pub fn tls13_derive_secret(secret: [int], label: [int], thash: [int]) -> [int] {
    return tls13_expand_label(secret, label, thash, _TLS_HASHLEN)
}

// Early Secret = HKDF-Extract(0, PSK). With no PSK pass psk = 32 zero bytes.
@pure
pub fn tls13_early_secret(psk: [int]) -> [int] {
    let mut zero: [int] = []
    let mut i = 0
    while i < _TLS_HASHLEN { zero.push(0); i = i + 1 }
    let mut ikm = psk
    if len(ikm) == 0 { ikm = zero }
    return tls13_hkdf_extract(zero, ikm)
}

// Handshake Secret = HKDF-Extract(Derive-Secret(Early, "derived", ""), (EC)DHE).
@pure
pub fn tls13_derive_handshake_secret(early: [int], ecdhe: [int]) -> [int] {
    // "derived" = 64 65 72 69 76 65 64
    let label = [0x64, 0x65, 0x72, 0x69, 0x76, 0x65, 0x64]
    // empty-transcript hash = SHA-256("")
    let empty: [int] = []
    let ehash = sha256_digest_bytes(empty)
    let salt = tls13_derive_secret(early, label, ehash)
    return tls13_hkdf_extract(salt, ecdhe)
}

// Master Secret = HKDF-Extract(Derive-Secret(Handshake, "derived", ""), 0).
@pure
pub fn tls13_derive_master_secret(handshake: [int]) -> [int] {
    let label = [0x64, 0x65, 0x72, 0x69, 0x76, 0x65, 0x64]
    let empty: [int] = []
    let ehash = sha256_digest_bytes(empty)
    let salt = tls13_derive_secret(handshake, label, ehash)
    let mut zero: [int] = []
    let mut i = 0
    while i < _TLS_HASHLEN { zero.push(0); i = i + 1 }
    return tls13_hkdf_extract(salt, zero)
}
