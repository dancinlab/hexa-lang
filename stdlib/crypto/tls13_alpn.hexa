// HEXA Standard Library — crypto/tls13_alpn
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 ALPN extension (Application-Layer Protocol Negotiation · RFC 7301)
// — pure hexa. Carries the list of application protocols (e.g. "h2",
// "http/1.1") the client speaks; the server picks one. let-mut (#1506).
//
// Structure (RFC 7301 §3.1):
//   extension_data = ProtocolNameList = uint16 list_len || ProtocolName[]
//   ProtocolName    = opaque name<1..255>  (= uint8 length + bytes)
//
// Surface:
//   pub fn tls13_ext_alpn(protocols: [string]) -> [int]
//   pub fn tls13_alpn_parse(ext_value: [int]) -> [string]

let _TLS_EXT_ALPN: int = 0x0010

@pure
pub fn tls13_ext_alpn(protocols: [string]) -> [int] {
    // build the ProtocolName entries
    let mut entries: [int] = []
    let mut i = 0
    while i < len(protocols) {
        let p = protocols[i]
        let nb = len(p)
        entries.push(nb & 0xFF)
        let mut j = 0
        while j < nb { entries.push(p.char_code_at(j)); j = j + 1 }
        i = i + 1
    }
    let el = len(entries)
    // inner = uint16 list_len || entries
    let mut inner: [int] = []
    inner.push((el >> 8) & 0xFF)
    inner.push(el & 0xFF)
    i = 0
    while i < el { inner.push(entries[i]); i = i + 1 }
    // outer Extension TLV
    let il = len(inner)
    let mut o: [int] = []
    o.push((_TLS_EXT_ALPN >> 8) & 0xFF)
    o.push(_TLS_EXT_ALPN & 0xFF)
    o.push((il >> 8) & 0xFF)
    o.push(il & 0xFF)
    i = 0
    while i < il { o.push(inner[i]); i = i + 1 }
    return o
}

@pure
pub fn tls13_alpn_parse(ext_value: [int]) -> [string] {
    let mut out: [string] = []
    if len(ext_value) < 2 { return out }
    let list_len = ((ext_value[0] & 0xFF) << 8) | (ext_value[1] & 0xFF)
    let mut i = 2
    let end = 2 + list_len
    while i < end && i < len(ext_value) {
        let nb = ext_value[i] & 0xFF
        i = i + 1
        let mut chars: [string] = []
        let mut j = 0
        while j < nb && i + j < len(ext_value) {
            chars.push(chr(ext_value[i + j] & 0xFF))
            j = j + 1
        }
        out.push(chars.join(""))
        i = i + nb
    }
    return out
}
