// HEXA Standard Library — crypto/poly1305
//
// @version 0.1.0
// @capabilities [pure]
//
// Poly1305 one-time MAC (RFC 8439 §2.5) — pure hexa. The h*r mod (2^130-5)
// arithmetic uses the poly1305-donna 5×26-bit limb layout so every partial
// product fits in a 64-bit signed int (max term ~2^57, sum ~2^60 < 2^63).
// This is the missing half of ChaCha20-Poly1305 AEAD (the other half,
// chacha20, already lands at stdlib/crypto/chacha20). let-mut idiom (#1506).
//
// Surface:
//   pub fn poly1305_mac(msg: [int], key: [int]) -> [int]   — 16-byte tag; key = 32 bytes (r‖s)
//
// Verified vector (RFC 8439 §2.5.2):
//   key = 85d6be7857556d337f4452fe42d506a80103808afb0db2fd4abff6af4149f51b
//   msg = "Cryptographic Forum Research Group"
//   tag = a8061dc1305136c6c22b8baf0c0127a9

let _POLY_MASK26: int = 0x3ffffff   // 2^26 - 1

// little-endian 32-bit load from bytes[off..off+4]
@pure
fn _ld32(b: [int], off: int) -> int {
    return b[off] + (b[off+1] << 8) + (b[off+2] << 16) + (b[off+3] << 24)
}

@pure
pub fn poly1305_mac(msg: [int], key: [int]) -> [int] {
    // clamp r (first 16 bytes): r &= 0x0ffffffc0ffffffc0ffffffc0fffffff
    let t0 = _ld32(key, 0)
    let t1 = _ld32(key, 4)
    let t2 = _ld32(key, 8)
    let t3 = _ld32(key, 12)
    // split into 5 26-bit limbs with the clamp masks baked in
    let mut r0 = t0 & 0x3ffffff
    let mut r1 = ((t0 >> 26) | (t1 << 6)) & 0x3ffff03
    let mut r2 = ((t1 >> 20) | (t2 << 12)) & 0x3ffc0ff
    let mut r3 = ((t2 >> 14) | (t3 << 18)) & 0x3f03fff
    let mut r4 = (t3 >> 8) & 0x00fffff
    // precomputed 5*r{1..4} for the mod-(2^130-5) fold
    let s1 = r1 * 5
    let s2 = r2 * 5
    let s3 = r3 * 5
    let s4 = r4 * 5
    // accumulator h (5 limbs)
    let mut h0 = 0
    let mut h1 = 0
    let mut h2 = 0
    let mut h3 = 0
    let mut h4 = 0

    let mut i = 0
    let n = len(msg)
    while i < n {
        // build one block (≤16 bytes) into 4 little-endian 32-bit words + hibit
        let mut blk: [int] = []
        let mut j = 0
        while j < 16 {
            if i + j < n { blk.push(msg[i + j]) } else { blk.push(0) }
            j = j + 1
        }
        let blocklen = if n - i >= 16 { 16 } else { n - i }
        // the high bit: 2^(8*blocklen). full block → bit128 (limb4 += 2^24);
        // partial block → append a 0x01 byte right after the data, then pad 0.
        let mut hibit = 1 << 24      // for a full 16-byte block
        if blocklen < 16 {
            blk[blocklen] = 1
            hibit = 0                // the 1 is already inside the limb data
        }
        let b0 = _ld32(blk, 0)
        let b1 = _ld32(blk, 4)
        let b2 = _ld32(blk, 8)
        let b3 = _ld32(blk, 12)
        // h += block (as 5 26-bit limbs)
        h0 = h0 + (b0 & 0x3ffffff)
        h1 = h1 + (((b0 >> 26) | (b1 << 6)) & 0x3ffffff)
        h2 = h2 + (((b1 >> 20) | (b2 << 12)) & 0x3ffffff)
        h3 = h3 + (((b2 >> 14) | (b3 << 18)) & 0x3ffffff)
        h4 = h4 + ((b3 >> 8) | hibit)
        // h *= r  (mod 2^130-5)
        let d0 = h0*r0 + h1*s4 + h2*s3 + h3*s2 + h4*s1
        let d1 = h0*r1 + h1*r0 + h2*s4 + h3*s3 + h4*s2
        let d2 = h0*r2 + h1*r1 + h2*r0 + h3*s4 + h4*s3
        let d3 = h0*r3 + h1*r2 + h2*r1 + h3*r0 + h4*s4
        let d4 = h0*r4 + h1*r3 + h2*r2 + h3*r1 + h4*r0
        // partial reduction / carry
        let mut c = d0 >> 26
        h0 = d0 & 0x3ffffff
        let dd1 = d1 + c
        c = dd1 >> 26
        h1 = dd1 & 0x3ffffff
        let dd2 = d2 + c
        c = dd2 >> 26
        h2 = dd2 & 0x3ffffff
        let dd3 = d3 + c
        c = dd3 >> 26
        h3 = dd3 & 0x3ffffff
        let dd4 = d4 + c
        c = dd4 >> 26
        h4 = dd4 & 0x3ffffff
        h0 = h0 + c * 5
        c = h0 >> 26
        h0 = h0 & 0x3ffffff
        h1 = h1 + c
        i = i + 16
    }

    // final full carry
    let mut c = h1 >> 26
    h1 = h1 & 0x3ffffff
    h2 = h2 + c
    c = h2 >> 26
    h2 = h2 & 0x3ffffff
    h3 = h3 + c
    c = h3 >> 26
    h3 = h3 & 0x3ffffff
    h4 = h4 + c
    c = h4 >> 26
    h4 = h4 & 0x3ffffff
    h0 = h0 + c * 5
    c = h0 >> 26
    h0 = h0 & 0x3ffffff
    h1 = h1 + c

    // compute h - p (p = 2^130-5) to decide final reduction
    let mut g0 = h0 + 5
    c = g0 >> 26
    g0 = g0 & 0x3ffffff
    let mut g1 = h1 + c
    c = g1 >> 26
    g1 = g1 & 0x3ffffff
    let mut g2 = h2 + c
    c = g2 >> 26
    g2 = g2 & 0x3ffffff
    let mut g3 = h3 + c
    c = g3 >> 26
    g3 = g3 & 0x3ffffff
    let g4 = h4 + c - (1 << 26)
    // if g4 >= 0 (i.e. h >= p) use g, else keep h.  mask = (g4 >> 63) ... use sign.
    let neg = if g4 < 0 { 1 } else { 0 }
    if neg == 0 {
        h0 = g0
        h1 = g1
        h2 = g2
        h3 = g3
        // h4 = g4, but we don't need h4 below (tag is 128-bit)
    }

    // serialize h (low 128 bits) into 4 little-endian 32-bit words
    let f0 = (h0 | (h1 << 26)) & 0xffffffff
    let f1 = ((h1 >> 6) | (h2 << 20)) & 0xffffffff
    let f2 = ((h2 >> 12) | (h3 << 14)) & 0xffffffff
    let f3 = ((h3 >> 18) | (h4 << 8)) & 0xffffffff

    // tag = (h + s) mod 2^128 ; s = key[16..32]
    let s0 = _ld32(key, 16)
    let s1w = _ld32(key, 20)
    let s2w = _ld32(key, 24)
    let s3w = _ld32(key, 28)
    let mut acc = f0 + s0
    let w0 = acc & 0xffffffff
    acc = f1 + s1w + (acc >> 32)
    let w1 = acc & 0xffffffff
    acc = f2 + s2w + (acc >> 32)
    let w2 = acc & 0xffffffff
    acc = f3 + s3w + (acc >> 32)
    let w3 = acc & 0xffffffff

    let mut tag: [int] = []
    let words = [w0, w1, w2, w3]
    let mut wi = 0
    while wi < 4 {
        let w = words[wi]
        tag.push(w & 0xFF)
        tag.push((w >> 8) & 0xFF)
        tag.push((w >> 16) & 0xFF)
        tag.push((w >> 24) & 0xFF)
        wi = wi + 1
    }
    return tag
}
