// HEXA Standard Library — crypto/sha512 self-test
// @ci_gate
use "stdlib/crypto/sha512"
let mut pass = 0
let mut total = 0
fn ck(name: string, got: string, want: string) {
    total = total + 1
    if got == want { pass = pass + 1 } else { println("FAIL " + name) }
}
fn main() {
    ck("empty", sha512_hex([]), "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")
    ck("abc", sha512_hex([0x61,0x62,0x63]), "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f")
    println("sha512 self-test: " + to_string(pass) + "/" + to_string(total))
    if pass == total { println("PASS") } else { println("FAILED") }
}
