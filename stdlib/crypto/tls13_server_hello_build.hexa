// HEXA Standard Library — crypto/tls13_server_hello_build
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 ServerHello body builder (RFC 8446 §4.1.3) — pure hexa, symmetric
// to tls13_client_hello (build) + tls13_server_hello (parse). Lets us
// produce SH byte sequences for testing AND compose HelloRetryRequest
// (which is a ServerHello with the magic random). let-mut idiom (#1506).
//
// Structure (RFC 8446 §4.1.3):
//   ProtocolVersion legacy_version = 0x0303
//   Random random[32]
//   opaque legacy_session_id_echo<0..32>
//   CipherSuite cipher_suite (2 bytes)
//   uint8 legacy_compression_method = 0
//   Extension extensions<6..2^16-1>
//
// Surface:
//   pub fn tls13_server_hello_body(
//       random32: [int],          — exactly 32 bytes
//       session_id_echo: [int],   — 0..32 bytes (echo of ClientHello)
//       cipher_suite: int,        — uint16 selected suite code
//       extensions_concat: [int]  — already concatenated extensions; this fn wraps with uint16 length
//   ) -> [int]

@pure
pub fn tls13_server_hello_body(random32: [int], session_id_echo: [int], cipher_suite: int, extensions_concat: [int]) -> [int] {
    let mut o: [int] = []
    // legacy_version 0x0303
    o.push(0x03)
    o.push(0x03)
    // random — 32 bytes
    let mut i = 0
    while i < 32 { o.push(if i < len(random32) { random32[i] } else { 0 }); i = i + 1 }
    // session_id_echo (uint8 len + bytes)
    let sl = len(session_id_echo)
    o.push(sl & 0xFF)
    i = 0
    while i < sl { o.push(session_id_echo[i]); i = i + 1 }
    // cipher_suite (uint16 BE)
    o.push((cipher_suite >> 8) & 0xFF)
    o.push(cipher_suite & 0xFF)
    // legacy_compression_method = 0
    o.push(0)
    // extensions vector (uint16 len + bytes)
    let en = len(extensions_concat)
    o.push((en >> 8) & 0xFF)
    o.push(en & 0xFF)
    i = 0
    while i < en { o.push(extensions_concat[i]); i = i + 1 }
    return o
}
