// HEXA Standard Library — crypto/tls13_wire
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 wire-format basic headers (RFC 8446 §5.1 + §4) — pure hexa. The
// first brick of the TLS 1.3 handshake state-machine series: build/parse
// the 5-byte TLSPlaintext record header and the 4-byte HandshakeMessage
// header. Specific message bodies (ClientHello, ServerHello, …) follow in
// later PRs. let-mut idiom (#1506).
//
// Surface — build:
//   pub fn tls13_record_header(content_type: int, version: int, length: int) -> [int]
//   pub fn tls13_hs_header(msg_type: int, length: int) -> [int]
// Surface — parse (b: [int] at offset o):
//   pub fn tls13_record_type(b: [int], o: int) -> int
//   pub fn tls13_record_version(b: [int], o: int) -> int
//   pub fn tls13_record_length(b: [int], o: int) -> int
//   pub fn tls13_hs_type(b: [int], o: int) -> int
//   pub fn tls13_hs_length(b: [int], o: int) -> int
//
// Constants (RFC 8446):
//   TLS_RT_HANDSHAKE = 0x16   TLS_RT_APPLICATION_DATA = 0x17   TLS_RT_ALERT = 0x15
//   TLS_HS_CLIENT_HELLO = 0x01   TLS_HS_SERVER_HELLO = 0x02
//   TLS_HS_ENCRYPTED_EXTENSIONS = 0x08   TLS_HS_CERTIFICATE = 0x0b
//   TLS_HS_CERTIFICATE_VERIFY = 0x0f   TLS_HS_FINISHED = 0x14

let TLS_RT_HANDSHAKE: int = 0x16
let TLS_RT_APPLICATION_DATA: int = 0x17
let TLS_RT_ALERT: int = 0x15
let TLS_RT_CHANGE_CIPHER_SPEC: int = 0x14

let TLS_HS_CLIENT_HELLO: int = 0x01
let TLS_HS_SERVER_HELLO: int = 0x02
let TLS_HS_ENCRYPTED_EXTENSIONS: int = 0x08
let TLS_HS_CERTIFICATE: int = 0x0b
let TLS_HS_CERTIFICATE_VERIFY: int = 0x0f
let TLS_HS_FINISHED: int = 0x14

// TLSPlaintext header: opaque_type(1) || legacy_version(2 big-endian) || length(2 big-endian)
@pure
pub fn tls13_record_header(content_type: int, version: int, length: int) -> [int] {
    let mut h: [int] = []
    h.push(content_type & 0xFF)
    h.push((version >> 8) & 0xFF)
    h.push(version & 0xFF)
    h.push((length >> 8) & 0xFF)
    h.push(length & 0xFF)
    return h
}

@pure
pub fn tls13_record_type(b: [int], o: int) -> int {
    return b[o] & 0xFF
}

@pure
pub fn tls13_record_version(b: [int], o: int) -> int {
    return ((b[o + 1] & 0xFF) << 8) | (b[o + 2] & 0xFF)
}

@pure
pub fn tls13_record_length(b: [int], o: int) -> int {
    return ((b[o + 3] & 0xFF) << 8) | (b[o + 4] & 0xFF)
}

// HandshakeMessage header: msg_type(1) || length(3 big-endian uint24)
@pure
pub fn tls13_hs_header(msg_type: int, length: int) -> [int] {
    let mut h: [int] = []
    h.push(msg_type & 0xFF)
    h.push((length >> 16) & 0xFF)
    h.push((length >> 8) & 0xFF)
    h.push(length & 0xFF)
    return h
}

@pure
pub fn tls13_hs_type(b: [int], o: int) -> int {
    return b[o] & 0xFF
}

@pure
pub fn tls13_hs_length(b: [int], o: int) -> int {
    return ((b[o + 1] & 0xFF) << 16) | ((b[o + 2] & 0xFF) << 8) | (b[o + 3] & 0xFF)
}
