// HEXA Standard Library — crypto/tls13_hrr_compose
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 HelloRetryRequest composer (RFC 8446 §4.1.4) — pure hexa. HRR is
// wire-identical to ServerHello but uses the magic 32-byte random
// (SHA-256 of "HelloRetryRequest") that signals "negotiate a different
// key_share / cookie". The key_share extension in HRR carries only the
// selected_group (no public key), not a full KeyShareEntry.
// let-mut idiom (#1506).
//
// Surface:
//   pub fn tls13_compose_hrr(session_id_echo: [int], cipher_suite: int, selected_group: int) -> [int]
//   pub fn tls13_ext_key_share_hrr(selected_group: int) -> [int]

use "stdlib/crypto/tls13_server_hello_build"
use "stdlib/crypto/tls13_misc"
use "stdlib/crypto/tls13_extensions"

let _TLS_EXT_KEY_SHARE_HRR: int = 0x0033

// key_share extension in HRR form: just NamedGroup (2 bytes), no public key.
@pure
pub fn tls13_ext_key_share_hrr(selected_group: int) -> [int] {
    return [(_TLS_EXT_KEY_SHARE_HRR >> 8) & 0xFF, _TLS_EXT_KEY_SHARE_HRR & 0xFF,
            0, 2,
            (selected_group >> 8) & 0xFF, selected_group & 0xFF]
}

@pure
pub fn tls13_compose_hrr(session_id_echo: [int], cipher_suite: int, selected_group: int) -> [int] {
    let sv = tls13_ext_supported_versions_server_tls13()
    let ks = tls13_ext_key_share_hrr(selected_group)
    // concatenate extensions
    let mut ext_concat: [int] = []
    let mut i = 0
    while i < len(sv) { ext_concat.push(sv[i]); i = i + 1 }
    i = 0
    while i < len(ks) { ext_concat.push(ks[i]); i = i + 1 }
    return tls13_server_hello_body(tls13_hrr_random(), session_id_echo, cipher_suite, ext_concat)
}
