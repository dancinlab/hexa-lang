// HEXA Standard Library — crypto/tls13_cert_compression
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 compress_certificate extension (RFC 8879) — pure hexa. Advertises
// which CertificateCompressionAlgorithm codes the peer accepts so a large
// cert chain can be sent compressed (zlib / brotli / zstd). The actual
// CompressedCertificate message is sent in place of Certificate when the
// peer signaled support. let-mut idiom (#1506).
//
// Structure (RFC 8879 §3):
//   enum {
//       zlib(1), brotli(2), zstd(3), (255)
//   } CertificateCompressionAlgorithm;
//   struct {
//       CertificateCompressionAlgorithm algorithms<2..2^8-2>;
//   } CertificateCompressionAlgorithms;
//
// Surface:
//   pub fn tls13_ext_cert_compression(algs: [int]) -> [int]
//   pub fn tls13_cert_compression_parse(ext_value: [int]) -> [int]
//
// Constants:
//   TLS_CERT_COMP_ZLIB   = 1
//   TLS_CERT_COMP_BROTLI = 2
//   TLS_CERT_COMP_ZSTD   = 3

let TLS_CERT_COMP_ZLIB: int = 1
let TLS_CERT_COMP_BROTLI: int = 2
let TLS_CERT_COMP_ZSTD: int = 3

let _TLS_EXT_COMPRESS_CERTIFICATE: int = 0x001b

@pure
pub fn tls13_ext_cert_compression(algs: [int]) -> [int] {
    let n = len(algs)
    let list_byte_len = n * 2
    // inner = uint8 list_len + uint16 entries[]
    let mut inner: [int] = []
    inner.push(list_byte_len & 0xFF)
    let mut i = 0
    while i < n {
        inner.push((algs[i] >> 8) & 0xFF)
        inner.push(algs[i] & 0xFF)
        i = i + 1
    }
    let il = len(inner)
    let mut o: [int] = []
    o.push((_TLS_EXT_COMPRESS_CERTIFICATE >> 8) & 0xFF)
    o.push(_TLS_EXT_COMPRESS_CERTIFICATE & 0xFF)
    o.push((il >> 8) & 0xFF)
    o.push(il & 0xFF)
    i = 0
    while i < il { o.push(inner[i]); i = i + 1 }
    return o
}

@pure
pub fn tls13_cert_compression_parse(ext_value: [int]) -> [int] {
    let mut out: [int] = []
    if len(ext_value) < 1 { return out }
    let list_byte_len = ext_value[0] & 0xFF
    let mut i = 0
    while i + 1 < list_byte_len && 1 + i + 1 < len(ext_value) {
        out.push(((ext_value[1 + i] & 0xFF) << 8) | (ext_value[1 + i + 1] & 0xFF))
        i = i + 2
    }
    return out
}
