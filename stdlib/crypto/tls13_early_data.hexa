// HEXA Standard Library — crypto/tls13_early_data
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 early_data extension (RFC 8446 §4.2.10) — pure hexa. Signals
// 0-RTT data. Two forms by context:
//   - ClientHello / EncryptedExtensions: empty extension_data (length=0)
//   - NewSessionTicket: uint32 max_early_data_size
// let-mut idiom (#1506).
//
// Surface:
//   pub fn tls13_ext_early_data_empty() -> [int]                 — for CH/EE
//   pub fn tls13_ext_early_data_max_size(max_size: int) -> [int] — for NST
//   pub fn tls13_early_data_nst_size(ext_value: [int]) -> int    — parse NST form

let _TLS_EXT_EARLY_DATA: int = 0x002a

@pure
pub fn tls13_ext_early_data_empty() -> [int] {
    // 0002a 0000 — type + length 0
    return [(_TLS_EXT_EARLY_DATA >> 8) & 0xFF, _TLS_EXT_EARLY_DATA & 0xFF, 0, 0]
}

@pure
pub fn tls13_ext_early_data_max_size(max_size: int) -> [int] {
    // 002a 0004 || uint32 max_size
    let mut o: [int] = []
    o.push((_TLS_EXT_EARLY_DATA >> 8) & 0xFF)
    o.push(_TLS_EXT_EARLY_DATA & 0xFF)
    o.push(0); o.push(4)
    o.push((max_size >> 24) & 0xFF)
    o.push((max_size >> 16) & 0xFF)
    o.push((max_size >> 8) & 0xFF)
    o.push(max_size & 0xFF)
    return o
}

@pure
pub fn tls13_early_data_nst_size(ext_value: [int]) -> int {
    if len(ext_value) != 4 { return -1 }
    return ((ext_value[0] & 0xFF) << 24) | ((ext_value[1] & 0xFF) << 16) | ((ext_value[2] & 0xFF) << 8) | (ext_value[3] & 0xFF)
}
