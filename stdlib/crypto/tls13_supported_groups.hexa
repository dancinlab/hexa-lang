// HEXA Standard Library — crypto/tls13_supported_groups
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 supported_groups extension (RFC 8446 §4.2.7) — pure hexa.
// Advertises which NamedGroups (ECDHE curves / FFDHE groups) the
// ClientHello accepts. let-mut idiom (#1506).
//
// Structure (RFC 8446 §4.2.7):
//   extension_data = NamedGroupList = uint16 list_length || NamedGroup[]
//   each NamedGroup is a 2-byte uint16 code.
//
// Surface:
//   pub fn tls13_ext_supported_groups(groups: [int]) -> [int]
//   pub fn tls13_supported_groups_parse(ext_value: [int]) -> [int]
//
// NamedGroup constants (RFC 8446 §4.2.7 selected):
//   TLS_GRP_SECP256R1 = 0x0017   TLS_GRP_SECP384R1 = 0x0018
//   TLS_GRP_SECP521R1 = 0x0019   TLS_GRP_X25519 = 0x001d   TLS_GRP_X448 = 0x001e
//   TLS_GRP_FFDHE2048 = 0x0100   TLS_GRP_FFDHE3072 = 0x0101

let TLS_GRP_SECP256R1: int = 0x0017
let TLS_GRP_SECP384R1: int = 0x0018
let TLS_GRP_SECP521R1: int = 0x0019
let TLS_GRP_X25519: int = 0x001d
let TLS_GRP_X448: int = 0x001e
let TLS_GRP_FFDHE2048: int = 0x0100
let TLS_GRP_FFDHE3072: int = 0x0101

let _TLS_EXT_SUPPORTED_GROUPS: int = 0x000a

@pure
pub fn tls13_ext_supported_groups(groups: [int]) -> [int] {
    let n = len(groups)
    let list_len = n * 2
    let mut inner: [int] = []
    inner.push((list_len >> 8) & 0xFF)
    inner.push(list_len & 0xFF)
    let mut i = 0
    while i < n {
        inner.push((groups[i] >> 8) & 0xFF)
        inner.push(groups[i] & 0xFF)
        i = i + 1
    }
    let il = len(inner)
    let mut o: [int] = []
    o.push((_TLS_EXT_SUPPORTED_GROUPS >> 8) & 0xFF)
    o.push(_TLS_EXT_SUPPORTED_GROUPS & 0xFF)
    o.push((il >> 8) & 0xFF)
    o.push(il & 0xFF)
    i = 0
    while i < il { o.push(inner[i]); i = i + 1 }
    return o
}

@pure
pub fn tls13_supported_groups_parse(ext_value: [int]) -> [int] {
    if len(ext_value) < 2 { return [] }
    let list_len = ((ext_value[0] & 0xFF) << 8) | (ext_value[1] & 0xFF)
    let mut out: [int] = []
    let mut i = 0
    while i + 1 < list_len && 2 + i + 1 < len(ext_value) {
        out.push(((ext_value[2 + i] & 0xFF) << 8) | (ext_value[2 + i + 1] & 0xFF))
        i = i + 2
    }
    return out
}
