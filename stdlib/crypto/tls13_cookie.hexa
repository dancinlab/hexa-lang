// HEXA Standard Library — crypto/tls13_cookie
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 cookie extension (RFC 8446 §4.2.2) — pure hexa. Sent by the
// server in HelloRetryRequest and echoed by the client in the retried
// ClientHello so the server can bind the retry to the original ClientHello
// without keeping state. let-mut idiom (#1506).
//
// Structure (RFC 8446 §4.2.2):
//   struct { opaque cookie<1..2^16-1>; } Cookie;
//
// Surface:
//   pub fn tls13_ext_cookie(cookie_bytes: [int]) -> [int]
//   pub fn tls13_cookie_parse(ext_value: [int]) -> [int]

let _TLS_EXT_COOKIE: int = 0x002c

@pure
pub fn tls13_ext_cookie(cookie_bytes: [int]) -> [int] {
    let n = len(cookie_bytes)
    // inner = uint16 length + bytes
    let mut inner: [int] = []
    inner.push((n >> 8) & 0xFF)
    inner.push(n & 0xFF)
    let mut i = 0
    while i < n { inner.push(cookie_bytes[i]); i = i + 1 }
    let il = len(inner)
    let mut o: [int] = []
    o.push((_TLS_EXT_COOKIE >> 8) & 0xFF)
    o.push(_TLS_EXT_COOKIE & 0xFF)
    o.push((il >> 8) & 0xFF)
    o.push(il & 0xFF)
    i = 0
    while i < il { o.push(inner[i]); i = i + 1 }
    return o
}

@pure
pub fn tls13_cookie_parse(ext_value: [int]) -> [int] {
    if len(ext_value) < 2 { return [] }
    let n = ((ext_value[0] & 0xFF) << 8) | (ext_value[1] & 0xFF)
    let mut out: [int] = []
    let mut i = 0
    while i < n && 2 + i < len(ext_value) {
        out.push(ext_value[2 + i] & 0xFF)
        i = i + 1
    }
    return out
}
