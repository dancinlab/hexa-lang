// HEXA Standard Library — crypto/tls13_server_name
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 server_name extension (SNI · RFC 6066 §3, retained by RFC 8446)
// — pure hexa. Carries the host name the client is connecting to so the
// server can pick the right cert. host_name is the only NameType; per
// RFC 6066 the value is an ASCII (no IDNA, no trailing dot) DNS name.
// let-mut idiom (#1506).
//
// Structure (RFC 6066 §3):
//   extension_data = ServerNameList = uint16 list_len || ServerName[]
//   ServerName = uint8 NameType(=0 host_name) || opaque HostName<1..2^16-1>
//   HostName encoded as uint16 length + bytes.
//
// Surface:
//   pub fn tls13_ext_server_name(hostname: string) -> [int]
//   pub fn tls13_server_name_parse(ext_value: [int]) -> string

let _TLS_EXT_SERVER_NAME: int = 0x0000

@pure
pub fn tls13_ext_server_name(hostname: string) -> [int] {
    // bytes of hostname
    let mut hb: [int] = []
    let mut i = 0
    while i < len(hostname) { hb.push(hostname.char_code_at(i)); i = i + 1 }
    let hn = len(hb)
    // ServerName entry = uint8 NameType + uint16 len + bytes  (size = 3 + hn)
    let mut entry: [int] = []
    entry.push(0)                           // NameType = host_name
    entry.push((hn >> 8) & 0xFF)
    entry.push(hn & 0xFF)
    i = 0
    while i < hn { entry.push(hb[i]); i = i + 1 }
    // ServerNameList = uint16 list_len + entry
    let el = len(entry)
    let mut inner: [int] = []
    inner.push((el >> 8) & 0xFF)
    inner.push(el & 0xFF)
    i = 0
    while i < el { inner.push(entry[i]); i = i + 1 }
    // Outer Extension wrapper
    let il = len(inner)
    let mut o: [int] = []
    o.push((_TLS_EXT_SERVER_NAME >> 8) & 0xFF)
    o.push(_TLS_EXT_SERVER_NAME & 0xFF)
    o.push((il >> 8) & 0xFF)
    o.push(il & 0xFF)
    i = 0
    while i < il { o.push(inner[i]); i = i + 1 }
    return o
}

// Parse the server_name extension's value (ext_data, not the full TLV).
// Returns the first host_name, or "" on malformed input.
@pure
pub fn tls13_server_name_parse(ext_value: [int]) -> string {
    if len(ext_value) < 5 { return "" }
    // skip the uint16 list_len, read first entry
    let nt = ext_value[2] & 0xFF
    if nt != 0 { return "" }
    let hn = ((ext_value[3] & 0xFF) << 8) | (ext_value[4] & 0xFF)
    if len(ext_value) < 5 + hn { return "" }
    let mut chars: [string] = []
    let mut i = 0
    while i < hn {
        let by = ext_value[5 + i] & 0xFF
        chars.push(chr(by))
        i = i + 1
    }
    return chars.join("")
}
