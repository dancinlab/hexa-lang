// HEXA Standard Library — crypto/hmac_drbg self-test
// @ci_gate
use "stdlib/crypto/hmac_drbg"
fn hx(b: [int]) -> string {
    let H = "0123456789abcdef"
    let mut p: [string] = []
    let mut i = 0
    while i < len(b) { p.push(H.substring((b[i]>>4)&15,((b[i]>>4)&15)+1)); p.push(H.substring(b[i]&15,(b[i]&15)+1)); i=i+1 }
    return p.join("")
}
fn main() {
    let ent = [0xca,0x85,0x19,0x11,0x34,0x93,0x84,0xbf,0xfe,0x89,0xde,0x1c,0xbd,0xc4,0x6e,0x68,0x31,0xe4,0x4d,0x34,0xa4,0xfb,0x93,0x5e,0xe2,0x85,0xdd,0x14,0xb7,0x1a,0x74,0x88]
    let nonce = [0x65,0x9b,0xa9,0x6c,0x60,0x1d,0xc6,0x9f,0xc9,0x02,0x94,0x08,0x05,0xec,0x0c,0xa8]
    let got = hx(hmac_drbg_generate(ent, nonce, [], 128, 128))
    let want = "e528e9abf2dece54d47c7e75e5fe302149f817ea9fb4bee6f4199697d04d5b89d54fbb978a15b5c443c9ec21036d2460b6f73ebad0dc2aba6e624abf07745bc107694bb7547bb0995f70de25d6b29e2d3011bb19d27676c07162c8b5ccde0668961df86803482cb37ed6d5c0bb8d50cf1f50d476aa0458bdaba806f48be9dcb8"
    if got == want { println("hmac_drbg NIST KAT: 1/1 PASS") } else { println("FAIL got=" + got) }
}
