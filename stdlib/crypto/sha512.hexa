// HEXA Standard Library — crypto/sha512
//
// @version 0.1.0
// @capabilities [pure]
//
// SHA-512 (FIPS 180-4) — pure hexa, 64-bit words modelled as [hi, lo]
// 32-bit limb pairs (each in [0, 2^32) — always positive, so hexa's
// signed-int64 right-shift/mask behave logically). No libc. Standalone
// + the SHA-512 dependency for ed25519. let-mut idiom (#1506-safe).
//
// Surface:
//   pub fn sha512_bytes(msg: [int]) -> [int]   — 64-byte digest
//   pub fn sha512_hex(msg: [int]) -> string     — 128-char lowercase hex
//
// Verified (FIPS 180-4):
//   sha512("")    = cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce
//                   47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e
//   sha512("abc") = ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a
//                   2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f

let _SH_M: int = 0xFFFFFFFF

// 64-bit word ops on [hi, lo] limb pairs.
@pure
fn _w_add(a: [int], b: [int]) -> [int] {
    let lo = a[1] + b[1]
    let carry = lo / 0x100000000
    let hi = (a[0] + b[0] + carry) & _SH_M
    return [hi, lo & _SH_M]
}
@pure
fn _w_xor(a: [int], b: [int]) -> [int] { return [(a[0] ^ b[0]) & _SH_M, (a[1] ^ b[1]) & _SH_M] }
@pure
fn _w_and(a: [int], b: [int]) -> [int] { return [(a[0] & b[0]) & _SH_M, (a[1] & b[1]) & _SH_M] }
@pure
fn _w_not(a: [int]) -> [int] { return [(a[0] ^ _SH_M) & _SH_M, (a[1] ^ _SH_M) & _SH_M] }

// rotate-right of a 64-bit [hi,lo] by n (1..63).
@pure
fn _w_rotr(a: [int], n: int) -> [int] {
    let hi = a[0]
    let lo = a[1]
    if n < 32 {
        let nh = ((hi >> n) | (lo << (32 - n))) & _SH_M
        let nl = ((lo >> n) | (hi << (32 - n))) & _SH_M
        return [nh, nl]
    }
    if n == 32 { return [lo, hi] }
    let m = n - 32
    let nh = ((lo >> m) | (hi << (32 - m))) & _SH_M
    let nl = ((hi >> m) | (lo << (32 - m))) & _SH_M
    return [nh, nl]
}

// shift-right of a 64-bit [hi,lo] by n (1..63).
@pure
fn _w_shr(a: [int], n: int) -> [int] {
    let hi = a[0]
    let lo = a[1]
    if n < 32 {
        let nh = (hi >> n) & _SH_M
        let nl = ((lo >> n) | (hi << (32 - n))) & _SH_M
        return [nh, nl]
    }
    if n == 32 { return [0, hi] }
    let m = n - 32
    return [0, (hi >> m) & _SH_M]
}

// SHA-512 round constants K[0..79] as flat [hi,lo, hi,lo, …] (160 ints).
@pure
fn _sha512_k() -> [int] {
    return [
        0x428a2f98,0xd728ae22, 0x71374491,0x23ef65cd, 0xb5c0fbcf,0xec4d3b2f, 0xe9b5dba5,0x8189dbbc,
        0x3956c25b,0xf348b538, 0x59f111f1,0xb605d019, 0x923f82a4,0xaf194f9b, 0xab1c5ed5,0xda6d8118,
        0xd807aa98,0xa3030242, 0x12835b01,0x45706fbe, 0x243185be,0x4ee4b28c, 0x550c7dc3,0xd5ffb4e2,
        0x72be5d74,0xf27b896f, 0x80deb1fe,0x3b1696b1, 0x9bdc06a7,0x25c71235, 0xc19bf174,0xcf692694,
        0xe49b69c1,0x9ef14ad2, 0xefbe4786,0x384f25e3, 0x0fc19dc6,0x8b8cd5b5, 0x240ca1cc,0x77ac9c65,
        0x2de92c6f,0x592b0275, 0x4a7484aa,0x6ea6e483, 0x5cb0a9dc,0xbd41fbd4, 0x76f988da,0x831153b5,
        0x983e5152,0xee66dfab, 0xa831c66d,0x2db43210, 0xb00327c8,0x98fb213f, 0xbf597fc7,0xbeef0ee4,
        0xc6e00bf3,0x3da88fc2, 0xd5a79147,0x930aa725, 0x06ca6351,0xe003826f, 0x14292967,0x0a0e6e70,
        0x27b70a85,0x46d22ffc, 0x2e1b2138,0x5c26c926, 0x4d2c6dfc,0x5ac42aed, 0x53380d13,0x9d95b3df,
        0x650a7354,0x8baf63de, 0x766a0abb,0x3c77b2a8, 0x81c2c92e,0x47edaee6, 0x92722c85,0x1482353b,
        0xa2bfe8a1,0x4cf10364, 0xa81a664b,0xbc423001, 0xc24b8b70,0xd0f89791, 0xc76c51a3,0x0654be30,
        0xd192e819,0xd6ef5218, 0xd6990624,0x5565a910, 0xf40e3585,0x5771202a, 0x106aa070,0x32bbd1b8,
        0x19a4c116,0xb8d2d0c8, 0x1e376c08,0x5141ab53, 0x2748774c,0xdf8eeb99, 0x34b0bcb5,0xe19b48a8,
        0x391c0cb3,0xc5c95a63, 0x4ed8aa4a,0xe3418acb, 0x5b9cca4f,0x7763e373, 0x682e6ff3,0xd6b2b8a3,
        0x748f82ee,0x5defb2fc, 0x78a5636f,0x43172f60, 0x84c87814,0xa1f0ab72, 0x8cc70208,0x1a6439ec,
        0x90befffa,0x23631e28, 0xa4506ceb,0xde82bde9, 0xbef9a3f7,0xb2c67915, 0xc67178f2,0xe372532b,
        0xca273ece,0xea26619c, 0xd186b8c7,0x21c0c207, 0xeada7dd6,0xcde0eb1e, 0xf57d4f7f,0xee6ed178,
        0x06f067aa,0x72176fba, 0x0a637dc5,0xa2c898a6, 0x113f9804,0xbef90dae, 0x1b710b35,0x131c471b,
        0x28db77f5,0x23047d84, 0x32caab7b,0x40c72493, 0x3c9ebe0a,0x15c9bebc, 0x431d67c4,0x9c100d4c,
        0x4cc5d4be,0xcb3e42b6, 0x597f299c,0xfc657e2a, 0x5fcb6fab,0x3ad6faec, 0x6c44198c,0x4a475817
    ]
}

// SHA-512 compression core (FIPS 180-4) — runs the padding + 80-round block
// loop from a caller-supplied initial hash vector, returning the final 8
// [hi,lo] words. Shared by SHA-512 (sha512_iv, full 64-byte digest) and
// SHA-384 (sha384_iv, 48-byte truncation).
@pure
fn _sha512_compress(msg: [int], h_init: [[int]]) -> [[int]] {
    let mut h: [[int]] = [
        h_init[0], h_init[1], h_init[2], h_init[3],
        h_init[4], h_init[5], h_init[6], h_init[7]
    ]
    let k = _sha512_k()

    // padding: append 0x80, zero to 112 mod 128, then 128-bit big-endian length.
    let ml = len(msg)
    let mut data: [int] = []
    let mut i = 0
    while i < ml { data.push(msg[i] & 0xFF); i = i + 1 }
    data.push(0x80)
    while (len(data) % 128) != 112 { data.push(0) }
    // 128-bit length: high 64 bits are 0 for our sizes; low 64 = ml*8.
    let bitlen = ml * 8
    let mut z = 0
    while z < 8 { data.push(0); z = z + 1 }      // high 64 bits = 0
    let mut bi = 7
    while bi >= 0 { data.push((bitlen >> (bi * 8)) & 0xFF); bi = bi - 1 }

    let nblocks = len(data) / 128
    let mut b = 0
    while b < nblocks {
        let base = b * 128
        // message schedule w[0..79], each [hi,lo]
        let mut w: [[int]] = []
        let mut t = 0
        while t < 16 {
            let o = base + t * 8
            let hi = ((data[o] << 24) | (data[o+1] << 16) | (data[o+2] << 8) | data[o+3]) & _SH_M
            let lo = ((data[o+4] << 24) | (data[o+5] << 16) | (data[o+6] << 8) | data[o+7]) & _SH_M
            w.push([hi, lo])
            t = t + 1
        }
        t = 16
        while t < 80 {
            // s0 = rotr(w[t-15],1) ^ rotr(w[t-15],8) ^ shr(w[t-15],7)
            let s0 = _w_xor(_w_xor(_w_rotr(w[t-15],1), _w_rotr(w[t-15],8)), _w_shr(w[t-15],7))
            // s1 = rotr(w[t-2],19) ^ rotr(w[t-2],61) ^ shr(w[t-2],6)
            let s1 = _w_xor(_w_xor(_w_rotr(w[t-2],19), _w_rotr(w[t-2],61)), _w_shr(w[t-2],6))
            w.push(_w_add(_w_add(w[t-16], s0), _w_add(w[t-7], s1)))
            t = t + 1
        }

        let mut a = h[0]; let mut bb = h[1]; let mut c = h[2]; let mut d = h[3]
        let mut e = h[4]; let mut f = h[5]; let mut g = h[6]; let mut hh = h[7]

        t = 0
        while t < 80 {
            // S1 = rotr(e,14)^rotr(e,18)^rotr(e,41)
            let S1 = _w_xor(_w_xor(_w_rotr(e,14), _w_rotr(e,18)), _w_rotr(e,41))
            let ch = _w_xor(_w_and(e, f), _w_and(_w_not(e), g))
            let kt = [k[t*2], k[t*2+1]]
            let temp1 = _w_add(_w_add(_w_add(hh, S1), _w_add(ch, kt)), w[t])
            let S0 = _w_xor(_w_xor(_w_rotr(a,28), _w_rotr(a,34)), _w_rotr(a,39))
            let maj = _w_xor(_w_xor(_w_and(a, bb), _w_and(a, c)), _w_and(bb, c))
            let temp2 = _w_add(S0, maj)
            hh = g; g = f; f = e; e = _w_add(d, temp1)
            d = c; c = bb; bb = a; a = _w_add(temp1, temp2)
            t = t + 1
        }

        h[0] = _w_add(h[0], a); h[1] = _w_add(h[1], bb); h[2] = _w_add(h[2], c); h[3] = _w_add(h[3], d)
        h[4] = _w_add(h[4], e); h[5] = _w_add(h[5], f); h[6] = _w_add(h[6], g); h[7] = _w_add(h[7], hh)
        b = b + 1
    }

    return h
}

@pure
fn _sha512_iv() -> [[int]] {
    return [
        [0x6a09e667,0xf3bcc908], [0xbb67ae85,0x84caa73b], [0x3c6ef372,0xfe94f82b], [0xa54ff53a,0x5f1d36f1],
        [0x510e527f,0xade682d1], [0x9b05688c,0x2b3e6c1f], [0x1f83d9ab,0xfb41bd6b], [0x5be0cd19,0x137e2179]
    ]
}

// SHA-384 IV (FIPS 180-4 §5.3.4)
@pure
fn _sha384_iv() -> [[int]] {
    return [
        [0xcbbb9d5d,0xc1059ed8], [0x629a292a,0x367cd507], [0x9159015a,0x3070dd17], [0x152fecd8,0xf70e5939],
        [0x67332667,0xffc00b31], [0x8eb44a87,0x68581511], [0xdb0c2e0d,0x64f98fa7], [0x47b5481d,0xbefa4fa4]
    ]
}

// emit nwords × 8 bytes big-endian
@pure
fn _emit_words(h: [[int]], nwords: int) -> [int] {
    let mut out: [int] = []
    let mut wi = 0
    while wi < nwords {
        let hi = h[wi][0]
        let lo = h[wi][1]
        out.push((hi >> 24) & 0xFF); out.push((hi >> 16) & 0xFF); out.push((hi >> 8) & 0xFF); out.push(hi & 0xFF)
        out.push((lo >> 24) & 0xFF); out.push((lo >> 16) & 0xFF); out.push((lo >> 8) & 0xFF); out.push(lo & 0xFF)
        wi = wi + 1
    }
    return out
}

@pure
pub fn sha512_bytes(msg: [int]) -> [int] {
    return _emit_words(_sha512_compress(msg, _sha512_iv()), 8)
}

// SHA-384 (FIPS 180-4) — SHA-512 core with the SHA-384 IV, truncated to 48 bytes.
@pure
pub fn sha384_bytes(msg: [int]) -> [int] {
    return _emit_words(_sha512_compress(msg, _sha384_iv()), 6)
}

let _SH_HEX: string = "0123456789abcdef"

@pure
pub fn sha512_hex(msg: [int]) -> string {
    let d = sha512_bytes(msg)
    let mut p: [string] = []
    let mut i = 0
    while i < len(d) {
        p.push(_SH_HEX.substring((d[i] >> 4) & 0xF, ((d[i] >> 4) & 0xF) + 1))
        p.push(_SH_HEX.substring(d[i] & 0xF, (d[i] & 0xF) + 1))
        i = i + 1
    }
    return p.join("")
}
