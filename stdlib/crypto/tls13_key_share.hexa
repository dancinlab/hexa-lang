// HEXA Standard Library — crypto/tls13_key_share
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 key_share extension (RFC 8446 §4.2.8) — pure hexa. Builds and
// parses the ECDHE key-exchange carrier for the X25519 group, the
// most-common TLS-1.3 curve. Pairs with stdlib/crypto/x25519 for the actual
// scalar/shared-secret math. let-mut idiom (#1506).
//
// Structures (RFC 8446 §4.2.8):
//   ClientHello key_share_data = uint16 client_shares_len ‖ KeyShareEntry[]
//   ServerHello key_share_data = KeyShareEntry server_share
//   KeyShareEntry              = NamedGroup group(2) ‖ uint16 key_len ‖ key_exchange[key_len]
//
// Surface:
//   pub fn tls13_ext_key_share_client_x25519(pubkey: [int]) -> [int]
//   pub fn tls13_ext_key_share_server_x25519(pubkey: [int]) -> [int]
//   pub fn tls13_key_share_parse_x25519(ext_value: [int]) -> [int]   — extract a 32-byte X25519 key
//
// Constants (RFC 8446 §4.2.7 NamedGroup):
//   TLS_GROUP_X25519 = 0x001d   TLS_GROUP_X448 = 0x001e
//   TLS_GROUP_SECP256R1 = 0x0017   TLS_GROUP_SECP384R1 = 0x0018

let TLS_GROUP_X25519: int = 0x001d
let TLS_GROUP_SECP256R1: int = 0x0017
let TLS_GROUP_SECP384R1: int = 0x0018
let _TLS_EXT_KEY_SHARE: int = 0x0033

// build a KeyShareEntry: group(2) ‖ uint16 key_len ‖ key
@pure
fn _keyshare_entry(group: int, key: [int]) -> [int] {
    let mut o: [int] = []
    o.push((group >> 8) & 0xFF)
    o.push(group & 0xFF)
    let n = len(key)
    o.push((n >> 8) & 0xFF)
    o.push(n & 0xFF)
    let mut i = 0
    while i < n { o.push(key[i]); i = i + 1 }
    return o
}

// build the outer Extension TLV
@pure
fn _wrap_ext(ext_type: int, value: [int]) -> [int] {
    let mut o: [int] = []
    o.push((ext_type >> 8) & 0xFF)
    o.push(ext_type & 0xFF)
    let n = len(value)
    o.push((n >> 8) & 0xFF)
    o.push(n & 0xFF)
    let mut i = 0
    while i < n { o.push(value[i]); i = i + 1 }
    return o
}

// ClientHello key_share with a single X25519 entry.
// Bytes: 0033 ‖ <ext_len> ‖ <client_shares_len(2)> ‖ 001d ‖ 0020 ‖ <32 bytes>
@pure
pub fn tls13_ext_key_share_client_x25519(pubkey: [int]) -> [int] {
    let entry = _keyshare_entry(TLS_GROUP_X25519, pubkey)
    let mut inner: [int] = []
    let n = len(entry)
    inner.push((n >> 8) & 0xFF)
    inner.push(n & 0xFF)
    let mut i = 0
    while i < len(entry) { inner.push(entry[i]); i = i + 1 }
    return _wrap_ext(_TLS_EXT_KEY_SHARE, inner)
}

// ServerHello key_share — a single KeyShareEntry (no vector wrapper).
// Bytes: 0033 ‖ <ext_len> ‖ 001d ‖ 0020 ‖ <32 bytes>
@pure
pub fn tls13_ext_key_share_server_x25519(pubkey: [int]) -> [int] {
    let entry = _keyshare_entry(TLS_GROUP_X25519, pubkey)
    return _wrap_ext(_TLS_EXT_KEY_SHARE, entry)
}

// Given the raw ext_value bytes of a ServerHello key_share extension, extract
// the 32-byte X25519 public key (returns empty array on mismatch).
@pure
pub fn tls13_key_share_parse_x25519(ext_value: [int]) -> [int] {
    if len(ext_value) < 4 { return [] }
    let group = ((ext_value[0] & 0xFF) << 8) | (ext_value[1] & 0xFF)
    if group != TLS_GROUP_X25519 { return [] }
    let n = ((ext_value[2] & 0xFF) << 8) | (ext_value[3] & 0xFF)
    if n != 32 { return [] }
    if len(ext_value) < 4 + n { return [] }
    let mut o: [int] = []
    let mut i = 0
    while i < n { o.push(ext_value[4 + i]); i = i + 1 }
    return o
}
