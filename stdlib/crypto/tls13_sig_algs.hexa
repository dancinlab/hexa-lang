// HEXA Standard Library — crypto/tls13_sig_algs
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 signature_algorithms extension (RFC 8446 §4.2.3) — pure hexa. The
// extension a ClientHello uses to advertise which Certificate signature
// schemes it accepts (and a CertificateRequest mirrors). Build/parse the
// SignatureScheme list; supports any uint16 scheme code. let-mut (#1506).
//
// Structure (RFC 8446 §4.2.3):
//   extension_data = SignatureSchemeList = uint16 list_length || SignatureScheme[]
//   each SignatureScheme is 2 bytes (NamedGroup-shaped uint16).
//
// Surface:
//   pub fn tls13_ext_signature_algorithms(schemes: [int]) -> [int]
//   pub fn tls13_sig_algs_parse(ext_value: [int]) -> [int]   — returns the list of uint16 scheme codes
//
// SignatureScheme constants (RFC 8446 §4.2.3 selected):
//   TLS_SIG_RSA_PKCS1_SHA256       = 0x0401
//   TLS_SIG_ECDSA_SECP256R1_SHA256 = 0x0403
//   TLS_SIG_RSA_PSS_RSAE_SHA256    = 0x0804
//   TLS_SIG_ED25519                = 0x0807
//   TLS_SIG_ED448                  = 0x0808
//   TLS_SIG_RSA_PSS_PSS_SHA256     = 0x0809

let TLS_SIG_RSA_PKCS1_SHA256: int = 0x0401
let TLS_SIG_ECDSA_SECP256R1_SHA256: int = 0x0403
let TLS_SIG_RSA_PSS_RSAE_SHA256: int = 0x0804
let TLS_SIG_ED25519: int = 0x0807
let TLS_SIG_ED448: int = 0x0808
let TLS_SIG_RSA_PSS_PSS_SHA256: int = 0x0809

let _TLS_EXT_SIGNATURE_ALGORITHMS: int = 0x000d

// Build the signature_algorithms extension from a list of uint16 SignatureScheme codes.
// Total bytes = 4 (ext header) + 2 (list len) + 2*N (scheme entries).
@pure
pub fn tls13_ext_signature_algorithms(schemes: [int]) -> [int] {
    let n = len(schemes)
    let list_len = n * 2
    let mut inner: [int] = []
    inner.push((list_len >> 8) & 0xFF)
    inner.push(list_len & 0xFF)
    let mut i = 0
    while i < n {
        inner.push((schemes[i] >> 8) & 0xFF)
        inner.push(schemes[i] & 0xFF)
        i = i + 1
    }
    let il = len(inner)
    let mut o: [int] = []
    o.push((_TLS_EXT_SIGNATURE_ALGORITHMS >> 8) & 0xFF)
    o.push(_TLS_EXT_SIGNATURE_ALGORITHMS & 0xFF)
    o.push((il >> 8) & 0xFF)
    o.push(il & 0xFF)
    i = 0
    while i < il { o.push(inner[i]); i = i + 1 }
    return o
}

// Parse the signature_algorithms extension VALUE (the ext_data, not the full TLV) →
// list of uint16 scheme codes.
@pure
pub fn tls13_sig_algs_parse(ext_value: [int]) -> [int] {
    if len(ext_value) < 2 { return [] }
    let list_len = ((ext_value[0] & 0xFF) << 8) | (ext_value[1] & 0xFF)
    let mut out: [int] = []
    let mut i = 0
    while i + 1 < list_len && 2 + i + 1 < len(ext_value) {
        out.push(((ext_value[2 + i] & 0xFF) << 8) | (ext_value[2 + i + 1] & 0xFF))
        i = i + 2
    }
    return out
}
