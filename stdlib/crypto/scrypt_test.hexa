// HEXA Standard Library — crypto/scrypt self-test
// @ci_gate
use "stdlib/crypto/scrypt"
fn hx(b: [int]) -> string {
    let H = "0123456789abcdef"
    let mut p: [string] = []
    let mut i = 0
    while i < len(b) { p.push(H.substring((b[i]>>4)&15,((b[i]>>4)&15)+1)); p.push(H.substring(b[i]&15,(b[i]&15)+1)); i=i+1 }
    return p.join("")
}
fn main() {
    let got = hx(scrypt([], [], 16, 1, 1, 64))
    let want = "77d6576238657b203b19ca42c18a0497f16b4844e3074ae8dfdffa3fede21442fcd0069ded0948f8326a753a0fc81f17e8d3e0fb2e0d3628cf35e20c38d18906"
    if got == want { println("scrypt RFC7914 KAT: 1/1 PASS") } else { println("FAIL got=" + got) }
}
