// HEXA Standard Library — crypto/rsa_pkcs1
//
// @version 0.1.0
// @capabilities [pure]
//
// RSA PKCS#1 v1.5 signature verification (RFC 8017 §8.2.2) — pure hexa. The
// third (and most common) X.509 cert signature algorithm alongside Ed25519
// and ECDSA-P256. 2048-bit bignum on 128×16-bit limbs; verify computes
// sig^e mod n (e small, e.g. 65537 → ~17 squarings) then checks the
// EMSA-PKCS1-v1_5 encoding `00 01 FF..FF 00 ‖ DigestInfo ‖ hash`. let-mut (#1506).
//
// Surface:
//   pub fn rsa_pkcs1_sha256_verify(n_be: [int], e: int, sig_be: [int], hash: [int]) -> bool
//     — n_be = 256-byte big-endian modulus, e = public exponent (int),
//       sig_be = 256-byte big-endian signature, hash = 32-byte SHA-256 digest.
//
// Verified vs python-cryptography (RSA-2048, SHA-256, e=65537).

let _RSA_LIMBS: int = 128   // 2048-bit / 16

// big-endian bytes → little-endian 16-bit limbs (width limbs)
@pure
fn _rsa_from_be(b: [int], width: int) -> [int] {
    let nb = len(b)
    let mut o: [int] = []
    let mut i = 0
    while i < width {
        let lo_idx = nb - 1 - 2*i
        let hi_idx = nb - 2 - 2*i
        let lo = if lo_idx >= 0 { b[lo_idx] & 0xFF } else { 0 }
        let hi = if hi_idx >= 0 { b[hi_idx] & 0xFF } else { 0 }
        o.push(lo | (hi << 8))
        i = i + 1
    }
    return o
}

// limbs → big-endian bytes (width limbs → 2*width bytes)
@pure
fn _rsa_to_be(a: [int]) -> [int] {
    let w = len(a)
    let mut o: [int] = []
    let mut i = 0
    while i < 2*w { o.push(0); i = i + 1 }
    i = 0
    while i < w {
        o[2*w - 1 - 2*i] = a[i] & 0xFF
        o[2*w - 2 - 2*i] = (a[i] >> 8) & 0xFF
        i = i + 1
    }
    return o
}

@pure
fn _rsa_cmp(a: [int], b: [int]) -> int {
    // compare equal-width limb arrays, MSB first
    let mut i = len(a) - 1
    while i >= 0 {
        if a[i] > b[i] { return 1 }
        if a[i] < b[i] { return -1 }
        i = i - 1
    }
    return 0
}

// schoolbook multiply: width-limb × width-limb → 2*width-limb
@pure
fn _rsa_mul(a: [int], b: [int]) -> [int] {
    let w = len(a)
    let mut acc: [int] = []
    let mut k = 0
    while k < 2*w { acc.push(0); k = k + 1 }
    let mut i = 0
    while i < w {
        let mut j = 0
        let mut carry = 0
        while j < w {
            let t = acc[i+j] + a[i] * b[j] + carry
            acc[i+j] = t & 0xFFFF
            carry = t >> 16
            j = j + 1
        }
        acc[i + w] = acc[i + w] + carry
        i = i + 1
    }
    return acc
}

// reduce a 2*W-limb value t modulo W-limb n via shift-and-subtract → W-limb.
@pure
fn _rsa_mod(t: [int], n: [int]) -> [int] {
    let w = len(n)
    let total_bits = len(t) * 16
    // acc, W limbs
    let mut acc: [int] = []
    let mut z = 0
    while z < w { acc.push(0); z = z + 1 }
    let mut bit = total_bits - 1
    while bit >= 0 {
        // shift acc left 1 bit in place
        let mut carry = 0
        let mut i = 0
        while i < w {
            let v = (acc[i] << 1) | carry
            acc[i] = v & 0xFFFF
            carry = (v >> 16) & 1
            i = i + 1
        }
        let shift_out = carry
        // OR in bit `bit` of t
        let limb = bit >> 4
        let off = bit & 15
        acc[0] = acc[0] | ((t[limb] >> off) & 1)
        // if shift_out or acc >= n, subtract n
        if shift_out != 0 || _rsa_cmp(acc, n) >= 0 {
            let mut br = 0
            i = 0
            while i < w {
                let d = acc[i] - n[i] - br
                if d < 0 { acc[i] = d + 0x10000; br = 1 } else { acc[i] = d; br = 0 }
                i = i + 1
            }
        }
        bit = bit - 1
    }
    return acc
}

@pure
fn _rsa_mulmod(a: [int], b: [int], n: [int]) -> [int] {
    return _rsa_mod(_rsa_mul(a, b), n)
}

// modexp: base^e mod n  (e a small non-negative int; left-to-right square-and-multiply)
@pure
fn _rsa_modexp(base: [int], e: int, n: [int]) -> [int] {
    let w = len(n)
    // result = 1
    let mut result: [int] = []
    let mut z = 0
    while z < w { result.push(0); z = z + 1 }
    result[0] = 1
    // find top bit of e
    let mut top = 31
    while top >= 0 {
        if ((e >> top) & 1) == 1 { z = top; top = -1 } else { top = top - 1 }
    }
    let hi = z
    let mut bit = hi
    while bit >= 0 {
        result = _rsa_mulmod(result, result, n)
        if ((e >> bit) & 1) == 1 {
            result = _rsa_mulmod(result, base, n)
        }
        bit = bit - 1
    }
    return result
}

// EMSA-PKCS1-v1_5 SHA-256 DigestInfo prefix (RFC 8017 §9.2)
@pure
fn _digestinfo_sha256_prefix() -> [int] {
    return [0x30,0x31,0x30,0x0d,0x06,0x09,0x60,0x86,0x48,0x01,0x65,0x03,0x04,0x02,0x01,0x05,0x00,0x04,0x20]
}

@pure
pub fn rsa_pkcs1_sha256_verify(n_be: [int], e: int, sig_be: [int], hash: [int]) -> bool {
    if len(hash) != 32 { return false }
    let n = _rsa_from_be(n_be, _RSA_LIMBS)
    let sig = _rsa_from_be(sig_be, _RSA_LIMBS)
    // EM = sig^e mod n, rendered as big-endian bytes (2*W = 256)
    let em_limbs = _rsa_modexp(sig, e, n)
    let em = _rsa_to_be(em_limbs)
    let elen = len(em)   // 256
    // expected EM = 00 01 FF..FF 00 || DigestInfo || hash
    // build expected tail = DigestInfo(19) || hash(32) = 51 bytes
    let di = _digestinfo_sha256_prefix()
    let tail_len = len(di) + 32   // 51
    // check leading 00 01
    if (em[0] & 0xFF) != 0x00 { return false }
    if (em[1] & 0xFF) != 0x01 { return false }
    // FF padding from index 2 up to (elen - tail_len - 1); then a 00 separator
    let sep = elen - tail_len - 1
    let mut i = 2
    while i < sep {
        if (em[i] & 0xFF) != 0xFF { return false }
        i = i + 1
    }
    if (em[sep] & 0xFF) != 0x00 { return false }
    // DigestInfo
    i = 0
    while i < len(di) {
        if (em[sep + 1 + i] & 0xFF) != (di[i] & 0xFF) { return false }
        i = i + 1
    }
    // hash
    i = 0
    while i < 32 {
        if (em[sep + 1 + len(di) + i] & 0xFF) != (hash[i] & 0xFF) { return false }
        i = i + 1
    }
    // also require enough FF padding (≥ 8 per RFC)
    if sep - 2 < 8 { return false }
    return true
}
