// HEXA Standard Library — crypto/tls13_client_hello_parse
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 ClientHello body parser (RFC 8446 §4.1.2) — pure hexa. Mirror of
// the tls13_client_hello builder; with this both ClientHello and ServerHello
// have full build/parse symmetry. Each accessor takes the body offset
// (typically 0) and navigates the variable-length leading fields internally.
// let-mut idiom (#1506).
//
// Structure (RFC 8446 §4.1.2):
//   ProtocolVersion legacy_version = 0x0303
//   Random random[32]
//   opaque legacy_session_id<0..32>
//   CipherSuite cipher_suites<2..2^16-2>
//   opaque legacy_compression_methods<1..2^8-1>
//   Extension extensions<8..2^16-1>
//
// Surface — each takes (body, o) with o = offset of body's first byte:
//   pub fn tls13_ch_version(body: [int], o: int) -> int
//   pub fn tls13_ch_random(body: [int], o: int) -> [int]
//   pub fn tls13_ch_session_id(body: [int], o: int) -> [int]
//   pub fn tls13_ch_cipher_suites(body: [int], o: int) -> [int]    — list of uint16 codes
//   pub fn tls13_ch_extensions_offset(body: [int], o: int) -> int
//   pub fn tls13_ch_extensions_length(body: [int], o: int) -> int

@pure
fn _u16(b: [int], o: int) -> int {
    return ((b[o] & 0xFF) << 8) | (b[o + 1] & 0xFF)
}

@pure
pub fn tls13_ch_version(body: [int], o: int) -> int {
    return _u16(body, o)
}

@pure
pub fn tls13_ch_random(body: [int], o: int) -> [int] {
    let mut r: [int] = []
    let mut i = 0
    while i < 32 { r.push(body[o + 2 + i]); i = i + 1 }
    return r
}

@pure
pub fn tls13_ch_session_id(body: [int], o: int) -> [int] {
    let sl = body[o + 34] & 0xFF
    let mut s: [int] = []
    let mut i = 0
    while i < sl { s.push(body[o + 35 + i]); i = i + 1 }
    return s
}

@pure
fn _cs_offset(body: [int], o: int) -> int {
    let sl = body[o + 34] & 0xFF
    return o + 35 + sl
}

@pure
fn _cs_byte_length(body: [int], o: int) -> int {
    return _u16(body, _cs_offset(body, o))
}

@pure
pub fn tls13_ch_cipher_suites(body: [int], o: int) -> [int] {
    let cso = _cs_offset(body, o) + 2
    let cs_bytes = _cs_byte_length(body, o)
    let mut out: [int] = []
    let mut i = 0
    while i + 1 < cs_bytes {
        out.push(((body[cso + i] & 0xFF) << 8) | (body[cso + i + 1] & 0xFF))
        i = i + 2
    }
    return out
}

@pure
fn _comp_offset(body: [int], o: int) -> int {
    return _cs_offset(body, o) + 2 + _cs_byte_length(body, o)
}

@pure
fn _comp_length(body: [int], o: int) -> int {
    return body[_comp_offset(body, o)] & 0xFF
}

@pure
pub fn tls13_ch_extensions_offset(body: [int], o: int) -> int {
    let co = _comp_offset(body, o)
    let cl = _comp_length(body, o)
    return co + 1 + cl + 2  // skip comp_len byte + comp_bytes + uint16 ext_len header
}

@pure
pub fn tls13_ch_extensions_length(body: [int], o: int) -> int {
    let co = _comp_offset(body, o)
    let cl = _comp_length(body, o)
    return _u16(body, co + 1 + cl)
}
