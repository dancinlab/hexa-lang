// HEXA Standard Library — crypto/pbkdf2 self-test
// @ci_gate
use "stdlib/crypto/pbkdf2"
let mut pass = 0
let mut total = 0
fn hx(b: [int]) -> string {
    let H = "0123456789abcdef"
    let mut p: [string] = []
    let mut i = 0
    while i < len(b) { p.push(H.substring((b[i]>>4)&15,((b[i]>>4)&15)+1)); p.push(H.substring(b[i]&15,(b[i]&15)+1)); i=i+1 }
    return p.join("")
}
fn ck(name: string, got: string, want: string) {
    total = total + 1
    if got == want { pass = pass + 1 } else { println("FAIL " + name + " got=" + got) }
}
fn main() {
    let pw = [0x70,0x61,0x73,0x73,0x77,0x6f,0x72,0x64]
    let salt = [0x73,0x61,0x6c,0x74]
    // PBKDF2-HMAC-SHA256 RFC 6070-style
    ck("pbkdf2_c1", hx(pbkdf2_hmac_sha256(pw, salt, 1, 32)), "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b")
    ck("pbkdf2_c2", hx(pbkdf2_hmac_sha256(pw, salt, 2, 32)), "ae4d0c95af6b46d32d0adff928f06dd02a303f8ef3c251dfd6e2d85a95474c43")
    // HKDF RFC 5869 A.1
    let mut ikm: [int] = []
    let mut i = 0
    while i < 22 { ikm.push(0x0b); i = i + 1 }
    let mut s: [int] = []
    i = 0
    while i < 13 { s.push(i); i = i + 1 }
    let info = [0xf0,0xf1,0xf2,0xf3,0xf4,0xf5,0xf6,0xf7,0xf8,0xf9]
    ck("hkdf_a1", hx(hkdf_sha256(ikm, s, info, 42)), "3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865")
    println("pbkdf2/hkdf self-test: " + to_string(pass) + "/" + to_string(total))
    if pass == total { println("PASS") } else { println("FAILED") }
}
