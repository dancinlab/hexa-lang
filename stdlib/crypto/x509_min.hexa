// HEXA Standard Library — crypto/x509_min
//
// @version 0.1.0
// @capabilities [pure]
//
// Minimal X.509 certificate field extraction (RFC 5280) — pure hexa. The
// first installment of the X.509 chain-validation series, on the verified
// asn1_der decoder + ed25519. Extracts: the TBSCertificate bytes (the signed
// data), the signatureValue (raw signature bytes), and the subjectPublicKey
// (raw key bytes). Self-signed Ed25519 cert verify works end-to-end.
//
// Remaining for full chain validation (separate PRs): RSA / ECDSA signature
// verification (for non-Ed25519 certs) · validity date check · name
// constraints · chain traversal to a trust anchor. let-mut idiom (#1506).
//
// Structure (RFC 5280 §4.1):
//   Certificate ::= SEQUENCE { tbsCertificate, signatureAlgorithm, signatureValue BIT STRING }
//   TBSCertificate children (index): 0=[0]version, 1=serial, 2=sigAlg,
//     3=issuer, 4=validity, 5=subject, 6=SPKI, [7+=optional]
//   SPKI ::= SEQUENCE { algorithmIdentifier, subjectPublicKey BIT STRING }
//
// Surface:
//   pub fn x509_tbs_bytes(cert: [int]) -> [int]                 — the signed TLV
//   pub fn x509_signature(cert: [int]) -> [int]                 — raw sig bytes
//   pub fn x509_subject_public_key(cert: [int]) -> [int]        — raw pubkey bytes
//   pub fn x509_verify_self_ed25519(cert: [int]) -> bool

use "stdlib/crypto/asn1_der"
use "stdlib/crypto/ed25519"

// slice helper — return cert[from .. to)
@pure
fn _slice(b: [int], from: int, to: int) -> [int] {
    let mut o: [int] = []
    let mut i = from
    while i < to { o.push(b[i]); i = i + 1 }
    return o
}

// offset of the TBSCertificate TLV (first child of outer SEQ) = outer's value_start
@pure
fn _tbs_offset(cert: [int]) -> int {
    return der_value_start(cert, 0)
}

// extract TBSCertificate TLV bytes (the data that was signed)
@pure
pub fn x509_tbs_bytes(cert: [int]) -> [int] {
    let tbs_o = _tbs_offset(cert)
    let tbs_end = der_next(cert, tbs_o)
    return _slice(cert, tbs_o, tbs_end)
}

// extract the raw signature bytes (BIT STRING value minus the unused-bits byte)
@pure
pub fn x509_signature(cert: [int]) -> [int] {
    let tbs_o = _tbs_offset(cert)
    let sig_alg = der_next(cert, tbs_o)         // 2nd outer child = signatureAlgorithm
    let sig_bs = der_next(cert, sig_alg)        // 3rd outer child = signatureValue BIT STRING
    let v = der_value_start(cert, sig_bs)
    let n = der_value_len(cert, sig_bs)
    // BIT STRING: first byte = unused bits count (must be 0 for these algos)
    return _slice(cert, v + 1, v + n)
}

// extract the raw subjectPublicKey bytes from the SPKI BIT STRING
@pure
pub fn x509_subject_public_key(cert: [int]) -> [int] {
    // navigate to SPKI. TBS children: [0]version?, serial, sigAlg, issuer,
    // validity, subject, SPKI. The version field is OPTIONAL (RFC 5280:
    // `version [0] EXPLICIT Version DEFAULT v1`) — present in v3 certs (tag
    // 0xA0), absent in v1. So SPKI is the 7th child when version is present,
    // the 6th when it is not. Detect by the first child's tag.
    let tbs_o = _tbs_offset(cert)
    let mut c = der_value_start(cert, tbs_o)    // first TBS child
    let mut skip = 5                            // v1: serial is child 0 → 5 hops to SPKI
    if (der_tag(cert, c) & 0xFF) == 0xA0 { skip = 6 }   // v3: skip [0]version too
    let mut k = 0
    while k < skip { c = der_next(cert, c); k = k + 1 }
    // c is now at SPKI; its 2nd child = subjectPublicKey BIT STRING
    let spki_v = der_value_start(cert, c)
    let alg = spki_v                            // 1st SPKI child = algId
    let pk_bs = der_next(cert, alg)             // 2nd SPKI child = BIT STRING
    let v = der_value_start(cert, pk_bs)
    let n = der_value_len(cert, pk_bs)
    return _slice(cert, v + 1, v + n)
}

// verify a self-signed Ed25519 certificate: ed25519_verify(spki_pubkey, tbs, sig)
@pure
pub fn x509_verify_self_ed25519(cert: [int]) -> bool {
    let pk = x509_subject_public_key(cert)
    if len(pk) != 32 { return false }
    let tbs = x509_tbs_bytes(cert)
    let sig = x509_signature(cert)
    if len(sig) != 64 { return false }
    return ed25519_verify(pk, tbs, sig)
}
