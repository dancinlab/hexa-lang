// HEXA Standard Library — crypto/tls13_finished
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 Finished message verify_data (RFC 8446 §4.4.4) — the cryptographic
// core of handshake authentication. Pure hexa on the verified Expand-Label
// (tls13_keyschedule) + HMAC-SHA256 (core/hash/hmac). With this, all
// pure-logic TLS 1.3 handshake crypto is implementable; the remaining
// handshake work is message framing / state transitions over an existing
// socket (stdlib/net/socket). let-mut idiom (#1506).
//
// Definitions (RFC 8446 §4.4.4):
//   finished_key = HKDF-Expand-Label(BaseKey, "finished", "", Hash.length)
//   verify_data  = HMAC-Hash(finished_key, Transcript-Hash(Handshake Context))
//
// Surface:
//   pub fn tls13_finished_key(secret: [int]) -> [int]                          — 32-byte key
//   pub fn tls13_finished_verify_data(secret: [int], thash: [int]) -> [int]    — 32-byte tag
//   pub fn tls13_finished_verify(secret: [int], thash: [int], got: [int]) -> bool
//
// Verified vector (RFC 8448 §3, server_handshake_traffic_secret):
//   secret      = b67b7d690cc16c4e75e54213cb2d37b4e9c912bcded9105d42befd59d391ad38
//   finished_key= 008d3b66f816ea559f96b537e885c31fc068bf492c652f01f288a1d8cdc19fc8  (RFC documented)
//   verify_data with thash=SHA256("") cross-checked vs python (independent reference).

use "stdlib/crypto/tls13_keyschedule"
use "stdlib/core/hash/hmac"

@pure
pub fn tls13_finished_key(secret: [int]) -> [int] {
    // "finished" = 66 69 6e 69 73 68 65 64
    let label = [0x66, 0x69, 0x6e, 0x69, 0x73, 0x68, 0x65, 0x64]
    let ctx: [int] = []
    return tls13_expand_label(secret, label, ctx, 32)
}

@pure
pub fn tls13_finished_verify_data(secret: [int], thash: [int]) -> [int] {
    let fk = tls13_finished_key(secret)
    return hmac_sha256_bytes(fk, thash)
}

@pure
pub fn tls13_finished_verify(secret: [int], thash: [int], got: [int]) -> bool {
    if len(got) != 32 { return false }
    let want = tls13_finished_verify_data(secret, thash)
    let mut diff = 0
    let mut i = 0
    while i < 32 { if want[i] != got[i] { diff = 1 }; i = i + 1 }
    return diff == 0
}
