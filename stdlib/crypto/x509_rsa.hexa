// HEXA Standard Library — crypto/x509_rsa
//
// @version 0.1.0
// @capabilities [pure]
//
// X.509 RSA (PKCS#1 v1.5 / SHA-256) certificate verification — pure hexa.
// The 3rd cert signature family alongside x509_min (Ed25519) and x509_p256
// (ECDSA). Extracts the RSAPublicKey (SEQUENCE{INTEGER n, INTEGER e}) from
// the SPKI, hashes the TBSCertificate with SHA-256, and verifies the raw
// RSA signature via rsa_pkcs1. let-mut idiom (#1506).
//
// Surface:
//   pub fn x509_rsa_modulus(cert: [int]) -> [int]   — 256-byte big-endian n (or [] on parse fail)
//   pub fn x509_rsa_exponent(cert: [int]) -> int    — public exponent e (or -1)
//   pub fn x509_verify_self_rsa(cert: [int]) -> bool

use "stdlib/crypto/asn1_der"
use "stdlib/crypto/rsa_pkcs1"
use "stdlib/crypto/x509_min"
use "stdlib/core/hash/hmac"

// the SPKI subjectPublicKey BIT STRING content = DER SEQUENCE{INTEGER n, INTEGER e}
// extract modulus n as exactly 256 big-endian bytes (strip a DER sign 0x00; left-pad)
@pure
pub fn x509_rsa_modulus(cert: [int]) -> [int] {
    let spki = x509_subject_public_key(cert)   // RSAPublicKey DER SEQUENCE bytes
    if len(spki) < 8 { return [] }
    if (der_tag(spki, 0) & 0xFF) != 0x30 { return [] }
    let seq_v = der_value_start(spki, 0)
    if (der_tag(spki, seq_v) & 0xFF) != 0x02 { return [] }   // INTEGER n
    let n_v = der_value_start(spki, seq_v)
    let n_len = der_value_len(spki, seq_v)
    // strip leading 0x00 sign bytes
    let mut start = n_v
    let mut count = n_len
    while count > 0 && (spki[start] & 0xFF) == 0 { start = start + 1; count = count - 1 }
    if count > 256 { return [] }
    let mut out: [int] = []
    let pad = 256 - count
    let mut i = 0
    while i < pad { out.push(0); i = i + 1 }
    i = 0
    while i < count { out.push(spki[start + i] & 0xFF); i = i + 1 }
    return out
}

@pure
pub fn x509_rsa_exponent(cert: [int]) -> int {
    let spki = x509_subject_public_key(cert)
    if len(spki) < 8 { return -1 }
    let seq_v = der_value_start(spki, 0)
    // skip the modulus INTEGER, read the exponent INTEGER
    let e_off = der_next(spki, seq_v)
    if (der_tag(spki, e_off) & 0xFF) != 0x02 { return -1 }
    let e_v = der_value_start(spki, e_off)
    let e_len = der_value_len(spki, e_off)
    let mut e = 0
    let mut i = 0
    while i < e_len { e = (e << 8) | (spki[e_v + i] & 0xFF); i = i + 1 }
    return e
}

@pure
pub fn x509_verify_self_rsa(cert: [int]) -> bool {
    let n = x509_rsa_modulus(cert)
    if len(n) != 256 { return false }
    let e = x509_rsa_exponent(cert)
    if e <= 0 { return false }
    let sig = x509_signature(cert)   // raw RSA signature (256 bytes)
    if len(sig) != 256 { return false }
    let tbs = x509_tbs_bytes(cert)
    let hash = sha256_digest_bytes(tbs)
    return rsa_pkcs1_sha256_verify(n, e, sig, hash)
}
