// HEXA Standard Library — crypto/hmac_drbg
//
// @version 0.1.0
// @capabilities [pure]
//
// HMAC_DRBG (NIST SP 800-90A §10.1.2) over the hexa-native HMAC-SHA256
// (stdlib/core/hash/hmac.hexa). Deterministic random-bit generator —
// completes the HMAC-DRBG leg of RUNTIME.md Phase 2 "Crypto helpers".
// Pure hexa (let-mut idiom per #1506), no libc.
//
// Surface:
//   pub fn hmac_drbg_generate(entropy: [int], nonce: [int], person: [int],
//                             gen1_len: int, gen2_len: int) -> [int]
//     — instantiate(entropy‖nonce‖person), Generate(gen1_len) [discarded],
//       Generate(gen2_len) [returned]. Matches the NIST CAVP 2-generate
//       drill (no reseed, no prediction-resistance, no additional input).
//
// Verified vector (NIST SP 800-90A HMAC_DRBG-SHA256, PR=False, no df):
//   EntropyInput = ca851911349384bffe89de1cbdc46e6831e44d34a4fb935ee285dd14b71a7488
//   Nonce        = 659ba96c601dc69fc902940805ec0ca8
//   ReturnedBits(2nd gen, 128B) prefix = e528e9abf2dece54d47c7e75e5fe3021…

use "stdlib/core/hash/hmac"

// HMAC_DRBG Update (SP 800-90A 10.1.2.2). state = [K(32) ‖ V(32)] (64 ints).
@pure
fn _drbg_update(state: [int], provided: [int]) -> [int] {
    // split K, V
    let mut k: [int] = []
    let mut v: [int] = []
    let mut i = 0
    while i < 32 { k.push(state[i]); i = i + 1 }
    i = 0
    while i < 32 { v.push(state[32 + i]); i = i + 1 }

    // K = HMAC(K, V ‖ 0x00 ‖ provided)
    let mut m: [int] = []
    i = 0
    while i < 32 { m.push(v[i]); i = i + 1 }
    m.push(0)
    i = 0
    while i < len(provided) { m.push(provided[i]); i = i + 1 }
    k = hmac_sha256_bytes(k, m)
    // V = HMAC(K, V)
    v = hmac_sha256_bytes(k, v)

    if len(provided) > 0 {
        // K = HMAC(K, V ‖ 0x01 ‖ provided)
        let mut m2: [int] = []
        i = 0
        while i < 32 { m2.push(v[i]); i = i + 1 }
        m2.push(1)
        i = 0
        while i < len(provided) { m2.push(provided[i]); i = i + 1 }
        k = hmac_sha256_bytes(k, m2)
        v = hmac_sha256_bytes(k, v)
    }

    let mut out: [int] = []
    i = 0
    while i < 32 { out.push(k[i]); i = i + 1 }
    i = 0
    while i < 32 { out.push(v[i]); i = i + 1 }
    return out
}

// Generate num_bytes from state; returns [bytes ‖ newstate(64)].
@pure
fn _drbg_generate(state: [int], num_bytes: int) -> [int] {
    let mut k: [int] = []
    let mut v: [int] = []
    let mut i = 0
    while i < 32 { k.push(state[i]); i = i + 1 }
    i = 0
    while i < 32 { v.push(state[32 + i]); i = i + 1 }

    let mut temp: [int] = []
    while len(temp) < num_bytes {
        v = hmac_sha256_bytes(k, v)
        let mut j = 0
        while j < 32 { temp.push(v[j]); j = j + 1 }
    }
    // truncate output
    let outbytes = temp.slice(0, num_bytes)
    // Update(empty) post-generate
    let mut st: [int] = []
    i = 0
    while i < 32 { st.push(k[i]); i = i + 1 }
    i = 0
    while i < 32 { st.push(v[i]); i = i + 1 }
    st = _drbg_update(st, [])

    // pack [outbytes ‖ newstate]
    let mut res: [int] = []
    i = 0
    while i < len(outbytes) { res.push(outbytes[i]); i = i + 1 }
    i = 0
    while i < 64 { res.push(st[i]); i = i + 1 }
    return res
}

@pure
pub fn hmac_drbg_generate(entropy: [int], nonce: [int], person: [int],
                          gen1_len: int, gen2_len: int) -> [int] {
    // Instantiate: K=0x00*32, V=0x01*32, Update(entropy‖nonce‖person)
    let mut state: [int] = []
    let mut i = 0
    while i < 32 { state.push(0); i = i + 1 }      // K
    while i < 64 { state.push(1); i = i + 1 }      // V = 0x01*32

    let mut seed: [int] = []
    i = 0
    while i < len(entropy) { seed.push(entropy[i]); i = i + 1 }
    i = 0
    while i < len(nonce) { seed.push(nonce[i]); i = i + 1 }
    i = 0
    while i < len(person) { seed.push(person[i]); i = i + 1 }
    state = _drbg_update(state, seed)

    // Generate #1 (discarded) — advances state
    let g1 = _drbg_generate(state, gen1_len)
    let mut st2: [int] = []
    i = 0
    while i < 64 { st2.push(g1[gen1_len + i]); i = i + 1 }

    // Generate #2 (returned)
    let g2 = _drbg_generate(st2, gen2_len)
    return g2.slice(0, gen2_len)
}
