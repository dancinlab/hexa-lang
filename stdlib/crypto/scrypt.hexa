// HEXA Standard Library — crypto/scrypt
//
// @version 0.1.0
// @capabilities [pure]
//
// scrypt KDF (RFC 7914 / Percival 2009) — pure hexa over the hexa-native
// PBKDF2-HMAC-SHA256 (stdlib/crypto/pbkdf2). Completes the scrypt leg of
// RUNTIME.md Phase 2 "Crypto helpers". let-mut idiom (#1506-safe), no libc.
//
// scrypt(P,S,N,r,p,dkLen):
//   B = PBKDF2-HMAC-SHA256(P, S, 1, p*128*r)
//   for i in 0..p: B_i = ROMix_r(B_i, N)         (N must be a power of two)
//   DK = PBKDF2-HMAC-SHA256(P, B, 1, dkLen)
// where ROMix uses BlockMix over the Salsa20/8 core.
//
// Surface:
//   pub fn scrypt(passwd: [int], salt: [int], n: int, r: int, p: int, dklen: int) -> [int]
//
// Verified vector (RFC 7914 §12, first):
//   scrypt("", "", N=16, r=1, p=1, dkLen=64)
//     = 77d6576238657b203b19ca42c18a0497f16b4844e3074ae8dfdffa3fede21442
//       fcd0069ded0948f8326a753a0fc81f17e8d3e0fb2e0d3628cf35e20c38d18906

use "stdlib/crypto/pbkdf2"

let _SC_M32: int = 0xFFFFFFFF

@pure
fn _sc_rotl(x: int, n: int) -> int {
    return ((x << n) | (x >> (32 - n))) & _SC_M32
}

// Salsa20/8 core on 16 little-endian 32-bit words (64 bytes in/out).
@pure
fn _salsa20_8(inb: [int]) -> [int] {
    // load 16 words little-endian
    let mut x: [int] = []
    let mut i = 0
    while i < 16 {
        let o = i * 4
        x.push((inb[o] | (inb[o+1] << 8) | (inb[o+2] << 16) | (inb[o+3] << 24)) & _SC_M32)
        i = i + 1
    }
    let mut w: [int] = []
    i = 0
    while i < 16 { w.push(x[i]); i = i + 1 }

    // 8 rounds (4 double-rounds)
    let mut r = 0
    while r < 4 {
        // column rounds
        w[4]  = w[4]  ^ _sc_rotl((w[0]  + w[12]) & _SC_M32, 7)
        w[8]  = w[8]  ^ _sc_rotl((w[4]  + w[0])  & _SC_M32, 9)
        w[12] = w[12] ^ _sc_rotl((w[8]  + w[4])  & _SC_M32, 13)
        w[0]  = w[0]  ^ _sc_rotl((w[12] + w[8])  & _SC_M32, 18)
        w[9]  = w[9]  ^ _sc_rotl((w[5]  + w[1])  & _SC_M32, 7)
        w[13] = w[13] ^ _sc_rotl((w[9]  + w[5])  & _SC_M32, 9)
        w[1]  = w[1]  ^ _sc_rotl((w[13] + w[9])  & _SC_M32, 13)
        w[5]  = w[5]  ^ _sc_rotl((w[1]  + w[13]) & _SC_M32, 18)
        w[14] = w[14] ^ _sc_rotl((w[10] + w[6])  & _SC_M32, 7)
        w[2]  = w[2]  ^ _sc_rotl((w[14] + w[10]) & _SC_M32, 9)
        w[6]  = w[6]  ^ _sc_rotl((w[2]  + w[14]) & _SC_M32, 13)
        w[10] = w[10] ^ _sc_rotl((w[6]  + w[2])  & _SC_M32, 18)
        w[3]  = w[3]  ^ _sc_rotl((w[15] + w[11]) & _SC_M32, 7)
        w[7]  = w[7]  ^ _sc_rotl((w[3]  + w[15]) & _SC_M32, 9)
        w[11] = w[11] ^ _sc_rotl((w[7]  + w[3])  & _SC_M32, 13)
        w[15] = w[15] ^ _sc_rotl((w[11] + w[7])  & _SC_M32, 18)
        // row rounds
        w[1]  = w[1]  ^ _sc_rotl((w[0]  + w[3])  & _SC_M32, 7)
        w[2]  = w[2]  ^ _sc_rotl((w[1]  + w[0])  & _SC_M32, 9)
        w[3]  = w[3]  ^ _sc_rotl((w[2]  + w[1])  & _SC_M32, 13)
        w[0]  = w[0]  ^ _sc_rotl((w[3]  + w[2])  & _SC_M32, 18)
        w[6]  = w[6]  ^ _sc_rotl((w[5]  + w[4])  & _SC_M32, 7)
        w[7]  = w[7]  ^ _sc_rotl((w[6]  + w[5])  & _SC_M32, 9)
        w[4]  = w[4]  ^ _sc_rotl((w[7]  + w[6])  & _SC_M32, 13)
        w[5]  = w[5]  ^ _sc_rotl((w[4]  + w[7])  & _SC_M32, 18)
        w[11] = w[11] ^ _sc_rotl((w[10] + w[9])  & _SC_M32, 7)
        w[8]  = w[8]  ^ _sc_rotl((w[11] + w[10]) & _SC_M32, 9)
        w[9]  = w[9]  ^ _sc_rotl((w[8]  + w[11]) & _SC_M32, 13)
        w[10] = w[10] ^ _sc_rotl((w[9]  + w[8])  & _SC_M32, 18)
        w[12] = w[12] ^ _sc_rotl((w[15] + w[14]) & _SC_M32, 7)
        w[13] = w[13] ^ _sc_rotl((w[12] + w[15]) & _SC_M32, 9)
        w[14] = w[14] ^ _sc_rotl((w[13] + w[12]) & _SC_M32, 13)
        w[15] = w[15] ^ _sc_rotl((w[14] + w[13]) & _SC_M32, 18)
        r = r + 1
    }

    // out = (x + w) serialized little-endian
    let mut out: [int] = []
    i = 0
    while i < 16 {
        let v = (x[i] + w[i]) & _SC_M32
        out.push(v & 0xFF); out.push((v >> 8) & 0xFF)
        out.push((v >> 16) & 0xFF); out.push((v >> 24) & 0xFF)
        i = i + 1
    }
    return out
}

@pure
fn _xor_block(a: [int], b: [int]) -> [int] {
    let mut o: [int] = []
    let mut i = 0
    while i < len(a) { o.push((a[i] ^ b[i]) & 0xFF); i = i + 1 }
    return o
}

// BlockMix (r): in = 2r 64-byte blocks → out = 2r 64-byte blocks reordered.
@pure
fn _block_mix(b: [int], r: int) -> [int] {
    let two_r = 2 * r
    // X = last 64-byte block
    let mut x: [int] = []
    let mut i = 0
    let last_off = (two_r - 1) * 64
    while i < 64 { x.push(b[last_off + i]); i = i + 1 }
    // even slots → out[0..r], odd slots → out[r..2r]
    let mut yeven: [int] = []
    let mut yodd: [int] = []
    let mut bi = 0
    while bi < two_r {
        let off = bi * 64
        let mut blk: [int] = []
        i = 0
        while i < 64 { blk.push(b[off + i]); i = i + 1 }
        x = _salsa20_8(_xor_block(x, blk))
        if (bi % 2) == 0 {
            i = 0; while i < 64 { yeven.push(x[i]); i = i + 1 }
        } else {
            i = 0; while i < 64 { yodd.push(x[i]); i = i + 1 }
        }
        bi = bi + 1
    }
    let mut out: [int] = []
    i = 0
    while i < len(yeven) { out.push(yeven[i]); i = i + 1 }
    i = 0
    while i < len(yodd) { out.push(yodd[i]); i = i + 1 }
    return out
}

// ROMix (r, N): N a power of two. in/out = 128*r bytes.
@pure
fn _ro_mix(b: [int], r: int, n: int) -> [int] {
    let blen = 128 * r
    let mut x: [int] = []
    let mut i = 0
    while i < blen { x.push(b[i]); i = i + 1 }
    // V[0..N]
    let mut v: [[int]] = []
    let mut j = 0
    while j < n {
        let mut snap: [int] = []
        i = 0
        while i < blen { snap.push(x[i]); i = i + 1 }
        v.push(snap)
        x = _block_mix(x, r)
        j = j + 1
    }
    // integerify mod N, XOR V[j], BlockMix
    j = 0
    while j < n {
        // j' = integerify(X) mod N = little-endian of last 64-byte block's first word
        let last = (2 * r - 1) * 64
        let idx = (x[last] | (x[last+1] << 8) | (x[last+2] << 16) | (x[last+3] << 24)) & _SC_M32
        let jj = idx % n
        x = _block_mix(_xor_block(x, v[jj]), r)
        j = j + 1
    }
    return x
}

@pure
pub fn scrypt(passwd: [int], salt: [int], n: int, r: int, p: int, dklen: int) -> [int] {
    let mpk = 128 * r
    // B = PBKDF2(P, S, 1, p*128*r)
    let mut b = pbkdf2_hmac_sha256(passwd, salt, 1, p * mpk)
    // ROMix each of the p blocks
    let mut bi = 0
    while bi < p {
        let off = bi * mpk
        let mut blk: [int] = []
        let mut i = 0
        while i < mpk { blk.push(b[off + i]); i = i + 1 }
        let mixed = _ro_mix(blk, r, n)
        i = 0
        while i < mpk { b[off + i] = mixed[i]; i = i + 1 }
        bi = bi + 1
    }
    // DK = PBKDF2(P, B, 1, dkLen)
    return pbkdf2_hmac_sha256(passwd, b, 1, dklen)
}
