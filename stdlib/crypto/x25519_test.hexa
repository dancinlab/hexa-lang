// HEXA Standard Library — crypto/x25519 self-test
// @ci_gate
use "stdlib/crypto/x25519"
fn unhex(s: string) -> [int] {
    let H = "0123456789abcdef"
    let mut b: [int] = []
    let mut i = 0
    while i < byte_len(s) { b.push(H.index_of(s.substring(i,i+1))*16 + H.index_of(s.substring(i+1,i+2))); i = i + 2 }
    return b
}
fn hx(b: [int]) -> string {
    let H = "0123456789abcdef"
    let mut p: [string] = []
    let mut i = 0
    while i < len(b) { p.push(H.substring((b[i]>>4)&15,((b[i]>>4)&15)+1)); p.push(H.substring(b[i]&15,(b[i]&15)+1)); i=i+1 }
    return p.join("")
}
let mut pass = 0
let mut total = 0
fn ck(name: string, got: string, want: string) {
    total = total + 1
    if got == want { pass = pass + 1 } else { println("FAIL " + name + " got=" + got) }
}
fn main() {
    // RFC 7748 §5.2 scalarmult
    ck("rfc7748_smul",
       hx(x25519(unhex("a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4"),
                 unhex("e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c"))),
       "c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552")
    // RFC 7748 §6.1 Alice public = base·privA
    ck("rfc7748_alice_pub",
       hx(x25519_base(unhex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a"))),
       "8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a")
    // ECDH agreement: A·(b·G) == B·(a·G)
    let priva = unhex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let privb = unhex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    let puba = x25519_base(priva)
    let pubb = x25519_base(privb)
    ck("ecdh_shared", hx(x25519(priva, pubb)), hx(x25519(privb, puba)))
    println("x25519 self-test: " + to_string(pass) + "/" + to_string(total))
    if pass == total { println("PASS") } else { println("FAILED") }
}
