// HEXA Standard Library — crypto/tls13_binder
//
// @version 0.1.0
// @capabilities [pure]
//
// TLS 1.3 PSK binder key derivation + binder MAC (RFC 8446 §4.2.11.2) — pure
// hexa. Used in the pre_shared_key extension to bind each PSK offer to the
// ClientHello prefix. Two binder-key variants:
//   - "res binder" (PSK resumed from a NewSessionTicket)
//   - "ext binder" (external PSK out-of-band)
// The binder itself is HMAC-SHA-256 over the truncated transcript using a
// "finished" key derived from the binder_key. let-mut idiom (#1506).
//
// Surface:
//   pub fn tls13_res_binder_key(early_secret: [int]) -> [int]
//   pub fn tls13_ext_binder_key(early_secret: [int]) -> [int]
//   pub fn tls13_psk_binder(binder_key: [int], truncated_transcript_hash: [int]) -> [int]

use "stdlib/crypto/tls13_keyschedule"
use "stdlib/crypto/tls13_finished"

@pure
pub fn tls13_res_binder_key(early_secret: [int]) -> [int] {
    // "res binder" = 72 65 73 20 62 69 6e 64 65 72
    let label = [0x72, 0x65, 0x73, 0x20, 0x62, 0x69, 0x6e, 0x64, 0x65, 0x72]
    // Hash("") for SHA-256 (the third Derive-Secret arg is Hash("") for binder-key derivation)
    let zh = [0xe3,0xb0,0xc4,0x42, 0x98,0xfc,0x1c,0x14, 0x9a,0xfb,0xf4,0xc8, 0x99,0x6f,0xb9,0x24,
              0x27,0xae,0x41,0xe4, 0x64,0x9b,0x93,0x4c, 0xa4,0x95,0x99,0x1b, 0x78,0x52,0xb8,0x55]
    let mut empty_hash: [int] = []
    let mut i = 0
    while i < 32 { empty_hash.push(zh[i]); i = i + 1 }
    return tls13_derive_secret(early_secret, label, empty_hash)
}

@pure
pub fn tls13_ext_binder_key(early_secret: [int]) -> [int] {
    // "ext binder" = 65 78 74 20 62 69 6e 64 65 72
    let label = [0x65, 0x78, 0x74, 0x20, 0x62, 0x69, 0x6e, 0x64, 0x65, 0x72]
    let zh = [0xe3,0xb0,0xc4,0x42, 0x98,0xfc,0x1c,0x14, 0x9a,0xfb,0xf4,0xc8, 0x99,0x6f,0xb9,0x24,
              0x27,0xae,0x41,0xe4, 0x64,0x9b,0x93,0x4c, 0xa4,0x95,0x99,0x1b, 0x78,0x52,0xb8,0x55]
    let mut empty_hash: [int] = []
    let mut i = 0
    while i < 32 { empty_hash.push(zh[i]); i = i + 1 }
    return tls13_derive_secret(early_secret, label, empty_hash)
}

// Compute the PSK binder MAC: HMAC-SHA-256(finished_key(binder_key), Truncated-Transcript-Hash).
// The truncated transcript = Hash(CH bytes up to (but not including) the binders field).
@pure
pub fn tls13_psk_binder(binder_key: [int], truncated_transcript_hash: [int]) -> [int] {
    // finished MAC over the truncated transcript using the binder_key — same shape as
    // Finished verify_data, just over a different transcript window.
    return tls13_finished_verify_data(binder_key, truncated_transcript_hash)
}
