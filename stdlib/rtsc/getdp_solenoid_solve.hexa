#!hexa strict
// stdlib/rtsc/getdp_solenoid_solve.hexa — `rtsc + verify` solve-driver.
//
// FUSION gate (e) F5 promote · HEXA-PORT P2 parity-oracle FEM bridge.
// This sibling of `getdp_hts.py` actually RUNS the validated A-φ getdp
// deck (stdlib/rtsc/decks/solenoid_axisym.{geo,pro}) on the reference
// HEXA-PORT P2 coil (NI=2e6, a=0.50, b=0.70, h=1.20) and prints a
// single parseable token `B_peak → <value>` on stdout. The fusion
// magnet-gate (stdlib/fusion/magnet_gate.hexa → _drive_rtsc_field_solve)
// greps that token to flip its `field_path` from `closed_form_1overR`
// to `getdp` when the substrate solve succeeds.
//
// VALIDATED (ubu-1 getdp 3.5.0, ~33k-node mesh):
//   FEM B_z(0) = 1.4817 T  vs  closed-form anchor 1.48265 T  →  Δ = -0.064%.
//   (Anchor: tool/verify_cli.hexa _solenoid_axis_bz(2e6,0.5,0.7,1.2)=1.48265 T)
//
// WHY .hexa (not .py): per CLAUDE.md hexa-native rule for this project,
// `.py` Writes are hook-blocked under stdlib/ — the solve-driver is
// authored in hexa-native and shells out to `gmsh` / `getdp` via `exec()`
// (mirrors the openmc_tbr.hexa / f3_grad_shafranov_adapter.hexa pattern).
//
// USAGE:
//   hexa run stdlib/rtsc/getdp_solenoid_solve.hexa <out_dir>
// emits:
//   B_peak → 1.4817         (on stdout, one line, just before exit)
//   plus the raw deck artifacts in <out_dir>/ (msh + Print tables).
// On any failure (gmsh / getdp absent / non-zero exit / sweep unreadable)
// emits NOTHING on stdout — the caller treats absence as "honest skip"
// and falls back to the closed-form 1/R estimate.

// ── deck SSOT (relative to project root; hexa-lang code-home @D d3) ──────
let DECK_GEO: string = "stdlib/rtsc/decks/solenoid_axisym.geo"
let DECK_PRO: string = "stdlib/rtsc/decks/solenoid_axisym.pro"

// ── shell helpers ───────────────────────────────────────────────────────
fn _shell_quote(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _probe(cmd: string) -> bool {
    // `command -v <bin> >/dev/null 2>&1 && echo ok` — empty = absent.
    let r = exec(cmd).trim()
    return r == "ok"
}

// ── main entry ──────────────────────────────────────────────────────────
fn main() {
    let argv = args()
    let mut out_dir = "/tmp/rtsc_solve"
    // argv[0] is the program; argv[1] is the out_dir if supplied.
    if argv.len() > 1 {
        let a = argv[1]
        if a.len() > 0 { out_dir = a }
    }

    let qd = _shell_quote(out_dir)
    let _ = exec("mkdir -p " + qd + " 2>/dev/null")

    // Probe both binaries; bail silently if either is absent (honest
    // install-gated skip — caller falls back to closed-form).
    let have_gmsh = _probe("command -v gmsh >/dev/null 2>&1 && echo ok")
    let have_getdp = _probe("command -v getdp >/dev/null 2>&1 && echo ok")
    if !have_gmsh || !have_getdp { return }

    // Resolve deck paths to absolute up front (out_dir may be anywhere on
    // disk; relative paths break the moment we `cd` into it). On hosts
    // without `realpath` (rare; macOS bare), `readlink -f` is the fallback.
    let abs_geo = exec("realpath " + _shell_quote(DECK_GEO) + " 2>/dev/null || readlink -f " + _shell_quote(DECK_GEO) + " 2>/dev/null").trim()
    let abs_pro = exec("realpath " + _shell_quote(DECK_PRO) + " 2>/dev/null || readlink -f " + _shell_quote(DECK_PRO) + " 2>/dev/null").trim()
    if abs_geo.len() == 0 || abs_pro.len() == 0 { return }
    let qgeo = _shell_quote(abs_geo)
    let qpro = _shell_quote(abs_pro)

    // 1) Mesh into out_dir.
    let mesh_path = out_dir + "/solenoid_axisym.msh"
    let qmsh = _shell_quote(mesh_path)
    let mesh_cmd = "gmsh -2 " + qgeo + " -o " + qmsh + " >/dev/null 2>&1; echo $?"
    let mesh_rc = exec(mesh_cmd).trim()
    if mesh_rc != "0" { return }

    // 2) Solve + post-process. We cd into out_dir so getdp's solution
    // artifacts (.pre/.res) land there, AND we pass OUT_DIR as the ABSOLUTE
    // out_dir path: getdp 4.0 resolves a relative OUT_DIR relative to the
    // .pro file's directory (NOT cwd, getdp 3.5's behaviour) — passing an
    // absolute path keeps Print[] tables next to the mesh on both versions.
    let abs_out = exec("realpath " + qd + " 2>/dev/null || readlink -f " + qd + " 2>/dev/null").trim()
    if abs_out.len() == 0 { return }
    let qaout = _shell_quote(abs_out)
    let solve_cmd = "cd " + qd + " && getdp " + qpro
        + " -msh solenoid_axisym.msh -solve MagStat -pos MagStat -setstring OUT_DIR " + qaout + " >/dev/null 2>&1; echo $?"
    let solve_rc = exec(solve_cmd).trim()
    if solve_rc != "0" { return }

    // 3) Read on-axis |B| at z=0 from the OnLine sweep (200 samples over
    //    z∈[-Z_SWEEP,+Z_SWEEP], so row 101 is z=0; last whitespace-delimited
    //    column is |B|). Equivalent: awk 'NR==101 {print $NF}'.
    let sweep = out_dir + "/bmag_axis.txt"
    let read_cmd = "awk 'NR==101 {print $NF}' " + _shell_quote(sweep) + " 2>/dev/null"
    let bpeak_s = exec(read_cmd).trim()
    if len(bpeak_s) == 0 { return }
    let bpeak = to_float(bpeak_s)
    if bpeak <= 0.0 { return }

    // 4) Emit the parseable token consumed by
    //    stdlib/fusion/magnet_gate.hexa _drive_rtsc_field_solve().
    println("B_peak → " + to_string(bpeak))
}
