// @raw117_exempt
// ════════════════════════════════════════════════════════════════════════
// stdlib/alloc/json_cli_pattern_test.hexa
//
// CANONICAL EXAMPLE — single-file CLI pattern (read JSON · mutate ·
// write JSON pretty-printed) using stdlib/alloc/json.hexa +
// stdlib/alloc/json_object.hexa.
//
// Resolves archive/patches/port-pool-cli-to-hexa.md (option a: document
// the existing surface — smallest delta). After landing, dancinlab/pool's
// `bin/pool.hexa` port mirrors this pattern verbatim (the 6 verbs:
// add · list · on · rm · off · status — all of which are simple
// transformations on a top-level object with a `hosts` array).
//
// ── Canonical primitives map (no new code in hexa-lang needed) ─────
//
//   Patch sketch                            Actual hexa-lang primitive
//   ──────────────────────────────────────  ───────────────────────────────
//   fs_read(path) -> str                     read_file(path) -> string
//                                            (canonical name; the
//                                            self/std_fs.hexa `fs_read`
//                                            wrappers are dormant — the
//                                            __builtin_fs_* layer they
//                                            target doesn't exist in
//                                            codegen. Use read_file.)
//   fs_write(path, content)                  write_file(path, content)
//   exec_capture(cmd) -> [out, err, exit]    exec_capture(cmd)
//                                            (codegen_c2.hexa:4409)
//   argv -> [str]                            args() -> [string]
//   json_parse(str) -> JsonValue             json_parse(text)
//                                            runtime builtin; returns
//                                            map | array | scalar | void
//   json_field(root, "k")                    root["k"]
//                                            (hexa native index; or use
//                                            json_object_get(root, "k")
//                                            for void-safe variant)
//   json_array(json_field(root,"hosts"))     json_object_get_array(root, "hosts")
//                                            (returns [] if not array)
//   json_pretty(v) -> str                    json_dump_pretty(v, 2)
//                                            (2-space indent canonical)
//
// ── FALSIFIERS ────────────────────────────────────────────────────────
//   F-JSON-POOL-PATTERN-PARSE     parse mock pool.json → top-level object
//   F-JSON-POOL-PATTERN-LIST      iterate hosts array → expected names
//   F-JSON-POOL-PATTERN-ADD       in-place append → length +1
//   F-JSON-POOL-PATTERN-REMOVE    rebuild without index N → length -1
//   F-JSON-POOL-PATTERN-MUTATE    json_object_set on host field → value
//   F-JSON-POOL-PATTERN-ROUNDTRIP read-mutate-pretty-print-reparse →
//                                  semantic equivalence
// ════════════════════════════════════════════════════════════════════════

use "stdlib/alloc/json"
use "stdlib/alloc/json_object"

fn _t_fail(msg: string) {
    println("  FAIL: " + msg)
}

fn _t_pass(name: string) {
    println("  PASS: " + name)
}

// Mock pool.json content (matches dancinlab/pool schema sketch).
fn _mock_pool_json() -> string {
    return "{\"hosts\":[{\"name\":\"ubu-1\",\"addr\":\"10.0.0.21\",\"state\":\"on\"},{\"name\":\"ubu-2\",\"addr\":\"10.0.0.22\",\"state\":\"off\"},{\"name\":\"mini\",\"addr\":\"10.0.0.30\",\"state\":\"on\"}],\"version\":1}"
}

// ── pool verbs (six) ───────────────────────────────────────────────

// verb: list — host names + state per row
fn pool_list(root) {
    let hosts = json_object_get_array(root, "hosts")
    let mut i = 0
    while i < len(hosts) {
        let h = hosts[i]
        let name = json_object_get_str(h, "name", "?")
        let addr = json_object_get_str(h, "addr", "?")
        let state = json_object_get_str(h, "state", "unknown")
        println("    " + name + "  " + addr + "  [" + state + "]")
        i = i + 1
    }
}

// verb: status — count by state
fn pool_status(root) -> string {
    let hosts = json_object_get_array(root, "hosts")
    let mut n_on = 0
    let mut n_off = 0
    let mut n_other = 0
    let mut i = 0
    while i < len(hosts) {
        let s = json_object_get_str(hosts[i], "state", "?")
        if s == "on" { n_on = n_on + 1 }
        else { if s == "off" { n_off = n_off + 1 }
        else { n_other = n_other + 1 }}
        i = i + 1
    }
    return "on=" + to_string(n_on) + " off=" + to_string(n_off) +
           " other=" + to_string(n_other) + " total=" + to_string(len(hosts))
}

// verb: add — append a host
fn pool_add(root, name: string, addr: string) {
    let hosts = json_object_get_array(root, "hosts")
    let new_host = json_parse("{}")
    let _ = json_object_set(new_host, "name", name)
    let _ = json_object_set(new_host, "addr", addr)
    let _ = json_object_set(new_host, "state", "off")
    let _ = json_array_push(hosts, new_host)
    // hosts is the same reference as root["hosts"] — mutation persists.
}

// verb: on / off — set state by name
fn pool_set_state(root, name: string, state: string) -> bool {
    let hosts = json_object_get_array(root, "hosts")
    let mut i = 0
    while i < len(hosts) {
        let h = hosts[i]
        if json_object_get_str(h, "name", "") == name {
            let _ = json_object_set(h, "state", state)
            return true
        }
        i = i + 1
    }
    return false
}

// verb: rm — remove a host by name (rebuild array)
fn pool_rm(root, name: string) -> bool {
    let hosts = json_object_get_array(root, "hosts")
    let new_hosts = []
    let mut found = false
    let mut i = 0
    while i < len(hosts) {
        let h = hosts[i]
        if json_object_get_str(h, "name", "") == name {
            found = true
        } else {
            let _ = json_array_push(new_hosts, h)
        }
        i = i + 1
    }
    let _ = json_object_set(root, "hosts", new_hosts)
    return found
}

// ── falsifiers ─────────────────────────────────────────────────────

fn main() -> int {
    println("=== json_cli_pattern_test (pool.hexa canonical reference) ===")
    let txt = _mock_pool_json()
    let root = json_parse(txt)

    // F-JSON-POOL-PATTERN-PARSE
    if type_of(root) != "map" {
        _t_fail("F-JSON-POOL-PATTERN-PARSE — root not a map: got " + type_of(root))
        return 1
    }
    if !has_key(root, "hosts") {
        _t_fail("F-JSON-POOL-PATTERN-PARSE — 'hosts' key missing")
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-PARSE")

    // F-JSON-POOL-PATTERN-LIST
    println("  list (initial):")
    pool_list(root)
    let hosts_initial_len = len(json_object_get_array(root, "hosts"))
    if hosts_initial_len != 3 {
        _t_fail("F-JSON-POOL-PATTERN-LIST — expected 3 hosts, got " + to_string(hosts_initial_len))
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-LIST (n=3)")

    // F-JSON-POOL-PATTERN-ADD
    pool_add(root, "summer", "10.0.0.40")
    let after_add = len(json_object_get_array(root, "hosts"))
    if after_add != hosts_initial_len + 1 {
        _t_fail("F-JSON-POOL-PATTERN-ADD — expected " + to_string(hosts_initial_len + 1) +
                ", got " + to_string(after_add))
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-ADD (+summer → n=" + to_string(after_add) + ")")

    // F-JSON-POOL-PATTERN-MUTATE
    let ok_on = pool_set_state(root, "ubu-2", "on")
    if !ok_on {
        _t_fail("F-JSON-POOL-PATTERN-MUTATE — ubu-2 not found")
        return 1
    }
    let hosts_chk = json_object_get_array(root, "hosts")
    let mut found_on = false
    let mut k = 0
    while k < len(hosts_chk) {
        let h = hosts_chk[k]
        if json_object_get_str(h, "name", "") == "ubu-2" {
            if json_object_get_str(h, "state", "") == "on" { found_on = true }
        }
        k = k + 1
    }
    if !found_on {
        _t_fail("F-JSON-POOL-PATTERN-MUTATE — ubu-2 state not 'on' after set")
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-MUTATE (ubu-2 → on)")

    // F-JSON-POOL-PATTERN-REMOVE
    let ok_rm = pool_rm(root, "mini")
    if !ok_rm {
        _t_fail("F-JSON-POOL-PATTERN-REMOVE — mini not found")
        return 1
    }
    let after_rm = len(json_object_get_array(root, "hosts"))
    if after_rm != after_add - 1 {
        _t_fail("F-JSON-POOL-PATTERN-REMOVE — expected " + to_string(after_add - 1) +
                ", got " + to_string(after_rm))
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-REMOVE (-mini → n=" + to_string(after_rm) + ")")

    // status
    println("  status: " + pool_status(root))

    // F-JSON-POOL-PATTERN-ROUNDTRIP
    // Pretty-print → parse-back → check structure preserved.
    let pretty = json_dump_pretty(root, 2)
    println("  pretty (preview, first 80 chars):")
    println("    " + str_slice(pretty, 0, 80) + " …")
    let reparsed = json_parse(pretty)
    if type_of(reparsed) != "map" {
        _t_fail("F-JSON-POOL-PATTERN-ROUNDTRIP — reparsed not a map")
        return 1
    }
    let reparsed_hosts = json_object_get_array(reparsed, "hosts")
    if len(reparsed_hosts) != after_rm {
        _t_fail("F-JSON-POOL-PATTERN-ROUNDTRIP — host count mismatch: " +
                to_string(len(reparsed_hosts)) + " vs " + to_string(after_rm))
        return 1
    }
    // Spot-check one field round-tripped exactly
    let r0 = reparsed_hosts[0]
    let orig_hosts = json_object_get_array(root, "hosts")
    if json_object_get_str(r0, "name", "") != json_object_get_str(orig_hosts[0], "name", "_x_") {
        _t_fail("F-JSON-POOL-PATTERN-ROUNDTRIP — first host name not preserved")
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-ROUNDTRIP (n=" + to_string(len(reparsed_hosts)) + " preserved)")

    // ── read_file / write_file demo (Mac-tmp roundtrip) ────────────
    // Demonstrates the full disk pattern. If the env can't write /tmp,
    // skip — Mac CI smoke can always.
    let tmp_path = "/tmp/pool_pattern_test.json"
    write_file(tmp_path, pretty + "\n")
    let read_back = to_string(read_file(tmp_path))
    let reparsed_disk = json_parse(read_back)
    let disk_hosts = json_object_get_array(reparsed_disk, "hosts")
    if len(disk_hosts) != after_rm {
        _t_fail("F-JSON-POOL-PATTERN-DISKIO — disk roundtrip host count mismatch")
        return 1
    }
    _t_pass("F-JSON-POOL-PATTERN-DISKIO (read_file ↔ write_file ↔ json_parse ↔ json_dump_pretty)")

    println("=== ALL FALSIFIERS PASS ===")
    return 0
}
