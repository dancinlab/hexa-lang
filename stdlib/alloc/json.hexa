// stdlib/json.hexa — JSON write-side helpers (P1 — qmirror calibration cache)
//
// @version 1.0.0
// @capabilities [pure]
//
//
// @module(slug="stdlib-json", desc="write-side JSON helpers built on the runtime json_stringify builtin")
// @usage(import stdlib/json; let s = json_dump_pretty(cache_map, 2))
//
// ── module governance metadata (hexa-lang module versioning spec 2026-05-03) ──
// @version 1.0.0
// @capabilities [json_stringify_value, json_dump_pretty, json_object_set, json_array_push]
// @stability stable
// @since 2026-05-03
// @maintainer anima-core
// @priority P1
// Versioning policy: docs/hexa_lang_module_versioning_spec_2026_05_03.md
// Note: read-side helpers live in stdlib/json_object.hexa (separate @module).
//
// Source: anima/docs/hexa_lang_attr_review_for_qmirror_2026_05_03.md §5.3
//
// PROBLEM (qmirror calibration cache writeback)
//   nexus/modules/{calibration_v2,engine_aer}.hexa need to serialize a
//   nested map (counts, ρ matrix slices, per-shot timings) to disk with
//   stable, diff-friendly formatting. The runtime `json_stringify` builtin
//   produces compact one-line output — fine for transport, awkward for
//   git-diffable cache files. Sisters were hand-concatenating
//   `"{\"key\": " + ... + "}"` strings (escape-fragile).
//
// FIX (additive, no runtime.c change)
//   1. json_stringify_value(v) -> string
//        Stable alias over the runtime `json_stringify` builtin so callers
//        that `use "stdlib/json"` get a guaranteed symbol path. Pure
//        delegation — no behavioural change vs builtin.
//   2. json_dump_pretty(v, indent) -> string
//        Recursive pretty-printer. Indent = number of spaces per level
//        (0 = compact, 2 = canonical cache format).
//   3. json_object_set(obj, key, value) -> map
//        In-place set (via index assignment) returning the same map for
//        chaining. Mirrors hexa map convention without forcing callers to
//        learn the `obj[key] = v` syntax inside expression contexts.
//   4. json_array_push(arr, value) -> array
//        Same idea for arrays — return-self push.
//
// Breaking risk: 0. All new symbol names; the runtime `json_stringify`
// builtin is untouched and remains the canonical compact encoder.
// stdlib/json_object.hexa (read side) is unchanged.
//
// Caveats (C3):
//   · json_dump_pretty escaping is the runtime builtin's escape policy
//     applied per-leaf — minimal `\\`, `\"`, `\n` only. Calibration cache
//     payload is ASCII-numeric, so this is adequate. Arbitrary user input
//     direct-serialize is NOT safe (UTF-16 surrogate pair, control chars
//     not handled). See attr review §6 caveat 7.
//   · The pretty-printer parses-then-re-emits via json_stringify on each
//     leaf — O(N · depth) string concat, not the optimal single-pass
//     emitter. For typical calibration files (<100KB) this is negligible.
//   · json_object_set/json_array_push mutate the caller's map/array in
//     place. The return value is the same reference — useful for
//     chaining, NOT a copy. Callers mutating shared state should clone
//     first via json_parse(json_stringify(orig)).
//
// hexa-only-strict: pure hexa wrapper, zero exec(), zero new C
//   builtin. The underlying serializer is the existing runtime
//   `json_stringify` already exercised by 37+ callsites (see runtime.c
//   line 6669 inventory).

// ── json_stringify_value — runtime builtin alias ─────────────────
//
// Re-exports the runtime json_stringify under a path-stable name. Callers
// that `use "stdlib/json"` can rely on this symbol surviving any future
// runtime rename. Pure passthrough — no allocation, no escape changes.
pub fn json_stringify_value(v) -> string {
    return json_stringify(v)
}

// ── json_dump_pretty — recursive pretty-printer ──────────────────
//
// Emits `v` as JSON with `indent` spaces per nesting level. indent=0
// degenerates to compact mode (delegates to runtime builtin one-shot).
//
// Type dispatch uses runtime type_of() — identical to the builtin's own
// dispatch table. Unknown types fall through to the builtin which emits
// "null" or a quoted string representation depending on runtime policy.
pub fn json_dump_pretty(v, indent: int) -> string {
    if indent <= 0 { return json_stringify(v) }
    return _json_dump_indent(v, indent, 0)
}

// _json_dump_indent — internal recursive emitter.
//
// `level` is the current nesting depth (0 at root). The pad is computed
// fresh each level; cheap O(depth) string-build, not memoised because
// depth in calibration files is typically ≤4.
// decreases v — structural
fn _json_dump_indent(v, indent: int, level: int) -> string {
    let t = type_of(v)
    if t == "void" { return "null" }
    if t == "bool" { return json_stringify(v) }
    if t == "int" { return json_stringify(v) }
    if t == "float" { return json_stringify(v) }
    if t == "string" { return json_stringify(v) }
    if t == "array" {
        if len(v) == 0 { return "[]" }
        let pad = _json_pad(indent, level + 1)
        let close_pad = _json_pad(indent, level)
        let mut out = "[\n"
        let mut i = 0
        while i < len(v) {
            out = out + pad + _json_dump_indent(v[i], indent, level + 1)
            if i + 1 < len(v) { out = out + "," }
            out = out + "\n"
            i = i + 1
        }
        out = out + close_pad + "]"
        return out
    }
    if t == "map" {
        let ks = dict_keys(v)
        if len(ks) == 0 { return "{}" }
        let pad = _json_pad(indent, level + 1)
        let close_pad = _json_pad(indent, level)
        let mut out = "{\n"
        let mut i = 0
        while i < len(ks) {
            let k = ks[i]
            out = out + pad + json_stringify(k) + ": " + _json_dump_indent(v[k], indent, level + 1)
            if i + 1 < len(ks) { out = out + "," }
            out = out + "\n"
            i = i + 1
        }
        out = out + close_pad + "}"
        return out
    }
    return json_stringify(v)
}

// _json_pad — N spaces per level, computed on demand.
fn _json_pad(indent: int, level: int) -> string {
    let total = indent * level
    let mut s = ""
    let mut i = 0
    while i < total {
        s = s + " "
        i = i + 1
    }
    return s
}

// ── json_object_set / json_array_push — in-place builders ────────
//
// Conventional hexa style is `m[k] = v` and `arr.push(v)`. These
// helpers exist for two ergonomic reasons:
//   1. Chainable: `json_object_set(json_object_set(m, "a", 1), "b", 2)`
//      builds a map in expression context (no statement chain needed).
//   2. Symbol stability: callers using `use "stdlib/json"` get a
//      guaranteed-named entry point that survives map literal syntax
//      churn (the language has had three map literal forms — `{}`,
//      `#{}`, `json_parse("{}")` — over its lifetime).
//
// Return value is the SAME map/array reference (mutated in place).
// ── json_dumps_canonical — Python json.dumps(x, sort_keys=True) byte-exact ──
//
// T3/T4 asset: hexa-bio witness gates hash
//   hashlib.sha256(json.dumps(obj, sort_keys=True).encode()).hexdigest()
// so an in-repo encoder must be BYTE-IDENTICAL to CPython's default
// (ensure_ascii=True, separators=(", ", ": "), recursive key sort).
// Input `v` is a json_parse'd value (native map/array/scalar). Pure
// hexa, zero exec(); scalars delegate to the runtime json_stringify
// (verified to match Python repr for int/float/bool/null); strings use
// the ensure_ascii escaper below (json_stringify keeps raw UTF-8, which
// CPython does NOT). Residual: extreme float reprs are re-checked
// empirically against Python on the actual corpus (g3 — no silent
// approximation).

let _HEX = "0123456789abcdef"

fn _hex4(n: int) -> string {
    let a = (n / 4096) % 16
    let b = (n / 256) % 16
    let c = (n / 16) % 16
    let d = n % 16
    return _HEX.substr(a, 1) + _HEX.substr(b, 1) + _HEX.substr(c, 1) + _HEX.substr(d, 1)
}

// byte-wise (== Unicode code-point) less-than, == CPython str sort key.
fn _str_lt(a: string, b: string) -> bool {
    let mut i = 0
    while i < len(a) && i < len(b) {
        let ca = ord(a.substr(i, 1))
        let cb = ord(b.substr(i, 1))
        if ca != cb { return ca < cb }
        i = i + 1
    }
    return len(a) < len(b)
}

fn _sorted_keys(v) -> array {
    let ks = dict_keys(v)
    let mut a: array = []
    let mut i = 0
    while i < len(ks) { a.push(ks[i]); i = i + 1 }
    // insertion sort (key counts are small per object)
    let mut j = 1
    while j < len(a) {
        let key = a[j]
        let mut k = j - 1
        while k >= 0 && _str_lt(key, a[k]) {
            a[k + 1] = a[k]
            k = k - 1
        }
        a[k + 1] = key
        j = j + 1
    }
    return a
}

// CPython json string encoder: ensure_ascii=True, short escapes for
// \" \\ \b \f \n \r \t, other C0 → \u00xx, every byte ≥0x80 UTF-8
// decoded to a code point → \uXXXX (BMP) or surrogate pair (astral).
fn _json_str(s: string) -> string {
    let mut out = "\""
    let n = len(s)
    let mut i = 0
    while i < n {
        let b0 = ord(s.substr(i, 1))
        if b0 == 34 { out = out + "\\\""; i = i + 1 }
        else if b0 == 92 { out = out + "\\\\"; i = i + 1 }
        else if b0 == 8 { out = out + "\\b"; i = i + 1 }
        else if b0 == 12 { out = out + "\\f"; i = i + 1 }
        else if b0 == 10 { out = out + "\\n"; i = i + 1 }
        else if b0 == 13 { out = out + "\\r"; i = i + 1 }
        else if b0 == 9 { out = out + "\\t"; i = i + 1 }
        else if b0 < 32 { out = out + "\\u" + _hex4(b0); i = i + 1 }
        else if b0 < 128 { out = out + s.substr(i, 1); i = i + 1 }
        else {
            // multi-byte UTF-8 → code point (arithmetic, no bit ops)
            let mut cp = 0
            let mut adv = 1
            if b0 >= 240 {
                let b1 = ord(s.substr(i + 1, 1))
                let b2 = ord(s.substr(i + 2, 1))
                let b3 = ord(s.substr(i + 3, 1))
                cp = (b0 - 240) * 262144 + (b1 - 128) * 4096 + (b2 - 128) * 64 + (b3 - 128)
                adv = 4
            } else if b0 >= 224 {
                let b1 = ord(s.substr(i + 1, 1))
                let b2 = ord(s.substr(i + 2, 1))
                cp = (b0 - 224) * 4096 + (b1 - 128) * 64 + (b2 - 128)
                adv = 3
            } else {
                let b1 = ord(s.substr(i + 1, 1))
                cp = (b0 - 192) * 64 + (b1 - 128)
                adv = 2
            }
            if cp > 65535 {
                let u = cp - 65536
                let hi = 55296 + (u / 1024)
                let lo = 56320 + (u % 1024)
                out = out + "\\u" + _hex4(hi) + "\\u" + _hex4(lo)
            } else {
                out = out + "\\u" + _hex4(cp)
            }
            i = i + adv
        }
    }
    return out + "\""
}

fn _canon(v) -> string {
    let t = type_of(v)
    if t == "void" { return "null" }
    if t == "bool" { return json_stringify(v) }
    if t == "int" { return json_stringify(v) }
    if t == "float" { return json_stringify(v) }
    if t == "string" { return _json_str(v) }
    if t == "array" {
        if len(v) == 0 { return "[]" }
        let mut out = "["
        let mut i = 0
        while i < len(v) {
            if i > 0 { out = out + ", " }
            out = out + _canon(v[i])
            i = i + 1
        }
        return out + "]"
    }
    if t == "map" {
        let ks = _sorted_keys(v)
        if len(ks) == 0 { return "{}" }
        let mut out = "{"
        let mut i = 0
        while i < len(ks) {
            if i > 0 { out = out + ", " }
            out = out + _json_str(ks[i]) + ": " + _canon(v[ks[i]])
            i = i + 1
        }
        return out + "}"
    }
    return json_stringify(v)
}

// json_dumps_canonical(v) — byte-identical to CPython
// json.dumps(v, sort_keys=True) (default ensure_ascii / separators).
pub fn json_dumps_canonical(v) -> string {
    return _canon(v)
}

pub fn json_object_set(obj, key: string, value) {
    obj[key] = value
    return obj
}

pub fn json_array_push(arr, value) {
    arr.push(value)
    return arr
}
