// HEXA Standard Library — info/entropy_histogram
//
// @version 0.1.0
// @capabilities [pure]
//
// Shannon entropy (in NATS) over a fixed min/max histogram of a flat list.
// Promoted from anima canonical site `anima-physics/realtime_monitor.hexa`
// (`entropy_hist` + `joint_entropy_hist`) per STDLIB phase4 survey #455 —
// 23 duplicate clones across anima (anima-engines/*, anima-physics/*,
// archive/anima-hexad/*).
//
// Byte-equal-faithful to the anima sites:
//   - signature order (v, lo, hi, nb) preserved (not the RFC sketch order).
//   - natural log via libm `log` (= anima `ln_safe` after guard).
//   - p > 0 branch (zero-count bins contribute 0, no smoothing constant).
//   - bin clamp [0, nb-1], `hi <= lo` -> all bin 0 short-circuit.
//
// NOTE: anima sites used NATURAL log (nats); this module preserves that for
// drop-in replacement. For Shannon in BITS use `* (1.0 / log(2.0))` at the
// caller, or compose with `stdlib/info/entropy.hexa::shannon_entropy` which
// divides by log(2.0) internally (different surface: farr handle + counts).
//
// Surface:
//   pub fn entropy_hist(v: [float], lo: float, hi: float, nb: int) -> float
//   pub fn joint_entropy_hist(a: [float], b: [float], lo: float, hi: float, nb: int) -> float

fn _ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return log(x)
}

fn _bin_index(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn _count_hits(bin_ids: array, n_bins: int) -> array {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

pub fn entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(_bin_index(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = _count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 {
            h = h - p * _ln_safe(p)
        }
        k = k + 1
    }
    return h
}

pub fn joint_entropy_hist(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = _bin_index(a[i], lo, hi, nb)
        let ib = _bin_index(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let nb2 = nb * nb
    let counts = _count_hits(pair_ids, nb2)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb2 {
        let p = counts[k] * inv_n
        if p > 0.0 {
            h = h - p * _ln_safe(p)
        }
        k = k + 1
    }
    return h
}
