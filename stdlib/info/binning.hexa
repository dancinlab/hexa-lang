// HEXA Standard Library — info/binning
//
// @version 0.1.0
// @capabilities [pure]
//
// Min-max histogram binning. Promoted from anima HEXAD/LIFE phi_native.hexa
// (`phi_bin_values`) per RFC stdlib_scaffold §3. Byte-equal to the RFC 036 C
// replica (self/runtime.c:7849-7872).
//
// Edge cases (verbatim from the C replica):
//   - n <= 0                       -> length-n zero farr
//   - all-identical (range < f32 EPSILON 1.19209290e-7) -> all bin 0
//   - boundary truncation == n_bins -> clamp to n_bins-1
//
// Surface:
//   pub fn bin_values_minmax(values: int, n: int, n_bins: int) -> int
//     values = flat farr handle (length >= n). Returns a farr handle of length
//     n holding bin indices in [0, n_bins-1].

pub fn bin_values_minmax(values: int, n: int, n_bins: int) -> int {
    let bins = farr_zeros(n)
    if n <= 0 { return bins }

    let mut mn = farr_get(values, 0)
    let mut mx = mn
    let mut i = 1
    while i < n {
        let v = farr_get(values, i)
        if v < mn { mn = v }
        if v > mx { mx = v }
        i = i + 1
    }
    let range = mx - mn
    if range < 1.19209290e-7 { return bins }

    let bw = range / n_bins
    let mut j = 0
    while j < n {
        let r = (farr_get(values, j) - mn) / bw
        let mut b = floor(r).to_int()
        if b > n_bins - 1 { b = n_bins - 1 }
        if b < 0 { b = 0 }
        let _ = farr_set(bins, j, b)
        j = j + 1
    }
    return bins
}
