// Smoke test — stdlib info+math scaffold phase 1 (RFC stdlib_scaffold §3).
// Verifies the 4 promoted modules compile, import, and produce correct values.

import "stdlib/math/bitops.hexa"
import "stdlib/info/binning.hexa"
import "stdlib/info/entropy.hexa"
import "stdlib/info/mutual_info.hexa"

fn _check_int(name: string, got: int, want: int) -> int {
    if got == want {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    return 1
}

fn _check_flag(name: string, ok: int) -> int {
    if ok == 1 {
        println("PASS " + name)
        return 0
    }
    println("FAIL " + name)
    return 1
}

fn main() {
    let mut fails = 0

    // ── bitops ──
    fails = fails + _check_int("pow2_int(0)", pow2_int(0), 1)
    fails = fails + _check_int("pow2_int(5)", pow2_int(5), 32)
    fails = fails + _check_int("pow2_int(19)", pow2_int(19), 524288)
    fails = fails + _check_int("bit_set(5,0)", bit_set(5, 0), 1)
    fails = fails + _check_int("bit_set(5,1)", bit_set(5, 1), 0)
    fails = fails + _check_int("bit_set(5,2)", bit_set(5, 2), 1)

    // ── binning: [0,1,2,3] into 4 bins -> [0,1,2,3] ──
    let v = farr_zeros(4)
    let _ = farr_set(v, 0, 0.0)
    let _ = farr_set(v, 1, 1.0)
    let _ = farr_set(v, 2, 2.0)
    let _ = farr_set(v, 3, 3.0)
    let bins = bin_values_minmax(v, 4, 4)
    fails = fails + _check_int("bin[0]", farr_get(bins, 0).to_int(), 0)
    fails = fails + _check_int("bin[3]", farr_get(bins, 3).to_int(), 3)

    // ── entropy: uniform 2-bin counts [1,1], total 2 -> ~1 bit ──
    let c = farr_zeros(2)
    let _ = farr_set(c, 0, 1.0)
    let _ = farr_set(c, 1, 1.0)
    let h = shannon_entropy(c, 2, 2)
    let mut he = 0
    if h > 0.9 { if h < 1.001 { he = 1 } }
    fails = fails + _check_flag("entropy_uniform~1bit", he)

    // ── mutual_info: a==b perfectly correlated -> MI > 0 ──
    let mi = mutual_info_pair(v, v, 4, 4)
    let mut mie = 0
    if mi > 0.0 { mie = 1 }
    fails = fails + _check_flag("mi_self>0", mie)

    if fails == 0 {
        println("ALL PASS — stdlib scaffold phase 1 (4 modules)")
    } else {
        println("FAILURES: " + to_string(fails))
        exit(1)
    }
}
