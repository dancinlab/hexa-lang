#!hexa strict
// perovskite verify — SQ-limit empirical at Eg=1.34 eV.
fn main() {
    let Eg_eV = 1.34
    let Voc_loss_eV = 0.3
    let Voc_max_V = Eg_eV - Voc_loss_eV
    let PCE_SQ_pct = 33.7  // detailed-balance Shockley-Queisser
    println("perovskite_verify (SQ-limit · Eg=1.34 eV):")
    println("  Eg_eV = " + str(Eg_eV))
    println("  Voc_max_V = " + str(Voc_max_V))
    println("  PCE_SQ_percent = " + str(PCE_SQ_pct))
    println("__HEXA_PEROVSKITE_VERIFY__ PASS gate=GATE_OPEN absorbed=false")
}
