// HEXA Standard Library — n6/discover
//
// @version 0.1.0
// @capabilities [pure]
//
// absorbed from ~/core/anima/anima-tools/discovery-engine/main.hexa (MIT, dancinlab 2026-05-14)
//
// n=6 arithmetic discovery: enumerate small expression trees over the n6
// invariants and search for matches against caller-supplied target values.
//
// Diet vs the 362-LOC anima original:
//   - drop `--json` / `--bench` / CLI parsing (CLI lives in stdlib/n6/main.hexa).
//   - drop the anima target table (callers pass seeds).
//   - drop the diversity / domain categorisation scaffolding (kept the
//     core operator surface only — COLLISION / INVERSE / COMPOSE).
//   - operate on simple `int` seeds for parity with the request surface;
//     internally we still use float math.
//
// n6 base constants (hardcoded — these are the n=6 invariants):
//   sigma=12, tau=4, phi=2, sopfr=5, J2=24, mu=1, n=6
//
// Public surface:
//   pub fn op_collision(a: int, b: int) -> int
//   pub fn op_inverse(a: int) -> int
//   pub fn op_compose(a: int, b: int) -> int
//   pub struct Relation { op: string, lhs: int, rhs: int, value: int }
//   pub fn discover_relations(seeds: [int]) -> [Relation]

let _N6_N     = 6
let _N6_SIGMA = 12
let _N6_TAU   = 4
let _N6_PHI   = 2
let _N6_SOPFR = 5
let _N6_J2    = 24
let _N6_MU    = 1

pub struct Relation {
    op: string,
    lhs: int,
    rhs: int,
    value: int
}

// ── op_collision ───────────────────────────────────────────────────────────
//
// COLLISION(a, b): the n6 "encounter" arithmetic — gcd-based reduction folded
// against sigma. Encoded as: (a · b) mod sigma, with sigma=12 the natural
// modulus (sigma = P(tau,2)). Returns 0 when a or b is 0.
//
// Reference: anima discovery-engine treats COLLISION as the cross-domain
// arithmetic operator that maps two inputs into a sigma-bounded output;
// `(a*b) mod sigma` is the stdlib stage-1 canonical form.

pub fn op_collision(a: int, b: int) -> int {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    let p = a * b
    let r = p % _N6_SIGMA
    if r < 0 { return r + _N6_SIGMA }
    return r
}

// ── op_inverse ─────────────────────────────────────────────────────────────
//
// INVERSE(a): n6 reflection about the J2 axis. J2(6)=24 is the n6 "double-
// cover" invariant — the n6 inverse of a (within the J2 lattice) is J2-a.
// Returns 0 when a is 0 (fixed point of the lattice).

pub fn op_inverse(a: int) -> int {
    if a == 0 { return 0 }
    return _N6_J2 - a
}

// ── op_compose ─────────────────────────────────────────────────────────────
//
// COMPOSE(a, b): sequential application — apply INVERSE to b then COLLISION
// with a. Returns the resulting n6 lattice element. This is the anima
// "co-action" form used to chain two single-operand operators.

pub fn op_compose(a: int, b: int) -> int {
    let ib = op_inverse(b)
    return op_collision(a, ib)
}

// ── discover_relations ─────────────────────────────────────────────────────
//
// Iterate all (a, b) seed pairs and emit one Relation per operator. For
// COLLISION and COMPOSE we emit a relation per ordered pair; for INVERSE
// we emit one relation per unique seed. The result is a closed-form
// catalogue — callers can filter by `op` or `value` downstream.

pub fn discover_relations(seeds: array) -> array {
    let mut out = []
    let n = len(seeds)
    // INVERSE — one row per seed (skip duplicates by simple linear scan)
    let mut seen = []
    let mut i = 0
    while i < n {
        let a = to_int(seeds[i])
        let mut dup = false
        let mut s = 0
        while s < len(seen) {
            if to_int(seen[s]) == a { dup = true; s = len(seen) }
            s = s + 1
        }
        if !dup {
            seen.push(a)
            out.push(Relation { op: "INVERSE", lhs: a, rhs: 0, value: op_inverse(a) })
        }
        i = i + 1
    }
    // COLLISION + COMPOSE — every ordered pair
    i = 0
    while i < n {
        let a = to_int(seeds[i])
        let mut j = 0
        while j < n {
            let b = to_int(seeds[j])
            out.push(Relation { op: "COLLISION", lhs: a, rhs: b, value: op_collision(a, b) })
            out.push(Relation { op: "COMPOSE",   lhs: a, rhs: b, value: op_compose(a, b) })
            j = j + 1
        }
        i = i + 1
    }
    return out
}
