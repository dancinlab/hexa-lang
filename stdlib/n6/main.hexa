// HEXA Standard Library — n6/main (CLI shim)
//
// @version 0.1.0
// @capabilities [pure]
//
// absorbed from ~/core/anima/anima-tools/{discovery-engine,formula-miner}/main.hexa (MIT, dancinlab 2026-05-14)
//
// Standalone CLI dispatcher for the absorbed n6 surface. Two verbs:
//   discover   — print n6 arithmetic relations over a tiny default seed list
//   mine       — depth-3 formula miner against a sigma·phi target (= 24)
//
// Suggested registration: `hexa n6 discover` / `hexa n6 mine` (atlas verbs).

import "stdlib/n6/discover.hexa"
import "stdlib/n6/miner.hexa"

fn _print_relations() {
    let seeds = [2, 3, 4, 5, 6, 12, 24]
    let rels = discover_relations(seeds)
    println("n6/discover — " + to_string(len(rels)) + " relations over " + to_string(len(seeds)) + " seeds")
    let mut i = 0
    while i < len(rels) {
        let r = rels[i]
        if r.op == "INVERSE" {
            println("  " + r.op + "(" + to_string(r.lhs) + ") = " + to_string(r.value))
        } else {
            println("  " + r.op + "(" + to_string(r.lhs) + ", " + to_string(r.rhs) + ") = " + to_string(r.value))
        }
        i = i + 1
    }
}

fn _print_mine() {
    // Target: 24 = sigma(6) * phi(6) = J2(6)
    let targets = [24.0]
    let primitives = [2.0, 4.0, 5.0, 6.0, 12.0]   // phi, tau, sopfr, n, sigma
    let formulas = mine_formulas_depth3(targets, primitives)
    println("n6/mine — " + to_string(len(formulas)) + " formulas for target=24 (= J2(6))")
    let mut i = 0
    let cap = if len(formulas) < 20 { len(formulas) } else { 20 }
    while i < cap {
        let f = formulas[i]
        println("  fit=" + to_string(f.fitness) + " " + f.expr + " ~= " + to_string(f.target))
        i = i + 1
    }
}

fn main() {
    let argv = args()
    // Skip leading non-verb tokens (interpreter sometimes hands us the
    // script path or builder prefix). Look for the first `discover`/`mine`.
    let mut verb = ""
    let mut i = 0
    while i < len(argv) {
        let a = to_string(argv[i])
        if a == "discover" || a == "mine" { verb = a; i = len(argv) }
        i = i + 1
    }
    if verb == "" {
        println("usage: n6 (discover | mine)")
        return
    }
    if verb == "discover" {
        _print_relations()
    } else {
        _print_mine()
    }
}
