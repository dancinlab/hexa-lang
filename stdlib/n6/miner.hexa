// HEXA Standard Library — n6/miner
//
// @version 0.1.0
// @capabilities [pure]
//
// absorbed from ~/core/anima/anima-tools/formula-miner/main.hexa (MIT, dancinlab 2026-05-14)
//
// Formula miner — exhaustive depth-3 + small-GA search over expressions in
// caller-supplied float primitives. Each formula matches one of the
// caller-supplied target values within a relative-error tolerance.
//
// Diet vs the 248-LOC anima original:
//   - drop the anima target table (callers pass targets + primitives).
//   - drop hardcoded n=6 constants — the caller can pass them in `primitives`
//     to recover the n6 default behaviour.
//   - drop `*Expr` heap pointers — we represent expressions as strings, since
//     hexa stdlib's stage-1 surface is value-only.
//   - drop the 5000-pop / 500-gen scale — defaults are tuned for unit tests
//     (caller picks `iters`).
//   - keep depth-3 exhaustive enumeration over the 4 binary ops (+ - * /)
//     and the seed leaves; keep the GA mutation/selection loop.
//
// Public surface:
//   pub struct Formula { expr: string, fitness: float, target: float }
//   pub fn mine_formulas_depth3(targets: [float], primitives: [float]) -> [Formula]
//   pub fn mine_formulas_ga(targets: [float], primitives: [float], iters: int) -> [Formula]

let _MINER_TOL = 0.001       // relative-error tolerance for a "match"
let _MINER_EPS = 1.0e-15

// xorshift32 PRNG (deterministic across runs — independent of `random()`).
let mut _MINER_RNG = 0x1234ABCD

fn _miner_rng_next() -> int {
    let mut s = _MINER_RNG
    s = s ^ (s << 13)
    s = s ^ (s >> 7)
    s = s ^ (s << 17)
    _MINER_RNG = s
    if s < 0 { return 0 - s }
    return s
}

fn _miner_rng_seed(seed: int) {
    if seed == 0 {
        _MINER_RNG = 0x1234ABCD
    } else {
        _MINER_RNG = seed
    }
}

fn _miner_rng_u(max_val: int) -> int {
    if max_val <= 0 { return 0 }
    return _miner_rng_next() % max_val
}

fn _miner_rng_f() -> float {
    let v = _miner_rng_next() & 0xFFFFFF
    return to_float(v) / 16777216.0
}

pub struct Formula {
    expr: string,
    fitness: float,
    target: float
}

// ── helpers ────────────────────────────────────────────────────────────────

fn _op_apply(op: int, a: float, b: float) -> float {
    if op == 0 { return a + b }
    if op == 1 { return a - b }
    if op == 2 { return a * b }
    // op == 3 → division
    let bb = if b < 0.0 { 0.0 - b } else { b }
    if bb < _MINER_EPS { return 0.0 }
    return a / b
}

fn _op_sym(op: int) -> string {
    if op == 0 { return "+" }
    if op == 1 { return "-" }
    if op == 2 { return "*" }
    return "/"
}

fn _rel_err(got: float, want: float) -> float {
    let denom = if want < 0.0 { 0.0 - want } else { want }
    let scale = if denom < _MINER_EPS { _MINER_EPS } else { denom }
    let diff = got - want
    let ad = if diff < 0.0 { 0.0 - diff } else { diff }
    return ad / scale
}

// match a single value against the target list; return (best_target_idx,
// best_rel_err) as a parallel pair. -1 idx → no match within tolerance.
fn _best_match(val: float, targets: array) -> array {
    let n = len(targets)
    let mut best_i = 0 - 1
    let mut best_e = 1.0e18
    let mut i = 0
    while i < n {
        let t = to_float(targets[i])
        let e = _rel_err(val, t)
        if e < best_e {
            best_e = e
            best_i = i
        }
        i = i + 1
    }
    let out = []
    out.push(best_i)
    out.push(best_e)
    return out
}

fn _is_finite(x: float) -> bool {
    // crude finite check: NaN != NaN, inf > 1e300
    if x != x { return false }
    if x > 1.0e300 { return false }
    if x < -1.0e300 { return false }
    return true
}

// ── mine_formulas_depth3 — exhaustive depth-3 over the 4 binary ops ────────
//
// Enumerates expression trees up to depth 3 over caller-supplied primitives.
// For each tree we record the best target match (if within tolerance).

pub fn mine_formulas_depth3(targets: array, primitives: array) -> array {
    let mut out = []
    let np = len(primitives)
    if np == 0 { return out }
    // Depth 1: just the leaves
    let mut leaves_v = []   // values
    let mut leaves_s = []   // expr strings
    let mut i = 0
    while i < np {
        leaves_v.push(to_float(primitives[i]))
        leaves_s.push("p" + to_string(i))
        i = i + 1
    }
    // Depth 2: (leaf op leaf) for all op ∈ {0..3}, all (i,j)
    let mut d2_v = []
    let mut d2_s = []
    let mut a = 0
    while a < np {
        let mut b = 0
        while b < np {
            let mut op = 0
            while op < 4 {
                let v = _op_apply(op, leaves_v[a], leaves_v[b])
                if _is_finite(v) {
                    d2_v.push(v)
                    d2_s.push("(" + leaves_s[a] + _op_sym(op) + leaves_s[b] + ")")
                }
                op = op + 1
            }
            b = b + 1
        }
        a = a + 1
    }
    // Score depth-1 + depth-2 + depth-3
    // Depth 1 scoring
    i = 0
    while i < len(leaves_v) {
        let m = _best_match(leaves_v[i], targets)
        let bi = to_int(m[0])
        let be = to_float(m[1])
        if bi >= 0 {
            if be < _MINER_TOL {
                let t = to_float(targets[bi])
                let fit = 1.0 - be
                out.push(Formula { expr: leaves_s[i], fitness: fit, target: t })
            }
        }
        i = i + 1
    }
    i = 0
    while i < len(d2_v) {
        let m = _best_match(d2_v[i], targets)
        let bi = to_int(m[0])
        let be = to_float(m[1])
        if bi >= 0 {
            if be < _MINER_TOL {
                let t = to_float(targets[bi])
                let fit = 1.0 - be
                out.push(Formula { expr: d2_s[i], fitness: fit, target: t })
            }
        }
        i = i + 1
    }
    // Depth 3: (d2 op leaf). We skip leaf op d2 since binary ops are
    // structurally symmetric for our purposes (combinations not permutations
    // — keeps the search space bounded for stage-1).
    let mut x = 0
    while x < len(d2_v) {
        let mut y = 0
        while y < np {
            let mut op = 0
            while op < 4 {
                let v = _op_apply(op, d2_v[x], leaves_v[y])
                if _is_finite(v) {
                    let m = _best_match(v, targets)
                    let bi = to_int(m[0])
                    let be = to_float(m[1])
                    if bi >= 0 {
                        if be < _MINER_TOL {
                            let t = to_float(targets[bi])
                            let fit = 1.0 - be
                            let e = "(" + d2_s[x] + _op_sym(op) + leaves_s[y] + ")"
                            out.push(Formula { expr: e, fitness: fit, target: t })
                        }
                    }
                }
                op = op + 1
            }
            y = y + 1
        }
        x = x + 1
    }
    return out
}

// ── mine_formulas_ga — genetic-algorithm refinement ────────────────────────
//
// Stage-1 GA: random depth-≤3 trees, mutate / cross by re-rolling sub-leaves.
// Returns the best-fitness formula per target observed across `iters` rounds.

fn _random_expr(primitives: array, max_depth: int) -> array {
    // Returns [value, expr_string] as a parallel pair.
    let np = len(primitives)
    if max_depth <= 0 || _miner_rng_f() < 0.35 {
        let i = _miner_rng_u(np)
        let r = []
        r.push(to_float(primitives[i]))
        r.push("p" + to_string(i))
        return r
    }
    let op = _miner_rng_u(4)
    let l = _random_expr(primitives, max_depth - 1)
    let r = _random_expr(primitives, max_depth - 1)
    let v = _op_apply(op, to_float(l[0]), to_float(r[0]))
    let s = "(" + to_string(l[1]) + _op_sym(op) + to_string(r[1]) + ")"
    let out = []
    out.push(v)
    out.push(s)
    return out
}

pub fn mine_formulas_ga(targets: array, primitives: array, iters: int) -> array {
    _miner_rng_seed(0)
    let np = len(primitives)
    let nt = len(targets)
    if np == 0 || nt == 0 || iters <= 0 { return [] }
    // best[i] = Formula | null  for target i
    let mut best_fit = []
    let mut best_expr = []
    let mut best_val = []
    let mut t = 0
    while t < nt {
        best_fit.push(0.0 - 1.0e18)
        best_expr.push("")
        best_val.push(0.0)
        t = t + 1
    }
    let mut it = 0
    while it < iters {
        let cand = _random_expr(primitives, 3)
        let v = to_float(cand[0])
        if _is_finite(v) {
            let mut ti = 0
            while ti < nt {
                let tgt = to_float(targets[ti])
                let e = _rel_err(v, tgt)
                let fit = 1.0 - e
                if fit > to_float(best_fit[ti]) {
                    best_fit[ti] = fit
                    best_expr[ti] = to_string(cand[1])
                    best_val[ti] = v
                }
                ti = ti + 1
            }
        }
        it = it + 1
    }
    let mut out = []
    let mut i = 0
    while i < nt {
        let f = to_float(best_fit[i])
        if f > 0.0 {     // any match better than err=1.0
            out.push(Formula {
                expr: to_string(best_expr[i]),
                fitness: f,
                target: to_float(targets[i])
            })
        }
        i = i + 1
    }
    return out
}
