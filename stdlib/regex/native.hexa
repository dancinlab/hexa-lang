// HEXA Standard Library — regex/native
//
// @version 0.1.0
// @capabilities [pure]
//
// Pure-hexa regex engine — NO libc regcomp/regexec dependency. Closes
// RUNTIME.md Phase 2 item "regex: _regcomp/_regexec/_regfree (DFA in
// hexa)" at layer ① (reimplementable) per Policy DECIDED 2026-05-26.
//
// Engine: recursive-descent parse → AST → backtracking NFA-simulation
// matcher. Covers the ERE subset the stdlib/regex libc-bridge exposes:
//   literal · .  · * + ? · {n} {n,} {n,m} · [...] [^...] (ranges) ·
//   ^ $ anchors · | alternation · (...) groups · \\ escape
//
// Surface (libc-free twins of the bridge API):
//   pub fn regex_match_native(pat, s) -> bool       — match anywhere
//   pub fn regex_full_match_native(pat, s) -> bool  — anchored whole-string
//   pub fn regex_find_native(pat, s) -> [int]       — [start,end) of first match, [] none
//
// NOT a goal: capture groups, backreferences, lookaround, named classes
// (\\d \\w \\s) — those stay on the libc bridge until a follow-up. The
// point of this module is the zero-libc match path for the common ERE
// subset (the 80% that compiler/lint/config matching actually uses).
//
// AST node encoding ([int] flat tape, index-addressed):
//   each node = [kind, a, b, c] 4-int record.
//   kind: 0=CHAR(a=byte) 1=ANY 2=CLASS(a=class_id) 3=STAR(a=child)
//         4=PLUS(a=child) 5=OPT(a=child) 6=CONCAT(a=left,b=right)
//         7=ALT(a=left,b=right) 8=EMPTY 9=BOL 10=EOL
//         11=REPEAT(a=child,b=min,c=max; max=-1 means unbounded)
// Class table: parallel [[int]] where each entry is a flat
//   [neg, lo0,hi0, lo1,hi1, ...] range list.

// ── parser state (module-threaded via struct) ───────────────────────
struct ReParse {
    pat: string
    pos: int
    plen: int
    nodes: [[int]]      // AST node records
    classes: [[int]]    // class range tables
    ok: bool
}

@pure
fn _re_peek(p: ReParse) -> int {
    if p.pos >= p.plen { return -1 }
    return p.pat.byte_at(p.pos)
}

// Emit a node, return its index.
fn _re_emit(p: ReParse, rec: [int]) -> int {
    p.nodes.push(rec)
    return len(p.nodes) - 1
}

// Parse a bracket class [...] starting at p.pos (just past '['). Returns
// class table id; advances p.pos past ']'.
fn _re_parse_class(p: ReParse) -> int {
    let mut ranges: [int] = []
    let mut neg = 0
    if _re_peek(p) == 94 {  // '^'
        neg = 1
        p.pos = p.pos + 1
    }
    // A leading ']' is a literal.
    let mut first = true
    while p.pos < p.plen {
        let c = _re_peek(p)
        if c == 93 && !first {  // ']'
            p.pos = p.pos + 1
            ranges = _re_prepend(ranges, neg)
            p.classes.push(ranges)
            return len(p.classes) - 1
        }
        first = false
        // Handle range a-b.
        let lo = c
        p.pos = p.pos + 1
        if _re_peek(p) == 45 && (p.pos + 1) < p.plen && p.pat.byte_at(p.pos + 1) != 93 {
            // range
            p.pos = p.pos + 1   // skip '-'
            let hi = _re_peek(p)
            p.pos = p.pos + 1
            ranges.push(lo)
            ranges.push(hi)
        } else {
            ranges.push(lo)
            ranges.push(lo)
        }
    }
    // Unterminated class — fail.
    p.ok = false
    return -1
}

@pure
fn _re_prepend(ranges: [int], neg: int) -> [int] {
    let mut out: [int] = [neg]
    let mut i = 0
    while i < len(ranges) { out.push(ranges[i]); i = i + 1 }
    return out
}

// Recursive grammar (mutual recursion — hexa binds in a 2nd pass, no
// forward decls needed): alt → concat → repeat → atom → alt (via groups).

// alt := concat ('|' concat)*
fn _re_parse_alt(p: ReParse) -> int {
    let mut left = _re_parse_concat(p)
    while _re_peek(p) == 124 {  // '|'
        p.pos = p.pos + 1
        let right = _re_parse_concat(p)
        left = _re_emit(p, [7, left, right, 0])
    }
    return left
}

// concat := repeat*
fn _re_parse_concat(p: ReParse) -> int {
    let c = _re_peek(p)
    if c == -1 || c == 124 || c == 41 {  // end | '|' | ')'
        return _re_emit(p, [8, 0, 0, 0])   // EMPTY
    }
    let mut left = _re_parse_repeat(p)
    while true {
        let nc = _re_peek(p)
        if nc == -1 || nc == 124 || nc == 41 { break }
        let right = _re_parse_repeat(p)
        left = _re_emit(p, [6, left, right, 0])
    }
    return left
}

// repeat := atom ('*' | '+' | '?' | '{n,m}')?
fn _re_parse_repeat(p: ReParse) -> int {
    let atom = _re_parse_atom(p)
    let c = _re_peek(p)
    if c == 42 { p.pos = p.pos + 1; return _re_emit(p, [3, atom, 0, 0]) }  // '*'
    if c == 43 { p.pos = p.pos + 1; return _re_emit(p, [4, atom, 0, 0]) }  // '+'
    if c == 63 { p.pos = p.pos + 1; return _re_emit(p, [5, atom, 0, 0]) }  // '?'
    if c == 123 {  // '{'
        p.pos = p.pos + 1
        let mut lo = 0
        let mut have_lo = false
        while _re_peek(p) >= 48 && _re_peek(p) <= 57 {
            lo = lo * 10 + (_re_peek(p) - 48); p.pos = p.pos + 1; have_lo = true
        }
        let mut hi = lo
        if _re_peek(p) == 44 {  // ','
            p.pos = p.pos + 1
            if _re_peek(p) == 125 {  // '}' → {n,} unbounded
                hi = -1
            } else {
                hi = 0
                while _re_peek(p) >= 48 && _re_peek(p) <= 57 {
                    hi = hi * 10 + (_re_peek(p) - 48); p.pos = p.pos + 1
                }
            }
        }
        if _re_peek(p) == 125 { p.pos = p.pos + 1 }   // consume '}'
        if !have_lo { lo = 0 }
        return _re_emit(p, [11, atom, lo, hi])
    }
    return atom
}

// atom := '(' alt ')' | '[' class ']' | '.' | '^' | '$' | '\\' c | char
fn _re_parse_atom(p: ReParse) -> int {
    let c = _re_peek(p)
    if c == 40 {  // '('
        p.pos = p.pos + 1
        let inner = _re_parse_alt(p)
        if _re_peek(p) == 41 { p.pos = p.pos + 1 }  // ')'
        return inner
    }
    if c == 91 {  // '['
        p.pos = p.pos + 1
        let cid = _re_parse_class(p)
        return _re_emit(p, [2, cid, 0, 0])
    }
    if c == 46 { p.pos = p.pos + 1; return _re_emit(p, [1, 0, 0, 0]) }   // '.'
    if c == 94 { p.pos = p.pos + 1; return _re_emit(p, [9, 0, 0, 0]) }   // '^'
    if c == 36 { p.pos = p.pos + 1; return _re_emit(p, [10, 0, 0, 0]) }  // '$'
    if c == 92 {  // '\\' escape
        p.pos = p.pos + 1
        let e = _re_peek(p)
        p.pos = p.pos + 1
        return _re_emit(p, [0, e, 0, 0])
    }
    // literal char
    p.pos = p.pos + 1
    return _re_emit(p, [0, c, 0, 0])
}

@pure
fn _re_class_match(classes: [[int]], cid: int, ch: int) -> bool {
    let tbl = classes[cid]
    let neg = tbl[0]
    let mut i = 1
    let mut hit = false
    while i + 1 < len(tbl) {
        if ch >= tbl[i] && ch <= tbl[i+1] { hit = true }
        i = i + 2
    }
    if neg == 1 { return !hit }
    return hit
}

// Continuation-stack backtracking matcher (Russ Cox style). `conts` is a
// stack of pending node indices to match IN ORDER after the current focus.
// This makes greedy STAR/PLUS correctly backtrack: `a.*c` against "axyzc"
// gives back chars from `.*` so the trailing `c` can match. A 4-int
// "repeat continuation" marker (kind 12) is synthesized on the conts stack
// to thread {min,max} counters without mutating the AST.
//
// Returns end index on success, -1 on failure.

@pure
fn _re_cons(head: int, tail: [int]) -> [int] {
    let mut out: [int] = [head]
    let mut i = 0
    while i < len(tail) { out.push(tail[i]); i = i + 1 }
    return out
}

@pure
fn _re_tail(lst: [int]) -> [int] {
    let mut out: [int] = []
    let mut i = 1
    while i < len(lst) { out.push(lst[i]); i = i + 1 }
    return out
}

// Match the continuation stack `conts` against `s` at index `si`.
fn _re_run(nodes: [[int]], classes: [[int]], conts: [int], s: string, si: int, n: int) -> int {
    if len(conts) == 0 { return si }   // accept: nothing left to match
    let ni = conts[0]
    let rest = _re_tail(conts)
    let rec = nodes[ni]
    let kind = rec[0]
    if kind == 8 { return _re_run(nodes, classes, rest, s, si, n) }   // EMPTY
    if kind == 9 {                                                    // BOL
        if si == 0 { return _re_run(nodes, classes, rest, s, si, n) }
        return -1
    }
    if kind == 10 {                                                  // EOL
        if si == n { return _re_run(nodes, classes, rest, s, si, n) }
        return -1
    }
    if kind == 0 {                                                  // CHAR
        if si < n && s.byte_at(si) == rec[1] { return _re_run(nodes, classes, rest, s, si + 1, n) }
        return -1
    }
    if kind == 1 {                                                 // ANY
        if si < n { return _re_run(nodes, classes, rest, s, si + 1, n) }
        return -1
    }
    if kind == 2 {                                                // CLASS
        if si < n && _re_class_match(classes, rec[1], s.byte_at(si)) {
            return _re_run(nodes, classes, rest, s, si + 1, n)
        }
        return -1
    }
    if kind == 6 {                                               // CONCAT a·b
        return _re_run(nodes, classes, _re_cons(rec[1], _re_cons(rec[2], rest)), s, si, n)
    }
    if kind == 7 {                                              // ALT a|b
        let r1 = _re_run(nodes, classes, _re_cons(rec[1], rest), s, si, n)
        if r1 >= 0 { return r1 }
        return _re_run(nodes, classes, _re_cons(rec[2], rest), s, si, n)
    }
    if kind == 5 {                                             // OPT (greedy)
        let r = _re_run(nodes, classes, _re_cons(rec[1], rest), s, si, n)
        if r >= 0 { return r }
        return _re_run(nodes, classes, rest, s, si, n)
    }
    if kind == 3 {                                            // STAR (greedy)
        // Try one-more-rep (child then STAR again) FIRST, else skip.
        let more = _re_run(nodes, classes, _re_cons(rec[1], _re_cons(ni, rest)), s, si, n)
        if more >= 0 && more > si { return more }
        return _re_run(nodes, classes, rest, s, si, n)
    }
    if kind == 4 {                                           // PLUS (≥1 greedy)
        // One mandatory child, then STAR-equivalent (re-enter as STAR node copy
        // is unavailable; emulate by child then a STAR-of-same-child via marker).
        // We push child + a STAR marker (kind 3 with same child) onto conts.
        // To avoid mutating AST, reuse: child, then (this PLUS reinterpreted as
        // STAR by toggling — represent via a synthesized STAR view: kind 3
        // shares rec[1]). We emit a transient STAR node id lazily.
        return _re_run(nodes, classes, _re_cons(rec[1], _re_cons(_re_star_view(nodes, rec[1]), rest)), s, si, n)
    }
    if kind == 11 {                                          // REPEAT {min,max}
        // Encode remaining count on a kind-12 marker: [12, child, remaining, hi].
        return _re_run_repeat(nodes, classes, rec[1], rec[2], rec[3], rest, s, si, n)
    }
    if kind == 12 {                                          // REPEAT-CONT marker
        return _re_run_repeat(nodes, classes, rec[1], rec[2], rec[3], rest, s, si, n)
    }
    return -1
}

// Lazily materialize a STAR node wrapping `child`, return its index.
// (Append-only; safe because matching never re-parses.)
fn _re_star_view(nodes: [[int]], child: int) -> int {
    nodes.push([3, child, 0, 0])
    return len(nodes) - 1
}

// {min,max} repeat with continuation. `lo`/`hi` are the REMAINING bounds.
fn _re_run_repeat(nodes: [[int]], classes: [[int]], child: int, lo: int, hi: int,
                  rest: [int], s: string, si: int, n: int) -> int {
    // If we still MUST match (lo > 0): match child then recurse with lo-1.
    if lo > 0 {
        let marker = _re_repeat_marker(nodes, child, lo - 1, if hi < 0 { -1 } else { hi - 1 })
        return _re_run(nodes, classes, _re_cons(child, _re_cons(marker, rest)), s, si, n)
    }
    // lo == 0: optional more (if hi != 0), greedy.
    if hi != 0 {
        let nhi = if hi < 0 { -1 } else { hi - 1 }
        let marker = _re_repeat_marker(nodes, child, 0, nhi)
        let more = _re_run(nodes, classes, _re_cons(child, _re_cons(marker, rest)), s, si, n)
        if more >= 0 && more > si { return more }
    }
    return _re_run(nodes, classes, rest, s, si, n)
}

fn _re_repeat_marker(nodes: [[int]], child: int, lo: int, hi: int) -> int {
    nodes.push([12, child, lo, hi])
    return len(nodes) - 1
}

// Compile pattern into (nodes, classes, root). Returns root index or -1.
fn _re_compile(pat: string) -> ReParse {
    let p = ReParse {
        pat: pat,
        pos: 0,
        plen: byte_len(pat),
        nodes: [],
        classes: [],
        ok: true,
    }
    let root = _re_parse_alt(p)
    // Stash root as the last-emitted convention: append a CONCAT(root, EMPTY)
    // sentinel so callers read len-1 as root.
    let _ = _re_emit(p, [6, root, _re_emit(p, [8, 0, 0, 0]), 0])
    return p
}

@pure
pub fn regex_match_native(pat: string, s: string) -> bool {
    let p = _re_compile(pat)
    if !p.ok { return false }
    let root = len(p.nodes) - 1
    let n = byte_len(s)
    // Try every start offset (match-anywhere); ^ inside the AST self-anchors.
    let mut start = 0
    while start <= n {
        let r = _re_run(p.nodes, p.classes, [root], s, start, n)
        if r >= 0 { return true }
        start = start + 1
    }
    return false
}

@pure
pub fn regex_full_match_native(pat: string, s: string) -> bool {
    let p = _re_compile(pat)
    if !p.ok { return false }
    let root = len(p.nodes) - 1
    let n = byte_len(s)
    // Append an EOL ($) continuation so ONLY an end-anchored match accepts;
    // this lets the backtracker explore every path to the string end (not
    // just the first greedy end) — correct full-match semantics.
    let eol = len(p.nodes)
    p.nodes.push([10, 0, 0, 0])
    let r = _re_run(p.nodes, p.classes, [root, eol], s, 0, n)
    return r >= 0
}

@pure
pub fn regex_find_native(pat: string, s: string) -> [int] {
    let p = _re_compile(pat)
    if !p.ok { return [] }
    let root = len(p.nodes) - 1
    let n = byte_len(s)
    let mut start = 0
    while start <= n {
        let r = _re_run(p.nodes, p.classes, [root], s, start, n)
        if r >= 0 { return [start, r] }
        start = start + 1
    }
    return []
}
