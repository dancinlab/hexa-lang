// HEXA Standard Library — regex/native self-test
// @ci_gate
//
// Verifies the pure-hexa (zero-libc) regex engine in stdlib/regex/native.hexa.

use "stdlib/regex/native"

let mut pass_count = 0
let mut total_count = 0

fn check(name: string, got: bool, want: bool) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn main() {
    check("lit-hit",     regex_match_native("abc", "xxabcyy"), true)
    check("lit-miss",    regex_match_native("abc", "xxabyy"), false)
    check("dotstar",     regex_full_match_native("a.*c", "axyzc"), true)
    check("star-empty",  regex_full_match_native("a.*", "a"), true)
    check("plus",        regex_full_match_native("ab+c", "abbbc"), true)
    check("plus-zero",   regex_full_match_native("ab+c", "ac"), false)
    check("class",       regex_full_match_native("[0-9]+", "12345"), true)
    check("class-neg",   regex_match_native("[^0-9]", "abc"), true)
    check("class-range", regex_full_match_native("[a-z]+", "hello"), true)
    check("class-mixed", regex_full_match_native("[A-Za-z0-9_]+", "Var_99"), true)
    check("alt",         regex_full_match_native("cat|dog", "dog"), true)
    check("alt-miss",    regex_full_match_native("cat|dog", "cow"), false)
    check("bol",         regex_match_native("^hi", "hi there"), true)
    check("bol-miss",    regex_match_native("^hi", "say hi"), false)
    check("eol",         regex_match_native("end$", "the end"), true)
    check("opt",         regex_full_match_native("colou?r", "color"), true)
    check("opt2",        regex_full_match_native("colou?r", "colour"), true)
    check("repeat-exact",regex_full_match_native("a{3}", "aaa"), true)
    check("repeat-range",regex_full_match_native("a{2,3}", "aa"), true)
    check("repeat-over",  regex_full_match_native("a{2,3}", "a"), false)
    check("repeat-unbounded", regex_full_match_native("ab{2,}", "abbbb"), true)
    check("group",       regex_full_match_native("(ab)+", "ababab"), true)
    check("dotany",      regex_full_match_native("a.c", "axc"), true)

    let f = regex_find_native("[0-9]+", "abc123def")
    total_count = total_count + 1
    if len(f) == 2 && f[0] == 3 && f[1] == 6 { pass_count = pass_count + 1 }
    else { println("FAIL find") }

    println("regex/native self-test: " + to_string(pass_count) + "/" + to_string(total_count))
    if pass_count == total_count { println("PASS") } else { println("FAILED") }
}
