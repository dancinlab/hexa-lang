// HEXA Standard Library — phi
//
// @version 0.1.0
// @capabilities [pure]
//
// absorbed from ~/core/anima/anima-core/phi_engine.hexa (MIT, dancinlab 2026-05-14)
//
// IIT Φ proxy + spectral Φ + n6 scaling law.
//
// Diet vs the 433-LOC anima original:
//   - drop JSON ψ-constants loader (`_psi_load`) — callers pass alpha as a
//     parameter. After BG-1 the canonical values will live in
//     compiler/atlas/anima_psi.gen.hexa.
//   - drop substrate / EEG / audio adapter hooks.
//   - drop the demo `main()` (CLI verb lives in stdlib/n6/main.hexa).
//   - keep only the math: phi_iit, phi_spectral, phi_scaling, plus a couple of
//     small helpers (zeros, vec_mean, frustration) that the math depends on.
//
// n6 bridge (informational, unchanged from anima):
//   optimal_factions   = sigma(6) = 12
//   phi_scaling_exp    = (sigma - sopfr) / sigma = 7/12
//   critical_frustration = n / (sigma * sopfr) = 0.1
//   bottleneck_ratio   = n / sigma = 0.5
//
// Public surface:
//   pub fn phi_iit(adjacency: [[float]], state: [int]) -> float
//   pub fn phi_spectral(adjacency: [[float]]) -> float
//   pub fn phi_scaling(n: int, alpha: float) -> float

let _PHI_EPS = 0.00001
let _PHI_SCALING_EXP = 0.5833333333333334   // 7/12 = (sigma-sopfr)/sigma

// ── vector helpers (private) ───────────────────────────────────────────────

fn _phi_zeros(n: int) -> array {
    let mut v = []
    let mut i = 0
    while i < n {
        v.push(0.0)
        i = i + 1
    }
    return v
}

// ── phi_scaling — n6 scaling law (closed-form) ─────────────────────────────
//
// Anima's scaling law: phi(N) ≈ alpha · N^((sigma-sopfr)/sigma) = alpha · N^(7/12).
// `alpha` is the anima Ψ-coupling constant — caller-supplied. The anima default
// is 0.014 (≈ ln(2)/2^5.5); the stdlib does NOT hardcode it.

pub fn phi_scaling(n: int, alpha: float) -> float {
    if n < 1 { return 0.0 }
    return alpha * pow(to_float(n), _PHI_SCALING_EXP)
}

// ── phi_iit — IIT Φ proxy (global-var minus best-bipartition var) ──────────
//
// Adjacency `adjacency` is an N x N float matrix (weighted; thresholded
// internally). `state` is the N-vector of node activations (0 or 1 typically,
// but any int is accepted; cast to float). We compute:
//
//   activations[i] = sum_j adjacency[i][j] * state[j]
//   global_var     = mean( (activations[i] - mean(activations))^2 )
//   bipartition_var (over the cut at i = N/2) = analogous on each half
//   Φ ≈ max(global_var - (var_left + var_right) / N, 0)
//
// This is the same proxy the anima phi_proxy() returns; we treat each
// activation vector as a scalar (dim=1) for the stdlib case. Real IIT 4.0
// requires full bipartition search — see stdlib/iit_ei.hexa for the
// effective-information lower bound.

pub fn phi_iit(adjacency: array, state: array) -> float {
    let n = len(adjacency)
    if n < 4 { return 0.0 }
    // activations[i] = sum_j adj[i][j] * state[j]
    let mut act = _phi_zeros(n)
    let mut i = 0
    while i < n {
        let mut a = 0.0
        let mut j = 0
        while j < n {
            a = a + adjacency[i][j] * to_float(state[j])
            j = j + 1
        }
        act[i] = a
        i = i + 1
    }
    // global mean & var
    let mut g_mean = 0.0
    i = 0
    while i < n {
        g_mean = g_mean + act[i] / to_float(n)
        i = i + 1
    }
    let mut g_var = 0.0
    i = 0
    while i < n {
        let d = act[i] - g_mean
        g_var = g_var + d * d / to_float(n)
        i = i + 1
    }
    // bipartition at n/2
    let half = n / 2
    let n2 = n - half
    let mut m1 = 0.0
    i = 0
    while i < half { m1 = m1 + act[i] / to_float(half); i = i + 1 }
    let mut v1 = 0.0
    i = 0
    while i < half {
        let d = act[i] - m1
        v1 = v1 + d * d
        i = i + 1
    }
    let mut m2 = 0.0
    i = half
    while i < n { m2 = m2 + act[i] / to_float(n2); i = i + 1 }
    let mut v2 = 0.0
    i = half
    while i < n {
        let d = act[i] - m2
        v2 = v2 + d * d
        i = i + 1
    }
    let phi = g_var - (v1 + v2) / to_float(n)
    if phi < 0.0 { return 0.0 }
    return phi
}

// ── phi_spectral — spectral Φ via dominant-eigenvalue / Frobenius ratio ────
//
// Spectral proxy: ratio of the squared dominant eigenvalue to the Frobenius
// norm squared of the adjacency matrix. Power-iteration estimate.
//   Φ_spectral ≈ λ_1^2 / ||A||_F^2
// Bounded in [0, 1]: 1.0 means the graph is rank-1 (fully integrated by the
// dominant mode); near-0 means many comparable modes / no integration.

pub fn phi_spectral(adjacency: array) -> float {
    let n = len(adjacency)
    if n < 2 { return 0.0 }
    // Frobenius norm squared
    let mut frob2 = 0.0
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            let a = adjacency[i][j]
            frob2 = frob2 + a * a
            j = j + 1
        }
        i = i + 1
    }
    if frob2 < _PHI_EPS { return 0.0 }
    // Power iteration for dominant eigenvalue
    let mut v = _phi_zeros(n)
    i = 0
    while i < n { v[i] = 1.0 / sqrt(to_float(n)); i = i + 1 }
    let mut lambda = 0.0
    let mut iter = 0
    while iter < 50 {
        // w = A v
        let mut w = _phi_zeros(n)
        i = 0
        while i < n {
            let mut s = 0.0
            let mut j = 0
            while j < n {
                s = s + adjacency[i][j] * v[j]
                j = j + 1
            }
            w[i] = s
            i = i + 1
        }
        // norm
        let mut nm = 0.0
        i = 0
        while i < n { nm = nm + w[i] * w[i]; i = i + 1 }
        nm = sqrt(nm)
        if nm < _PHI_EPS { return 0.0 }
        // normalize → v
        i = 0
        while i < n { v[i] = w[i] / nm; i = i + 1 }
        lambda = nm
        iter = iter + 1
    }
    return (lambda * lambda) / frob2
}
