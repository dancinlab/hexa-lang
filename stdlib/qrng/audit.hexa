#!hexa strict
// stdlib/qrng/audit.hexa — NIST SP 800-22 tier-1+ statistical audit
//
// @version 1.0.0
// @capabilities [randomness, statistical_audit, math, shell]
// @stability stable
// @since 2026-05-16
//
// 5 NIST SP 800-22 Rev. 1a tests:
//   §2.1 monobit (frequency)
//   §2.2 frequency-block (M=128)
//   §2.3 runs (gated by monobit pre-check)
//   §2.4 longest-run-of-1s (M=128 K=5 N=49)
//   §2.6 DFT spectral (n ≤ 1024 bits, O(n²) cap)
//
// Single-stage integrated API:
//   qrng_audited_bytes(n_bytes, audit_level, vendor) -> AuditedQrngBytes
//     pulls entropy from backend + runs audit, returns bytes_hex + audit_pass
//     + per-test verdicts + tier provenance in one call.
//
// Tier model: tier1+ = monobit + frequency-block + runs + longest-run + DFT at
// alpha=0.01. PASS = ALL 5 tests pass. SKIP allowed for small n. delivered
// label downgrades to "tier1-partial" when some tests are skipped.
//
// Math primitives (pure-hexa, no extern): _sqrt_f, _ln_f, _exp_f, _cos_f,
// _sin_f, _erfc_f (Abramowitz-Stegun 7.1.26), _gammaln_f (Lanczos),
// _igamc_f (series + continued fraction). Validated to ~1e-7 absolute on the
// alpha=0.01 test region.
//
// DFT-spectral uses rotation recurrence (no per-bin trig); drift over 1024
// steps < 1e-9. Larger DFT windows (16k+) require Cooley-Tukey FFT — deferred.
//
// Reference: NIST SP 800-22 Rev. 1a
//   https://nvlpubs.nist.gov/nistpubs/Legacy/SP/nistspecialpublication800-22r1a.pdf
//
// Source: ~/core/qrng/audit/module/audit.hexa @ v1.0.0 (RFC 044).

// shared types (kept local — struct-shape-compatible with source.hexa convention)

struct AuditTestResult {
    name:    str,    // "monobit"|"frequency_block"|"runs"|"longest_run"|"dft_spectral"
    p_value: float,
    passed:  int,    // 0/1 (1 if p >= alpha and test ran)
    skipped: int,    // 0/1 (1 if input too small for test)
    note:    str
}

struct AuditedQrngBytes {
    ok:                       int,
    n_bytes:                  int,
    bytes_hex:                str,
    audit_pass:               int,                // 0/1; 1 iff every non-skipped test passed
    tests_run:                [AuditTestResult],
    audit_level_requested:    str,                // "tier1+"|"none"
    audit_level_delivered:    str,                // may downgrade to "tier1-partial"
    tier:                     str,                // backend tier label (T0..T3)
    vendor:                   str,                // backend identifier
    alpha:                    float,
    message:                  str
}

// ─── math primitives ─────────────────────────────────────────

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _sqrt_f(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = if x > 1.0 { x / 2.0 } else { 1.0 }
    let mut i = 0
    while i < 60 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn _ln_f(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1.0e9 }
    let mut k = 0
    let mut v = x
    while v >= 2.0 { v = v / 2.0  k = k + 1 }
    while v < 1.0 { v = v * 2.0  k = k - 1 }
    let y = (v - 1.0) / (v + 1.0)
    let y2 = y * y
    let mut s = 0.0
    let mut t = y
    let mut n = 0
    while n < 30 {
        s = s + t / (2.0 * to_float(n) + 1.0)
        t = t * y2
        n = n + 1
    }
    let ln2 = 0.6931471805599453
    return 2.0 * s + to_float(k) * ln2
}

fn _exp_f(x: float) -> float {
    if x < -700.0 { return 0.0 }
    let mut k = 0
    let mut v = x
    while v > 1.0 { v = v - 1.0  k = k + 1 }
    while v < -1.0 { v = v + 1.0  k = k - 1 }
    let mut term = 1.0
    let mut sum = 1.0
    let mut n = 1
    while n < 50 {
        term = term * v / to_float(n)
        sum = sum + term
        n = n + 1
    }
    let e = 2.7182818284590452
    let mut r = sum
    if k > 0 {
        let mut i = 0
        while i < k { r = r * e  i = i + 1 }
    }
    if k < 0 {
        let mut i = 0
        while i < (0 - k) { r = r / e  i = i + 1 }
    }
    return r
}

fn _cos_f(x: float) -> float {
    let two_pi = 6.283185307179586
    let pi = 3.141592653589793
    let mut t = x
    while t > pi { t = t - two_pi }
    while t < (0.0 - pi) { t = t + two_pi }
    let t2 = t * t
    let mut term = 1.0
    let mut sum = 1.0
    let mut n = 1
    while n < 30 {
        let denom = to_float(2 * n) * to_float(2 * n - 1)
        term = term * (0.0 - t2) / denom
        sum = sum + term
        n = n + 1
    }
    return sum
}

fn _sin_f(x: float) -> float {
    let two_pi = 6.283185307179586
    let pi = 3.141592653589793
    let mut t = x
    while t > pi { t = t - two_pi }
    while t < (0.0 - pi) { t = t + two_pi }
    let t2 = t * t
    let mut term = t
    let mut sum = t
    let mut n = 1
    while n < 30 {
        let denom = to_float(2 * n) * to_float(2 * n + 1)
        term = term * (0.0 - t2) / denom
        sum = sum + term
        n = n + 1
    }
    return sum
}

// erfc(x) via Abramowitz-Stegun 7.1.26 with exp(-x^2) via _exp_f.
// Accurate to ~1e-7 across alpha=0.01 region (|x| up to ~3).
fn _erfc_f(x: float) -> float {
    let absx = _abs_f(x)
    let t = 1.0 / (1.0 + 0.3275911 * absx)
    let a1 = 0.254829592
    let a2 = 0.0 - 0.284496736
    let a3 = 1.421413741
    let a4 = 0.0 - 1.453152027
    let a5 = 1.061405429
    let poly = ((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t
    let exp_minus = _exp_f(0.0 - absx * absx)
    let val = poly * exp_minus
    if x >= 0.0 { return val }
    return 2.0 - val
}

// Lanczos lgamma — sufficient for chi-square at NIST tier-1 sample sizes.
fn _gammaln_f(x: float) -> float {
    let g = 7.0
    let c0 = 0.99999999999980993
    let c1 = 676.5203681218851
    let c2 = 0.0 - 1259.1392167224028
    let c3 = 771.32342877765313
    let c4 = 0.0 - 176.61502916214059
    let c5 = 12.507343278686905
    let c6 = 0.0 - 0.13857109526572012
    let c7 = 9.9843695780195716e-6
    let c8 = 1.5056327351493116e-7
    let z = x - 1.0
    let mut a = c0
    a = a + c1 / (z + 1.0)
    a = a + c2 / (z + 2.0)
    a = a + c3 / (z + 3.0)
    a = a + c4 / (z + 4.0)
    a = a + c5 / (z + 5.0)
    a = a + c6 / (z + 6.0)
    a = a + c7 / (z + 7.0)
    a = a + c8 / (z + 8.0)
    let t = z + g + 0.5
    let half_log_2pi = 0.91893853320467274
    return half_log_2pi + (z + 0.5) * _ln_f(t) - t + _ln_f(a)
}

// Regularized upper incomplete gamma Q(a, x). Used for chi-square p-values.
fn _igamc_f(a: float, x: float) -> float {
    if x < 0.0 { return 1.0 }
    if a <= 0.0 { return 1.0 }
    if x == 0.0 { return 1.0 }
    if x < a + 1.0 {
        let mut ap = a
        let mut sum = 1.0 / a
        let mut term = sum
        let mut n = 0
        while n < 300 {
            ap = ap + 1.0
            term = term * x / ap
            sum = sum + term
            if _abs_f(term) < _abs_f(sum) * 1.0e-13 { n = 9999  break }
            n = n + 1
        }
        let lnpref = (0.0 - x) + a * _ln_f(x) - _gammaln_f(a)
        let pref = _exp_f(lnpref)
        let p = sum * pref
        let q = 1.0 - p
        if q < 0.0 { return 0.0 }
        if q > 1.0 { return 1.0 }
        return q
    }
    let tiny = 1.0e-30
    let mut b = x + 1.0 - a
    let mut c = 1.0 / tiny
    let mut d = 1.0 / b
    let mut h = d
    let mut i = 1
    while i < 300 {
        let an = 0.0 - to_float(i) * (to_float(i) - a)
        b = b + 2.0
        d = an * d + b
        if _abs_f(d) < tiny { d = tiny }
        c = b + an / c
        if _abs_f(c) < tiny { c = tiny }
        d = 1.0 / d
        let del = d * c
        h = h * del
        if _abs_f(del - 1.0) < 1.0e-13 { i = 9999  break }
        i = i + 1
    }
    let lnpref = (0.0 - x) + a * _ln_f(x) - _gammaln_f(a)
    let pref = _exp_f(lnpref)
    let q = pref * h
    if q < 0.0 { return 0.0 }
    if q > 1.0 { return 1.0 }
    return q
}

// ─── bytes <-> bits helpers ──────────────────────────────────

fn _bytes_to_bits(bytes_: [int]) -> [int] {
    let mut bits = []
    let mut i = 0
    while i < len(bytes_) {
        let b = bytes_[i]
        let mut k = 7
        while k >= 0 {
            let pow_2 = if k == 0 { 1 } else if k == 1 { 2 } else if k == 2 { 4 } else if k == 3 { 8 } else if k == 4 { 16 } else if k == 5 { 32 } else if k == 6 { 64 } else { 128 }
            let bit = if (b / pow_2) % 2 == 1 { 1 } else { 0 }
            bits = bits.push(bit)
            k = k - 1
        }
        i = i + 1
    }
    return bits
}

fn _hex_byte(b: int) -> str {
    let chars = "0123456789abcdef"
    let hi = b / 16
    let lo = b % 16
    return chars.substring(hi, hi + 1) + chars.substring(lo, lo + 1)
}

fn _bytes_to_hex(bytes_: [int]) -> str {
    let mut hex = ""
    let mut i = 0
    while i < len(bytes_) {
        hex = hex + _hex_byte(bytes_[i])
        i = i + 1
    }
    return hex
}

// ─── NIST SP 800-22 §2.1 — monobit (frequency) ───────────────

fn _test_monobit(bits: [int]) -> AuditTestResult {
    let n = len(bits)
    if n < 100 {
        return AuditTestResult { name: "monobit", p_value: 0.0, passed: 0, skipped: 1, note: "n<100 bits — skipped per SP 800-22" }
    }
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + (2 * bits[i] - 1)
        i = i + 1
    }
    let s_obs = _abs_f(to_float(s)) / _sqrt_f(to_float(n))
    let p = _erfc_f(s_obs / _sqrt_f(2.0))
    let passed = if p >= 0.01 { 1 } else { 0 }
    return AuditTestResult { name: "monobit", p_value: p, passed: passed, skipped: 0, note: "ones=" + str((n + s) / 2) + " zeros=" + str((n - s) / 2) }
}

// ─── NIST SP 800-22 §2.2 — frequency within block ────────────

fn _test_frequency_block(bits: [int]) -> AuditTestResult {
    let n = len(bits)
    let M = 128
    if n < M * 20 {
        return AuditTestResult { name: "frequency_block", p_value: 0.0, passed: 0, skipped: 1, note: "n<2560 bits — skipped (need M=128, N>=20)" }
    }
    let N = n / M
    let mut chi_sq = 0.0
    let mut bi = 0
    while bi < N {
        let mut ones = 0
        let mut j = 0
        while j < M {
            ones = ones + bits[bi * M + j]
            j = j + 1
        }
        let pi = to_float(ones) / to_float(M)
        let dev = pi - 0.5
        chi_sq = chi_sq + dev * dev
        bi = bi + 1
    }
    chi_sq = chi_sq * 4.0 * to_float(M)
    let p = _igamc_f(to_float(N) / 2.0, chi_sq / 2.0)
    let passed = if p >= 0.01 { 1 } else { 0 }
    return AuditTestResult { name: "frequency_block", p_value: p, passed: passed, skipped: 0, note: "M=128 N=" + str(N) + " chi_sq=" + str(chi_sq) }
}

// ─── NIST SP 800-22 §2.3 — runs ──────────────────────────────

fn _test_runs(bits: [int]) -> AuditTestResult {
    let n = len(bits)
    if n < 100 {
        return AuditTestResult { name: "runs", p_value: 0.0, passed: 0, skipped: 1, note: "n<100 bits — skipped" }
    }
    let mut ones = 0
    let mut i = 0
    while i < n {
        ones = ones + bits[i]
        i = i + 1
    }
    let pi = to_float(ones) / to_float(n)
    let tau = 2.0 / _sqrt_f(to_float(n))
    if _abs_f(pi - 0.5) >= tau {
        return AuditTestResult { name: "runs", p_value: 0.0, passed: 0, skipped: 0, note: "monobit pre-test fail (|pi-0.5|>=tau); runs not run" }
    }
    let mut V = 1
    let mut k = 1
    while k < n {
        if bits[k] != bits[k - 1] { V = V + 1 }
        k = k + 1
    }
    let num = _abs_f(to_float(V) - 2.0 * to_float(n) * pi * (1.0 - pi))
    let den = 2.0 * _sqrt_f(2.0 * to_float(n)) * pi * (1.0 - pi)
    let p = _erfc_f(num / den)
    let passed = if p >= 0.01 { 1 } else { 0 }
    return AuditTestResult { name: "runs", p_value: p, passed: passed, skipped: 0, note: "V=" + str(V) + " pi=" + str(pi) }
}

// ─── NIST SP 800-22 §2.4 — longest run of ones ───────────────
// (M=128, K=5, N=49 per recommendation for 6272 <= n < 750000)

fn _test_longest_run(bits: [int]) -> AuditTestResult {
    let n = len(bits)
    if n < 6272 {
        return AuditTestResult { name: "longest_run", p_value: 0.0, passed: 0, skipped: 1, note: "n<6272 bits — skipped (M=128 N=49 floor)" }
    }
    let M = 128
    let N = 49
    let mut v = [0, 0, 0, 0, 0, 0]
    let mut bi = 0
    while bi < N {
        let mut max_run = 0
        let mut cur = 0
        let mut j = 0
        while j < M {
            if bits[bi * M + j] == 1 {
                cur = cur + 1
                if cur > max_run { max_run = cur }
            } else {
                cur = 0
            }
            j = j + 1
        }
        let cls = if max_run <= 4 { 0 } else if max_run == 5 { 1 } else if max_run == 6 { 2 } else if max_run == 7 { 3 } else if max_run == 8 { 4 } else { 5 }
        let mut new_v = []
        let mut q = 0
        while q < 6 {
            if q == cls { new_v = new_v.push(v[q] + 1) } else { new_v = new_v.push(v[q]) }
            q = q + 1
        }
        v = new_v
        bi = bi + 1
    }
    let pi0 = 0.1174
    let pi1 = 0.2430
    let pi2 = 0.2493
    let pi3 = 0.1752
    let pi4 = 0.1027
    let pi5 = 0.1124
    let pis = [pi0, pi1, pi2, pi3, pi4, pi5]
    let mut chi_sq = 0.0
    let mut q = 0
    while q < 6 {
        let exp_v = to_float(N) * pis[q]
        let dev = to_float(v[q]) - exp_v
        chi_sq = chi_sq + (dev * dev) / exp_v
        q = q + 1
    }
    let K = 5
    let p = _igamc_f(to_float(K) / 2.0, chi_sq / 2.0)
    let passed = if p >= 0.01 { 1 } else { 0 }
    return AuditTestResult { name: "longest_run", p_value: p, passed: passed, skipped: 0, note: "M=128 N=" + str(N) + " chi_sq=" + str(chi_sq) }
}

// ─── NIST SP 800-22 §2.6 — DFT spectral ──────────────────────

fn _test_dft_spectral(bits: [int]) -> AuditTestResult {
    let n = len(bits)
    if n < 1000 {
        return AuditTestResult { name: "dft_spectral", p_value: 0.0, passed: 0, skipped: 1, note: "n<1000 bits — skipped" }
    }
    // Cap n at 1024 bits (O(n²) DFT bound). NIST §2.6 minimum = 1000 bits.
    let n_eff_raw = if n > 1024 { 1024 } else { n }
    let n_eff = if n_eff_raw % 2 == 0 { n_eff_raw } else { n_eff_raw - 1 }
    let half = n_eff / 2
    let mut x = []
    let mut i = 0
    while i < n_eff {
        x = x.push(2 * bits[i] - 1)
        i = i + 1
    }
    let pi = 3.141592653589793
    let T = _sqrt_f(_ln_f(1.0 / 0.05) * to_float(n_eff))
    let N_0 = 0.95 * to_float(half)
    let mut N_1 = 0
    // Rotation recurrence (no per-bin trig): c_{j+1} = c_j*cos_dk - s_j*sin_dk.
    let mut k = 0
    while k < half {
        let dtheta = (0.0 - 2.0 * pi * to_float(k)) / to_float(n_eff)
        let cos_dk = _cos_f(dtheta)
        let sin_dk = _sin_f(dtheta)
        let mut c = 1.0
        let mut s = 0.0
        let mut re = 0.0
        let mut im = 0.0
        let mut j = 0
        while j < n_eff {
            let xj = to_float(x[j])
            re = re + xj * c
            im = im + xj * s
            let c_new = c * cos_dk - s * sin_dk
            let s_new = s * cos_dk + c * sin_dk
            c = c_new
            s = s_new
            j = j + 1
        }
        let mag = _sqrt_f(re * re + im * im)
        if mag < T { N_1 = N_1 + 1 }
        k = k + 1
    }
    let d = (to_float(N_1) - N_0) / _sqrt_f(to_float(n_eff) * 0.95 * 0.05 / 4.0)
    let p = _erfc_f(_abs_f(d) / _sqrt_f(2.0))
    let passed = if p >= 0.01 { 1 } else { 0 }
    return AuditTestResult { name: "dft_spectral", p_value: p, passed: passed, skipped: 0, note: "n_eff=" + str(n_eff) + " T=" + str(T) + " N0=" + str(N_0) + " N1=" + str(N_1) + " d=" + str(d) }
}

// ─── audit driver ────────────────────────────────────────────

fn audit_run_tier1plus(bytes_: [int]) -> [AuditTestResult] {
    let bits = _bytes_to_bits(bytes_)
    let mut out = []
    out = out.push(_test_monobit(bits))
    out = out.push(_test_frequency_block(bits))
    out = out.push(_test_runs(bits))
    out = out.push(_test_longest_run(bits))
    out = out.push(_test_dft_spectral(bits))
    return out
}

fn _audit_pass_aggregate(tests: [AuditTestResult]) -> int {
    let mut all_pass = 1
    let mut any_ran = 0
    let mut i = 0
    while i < len(tests) {
        if tests[i].skipped == 0 {
            any_ran = 1
            if tests[i].passed != 1 { all_pass = 0 }
        }
        i = i + 1
    }
    if any_ran == 0 { return 0 }
    return all_pass
}

fn _delivered_label(tests: [AuditTestResult], requested: str) -> str {
    if requested != "tier1+" { return requested }
    let mut skipped_n = 0
    let mut i = 0
    while i < len(tests) {
        if tests[i].skipped == 1 { skipped_n = skipped_n + 1 }
        i = i + 1
    }
    if skipped_n == 0 { return "tier1+" }
    if skipped_n == len(tests) { return "tier1-none" }
    return "tier1-partial"
}

// ─── entropy fixture (mock LCG, byte-identical to mock_qrng) ─

fn _mock_lcg(n_bytes: int, seed: int) -> [int] {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return bytes_
}

// ANU live legacy keyless pull (rate-limited 1 req/min, no key).
fn _anu_legacy_pull(n_bytes: int) -> [int] {
    if n_bytes < 1 { return [] }
    if n_bytes > 1024 { return [] }
    let url = "https://qrng.anu.edu.au/API/jsonI.php?length=" + str(n_bytes) + "&type=uint8"
    let cmd = "curl -sS --max-time 30 '" + url + "' 2>&1"
    let body = exec(cmd).trim()
    if len(body) < 1 { return [] }
    if body.contains("\"success\":true") == false { return [] }
    if body.contains("\"data\":[") == false { return [] }
    let after = body.split("\"data\":[")
    if len(after) < 2 { return [] }
    let arr_parts = after[1].split("]")
    if len(arr_parts) < 1 { return [] }
    let toks = arr_parts[0].split(",")
    let mut out = []
    let mut i = 0
    while i < len(toks) {
        let t = toks[i].trim()
        if len(t) > 0 {
            let v = to_int(t)
            if v >= 0 { if v <= 255 { out = out.push(v) } }
        }
        i = i + 1
    }
    if len(out) != n_bytes { return [] }
    return out
}

fn _resolve_vendor(vendor: str) -> str {
    if vendor != "auto" { return vendor }
    let live = exec("printenv QRNG_LIVE 2>/dev/null || true").trim()
    if live == "1" { return "anu" }
    return "mock_qrng"
}

fn _vendor_tier(vendor: str) -> str {
    if vendor == "mock_qrng" { return "T0" }
    if vendor == "anu" { return "T1" }
    if vendor == "anu_legacy" { return "T1" }
    if vendor == "curby" { return "T1" }
    if vendor == "nist_beacon" { return "T1" }
    if vendor == "hardware_qrng" { return "T3" }
    return "T?"
}

// ─── PUBLIC: qrng_audited_bytes — entropy + audit single call ─

fn qrng_audited_bytes(n_bytes: int, audit_level: str, vendor: str) -> AuditedQrngBytes {
    if n_bytes < 1 {
        return AuditedQrngBytes {
            ok: 0, n_bytes: 0, bytes_hex: "", audit_pass: 0, tests_run: [],
            audit_level_requested: audit_level, audit_level_delivered: "none",
            tier: "T?", vendor: vendor, alpha: 0.01,
            message: "qrng_audited_bytes: n_bytes >= 1 required"
        }
    }
    let v = _resolve_vendor(vendor)
    let mut bytes_ = []
    let mut msg = ""
    if v == "mock_qrng" {
        bytes_ = _mock_lcg(n_bytes, 42)
        msg = "qrng_audited_bytes: mock_qrng LCG fixture"
    } else if v == "anu" || v == "anu_legacy" {
        bytes_ = _anu_legacy_pull(n_bytes)
        if len(bytes_) != n_bytes {
            bytes_ = _mock_lcg(n_bytes, 42)
            msg = "qrng_audited_bytes: ANU live failed -> mock_qrng fallback"
        } else {
            msg = "qrng_audited_bytes: ANU legacy keyless live"
        }
    } else {
        bytes_ = _mock_lcg(n_bytes, 42)
        msg = "qrng_audited_bytes: unknown vendor='" + v + "' -> mock_qrng fallback"
    }

    let hex = _bytes_to_hex(bytes_)
    let mut tests = []
    let mut delivered = "none"
    let mut audit_pass = 0
    if audit_level == "tier1+" {
        tests = audit_run_tier1plus(bytes_)
        audit_pass = _audit_pass_aggregate(tests)
        delivered = _delivered_label(tests, audit_level)
    } else {
        delivered = "none"
    }

    return AuditedQrngBytes {
        ok: 1, n_bytes: len(bytes_), bytes_hex: hex,
        audit_pass: audit_pass, tests_run: tests,
        audit_level_requested: audit_level, audit_level_delivered: delivered,
        tier: _vendor_tier(v), vendor: v, alpha: 0.01,
        message: msg
    }
}
