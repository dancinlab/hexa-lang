#!hexa strict
// stdlib/qrng/backends/cloud/ionq.hexa — IonQ trapped-ion cloud QRNG (T2.b STUB_CREDENTIALED)
//
// @version 1.0.0
// @capabilities [network, randomness, shell, credentials]
// @stability stub
// @since 2026-05-16
//
// IonQ Forte 1 (35 algorithmic qubits, trapped-ion 171Yb+) extraction via
// IonQ Cloud REST API. Requires IONQ_API_KEY. Live deferred to consumer adapter.
//
//   (1) is_quantum=1 (vendor-asserted trapped-ion 171Yb+ Hadamard-measure chain).
//   (2) Live requires IonQ Cloud account + IONQ_API_KEY + qiskit-ionq or REST.
//   (3) No permanent free tier (PAYG); trial credits intermittent.
//   (4) Mock fixture byte-identical to mock_qrng.
//
// FALSIFIERS (frozen):
//   F_IONQ_01: meta shape — name=ionq, tier=2, is_quantum=1, is_free=0
//   F_IONQ_02: secret-chain — IONQ_API_KEY single-source
//   F_IONQ_03: live without token + without mock → ok=0 cites secret
//   F_IONQ_04: mock fixture deterministic
//
// Source: ~/core/qrng/ionq/module/ionq.hexa @ v1.0.0 (RFC 044).

use "stdlib/qrng/source"

let IONQ_NAME    = "ionq"
let IONQ_TIER    = 2
let IONQ_BPS     = 100
let IONQ_VENDOR  = "ionq_forte_1_trapped_ion_171ybplus"
let IONQ_SECRET  = "IONQ_API_KEY"

fn qrng_source_meta_ionq() -> QrngSourceMeta {
    return qrng_meta_make(
        IONQ_NAME, IONQ_TIER, IONQ_BPS,
        1,    // cost_usd: PAYG
        0,    // lead_days
        1,    // is_quantum
        0,    // is_local: cloud
        0,    // is_free: NO permanent free tier
        "STUB_CREDENTIALED",
        IONQ_VENDOR
    )
}

fn _ionq_env(name: str) -> str {
    return exec("printenv " + name + " 2>/dev/null || true").trim()
}

fn _ionq_resolve_secret_name() -> str {
    let v = _ionq_env(IONQ_SECRET)
    if len(v) > 0 { return IONQ_SECRET }
    return ""
}

fn _ionq_mock_fixture(n_bytes: int, seed: int) -> QrngBytes {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "ionq: mock fixture (NEXUS_QRNG_MOCK=1; byte-identical to mock_qrng)")
}

fn qrng_source_collect_ionq(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 { return qrng_bytes_fail("ionq: n_bytes must be >= 1") }
    let mock_n = _ionq_env("NEXUS_QRNG_MOCK")
    let mock_a = _ionq_env("ANIMA_QRNG_MOCK")
    let mock_q = _ionq_env("QRNG_MOCK")
    if mock_n == "1" { return _ionq_mock_fixture(n_bytes, seed) }
    if mock_a == "1" { return _ionq_mock_fixture(n_bytes, seed) }
    if mock_q == "1" { return _ionq_mock_fixture(n_bytes, seed) }
    let live = _ionq_env("NEXUS_QRNG_LIVE")
    let live_q = _ionq_env("QRNG_LIVE")
    if live != "1" { if live_q != "1" {
        return qrng_bytes_fail("ionq: live path gated — set NEXUS_QRNG_LIVE=1 (or NEXUS_QRNG_MOCK=1 for CI)")
    } }
    let secret = _ionq_resolve_secret_name()
    if len(secret) == 0 {
        return qrng_bytes_fail("ionq: credentials missing — set " + IONQ_SECRET + ". Sign up at https://cloud.ionq.com (PAYG)")
    }
    return qrng_bytes_fail("ionq: credentials resolved (" + secret + ") but in-process bridge not implemented; use consumer adapter (qiskit-ionq)")
}
