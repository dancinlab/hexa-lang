#!hexa strict
// stdlib/qrng/backends/hardware_qrng.hexa — local HW QRNG (T3 IMPLEMENTED)
//
// @version 1.0.0
// @capabilities [hardware, randomness, shell, serial_io]
// @stability stable
// @since 2026-05-16
//
// Local hardware QRNG abstraction. Default mock-mode (deterministic LCG).
// Live path probes (a) /dev/quantis* (IDQ libQuantis SDK), (b) /dev/cu.usbmodem*
// / /dev/cu.usbserial* (ESP32-quantum-like serial source). Both opt-in via
// NEXUS_QRNG_HW_LIVE=1.
//
//   (1) Mock-mode default. Live opt-in (NEXUS_QRNG_HW_LIVE=1).
//   (2) Probes 2 device classes: /dev/quantis* (IDQ Quantis PCIe/USB) and
//       /dev/cu.usbmodem* / /dev/cu.usbserial* (ESP32 / FTDI serial bridges).
//       NEITHER independently verified — vendor health check + NIST SP 800-90B
//       not implemented. is_quantum=1 by vendor claim only.
//   (3) Mock fixture byte-identical to mock_qrng (same LCG params).
//   (4) Live serial uses `head -c <n>` BLOCKING I/O; gated by timeout(1).
//       Set NEXUS_QRNG_HW_TIMEOUT_S env (default 5s).
//   (5) Vendor label changes by probe outcome; tier remains 3.
//
// Source: ~/core/qrng/hardware_qrng/module/hardware_qrng.hexa @ v1.0.0 (RFC 044).

use "stdlib/qrng/source"

fn qrng_source_meta_hardware_qrng() -> QrngSourceMeta {
    return qrng_meta_make("hardware_qrng", 3, 240000000, 5000, 42, 1, 1, 0, "IMPLEMENTED", "ID_Quantique_Quantis_PCIe_or_ESP32_serial")
}

fn _hw_env(name: str) -> str {
    return exec("printenv " + name + " 2>/dev/null || true").trim()
}

fn _hw_mock_fixture(n_bytes: int, seed: int) -> QrngBytes {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "hardware_qrng: mock fixture (NEXUS_QRNG_HW_MOCK=1)")
}

fn _hw_probe_device() -> str {
    let q = exec("ls /dev/quantis* 2>/dev/null | head -1 || true").trim()
    if len(q) > 0 { return q }
    let u1 = exec("ls /dev/cu.usbmodem* 2>/dev/null | head -1 || true").trim()
    if len(u1) > 0 { return u1 }
    let u2 = exec("ls /dev/cu.usbserial* 2>/dev/null | head -1 || true").trim()
    if len(u2) > 0 { return u2 }
    return ""
}

fn _hw_read_device_bytes(dev: str, n_bytes: int, timeout_s: str) -> QrngBytes {
    let cmd = "timeout " + timeout_s + " head -c " + str(n_bytes) + " " + dev + " 2>/dev/null | xxd -p -c 4096 | tr -d '\\n'"
    let hex = exec(cmd).trim()
    if len(hex) < 2 * n_bytes {
        return qrng_bytes_fail("hardware_qrng: device read short — got " + str(len(hex) / 2) + " bytes from " + dev)
    }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        let pair = hex.substring(2 * i, 2 * i + 2)
        let v_str = exec("printf '%d' 0x" + pair + " 2>/dev/null || echo -1").trim()
        let v = to_int(v_str)
        if v < 0 { return qrng_bytes_fail("hardware_qrng: hex parse error at byte " + str(i)) }
        if v > 255 { return qrng_bytes_fail("hardware_qrng: hex parse overflow at byte " + str(i)) }
        bytes_ = bytes_.push(v)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "hardware_qrng: live device " + dev)
}

fn qrng_source_collect_hardware_qrng(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 { return qrng_bytes_fail("hardware_qrng: n_bytes must be >= 1") }
    let mock_hw = _hw_env("NEXUS_QRNG_HW_MOCK")
    let mock_n = _hw_env("NEXUS_QRNG_MOCK")
    let mock_a = _hw_env("ANIMA_QRNG_MOCK")
    if mock_hw == "1" { return _hw_mock_fixture(n_bytes, seed) }
    if mock_n == "1" { return _hw_mock_fixture(n_bytes, seed) }
    if mock_a == "1" { return _hw_mock_fixture(n_bytes, seed) }
    let live = _hw_env("NEXUS_QRNG_HW_LIVE")
    if live != "1" {
        return qrng_bytes_fail("hardware_qrng: live path gated — set NEXUS_QRNG_HW_LIVE=1 (or NEXUS_QRNG_HW_MOCK=1 for CI)")
    }
    let dev = _hw_probe_device()
    if len(dev) < 1 {
        return qrng_bytes_fail("hardware_qrng: no device found at /dev/quantis* or /dev/cu.usbmodem* or /dev/cu.usbserial*")
    }
    let to = _hw_env("NEXUS_QRNG_HW_TIMEOUT_S")
    let to_eff = if len(to) > 0 { to } else { "5" }
    if n_bytes > 65536 {
        return qrng_bytes_fail("hardware_qrng: chunk > 65536 bytes — use chained chunks (no streaming today)")
    }
    return _hw_read_device_bytes(dev, n_bytes, to_eff)
}
