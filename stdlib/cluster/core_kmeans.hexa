// stdlib/cluster/core_kmeans.hexa
//
// Iterative k-means (Lloyd's algorithm) — RFC-037 2nd-wave reification of the
// clustering stdlib promotion. Sibling to core_distance.hexa (#863) and
// core_knn.hexa (#863). Centroid init flavors:
//   - Random-from-data via seeded LCG (RFC-037 2nd-wave, #869).
//   - k-means++ D²-weighted (RFC-037 3rd-wave, Arthur & Vassilvitskii 2007).
//
// Scope (this module):
//   - kmeans_fit(x, k, max_iter, seed) -> [int]
//       Lloyd's algorithm with random-from-data init. Returns one cluster label
//       per row of `x`.
//       1. Init k centroids by sampling without replacement from `x`
//          (deterministic — same seed → same indices).
//       2. Repeat up to max_iter times:
//            a. Assign each point to the nearest centroid (euclidean).
//            b. Recompute centroids as the mean of their assigned points.
//            c. Halt early on a no-change assignment epoch (converged).
//       3. Return the final per-point cluster labels.
//   - kmeans_fit_pp(x, k, max_iter, seed) -> [int]
//       Same Lloyd loop, but seeded with k-means++ D²-weighted init:
//       1. Pick first centroid uniformly at random from x.
//       2. For each remaining centroid (2..k):
//            a. Compute D(p)² = squared distance from p to nearest existing
//               centroid for each p in x.
//            b. Sample next centroid with probability ∝ D²(p).
//       Provides O(log k) approximation guarantee + tighter initial WCSS on
//       adversarial geometries vs. random-from-data init.
//   - wcss(x, labels, centroids) -> float
//       Within-cluster sum of squares — Σ ‖xᵢ − μ_{labelᵢ}‖². The built-in
//       falsifier for Lloyd's algorithm: each Lloyd iteration must produce a
//       non-increasing wcss (theorem). The companion test asserts strict
//       monotone-decrease across iterations.
//
// Determinism contract: identical (x, k, max_iter, seed) → identical labels for
// both kmeans_fit and kmeans_fit_pp.
// Convergence contract: wcss is non-increasing across iterations until the
// no-change epoch fires. Both are exercised by core_kmeans_test.hexa.
//
// Edge cases (defined fallback discipline matches core_distance / core_knn):
//   - k <= 0  → all points labeled 0.
//   - k >= n  → degenerate; each point becomes its own cluster (clamped).
//   - empty x → [].
//   - empty cluster at recompute → centroid frozen at prior position
//     (rather than re-seeded — keeps wcss-monotone invariant intact).
//
// `sqrt` for euclidean is the libm builtin via stdlib/cluster/core_distance.hexa
// (project.tape @D stdlib_trig_libm: no Taylor reimplementation).

import "stdlib/cluster/core_distance.hexa"

// --- Seeded LCG (deterministic, no global state) -----------------------------
// Numerical Recipes constants — same multiplier/increment family as glibc.
// Operates on 32-bit-ish unsigned semantics via mod 2^31; sufficient for
// pick-without-replacement on stdlib-scale datasets.

fn _kmeans_lcg_next(state: int) -> int {
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    let mut s = state * a + c
    // Force into [0, m). Hexa int division truncates toward zero; mod via
    // subtraction keeps the math defined-fallback simple.
    let q = s / m
    s = s - q * m
    if s < 0 { s = s + m }
    return s
}

fn _kmeans_pick_init_indices(n: int, k: int, seed: int) -> [int] {
    // Sample k distinct indices from [0, n) deterministically. If k >= n, return
    // [0, 1, ..., n-1] (every point becomes a seed centroid).
    if k <= 0 || n <= 0 { return [] }
    let mut state = seed
    // Mix the seed so seed=0 doesn't degenerate to an all-zero stream.
    state = _kmeans_lcg_next(state + 1)

    let mut picked: [int] = []
    let mut taken: [bool] = []
    let mut t = 0
    while t < n {
        taken = taken + [false]
        t = t + 1
    }

    let mut want = k
    if want > n { want = n }

    let mut found = 0
    // Guard against pathological repeat collisions by capping inner attempts.
    let max_attempts = (n + k) * 8 + 64
    let mut attempts = 0
    while found < want && attempts < max_attempts {
        state = _kmeans_lcg_next(state)
        let idx = state - (state / n) * n
        if taken[idx] == false {
            taken[idx] = true
            picked = picked + [idx]
            found = found + 1
        }
        attempts = attempts + 1
    }
    // Linear-scan fallback if the random draw under-fills (extreme seeds).
    let mut scan = 0
    while found < want && scan < n {
        if taken[scan] == false {
            taken[scan] = true
            picked = picked + [scan]
            found = found + 1
        }
        scan = scan + 1
    }
    return picked
}

// --- WCSS --------------------------------------------------------------------

pub fn wcss(x: [[float]], labels: [int], centroids: [[float]]) -> float {
    let n = len(x)
    if n == 0 { return 0.0 }
    if n != len(labels) { return 0.0 }
    let k = len(centroids)
    if k == 0 { return 0.0 }

    let mut total = 0.0
    let mut i = 0
    while i < n {
        let lab = labels[i]
        if lab >= 0 && lab < k {
            let d = euclidean(x[i], centroids[lab])
            total = total + d * d
        }
        i = i + 1
    }
    return total
}

// --- Lloyd's algorithm -------------------------------------------------------

fn _kmeans_assign(x: [[float]], centroids: [[float]]) -> [int] {
    let n = len(x)
    let k = len(centroids)
    let mut labels: [int] = []
    let mut i = 0
    while i < n {
        let mut best = 0
        let mut best_d = euclidean(x[i], centroids[0])
        let mut j = 1
        while j < k {
            let d = euclidean(x[i], centroids[j])
            if d < best_d {
                best_d = d
                best = j
            }
            j = j + 1
        }
        labels = labels + [best]
        i = i + 1
    }
    return labels
}

fn _kmeans_recompute(x: [[float]],
                     labels: [int],
                     centroids_prev: [[float]],
                     k: int) -> [[float]] {
    let n = len(x)
    if n == 0 { return centroids_prev }
    let dim = len(x[0])

    // Pre-size accumulators: k × dim sums + k counts.
    let mut sums: [[float]] = []
    let mut counts: [int] = []
    let mut a = 0
    while a < k {
        let mut row: [float] = []
        let mut b = 0
        while b < dim {
            row = row + [0.0]
            b = b + 1
        }
        sums = sums + [row]
        counts = counts + [0]
        a = a + 1
    }

    let mut i = 0
    while i < n {
        let lab = labels[i]
        if lab >= 0 && lab < k {
            let mut d = 0
            while d < dim {
                sums[lab][d] = sums[lab][d] + x[i][d]
                d = d + 1
            }
            counts[lab] = counts[lab] + 1
        }
        i = i + 1
    }

    // Build new centroids; empty clusters freeze at their prior centroid so wcss
    // stays monotone-non-increasing across iterations.
    let mut centroids_new: [[float]] = []
    let mut c = 0
    while c < k {
        if counts[c] == 0 {
            centroids_new = centroids_new + [centroids_prev[c]]
        } else {
            let cnt = counts[c]
            let mut row: [float] = []
            let mut d = 0
            while d < dim {
                row = row + [sums[c][d] / to_float(cnt)]
                d = d + 1
            }
            centroids_new = centroids_new + [row]
        }
        c = c + 1
    }
    return centroids_new
}

fn _kmeans_labels_equal(a: [int], b: [int]) -> bool {
    let n = len(a)
    if n != len(b) { return false }
    let mut i = 0
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

// --- k-means++ D²-weighted init (Arthur & Vassilvitskii 2007) ----------------
// Internal: returns the k initial centroid indices selected by D²-weighting.
//   1. First centroid: uniform random pick from [0, n).
//   2. For remaining centroids: D(p)² = squared euclidean distance from p to
//      the nearest already-chosen centroid; sample next index with probability
//      ∝ D²(p). Realized via cumulative-sum + uniform draw in [0, total_d2).
// Determinism: identical (n, k, seed) → identical index list. Uses the same
// _kmeans_lcg_next stream as random init for cross-flavor seed compatibility.
fn _kmeans_init_pp(x: [[float]], k: int, seed: int) -> [int] {
    let n = len(x)
    if k <= 0 || n <= 0 { return [] }

    let mut state = seed
    // Mix the seed (matches _kmeans_pick_init_indices) so seed=0 doesn't
    // degenerate to an all-zero stream.
    state = _kmeans_lcg_next(state + 1)

    let mut want = k
    if want > n { want = n }

    // 1. First centroid: uniform random pick.
    state = _kmeans_lcg_next(state)
    let first_idx = state - (state / n) * n
    let mut picked: [int] = [first_idx]

    // d2[i] = squared distance from x[i] to the nearest already-picked centroid.
    // Initialise with distance to the first centroid; updated incrementally as
    // each new centroid is appended (only need min(d2[i], dist_to_new)).
    let mut d2: [float] = []
    let mut i = 0
    while i < n {
        let d = euclidean(x[i], x[first_idx])
        d2 = d2 + [d * d]
        i = i + 1
    }

    let mut found = 1
    let lcg_m = 2147483648
    while found < want {
        // 2a. Sample next index ∝ d2.
        let mut total = 0.0
        let mut t = 0
        while t < n {
            total = total + d2[t]
            t = t + 1
        }
        let mut next_idx = 0
        if total <= 0.0 {
            // All points sit on existing centroids (duplicates / k > unique).
            // Fall back to the first not-yet-picked index for determinism.
            let mut scan = 0
            let mut chosen = -1
            while scan < n && chosen < 0 {
                let mut seen = false
                let mut pi = 0
                while pi < len(picked) && seen == false {
                    if picked[pi] == scan { seen = true }
                    pi = pi + 1
                }
                if seen == false { chosen = scan }
                scan = scan + 1
            }
            if chosen < 0 { chosen = 0 }
            next_idx = chosen
        } else {
            state = _kmeans_lcg_next(state)
            // Uniform float in [0, total) via state/lcg_m * total.
            let u01 = to_float(state) / to_float(lcg_m)
            let target = u01 * total
            let mut cum = 0.0
            let mut j = 0
            let mut chosen = n - 1
            let mut done = false
            while j < n && done == false {
                cum = cum + d2[j]
                if cum >= target {
                    chosen = j
                    done = true
                }
                j = j + 1
            }
            next_idx = chosen
        }

        picked = picked + [next_idx]
        found = found + 1

        // 2b. Update d2 with distance to the newly added centroid.
        let mut u = 0
        while u < n {
            let dn = euclidean(x[u], x[next_idx])
            let dn2 = dn * dn
            if dn2 < d2[u] { d2[u] = dn2 }
            u = u + 1
        }
    }
    return picked
}

// kmeans_fit — Lloyd's algorithm. Returns the final per-point cluster label.
pub fn kmeans_fit(x: [[float]], k: int, max_iter: int, seed: int) -> [int] {
    let n = len(x)
    if n == 0 { return [] }

    // Degenerate guards.
    if k <= 0 {
        let mut zeros: [int] = []
        let mut i = 0
        while i < n {
            zeros = zeros + [0]
            i = i + 1
        }
        return zeros
    }

    // Init centroids = k seed points sampled deterministically from x.
    let init_idx = _kmeans_pick_init_indices(n, k, seed)
    let k_eff = len(init_idx)
    let mut centroids: [[float]] = []
    let mut s = 0
    while s < k_eff {
        centroids = centroids + [x[init_idx[s]]]
        s = s + 1
    }

    // Initial assignment.
    let mut labels = _kmeans_assign(x, centroids)

    let mut iter = 0
    while iter < max_iter {
        let new_centroids = _kmeans_recompute(x, labels, centroids, k_eff)
        let new_labels = _kmeans_assign(x, new_centroids)
        let stable = _kmeans_labels_equal(labels, new_labels)
        centroids = new_centroids
        labels = new_labels
        if stable { return labels }
        iter = iter + 1
    }
    return labels
}

// kmeans_fit_pp — Lloyd's algorithm with k-means++ D²-weighted init.
// Same Lloyd loop as kmeans_fit; differs only in the centroid seeding strategy.
// Determinism: identical (x, k, max_iter, seed) → identical labels.
pub fn kmeans_fit_pp(x: [[float]], k: int, max_iter: int, seed: int) -> [int] {
    let n = len(x)
    if n == 0 { return [] }

    // Degenerate guards (mirror kmeans_fit).
    if k <= 0 {
        let mut zeros: [int] = []
        let mut i = 0
        while i < n {
            zeros = zeros + [0]
            i = i + 1
        }
        return zeros
    }

    // Init centroids via k-means++ D²-weighted picking.
    let init_idx = _kmeans_init_pp(x, k, seed)
    let k_eff = len(init_idx)
    let mut centroids: [[float]] = []
    let mut s = 0
    while s < k_eff {
        centroids = centroids + [x[init_idx[s]]]
        s = s + 1
    }

    let mut labels = _kmeans_assign(x, centroids)

    let mut iter = 0
    while iter < max_iter {
        let new_centroids = _kmeans_recompute(x, labels, centroids, k_eff)
        let new_labels = _kmeans_assign(x, new_centroids)
        let stable = _kmeans_labels_equal(labels, new_labels)
        centroids = new_centroids
        labels = new_labels
        if stable { return labels }
        iter = iter + 1
    }
    return labels
}
