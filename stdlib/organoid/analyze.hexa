#!hexa strict
// organoid analyze — viability fraction + doubling-time fold change.
fn main() {
    let N_live = 95.0
    let N_total = 100.0
    let viability = N_live / N_total
    let days = 7.0
    let doubling_h = 24.0
    let fold = days * 24.0 / doubling_h
    println("organoid_analyze (viability + growth):")
    println("  viability_fraction = " + str(viability))
    println("  doubling_h = " + str(doubling_h) + "  days = " + str(days))
    println("  fold_doublings = " + str(fold))
    println("__HEXA_ORGANOID_ANALYZE__ PASS gate=GATE_OPEN absorbed=false")
}
