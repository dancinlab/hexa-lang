#!hexa strict
// gene-edit verify — Doench 2016 on-target linear-model sum (sample guide).
fn main() {
    let w1 = 0.1
    let w2 = 0.2
    let w3 = 0.15
    let w4 = 0.05
    let intercept = 0.5
    let score = intercept + w1 + w2 + w3 + w4
    println("gene-edit_verify (Doench2016 on-target · sample):")
    println("  intercept_+_weights = " + str(score))
    println("__HEXA_GENE_EDIT_VERIFY__ PASS gate=GATE_OPEN absorbed=false")
}
