// @ci_gate вҖ” deterministic В· network-free В· PBE GGA мғҒкҙҖ g5 кІҢмқҙнҠё
//
// correlation_pbe_selftest.hexa вҖ” QFORGE PBE GGA мғҒкҙҖ(gradient correction H) g5 gate.
//   PR1 мқҳ LDA мғҒкҙҖ(PW92) мң„м—җ PBE H(r_s,t) лҘј мҳ¬лҰ° PR2 лҘј кІҖмҰқн•ңлӢӨ.
//
// кІҖмҰқ мјҖмқҙмҠӨ:
//  рҹ”ө (A) LDA нҷҳмӣҗ: tвҶ’0 вҮ’ HвҶ’0 вҮ’ Оө_c^PBE(r_s,tвҶ’0) = Оө_c^PW92(r_s) (abs<1e-10).
//         PBE мқҳ н•өмӢ¬ мқјкҙҖм„ұ вҖ” к· м§Ҳк·№н•ңм—җм„ң PW92-LDA лЎң м •нҷ•нһҲ нҷҳмӣҗ.
//  рҹҹў (B) H closed-form мҶҗкі„мӮ° мһ¬нҳ„ (r_s=1,2,5 В· t=0.5,1.0, float мһ¬кІ°н•©Оө abs<1e-6).
//         H=Оі ln(1+(ОІ/Оі)tВІ(1+AtВІ)/(1+AtВІ+AВІtвҒҙ)) лҘј selftest лӮҙл¶Җ лҸ…лҰҪ мһ¬кі„мӮ°.
//  рҹ”ө (C) кі кё°мҡёкё° нҸ¬нҷ”к·№н•ң tвҶ’вҲһ: H вҶ’ вҲ’Оө_c^LDA (PBE м„Өкі„ н•ӯл“ұ вҶ’ Оө_c^PBEвҶ’0) (abs<1e-9).
//         AвҶ’(ОІ/Оі)/(e^{вҲ’Оө/Оі}вҲ’1) м—җм„ң H_max=Оі ln(1+(ОІ/Оі)/A)=вҲ’Оө_lda вҖ” лӢ«нһҢнҳ•.
//  рҹҹў (D) H м–‘мҲҳВ·лӢЁмЎ°мҰқк°Җ(0<t): мһ‘мқҖ кё°мҡёкё°вҶ’мһ‘мқҖ H, нҒ° кё°мҡёкё°вҶ’нҒ° H.
//         H(t=0.5) < H(t=1) < H(t=2)  (к°Ғ r_s).
//  рҹҹў (E) from_rho helper нҷҳмӣҗ: |вҲҮПҒ|=0 вҮ’ Оө_c^PBE_from_rho(ПҒ,0) = Оө_c^PW92(r_s(ПҒ)).
//  рҹ”ө (F) ОіВ·(мғҒмҲҳ) л¶Җнҳё sanity: H(r_s,t)>0 (вҲҮ ліҙм •мқҖ Оө_c лҘј 0 мӘҪмңјлЎң вҖ” м–‘мҲҳ).
//
// Run:  hexa run --no-sentinel stdlib/qforge/correlation_pbe_selftest.hexa
// PASS: "qforge_correlation_pbe_selftest PASS".
use "stdlib/qforge/correlation"

fn _abs(x: float) -> float { if x < 0.0 { return -x } return x }
fn _ck_close(name: str, got: float, want: float, eps: float) -> int {
    if _abs(got - want) <= eps { println("PASS " + name + " (" + to_string(got) + ")") ; return 0 }
    println("FAIL " + name + " вҖ” got " + to_string(got) + " want " + to_string(want)) ; return 1
}
fn _ck_bool(name: str, got: bool, want: bool) -> int {
    if got == want { println("PASS " + name + " (" + to_string(got) + ")") ; return 0 }
    println("FAIL " + name + " вҖ” got " + to_string(got) + " want " + to_string(want)) ; return 1
}

// PBE H мҶҗкі„мӮ° (selftest лҸ…лҰҪ мһ¬нҳ„ вҖ” ліё мҪ”л“ңмҷҖ лі„кІҪлЎң).
fn _h_hand(rs: float, t: float) -> float {
    let g = 0.031090690869654895
    let b = 0.06672455060314922
    let ec = qforge_ec_pw92(rs)
    let bg = b / g
    let aa = bg / (exp(-1.0 * ec / g) - 1.0)
    let t2 = t * t
    let t4 = t2 * t2
    let inner = 1.0 + bg * t2 * (1.0 + aa * t2) / (1.0 + aa * t2 + aa * aa * t4)
    return g * log(inner)
}

fn main() {
    let mut fails = 0

    // в”Җв”Җ (A) LDA нҷҳмӣҗ: tвҶ’0 вҮ’ Оө_c^PBE = Оө_c^PW92 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    let rsA = [1.0, 2.0, 5.0, 10.0]
    let mut ia = 0
    while ia < len(rsA) {
        let rs = rsA[ia]
        fails = fails + _ck_close("(A) PBEвҶ’PW92 reduction tвҶ’0 r_s=" + to_string(rs),
                                  qforge_ec_pbe(rs, 1.0e-9), qforge_ec_pw92(rs), 1.0e-10)
        ia = ia + 1
    }

    // в”Җв”Җ (B) H closed-form мҶҗкі„мӮ° мһ¬нҳ„ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    let rsB = [1.0, 2.0, 5.0]
    let tsB = [0.5, 1.0]
    let mut ib = 0
    while ib < len(rsB) {
        let mut jb = 0
        while jb < len(tsB) {
            let rs = rsB[ib]
            let t = tsB[jb]
            fails = fails + _ck_close("(B) H closed-form r_s=" + to_string(rs) + " t=" + to_string(t),
                                      qforge_h_pbe(rs, t), _h_hand(rs, t), 1.0e-6)
            jb = jb + 1
        }
        ib = ib + 1
    }

    // в”Җв”Җ (C) нҸ¬нҷ”к·№н•ң tвҶ’вҲһ: H вҶ’ вҲ’Оө_c^LDA (Оө_c^PBEвҶ’0) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    let rsC = [1.0, 2.0, 5.0]
    let mut icx = 0
    while icx < len(rsC) {
        let rs = rsC[icx]
        let hmax = qforge_h_pbe(rs, 1.0e6)
        fails = fails + _ck_close("(C) H saturation tвҶ’вҲһ вҶ’ вҲ’Оө_c^LDA r_s=" + to_string(rs),
                                  hmax, -1.0 * qforge_ec_pw92(rs), 1.0e-9)
        icx = icx + 1
    }

    // в”Җв”Җ (D) H лӢЁмЎ°мҰқк°Җ (0 < t) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    let rsD = [1.0, 2.0, 5.0]
    let mut idx = 0
    while idx < len(rsD) {
        let rs = rsD[idx]
        let h05 = qforge_h_pbe(rs, 0.5)
        let h1 = qforge_h_pbe(rs, 1.0)
        let h2 = qforge_h_pbe(rs, 2.0)
        fails = fails + _ck_bool("(D) H monotone H(0.5)<H(1)<H(2) r_s=" + to_string(rs),
                                 h05 < h1 && h1 < h2, true)
        idx = idx + 1
    }

    // в”Җв”Җ (E) from_rho helper нҷҳмӣҗ: |вҲҮПҒ|=0 вҮ’ PW92 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    let rhoE = [0.05, 0.1, 0.5]
    let mut ie = 0
    while ie < len(rhoE) {
        let rho = rhoE[ie]
        let rs = qforge_rs_from_rho(rho)
        fails = fails + _ck_close("(E) from_rho |вҲҮПҒ|=0 вҮ’ PW92 ПҒ=" + to_string(rho),
                                  qforge_ec_pbe_from_rho(rho, 0.0), qforge_ec_pw92(rs), 1.0e-12)
        ie = ie + 1
    }

    // в”Җв”Җ (F) H > 0 (gradient ліҙм •мқҖ Оө_c лҘј 0 мӘҪмңјлЎң) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    fails = fails + _ck_bool("(F) H(r_s=2,t=1) > 0", qforge_h_pbe(2.0, 1.0) > 0.0, true)
    fails = fails + _ck_bool("(F) Оө_c^PBE(r_s=2,t=1) > Оө_c^LDA (less negative)",
                             qforge_ec_pbe(2.0, 1.0) > qforge_ec_pw92(2.0), true)

    if fails == 0 { println("qforge_correlation_pbe_selftest PASS") }
    else { println("qforge_correlation_pbe_selftest FAIL вҖ” " + to_string(fails) + " case(s)") }
}
