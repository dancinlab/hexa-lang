// @ci_gate — deterministic · network-free · LDA 상관(PZ81/PW92) g5 게이트
//
// correlation_selftest.hexa — QFORGE LDA 상관 에너지/전위 g5 gate.
//   screening.hexa 가 비워 둔 상관항(PZ81 · PW92)을 검증한다.
//
// 검증 케이스:
//  🔵 (A) PW92 ε_c(r_s) closed-form 손계산 재현 (r_s=1,2,5,10, abs<1e-7).
//         G(r_s)=−2A(1+α₁r_s)ln(1+1/(2A·Q1)) 직접 평가값과 일치.
//  🟢 (B) PW92 ε_c vs 공개 표준 표 (Perdew-Wang 1992, spin-unpolarized, Ha):
//         r_s=1 −0.0598 · r_s=2 −0.0448 · r_s=5 −0.0282 · r_s=10 −0.0186 (abs<5e-4).
//  🔵 (C) PW92 V_c = ε_c − (r_s/3)dε_c/dr_s : 해석 미분 = 중심차분 (abs<1e-7).
//  🟢 (D) PW92 고밀도극한 r_s→0: ε_c → A_HD ln r_s + ... → log-발산(음), 부호·단조.
//         r_s=0.01 < r_s=0.1 (더 음) — 고밀도일수록 ε_c 더 음.
//  🟢 (E) PW92 저밀도극한 r_s→∞: ε_c → 0⁻ (r_s=1000 매우 작은 음수, |ε_c|<3e-3).
//  🔵 (F) PZ81 ε_c closed-form 손계산 재현 (r_s=0.5 저밀도분기 · r_s=5 고분기).
//  🔵 (G) PZ81 V_c 해석형 = 중심차분(분기 내부, seam r_s=1 회피) (abs<1e-7).
//  🟢 (H) PZ81 vs PW92 일치(동일 CA 데이터의 두 fit): r_s=2,5,10 abs<2e-3.
//  🟢 (I) ρ→r_s 왕복: r_s=(3/(4πρ))^{1/3}, ρ=3/(4π r_s³) 항등 (cube round-trip ε, abs<1e-6).
//
// Run:  hexa run --no-sentinel stdlib/qforge/correlation_selftest.hexa
// PASS: "qforge_correlation_selftest PASS".
use "stdlib/qforge/correlation"

fn _abs(x: float) -> float { if x < 0.0 { return -x } return x }
fn _ck_close(name: str, got: float, want: float, eps: float) -> int {
    if _abs(got - want) <= eps { println("PASS " + name + " (" + to_string(got) + ")") ; return 0 }
    println("FAIL " + name + " — got " + to_string(got) + " want " + to_string(want)) ; return 1
}
fn _ck_bool(name: str, got: bool, want: bool) -> int {
    if got == want { println("PASS " + name + " (" + to_string(got) + ")") ; return 0 }
    println("FAIL " + name + " — got " + to_string(got) + " want " + to_string(want)) ; return 1
}

// PW92 ε_c 손계산 (selftest 내부 독립 재현 — 본 코드와 별경로).
fn _pw92_hand(rs: float) -> float {
    let aa = 0.031091
    let a1 = 0.21370
    let b1 = 7.5957
    let b2 = 3.5876
    let b3 = 1.6382
    let b4 = 0.49294
    let srs = sqrt(rs)
    let q1 = b1 * srs + b2 * rs + b3 * rs * srs + b4 * rs * rs
    let arg = 1.0 + 1.0 / (2.0 * aa * q1)
    return -2.0 * aa * (1.0 + a1 * rs) * log(arg)
}

fn main() {
    let mut fails = 0
    let PI = 3.14159265358979323846

    // ── (A) PW92 ε_c closed-form 재현 ────────────────────────────────────────
    let rsA = [1.0, 2.0, 5.0, 10.0]
    let mut ia = 0
    while ia < len(rsA) {
        let rs = rsA[ia]
        fails = fails + _ck_close("(A) PW92 ε_c closed-form r_s=" + to_string(rs),
                                  qforge_ec_pw92(rs), _pw92_hand(rs), 1.0e-7)
        ia = ia + 1
    }

    // ── (B) PW92 ε_c vs 공개 표준 표 (Ha, spin-unpolarized) ───────────────────
    fails = fails + _ck_close("(B) PW92 ε_c(r_s=1) vs lit −0.0598", qforge_ec_pw92(1.0), -0.0598, 5.0e-4)
    fails = fails + _ck_close("(B) PW92 ε_c(r_s=2) vs lit −0.0448", qforge_ec_pw92(2.0), -0.0448, 5.0e-4)
    fails = fails + _ck_close("(B) PW92 ε_c(r_s=5) vs lit −0.0282", qforge_ec_pw92(5.0), -0.0282, 5.0e-4)
    fails = fails + _ck_close("(B) PW92 ε_c(r_s=10) vs lit −0.0186", qforge_ec_pw92(10.0), -0.0186, 5.0e-4)

    // ── (C) PW92 V_c 해석 미분 = 중심차분 ────────────────────────────────────
    let rsC = [1.0, 2.0, 5.0, 10.0]
    let mut ic = 0
    while ic < len(rsC) {
        let rs = rsC[ic]
        let eps = 1.0e-6
        let fd = (qforge_ec_pw92(rs + eps) - qforge_ec_pw92(rs - eps)) / (2.0 * eps)
        let vc_fd = qforge_ec_pw92(rs) - (rs / 3.0) * fd
        fails = fails + _ck_close("(C) PW92 V_c analytic=FD r_s=" + to_string(rs),
                                  qforge_vc_pw92(rs), vc_fd, 1.0e-7)
        ic = ic + 1
    }

    // ── (D) 고밀도극한: ε_c(r_s→0) → −∞ (log), 더 작은 r_s 가 더 음 ────────────
    let e_001 = qforge_ec_pw92(0.01)
    let e_01 = qforge_ec_pw92(0.1)
    fails = fails + _ck_bool("(D) HD limit ε_c(0.01) < ε_c(0.1) (more negative)", e_001 < e_01, true)
    fails = fails + _ck_bool("(D) HD limit ε_c(0.01) < 0", e_001 < 0.0, true)

    // ── (E) 저밀도극한: ε_c(r_s→∞) → 0⁻ ──────────────────────────────────────
    let e_1000 = qforge_ec_pw92(1000.0)
    fails = fails + _ck_bool("(E) LD limit ε_c(1000) → 0⁻ (|ε_c|<3e-3)", _abs(e_1000) < 3.0e-3, true)
    fails = fails + _ck_bool("(E) LD limit ε_c(1000) < 0", e_1000 < 0.0, true)

    // ── (F) PZ81 ε_c closed-form 재현 (양 분기) ───────────────────────────────
    //   r_s=0.5 (저밀도분기 r_s<1): ε_c = A ln r_s + B + C r_s ln r_s + D r_s.
    let lr = log(0.5)
    let pz_lo = 0.0311 * lr + (-0.048) + 0.0020 * 0.5 * lr + (-0.0116) * 0.5
    fails = fails + _ck_close("(F) PZ81 ε_c r_s=0.5 (HD branch)", qforge_ec_pz81(0.5), pz_lo, 1.0e-12)
    //   r_s=5 (고분기 r_s>=1): ε_c = γ/(1+β₁√r_s+β₂ r_s).
    let pz_hi = -0.1423 / (1.0 + 1.0529 * sqrt(5.0) + 0.3334 * 5.0)
    fails = fails + _ck_close("(F) PZ81 ε_c r_s=5 (LD branch)", qforge_ec_pz81(5.0), pz_hi, 1.0e-12)

    // ── (G) PZ81 V_c 해석형 = 중심차분(분기 내부; seam r_s=1 회피) ─────────────
    let rsG = [0.5, 2.0, 5.0, 10.0]
    let mut ig = 0
    while ig < len(rsG) {
        let rs = rsG[ig]
        let eps = 1.0e-6
        let fd = (qforge_ec_pz81(rs + eps) - qforge_ec_pz81(rs - eps)) / (2.0 * eps)
        let vc_fd = qforge_ec_pz81(rs) - (rs / 3.0) * fd
        fails = fails + _ck_close("(G) PZ81 V_c analytic=FD r_s=" + to_string(rs),
                                  qforge_vc_pz81(rs), vc_fd, 1.0e-7)
        ig = ig + 1
    }

    // ── (H) PZ81 ≈ PW92 (동일 CA 데이터 두 fit) ───────────────────────────────
    let rsH = [2.0, 5.0, 10.0]
    let mut ih = 0
    while ih < len(rsH) {
        let rs = rsH[ih]
        fails = fails + _ck_close("(H) PZ81≈PW92 ε_c r_s=" + to_string(rs),
                                  qforge_ec_pz81(rs), qforge_ec_pw92(rs), 2.0e-3)
        ih = ih + 1
    }

    // ── (I) ρ→r_s 왕복 항등 ──────────────────────────────────────────────────
    let rho_t = 0.05
    let rs_t = qforge_rs_from_rho(rho_t)
    let rho_back = 3.0 / (4.0 * PI * rs_t * rs_t * rs_t)
    fails = fails + _ck_close("(I) ρ→r_s→ρ round-trip", rho_back, rho_t, 1.0e-6)

    if fails == 0 { println("qforge_correlation_selftest PASS") }
    else { println("qforge_correlation_selftest FAIL — " + to_string(fails) + " case(s)") }
}
