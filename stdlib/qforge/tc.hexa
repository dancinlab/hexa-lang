// HEXA Standard Library — qforge/tc
//
// @version 0.1.0
// @capabilities [pure]
//
// QFORGE L0 — the first engine layer of the QFORGE domain, a hexa-native
// first-principles electron-phonon engine. L0 is a *composing* layer: it does
// NOT re-implement any physics. It binds the already-verified 🟢
// SUPPORTED-NUMERICAL Tc / α²F atoms living in `stdlib/material/sim` (Allen-
// Dynes, McMillan, Eliashberg-moment integrator — PR#299 Python bit-exact)
// into a QFORGE-namespaced superconductor-Tc pipeline.
//
//   raw α²F(ω) ──eliashberg_moments_from_a2f──▶ [λ, ω_log, ω̄₂]
//                                                       │
//                                              allen_dynes_full
//                                                       ▼
//                                                     Tc (K)
//
// d3 (one canonical code home): the predictors live ONLY in stdlib/material/
// sim.hexa. This module `use`s them and calls through — no copy, no move
// (moving would churn RTSC and invalidate the verified atoms). d4 (generic
// dispatch): the pipeline is formula-agnostic — it forwards whatever spectral
// function / scalar moments it is handed; there is no per-material branch and
// no hardcoded formula. New materials are data (an α²F grid + μ*), not code.
//
// All three Tc entries forward to the verified `allen_dynes_tc` (Allen &
// Dynes 1975, PRB 12 905, ω_log/1.2 prefactor) — the form whose published
// Nb-anchor band is Tc = 9.9-13 K; `eliashberg_moments_from_a2f` supplies the
// (λ, ω_log, ω̄₂) moments for the spectral-function entry.
//
// Surface (pure functions, no syscall):
//   pub fn qforge_tc_allen_dynes(lam, omega_log_K, mu_star) -> float
//   pub fn qforge_tc_allen_dynes_full(lam, omega_log_K, omega2_K, mu_star) -> float
//   pub fn qforge_tc_from_a2f(omega: [float], a2f: [float], mu_star) -> float
//
// L1 — isotropic Migdal-Eliashberg Tc (the rigorous form Allen-Dynes fits):
//   pub fn qforge_tc_eliashberg(omega, a2f, mu_star, n_mats) -> float
//   pub fn qforge_tc_eliashberg_from_lambda(lam, omega_rep_K, mu_star, n_mats) -> float
// These delegate to stdlib/qforge/eliashberg (the Matsubara eigenvalue solver
// ρ_max(Tc)=1). They sit ABOVE L0: L0 returns the Allen-Dynes *fit*, L1 solves
// the linearized gap equation that fit was derived from. NEW numerical layer
// (🟢 rel-ε tier for the Tc solve — see eliashberg.hexa + the L1 selftest).

use "stdlib/material/sim"
use "stdlib/qforge/eliashberg"
use "stdlib/qforge/elph"

// ── L0.1 — thin Allen-Dynes pass-through (f1·f2, ω̄₂ = ω_log → f2 = 1) ───
//
// The 3-scalar entry: hand-fed (λ, ω_log) with μ*. ω̄₂ defaults to ω_log so
// the spectral-shape factor f2 = 1 and only the f1 strong-coupling lift acts.
// Forwards to the verified `allen_dynes_tc` (Allen & Dynes 1975, PRB 12 905,
// canonical ω_log/1.2 prefactor) — this is the form whose published Nb-anchor
// range is Tc = 9.9-13 K (atlas `rtsc_nb_dft_tc_measurement_match`). Zero new
// physics.
pub fn qforge_tc_allen_dynes(lam: float, omega_log_K: float,
                             mu_star: float) -> float {
    return allen_dynes_tc(omega_log_K, lam, mu_star, omega_log_K)
}

// ── L0.2 — full Allen-Dynes pass-through (f1·f2, explicit ω̄₂) ───────────
//
// The 4-scalar entry: caller supplies the mean-square frequency ω̄₂ so the
// spectral-shape correction f2 is active. Direct forward to the verified atom.
pub fn qforge_tc_allen_dynes_full(lam: float, omega_log_K: float,
                                  omega2_K: float, mu_star: float) -> float {
    return allen_dynes_tc(omega_log_K, lam, mu_star, omega2_K)
}

// ── L0.3 — α²F(ω) → Tc, the full engine pipeline ────────────────────────
//
// Collapse a sampled Eliashberg spectral function α²F(ω) into its three
// moments via the verified trapezoid integrator, then feed the full f1·f2
// Allen-Dynes Tc. This is the canonical L0 entry the later layers (L1-L5)
// regress against. Returns 0.0 when the moments are malformed (sentinel
// λ ≤ 0 from the integrator) — no superconductivity predicted / bad input.
pub fn qforge_tc_from_a2f(omega: [float], a2f: [float],
                          mu_star: float) -> float {
    let m = eliashberg_moments_from_a2f(omega, a2f)
    let lam = m[0]
    if lam <= 0.0 { return 0.0 }
    let omega_log_K = m[1]
    let omega2_K = m[2]
    return allen_dynes_tc(omega_log_K, lam, mu_star, omega2_K)
}

// ── L1.1 — α²F(ω) → isotropic Eliashberg Tc (Matsubara eigenvalue solve) ─
//
// The rigorous superconducting Tc: the temperature where the largest
// eigenvalue of the linearized isotropic Migdal-Eliashberg gap kernel equals
// 1 (gap Δ→0⁺). This is the form Allen-Dynes (1975) fit their closed formula
// FROM — L1 solves it directly. Delegates to the verified-eigensolver-backed
// `eliashberg_tc` (stdlib/qforge/eliashberg). `n_mats` = number of positive
// Matsubara frequencies kept (the sharp μ* cutoff); 256–512 is converged for
// conventional λ≲1.5 phonon scales. Returns 0.0 when no SC solution exists in
// the search window (same sentinel as L0).
pub fn qforge_tc_eliashberg(omega: [float], a2f: [float], mu_star: float,
                            n_mats: int) -> float {
    return eliashberg_tc(omega, a2f, mu_star, n_mats)
}

// ── L1.2 — (λ, ω_rep) → isotropic Eliashberg Tc (single-Einstein-mode) ──
//
// When only the scalar coupling λ and a representative phonon frequency are
// known (no sampled spectrum), model α²F as a single Einstein mode at ω_rep:
// λ(ℓ) = λ ω_rep²/(ω_rep²+(2πTℓ)²). Same Matsubara eigenvalue solve. This is
// the apples-to-apples L1 counterpart of qforge_tc_allen_dynes(λ, ω, μ*) and
// the entry the L1 selftest pins for the Eliashberg ≥ Allen-Dynes ordering.
pub fn qforge_tc_eliashberg_from_lambda(lam: float, omega_rep_K: float,
                                        mu_star: float, n_mats: int) -> float {
    return eliashberg_tc_from_lambda(lam, omega_rep_K, mu_star, n_mats)
}

// ── L3.1 — α²F(ω) ASSEMBLY from el-ph matrix elements (BZ double-delta) ──
//
// The QFORGE entry one rung BELOW the spectral function: assemble α²F(ω) itself
// from the electron-phonon matrix elements |g(k,q,ν)|², the phonon frequencies
// ω(q,ν), the electron band energies ε_k, and N(E_F), via the Fermi-surface
// double-delta BZ sum (Gaussian-smeared δ). Delegates to the verified-integrator
// -backed `qforge_a2f_from_elph` (stdlib/qforge/elph). The returned α²F feeds
// straight into qforge_tc_from_a2f / qforge_tc_eliashberg above — L3 produces
// the input L0/L1 consume. NEW physics layer (🟢 rel-ε on synthetic-analytic;
// real QE-DFPT |g| cross-val is the deferred next sub-step). Returns [-1.0] on
// malformed input (the elph assembler sentinel).
pub fn qforge_a2f_from_elph(eps_k: [float], eps_kq: [float], g2: [float],
                            omega_qnu: [float], e_fermi: float, n_ef: float,
                            omega_grid: [float], weight: float,
                            sigma_el: float, sigma_ph: float) -> [float] {
    return qforge_a2f_from_elph_impl(eps_k, eps_kq, g2, omega_qnu, e_fermi,
                                     n_ef, omega_grid, weight,
                                     sigma_el, sigma_ph)
}
