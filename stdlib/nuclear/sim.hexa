// HEXA Standard Library — nuclear/sim
//
// @version 0.6.0
// @capabilities [pure, io]
//
// NUCLEAR.md §6 Phase 4 #1 — N7 hot closed-form post-processing,
// hexa-native port of `stdlib/nuclear/wkb_alpha_decay.py` closed-form
// kernels. Mirror of `stdlib/material/sim.hexa` v0.2.0 precedent
// (BCS / McMillan / Allen-Dynes / WHH + inverse_variance_consensus).
//
// The Python file is kept intact at `stdlib/nuclear/wkb_alpha_decay.py`
// for orchestration + record emission + skip-cascade policy; this hexa
// module ports ONLY the libm-only closed-form kernels (NC1 + NC2 + NC3
// per `docs/notes/2026-05-22-nuclear-9-phase2-stabilization.md` §7).
//
// Surface (pure functions, no syscall):
//   pub fn viola_seaborg_log10_t(Z, Q_alpha_MeV) -> float          // NC1
//   pub fn royer_log10_t(Z, A, Q_alpha_MeV) -> float               // NC2
//   pub fn consensus_alpha(values: [float]) -> Consensus           // NC3
//   pub fn sf_log10_t(Z, A) -> float                               // C1 (SF)
//   pub fn total_halflife(L_alpha, L_sf) -> DecayTotal             // C1 (combine)
//   pub fn c_gate_total_cell(Z, A, Q_alpha_MeV) -> DecayTotal      // C1 (one-shot)
//   pub fn c_gate_window_score(mean_log10_T, lo, hi) -> float       // N11
//   pub fn n11_alpha_cell(Z, A, Q_alpha_MeV, lo, hi) -> NuclideScore// N11
//   pub fn island_weight(Z, N, sigma) -> float                     // C2 (weight)
//   pub fn n11_island_cell(Z,A,Q_α,lo,hi,σ) -> IslandScore         // C2 (composite)
//   pub fn n11_alpha_cell_checked(Z,N,A,Q_α,lo,hi) -> NuclideScore  // G1 (A=Z+N guard)
//   pub fn n11_island_cell_checked(Z,N,A,Q_α,lo,hi,σ) -> IslandScore// G1 (A=Z+N guard)
//   (internal) _write_n11_she_topk — G3 PREDICTED-Q_α Z=119/120 top-K emit
//
// Source formulas (closed-form algebraic identities, not solvers):
//   - Viola-Seaborg 1966 / Sobiczewski-Parkhomenko 2005 refit
//     log10 T₁/₂ [s] = (a·Z + b)/√Q_α + (c·Z + d)
//     a=1.66175  b=-8.5166  c=-0.20228  d=-33.9069
//     Refs: Viola & Seaborg 1966, J Inorg Nucl Chem 28:741;
//           Sobiczewski/Parkhomenko 2005, PRC 72.044316.
//   - Royer 2000 (mass-dependent refinement)
//     log10 T₁/₂ [s] = a + b·A^{1/6}·√Z + c·Z/√Q_α
//     a=-25.31  b=-1.1629  c=1.5864  (even-even nuclei)
//     Refs: Royer 2000, J Phys G 26:1149; arxiv:nucl-th/0510074.
//   - Consensus reducer (NC3) — mean / min / max / spread report
//     across the formula ensemble. Mirrors `_consensus` in
//     `wkb_alpha_decay.py:124-144` verbatim arithmetic.
//
// Cross-stack reuse decision (NC3):
//   stdlib/material/sim.hexa v0.2.0 already ships
//   `inverse_variance_consensus` (weighted by 1/σ²) — a strictly more
//   general kernel. Substituting σ=1 for every formula reduces it to
//   the *unweighted* mean used by the nuclear N7 producer, but the
//   spread / min / max shape this module returns is intentionally
//   *different* from the `Consensus { mean, combined_sigma,
//   n_sources, rel_err_max_pairwise }` struct in material/sim.hexa
//   (the nuclear N7 spread_dex is `max - min` of the formula
//   ensemble, not an inverse-variance combined σ). To avoid coupling
//   two intentionally-distinct semantics across sibling stdlib
//   modules, NC3 is implemented as a **dedicated struct + kernel in
//   this module** rather than a wrapper around material/sim.hexa.
//   The arithmetic is independent — code drift risk noted in the
//   "MIRROR" comment near `consensus_alpha` below.
//
// g3 (honest scope · NUCLEAR.md §7 wet-lab dependency permanent):
//   absorbed = false FOREVER for N7 records. Tier 1 prediction
//   NEVER measurement. The kernel returns numbers only; the
//   Python orchestrator (`wkb_alpha_decay.py`) keeps record-level
//   gate_type / skip-cascade / absorbed policy (R4 invariant
//   carried over per NUCLEAR.md §3.3 + §7).

// ── helpers ────────────────────────────────────────────────────────────

fn _fabs(x: float) -> float { if x < 0.0 { return -x } return x }

fn _fmin(a: float, b: float) -> float { if a < b { return a } return b }

fn _fmax(a: float, b: float) -> float { if a > b { return a } return b }

// Finite-value guard (no native is_nan/is_finite builtin). NaN fails the
// self-equality test; ±inf exceeds the double magnitude ceiling. Used to
// reject a non-finite Q_α before it silently propagates through the kernels.
fn _is_finite(x: float) -> bool {
    if x != x { return false }                 // NaN ≠ itself
    if x > 1.0e308 { return false }            // +inf
    if x < 0.0 - 1.0e308 { return false }      // -inf
    return true
}

// ── (Z,N,A,Q_α) input-consistency guard ────────────────────────────────
//
// gap-audit top-2 silent-failure: a TRANSPOSED (Z,N) — e.g. passing N where
// Z is expected — keeps A=Z+N self-consistent only if the caller also flips
// A, but a partial transpose (Z↔N with A held) violates A=Z+N, and the
// Geiger-Nuttall log10 T scales ~linearly in Z, so a Z↔N swap flips log10 T
// by ≈10× UNDETECTED. We reject any cell whose declared A ≠ Z+N (or Z≤0 /
// N≤0 / non-finite-or-≤0 Q_α) with an honest reason CODE instead of silently
// computing a physically-meaningless number (NUCLEAR.md §3.3 no fabrication).
//
// Reason codes (0 = pass):
//   0 = ok
//   1 = A_N_mismatch          (A ≠ Z + N — likely a transposed/garbled cell)
//   2 = nonpositive_Z_or_N    (Z ≤ 0 or N ≤ 0 — not a physical nuclide)
//   3 = nonfinite_or_nonpos_Q (Q_α NaN/±inf or ≤ 0 — α not energetically allowed)
//   4 = Z_out_of_range        (Z > 130 — catches a FULL Z↔N transpose whose
//                              swapped sum still happens to equal A; no real
//                              element / SHE-funnel cell exceeds Z=130)
//
// The cell scorers below return valid=0 + this reason code; the Python
// orchestrator maps a nonzero reason to an honest error_record / install-
// gated skip rather than emitting a fabricated half-life. (Z, N, A) are
// all passed INDEPENDENTLY so a transposed/stale triple is caught — the
// kernels otherwise derive N=A−Z internally and could never see the
// inconsistency.
let _Z_FUNNEL_MAX: int = 130

fn _anz_reason(Z: int, N: int, A: int, Q_alpha_MeV: float) -> int {
    if A != Z + N { return 1 }      // declared A inconsistent with declared (Z,N)
    if Z <= 0 { return 2 }
    if N <= 0 { return 2 }
    if !_is_finite(Q_alpha_MeV) { return 3 }
    if Q_alpha_MeV <= 0.0 { return 3 }
    if Z > _Z_FUNNEL_MAX { return 4 }  // full Z↔N transpose w/ A self-consistent
    return 0
}

// Human-readable honest reason for a nonzero _anz_reason code (record text).
fn _anz_reason_str(code: int) -> string {
    if code == 1 { return "A_N_mismatch" }
    if code == 2 { return "nonpositive_Z_or_N" }
    if code == 3 { return "nonfinite_or_nonpositive_Q_alpha" }
    if code == 4 { return "Z_out_of_range" }
    return "ok"
}

// ── 1. NC1 — Viola-Seaborg log10 T₁/₂ [s] ──────────────────────────────
//
// log10 T₁/₂ [s] = (a·Z + b)/√Q_α + (c·Z + d)
//
// Domain: even-even heavy α emitters; Q_α > 0 (else formula sign-
// invalid → caller must skip via the Python record path
// `gate_type=install-gated`).
//
// Sentinel: Q_α ≤ 0 returns 0.0 (NaN-free convention — mirror of
// material/sim.hexa `bcs_weak_tc(λ≤0) = 0.0`). Real callers gate on
// the same condition upstream, so the sentinel is never the path the
// nuclear N7 record actually takes.
pub fn viola_seaborg_log10_t(Z: int, Q_alpha_MeV: float) -> float {
    if Q_alpha_MeV <= 0.0 { return 0.0 }
    let a: float =  1.66175
    let b: float = -8.5166
    let c: float = -0.20228
    let d: float = -33.9069
    let Zf = to_float(Z)
    return (a * Zf + b) / sqrt(Q_alpha_MeV) + (c * Zf + d)
}

// ── 2. NC2 — Royer 2000 log10 T₁/₂ [s] ─────────────────────────────────
//
// log10 T₁/₂ [s] = a + b·A^{1/6}·√Z + c·Z/√Q_α
//
// Domain: even-even heavy α emitters; Q_α > 0. A and Z must be > 0
// (parent nuclide). Same sentinel as NC1.
pub fn royer_log10_t(Z: int, A: int, Q_alpha_MeV: float) -> float {
    if Q_alpha_MeV <= 0.0 { return 0.0 }
    let a: float = -25.31
    let b: float = -1.1629
    let c: float =  1.5864
    let Zf = to_float(Z)
    let Af = to_float(A)
    // A^(1/6) via pow(A, 1/6).
    let A_pow_1_6 = pow(Af, 1.0 / 6.0)
    return a + b * A_pow_1_6 * sqrt(Zf) + c * Zf / sqrt(Q_alpha_MeV)
}

// ── 3. NC3 — Cross-formula consensus ───────────────────────────────────
//
// MIRROR of stdlib/material/sim.hexa Consensus struct — keep in sync.
// Distinct semantics: nuclear N7 uses *unweighted* mean + raw spread
// (max-min) instead of inverse-variance combined σ (material/sim.hexa
// `Consensus { mean, combined_sigma, n_sources, rel_err_max_pairwise }`).
// The two structs are intentionally different shapes; do NOT collapse.
//
// Ported from `wkb_alpha_decay.py::_consensus` verbatim:
//   mean = Σx / n
//   min  = min(x)
//   max  = max(x)
//   spread_dex = max - min
//   n    = len(values)
//
// Edge case (n=0): returns ConsensusAlpha { mean=0, min=0, max=0,
// spread_dex=0, n=0 }. Caller should check `n == 0`. In Python the
// equivalent returns a dict with `None` fields; the hexa-native form
// uses the same n-sentinel convention as material/sim.hexa
// `inverse_variance_consensus` (mirror v0.2.0 §5 documented divergence
// from Python `None`).

struct ConsensusAlpha {
    mean:         float,
    min:          float,
    max:          float,
    spread_dex:   float,
    n:            int,
    outlier_count: int,    // members with |x − mean| > 3·spread (Byzantine guard)
    robust_mean:  float,   // mean of the in-bound members (outliers excluded)
}

// ── NC3 outlier (Byzantine-formula) guard ──────────────────────────────
//
// gap-audit top-3 (b): the consensus is an UNWEIGHTED mean across the
// formula ensemble, so a single Byzantine formula (a mis-typed coefficient,
// a wrong-domain refit, a future 3rd predictor that diverges in the SHE
// extrapolation region) silently skews the mean. We FLAG a member whose
// deviation from the consensus of the OTHERS exceeds 3× the OTHERS' spread,
// and report both the count and a robust_mean over the surviving members.
//
// LEAVE-ONE-OUT scale (not |x − global_mean| > 3·global_spread, which is
// mathematically unreachable: a member always sits within ±spread of the
// global mean). For member i: peer_spread = max_{j≠i} − min_{j≠i};
// peer_mean = mean_{j≠i}; flag i iff |x_i − peer_mean| > 3·peer_spread. This
// is robust because the Byzantine member can't inflate the scale it's judged
// against. With n=2 every member's "peers" are a single point (peer_spread=0)
// so no honest outlier call is possible → outlier_count=0 (the current VS,
// Royer pair is never trimmed). The guard activates at n≥3, exactly when one
// Byzantine member could otherwise outvote the 2-member majority. It NEVER
// silently drops a value: robust_mean falls back to the plain mean when no
// member is flagged or when every member would be flagged (n_in=0).
pub fn consensus_alpha(values: [float]) -> ConsensusAlpha {
    let n = len(values)
    if n == 0 {
        return ConsensusAlpha { mean: 0.0, min: 0.0, max: 0.0,
                                spread_dex: 0.0, n: 0,
                                outlier_count: 0, robust_mean: 0.0 }
    }
    let nf = to_float(n)
    let mut sum: float = 0.0
    let mut lo: float = values[0]
    let mut hi: float = values[0]
    let mut i = 0
    while i < n {
        let v = values[i]
        sum = sum + v
        lo = _fmin(lo, v)
        hi = _fmax(hi, v)
        i = i + 1
    }
    let mean = sum / nf
    let spread = hi - lo
    // Leave-one-out Byzantine flag (n≥3). For each member, recompute the
    // peers' mean + spread and test |x_i − peer_mean| > 3·peer_spread.
    let mut n_out = 0
    let mut in_sum: float = 0.0
    let mut n_in = 0
    if n < 3 {
        // too few members to identify an outlier honestly — all in-bound.
        return ConsensusAlpha { mean: mean, min: lo, max: hi,
                                spread_dex: spread, n: n,
                                outlier_count: 0, robust_mean: mean }
    }
    let mut a = 0
    while a < n {
        // peers = all members except a.
        let mut psum: float = 0.0
        let mut plo: float = 0.0
        let mut phi: float = 0.0
        let mut seen = 0
        let mut b = 0
        while b < n {
            if b != a {
                let pv = values[b]
                psum = psum + pv
                if seen == 0 { plo = pv  phi = pv }
                plo = _fmin(plo, pv)
                phi = _fmax(phi, pv)
                seen = seen + 1
            }
            b = b + 1
        }
        let peer_mean = psum / to_float(seen)
        let peer_spread = phi - plo
        let xa = values[a]
        if _fabs(xa - peer_mean) > 3.0 * peer_spread {
            n_out = n_out + 1
        } else {
            in_sum = in_sum + xa
            n_in = n_in + 1
        }
        a = a + 1
    }
    let mut rmean = mean
    if n_out > 0 {
        if n_in > 0 { rmean = in_sum / to_float(n_in) }
    }
    return ConsensusAlpha { mean: mean, min: lo, max: hi,
                            spread_dex: spread, n: n,
                            outlier_count: n_out, robust_mean: rmean }
}

// ── 4. C1 — Spontaneous-fission (SF) competition closed-form ───────────
//
// NUCLEAR.md §4.2 (N7 (c)-gate) + NOVEL probe C1 (exports/nuclear_discovery
// /novel/2026-05-25-novel-probe.md). The landed NC1/NC2/NC3 kernels score
// the α-decay channel ONLY. For Z ≥ 104 spontaneous fission frequently
// DOMINATES, so an α-only T₁/₂ OVERESTIMATES total survival (sim.hexa s4
// self-flag: "SF competing channel NOT modeled here"). C1 closes that flaw
// with a published SF systematics + a partial-rate branching combiner.
//
// ── SF systematics: Ren–Xu 2005 phenomenological formula ───────────────
//
//   log10 T_SF [s] = 21.08
//       + C1·(Z−90−ν)/A
//       + C2·(Z−90−ν)²/A
//       + C3·(Z−90−ν)³/A
//       + C4·(Z−90−ν)·(N−Z−52)²/A
//
//   C1 = -548.825021  C2 = -5.359139  C3 = 0.767379  C4 = -4.282220
//   ν (seniority / blocking term) = 0 even-even · 2 odd-A & odd-odd.
//
//   VERBATIM coefficients — C. Xu & Z. Ren, Phys. Rev. C 71, 014309 (2005)
//   (DOI 10.1103/PhysRevC.71.014309), the generalized phenomenological SF
//   half-life formula for ground states + odd nuclei + fission isomers.
//   Reproduced verbatim in Kiren/Gudennavar/Bubbly 2013, Romanian J. Phys.
//   57, 1335 (arxiv:1301.1767) Eq.(2.4), which pairs it with Viola-Seaborg
//   for exactly the α-vs-SF competition C1 implements. NUCLEAR.md §3.3 no-
//   fabrication: coefficients cited, not refit. Closed-form polynomial in
//   (Z, A, N) — NO transcendental, libm-trivial.
//
// Honest scope (NOVEL C1 caveats · §3.3 · §7):
//   - SF systematics scatter is LARGER than α (±2–3 dex typical, vs α's
//     ±0.5–1 dex). The Ren-Xu fit anchor region is Z≈90–114; extrapolation
//     above is honest but the spread widens.
//   - The ν term captures only the gross even/odd blocking; detailed odd-A
//     hindrance + shape-isomer effects are NOT modeled.
//   - SF dominance for an SHE candidate is a *prediction* (a priority-down-
//     weight hint), NEVER "this nuclide cannot exist" (@D d2). absorbed=
//     false 永久 (R4) — the combiner returns numbers only.

let _SF_C1: float = 0.0 - 548.825021
let _SF_C2: float = 0.0 - 5.359139
let _SF_C3: float =       0.767379
let _SF_C4: float = 0.0 - 4.282220
let _SF_A0: float =      21.08

// ν seniority term: 0 for even-even, 2 for odd-A / odd-odd (Ren-Xu 2005).
// Closed-form parity test on (Z, N) — A=Z+N so odd-A ⇔ Z,N differ in
// parity; odd-odd ⇔ both odd. Even-even ⇔ both even → ν=0, else ν=2.
fn _sf_seniority(Z: int, N: int) -> float {
    let z_even = (Z % 2) == 0
    let n_even = (N % 2) == 0
    if z_even && n_even { return 0.0 }
    return 2.0
}

// ── model_validity_flag — odd-A hindrance / domain classifier ──────────
//
// gap-audit top-3 (a): the α formulas (Viola-Seaborg, Royer) are fit to
// EVEN-EVEN emitters, and the Ren-Xu SF ν=2 seniority term OVER-PREDICTS SF
// dominance for odd-A nuclei. So an odd-A cell whose C2 composite collapses
// to score=0 is INDISTINGUISHABLE from a true SF-dominant even-even cell —
// the Lv-293 / Fl-289 collapse in the funnel output is the symptom. This
// classifier surfaces WHY a score is what it is, as an explicit per-cell
// model-validity flag (NUCLEAR.md §3.4 / s4 odd-A self-caveat).
//
// Codes / strings:
//   0 = "nominal"                       even-even (Z,N both even) — formulas
//                                       are in-domain; score is trustworthy.
//   1 = "odd-A-hindrance-not-modeled"   odd A (Z,N differ in parity) — α
//                                       hindrance + Ren-Xu ν=2 SF over-
//                                       prediction NOT modeled; a score=0 may
//                                       be a MODEL artifact, not true SF dom.
//   2 = "out-of-domain"                 odd-odd (Z,N both odd) — double
//                                       hindrance; furthest from the even-even
//                                       fit domain (worst-case reliability).
fn _model_validity_code(Z: int, N: int) -> int {
    let z_even = (Z % 2) == 0
    let n_even = (N % 2) == 0
    if z_even && n_even { return 0 }   // even-even — nominal
    if z_even != n_even { return 1 }   // odd-A — hindrance not modeled
    return 2                            // odd-odd — out-of-domain
}

fn _model_validity_str(code: int) -> string {
    if code == 0 { return "nominal" }
    if code == 1 { return "odd-A-hindrance-not-modeled" }
    return "out-of-domain"
}

// Ren-Xu 2005 spontaneous-fission log10 T₁/₂ [s] from (Z, A). N = A − Z.
// Domain: heavy / superheavy ground states (anchor Z≈90–114). Pure
// polynomial — no Q-value input needed (SF barrier is implicit in the
// (Z−90)/A systematics). A must be > 0 (sentinel 0.0 mirrors NC1/NC2).
pub fn sf_log10_t(Z: int, A: int) -> float {
    if A <= 0 { return 0.0 }
    let N = A - Z
    let nu = _sf_seniority(Z, N)
    let Af = to_float(A)
    let Zf = to_float(Z)
    let Nf = to_float(N)
    let x = Zf - 90.0 - nu                 // (Z − 90 − ν)
    let asym = Nf - Zf - 52.0              // (N − Z − 52)
    return _SF_A0
        + _SF_C1 * x / Af
        + _SF_C2 * x * x / Af
        + _SF_C3 * x * x * x / Af
        + _SF_C4 * x * asym * asym / Af
}

// ── C1 combiner — competing α + SF partial rates → total survival ──────
//
// Two parallel decay channels add their partial DECAY RATES (λ = ln2/T):
//   λ_total = λ_α + λ_SF   →   T_total = 1 / (λ_α + λ_SF)
// In log10-half-life space (the kernels' native units), with
// L_α = log10 T_α  and  L_SF = log10 T_SF:
//   T_total = 1 / (10^(−L_α) + 10^(−L_SF))
//   log10 T_total = − log10( 10^(−L_α) + 10^(−L_SF) )
// (the ln2 prefactors cancel — partial-half-life combination is exact).
// Branching ratio (fraction decaying via α):
//   b_α = (10^(−L_α)) / (10^(−L_α) + 10^(−L_SF)) = λ_α / λ_total
//   b_SF = 1 − b_α
// This is the honest (c)-gate TOTAL-survival score for SHE: when SF
// dominates (L_SF ≪ L_α) the total half-life collapses toward T_SF and
// b_α → 0, correcting the α-only overestimate (NOVEL C1 rationale).

struct DecayTotal {
    log10_T_alpha_s: float,   // input α log10 T₁/₂ [s] (from NC1/NC2/NC3)
    log10_T_sf_s:    float,   // input SF log10 T₁/₂ [s] (Ren-Xu)
    log10_T_total_s: float,   // combined partial-rate total log10 T₁/₂ [s]
    alpha_branching: float,   // b_α ∈ [0,1] — fraction decaying via α
    sf_branching:    float,   // b_SF = 1 − b_α
    sf_dominates:    int,     // 1 if b_SF > b_α (SF is the faster channel)
}

// Combine an α log10 T₁/₂ with an SF log10 T₁/₂ into the total-survival
// decay record. Pure libm (pow via 10^x). Both inputs are log10 seconds.
pub fn total_halflife(log10_T_alpha_s: float, log10_T_sf_s: float) -> DecayTotal {
    // rate ∝ 10^(−log10 T)  (drop the common ln2 — cancels in branching;
    // and 1/(Σ rate) gives the partial-half-life total exactly).
    let r_alpha = pow(10.0, 0.0 - log10_T_alpha_s)
    let r_sf    = pow(10.0, 0.0 - log10_T_sf_s)
    let r_tot   = r_alpha + r_sf
    // log10 T_total = − log10(r_tot)  (r_tot = 1/T_total).
    let l_tot = 0.0 - (log(r_tot) / log(10.0))
    let b_alpha = r_alpha / r_tot
    let b_sf = r_sf / r_tot
    let mut dom = 0
    if b_sf > b_alpha { dom = 1 }
    return DecayTotal {
        log10_T_alpha_s: log10_T_alpha_s,
        log10_T_sf_s:    log10_T_sf_s,
        log10_T_total_s: l_tot,
        alpha_branching: b_alpha,
        sf_branching:    b_sf,
        sf_dominates:    dom,
    }
}

// One-shot (c)-gate total-survival from (Z, A, Q_α): chains NC1+NC2+NC3
// (α consensus) ⊕ Ren-Xu SF → DecayTotal. The honest C1 (c)-gate score.
// Q_α ≤ 0 → caller honest-skips (sentinel: α set to SF so b_α=0 reported,
// but real callers gate on Q_α upstream per §3.3).
pub fn c_gate_total_cell(Z: int, A: int, Q_alpha_MeV: float) -> DecayTotal {
    let l_sf = sf_log10_t(Z, A)
    if Q_alpha_MeV <= 0.0 {
        // No cited Q_α → α channel unscored; report SF-only total honestly.
        return total_halflife(l_sf, l_sf)
    }
    let vs = viola_seaborg_log10_t(Z, Q_alpha_MeV)
    let ro = royer_log10_t(Z, A, Q_alpha_MeV)
    let v: [float] = [vs, ro]
    let c = consensus_alpha(v)
    return total_halflife(c.mean, l_sf)
}

// ── 4b. N11 — (Z,N) funnel (c)-gate half-life score ────────────────────
//
// NUCLEAR.md §6.2 (N11 funnel cohort) — mirror of RTSC.md §9.10 N5
// compositional-explorer, transposed to ELEMENTAL (Z,N) discovery.
// N11 enumerates a bounded (Z,N) candidate strip and ranks each cell by
// a composite of the available 5-gate scores. Only the (c) gate
// (α-decay half-life) is closed-form here — it reuses NC1+NC2+NC3 above.
// The (a)/(b)/(d)/(e) gates are install-gated (N6 HFB / N9 shell-model
// are external-binary B-path) and so contribute a neutral default; the
// Python orchestrator (`n11_funnel.py`) owns gate composition + the
// install-gated/sim skip-cascade per cell + R4 record emission.
//
// (c)-gate score design (closed-form, NUCLEAR.md §3.4 SHE μs-ms window):
//   The accelerator-priority sweet spot is a half-life LONG enough to
//   survive recoil-separator transit (~μs floor, log10 T ≳ -6) yet
//   SHORT enough that the implant-decay correlation chain is timed-out
//   tractable (~s ceiling, log10 T ≲ +3 for SHE recoil tagging). We
//   score a cell by a triangular window peaking at the center of that
//   log10-T band, normalised to [0,1]. This is a HEURISTIC priority
//   weight, NOT a measurement — absorbed=false永久 (R4, §7).
//
//   center = (lo + hi) / 2   half_width = (hi - lo) / 2
//   raw    = 1 - |mean_log10_T - center| / half_width   (clamp ≥ 0)
//
// Default band lo=-6.0 (μs separator-transit floor) hi=+3.0 (recoil-
// tagging ceiling) → center=-1.5, half_width=4.5. Caller may pass a
// different band (drip-line strips want a wider/longer window).

struct NuclideScore {
    Z:               int,
    A:               int,
    Q_alpha_MeV:     float,
    mean_log10_T_s:  float,
    spread_dex:      float,
    c_gate_score:    float,
    valid:           int,    // 1 = scored, 0 = invalid (caller honest-skips)
    reason:          int,    // _anz_reason code (0=ok; 1/2/3 honest-skip cause)
}

// (c)-gate priority window score for log10 T₁/₂ [s] vs. an accelerator
// band [lo, hi]. Triangular peak at band center, clamped to [0,1].
pub fn c_gate_window_score(mean_log10_T_s: float, lo: float, hi: float) -> float {
    if hi <= lo { return 0.0 }
    let center = (lo + hi) / 2.0
    let half_width = (hi - lo) / 2.0
    let dist = _fabs(mean_log10_T_s - center)
    let raw = 1.0 - dist / half_width
    if raw < 0.0 { return 0.0 }
    return raw
}

// Full N11 (c)-gate cell scorer: chains NC1 (Viola-Seaborg) + NC2
// (Royer) → NC3 consensus → window score. Q_α ≤ 0 returns valid=0 so
// the Python orchestrator can emit gate_type=install-gated honestly
// (NUCLEAR.md §3.3 — never fabricate Q_α; honest-skip instead).
pub fn n11_alpha_cell(Z: int, A: int, Q_alpha_MeV: float,
                      band_lo: float, band_hi: float) -> NuclideScore {
    if Q_alpha_MeV <= 0.0 {
        return NuclideScore { Z: Z, A: A, Q_alpha_MeV: Q_alpha_MeV,
                              mean_log10_T_s: 0.0, spread_dex: 0.0,
                              c_gate_score: 0.0, valid: 0, reason: 3 }
    }
    let vs = viola_seaborg_log10_t(Z, Q_alpha_MeV)
    let ro = royer_log10_t(Z, A, Q_alpha_MeV)
    let v: [float] = [vs, ro]
    let c = consensus_alpha(v)
    let score = c_gate_window_score(c.mean, band_lo, band_hi)
    return NuclideScore { Z: Z, A: A, Q_alpha_MeV: Q_alpha_MeV,
                          mean_log10_T_s: c.mean, spread_dex: c.spread_dex,
                          c_gate_score: score, valid: 1, reason: 0 }
}

// (Z,N,A)-EXPLICIT validated N11 (c)-gate cell. Runs the _anz_reason guard
// (A=Z+N consistency · positive Z,N · finite positive Q_α) FIRST; on any
// nonzero reason it returns an honest valid=0 record carrying the reason
// code instead of silently computing on a transposed/garbled triple
// (gap-audit top-2). On reason=0 it delegates to n11_alpha_cell.
pub fn n11_alpha_cell_checked(Z: int, N: int, A: int, Q_alpha_MeV: float,
                              band_lo: float, band_hi: float) -> NuclideScore {
    let reason = _anz_reason(Z, N, A, Q_alpha_MeV)
    if reason != 0 {
        return NuclideScore { Z: Z, A: A, Q_alpha_MeV: Q_alpha_MeV,
                              mean_log10_T_s: 0.0, spread_dex: 0.0,
                              c_gate_score: 0.0, valid: 0, reason: reason }
    }
    return n11_alpha_cell(Z, A, Q_alpha_MeV, band_lo, band_hi)
}

// ── 4c. C2 — shell-gap-aware island-of-stability weighting ─────────────
//
// NUCLEAR.md §6.2 (N11 composite) + NOVEL probe C2 (exports/nuclear_
// discovery/novel/2026-05-25-novel-probe.md). The landed N11 composite is
// a FLAT (a)(c) average; C2 replaces the flat weighting with a magic-
// number-distance Gaussian so candidates near the predicted island of
// stability rank higher, AND sources the (c)-score from C1's α⊕SF T_total
// (not α-only) so SF-dominated SHE are honestly down-weighted.
//
// ── Shell-closure magic numbers (cited) ────────────────────────────────
//
//   Proton magic Z ∈ {82, 114, 120, 126}   Neutron magic N ∈ {126, 184}
//
//   Z=82 / N=126 are the established (²⁰⁸Pb doubly-magic) closures. The SHE
//   proton-closure candidates Z=114 (macro-micro / FRDM Möller-Nix), Z=120
//   & Z=126 (self-consistent RMF/HFB) are MODEL-DEPENDENT PREDICTIONS — no
//   consensus on which is the true proton magic number. N=184 is the
//   strong-consensus neutron closure. The canonical doubly-magic island
//   candidate is ²⁹⁸Fl (Z=114, N=184).
//   Refs: Sobiczewski & Pomorski 2007, Prog. Part. Nucl. Phys. 58, 292
//         (arxiv:nucl-th/0610090, shell-closure review);
//         Samanta 2008 "Superheavy elements in the magic islands"
//         (arxiv:0803.4151); Oganessian 2017 IPAC island-of-stability
//         (proceedings.jacow.org/ipac2017/fryaa1). Z=120/126 RMF/HFB:
//         Bender/Rutz/Reinhard/Maruhn 1999, PRC 60, 034304.
//
// Honest scope (NOVEL C2 caveats · §3.3 · §7 · @D d2):
//   - The proton magic number itself is a model-dependent PREDICTION
//     (Z=114 vs 120 vs 126 is unresolved) — the weight is a *proximity
//     hint*, NEVER "near the island ⇒ this nuclide is discovered/stable".
//   - σ (Gaussian width) is a HYPERPARAMETER (default 6.0 in (Z,N)-space
//     shell units); a different σ reorders mid-field candidates. Caller may
//     override. The weight is bounded (0,1]; it RE-RANKS, never gates.
//   - absorbed=false 永久 (R4). The composite is an accelerator-priority
//     heuristic, not a stability claim.

let _MAGIC_N_184: float = 184.0
let _MAGIC_N_126: float = 126.0
let _MAGIC_Z_82:  float =  82.0
let _MAGIC_Z_114: float = 114.0
let _MAGIC_Z_120: float = 120.0
let _MAGIC_Z_126: float = 126.0
let _ISLAND_SIGMA_DEFAULT: float = 6.0

// nearest |x − magic| over a 4-element proton magic set.
fn _min_dist_z(Zf: float) -> float {
    let d82  = _fabs(Zf - _MAGIC_Z_82)
    let d114 = _fabs(Zf - _MAGIC_Z_114)
    let d120 = _fabs(Zf - _MAGIC_Z_120)
    let d126 = _fabs(Zf - _MAGIC_Z_126)
    return _fmin(_fmin(d82, d114), _fmin(d120, d126))
}

// nearest |x − magic| over the 2-element neutron magic set.
fn _min_dist_n(Nf: float) -> float {
    let d126 = _fabs(Nf - _MAGIC_N_126)
    let d184 = _fabs(Nf - _MAGIC_N_184)
    return _fmin(d126, d184)
}

// Island-of-stability proximity weight ∈ (0,1]: a 2-D Gaussian on the
// shell-distance d² = dZ² + dN² (dZ/dN = distance to the nearest proton/
// neutron magic number). weight = exp(−d²/(2σ²)). At a doubly-magic point
// (dZ=dN=0) weight=1; it decays smoothly with shell distance. σ is a
// hyperparameter (default 6.0 shell units). σ ≤ 0 → sentinel 0.0.
pub fn island_weight(Z: int, N: int, sigma: float) -> float {
    if sigma <= 0.0 { return 0.0 }
    let Zf = to_float(Z)
    let Nf = to_float(N)
    let dz = _min_dist_z(Zf)
    let dn = _min_dist_n(Nf)
    let d2 = dz * dz + dn * dn
    return exp(0.0 - d2 / (2.0 * sigma * sigma))
}

// ── C2 composite — C1 (c)-total-survival × island weight ───────────────
//
// The NOVEL C2 core: fold the magic-number proximity weight into the N11
// composite, and source the (c)-score from C1's α⊕SF T_total (not α-only).
//   c_total_score = c_gate_window_score(log10_T_total, band)   ← C1
//   island        = island_weight(Z, N, σ)                     ← C2
//   composite     = c_total_score · island
// vs the C1-less baseline composite = c_gate_score (α-only) · 0.2 flat.

struct IslandScore {
    Z:                  int,
    A:                  int,
    Q_alpha_MeV:        float,
    log10_T_total_s:    float,   // C1 α⊕SF total (the honest (c) source)
    alpha_branching:    float,   // C1 branching (SF-dominance visibility)
    sf_dominates:       int,     // C1 flag
    c_total_score:      float,   // window score on the C1 total
    island_weight:      float,   // C2 magic-number Gaussian weight
    composite_score:    float,   // c_total_score · island_weight
    valid:              int,     // 1 = scored, 0 = invalid (honest-skip)
    reason:             int,     // _anz_reason code (0=ok; 1/2/3 skip cause)
}

// Full C2 island-weighted (c)-gate cell. Chains C1 c_gate_total_cell
// (α⊕SF) → window score on the TOTAL log10 T → × island_weight. Q_α ≤ 0
// → valid=0 (caller emits install-gated honestly · §3.3 no fabrication).
pub fn n11_island_cell(Z: int, A: int, Q_alpha_MeV: float,
                       band_lo: float, band_hi: float,
                       sigma: float) -> IslandScore {
    let N = A - Z
    if Q_alpha_MeV <= 0.0 {
        return IslandScore { Z: Z, A: A, Q_alpha_MeV: Q_alpha_MeV,
                             log10_T_total_s: 0.0, alpha_branching: 0.0,
                             sf_dominates: 0, c_total_score: 0.0,
                             island_weight: 0.0, composite_score: 0.0,
                             valid: 0, reason: 3 }
    }
    let d = c_gate_total_cell(Z, A, Q_alpha_MeV)    // C1 α⊕SF total
    let c_total = c_gate_window_score(d.log10_T_total_s, band_lo, band_hi)
    let iw = island_weight(Z, N, sigma)
    return IslandScore { Z: Z, A: A, Q_alpha_MeV: Q_alpha_MeV,
                         log10_T_total_s: d.log10_T_total_s,
                         alpha_branching: d.alpha_branching,
                         sf_dominates: d.sf_dominates,
                         c_total_score: c_total, island_weight: iw,
                         composite_score: c_total * iw, valid: 1, reason: 0 }
}

// (Z,N,A)-EXPLICIT validated C2 island cell. Runs the _anz_reason guard
// (A=Z+N consistency · positive Z,N · finite positive Q_α) FIRST; on any
// nonzero reason it returns an honest valid=0 record carrying the reason
// code instead of silently computing on a transposed/garbled triple
// (gap-audit top-2). On reason=0 it delegates to n11_island_cell.
pub fn n11_island_cell_checked(Z: int, N: int, A: int, Q_alpha_MeV: float,
                               band_lo: float, band_hi: float,
                               sigma: float) -> IslandScore {
    let reason = _anz_reason(Z, N, A, Q_alpha_MeV)
    if reason != 0 {
        return IslandScore { Z: Z, A: A, Q_alpha_MeV: Q_alpha_MeV,
                             log10_T_total_s: 0.0, alpha_branching: 0.0,
                             sf_dominates: 0, c_total_score: 0.0,
                             island_weight: 0.0, composite_score: 0.0,
                             valid: 0, reason: reason }
    }
    return n11_island_cell(Z, A, Q_alpha_MeV, band_lo, band_hi, sigma)
}

// ── reference-panel runner ─────────────────────────────────────────────
//
// Mirror of material/sim.hexa `_emit_row` + `main` pattern: emit a
// small reference panel for the Phase 2 audit's two simulation cells
// (²³⁸U and ²⁹⁴Og), plus a couple of mid-Q regime spot-checks.
// Cross-validation is a textual diff against `wkb_alpha_decay.py`
// stdout (or its JSON record's `prediction.viola_seaborg_log10_T_s`
// + `prediction.royer_log10_T_s` fields).

fn _emit_row(name: string, Z: int, A: int, Q_alpha_MeV: float) {
    let vs = viola_seaborg_log10_t(Z, Q_alpha_MeV)
    let ro = royer_log10_t(Z, A, Q_alpha_MeV)
    let v: [float] = [vs, ro]
    let c = consensus_alpha(v)
    println("  · " + name +
            ": VS=" + to_string(vs) +
            "  Royer=" + to_string(ro) +
            "  mean=" + to_string(c.mean) +
            "  spread=" + to_string(c.spread_dex) + " dex")
}

fn _emit_n11(name: string, Z: int, A: int, Q_alpha_MeV: float) {
    let s = n11_alpha_cell(Z, A, Q_alpha_MeV, 0.0 - 6.0, 3.0)
    println("  · " + name +
            ": mean_log10_T=" + to_string(s.mean_log10_T_s) +
            "  c_gate_score=" + to_string(s.c_gate_score) +
            "  valid=" + to_string(s.valid))
}

// C1 demo row: α-consensus ⊕ Ren-Xu SF → total survival + branching.
fn _emit_c1(name: string, Z: int, A: int, Q_alpha_MeV: float) {
    let d = c_gate_total_cell(Z, A, Q_alpha_MeV)
    let mut dom = "alpha"
    if d.sf_dominates == 1 { dom = "SF" }
    println("  · " + name +
            ": L_alpha=" + to_string(d.log10_T_alpha_s) +
            "  L_SF=" + to_string(d.log10_T_sf_s) +
            "  L_total=" + to_string(d.log10_T_total_s) +
            "  b_alpha=" + to_string(d.alpha_branching) +
            "  dominant=" + dom)
}

// Guard demo row: (Z,N,A)-explicit checked cell — shows valid + reason for
// a transposed/inconsistent triple vs. a clean one (gap-audit top-2).
fn _emit_guard(name: string, Z: int, N: int, A: int, Q_alpha_MeV: float) {
    let s = n11_island_cell_checked(Z, N, A, Q_alpha_MeV, 0.0 - 6.0, 3.0, 6.0)
    println("  · " + name +
            ": Z=" + to_string(Z) + " N=" + to_string(N) + " A=" + to_string(A) +
            "  valid=" + to_string(s.valid) +
            "  reason=" + to_string(s.reason) +
            " (" + _anz_reason_str(s.reason) + ")" +
            "  composite=" + to_string(s.composite_score))
}

// ── N11 top-K JSON record emit (NUCLEAR.md §6.1 schema) ─────────────────
//
// Renders one scored (Z,N) cell as a JSON object string. gate_type +
// absorbed=false hardcoded per R4 (§3.1). Q_α here is from the CITED
// table only (caller never passes a fabricated value — §3.3).
fn _n11_cell_json(name: string, Z: int, A: int, Q_alpha_MeV: float,
                  Q_cite: string) -> string {
    let s = n11_alpha_cell(Z, A, Q_alpha_MeV, 0.0 - 6.0, 3.0)
    let N = A - Z
    return "    {\n" +
        "      \"name\": \"" + name + "\",\n" +
        "      \"Z\": " + to_string(Z) +
        ", \"N\": " + to_string(N) +
        ", \"A\": " + to_string(A) + ",\n" +
        "      \"Q_alpha_MeV\": " + to_string(Q_alpha_MeV) + ",\n" +
        "      \"Q_alpha_source\": \"" + Q_cite + "\",\n" +
        "      \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "      \"absorbed\": false,\n" +
        "      \"prediction\": { \"consensus_mean_log10_T_s\": " +
        to_string(s.mean_log10_T_s) +
        ", \"consensus_spread_dex\": " + to_string(s.spread_dex) + " },\n" +
        "      \"scores\": { \"c_gate_score\": " +
        to_string(s.c_gate_score) +
        ", \"gate_coverage\": 0.2, \"composite_score\": " +
        to_string(s.c_gate_score * 0.2) + " }\n" +
        "    }"
}

// Build + write the N11 top-K record to <out_dir>/top_k.json. Returns the
// path written. The (Z,N) candidate strip here is the cited-Q_α SHE/heavy
// shortlist (sorted by c_gate_score descending — see ordering below).
fn _write_n11_topk(out_dir: string) -> string {
    let path = out_dir + "/top_k.json"

    // Cited cells, pre-ordered by descending c_gate_score (closest to the
    // accelerator band center -1.5 ranks first): Lv-293 > Og-294 > Fl-289.
    let rows: [string] = [
        _n11_cell_json("Lv-293", 116, 293, 10.54,
            "measured E_alpha first-detection (Lv->Fl) 10.54 MeV"),
        _n11_cell_json("Og-294", 118, 294, 11.65,
            "NUBASE2020 / discovery 11.65 MeV (Phase2 anchor)"),
        _n11_cell_json("Fl-289", 114, 289, 9.71,
            "measured decay energy 1998 Dubna 9.71 MeV"),
    ]
    let mut body = "[\n"
    let mut i = 0
    while i < len(rows) {
        body = body + rows[i]
        if i + 1 < len(rows) { body = body + "," }
        body = body + "\n"
        i = i + 1
    }
    body = body + "  ]"

    let json = "{\n" +
        "  \"domain\": \"nuclear\",\n" +
        "  \"verb\": \"verify\",\n" +
        "  \"kind\": \"n11_zn_funnel\",\n" +
        "  \"producer\": \"sim.hexa@nuclear-N11\",\n" +
        "  \"absorbed\": false,\n" +
        "  \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "  \"provisional\": true,\n" +
        "  \"query\": { \"Z_range\": [114, 122], \"N_range\": [170, 184], " +
        "\"accelerator_band_log10_s\": [-6.0, 3.0] },\n" +
        "  \"top_k_candidates\": " + body + ",\n" +
        "  \"scope_caveats\": [\n" +
        "    \"(s1) Closed-form HEURISTIC over the (c) alpha-decay " +
        "half-life gate only; (a)(b)(d)(e) gates install-gated (N6 HFB / " +
        "N9 shell-model are B-path).\",\n" +
        "    \"(s2) NUCLEAR.md 3.3 NO fabrication: Q_alpha from a CITED " +
        "table only (AME2020 / NUBASE2020 measured); uncited (Z,N) cells " +
        "honest-skip install-gated.\",\n" +
        "    \"(s3) absorbed=false 永久. 'Z=119 후보일 가능성' != " +
        "'Z=119 후보임' != 'Z=119 발견됨'. (d) production sigma + (e) " +
        "recoil-separator detection wet-lab dependent permanently.\"\n" +
        "  ],\n" +
        "  \"citations\": [\n" +
        "    \"Viola & Seaborg 1966 J Inorg Nucl Chem 28:741 (NC1)\",\n" +
        "    \"Sobiczewski/Parkhomenko 2005 PRC 72.044316 (VS refit)\",\n" +
        "    \"Royer 2000 J Phys G 26:1149 arxiv:nucl-th/0510074 (NC2)\",\n" +
        "    \"arxiv:2105.01035 AME2020 (Q_alpha source)\",\n" +
        "    \"NUBASE2020 Kondev et al Chinese Phys C 45:030001\",\n" +
        "    \"Poenaru & Gherghescu 2017 arxiv:1706.04068 (SHE context)\",\n" +
        "    \"NUCLEAR.md 6.2 (N11) + RTSC.md 9.10 (N5 pattern)\"\n" +
        "  ],\n" +
        "  \"recommendation\": \"top_k is an accelerator beam-time " +
        "priority shortlist. absorbed=true requires GSI/JINR/RIKEN beam " +
        "+ SHIP/DGFRS/GARIS detection + IUPAC priority — none from sim " +
        "(NUCLEAR.md 7). '가능성' != '임'.\"\n" +
        "}\n"

    write_file(path, json)
    return path
}

// ── C2 island-weighted top-K JSON cell (NUCLEAR.md §6.1 + C2) ───────────
//
// Renders one C2 IslandScore (Z,N) cell: C1 α⊕SF total-survival sourced
// (c)-score × island_weight Gaussian. gate_type + absorbed=false hardcoded
// (R4). Q_α from CITED table only (§3.3 no fabrication). σ = caller default.
fn _island_cell_json(name: string, Z: int, A: int, Q_alpha_MeV: float,
                     sigma: float, Q_cite: string) -> string {
    let s = n11_island_cell(Z, A, Q_alpha_MeV, 0.0 - 6.0, 3.0, sigma)
    let N = A - Z
    let mut dom = "alpha"
    if s.sf_dominates == 1 { dom = "SF" }
    // G2(a) model-validity flag: distinguishes a model-artifact score=0
    // (odd-A Ren-Xu ν=2 SF over-prediction) from a true even-even SF
    // dominance — the Lv-293 / Fl-289 funnel collapse (gap-audit top-3a).
    let mv = _model_validity_code(Z, N)
    // G2(b) α-formula ensemble health: outlier_count flags a Byzantine
    // member in the unweighted consensus (0 for the current VS,Royer pair).
    let vs = viola_seaborg_log10_t(Z, Q_alpha_MeV)
    let ro = royer_log10_t(Z, A, Q_alpha_MeV)
    let cv: [float] = [vs, ro]
    let ca = consensus_alpha(cv)
    return "    {\n" +
        "      \"name\": \"" + name + "\",\n" +
        "      \"Z\": " + to_string(Z) +
        ", \"N\": " + to_string(N) +
        ", \"A\": " + to_string(A) + ",\n" +
        "      \"Q_alpha_MeV\": " + to_string(Q_alpha_MeV) + ",\n" +
        "      \"Q_alpha_source\": \"" + Q_cite + "\",\n" +
        "      \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "      \"absorbed\": false,\n" +
        "      \"prediction\": { \"log10_T_total_s_alpha_sf\": " +
        to_string(s.log10_T_total_s) +
        ", \"alpha_branching\": " + to_string(s.alpha_branching) +
        ", \"dominant_channel\": \"" + dom + "\"" +
        ", \"alpha_consensus_outlier_count\": " + to_string(ca.outlier_count) +
        " },\n" +
        "      \"scores\": { \"c_total_score\": " +
        to_string(s.c_total_score) +
        ", \"island_weight\": " + to_string(s.island_weight) +
        ", \"composite_score\": " + to_string(s.composite_score) +
        ", \"model_validity_flag\": \"" + _model_validity_str(mv) + "\"" +
        " }\n" +
        "    }"
}

// Build + write the C2 island-weighted top-K record. Rows are emitted in
// DESCENDING composite_score (C1 α⊕SF total × C2 island weight). σ default.
fn _write_n11_island_topk(out_dir: string, sigma: float) -> string {
    let path = out_dir + "/top_k_island.json"

    // Cited measured-Q_α cells. Pre-ordered by descending composite_score
    // (computed below; ordering noted in the demo panel + NUCLEAR.log).
    let rows: [string] = [
        _island_cell_json("Og-294", 118, 294, 11.65, sigma,
            "NUBASE2020 / discovery 11.65 MeV (Phase2 anchor)"),
        _island_cell_json("Fl-289", 114, 289, 9.71, sigma,
            "measured decay energy 1998 Dubna 9.71 MeV"),
        _island_cell_json("Lv-293", 116, 293, 10.54, sigma,
            "measured E_alpha first-detection (Lv->Fl) 10.54 MeV"),
    ]
    let mut body = "[\n"
    let mut i = 0
    while i < len(rows) {
        body = body + rows[i]
        if i + 1 < len(rows) { body = body + "," }
        body = body + "\n"
        i = i + 1
    }
    body = body + "  ]"

    let json = "{\n" +
        "  \"domain\": \"nuclear\",\n" +
        "  \"verb\": \"verify\",\n" +
        "  \"kind\": \"n11_zn_funnel_island\",\n" +
        "  \"producer\": \"sim.hexa@nuclear-N11-C2\",\n" +
        "  \"absorbed\": false,\n" +
        "  \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "  \"provisional\": true,\n" +
        "  \"query\": { \"Z_range\": [114, 122], \"N_range\": [170, 184], " +
        "\"accelerator_band_log10_s\": [-6.0, 3.0], " +
        "\"island_sigma\": " + to_string(sigma) + ", " +
        "\"magic_Z\": [82, 114, 120, 126], \"magic_N\": [126, 184] },\n" +
        "  \"top_k_candidates\": " + body + ",\n" +
        "  \"scope_caveats\": [\n" +
        "    \"(s1) C2 composite = C1 alpha+SF TOTAL-survival window score " +
        "x island_weight Gaussian. (c)-source is NO LONGER alpha-only " +
        "(C1 closes that flaw); (a)(b)(d)(e) gates still install-gated.\",\n" +
        "    \"(s2) Proton magic number is MODEL-DEPENDENT (Z=114 vs 120 vs " +
        "126 unresolved) — island_weight is a proximity HINT, never " +
        "'near island ⇒ discovered/stable'. sigma is a hyperparameter.\",\n" +
        "    \"(s3) NUCLEAR.md 3.3 NO fabrication: Q_alpha CITED only " +
        "(AME2020/NUBASE2020). SF systematics scatter +-2-3 dex; SF " +
        "dominance is a priority-down-weight PREDICTION (@D d2).\",\n" +
        "    \"(s4) absorbed=false 永久. 'Z=119 후보일 가능성' != '발견됨'. " +
        "(d) production sigma + (e) recoil detection wet-lab permanent.\"\n" +
        "  ],\n" +
        "  \"citations\": [\n" +
        "    \"Viola & Seaborg 1966 J Inorg Nucl Chem 28:741 (NC1)\",\n" +
        "    \"Royer 2000 J Phys G 26:1149 arxiv:nucl-th/0510074 (NC2)\",\n" +
        "    \"C. Xu & Z. Ren PRC 71 014309 (2005) (C1 SF systematics)\",\n" +
        "    \"Kiren/Gudennavar/Bubbly 2013 Rom J Phys 57:1335 arxiv:1301.1767\",\n" +
        "    \"Sobiczewski & Pomorski 2007 PPNP 58:292 arxiv:nucl-th/0610090 (shell closures)\",\n" +
        "    \"Samanta 2008 arxiv:0803.4151 (magic islands) · Bender+ 1999 PRC 60:034304\",\n" +
        "    \"arxiv:2105.01035 AME2020 · NUBASE2020 Kondev+ Chin Phys C 45:030001\"\n" +
        "  ],\n" +
        "  \"recommendation\": \"C2 island-weighted accelerator priority " +
        "shortlist. absorbed=true requires GSI/JINR/RIKEN beam + detection " +
        "+ IUPAC priority — none from sim (NUCLEAR.md 7). '가능성' != '임'.\"\n" +
        "}\n"

    write_file(path, json)
    return path
}

// ── 4d. G3 — PREDICTED-Q_α SHE injection (Z=119–122 unlock) ─────────────
//
// gap-audit top-1 (highest impact · the @goal-completing step). The landed
// C2 funnel only scores 3 ALREADY-KNOWN nuclides (Og-294/Lv-293/Fl-289)
// because the headline targets Z=119–122 had no MEASURED Q_α to feed the (c)
// gate, so they were honest-skipped. The @goal — "rank novel Z>118
// candidates" — was therefore never actually met.
//
// G3 injects CITED PREDICTED Q_α (band midpoints) from demiurge
// exports/nuclear_discovery/research/2026-05-25-she-driplinelit.md §3 — a
// literature shortlist of Z=119/120 targets with Q_α bands + arxiv citations.
// Each predicted-input cell is flagged `predicted_input: true` and carries an
// explicit Q_alpha_source = "PREDICTED via <arxiv:...>, NOT measured" so the
// prediction-vs-measurement boundary is never blurred (NUCLEAR.md §3.3).
//
// HONEST SOURCING (§3.3 · @D d6 no forced numbers):
//   - Only the cited band MIDPOINTS are used; the band itself is recorded.
//   - A target whose Q_α is NOT a numeric band in the research note is
//     honest-SKIPPED, NOT fabricated:
//       · ²⁹³120 (rank 7): "Q_α 높음" qualitative only → SKIP.
//       · ²⁹⁸120 (rank 6): "N=178 deformed magic", no Q_α band given → SKIP.
//       · Z=121, Z=122: NO cited Q_α anywhere in the note → SKIP. This is
//         the honest answer for those Z — out-of-scope ≠ impossible (@D d2);
//         they re-enter the funnel the moment a cited Q_α band exists.
//   - Q_α is mass-model dependent (ΔQ_α ~0.3–1.0 MeV across FRDM/WS4/SkyHFB/
//     KTUY/BSk; note §3.1) — the band width IS the honest uncertainty.
//
// Cited predicted cells (research note §3 table):
//   ²⁹⁵119 (Z=119,N=176,A=295)  Q_α 12.5–13.4 → mid 12.95  arxiv:2604.19325, 2311.07145
//   ²⁹³119 (Z=119,N=174,A=293)  Q_α 12.8–13.6 → mid 13.20  arxiv:2604.19325, 2511.18337
//   ²⁹⁵120 (Z=120,N=175,A=295)  Q_α 13.0–13.7 → mid 13.35  arxiv:2604.09287, 2601.21317
//   ²⁹⁷120 (Z=120,N=177,A=297)  Q_α 12.9–13.5 → mid 13.20  arxiv:2604.09287, 2601.21317

// Render one SHE (Z,N,A) cell with the G1 (Z,N,A,Q_α) guard + G2 flags +
// an explicit measured/predicted provenance. predicted=1 stamps
// `predicted_input: true`. On a guard failure (valid=0) the honest reason is
// emitted instead of a fabricated score (§3.3).
fn _she_cell_json(name: string, Z: int, N: int, A: int, Q_alpha_MeV: float,
                  sigma: float, predicted: int,
                  Q_cite: string, Q_band: string) -> string {
    let s = n11_island_cell_checked(Z, N, A, Q_alpha_MeV, 0.0 - 6.0, 3.0, sigma)
    let mv = _model_validity_code(Z, N)
    let mut dom = "alpha"
    if s.sf_dominates == 1 { dom = "SF" }
    let mut pred = "false"
    if predicted == 1 { pred = "true" }
    let vs = viola_seaborg_log10_t(Z, Q_alpha_MeV)
    let ro = royer_log10_t(Z, A, Q_alpha_MeV)
    let cv: [float] = [vs, ro]
    let ca = consensus_alpha(cv)
    return "    {\n" +
        "      \"name\": \"" + name + "\",\n" +
        "      \"Z\": " + to_string(Z) +
        ", \"N\": " + to_string(N) +
        ", \"A\": " + to_string(A) + ",\n" +
        "      \"Q_alpha_MeV\": " + to_string(Q_alpha_MeV) + ",\n" +
        "      \"Q_alpha_band_MeV\": \"" + Q_band + "\",\n" +
        "      \"Q_alpha_source\": \"" + Q_cite + "\",\n" +
        "      \"predicted_input\": " + pred + ",\n" +
        "      \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "      \"absorbed\": false,\n" +
        "      \"valid\": " + to_string(s.valid) +
        ", \"guard_reason\": \"" + _anz_reason_str(s.reason) + "\",\n" +
        "      \"prediction\": { \"log10_T_total_s_alpha_sf\": " +
        to_string(s.log10_T_total_s) +
        ", \"alpha_branching\": " + to_string(s.alpha_branching) +
        ", \"dominant_channel\": \"" + dom + "\"" +
        ", \"alpha_consensus_outlier_count\": " + to_string(ca.outlier_count) +
        " },\n" +
        "      \"scores\": { \"c_total_score\": " +
        to_string(s.c_total_score) +
        ", \"island_weight\": " + to_string(s.island_weight) +
        ", \"composite_score\": " + to_string(s.composite_score) +
        ", \"model_validity_flag\": \"" + _model_validity_str(mv) + "\"" +
        " }\n" +
        "    }"
}

// Build + write the G3 SHE top-K record that INCLUDES the cited-predicted-Q_α
// Z=119/120 candidates alongside the measured anchors. Rows pre-ordered by
// DESCENDING composite_score (computed by the demo panel). This is the
// @goal-completing artifact: a ranking of actual novel Z>118 candidates with
// an explicit predicted-input caveat.
fn _write_n11_she_topk(out_dir: string, sigma: float) -> string {
    let path = out_dir + "/top_k_she.json"

    // Measured anchors (predicted=0) + cited-PREDICTED Z=119/120 cells
    // (predicted=1). Ordering below is by descending composite_score as
    // emitted by the [G3] demo panel (Og-294 leads; predicted cells follow).
    // Pre-ordered by DESCENDING composite_score (from the [G3] demo panel):
    //   Og-294 0.2420 > 295-119 0.0462 > 297-120 0.0306 > 293-119 0.00172
    //   > 295-120 / Lv-293 / Fl-289 (all 0.0; SF-dominant or odd-A collapse).
    let rows: [string] = [
        _she_cell_json("Og-294", 118, 176, 294, 11.65, sigma, 0,
            "NUBASE2020 / discovery 11.65 MeV (measured)",
            "11.65 (measured)"),
        _she_cell_json("295-119", 119, 176, 295, 12.95, sigma, 1,
            "PREDICTED via arxiv:2604.19325, arxiv:2311.07145, NOT measured",
            "12.5-13.4 (mass-model band; mid 12.95)"),
        _she_cell_json("297-120", 120, 177, 297, 13.20, sigma, 1,
            "PREDICTED via arxiv:2604.09287, arxiv:2601.21317, NOT measured",
            "12.9-13.5 (mass-model band; mid 13.20)"),
        _she_cell_json("293-119", 119, 174, 293, 13.20, sigma, 1,
            "PREDICTED via arxiv:2604.19325, arxiv:2511.18337, NOT measured",
            "12.8-13.6 (mass-model band; mid 13.20)"),
        _she_cell_json("295-120", 120, 175, 295, 13.35, sigma, 1,
            "PREDICTED via arxiv:2604.09287, arxiv:2601.21317, NOT measured",
            "13.0-13.7 (mass-model band; mid 13.35)"),
        _she_cell_json("Lv-293", 116, 177, 293, 10.54, sigma, 0,
            "measured E_alpha first-detection (Lv->Fl) 10.54 MeV (measured)",
            "10.54 (measured)"),
        _she_cell_json("Fl-289", 114, 175, 289, 9.71, sigma, 0,
            "measured decay energy 1998 Dubna 9.71 MeV (measured)",
            "9.71 (measured)"),
    ]
    let mut body = "[\n"
    let mut i = 0
    while i < len(rows) {
        body = body + rows[i]
        if i + 1 < len(rows) { body = body + "," }
        body = body + "\n"
        i = i + 1
    }
    body = body + "  ]"

    let json = "{\n" +
        "  \"domain\": \"nuclear\",\n" +
        "  \"verb\": \"verify\",\n" +
        "  \"kind\": \"n11_zn_funnel_she_predicted\",\n" +
        "  \"producer\": \"sim.hexa@nuclear-N11-G3\",\n" +
        "  \"absorbed\": false,\n" +
        "  \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "  \"provisional\": true,\n" +
        "  \"query\": { \"Z_range\": [114, 122], \"N_range\": [170, 184], " +
        "\"accelerator_band_log10_s\": [-6.0, 3.0], " +
        "\"island_sigma\": " + to_string(sigma) + ", " +
        "\"magic_Z\": [82, 114, 120, 126], \"magic_N\": [126, 184] },\n" +
        "  \"predicted_input_targets\": [\"295-119\", \"293-119\", " +
        "\"295-120\", \"297-120\"],\n" +
        "  \"honest_skipped\": [\n" +
        "    \"293-120 (Z=120,N=173): research note §3 rank7 gives 'Q_α " +
        "높음' QUALITATIVE only — no numeric band → honest-skip (§3.3).\",\n" +
        "    \"298-120 (Z=120,N=178): 'N=178 deformed magic', NO Q_α band " +
        "in note → honest-skip (no fabrication).\",\n" +
        "    \"Z=121, Z=122: NO cited Q_α anywhere in the research note → " +
        "honest-skip. Out-of-scope != impossible (@D d2); re-enter when a " +
        "cited Q_α band exists.\"\n" +
        "  ],\n" +
        "  \"top_k_candidates\": " + body + ",\n" +
        "  \"scope_caveats\": [\n" +
        "    \"(s1) PREDICTED-INPUT cells (Z=119/120) use a CITED Q_α band " +
        "MIDPOINT from arxiv mass-model literature — predicted_input=true. " +
        "This is sim-composed-with-sim (predicted Q_α → semi-empirical T), " +
        "NOT measurement. 'Z=119 후보일 가능성' != '후보임' != '발견됨'.\",\n" +
        "    \"(s2) Q_α is mass-model dependent (ΔQ_α ~0.3-1.0 MeV across " +
        "FRDM/WS4/SkyHFB/KTUY/BSk; note §3.1). The band width IS the honest " +
        "uncertainty; only the midpoint is scored. @D d6: no forced number.\",\n" +
        "    \"(s3) C2 composite = C1 alpha+SF window x island_weight. odd-A " +
        "cells carry model_validity_flag (G2) so a score=0 is distinguishable " +
        "from true SF dominance. (a)(b)(d)(e) gates still install-gated.\",\n" +
        "    \"(s4) absorbed=false 永久 (R4). 2026-05 현재 Z=119/120 confirmed " +
        "discovery 0건 (RIKEN/Berkeley/JINR 모두 진행중/착수예정; note §2). (d) " +
        "production sigma + (e) recoil-separator detection wet-lab permanent.\"\n" +
        "  ],\n" +
        "  \"citations\": [\n" +
        "    \"arxiv:2604.19325 — Z=119 Q_α/σ estimates (Ca,Ti,V,Cr beams)\",\n" +
        "    \"arxiv:2311.07145 — 51V+248Cm Z=119 optimal energy (DNS)\",\n" +
        "    \"arxiv:2604.09287 — element 120 DNS synthesis (PC-PK1)\",\n" +
        "    \"arxiv:2511.18337 — systematic SHE formation 5 mass models\",\n" +
        "    \"arxiv:2601.21317 — Z=120 competing decay modes (RMF/NL3,PCM)\",\n" +
        "    \"arxiv:2405.07704 — odd-Z 119 shell structure (def. RHB)\",\n" +
        "    \"Viola-Seaborg 1966 · Royer 2000 · Ren-Xu PRC71 014309 (kernels)\",\n" +
        "    \"demiurge research note 2026-05-25-she-driplinelit.md §3 (Q_α bands)\"\n" +
        "  ],\n" +
        "  \"recommendation\": \"G3 accelerator beam-time priority shortlist " +
        "INCLUDING cited-predicted Z=119/120 candidates (predicted_input=true). " +
        "absorbed=true requires GSI/JINR/RIKEN beam + SHIP/DGFRS/GARIS " +
        "detection + IUPAC priority — none from sim (NUCLEAR.md 7). " +
        "'가능성' != '임'.\"\n" +
        "}\n"

    write_file(path, json)
    return path
}

// G3 demo row: SHE cell with predicted/measured tag (composite for ranking).
fn _emit_she(name: string, Z: int, N: int, A: int, Q_alpha_MeV: float,
             sigma: float, predicted: int) {
    let s = n11_island_cell_checked(Z, N, A, Q_alpha_MeV, 0.0 - 6.0, 3.0, sigma)
    let mv = _model_validity_code(Z, N)
    let mut tag = "measured"
    if predicted == 1 { tag = "PREDICTED" }
    let mut dom = "alpha"
    if s.sf_dominates == 1 { dom = "SF" }
    println("  · " + name + " [" + tag + "]" +
            ": valid=" + to_string(s.valid) +
            "  L_total=" + to_string(s.log10_T_total_s) +
            "  c_total=" + to_string(s.c_total_score) +
            "  island=" + to_string(s.island_weight) +
            "  composite=" + to_string(s.composite_score) +
            "  dom=" + dom +
            "  mv=" + _model_validity_str(mv))
}

// C2 demo row: island weight + C1-total composite.
fn _emit_island(name: string, Z: int, A: int, Q_alpha_MeV: float, sigma: float) {
    let s = n11_island_cell(Z, A, Q_alpha_MeV, 0.0 - 6.0, 3.0, sigma)
    let mv = _model_validity_code(Z, A - Z)
    println("  · " + name +
            ": L_total=" + to_string(s.log10_T_total_s) +
            "  c_total=" + to_string(s.c_total_score) +
            "  island_w=" + to_string(s.island_weight) +
            "  composite=" + to_string(s.composite_score) +
            "  model_validity=" + _model_validity_str(mv))
}

// G2 demo: model-validity classifier + α-consensus outlier count.
fn _emit_mv(name: string, Z: int, N: int) {
    let code = _model_validity_code(Z, N)
    println("  · " + name + " (Z=" + to_string(Z) + ", N=" + to_string(N) +
            "): model_validity_flag=" + _model_validity_str(code))
}

// G2(b) demo: feed a 3-formula ensemble with one Byzantine member to show
// the leave-one-out outlier guard activating (outlier_count + robust_mean).
fn _emit_outlier(name: string, v: [float]) {
    let c = consensus_alpha(v)
    println("  · " + name +
            ": n=" + to_string(c.n) +
            "  mean=" + to_string(c.mean) +
            "  spread=" + to_string(c.spread_dex) +
            "  outlier_count=" + to_string(c.outlier_count) +
            "  robust_mean=" + to_string(c.robust_mean))
}

fn main() {
    println("[nuclear+verify] sim.hexa — NUCLEAR.md §6 Phase 4 #1 " +
            "(hexa-native N7 closed-form)")

    // Phase 2 audit anchors (the two `simulation` cells from the
    // 5×2 matrix in `2026-05-22-nuclear-9-phase2-stabilization.md` §2).
    _emit_row("U-238   (Z=92,  A=238, Q=4.27 MeV · low-Q calibration edge)",
              92, 238, 4.27)
    _emit_row("Og-294  (Z=118, A=294, Q=11.65 MeV · SHE anchor)",
              118, 294, 11.65)

    // Mid-Q regime spot-checks (heavy α emitters in the calibration set).
    _emit_row("Po-212  (Z=84,  A=212, Q=8.954 MeV)",
              84, 212, 8.954)
    _emit_row("Ra-226  (Z=88,  A=226, Q=4.871 MeV)",
              88, 226, 4.871)
    _emit_row("Cm-244  (Z=96,  A=244, Q=5.902 MeV)",
              96, 244, 5.902)

    // ── N11 (c)-gate funnel cells (NUCLEAR.md §6.2 · mirror RTSC N5) ────
    // Accelerator band [-6, +3] log10 s (μs separator-transit floor →
    // recoil-tagging ceiling). Cited measured-Q_α SHE α-emitters only —
    // unsourced cells honest-skip (valid=0) per §3.3 (no Q_α fabrication).
    println("[nuclear+verify · n11] (c)-gate funnel — band [-6,+3] log10 s")
    _emit_n11("Og-294  (Z=118, A=294, Q=11.65 · NUBASE2020 measured)",
              118, 294, 11.65)
    _emit_n11("Lv-293  (Z=116, A=293, Q=10.54 · measured E_α 1st-detect)",
              116, 293, 10.54)
    _emit_n11("Fl-289  (Z=114, A=289, Q=9.71  · measured E_α 1998)",
              114, 289, 9.71)

    // ── C1 (c)-gate TOTAL-survival cells (α ⊕ SF competition) ───────────
    // Ren-Xu 2005 SF systematics ⊕ NC1/NC2/NC3 α-consensus → DecayTotal.
    // For SHE the α-only T₁/₂ overestimates total survival; C1 reports the
    // honest competing-channel total + branching (NOVEL probe C1).
    println("[nuclear+verify · C1] (c)-gate α⊕SF competition (Ren-Xu 2005 SF)")
    _emit_c1("U-238   (Z=92,  A=238, Q=4.27  · SF anchor ~8e15 yr)",
             92, 238, 4.27)
    _emit_c1("Og-294  (Z=118, A=294, Q=11.65 · SHE anchor)",
             118, 294, 11.65)
    _emit_c1("Lv-293  (Z=116, A=293, Q=10.54 · odd-A)",
             116, 293, 10.54)
    _emit_c1("Fl-289  (Z=114, A=289, Q=9.71  · odd-A)",
             114, 289, 9.71)

    // ── C2 island-weighted composite (C1 α⊕SF total × magic-number Gaussian)
    // Sources the (c)-score from C1's TOTAL survival (not α-only) and folds
    // in island_weight(Z,N,σ) (σ=6.0 default). Re-ranks toward the island.
    println("[nuclear+verify · C2] island-weighted composite (σ=6.0; " +
            "magic Z{82,114,120,126} × N{126,184})")
    _emit_island("Og-294  (Z=118, N=176)", 118, 294, 11.65, 6.0)
    _emit_island("Fl-289  (Z=114, N=175)", 114, 289, 9.71, 6.0)
    _emit_island("Lv-293  (Z=116, N=177)", 116, 293, 10.54, 6.0)
    _emit_island("Fl-298  (Z=114, N=184 · doubly-magic candidate, no Q_α cite → skip)",
                 114, 298, 0.0, 6.0)

    // ── (Z,N,A) consistency guard demo (gap-audit top-2 silent-failure) ─
    // A transposed (Z,N) or stale A keeps A=Z+N self-consistent ONLY if the
    // caller flips ALL three; a partial transpose violates A=Z+N. Since
    // log10 T scales ~linearly in Z, an undetected Z↔N swap flips the answer
    // by ≈10×. n11_*_cell_checked rejects it honestly (valid=0 + reason).
    println("[nuclear+verify · guard] (Z,N,A) consistency — reject before compute")
    _emit_guard("Og-294  clean (Z=118, N=176, A=294)", 118, 176, 294, 11.65)
    _emit_guard("Og-294  A typo  (Z=118, N=176, A=295)", 118, 176, 295, 11.65)
    _emit_guard("Og-294  Z↔N swap (Z=176, N=118, A=294)", 176, 118, 294, 11.65)
    _emit_guard("bad N≤0  (Z=118, N=0,   A=118)", 118, 0, 118, 11.65)
    _emit_guard("bad Q≤0  (Z=118, N=176, A=294)", 118, 176, 294, 0.0)

    // ── G2(a) model-validity classifier (odd-A hindrance / domain) ──────
    // A score=0 from an odd-A cell may be a MODEL artifact (Ren-Xu ν=2 SF
    // over-prediction), NOT true SF dominance — the Lv-293/Fl-289 collapse.
    // The flag makes the two distinguishable (gap-audit top-3a).
    println("[nuclear+verify · G2a] model_validity_flag (even-even=nominal)")
    _emit_mv("Og-294  even-even", 118, 176)
    _emit_mv("Fl-289  odd-A    ", 114, 175)
    _emit_mv("Lv-293  odd-A    ", 116, 177)
    _emit_mv("Mc-288  odd-odd  ", 115, 173)

    // ── G2(b) consensus outlier (Byzantine-formula) guard ───────────────
    // Leave-one-out: a member far from the OTHERS' consensus is flagged so
    // one bad formula can't silently skew the unweighted mean (gap-audit
    // top-3b). n=2 (the live VS,Royer pair) is never trimmed.
    println("[nuclear+verify · G2b] consensus outlier guard (leave-one-out 3σ)")
    let pair: [float] = [0.0 - 2.82183, 0.0 - 3.03993]
    _emit_outlier("VS+Royer pair (live, n=2 → no trim)", pair)
    let clean3: [float] = [0.0 - 2.82, 0.0 - 3.04, 0.0 - 2.93]
    _emit_outlier("3 in-bound (no outlier)            ", clean3)
    let byz: [float] = [0.0 - 2.82, 0.0 - 3.04, 42.0]
    _emit_outlier("3 w/ Byzantine member (42.0)       ", byz)

    // ── G3 PREDICTED-Q_α SHE injection (Z=119–122 unlock · gap-audit top-1)
    // The headline targets were honest-skipped for lack of MEASURED Q_α. G3
    // feeds CITED PREDICTED Q_α band midpoints (research note §3) so the
    // novel Z=119/120 candidates finally enter the ranking — predicted_input
    // flagged, NOT measurement. Z=121/122 + uncited cells stay honest-skipped.
    println("[nuclear+verify · G3] PREDICTED-Q_α SHE (Z=119/120 unlock; σ=6.0)")
    _emit_she("Og-294  (Z=118, N=176)", 118, 176, 294, 11.65, 6.0, 0)
    _emit_she("295-119 (Z=119, N=176)", 119, 176, 295, 12.95, 6.0, 1)
    _emit_she("293-119 (Z=119, N=174)", 119, 174, 293, 13.20, 6.0, 1)
    _emit_she("295-120 (Z=120, N=175)", 120, 175, 295, 13.35, 6.0, 1)
    _emit_she("297-120 (Z=120, N=177)", 120, 177, 297, 13.20, 6.0, 1)
    _emit_she("Lv-293  (Z=116, N=177)", 116, 177, 293, 10.54, 6.0, 0)
    _emit_she("Fl-289  (Z=114, N=175)", 114, 175, 289, 9.71, 6.0, 0)
    println("[nuclear+verify · G3] honest-skip: 293-120 (Q_α qualitative) · " +
            "298-120 (no Q_α band) · Z=121,122 (no cited Q_α) — @D d2 ≠ impossible")

    // Emit the REAL N11 top-K JSON record (NUCLEAR.md §6.1 schema).
    let n11_out = "/tmp/nuclear_n11"
    let _ = exec("mkdir -p " + n11_out)
    let topk_path = _write_n11_topk(n11_out)
    println("[nuclear+verify · n11] wrote top-K record → " + topk_path)
    let island_path = _write_n11_island_topk(n11_out, 6.0)
    println("[nuclear+verify · C2] wrote island top-K record → " + island_path)
    let she_path = _write_n11_she_topk(n11_out, 6.0)
    println("[nuclear+verify · G3] wrote SHE predicted-Q_α top-K → " + she_path)

    println("[nuclear+verify] absorbed=false (R4 invariant; " +
            "NUCLEAR.md §7 wet-lab dependency permanent — Geiger-Nuttall " +
            "family is semi-empirical fit, NEVER measurement)")

    // ── scope_caveats (verbatim from wkb_alpha_decay.py s1-s5) ─────────
    println("[scope] (s1) Geiger-Nuttall family formulas (Viola-Seaborg, " +
            "Royer) are semi-empirical fits to ~400 known α emitters. " +
            "Extrapolation to Z > 118 / SHE region is honest but carries " +
            "intrinsic ~0.5-1.0 dex (factor of 3-10) uncertainty per " +
            "formula. The cross-formula spread (spread_dex) is the honest " +
            "lower bound — the *true* uncertainty against eventual " +
            "measurement may be larger if the formula family fails in " +
            "the extrapolation region.")
    println("[scope] (s2) For unsynthesized nuclides (Z=119, 120, drip-" +
            "line isotopes), Q_α is itself a sim output (from N6 HFB / " +
            "FRDM / BSk mass predictions). The formula chain is sim-" +
            "composed-with-sim, NOT measurement. R4 invariant blocks any " +
            "absorbed=true promotion for nuclear-novel-discovery-" +
            "simulation records (NUCLEAR.md §7).")
    println("[scope] (s3) 5-gate evaluation (NUCLEAR.md §2): this record " +
            "fills ONLY the (c) gate (α-decay half-life). The other 4 " +
            "gates ((a) mass, (b) spectroscopy, (d) production σ, (e) " +
            "detection) are NOT addressed. Even with all 5 sim gates " +
            "PASS, (d) and (e) remain wet-lab dependent permanently — " +
            "sim-PASS never substitutes for accelerator beam-time.")
    println("[scope] (s4) Formula domain limits: Viola-Seaborg + Royer " +
            "are tuned for even-even heavy α emitters. Odd-A / odd-odd " +
            "nuclei have hindrance factors not captured by these α forms; " +
            "predictions for odd-A SHE may underestimate T₁/₂ by 1-2 " +
            "orders. SF (spontaneous fission) competing channel IS NOW " +
            "modeled (C1: Ren-Xu 2005 sf_log10_t + total_halflife " +
            "branching combiner) — for Z ≥ 104 SF often dominates, so the " +
            "α-only T₁/₂ overestimates total survival; c_gate_total_cell " +
            "returns the honest α⊕SF total + branching ratio. SF " +
            "systematics scatter (±2-3 dex) EXCEEDS the α scatter and the " +
            "ν seniority term captures only gross even/odd blocking; SF " +
            "dominance is a priority-down-weight PREDICTION, never " +
            "'this nuclide cannot exist' (@D d2 · NUCLEAR.md §3.4).")
    println("[scope] (s5) Path A microkernel: this module is libm-only " +
            "closed-form (no external binary, no install gate). NUCLEAR.md " +
            "§6 Phase 4 #1 land — mirror of RTSC.md §9.9.1 Phase 4 #1 " +
            "material/sim.hexa v0.2.0 precedent. Wet-lab dependency " +
            "unchanged regardless of port (NUCLEAR.md §3.2).")

    // ── citations (mirror of wkb_alpha_decay.py header) ────────────────
    println("[cite] Viola & Seaborg 1966 · J Inorg Nucl Chem 28:741 — " +
            "original Geiger-Nuttall fit for α-decay.")
    println("[cite] Sobiczewski / Parkhomenko 2005 · PRC 72.044316 — " +
            "refit of Viola-Seaborg coefficients (used here).")
    println("[cite] Royer 2000 · J Phys G 26:1149 · arxiv:nucl-th/0510074 " +
            "— mass-dependent refinement (even-even nuclei coefficients).")
    println("[cite] arxiv:2105.01035 — Wang/Huang/Kondev/Audi/Naimi, " +
            "AME2020 evaluation (Q_α cross-validation oracle).")
    println("[anchor] NUCLEAR.md §2 (c) gate + §4.2 (N7 cohort spec) + " +
            "§6 (Phase 4 #1 microkernel port) + §7 (R4 invariant block)")
    println("[anchor] RTSC.md §9.9.1 Phase 4 (B→A microkernel transition " +
            "schedule — pattern source)")
}
