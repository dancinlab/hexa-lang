// HEXA Standard Library — nuclear/dripline
//
// @version 0.1.0
// @capabilities [pure, io]
//
// NUCLEAR.md §4.5 N10 — closed-form drip-line DETERMINATION from CITED
// measured separation energies (AME2020). Sibling of sim.hexa (N7/N11
// α-decay) — this module covers gate (a) drip-line, the *light-nuclei*
// half of @goal (the rest of the funnel is SHE-only). It does NOT replace
// the ab-initio N10 adapter (`stdlib/nuclear/n10_abinitio_adapter.py`,
// install-gated NCSM/CCSD/IM-SRG) — that predicts Sn/Sp for *unmeasured*
// nuclei; this module classifies the drip-line position of nuclei whose
// Sn/Sp are ALREADY measured + cited (AME2020). For unmeasured / heavier
// drip-line, the ab-initio N10 path stays the breakthrough route (@D d2 —
// out-of-scope ≠ impossible).
//
// Physics (textbook):
//   neutron drip-line crossed when neutron separation energy Sn < 0
//   proton  drip-line crossed when proton  separation energy Sp < 0
//   (a nuclide past the line is particle-unbound to 1n / 1p emission).
//
// §3.3 NO fabrication: every embedded Sn/Sp is a verbatim CITED AME2020
// value (arxiv:2105.01035 · IAEA NSDC relnsd/v1 ground_states, the live
// AME2020 mirror). A nuclide whose Sn/Sp is not in the cited subset is
// honest-skipped — never invented.
//
// R4 (§3.1 · §7): absorbed=false 永久 · gate_type=
// nuclear-novel-discovery-simulation. Classifying a (Z,N) as past/near the
// drip-line from CITED measured Sn/Sp is LITERATURE-ANCHORED — "this (Z,N)
// sits past/near the drip-line per AME2020", NEVER a new discovery.
//
// Surface (pure predicates + classifier; closed-form, libm-free):
//   pub fn is_neutron_drip(Sn) -> int          // 1 if Sn < 0 (unbound)
//   pub fn is_proton_drip(Sp)  -> int          // 1 if Sp < 0 (unbound)
//   pub fn classify_dripline(Sn, Sp) -> DripClass
//   + cohort emitter → dripline_cohort.json (NUCLEAR.md §6.1 schema)

// ── helpers ────────────────────────────────────────────────────────────

fn _fabs(x: float) -> float { if x < 0.0 { return -x } return x }

// Near-drip half-width [MeV]: |S| < NEAR_MEV ⇒ "near-drip" (weakly bound /
// weakly unbound). 2 MeV is a conventional weak-binding band for light
// nuclei (1n/1p separation comparable to typical level spacing).
let NEAR_MEV: float = 2.0

// ── 1/2. closed-form drip-line predicates ──────────────────────────────
//
// A nuclide is past the neutron (proton) drip-line iff its neutron
// (proton) separation energy is negative — particle-unbound to 1n (1p)
// emission. Trivial closed-form comparisons; registered as `hexa verify
// --expr` atoms returning 1.0 / 0.0 (NUCLEAR.md §4.5).
pub fn is_neutron_drip(Sn_MeV: float) -> int {
    if Sn_MeV < 0.0 { return 1 }
    return 0
}

pub fn is_proton_drip(Sp_MeV: float) -> int {
    if Sp_MeV < 0.0 { return 1 }
    return 0
}

// ── 3. per-nuclide classifier ──────────────────────────────────────────
//
// status code: 0 = bound (S ≥ NEAR_MEV both sides) · 1 = neutron-near
// · 2 = neutron-past (Sn<0) · 3 = proton-near · 4 = proton-past (Sp<0).
// margin = the SMALLEST relevant separation energy (the channel closest
// to / past the line); negative ⇒ past the line by |margin| MeV.
struct DripClass {
    status:   int,
    margin:   float,    // MeV; <0 ⇒ unbound by |margin| (past drip)
    Sn_MeV:   float,
    Sp_MeV:   float,
    is_n_drip: int,
    is_p_drip: int,
}

pub fn classify_dripline(Sn_MeV: float, Sp_MeV: float) -> DripClass {
    let nd = is_neutron_drip(Sn_MeV)
    let pd = is_proton_drip(Sp_MeV)
    // past-drip dominates near; neutron-past listed before proton-past
    // only by code ordering — a nuclide can in principle be both (very
    // light unbound), the margin field then carries the deeper unbinding.
    let mut status = 0
    let mut margin = Sn_MeV
    if Sp_MeV < margin { margin = Sp_MeV }
    if nd == 1 {
        status = 2
        margin = Sn_MeV
    } else if pd == 1 {
        status = 4
        margin = Sp_MeV
    } else if Sn_MeV < NEAR_MEV && Sn_MeV <= Sp_MeV {
        status = 1
        margin = Sn_MeV
    } else if Sp_MeV < NEAR_MEV {
        status = 3
        margin = Sp_MeV
    }
    return DripClass { status: status, margin: margin,
                       Sn_MeV: Sn_MeV, Sp_MeV: Sp_MeV,
                       is_n_drip: nd, is_p_drip: pd }
}

fn _status_label(s: int) -> string {
    if s == 2 { return "neutron-past-drip" }
    if s == 4 { return "proton-past-drip" }
    if s == 1 { return "neutron-near-drip" }
    if s == 3 { return "proton-near-drip" }
    return "bound"
}

// ── 4. cohort JSON emit (NUCLEAR.md §6.1 schema) ────────────────────────
//
// Render one CITED nuclide as a JSON drip-line classification record.
// gate_type + absorbed=false hardcoded per R4. Sn/Sp are verbatim AME2020
// (cite string carries the value's provenance). §3.3: caller passes only
// cited values — uncited nuclides are honest-skipped (never emitted).
fn _cell_json(name: string, Z: int, N: int,
              Sn_MeV: float, Sp_MeV: float, cite: string) -> string {
    let d = classify_dripline(Sn_MeV, Sp_MeV)
    let A = Z + N
    return "    {\n" +
        "      \"name\": \"" + name + "\",\n" +
        "      \"Z\": " + to_string(Z) +
        ", \"N\": " + to_string(N) +
        ", \"A\": " + to_string(A) + ",\n" +
        "      \"Sn_MeV\": " + to_string(Sn_MeV) +
        ", \"Sp_MeV\": " + to_string(Sp_MeV) + ",\n" +
        "      \"Sn_Sp_source\": \"" + cite + "\",\n" +
        "      \"is_neutron_drip\": " + to_string(d.is_n_drip) +
        ", \"is_proton_drip\": " + to_string(d.is_p_drip) + ",\n" +
        "      \"classification\": \"" + _status_label(d.status) + "\",\n" +
        "      \"margin_MeV\": " + to_string(d.margin) + ",\n" +
        "      \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "      \"absorbed\": false\n" +
        "    }"
}

// Build + write the N10 drip-line cohort record to <out_dir>/
// dripline_cohort.json. Returns the path written. CITED AME2020 light
// near-drip nuclei only — proton-drip side (⁸B/¹¹N/¹²O) + neutron-drip
// side (²²C/²⁴O/²⁵O/²⁶O/¹⁹B). All Sn/Sp verbatim from IAEA NSDC relnsd/v1
// ground_states (AME2020 mirror, arxiv:2105.01035), me_systematics=N
// (measured/evaluated, NOT extrapolated).
fn _write_cohort(out_dir: string) -> string {
    let path = out_dir + "/dripline_cohort.json"

    let rows: [string] = [
        // ── proton-drip side ──
        _cell_json("N-11", 7, 4, 22.5057016, 0.0 - 1.377999900,
            "AME2020 Sp=-1378.000 keV (proton-unbound, ground-state proton emitter)"),
        _cell_json("O-12", 8, 4, 23.7968964, 0.0 - 0.358719900,
            "AME2020 Sp=-358.720 keV (2p-unbound, past proton drip)"),
        _cell_json("B-8", 5, 3, 12.8263018, 0.136399700,
            "AME2020 Sp=+136.400 keV (weakly proton-bound, near proton drip)"),
        // ── neutron-drip side ──
        _cell_json("O-25", 8, 17, 0.0 - 0.757307700, 26.898000,
            "AME2020 Sn=-757.308 keV (1n-unbound resonance, past neutron drip)"),
        _cell_json("O-24", 8, 16, 4.192284300, 25.5089957,
            "AME2020 Sn=+4192.284 keV (last bound even-O; N=16 subshell)"),
        _cell_json("O-26", 8, 18, 0.739307700, 28.611000,
            "AME2020 Sn=+739.308 keV (1n weakly bound vs 2n-unbound; near drip)"),
        _cell_json("C-22", 6, 16, 0.103000, 32.0606549,
            "AME2020 Sn=+103.000 keV (weakly bound, neutron-drip-line nuclide)"),
        _cell_json("B-19", 5, 14, 0.093707300, 30.000000,
            "AME2020 Sn=+93.707 keV (weakly bound, near neutron drip)"),
    ]
    let mut body = "[\n"
    let mut i = 0
    while i < len(rows) {
        body = body + rows[i]
        if i + 1 < len(rows) { body = body + "," }
        body = body + "\n"
        i = i + 1
    }
    body = body + "  ]"

    let json = "{\n" +
        "  \"domain\": \"nuclear\",\n" +
        "  \"verb\": \"verify\",\n" +
        "  \"kind\": \"dripline_classification\",\n" +
        "  \"producer\": \"dripline.hexa@nuclear-N10\",\n" +
        "  \"absorbed\": false,\n" +
        "  \"gate_type\": \"nuclear-novel-discovery-simulation\",\n" +
        "  \"provisional\": true,\n" +
        "  \"query\": { \"predicate\": \"Sn<0 neutron-drip / Sp<0 proton-drip\", " +
        "\"near_drip_band_MeV\": " + to_string(NEAR_MEV) + " },\n" +
        "  \"nuclides\": " + body + ",\n" +
        "  \"scope_caveats\": [\n" +
        "    \"(s1) Drip-line classification from CITED measured Sn/Sp " +
        "(AME2020). 'This (Z,N) sits past/near the drip-line per AME2020' " +
        "is LITERATURE-ANCHORED, NEVER a new discovery (R4 · §3.1).\",\n" +
        "    \"(s2) NUCLEAR.md 3.3 NO fabrication: every Sn/Sp is verbatim " +
        "from IAEA NSDC relnsd/v1 ground_states (AME2020 mirror, " +
        "me_systematics=N measured/evaluated). Uncited nuclides honest-skip.\",\n" +
        "    \"(s3) Light nuclei only (A<=30). Heavier / unmeasured drip-line " +
        "needs ab-initio N10 (n10_abinitio_adapter.py · NCSM/CCSD/IM-SRG, " +
        "install-gated chiral-EFT ME). Out-of-scope != impossible (@D d2).\",\n" +
        "    \"(s4) absorbed=false 永久. Sn/Sp sign is a fact about the " +
        "MEASURED mass surface; 'past the drip-line' != 'a discovery'. The " +
        "drip-line position for unsynthesized nuclei stays PREDICTION (N10).\"\n" +
        "  ],\n" +
        "  \"citations\": [\n" +
        "    \"arxiv:2105.01035 — Wang/Huang/Kondev/Audi/Naimi, AME2020 " +
        "atomic mass evaluation (Sn/Sp source).\",\n" +
        "    \"Kondev et al 2021 Chinese Phys C 45:030001 (NUBASE2020).\",\n" +
        "    \"IAEA NSDC relnsd/v1 ground_states — live AME2020 mirror " +
        "(sn/sp/unc fields).\",\n" +
        "    \"NUCLEAR.md §4.5 (N10 drip-line spec) + §2 (a)-gate + §3.3 " +
        "(no-fabrication) + §7 (R4 invariant block).\"\n" +
        "  ],\n" +
        "  \"recommendation\": \"Drip-line map for light nuclei from cited " +
        "AME2020 Sn/Sp. absorbed=false 永久 — particle-unbound classification " +
        "is literature-anchored, not a discovery. Heavier/unmeasured drip-line " +
        "= ab-initio N10 (install-gated) breakthrough route (@D d2).\"\n" +
        "}\n"

    write_file(path, json)
    return path
}

// ── reference-panel runner ──────────────────────────────────────────────

fn _emit_row(name: string, Z: int, N: int, Sn_MeV: float, Sp_MeV: float) {
    let d = classify_dripline(Sn_MeV, Sp_MeV)
    println("  · " + name +
            " (Z=" + to_string(Z) + " N=" + to_string(N) + ")" +
            ": Sn=" + to_string(Sn_MeV) +
            " Sp=" + to_string(Sp_MeV) +
            " → " + _status_label(d.status) +
            " (margin " + to_string(d.margin) + " MeV)")
}

fn main() {
    println("[nuclear+verify] dripline.hexa — NUCLEAR.md §4.5 N10 " +
            "(closed-form drip-line from CITED AME2020 Sn/Sp)")
    println("[nuclear+verify · n10] predicate: Sn<0 neutron-drip / Sp<0 " +
            "proton-drip · near-band |S|<" + to_string(NEAR_MEV) + " MeV")

    // ── proton-drip side ──
    _emit_row("N-11", 7, 4, 22.5057016, 0.0 - 1.377999900)
    _emit_row("O-12", 8, 4, 23.7968964, 0.0 - 0.358719900)
    _emit_row("B-8",  5, 3, 12.8263018, 0.136399700)
    // ── neutron-drip side ──
    _emit_row("O-25", 8, 17, 0.0 - 0.757307700, 26.898000)
    _emit_row("O-24", 8, 16, 4.192284300, 25.5089957)
    _emit_row("O-26", 8, 18, 0.739307700, 28.611000)
    _emit_row("C-22", 6, 16, 0.103000, 32.0606549)
    _emit_row("B-19", 5, 14, 0.093707300, 30.000000)

    // Emit the REAL N10 drip-line cohort JSON record (§6.1 schema).
    let out = "/tmp/nuclear_n10"
    let _ = exec("mkdir -p " + out)
    let cohort_path = _write_cohort(out)
    println("[nuclear+verify · n10] wrote drip-line cohort → " + cohort_path)

    println("[nuclear+verify] absorbed=false (R4 invariant; NUCLEAR.md §7) " +
            "— drip-line classification from CITED measured Sn/Sp is " +
            "literature-anchored, NEVER a new discovery.")
    println("[scope] (s3) Light nuclei (A<=30) only. Heavier / unmeasured " +
            "drip-line → ab-initio N10 (n10_abinitio_adapter.py · NCSM/CCSD/" +
            "IM-SRG, install-gated). Out-of-scope != impossible (@D d2).")
    println("[cite] arxiv:2105.01035 AME2020 (Wang/Huang/Kondev/Audi/Naimi) " +
            "· IAEA NSDC relnsd/v1 ground_states (sn/sp, me_systematics=N).")
}
