// stdlib/runtime/numeric.hexa — RUNTIME.md step-3 cycle 1 POC.
//
// First HI-tier hexa-source replacement. `hexa_abs` C body in
// self/runtime_core.c:5679 splits on HexaVal tag (int vs float) and
// returns the corresponding signed absolute. We split the polymorphism
// into two hexa fns (rt_abs_int + rt_abs_float) since hexa typing
// doesn't model the HexaVal union directly; the C wrapper dispatches
// based on HX_IS_INT.
//
// This is step 3 (not step 4) by intent even though hexa_abs lives in
// runtime_core.c — the function logic is HI-tier (HexaVal value-level
// macros, no arena/GC touch). Step 3/4 split per RUNTIME.md is about
// which LOGIC moves to hexa, not which FILE the C wrapper lives in.

pub fn rt_abs_int(v: int) -> int {
    if v < 0 { return 0 - v }
    return v
}

pub fn rt_abs_float(v: float) -> float {
    if v < 0.0 { return 0.0 - v }
    return v
}

// Step 3 cycle 2 — floor/ceil. hexa's `as int` truncates toward 0; we
// adjust to truncate toward -inf (floor) or +inf (ceil).
pub fn rt_floor(v: float) -> int {
    let i = v as int
    if v >= 0.0 { return i }
    // Negative: if non-integral, subtract 1
    let f = i as float
    if f == v { return i }
    return i - 1
}

pub fn rt_ceil(v: float) -> int {
    let i = v as int
    if v <= 0.0 { return i }
    let f = i as float
    if f == v { return i }
    return i + 1
}

// Step 3 cycle 2 — u_floor (unsigned integer floor div).
pub fn rt_u_floor(a: int, b: int) -> int {
    if b == 0 { return 0 }
    let q = a / b
    let r = a - q * b
    // floor semantics: when signs differ and remainder non-zero, round down
    if r != 0 {
        let signs_differ = (a < 0) != (b < 0)
        if signs_differ { return q - 1 }
    }
    return q
}

// Step 3 cycle 3 — clamp (float). C wrapper extracts doubles via
// __hx_to_double and rebuilds HexaVal floats around our call.
pub fn rt_clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Step 3 cycle 3 — integer min/max (used by codegen + lowering passes).
pub fn rt_imin(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

pub fn rt_imax(a: int, b: int) -> int {
    if a > b { return a }
    return b
}

// Step 3 cycle 3 — sign function (returns -1, 0, or 1 for float input).
pub fn rt_sign(v: float) -> int {
    if v < 0.0 { return -1 }
    if v > 0.0 { return 1 }
    return 0
}

// Step 3 cycle 4 — round (half-away-from-zero). Matches llround() semantics:
// 0.5  →  1,  -0.5 → -1,  2.5  → 3,  -2.5 → -3.
// `as int` truncates toward zero in hexa, so we bias by ±0.5 first.
pub fn rt_round(v: float) -> int {
    if v >= 0.0 { return (v + 0.5) as int }
    return (v - 0.5) as int
}

// Step 3 cycle 5 — float min/max. C wrappers (hexa_math_min/max) used
// fmin/fmax from libm, which propagate NaN per IEEE 754 (fmin(NaN, x) → x).
// The hexa primitives use plain `<` comparison: if either operand is NaN
// all comparisons are false, so `rt_min_float(NaN, x)` returns x (mirroring
// fmin) but `rt_min_float(x, NaN)` returns NaN (diverges from fmin's x).
// Acceptable: hexa user code rarely traffics in NaN at this entry point.
pub fn rt_min_float(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

pub fn rt_max_float(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Step 3 cycle 13 — to_float pass-through. C wrapper unboxes any scalar
// via __hx_to_double then rewraps as hexa_float; this hexa primitive is
// the identity at the typed-float layer, exercised only for ABI path
// consistency with the other rt_* primitives.
pub fn rt_to_float(v: float) -> float { return v }

// Step 3 cycle 12 — one-hot vector. n-length [0.0, ...] with 1.0 at idx.
// Matches interpreter hexa_full.hexa:10512 and C body in self/runtime.c::
// hexa_one_hot. C wrapper handles HexaVal int/float→int coercion of inputs
// before delegating here.
pub fn rt_one_hot(idx: int, n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out.push(1.0) } else { out.push(0.0) }
        i = i + 1
    }
    return out
}

// Step 3 cycle 10 — IEEE 754 classifiers. NaN is the unique value with
// (x != x). Infinity is detected by exceeding DBL_MAX (1.79…e308) in
// absolute value — DBL_MAX itself is finite; +inf and -inf compare
// strictly greater/less than ±DBL_MAX.
pub fn rt_isnan(x: float) -> bool {
    return x != x
}

pub fn rt_isinf(x: float) -> bool {
    if x != x { return false }
    let big = 1.7976931348623157e308
    return x > big || x < (0.0 - big)
}

pub fn rt_isfinite(x: float) -> bool {
    if x != x { return false }
    let big = 1.7976931348623157e308
    if x > big { return false }
    if x < (0.0 - big) { return false }
    return true
}

// Step 3 cycle 6 — integer power fast-path (binary exponentiation).
// Mirrors the C hexa_pow int^int branch in runtime_core.c:5648. Negative
// exponents collapse to 0 (matches the original spec: hexa int^int has no
// rational fallback). Float fallback stays C-side calling libm pow().
pub fn rt_pow_int(b: int, e: int) -> int {
    if e < 0 { return 0 }
    let mut r: int = 1
    let mut base = b
    let mut exp = e
    while exp > 0 {
        if (exp & 1) != 0 { r = r * base }
        base = base * base
        exp = exp >> 1
    }
    return r
}
