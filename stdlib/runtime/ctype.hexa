// stdlib/runtime/ctype.hexa — RUNTIME.md step-2 cycle 1 POC.
//
// Hexa-source replacements for C-side `hxlcl_isalnum`/`hxlcl_isalpha`
// helpers in self/runtime.c (cycle 59). The C-side wrappers thin-shim
// onto these hexa fns via the standard HexaVal calling convention
// (every hexa pub fn emits `HexaVal name(HexaVal ...)` after hexa_v2
// transpile).
//
// This is the first proof of step 2 of RUNTIME.md's 4-step path:
//   step 1 (cycles 46-65): libc unhook via C-source hxlcl_* helpers
//   step 2 (NOW):          port hxlcl_* helpers C → hexa source
//   step 3 (later):        runtime.c HI tier C → hexa source
//   step 4 (final):        runtime_core.c CORE tier C → hexa source
//
// ASCII classifiers — locale-free. Per ANSI C `isalnum(c)` /
// `isalpha(c)` definition restricted to the C locale (matches the
// cycle-59 hxlcl_isalnum/_isalpha bodies).

pub fn rt_isalnum(c: int) -> bool {
    if c >= 48 && c <= 57 { return true }   // '0'..'9'
    if c >= 65 && c <= 90 { return true }   // 'A'..'Z'
    if c >= 97 && c <= 122 { return true }  // 'a'..'z'
    return false
}

pub fn rt_isalpha(c: int) -> bool {
    if c >= 65 && c <= 90 { return true }   // 'A'..'Z'
    if c >= 97 && c <= 122 { return true }  // 'a'..'z'
    return false
}

// Step 3 cycle 28 — string → [int] byte array. C body iterated until
// NULL terminator; hexa version uses byte_len + .byte_at(i) (byte_len is
// the canonical hexa string length builtin and doesn't depend on NUL).
pub fn rt_str_bytes(s: string) -> [int] {
    let mut out: [int] = []
    let n = byte_len(s)
    let mut i = 0
    while i < n {
        out = out.push(s.byte_at(i))
        i = i + 1
    }
    return out
}

// Step 3 cycle 52 — UTF-8 codepoint count. Thin wrapper over the
// rt_utf8_cpcount helper introduced in cycle 51.
pub fn rt_str_char_count(s: string) -> int {
    return rt_utf8_cpcount(s)
}

// Step 3 cycle 52 — byte-indexed `.char_at(i)` with Python-style
// negative-index wraparound. Returns "" on OOB.
// (Note: hexa_str_char_code_at is intentionally NOT ported — see the
// `s.byte_at(i)` → `hexa_str_byte_at` → `hexa_str_char_code_at`
// recursion trap. Porting it would infinite-loop through the byte_at
// builtin.)
pub fn rt_str_char_at(s: string, idx: int) -> string {
    let n = byte_len(s)
    let mut i = idx
    if i < 0 { i = i + n }
    if i < 0 || i >= n { return "" }
    return s.substring(i, i + 1)
}

// Step 3 cycle 51 — UTF-8 codepoint counter (helper for pad_left/right).
// Same bit-pattern table as rt_str_chars but just counts (no substring
// allocations).
pub fn rt_utf8_cpcount(s: string) -> int {
    let n = byte_len(s)
    let mut count = 0
    let mut i = 0
    while i < n {
        let b = s.byte_at(i)
        let mut cp = 1
        if (b & 0x80) == 0 {
            cp = 1
        } else if (b & 0xE0) == 0xC0 {
            cp = 2
        } else if (b & 0xF0) == 0xE0 {
            cp = 3
        } else if (b & 0xF8) == 0xF0 {
            cp = 4
        }
        i = i + cp
        count = count + 1
    }
    return count
}

// Step 3 cycle 51 — pad_left/right: ensure visible width (UTF-8
// codepoints, not bytes) is ≥ `width` by prepending/appending spaces.
// If already wide enough, returns the input unchanged. The C body uses
// hexa_to_string first; that polymorphic coercion stays in the C wrapper
// and the hexa fn always sees a string.
pub fn rt_pad_left(s: string, width: int) -> string {
    let cplen = rt_utf8_cpcount(s)
    if cplen >= width { return s }
    let pad = width - cplen
    let mut bytes: [int] = []
    let mut i = 0
    while i < pad {
        bytes = bytes.push(32)
        i = i + 1
    }
    return bytes_to_str_raw(bytes) + s
}

pub fn rt_pad_right(s: string, width: int) -> string {
    let cplen = rt_utf8_cpcount(s)
    if cplen >= width { return s }
    let pad = width - cplen
    let mut bytes: [int] = []
    let mut i = 0
    while i < pad {
        bytes = bytes.push(32)
        i = i + 1
    }
    return s + bytes_to_str_raw(bytes)
}

// Step 3 cycle 50 — ASCII case conversion. Non-ASCII bytes pass through
// unchanged (UTF-8 continuation bytes have high bit set, won't match
// the 'a'-'z' or 'A'-'Z' range). Collect bytes into [int] then one-shot
// `bytes_to_str_raw` so we avoid O(n²) string concat.
pub fn rt_str_to_upper(s: string) -> string {
    let n = byte_len(s)
    let mut bytes: [int] = []
    let mut i = 0
    while i < n {
        let b = s.byte_at(i)
        if b >= 97 && b <= 122 {
            bytes = bytes.push(b - 32)
        } else {
            bytes = bytes.push(b)
        }
        i = i + 1
    }
    return bytes_to_str_raw(bytes)
}

pub fn rt_str_to_lower(s: string) -> string {
    let n = byte_len(s)
    let mut bytes: [int] = []
    let mut i = 0
    while i < n {
        let b = s.byte_at(i)
        if b >= 65 && b <= 90 {
            bytes = bytes.push(b + 32)
        } else {
            bytes = bytes.push(b)
        }
        i = i + 1
    }
    return bytes_to_str_raw(bytes)
}

// Step 3 cycle 49 — strip trailing whitespace (mirror of trim_start).
pub fn rt_str_trim_end(s: string) -> string {
    let n = byte_len(s)
    let mut b_end = n
    while b_end > 0 {
        let b = s.byte_at(b_end - 1)
        if b == 32 || b == 9 || b == 10 || b == 13 {
            b_end = b_end - 1
        } else {
            break
        }
    }
    return s.substring(0, b_end)
}

// Step 3 cycle 49 — strip both leading and trailing whitespace.
// Could be implemented as trim_end(trim_start(s)) but inlining halves
// the string allocations.
pub fn rt_str_trim(s: string) -> string {
    let n = byte_len(s)
    let mut a = 0
    while a < n {
        let b = s.byte_at(a)
        if b == 32 || b == 9 || b == 10 || b == 13 {
            a = a + 1
        } else {
            break
        }
    }
    let mut b_end = n
    while b_end > a {
        let b = s.byte_at(b_end - 1)
        if b == 32 || b == 9 || b == 10 || b == 13 {
            b_end = b_end - 1
        } else {
            break
        }
    }
    return s.substring(a, b_end)
}

// Step 3 cycle 48 — strip leading whitespace (space, tab, LF, CR).
// Replaces the C-direct rt_str_trim_start in self/runtime.c:2970 when
// HEXA_HAS_HEXA_RT_STDLIB is defined. The C body uses strdup; this
// uses the substring builtin (perf-31 single-shot alloc).
pub fn rt_str_trim_start(s: string) -> string {
    let n = byte_len(s)
    let mut a = 0
    while a < n {
        let b = s.byte_at(a)
        if b == 32 || b == 9 || b == 10 || b == 13 {
            a = a + 1
        } else {
            break
        }
    }
    return s.substring(a, n)
}

// Step 3 cycle 47 — UTF-8 codepoint walker. Returns an array of
// 1-codepoint strings ("한글hi".chars().len() == 4, not 8). ASCII
// behaviour is unchanged (codepoint == byte for ASCII). Mirrors the
// C body in self/runtime_core.c:4072 (the `_hx_utf8_cp_len` table is
// inlined here as bit-pattern checks).
//   leading-byte 0xxxxxxx       → 1 byte
//   leading-byte 110xxxxx       → 2 bytes
//   leading-byte 1110xxxx       → 3 bytes
//   leading-byte 11110xxx       → 4 bytes
//   anything else (continuation) → 1 byte (defensive fallback)
pub fn rt_str_chars(s: string) -> [string] {
    let n = byte_len(s)
    let mut out: [string] = []
    let mut i = 0
    while i < n {
        let b = s.byte_at(i)
        let mut cp = 1
        if (b & 0x80) == 0 {
            cp = 1
        } else if (b & 0xE0) == 0xC0 {
            cp = 2
        } else if (b & 0xF0) == 0xE0 {
            cp = 3
        } else if (b & 0xF8) == 0xF0 {
            cp = 4
        }
        let mut end = i + cp
        if end > n { end = n }
        out = out.push(s.substring(i, end))
        i = end
    }
    return out
}

// Step 3 cycle 46 — byte-based string slice, [start, end) clamped.
// Uses the substring builtin so the actual allocation is the perf-31
// hexa_strbuf_alloc + memcpy single-shot path (better than the C body's
// strndup + hexa_str_own_with_len which double-allocates).
pub fn rt_str_slice(s: string, start: int, end: int) -> string {
    let slen = byte_len(s)
    let mut a = start
    let mut b = end
    if a < 0 { a = 0 }
    if b > slen { b = slen }
    if a > b { a = b }
    return s.substring(a, b)
}

// Step 3 cycle 44 — string replace-all-occurrences. Walks `s` byte by
// byte; on each position checks whether `old` matches and either emits
// `new_s` (advancing by olen) or copies one byte (advancing by 1).
// Empty `old` returns `s` unchanged (matches C body's no-op guard via
// `oldlen == 0` would loop forever otherwise).
pub fn rt_str_replace(s: string, old: string, new_s: string) -> string {
    let slen = byte_len(s)
    let olen = byte_len(old)
    if olen == 0 { return s }
    let mut out = ""
    let mut i = 0
    while i + olen <= slen {
        let mut k = 0
        let mut matched = true
        while k < olen {
            if s.byte_at(i + k) != old.byte_at(k) {
                matched = false
                k = olen
            } else {
                k = k + 1
            }
        }
        if matched {
            out = out + new_s
            i = i + olen
        } else {
            out = out + s.substring(i, i + 1)
            i = i + 1
        }
    }
    if i < slen {
        out = out + s.substring(i, slen)
    }
    return out
}

// Step 3 cycle 43 — string join, all-string fast path. C body uses
// hexa_to_string() to coerce mixed-type elements; this hexa-source
// variant skips that and assumes every element is already a string
// (caller-side typing or dispatch guard).
pub fn rt_str_join_str(arr: [string], sep: string) -> string {
    let n = len(arr)
    if n == 0 { return "" }
    let mut out = arr[0]
    let mut i = 1
    while i < n {
        out = out + sep + arr[i]
        i = i + 1
    }
    return out
}

// Step 3 cycle 42 — string substring with length-style semantics.
// C-side hexa_str_substr handles the void-len → slen-start defaulting
// (HX_TAG check), and passes a concrete count int here. We do the
// remaining clamps (start ∈ [0, slen], count ≥ 0, end ≤ slen) plus the
// substring builtin call.
pub fn rt_str_substr(s: string, start: int, count: int) -> string {
    let slen = byte_len(s)
    let mut a = start
    if a < 0 { a = 0 }
    if a > slen { a = slen }
    let mut c = count
    if c < 0 { c = 0 }
    let mut end_idx = a + c
    if end_idx > slen { end_idx = slen }
    return s.substring(a, end_idx)
}

// Step 3 cycle 27 — count non-overlapping occurrences of substring `sub` in `s`.
// Matches interpreter's greedy advance (hexa_full.hexa:14954-14973). Empty
// pattern → 0 (avoids infinite loop on .strstr-equivalent semantics).
pub fn rt_str_count_substr(s: string, sub: string) -> int {
    let slen = byte_len(s)
    let plen = byte_len(sub)
    if plen == 0 { return 0 }
    let mut cnt = 0
    let mut i = 0
    while i + plen <= slen {
        let mut k = 0
        let mut ok = true
        while k < plen {
            if s.byte_at(i + k) != sub.byte_at(k) {
                ok = false
                k = plen
            } else {
                k = k + 1
            }
        }
        if ok {
            cnt = cnt + 1
            i = i + plen
        } else {
            i = i + 1
        }
    }
    return cnt
}
