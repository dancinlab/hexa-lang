#!hexa strict
// stdlib/booksim/traffic.hexa — synthetic-traffic generators (CLEAN-ROOM)
//
// @version 0.0.1
// @capabilities [traffic, permutation, random]
// @stability phase-e (traffic slice of rfc_003 — uniform/transpose/tornado
//            bodies landed; sweep wiring is a separate later module)
// @since 2026-05-18
//
// CLEAN-ROOM PROVENANCE (design.md Decision 1 — public-surface clean-room)
//   This module re-derives the *public surface* of BookSim2's synthetic
//   TrafficPattern hierarchy by inspection of OSS source + manual only.
//   No upstream code is copied; the C++ class hierarchy
//   (TrafficPattern / PermutationTrafficPattern / *TrafficPattern::dest)
//   is re-expressed from scratch as typed pure hexa functions over a flat
//   k x k grid node-id space. Upstream identifiers ("uniform" /
//   "transpose" / "tornado") are used only as the standardized
//   traffic-pattern vocabulary the BookSim2 manual itself fixes.
//
//   - upstream code    : src/traffic.cpp
//                          :48-194   (TrafficPattern::New string dispatch)
//                          :230-250  (TransposeTrafficPattern::dest)
//                          :289-308  (TornadoTrafficPattern::dest —
//                                     generator STRUCTURE only; the exact
//                                     shift constant is anchored on the
//                                     external theorem below, NOT copied)
//                          :380-396  (UniformRandomTrafficPattern::dest —
//                                     wraps RandomInt(N-1))
//   - upstream spec    : doc/manual.tex §traffic_patterns
//   - upstream license : BSD-2-Clause (Stanford 2007-2015,
//                          /tmp/hexa-arch-rfc001-measurement/booksim2/LICENSE.md)
//   - upstream commit  : 28f43299f1706a3160ffac721ca461d74eb6e618
//
//   - external theorem : Dally & Towles, *Principles and Practices of
//                        Interconnection Networks*, Morgan Kaufmann 2004
//                        (PPIN) §3.2 — permutation-traffic taxonomy.
//                        * transpose  : the matrix-transpose permutation
//                          (i,j) -> (j,i) on the k x k grid (PPIN §3.2).
//                        * tornado    : the canonical adversarial-bisection
//                          stressor, each node shifts by ceil(k/2)-1 in
//                          every dimension (PPIN §3.2). This shift
//                          constant is the EXTERNAL-THEOREM value, marked
//                          NOT-from-BookSim2; only the per-dimension
//                          generator scaffold is re-derived from
//                          traffic.cpp:289-308.
//
//   No code copied from upstream.
//
// Coordinate model (matches the committed records' coord_kind = "xy",
// exports/chip/noc/f1f2/records/2026-05-18_*tornado*.json):
//   node id = i*k + j   for grid coords (i = row 0..k-1, j = col 0..k-1).
//   For k=8, N=64. xr (concentration) = 1 for the rfc_001 chip scope; an
//   xr>1 spec multiplies node count only (uniform range) and is rejected
//   for the permutation generators (raw-91) since the committed records
//   never exercise concentrated traffic.
//
// Structural acceptance (rfc_003 §3.3, task self-test):
//   tornado(0,0) == (3,3) and tornado(7,7) == (2,2) for k=8;
//   transpose is its own inverse; uniform covers the full 0..N-1 range.
//
// Source: rfc_001 §3 minimal subset + rfc_003 §3.3 / §5 provenance map.

// ─── public types ────────────────────────────────────────────────────────

// The three traffic kinds in rfc_001 §3 minimal subset.
// CLEAN-ROOM (traffic.cpp:48-194 TrafficPattern::New string dispatch — the
// upstream std::string switch is re-expressed as a typed enum).
enum TrafficKind {
    UNIFORM,        // uniform random   — traffic.cpp:380-396
    TRANSPOSE,      // matrix transpose — traffic.cpp:230-250 + PPIN §3.2
    TORNADO,        // adversarial-bisection rotate — traffic.cpp:289-308
}                   //                  + PPIN §3.2 shift = ceil(k/2)-1

// Single traffic specification — pure data, no state.
// k, n, xr mirror BookSim2's per-traffic-pattern arguments per
// doc/manual.tex §traffic_patterns table.
struct TrafficSpec {
    kind:  TrafficKind,
    k:     int,         // radix per dimension (8 for an 8x8 mesh)
    n:     int,         // dimension count (2 for a 2-D mesh)
    xr:    int,         // concentration; 1 unless cmesh (chip scope = 1)
    seed:  int,         // RNG seed for uniform's per-call choice
}

// ─── helpers ──────────────────────────────────────────────────────────────

// Total node count N = k^n * xr. CLEAN-ROOM (traffic.cpp uses gNodes =
// product of gK over gN; re-derived here as an explicit pow loop).
fn traffic_node_count(spec: TrafficSpec) -> int {
    let mut n_nodes = 1
    let mut d = 0
    while d < spec.n {
        n_nodes = n_nodes * spec.k
        d = d + 1
    }
    return n_nodes * spec.xr
}

// Per-dimension tornado shift = ceil(k/2) - 1.
// EXTERNAL THEOREM (Dally & Towles PPIN §3.2) — NOT from BookSim2. For
// even k this equals k/2 - 1; for k=8 -> 3. (Integer ceil(k/2) for k>0
// is (k+1)/2 with truncating division: (8+1)/2 = 4, minus 1 = 3.)
fn _tornado_shift(k: int) -> int {
    return ((k + 1) / 2) - 1
}

// Deterministic 32-bit LCG (Numerical Recipes constants). Self-contained:
// the rfc_001 stub's `use "stdlib/qrng/router"` is unavailable in the
// hexa-arch local tree (qrng was absorbed into hexa-lang, not vendored
// here), so per rfc_003 §6 ("LCG fallback if qrng degraded; pick the
// deterministic seed path") uniform uses this in-module generator. Pure
// integer math, no language extension required.
fn _lcg_next(state: int) -> int {
    let raw = (state * 1664525) + 1013904223
    // mask to 31 bits so values stay non-negative regardless of the
    // host int width (hexa `int` is platform-width; we only need a
    // well-mixed non-negative stream).
    return raw % 2147483647
}

// ─── per-kind destination functions ───────────────────────────────────────

// Uniform random destination, any node 0..N-1 (N = k^n * xr).
// CLEAN-ROOM (traffic.cpp:380-396 — `return RandomInt(_nodes-1);`): the
// upstream call into BookSim2's global RNG is re-expressed as a pure
// function of (seed, source) so the same (spec, source) is reproducible.
// The per-call draw mixes the seed with the source id then advances the
// LCG once, mirroring the upstream "one RandomInt per generate" contract.
fn traffic_dest_uniform(spec: TrafficSpec, source: int) -> int {
    let n_nodes = traffic_node_count(spec)
    if n_nodes <= 0 {
        return -1
    }
    let s0 = _lcg_next(spec.seed + (source * 2654435761))
    let s1 = _lcg_next(s0)
    return s1 % n_nodes
}

// Bit/matrix transpose permutation destination — deterministic per source.
// CLEAN-ROOM (traffic.cpp:230-250 TransposeTrafficPattern::dest — the
// upstream per-bit half-swap is re-expressed, for the rfc_001 2-D chip
// scope, as the matrix transpose on the k x k grid: (i,j) -> (j,i),
// PPIN §3.2). Own inverse by construction. xr>1 unsupported (raw-91:
// concentrated transpose is never exercised by the committed records).
fn traffic_dest_transpose(spec: TrafficSpec, source: int) -> int {
    if spec.n != 2 {
        return -1
    }
    if spec.xr != 1 {
        return -1
    }
    let k = spec.k
    let i = source / k
    let j = source % k
    return (j * k) + i
}

// Tornado — the adversarial-bisection stressor (rfc_001 §9 + §3).
// CLEAN-ROOM (traffic.cpp:289-308 TornadoTrafficPattern::dest — the
// upstream per-digit `(dest + shift) % gK` accumulation loop is the
// re-derived STRUCTURE). The shift CONSTANT (ceil(k/2)-1) is the
// EXTERNAL THEOREM (Dally & Towles PPIN §3.2), marked NOT-from-BookSim2.
//   for n=2, k=8, xr=1: shift = 3 → (i,j) -> ((i+3) mod 8, (j+3) mod 8).
// This is exactly the mapping behind
// exports/chip/noc/f1f2/records/2026-05-18_*tornado*.json (coord_kind
// "xy", node id = i*k + j). xr>1 unsupported (raw-91).
fn traffic_dest_tornado(spec: TrafficSpec, source: int) -> int {
    if spec.n != 2 {
        return -1
    }
    if spec.xr != 1 {
        return -1
    }
    let k = spec.k
    let shift = _tornado_shift(k)
    let i = source / k
    let j = source % k
    let di = (i + shift) % k
    let dj = (j + shift) % k
    return (di * k) + dj
}

// ─── dispatch ──────────────────────────────────────────────────────────────

// Generic dispatch — re-derives traffic.cpp:48-194 TrafficPattern::New
// string switch as a typed enum dispatch. Returns -1 on an invalid spec
// (caller MUST check; not a raw-91 here because the dispatcher/CLI parser
// validates the kind string before constructing the TrafficSpec).
//
// hexa-lang gap (this toolchain, hexa 0.1.0-dispatch): there is no `match`
// statement and `enum_a == enum_b` does NOT compare members (always
// false); `int(enum)` also collapses to 0. The working comparison idiom
// is the canonical string form `str(enum)` (yields "TrafficKind::TORNADO"
// etc.), which compares correctly. This is a toolchain limitation, not a
// design choice — see the deliverable's hexa-lang-gaps note.
fn traffic_dest(spec: TrafficSpec, source: int) -> int {
    let kind = str(spec.kind)
    if kind == str(TrafficKind.UNIFORM) {
        return traffic_dest_uniform(spec, source)
    }
    if kind == str(TrafficKind.TRANSPOSE) {
        return traffic_dest_transpose(spec, source)
    }
    if kind == str(TrafficKind.TORNADO) {
        return traffic_dest_tornado(spec, source)
    }
    return -1
}

// ─── self-test (rfc_003 task step 3) ───────────────────────────────────────
//
// Mirrors stdlib/booksim/anynet.hexa: a `fn main()` with a pass/total
// counter that prints PASS n/total and exit(1) on first failure.
// Run with: `hexa run stdlib/booksim/traffic.hexa`.

fn main() {
    let mut pass_count = 0
    let mut total_count = 0
    let mut first_fail = ""

    // k=8 8x8 grid spec (xr=1, n=2) — the committed-records configuration.
    let sp_tor = TrafficSpec {
        kind: TrafficKind.TORNADO, k: 8, n: 2, xr: 1, seed: 1
    }
    let sp_tps = TrafficSpec {
        kind: TrafficKind.TRANSPOSE, k: 8, n: 2, xr: 1, seed: 1
    }
    let sp_uni = TrafficSpec {
        kind: TrafficKind.UNIFORM, k: 8, n: 2, xr: 1, seed: 1
    }

    // --- node count N = k^n * xr = 64 ---
    let n_nodes = traffic_node_count(sp_tor)
    total_count = total_count + 1
    if n_nodes == 64 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "node_count" }
        println("FAIL node_count got=" + str(n_nodes) + " want=64")
    }

    // --- tornado shift constant for k=8 must be 3 ---
    let shift = _tornado_shift(8)
    total_count = total_count + 1
    if shift == 3 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "tornado_shift" }
        println("FAIL tornado_shift got=" + str(shift) + " want=3")
    }

    // --- tornado(0,0) -> (3,3) : src id 0 -> dst id 3*8+3 = 27 ---
    let t00 = traffic_dest_tornado(sp_tor, 0)
    total_count = total_count + 1
    if t00 == 27 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "tornado_00" }
        println("FAIL tornado_00 got=" + str(t00) + " want=27 (3,3)")
    }

    // --- tornado(7,7) -> (2,2) : src id 63 -> dst id 2*8+2 = 18 ---
    let t77 = traffic_dest_tornado(sp_tor, 63)
    total_count = total_count + 1
    if t77 == 18 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "tornado_77" }
        println("FAIL tornado_77 got=" + str(t77) + " want=18 (2,2)")
    }

    // --- tornado is a permutation: all 64 dests distinct + in range ---
    let mut seen_tor: [int] = []
    let mut z = 0
    while z < 64 {
        seen_tor = seen_tor.push(0)
        z = z + 1
    }
    let mut tor_ok = 1
    let mut s = 0
    while s < 64 {
        let d = traffic_dest_tornado(sp_tor, s)
        if d < 0 {
            tor_ok = 0
        } else {
            if d >= 64 {
                tor_ok = 0
            } else {
                if seen_tor[d] == 1 { tor_ok = 0 }
                seen_tor[d] = 1
            }
        }
        s = s + 1
    }
    total_count = total_count + 1
    if tor_ok == 1 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "tornado_permutation" }
        println("FAIL tornado_permutation: not a bijection over 0..63")
    }

    // --- transpose is its own inverse: transpose(transpose(s)) == s ---
    let mut tps_ok = 1
    let mut sx = 0
    while sx < 64 {
        let d1 = traffic_dest_transpose(sp_tps, sx)
        let d2 = traffic_dest_transpose(sp_tps, d1)
        if d2 != sx { tps_ok = 0 }
        sx = sx + 1
    }
    total_count = total_count + 1
    if tps_ok == 1 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "transpose_involution" }
        println("FAIL transpose_involution: transpose not its own inverse")
    }

    // --- transpose spot check: (0,1) id=1 -> (1,0) id=8 ; diagonal fixed ---
    let tp01 = traffic_dest_transpose(sp_tps, 1)
    total_count = total_count + 1
    if tp01 == 8 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "transpose_01" }
        println("FAIL transpose_01 got=" + str(tp01) + " want=8 (1,0)")
    }
    let tp_diag = traffic_dest_transpose(sp_tps, 9)   // (1,1) -> (1,1) = 9
    total_count = total_count + 1
    if tp_diag == 9 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "transpose_diag" }
        println("FAIL transpose_diag got=" + str(tp_diag) + " want=9")
    }

    // --- uniform covers the full 0..63 dest range over many draws ---
    // Draw across all sources, many seeds; assert every node id is hit
    // at least once and no draw escapes 0..63.
    let mut seen_uni: [int] = []
    let mut y = 0
    while y < 64 {
        seen_uni = seen_uni.push(0)
        y = y + 1
    }
    let mut uni_in_range = 1
    let mut trial = 0
    while trial < 400 {
        let mut src = 0
        while src < 64 {
            let sp_t = TrafficSpec {
                kind: TrafficKind.UNIFORM, k: 8, n: 2, xr: 1,
                seed: 1 + trial
            }
            let d = traffic_dest_uniform(sp_t, src)
            if d < 0 {
                uni_in_range = 0
            } else {
                if d >= 64 {
                    uni_in_range = 0
                } else {
                    seen_uni[d] = 1
                }
            }
            src = src + 1
        }
        trial = trial + 1
    }
    let mut uni_covered = 1
    let mut q = 0
    while q < 64 {
        if seen_uni[q] == 0 { uni_covered = 0 }
        q = q + 1
    }
    total_count = total_count + 1
    if uni_in_range == 1 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "uniform_range" }
        println("FAIL uniform_range: a draw escaped 0..63")
    }
    total_count = total_count + 1
    if uni_covered == 1 {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "uniform_coverage" }
        println("FAIL uniform_coverage: not all 64 dests hit")
    }

    // --- determinism: same (spec, source) -> same uniform dest ---
    let u_a = traffic_dest_uniform(sp_uni, 42)
    let u_b = traffic_dest_uniform(sp_uni, 42)
    total_count = total_count + 1
    if u_a == u_b {
        pass_count = pass_count + 1
    } else {
        if first_fail == "" { first_fail = "uniform_determinism" }
        println("FAIL uniform_determinism: " + str(u_a) + " != " + str(u_b))
    }

    // --- dispatch routes each kind correctly ---
    let dd_tor = traffic_dest(sp_tor, 0)
    let dd_tps = traffic_dest(sp_tps, 1)
    total_count = total_count + 1
    if dd_tor == 27 {
        if dd_tps == 8 {
            pass_count = pass_count + 1
        } else {
            if first_fail == "" { first_fail = "dispatch" }
            println("FAIL dispatch transpose got=" + str(dd_tps))
        }
    } else {
        if first_fail == "" { first_fail = "dispatch" }
        println("FAIL dispatch tornado got=" + str(dd_tor))
    }

    println("PASS " + str(pass_count) + "/" + str(total_count)
        + " — stdlib/booksim/traffic.hexa")
    println("  k=8 N=" + str(n_nodes) + " tornado_shift=" + str(shift)
        + " tornado(0,0)->" + str(t00) + " tornado(7,7)->" + str(t77))
    if first_fail != "" {
        println("first fail: " + first_fail)
        exit(1)
    }
}
