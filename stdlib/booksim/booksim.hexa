#!hexa strict
// stdlib/booksim/booksim.hexa — dispatcher / `hexa-arch booksim` entry
//
// @version 0.0.1
// @capabilities [dispatch, cli]
// @stability phase-g (rfc_003 §7) — dispatcher routing + help + version
//   landed; `topology` wired to anynet_load; sweep / wire-delay /
//   oracle / measure remain GATE-style (exit 90 / 91) until rfc_001
//   §8 GREEN — no "absorbed" claim (g3).
// @since 2026-05-18 (.stub) · body landed 2026-05-19
//
// CLEAN-ROOM PROVENANCE (design.md Decision 1)
//   This dispatcher carries NO BookSim2 re-derivation — it is the
//   hexa-arch CLI surface defined in rfc_001 §7.2, structured per the
//   dispatcher pattern of hexa-lang rfc_047 §4 (mc_integrate) and the
//   raw-91 fail-loud doctrine of rfc_048 §3 (xeno). The engine modules
//   it routes into (anynet / iq_router / traffic / sweep / wire_delay /
//   leighton) carry their own per-module clean-room provenance.
//
//   - upstream code    : none (CLI surface, not a BookSim2 port)
//   - upstream spec    : rfc_001 §7.2 (this RFC family's own CLI spec)
//   - dispatcher idiom : hexa-lang rfc_047 §4 · rfc_048 §3 raw-91
//
// CLI surface (rfc_001 §7.2):
//   hexa-arch booksim                       default = help
//   hexa-arch booksim topology load <file>  anynet topology -> typed
//   hexa-arch booksim sweep ...             (gated — rfc_001 §8)
//   hexa-arch booksim wire-delay ...        (gated — rfc_001 §8)
//   hexa-arch booksim oracle ...            (gated — rfc_001 §8)
//   hexa-arch booksim measure ...           (gated — rfc_001 §8)
//   hexa-arch booksim --help, -h
//   hexa-arch booksim --version, -v
//
// Exit codes (rfc_001 §7.3 — raw-91 doctrine; silent skip BANNED):
//   0  success · 1 arg error · 2 unknown topic
//   90 measurement gate not satisfied (no "absorbed" claim — rfc_001 §8)
//   91 unreachable / config missing / TBD body reached

// Only anynet is imported — the dispatcher routes `topology` into
// anynet_load; sweep / wire-delay / oracle / measure are GATE-style
// (exit 90/91, no module call) until rfc_001 §8 GREEN, so importing
// sweep/leighton/iq_router/traffic/wire_delay here is unnecessary
// (and currently triggers the hexa-compiler enum bug noted in
// rfc_003 — RegionShape/TrafficKind undeclared). They get wired in
// per-module as each Phase B/C/D body lands.
use "stdlib/kernels/noc_sim/anynet"
use "stdlib/kernels/noc_sim/leighton"
use "stdlib/kernels/noc_sim/wire_delay"
use "stdlib/kernels/noc_sim/iq_router"
use "stdlib/kernels/noc_sim/traffic"
use "stdlib/kernels/noc_sim/sweep"

let VERSION = "0.0.1"

// ─── flag helpers (mirror the .stub) ─────────────────────────────────────

fn _has_flag(a: [str], flag: str) -> int {
    let mut i = 0
    while i < len(a) {
        if a[i] == flag { return 1 }
        i = i + 1
    }
    return 0
}

fn _find_flag(a: [str], flag: str, default_val: str) -> str {
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] == flag {
            if i + 1 < n { return a[i + 1] }
        }
        let prefix = flag + "="
        if a[i].starts_with(prefix) {
            return a[i].substring(len(prefix), len(a[i]))
        }
        i = i + 1
    }
    return default_val
}

// ─── handlers ────────────────────────────────────────────────────────────

fn cmd_help() -> int {
    println("hexa-arch booksim — NoC-sim CLI (rfc_001 §7.2)")
    println("")
    println("  booksim                       help (default)")
    println("  booksim topology load <file>  parse anynet topology -> typed")
    println("  booksim sweep ...             injection-rate sweep (gated)")
    println("  booksim wire-delay ...        wire-delay profile (gated)")
    println("  booksim oracle ...            Leighton bisection oracle (gated)")
    println("  booksim measure ...           full pipeline -> F1F2 (gated)")
    println("  booksim --help, -h            this help")
    println("  booksim --version, -v         print version")
    println("")
    println("exit: 0 ok · 1 arg · 2 unknown · 90 gate-unmet · 91 unreachable")
    return 0
}

// `booksim topology load <file>` — anynet_load self-exits 91 on a
// read/parse failure (the clean-room loader's own fail-loud).
fn cmd_topology(argv: [str]) -> int {
    let n = len(argv)
    let mut path = ""
    let mut i = 0
    while i < n {
        if argv[i] == "load" {
            if i + 1 < n { path = argv[i + 1] }
        }
        i = i + 1
    }
    if path == "" {
        println("booksim topology: usage: topology load <file>")
        return 1
    }
    let t = anynet_load(path)
    println("booksim topology: parsed OK — router0 degree="
        + str(anynet_router_degree(t, 0)))
    return 0
}

// sweep / wire-delay / oracle — bodies pending rfc_001 §8 GREEN
// (rfc_003 Phase B/C/D). Honest exit 91: TBD body reached, NOT a
// silent skip (@F f4). No "absorbed" claim.
fn cmd_sweep(argv: [str]) -> int {
    println("booksim sweep: pending rfc_001 §8 GREEN (rfc_003 Phase B) — unreachable.")
    return 91
}

fn cmd_wire_delay(argv: [str]) -> int {
    println("booksim wire-delay: pending rfc_001 §8 GREEN (rfc_003 Phase C) — unreachable.")
    return 91
}

fn cmd_oracle(argv: [str]) -> int {
    println("booksim oracle: pending rfc_001 §8 GREEN (rfc_003 Phase D) — unreachable.")
    return 91
}

// ─── F1F2-record serialization (rfc_002 §3 schema 1.0) ──────────────────

fn _pad2i(n: int) -> str {
    if n < 10 { return "0" + str(n) }
    return str(n)
}

// epoch seconds -> "YYYY-MM-DDTHH:MM:SSZ" (UTC, proleptic Gregorian).
// Minimal inline: self/std_time.time_format is unusable on the
// `hexa run` codegen path (string_replace is not a registered
// builtin there) — this avoids that dependency for one ISO stamp.
fn _iso_utc(ts: int) -> str {
    let secs = ts % 60
    let mins = (ts / 60) % 60
    let hrs  = (ts / 3600) % 24
    let mut days = ts / 86400
    let mut year = 1970
    let mut scanning = 1
    while scanning == 1 {
        let mut dy = 365
        if (year % 4 == 0 && year % 100 != 0) || year % 400 == 0 {
            dy = 366
        }
        if days < dy {
            scanning = 0
        } else {
            days = days - dy
            year = year + 1
        }
    }
    let leap = (year % 4 == 0 && year % 100 != 0) || year % 400 == 0
    let mut mlen: [int] = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    if leap {
        mlen = [31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    }
    let mut month = 0
    while days >= mlen[month] {
        days = days - mlen[month]
        month = month + 1
    }
    let day = days + 1
    return str(year) + "-" + _pad2i(month + 1) + "-" + _pad2i(day)
        + "T" + _pad2i(hrs) + ":" + _pad2i(mins) + ":" + _pad2i(secs)
        + "Z"
}

// latency_curve array body — one {injection_rate, avg_latency_cycles}
// object per UNSATURATED sweep point. HONEST (g3): a saturated point
// carries no meaningful latency (sweep.hexa reports 0.0) — emitting
// it would be a false data row, so saturated points are dropped here
// and surfaced only via saturation_throughput.injection_rate_at_knee.
fn _latency_curve_json(pts: [SweepPoint]) -> str {
    let mut s = ""
    let mut emitted = 0
    let mut i = 0
    while i < len(pts) {
        if pts[i].saturated != 1 {
            if emitted > 0 { s = s + ",\n" }
            s = s + "    {\n"
            s = s + "      \"injection_rate\": " + str(pts[i].injection_rate) + ",\n"
            s = s + "      \"avg_latency_cycles\": " + str(pts[i].avg_packet_latency) + "\n"
            s = s + "    }"
            emitted = emitted + 1
        }
        i = i + 1
    }
    return s
}

// Assemble a full F1F2-record JSON (rfc_002 §3 schema 1.0). HONEST
// (g3): measurement_gate is fixed GATE_OPEN and absorbed=false — this
// is a single-point hexa-native analytic sweep, NOT a BookSim2
// cycle-accurate parity run; the scope_caveats spell that out.
fn _f1f2_json(rid: str, iso: str, curve: SweepCurve,
              oracle: LeightonOracle) -> str {
    let mut st = "FAIL"
    if oracle.pass == 1 { st = "PASS" }
    let mut j = "{\n"
    j = j + "  \"interface\": \"hexa-arch:chip:noc:F1F2-record\",\n"
    j = j + "  \"schema_version\": \"1.0\",\n"
    j = j + "  \"record_id\": \"" + rid + "\",\n"
    j = j + "  \"produced_at_utc\": \"" + iso + "\",\n"
    j = j + "  \"topology\": {\n"
    j = j + "    \"kind\": \"mesh_2d\",\n"
    j = j + "    \"degree\": 4,\n"
    j = j + "    \"node_count\": 64,\n"
    j = j + "    \"region_shape\": \"k_by_k\",\n"
    j = j + "    \"routing\": \"min\",\n"
    j = j + "    \"boundary\": \"open\",\n"
    j = j + "    \"coord_kind\": \"xy\"\n"
    j = j + "  },\n"
    j = j + "  \"wire_delay_model\": {\n"
    j = j + "    \"node\": \"22nm\",\n"
    j = j + "    \"ps_per_mm\": 90.0,\n"
    j = j + "    \"cycle_period_ps\": 1000.0,\n"
    j = j + "    \"rc_exponent\": 1\n"
    j = j + "  },\n"
    j = j + "  \"router_cost\": {\n"
    j = j + "    \"vc_count\": 8,\n"
    j = j + "    \"buffer_per_vc_flits\": 8,\n"
    j = j + "    \"packet_size_flits\": 20,\n"
    j = j + "    \"input_speedup\": 2\n"
    j = j + "  },\n"
    j = j + "  \"traffic\": \"uniform\",\n"
    j = j + "  \"latency_curve\": [\n"
    j = j + _latency_curve_json(curve.points) + "\n"
    j = j + "  ],\n"
    j = j + "  \"saturation_throughput\": {\n"
    j = j + "    \"injection_rate_at_knee\": " + str(curve.knee_rate) + ",\n"
    j = j + "    \"knee_definition\": \"first_unstable_injection_rate\"\n"
    j = j + "  },\n"
    j = j + "  \"leighton_oracle\": {\n"
    j = j + "    \"status\": \"" + st + "\",\n"
    j = j + "    \"bisection_bound\": " + str(oracle.bisection_bound) + ",\n"
    j = j + "    \"bisection_observed\": " + str(oracle.bisection_observed) + ",\n"
    j = j + "    \"diameter_bound\": " + str(oracle.diameter_bound) + ",\n"
    j = j + "    \"diameter_observed\": " + str(oracle.diameter_observed) + ",\n"
    j = j + "    \"source_citation\": \"@x_leighton_1992_doi_10.1007_BF01744433\"\n"
    j = j + "  },\n"
    j = j + "  \"verdict\": {\n"
    j = j + "    \"f1\": \"INCONCLUSIVE\",\n"
    j = j + "    \"f2\": \"INCONCLUSIVE\",\n"
    j = j + "    \"rationale\": \"single-topology record; F1/F2 verdict requires the pair-verdict aggregator over this + a degree-paired mate at identical (traffic, node, clock, wire_delay_model)\"\n"
    j = j + "  },\n"
    j = j + "  \"provenance\": {\n"
    j = j + "    \"absorbed\": false,\n"
    j = j + "    \"sim_engine\": \"hexa_native_booksim_stdlib\",\n"
    j = j + "    \"sim_commit_hash\": \"UNPINNED_hexa_lang_stdlib_booksim\",\n"
    j = j + "    \"measurement_gate\": \"GATE_OPEN\",\n"
    j = j + "    \"gate_failures\": [],\n"
    j = j + "    \"consumer_target\": \"hexa-lang:comb:RFC_057:F1F2\",\n"
    j = j + "    \"atlas_cite_block\": \"@cite hexa-arch:rfc_001 4 + 5 + 8 + 9; rfc_002 3; rfc_003 7\",\n"
    j = j + "    \"scope_caveats\": [\n"
    j = j + "      \"hexa-native booksim/sweep.hexa analytic-pipeline measurement -- NOT a BookSim2 cycle-accurate parity run; full-curve rfc_001 8 parity NOT done\",\n"
    j = j + "      \"sweep.hexa is an analytic zero-load + queueing latency model, not an event-driven flit simulator\",\n"
    j = j + "      \"router_cost is the iq_router_default_config analytic estimate, NOT measured silicon area/energy\",\n"
    j = j + "      \"single (22nm, 1 GHz, d4 mesh, uniform) point -- one cell of the rfc_001 9-sweep, not a standalone regime claim\"\n"
    j = j + "    ]\n"
    j = j + "  }\n"
    j = j + "}\n"
    return j
}

// `booksim measure` — the full §B pipeline: anynet -> wire_delay ->
// sweep_curve -> leighton_check -> F1F2-record. HONEST exit 90: the
// record IS emitted (with `--emit <dir>`) but measurement_gate stays
// GATE_OPEN and absorbed=false — emitting absorbed=true before the
// measured full-curve §8 gate is BANNED (g3 / rfc_001 §8). Without
// `--emit` it is a fast dry gate-status check (no file written).
// Exit 91 if the Leighton oracle is violated — record MUST NOT be
// emitted (rfc_001 §7.3).
fn cmd_measure(argv: [str]) -> int {
    let emit_dir = _find_flag(argv, "--emit", "")

    // --- §B pipeline: anynet -> wire_delay -> sweep_curve (uniform) ---
    let topo = anynet_parse(anynet_mesh_8x8_d4_text())
    let p22 = wire_delay_profile_lookup("22nm")
    let mut links: [WireLink] = []
    let mut ei = 0
    while ei < len(topo.edges) {
        links = links.push(WireLink {
            src_router: topo.edges[ei].src,
            dst_router: topo.edges[ei].dst,
            length_mm:  2.5
        })
        ei = ei + 1
    }
    let ll = wire_delay_apply(p22, links)
    let topo_wd = wire_delay_into_anynet(topo, ll)
    let cfg = SweepConfig {
        topology:   topo_wd,
        router_cfg: iq_router_default_config(),
        traffic: TrafficSpec {
            kind: TrafficKind.UNIFORM, k: 8, n: 2, xr: 1, seed: 1
        },
        packet_size:    20,
        sample_period:  4000,
        warmup_periods: 2,
        max_samples:    4,
        seed:           1,
    }
    let rates: [float] = [
        0.05, 0.10, 0.15, 0.20, 0.25, 0.30, 0.35, 0.40, 0.45, 0.50
    ]
    let curve = sweep_curve(cfg, rates)
    if curve.ok != 1 {
        println("booksim measure: sweep_curve failed — " + curve.message)
        return 2
    }

    // --- Leighton oracle — the no-over-claim cross-floor (g3) ---
    let obs_bis = anynet_mesh_bisection(topo, 8)
    let obs_dia = anynet_diameter_hops(topo)
    let d4 = LeightonInput {
        degree: 4, n_nodes: 64,
        region: RegionShape.K_BY_K, region_param: 8
    }
    let oracle = leighton_check(d4, obs_bis, obs_dia)
    if oracle.pass != 1 {
        println("booksim measure: Leighton oracle VIOLATED — "
            + oracle.message)
        return 91
    }

    println("booksim measure — 8x8 mesh · uniform · 22nm (rfc_001 §B):")
    println("  sweep: points=" + str(len(curve.points))
        + " zero_load_lat=" + str(curve.zero_load_lat)
        + " knee_rate=" + str(curve.knee_rate))
    println("  oracle: PASS bisection=" + str(oracle.bisection_observed)
        + ">=" + str(oracle.bisection_bound)
        + " diameter=" + str(oracle.diameter_observed)
        + ">=" + str(oracle.diameter_bound))

    if emit_dir == "" {
        println("booksim measure: dry gate-status — pass `--emit <dir>` "
            + "to write the F1F2 record. measurement_gate=GATE_OPEN, "
            + "absorbed=false (g3 — full-curve §8 parity NOT done).")
        return 90
    }

    // --- emit the F1F2-record (schema 1.0) ---
    let rid = "hexa_native_8x8_mesh_d4_uniform_22nm"
    let iso = _iso_utc(timestamp())
    let json = _f1f2_json(rid, iso, curve, oracle)
    let out_path = emit_dir + "/" + rid + ".json"
    write_file(out_path, json)
    println("booksim measure: F1F2 record emitted → " + out_path)
    println("  measurement_gate=GATE_OPEN absorbed=false — honest "
        + "single-point hexa-native sweep, NOT a parity claim (g3).")
    return 90
}

// ─── dispatch ────────────────────────────────────────────────────────────

// argv shape: [..., "booksim", <subcmd>, <args...>].
fn cmd_booksim(argv: [str]) -> int {
    let n = len(argv)
    let mut idx = 0 - 1
    let mut i = 0
    while i < n {
        if argv[i] == "booksim" { idx = i }
        i = i + 1
    }
    if idx < 0 { return cmd_help() }
    if idx + 1 >= n { return cmd_help() }
    let sub = argv[idx + 1]
    if sub == "--help" { return cmd_help() }
    if sub == "-h" { return cmd_help() }
    if sub == "--version" { println(VERSION); return 0 }
    if sub == "-v" { println(VERSION); return 0 }
    if sub == "topology" { return cmd_topology(argv) }
    if sub == "sweep" { return cmd_sweep(argv) }
    if sub == "wire-delay" { return cmd_wire_delay(argv) }
    if sub == "oracle" { return cmd_oracle(argv) }
    if sub == "measure" { return cmd_measure(argv) }
    println("booksim: unknown topic: " + sub)
    return 2
}

// ─── self-test (rfc_003 idiom — `hexa run stdlib/booksim/booksim.hexa`) ──

fn main() {
    let mut fails = 0
    let mut total = 0

    total = total + 1
    if cmd_booksim(["x", "booksim", "--version"]) != 0 {
        println("FAIL version_exit0"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim", "--help"]) != 0 {
        println("FAIL help_exit0"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim"]) != 0 {
        println("FAIL nosub_help_exit0"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim", "zzz"]) != 2 {
        println("FAIL unknown_exit2"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim", "measure"]) != 90 {
        println("FAIL measure_gate90"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim", "measure", "--emit", "/tmp"]) != 90 {
        println("FAIL measure_emit90"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim", "sweep"]) != 91 {
        println("FAIL sweep_unreach91"); fails = fails + 1
    }
    total = total + 1
    if cmd_booksim(["x", "booksim", "oracle"]) != 91 {
        println("FAIL oracle_unreach91"); fails = fails + 1
    }

    if fails > 0 {
        println("booksim dispatcher selftest: "
            + str(total - fails) + "/" + str(total) + " — FAIL")
        exit(1)
    }
    println("booksim dispatcher selftest: "
        + str(total) + "/" + str(total) + " PASS")
}
