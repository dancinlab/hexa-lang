// `booksim measure --baseline degree-4 --candidate degree-6 ...`.
// The full pipeline: anynet_load -> wire_delay_apply -> sweep_curve ->
// leighton_check -> emit F1F2-record. Exits 90 until the §8 gate closes,
// exits 91 if leighton_check returns pass=0.
fn cmd_measure(argv: [str]) -> int {
    // TBD body — pending rfc_001 §8 GREEN (rfc_003 Phase E + F).
    return 90
}

// `booksim --help`.
fn cmd_help() -> int {
    // TBD body — pending rfc_001 §8 GREEN. Will print the rfc_001 §7.2
    // subcommand table.
    return 91
}

// ─── dispatch table ──────────────────────────────────────────────────────

// Entry point. argv shape: [..., "booksim", <subcmd>, <args...>].
// Routed from self/main.hexa `else if sub == "booksim"` (NOT wired until
// rfc_001 §8 GREEN — rfc_003 §7 Phase G).
fn cmd_booksim(argv: [str]) -> int {
    // TBD body — pending rfc_001 §8 GREEN (rfc_003 Phase A Falsifier A1).
    // Skeleton dispatch shape (bodies TBD):
    //   if no subcmd                  -> cmd_help()
    //   "--help" | "-h"               -> cmd_help()
    //   "--version" | "-v"            -> print VERSION; 0
    //   "topology"                    -> cmd_topology(...)
    //   "sweep"                       -> cmd_sweep(...)
    //   "wire-delay"                  -> cmd_wire_delay(...)
    //   "oracle"                      -> cmd_oracle(...)
    //   "measure"                     -> cmd_measure(...)
    //   else                          -> unknown topic; exit 2
    return 91
}
