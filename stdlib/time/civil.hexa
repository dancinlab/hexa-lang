// HEXA Standard Library — time/civil
//
// @version 0.1.0
// @capabilities [pure]
//
// Pure-hexa civil-date ↔ unix-epoch conversion + ISO 8601 / RFC 3339
// formatting & parsing. NO libc gmtime/timegm/strftime/sprintf — closes
// RUNTIME.md Phase 2 "Time format (ISO 8601, RFC 3339)" with a hexa-native
// path (the existing stdlib/time/iso8601.hexa delegates to libc-backed
// utc_iso_* runtime builtins; this module is the zero-libc alternative).
//
// Algorithm: Howard Hinnant's days_from_civil / civil_from_days (proleptic
// Gregorian, exact for the full int64 range). All integer arithmetic.
//
// Surface:
//   pub fn civil_from_days(days: int) -> [int]    — [year, month, day]
//   pub fn days_from_civil(y: int, m: int, d: int) -> int   — days since 1970-01-01
//   pub fn iso8601_format_native(epoch: int) -> string   — "YYYY-MM-DDTHH:MM:SSZ"
//   pub fn rfc3339_format_native(epoch: int) -> string   — RFC 3339 (= ISO 8601 Z profile)
//   pub fn iso8601_parse_native(s: string) -> int        — epoch secs (−1 on malformed)
//
// Domain: epoch >= 0 (1970-01-01+). Negative epochs need floor-division
// handling not done here (documented; the formatter assumes non-negative).

let _SECS_PER_DAY: int = 86400

// Howard Hinnant: days (since 1970-01-01) → [year, month(1-12), day(1-31)].
@pure
pub fn civil_from_days(days: int) -> [int] {
    let z = days + 719468
    let mut era = z / 146097
    if z < 0 { era = (z - 146096) / 146097 }
    let doe = z - era * 146097                                  // [0, 146096]
    let yoe = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365  // [0, 399]
    let y = yoe + era * 400
    let doy = doe - (365 * yoe + yoe / 4 - yoe / 100)           // [0, 365]
    let mp = (5 * doy + 2) / 153                                 // [0, 11]
    let d = doy - (153 * mp + 2) / 5 + 1                         // [1, 31]
    let m = if mp < 10 { mp + 3 } else { mp - 9 }                // [1, 12]
    let year = if m <= 2 { y + 1 } else { y }
    return [year, m, d]
}

// Inverse: civil date → days since 1970-01-01.
@pure
pub fn days_from_civil(y: int, m: int, d: int) -> int {
    let yy = if m <= 2 { y - 1 } else { y }
    let mut era = yy / 400
    if yy < 0 { era = (yy - 399) / 400 }
    let yoe = yy - era * 400                                     // [0, 399]
    let mpart = if m > 2 { m - 3 } else { m + 9 }
    let doy = (153 * mpart + 2) / 5 + d - 1                      // [0, 365]
    let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy              // [0, 146096]
    return era * 146097 + doe - 719468
}

// Zero-pad an int to `width` digits (non-negative).
@pure
fn _zpad(val: int, width: int) -> string {
    let mut s = to_string(val)
    while len(s) < width { s = "0" + s }
    return s
}

// epoch seconds (UTC) → "YYYY-MM-DDTHH:MM:SSZ".
@pure
pub fn iso8601_format_native(epoch: int) -> string {
    let days = epoch / _SECS_PER_DAY
    let secs = epoch - days * _SECS_PER_DAY      // [0, 86399] for epoch >= 0
    let ymd = civil_from_days(days)
    let hh = secs / 3600
    let mm = (secs - hh * 3600) / 60
    let ss = secs - hh * 3600 - mm * 60
    return _zpad(ymd[0], 4) + "-" + _zpad(ymd[1], 2) + "-" + _zpad(ymd[2], 2)
         + "T" + _zpad(hh, 2) + ":" + _zpad(mm, 2) + ":" + _zpad(ss, 2) + "Z"
}

// RFC 3339 UTC profile is byte-identical to the ISO 8601 "Z" form above.
@pure
pub fn rfc3339_format_native(epoch: int) -> string {
    return iso8601_format_native(epoch)
}

// Parse "YYYY-MM-DDTHH:MM:SSZ" (or space separator, optional trailing Z)
// → epoch seconds. Returns -1 on a malformed/too-short input.
@pure
pub fn iso8601_parse_native(s: string) -> int {
    if byte_len(s) < 19 { return 0 - 1 }
    // Fixed-offset field extraction (ISO 8601 basic UTC form).
    let yr = _digits4(s, 0)
    let mo = _digits2(s, 5)
    let dy = _digits2(s, 8)
    let hh = _digits2(s, 11)
    let mm = _digits2(s, 14)
    let ss = _digits2(s, 17)
    if yr < 0 || mo < 0 || dy < 0 || hh < 0 || mm < 0 || ss < 0 { return 0 - 1 }
    let days = days_from_civil(yr, mo, dy)
    return days * _SECS_PER_DAY + hh * 3600 + mm * 60 + ss
}

@pure
fn _digit_at(s: string, i: int) -> int {
    let c = s.byte_at(i)
    if c < 48 || c > 57 { return 0 - 1 }   // not '0'-'9'
    return c - 48
}
@pure
fn _digits2(s: string, off: int) -> int {
    let a = _digit_at(s, off)
    let b = _digit_at(s, off + 1)
    if a < 0 || b < 0 { return 0 - 1 }
    return a * 10 + b
}
@pure
fn _digits4(s: string, off: int) -> int {
    let a = _digit_at(s, off)
    let b = _digit_at(s, off + 1)
    let c = _digit_at(s, off + 2)
    let d = _digit_at(s, off + 3)
    if a < 0 || b < 0 || c < 0 || d < 0 { return 0 - 1 }
    return a * 1000 + b * 100 + c * 10 + d
}
