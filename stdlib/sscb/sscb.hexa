#!hexa strict
// stdlib/sscb/sscb.hexa — dispatcher / `hexa-lang sscb` entry point
//
// @version 0.1.0
// @capabilities [dispatch, cli]
// @stability bodies landed (κ-41 — routes to wolfspeed + devsim, both
//            of which have real bodies; selftest at the tail)
// @since 2026-05-20
//
// CLEAN-ROOM PROVENANCE (demiurge/design.md D1 + D62 + D67)
//   This dispatcher carries no Wolfspeed `.lib` text and no DEVSIM
//   source — it is the hexa-lang CLI surface for the `sscb` domain,
//   structured per the dispatcher pattern of `stdlib/booksim/
//   booksim.hexa` (rfc_047 §4) + the raw-91 fail-loud doctrine of
//   rfc_048 §3. The engine modules it routes into (wolfspeed, devsim)
//   carry their own per-module clean-room provenance.
//
// CLI surface:
//   hexa run sscb.hexa                          default = help
//   hexa run sscb.hexa parse-lib <file>         SPICE .lib -> Subckt summary
//   hexa run sscb.hexa diode-iv <vmax_mv> <step_mv>   DEVSIM diode I-V
//   hexa run sscb.hexa --help | -h
//   hexa run sscb.hexa --version | -v
//
// Exit codes (booksim raw-91 doctrine — silent skip BANNED):
//   0   success
//   1   subcommand error (bad flags, missing input)
//   2   unknown topic
//   3   engine-tool gap (devsim absent — honest, not a crash)
//   91  unreachable / config missing (file-not-found in parse-lib)
//
// Source: demiurge κ-39 (D62) skeleton + κ-41 (D67) bodies.

import "stdlib/sscb/wolfspeed"
import "stdlib/sscb/devsim"
import "stdlib/sscb/wolfspeed_parity"

let VERSION = "0.1.0"

// ─── per-subcommand handlers ─────────────────────────────────────────────

// `sscb parse-lib <file>` — parse a SPICE .lib, print a typed summary.
fn cmd_parse_lib(argv: [str]) -> int {
    if len(argv) < 1 {
        println("sscb parse-lib: missing <file> argument")
        return 1
    }
    let path = argv[0]
    // wolfspeed_parse_lib exits 91 itself on a missing / malformed file.
    let s = wolfspeed_parse_lib(path)
    println("subckt: " + s.name)
    println("  pins:      " + str(len(s.pins)))
    println("  elements:  " + str(len(s.elements)))
    println("  params:    " + str(len(s.params)))
    println("  submodels: " + str(len(s.submodels)))
    let mut i = 0
    while i < len(s.submodels) {
        let m = s.submodels[i]
        let tag = ""
        if wolfspeed_is_vdmos(m) == 1 {
            println("    model[" + str(i) + "]: " + m.name + " (VDMOS, " + str(len(m.params)) + " params)")
        } else {
            println("    model[" + str(i) + "]: " + m.name + " (" + m.kind + ", " + str(len(m.params)) + " params)")
        }
        i = i + 1
    }
    return 0
}

// `sscb diode-iv <vmax_mv> <step_mv>` — DEVSIM 1-D Si PN-diode I-V sweep.
fn cmd_diode_iv(argv: [str]) -> int {
    let mut vmax_mv = 600
    let mut step_mv = 100
    if len(argv) >= 2 {
        vmax_mv = to_int(argv[0])
        step_mv = to_int(argv[1])
    }
    let run = devsim_diode_iv(vmax_mv, step_mv)
    if run.ok == 0 {
        println("sscb diode-iv: engine-tool gap — " + run.log)
        return 3
    }
    println("sscb diode-iv: device=" + run.device + " npts=" + str(run.npts))
    let mut i = 0
    while i < len(run.iv_curve) {
        let row = run.iv_curve[i]
        println("  V=" + str(row[0]) + " I=" + str(row[1]))
        i = i + 1
    }
    return 0
}

// `sscb datasheet-parity` — verify the clean-room C3M0021120K model
// reproduces the Wolfspeed datasheet (Rev.4) tabulated specs via ngspice.
fn cmd_datasheet_parity(argv: [str]) -> int {
    println("C3M0021120K datasheet parity (model: fixtures/c3m0021120k.lib)")
    let r1 = parity_rdson()
    let r2 = parity_vgsth()
    let results = [r1, r2]
    let mut fails = 0
    let mut i = 0
    while i < len(results) {
        let r = results[i]
        if r.ok == 1 {
            println("  ok  " + r.spec + ": measured=" + str(r.measured)
                    + " datasheet=" + str(r.datasheet)
                    + " err=" + str(r.rel_err * 100.0) + "%")
        } else {
            println("  FAIL " + r.spec + ": measured=" + str(r.measured)
                    + " datasheet=" + str(r.datasheet))
            fails = fails + 1
        }
        i = i + 1
    }
    if fails == 0 {
        println("parity: PASS (substrate — ngspice engine; absorbed=true still needs hexa-native solver)")
        return 0
    }
    return 1
}

fn cmd_help() -> int {
    println("hexa-lang sscb — solid-state DC circuit-breaker domain tools")
    println("usage:")
    println("  sscb parse-lib <file>             SPICE .lib -> typed Subckt summary")
    println("  sscb diode-iv <vmax_mv> <step_mv> DEVSIM 1-D Si PN-diode I-V sweep")
    println("  sscb datasheet-parity             C3M0021120K model vs Wolfspeed datasheet")
    println("  sscb --help | -h")
    println("  sscb --version | -v")
    return 0
}

// ─── dispatch table ──────────────────────────────────────────────────────

// argv shape: [<subcmd>, <args…>] — the `sscb` token and program name
// are NOT included (caller slices them off, mirrors booksim's cmd_*).
fn cmd_sscb(argv: [str]) -> int {
    if len(argv) == 0 { return cmd_help() }
    let sub = argv[0]
    if sub == "--help" || sub == "-h" { return cmd_help() }
    if sub == "--version" || sub == "-v" {
        println("sscb " + VERSION)
        return 0
    }
    // rest = argv[1..]
    let mut rest: [str] = []
    let mut i = 1
    while i < len(argv) {
        rest = rest.push(argv[i])
        i = i + 1
    }
    if sub == "parse-lib" { return cmd_parse_lib(rest) }
    if sub == "diode-iv" { return cmd_diode_iv(rest) }
    if sub == "datasheet-parity" { return cmd_datasheet_parity(rest) }
    println("sscb: unknown topic: " + sub)
    return 2
}

// ─── main ────────────────────────────────────────────────────────────────

// Live CLI: forward the real process args (minus argv[0] = script path).
fn main() {
    let av = argv()
    let mut rest: [str] = []
    let mut i = 1
    while i < len(av) {
        rest = rest.push(av[i])
        i = i + 1
    }
    let rc = cmd_sscb(rest)
    exit(rc)
}
