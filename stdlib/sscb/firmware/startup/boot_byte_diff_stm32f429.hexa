#!hexa strict
// stdlib/sscb/firmware/startup/boot_byte_diff_stm32f429.hexa
//   F5 RFC 063/064 full-boot byte-diff (stm32f429 CMSIS startup).
//
// Proves the hexa CMSIS-startup emitter (stdlib/hal/boot_emit.hexa
// ::stm32f429_emit_full_startup_s) produces a complete startup `.s`
// byte-identical to the hand-written
// stdlib/sscb/firmware/startup/startup_stm32f429.s.
//
// Phase: foundation (PR1 of F5 stm32f429 leg = LAST `.s` file).
// This is the BYTE-IDENTICAL `arm-none-eabi-as` byte-diff verify gate
// the runbook §F5 mandates before the hand-written `.s` can be
// deleted (`git rm startup_stm32f429.s`, `.s` 1→0 = `.s` leg COMPLETE).
//
// Scope: ALL THREE sections (.isr_vector, .text.Reset_Handler,
// .text.Default_Handler) PLUS reloc lists. All byte-equal → the
// hand-written `.s` is provably redundant.
//
// PASS criterion:
//   arm-none-eabi-{as,objcopy,objdump} available
//   emitter output assembles cleanly
//   sha256(.isr_vector            bytes) == orig
//   sha256(.text.Reset_Handler    bytes) == orig
//   sha256(.text.Default_Handler  bytes) == orig
//   reloc lists identical for all three sections
//
// FAIL: toolchain missing OR assemble error OR section byte-diff > 0.
// Returns 1 on FAIL so a parent falsifier_check or CI gate can flip to ✗.
//
// ⚠ HARD GATE: byte-diff PASS is REQUIRED before `git rm startup_stm32f429.s`.
// Wrong reset vector OR wrong prologue silently bricks the MCU.
//
// Run:
//   HEXA_HAL_ROOT=<repo-root> hexa-run \
//     stdlib/sscb/firmware/startup/boot_byte_diff_stm32f429.hexa

use "stdlib/hal/boot_emit"

let MODULE_NAME = "boot_byte_diff_stm32f429"

// ─── check harness ────────────────────────────────────────────────────

let mut RUN  = 0
let mut FAIL = 0

fn _check(ok: bool, label: str, detail: str) {
    RUN = RUN + 1
    let mark = if ok { "PASS" } else { "FAIL" }
    if !ok { FAIL = FAIL + 1 }
    println("  [" + mark + "] " + label)
    if detail.len() > 0 { println("         · " + detail) }
}

// ─── helpers ─────────────────────────────────────────────────────────

fn _root() -> str {
    let env_root = env("HEXA_HAL_ROOT")
    if env_root.len() > 0 { return env_root }
    return exec("pwd").trim()
}

fn _which(cmd: str) -> bool {
    let r = exec("command -v " + cmd + " >/dev/null 2>&1 && echo y || echo n").trim()
    return r == "y"
}

fn _exists(p: str) -> bool {
    let r = exec("[ -f \"" + p + "\" ] && echo y || echo n").trim()
    return r == "y"
}

fn _sha256(p: str) -> str {
    if _which("shasum") {
        let r = exec("shasum -a 256 \"" + p + "\" 2>/dev/null | awk '{print $1}'").trim()
        return r
    }
    if _which("sha256sum") {
        let r = exec("sha256sum \"" + p + "\" 2>/dev/null | awk '{print $1}'").trim()
        return r
    }
    return ""
}

fn _write_file(p: str, content: str) -> bool {
    let cmd = "cat > \"" + p + "\" <<'__BOOT_BYTE_DIFF_STM32F429_EOF__'\n" +
              content + "\n__BOOT_BYTE_DIFF_STM32F429_EOF__"
    let _ = exec(cmd)
    return _exists(p)
}

// stm32f429 as flags: mirrors sscb firmware/Makefile ASFLAGS verbatim
// (Cortex-M4 + FPv4-SP-D16 single-precision FPU + hard float ABI).

let AS_FLAGS_STM32F429 = "-mcpu=cortex-m4 -mthumb -mfpu=fpv4-sp-d16 -mfloat-abi=hard"

// ─── checks ──────────────────────────────────────────────────────────

fn check_toolchain() -> bool {
    let has_as      = _which("arm-none-eabi-as")
    let has_objcopy = _which("arm-none-eabi-objcopy")
    let has_objdump = _which("arm-none-eabi-objdump")
    let ok = has_as && has_objcopy && has_objdump
    let detail = "as=" + (if has_as { "y" } else { "n" }) +
                 " objcopy=" + (if has_objcopy { "y" } else { "n" }) +
                 " objdump=" + (if has_objdump { "y" } else { "n" })
    _check(ok, "arm-none-eabi-as + objcopy + objdump present", detail)
    return ok
}

fn check_orig_present(startup_dir: str) -> bool {
    // Post-deletion: the hand-written `.s` is `git rm`d after this
    // oracle PASSes. Missing file → graceful SKIP (the proof exists
    // in git history). Don't increment FAIL here.
    let p = startup_dir + "/startup_stm32f429.s"
    let ok = _exists(p)
    if ok {
        _check(true, "hand-written startup_stm32f429.s present", p)
    }
    return ok
}

fn check_emit_assembles(work_dir: str) -> bool {
    let gen_s = work_dir + "/gen_startup.s"
    let gen_o = work_dir + "/gen_startup.o"
    let s_text = stm32f429_emit_full_startup_s()
    let wrote = _write_file(gen_s, s_text)
    if !wrote {
        _check(false, "emitter `.s` text written", gen_s); return false
    }
    let cmd = "arm-none-eabi-as " + AS_FLAGS_STM32F429 +
              " -o \"" + gen_o + "\" \"" + gen_s + "\" 2>&1"
    let out = exec(cmd)
    let ok = _exists(gen_o)
    _check(ok, "emitter output assembles via arm-none-eabi-as",
           if ok { "wrote " + gen_o } else { "assemble error:\n" + out })
    return ok
}

fn check_orig_assembles(startup_dir: str, work_dir: str) -> bool {
    let orig_s = startup_dir + "/startup_stm32f429.s"
    let orig_o = work_dir + "/orig.o"
    let cmd = "arm-none-eabi-as " + AS_FLAGS_STM32F429 +
              " -o \"" + orig_o + "\" \"" + orig_s + "\" 2>&1"
    let out = exec(cmd)
    let ok = _exists(orig_o)
    _check(ok, "hand-written startup_stm32f429.s assembles",
           if ok { "wrote " + orig_o } else { "assemble error:\n" + out })
    return ok
}

fn _section_byte_identical(work_dir: str, section: str, label: str) -> bool {
    let gen_o = work_dir + "/gen_startup.o"
    let orig_o = work_dir + "/orig.o"
    let gen_bin = work_dir + "/gen_" + label + ".bin"
    let orig_bin = work_dir + "/orig_" + label + ".bin"
    if !_exists(gen_o) || !_exists(orig_o) {
        _check(false, section + " section byte-identical (gen ≡ orig)",
               "missing object file(s)"); return false
    }
    let _ = exec("arm-none-eabi-objcopy -O binary --only-section=" + section +
                 " \"" + gen_o + "\" \"" + gen_bin + "\" 2>&1")
    let _2 = exec("arm-none-eabi-objcopy -O binary --only-section=" + section +
                  " \"" + orig_o + "\" \"" + orig_bin + "\" 2>&1")
    let gen_sha = _sha256(gen_bin)
    let orig_sha = _sha256(orig_bin)
    let ok = gen_sha.len() > 0 && gen_sha == orig_sha
    let detail = "gen=" + gen_sha + " orig=" + orig_sha
    _check(ok, section + " section byte-identical (gen ≡ orig)", detail)
    return ok
}

fn _section_relocs_identical(work_dir: str, section: str, expected: str) -> bool {
    let gen_o = work_dir + "/gen_startup.o"
    let orig_o = work_dir + "/orig.o"
    if !_exists(gen_o) || !_exists(orig_o) {
        _check(false, section + " relocs identical (gen ≡ orig)",
               "missing object file(s)"); return false
    }
    let gen_r = exec("arm-none-eabi-objdump -r --section=" + section +
                     " \"" + gen_o + "\" 2>&1 | grep -E 'R_ARM' | sort").trim()
    let orig_r = exec("arm-none-eabi-objdump -r --section=" + section +
                      " \"" + orig_o + "\" 2>&1 | grep -E 'R_ARM' | sort").trim()
    let ok = gen_r == orig_r && gen_r.len() > 0
    let detail = if ok { expected } else { "gen:\n" + gen_r + "\norig:\n" + orig_r }
    _check(ok, section + " relocs identical (gen ≡ orig)", detail)
    return ok
}

// ─── main ────────────────────────────────────────────────────────────

fn main() {
    println("========================================================================")
    println("  stdlib/sscb — boot_byte_diff_stm32f429: F5 CMSIS-STARTUP byte-diff oracle")
    println("========================================================================")
    println("  generator: stdlib/hal/boot_emit.hexa (stm32f429_emit_full_startup_s)")
    println("  oracle:    arm-none-eabi-as byte-diff vs startup_stm32f429.s")
    println("  target:    ARMv7E-M Cortex-M4 + FPv4-SP-D16 CMSIS startup (full)")
    println("")

    let root = _root()
    let startup_dir = root + "/stdlib/sscb/firmware/startup"
    let work_dir = exec("mktemp -d -t boot_byte_diff_stm32f429.XXXXXX").trim()
    if work_dir.len() == 0 {
        println("[FATAL] mktemp failed — cannot allocate scratch dir")
        exit(1)
    }
    println("  scratch: " + work_dir)
    println("")

    if !check_toolchain() {
        println("")
        println("  Toolchain missing — install arm-none-eabi-{as,objcopy,objdump}.")
        println("  F5 stm32f429 CMSIS-startup byte-diff verify SKIP (toolchain gate).")
        println("__HEXA_LANG_SSCB_BOOT_BYTE_DIFF_STM32F429__ SKIP")
        exit(0)
    }

    if !check_orig_present(startup_dir) {
        // Post-deletion: hand-written startup_stm32f429.s was `git rm`d
        // after this oracle PASSed. Post-deletion runs SKIP gracefully —
        // the proof already exists in git history. To re-prove against a
        // fresh baseline, `git show <pre-deletion-sha>:stdlib/sscb/firmware/startup/startup_stm32f429.s`.
        println("")
        println("  POST-DELETION SKIP — hand-written baseline startup_stm32f429.s removed")
        println("  after this oracle PASSed (gen ≡ orig). The emitter remains the SSOT;")
        println("  replay the historical proof via")
        println("  `git show <pre-deletion-sha>:stdlib/sscb/firmware/startup/startup_stm32f429.s`.")
        println("__HEXA_LANG_SSCB_BOOT_BYTE_DIFF_STM32F429__ SKIP")
        exit(0)
    }

    let emit_ok = check_emit_assembles(work_dir)
    let orig_ok = check_orig_assembles(startup_dir, work_dir)

    if !emit_ok || !orig_ok {
        println("__HEXA_LANG_SSCB_BOOT_BYTE_DIFF_STM32F429__ FAIL")
        exit(1)
    }

    // 3 section byte-diffs + 3 reloc-list diffs = 6 verify checks.
    let _v1 = _section_byte_identical(work_dir, ".isr_vector", "isr_vector")
    let _v2 = _section_byte_identical(work_dir, ".text.Reset_Handler", "reset")
    let _v3 = _section_byte_identical(work_dir, ".text.Default_Handler", "default")
    let _v4 = _section_relocs_identical(work_dir, ".isr_vector",
        "107× R_ARM_ABS32 (16 system + 89 IRQ + 2 named handlers)")
    let _v5 = _section_relocs_identical(work_dir, ".text.Reset_Handler",
        "R_ARM_THM_CALL main + 6× R_ARM_ABS32 literal-pool entries")
    let _v6 = _section_relocs_identical(work_dir, ".text.Default_Handler",
        "(empty — Default_Handler body is a single self-branch with no relocs)")

    println("")
    println("  F5 stm32f429 leg (CMSIS startup full = vector + reset + default) byte-identity:")
    if FAIL == 0 {
        println("    PROVEN ✓ — stm32f429 CMSIS startup is fully hexa-emittable.")
        println("    DELETION GATE OPEN — hand-written startup_stm32f429.s may be `git rm`.")
        println("    `.s` 1→0 — F5 .s-leg COMPLETE (last hand-written .s deleted).")
    } else {
        println("    BYTE-DIFF FAIL — emitter output diverges from hand-written `.s`.")
        println("    ⚠ Hand-written `.s` MUST NOT be deleted until oracle PASSES.")
        println("    ⚠ Wrong reset vector OR wrong prologue silently bricks the MCU.")
    }

    let pass_n = RUN - FAIL
    println("========================================================================")
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_LANG_SSCB_BOOT_BYTE_DIFF_STM32F429__ FAIL")
        exit(1)
    }
    println("__HEXA_LANG_SSCB_BOOT_BYTE_DIFF_STM32F429__ PASS")
    exit(0)
}
