#!hexa strict
// stdlib/sscb/firmware/src/main_emit.hexa
//   B9.C-2 (.c-leg batch · #1847 pattern) — main.c source emitter.
//
// Mirrors adc_dma_emit.hexa one-to-one. Emits the SSCB firmware
// `main.c` — entry point from module/engineering_pack/README.md §5.1.
//
// Top-level decls: struct sscb_state · adc_buf · main · main_loop ·
// fault_sm_step · telemetry_send · wdt_refresh · irms_estimate ·
// fault_log_write · gpio_set_fault_low.
//
// Safe to regenerate: main.c only references identifiers defined in
// `include/sscb.h` + `include/stm32f4xx_min.h` (CMSIS-style headers)
// and other firmware .c files. No hidden invariants.
//
// Invocation:
//   hexa-run stdlib/sscb/firmware/src/main_emit.hexa <output-path>
//
// Default output path (if argv missing): "main.c" in cwd.

let MODULE_NAME = "main_emit"

fn emit_main_c() -> str {
    // Verbatim content of hand-written stdlib/sscb/firmware/src/main.c
    let s = "/* main.c — SSCB mk1 firmware entry.\n" +
            " * Source: module/engineering_pack/README.md §5.1.\n" +
            " */\n" +
            "#include \"stm32f4xx_min.h\"\n" +
            "#include \"sscb.h\"\n" +
            "\n" +
            "struct sscb_state sscb_state;\n" +
            "int16_t adc_buf[ADC_BLOCK_SIZE];\n" +
            "\n" +
            "int main(void) {\n" +
            "    system_init();\n" +
            "    dwt_cycle_counter_enable();\n" +
            "\n" +
            "    adc_spi_dma_init();\n" +
            "    comparator_init();\n" +
            "    gate_driver_init();\n" +
            "    host_iface_init();\n" +
            "\n" +
            "    sscb_state.state_id = SSCB_STATE_IDLE;\n" +
            "    main_loop();\n" +
            "\n" +
            "    /* not reached */\n" +
            "    return 0;\n" +
            "}\n" +
            "\n" +
            "void main_loop(void) {\n" +
            "    for (;;) {\n" +
            "        /* §5.1 — ADC consumed in DMA2_Stream2_IRQHandler; here we run the\n" +
            "         * state machine + telemetry + WDT refresh in a flat foreground. */\n" +
            "        fault_sm_step();\n" +
            "        telemetry_send();\n" +
            "        wdt_refresh();\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "/* §5.5 state machine — minimal mk1 implementation.\n" +
            " * Mk.II adds RECLOSE_WAIT timer; mk1 leaves reset to host. */\n" +
            "void fault_sm_step(void) {\n" +
            "    switch (sscb_state.state_id) {\n" +
            "    case SSCB_STATE_IDLE:\n" +
            "        /* self-test passes externally; placeholder transition */\n" +
            "        sscb_state.state_id = SSCB_STATE_ARMED;\n" +
            "        break;\n" +
            "    case SSCB_STATE_ARMED:\n" +
            "        if (sscb_state.flags & (FLT_HW_TRIPPED | FLT_SW_TRIPPED)) {\n" +
            "            sscb_state.state_id = SSCB_STATE_TRIPPED;\n" +
            "            sscb_state.cycle_count++;\n" +
            "        }\n" +
            "        break;\n" +
            "    case SSCB_STATE_TRIPPED:\n" +
            "        /* host clears flags; mk1 returns to IDLE for re-arm. */\n" +
            "        if ((sscb_state.flags & (FLT_HW_TRIPPED | FLT_SW_TRIPPED)) == 0) {\n" +
            "            sscb_state.state_id = SSCB_STATE_IDLE;\n" +
            "        }\n" +
            "        break;\n" +
            "    case SSCB_STATE_RECLOSE_WAIT:\n" +
            "        /* mk1: never entered; Mk.II adds AUTORECLOSE_DELAY_MS timer here. */\n" +
            "        sscb_state.state_id = SSCB_STATE_IDLE;\n" +
            "        break;\n" +
            "    }\n" +
            "}\n" +
            "\n" +
            "void telemetry_send(void) {\n" +
            "    /* UART3 ring-buffer drain; placeholder — full ring impl in §5.1 host_iface. */\n" +
            "}\n" +
            "\n" +
            "void wdt_refresh(void) {\n" +
            "    /* IWDG reload — KR=0xAAAA. Stub here; production firmware writes to IWDG->KR. */\n" +
            "}\n" +
            "\n" +
            "int32_t irms_estimate(const int16_t *p, uint16_t n) {\n" +
            "    /* Crude RMS: sum of squares / n, cast to int32. Production replaces with\n" +
            "     * fixed-point sqrt + EWMA. The §5.2 spec only requires \"rolling RMS\". */\n" +
            "    uint64_t sumsq = 0;\n" +
            "    for (uint16_t i = 0; i < n; i++) {\n" +
            "        int32_t s = p[i];\n" +
            "        sumsq += (uint64_t)(s * s);\n" +
            "    }\n" +
            "    return (int32_t)(sumsq / (n ? n : 1));\n" +
            "}\n" +
            "\n" +
            "void fault_log_write(uint32_t timestamp, uint8_t cause) {\n" +
            "    /* Ring-buffered UART log; placeholder. */\n" +
            "    (void)timestamp;\n" +
            "    (void)cause;\n" +
            "}\n" +
            "\n" +
            "void gpio_set_fault_low(void) {\n" +
            "    /* Drive /FAULT pin low. Pin assignment lives in engineering_pack §3 PCB.\n" +
            "     * Stub here — production sets GPIOx->BSRR with the pin's reset bit. */\n" +
            "}\n"
    return s
}

fn main() {
    let argv = real_args()
    let out_path = if argv.len() >= 1 { argv[0] } else { "main.c" }
    let c_text = emit_main_c()
    let cmd = "cat > \"" + out_path + "\" <<'__MAIN_EMIT_EOF__'\n" +
              c_text + "__MAIN_EMIT_EOF__"
    let _ = exec(cmd)
    let exists_check = exec("[ -f \"" + out_path + "\" ] && echo y || echo n").trim()
    if exists_check != "y" {
        println("[main_emit] FATAL: failed to write " + out_path)
        exit(1)
    }
    println("[main_emit] wrote " + out_path)
    exit(0)
}
