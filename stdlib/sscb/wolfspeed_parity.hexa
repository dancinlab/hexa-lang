#!hexa strict
// stdlib/sscb/wolfspeed_parity.hexa — datasheet-parity verification for
//                                     the C3M0021120K clean-room model
//
// @version 0.1.0
// @capabilities [parity, measure]
// @stability bodies landed (κ-41 addendum — real ngspice parity GREEN)
// @since 2026-05-20
//
// CLEAN-ROOM PROVENANCE (demiurge/design.md D1 + D67)
//   This module verifies that the clean-room SPICE model
//   `fixtures/c3m0021120k.lib` — built entirely from the PUBLIC
//   Wolfspeed C3M0021120K data sheet (Rev. 4, June 2025;
//   assets.wolfspeed.com/uploads/2020/12/C3M0021120K.pdf) — reproduces
//   that data sheet's own tabulated electrical-characteristics values
//   when simulated with ngspice. No bytes of Wolfspeed's distributed
//   `.lib` model are used (that file is form-gated and never accessed).
//
// ── What this measures (honest scope — g3) ──────────────────────────────
//   For each datasheet spec it (a) generates an ngspice deck that biases
//   the device at the datasheet's stated TEST CONDITION, (b) runs
//   `ngspice -b`, (c) parses the measured value, (d) compares to the
//   datasheet's tabulated typ value with a ±10 % tolerance gate.
//
//   Specs checked:
//     R_DS(on)  — datasheet 21 mOhm typ  @ V_GS=15 V, I_D=50 A   [p2]
//     V_GS(th)  — datasheet 2.5 V typ    @ V_DS=V_GS, I_D=17.7mA [p2]
//
//   HONEST CIRCULARITY NOTE (g3): the model's VTO is set to the
//   datasheet V_GS(th), and R_DS(on) is partly calibrated via the
//   access resistances RD/RS. So this is NOT a fully-independent
//   prediction — it is a *consistency* check: it confirms the netlist
//   parses, ngspice converges, and the simulated operating points land
//   on the datasheet table. The non-trivial part is genuine — the
//   channel contribution to R_DS(on) emerges from KP (which is sized
//   from the INDEPENDENT g_fs spec), and V_GS(th) measured at
//   I_D=17.7 mA is not identically VTO. A gross modelling error (wrong
//   units, non-convergence, bad topology) would fail this gate.
//
//   This is a SUBSTRATE parity: the engine is ngspice (external C
//   solver). It does NOT flip `absorbed=true` — that needs a
//   hexa-native SPICE MNA solver (a separate, large effort). It DOES
//   close the "datasheet parity 검증" deliverable: the model is now
//   datasheet-grounded and verified, not an arbitrary placeholder.
//
// ── Public API ──────────────────────────────────────────────────────────
//   pub struct ParityResult { spec, measured, datasheet, rel_err, ok }
//   pub fn parity_rdson() -> ParityResult
//   pub fn parity_vgsth() -> ParityResult

// ─── datasheet reference constants (Wolfspeed C3M0021120K Rev.4 p2) ──────

let DS_RDSON_OHM = 0.021      // R_DS(on) typ — V_GS=15 V, I_D=50 A
let DS_VGSTH_V   = 2.5        // V_GS(th) typ — V_DS=V_GS, I_D=17.7 mA
let TOL          = 0.10       // ±10 % parity gate

let LIB_PATH = "stdlib/sscb/fixtures/c3m0021120k.lib"

// ─── typed result ────────────────────────────────────────────────────────

pub struct ParityResult {
    spec: str,
    measured: float,
    datasheet: float,
    rel_err: float,
    ok: int
}

// ─── helpers ─────────────────────────────────────────────────────────────

fn _absf(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

fn _shq(s: str) -> str {
    let mut out = "'"
    let mut i = 0
    let n = len(s)
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "'" { out = out + "'\\''" } else { out = out + ch }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _split_ws(s: str) -> [str] {
    let mut out: [str] = []
    let mut cur = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let ch = s.substring(i, i + 1)
        let is_sp = ch == " " || ch == "\t" || ch == "\r"
        if is_sp {
            if cur != "" { out = out.push(cur) }
            cur = ""
        } else {
            cur = cur + ch
        }
        i = i + 1
    }
    if cur != "" { out = out.push(cur) }
    return out
}

// Absolute path to the .lib (ngspice .include needs a resolvable path).
fn _lib_abspath() -> str {
    let pwd = to_string(exec("pwd")).trim()
    return pwd + "/" + LIB_PATH
}

fn _locate_ngspice() -> str {
    let candidates = ["/opt/homebrew/bin/ngspice", "/usr/local/bin/ngspice", "/usr/bin/ngspice"]
    let mut i = 0
    while i < len(candidates) {
        let probe = to_string(exec("test -x " + _shq(candidates[i]) + " && printf ok || true")).trim()
        if probe == "ok" { return candidates[i] }
        i = i + 1
    }
    let p = to_string(exec("command -v ngspice 2>/dev/null || true")).trim()
    if len(p) > 0 { return p }
    return ""
}

// Pull the float that follows `key` + `=` out of ngspice batch output.
// ngspice prints `meas`/`print` results as `name = 1.234560e-02`.
fn _grab_eq(text: str, key: str) -> float {
    let lines = text.split("\n")
    let mut li = 0
    while li < len(lines) {
        let toks = _split_ws(lines[li])
        let mut k = 0
        while k < len(toks) {
            if toks[k] == key {
                // expect toks[k+1] == "=", toks[k+2] == value
                if k + 2 < len(toks) {
                    if toks[k + 1] == "=" { return to_float(toks[k + 2]) }
                }
                // or "key=value" already split? fall through
            }
            k = k + 1
        }
        li = li + 1
    }
    return -1.0
}

// ─── parity: R_DS(on) ────────────────────────────────────────────────────

// Datasheet test condition: V_GS=15 V, I_D=50 A → R_DS(on) = V_DS / I_D.
// Deck forces 50 A into the drain via a current source, holds gate at
// 15 V, and computes the on-resistance at the DC operating point.
pub fn parity_rdson() -> ParityResult {
    let ngs = _locate_ngspice()
    if ngs == "" {
        return ParityResult { spec: "R_DS(on)", measured: -1.0, datasheet: DS_RDSON_OHM, rel_err: -1.0, ok: 0 }
    }
    let nl = "\n"
    let mut deck = "* C3M0021120K R_DS(on) parity — Vgs=15 V, Id=50 A" + nl
    deck = deck + ".include " + _lib_abspath() + nl
    deck = deck + "X1 d g 0 tj tc C3M0021120K" + nl
    deck = deck + "Vgs g 0 DC 15" + nl
    deck = deck + "Itest 0 d DC 50" + nl
    deck = deck + "Vtj tj 0 DC 25" + nl
    deck = deck + "Vtc tc 0 DC 25" + nl
    deck = deck + ".control" + nl
    deck = deck + "op" + nl
    deck = deck + "let rdson = v(d)/50" + nl
    deck = deck + "print rdson" + nl
    deck = deck + ".endc" + nl
    deck = deck + ".end" + nl
    let deck_path = "/tmp/hexa_c3m_rdson.cir"
    write_file(deck_path, deck)

    let out = to_string(exec(_shq(ngs) + " -b " + _shq(deck_path) + " 2>&1"))
    let measured = _grab_eq(out, "rdson")
    if measured < 0.0 {
        return ParityResult { spec: "R_DS(on)", measured: -1.0, datasheet: DS_RDSON_OHM, rel_err: -1.0, ok: 0 }
    }
    let err = _absf(measured - DS_RDSON_OHM) / DS_RDSON_OHM
    let mut ok = 0
    if err <= TOL { ok = 1 }
    return ParityResult { spec: "R_DS(on)", measured: measured, datasheet: DS_RDSON_OHM, rel_err: err, ok: ok }
}

// ─── parity: V_GS(th) ────────────────────────────────────────────────────

// Datasheet test condition: V_DS=V_GS, I_D=17.7 mA. Deck ties drain to
// gate through a 1 mOhm sense resistor, sweeps the gate, and uses
// ngspice `meas` to find the gate voltage where the drain current
// crosses 17.7 mA.
pub fn parity_vgsth() -> ParityResult {
    let ngs = _locate_ngspice()
    if ngs == "" {
        return ParityResult { spec: "V_GS(th)", measured: -1.0, datasheet: DS_VGSTH_V, rel_err: -1.0, ok: 0 }
    }
    let nl = "\n"
    let mut deck = "* C3M0021120K V_GS(th) parity — Vds=Vgs, Id=17.7 mA" + nl
    deck = deck + ".include " + _lib_abspath() + nl
    deck = deck + "X1 d g 0 tj tc C3M0021120K" + nl
    deck = deck + "Vg g 0 DC 0" + nl
    deck = deck + "Rgd g d 0.001" + nl
    deck = deck + "Vtj tj 0 DC 25" + nl
    deck = deck + "Vtc tc 0 DC 25" + nl
    deck = deck + ".control" + nl
    deck = deck + "dc Vg 2.0 4.0 0.005" + nl
    deck = deck + "meas dc vth find v(g) when i(Vg)=-17.7m" + nl
    deck = deck + ".endc" + nl
    deck = deck + ".end" + nl
    let deck_path = "/tmp/hexa_c3m_vth.cir"
    write_file(deck_path, deck)

    let out = to_string(exec(_shq(ngs) + " -b " + _shq(deck_path) + " 2>&1"))
    let measured = _grab_eq(out, "vth")
    if measured < 0.0 {
        return ParityResult { spec: "V_GS(th)", measured: -1.0, datasheet: DS_VGSTH_V, rel_err: -1.0, ok: 0 }
    }
    let err = _absf(measured - DS_VGSTH_V) / DS_VGSTH_V
    let mut ok = 0
    if err <= TOL { ok = 1 }
    return ParityResult { spec: "V_GS(th)", measured: measured, datasheet: DS_VGSTH_V, rel_err: err, ok: ok }
}

// ─── main (CLI smoke) ────────────────────────────────────────────────────

fn _pct(x: float) -> str {
    return str(x * 100.0)
}

fn main() {
    println("== wolfspeed_parity :: C3M0021120K datasheet parity ==")
    println("   model: fixtures/c3m0021120k.lib (clean-room, datasheet Rev.4)")
    println("   engine: ngspice (substrate — does NOT imply absorbed=true)")

    let r1 = parity_rdson()
    let r2 = parity_vgsth()
    let mut fails = 0

    let mut i = 0
    let results = [r1, r2]
    while i < len(results) {
        let r = results[i]
        if r.ok == 1 {
            println("  ✓ " + r.spec + ": measured=" + str(r.measured)
                    + " datasheet=" + str(r.datasheet)
                    + " err=" + _pct(r.rel_err) + "%")
        } else {
            println("  ✗ " + r.spec + ": measured=" + str(r.measured)
                    + " datasheet=" + str(r.datasheet)
                    + " err=" + _pct(r.rel_err) + "% (gate ±" + _pct(TOL) + "%)")
            fails = fails + 1
        }
        i = i + 1
    }

    if fails == 0 {
        println("== wolfspeed_parity :: PASS (substrate datasheet parity) ==")
        exit(0)
    }
    println("== wolfspeed_parity :: FAIL ==")
    exit(1)
}
