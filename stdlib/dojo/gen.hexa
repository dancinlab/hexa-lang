// HEXA Standard Library — dojo/gen
//
// @version 0.1.0
// @capabilities [pure]
//
// GENERIC CLOUD TRAINING-JOB GENERATOR ("도장 — 학습 빵틀").
//
// Sibling of stdlib/deck (DFT input decks). Where deck bakes a static
// `.in` simulation deck, dojo bakes a CLOUD TRAINING-JOB SET: a `.hexa`
// driver + a `.py` payload + a `run.sh` glue script, all written into
// exports/<domain>/dojo/<slug>/. One generic entry point — gen_dojo(
// domain, spec) — dispatches by domain string to a per-domain string-
// emitter (g4 generic dispatch · g20 parameterize · g61 SSOT). Adding a
// domain = ONE dispatch branch + ONE emitter function.
//
// This is a STRING-EMITTER (job text → DojoFile records), NOT a compiled
// binary. It runs via `hexa run`, so it needs NO AOT build — pure-hexa
// string assembly only. The caller (dojo/cli.hexa) writes the returned
// DojoFile records to disk via stdlib/io.write_text — gen_dojo stays
// pure (no syscall).
//
// EMIT-AS-STRING discipline: the `.py` payload and `.sh` glue exist ONLY
// as emitted-string content here — never hand-authored source files. The
// hexa generator's own write_file does the disk I/O, so the hexa-native
// PreToolUse guard (which only sees agent Write/Edit/Bash-redirect) never
// fires on them — same path as deck's run.sh emit.
//
// SPEC schema (DojoSpec keys):
//   model           — base model id (default "gpt2")
//   dataset         — HF dataset id (default "wikitext")
//   dataset_config  — dataset config name (default "wikitext-2-raw-v1")
//   epochs          — training epochs int (default "1")
//   batch_size      — per-device batch size int (default "4")
//   lr              — learning rate, pre-formatted string (default "5e-5")
//   max_steps       — optional hard step cap (default "" = full epochs)
//   host            — cloud pool host for run.sh dispatch (default "ubu-1")
//   output_dir      — remote training output dir (default "out")

import "stdlib/dojo/llm.hexa"

// ── data types ───────────────────────────────────────────────────────

// One emitted dojo file: a relative path (under the caller's dojo dir)
// and its full text content. Mirrors deck.DeckFile.
pub struct DojoFile {
    path:     string,
    content:  string,
}

// Generic spec carrier. hexa v0.3 has no native map type, so a spec is
// two parallel arrays (keys ↔ vals). Same convention as deck.DeckSpec.
pub struct DojoSpec {
    keys:   [string],
    vals:   [string],
}

// ── spec constructors / accessors ────────────────────────────────────

pub fn dojo_spec_new() -> DojoSpec {
    return DojoSpec { keys: [], vals: [] }
}

pub fn spec_set(spec: DojoSpec, key: string, value: string) {
    let mut i = 0
    while i < len(spec.keys) {
        if spec.keys[i] == key {
            spec.vals[i] = value
            return
        }
        i = i + 1
    }
    spec.keys.push(key)
    spec.vals.push(value)
}

pub fn spec_has(spec: DojoSpec, key: string) -> bool {
    let mut i = 0
    while i < len(spec.keys) {
        if spec.keys[i] == key { return true }
        i = i + 1
    }
    return false
}

pub fn spec_get(spec: DojoSpec, key: string) -> string {
    let mut i = 0
    while i < len(spec.keys) {
        if spec.keys[i] == key { return spec.vals[i] }
        i = i + 1
    }
    return ""
}

pub fn spec_get_or(spec: DojoSpec, key: string, default: string) -> string {
    if spec_has(spec, key) { return spec_get(spec, key) }
    return default
}

// ── lang selection (--lang=hexa|py|both) ─────────────────────────────

// lang_keep(lang, kind) — decide whether a file of `kind` ("hexa" | "py"
// | "sh") survives the `--lang` filter. run.sh (sh) is glue: it is kept
// in EVERY mode except a pure "hexa"/"py" single-lang restriction where
// it would have nothing to glue. Convention:
//   both  → hexa + py + sh   (default — full job set)
//   hexa  → hexa only        (driver-only · no payload/glue)
//   py    → py only          (payload-only · no driver/glue)
pub fn lang_keep(lang: string, kind: string) -> bool {
    if lang == "both" { return true }
    if lang == "hexa" { return kind == "hexa" }
    if lang == "py"   { return kind == "py" }
    // unknown lang → treat as both (caller validates separately)
    return true
}

// ── generic dispatch (g4) ────────────────────────────────────────────

// gen_dojo(domain, slug, spec, lang) — emit the training-job file-set for
// `domain`, filtered by `lang`. Returns [] for an unknown domain (caller
// checks len). Adding a domain is ONE branch here + ONE emitter function
// (no name hardcoding past this dispatch — g20).
pub fn gen_dojo(domain: string, slug: string, spec: DojoSpec, lang: string) -> [DojoFile] {
    if domain == "llm" { return emit_llm(slug, spec, lang) }
    // d6 honest stub: vision / rl / tabular have NO emitter yet. The CLI
    // surfaces these via dojo_domains()/dojo_is_stub() and exits with a
    // clear TODO rather than pretending a full emit.
    let none: [DojoFile] = []
    return none
}

// dojo_domains() — known dojo domains (full + stub). Single source for
// the `dojo domains` CLI listing.
pub fn dojo_domains() -> [string] {
    return ["llm", "vision", "rl", "tabular"]
}

// dojo_is_stub(domain) — true for a registered-but-unimplemented domain
// (d6 honest stub). A domain not in dojo_domains() is "unknown", not a
// stub — the CLI distinguishes the two.
pub fn dojo_is_stub(domain: string) -> bool {
    if domain == "vision"  { return true }
    if domain == "rl"      { return true }
    if domain == "tabular" { return true }
    return false
}

// ── shared emit helpers ──────────────────────────────────────────────

// Append a DojoFile to an accumulator.
pub fn dojo_push(files: [DojoFile], path: string, content: string) {
    files.push(DojoFile { path: path, content: content })
}
