// HEXA Standard Library — dojo/llm
//
// @version 0.1.0
// @capabilities [pure]
//
// FULL llm training-job emitter for the dojo generator (d6 first impl).
//
// Emits a 3-file cloud training-job set from a DojoSpec:
//   job.hexa   — the .hexa DRIVER: a thin hexa front-door that dispatches
//                the python payload to a cloud pool host via
//                `hexa cloud nohup <host> <log> -- python3 train.py`.
//   train.py   — the .py PAYLOAD: a HuggingFace Trainer causal-LM
//                fine-tune script (emitted-string content only — never a
//                hand-authored source file; the generator's write_file
//                writes it, sidestepping the hexa-native guard).
//   run.sh     — the .sh GLUE: cd into the job dir, then invoke the
//                driver. d16 governance: prints a FREE pool dry-run hint
//                before any cost-bearing remote launch.
//
// `--lang` filters which of the three survive (see gen.lang_keep):
//   both → all 3 · hexa → job.hexa only · py → train.py only.

import "stdlib/dojo/gen.hexa"

pub fn emit_llm(slug: string, spec: DojoSpec, lang: string) -> [DojoFile] {
    let files: [DojoFile] = []
    if lang_keep(lang, "hexa") {
        dojo_push(files, "job.hexa", _llm_driver(slug, spec))
    }
    if lang_keep(lang, "py") {
        dojo_push(files, "train.py", _llm_payload(slug, spec))
    }
    if lang_keep(lang, "sh") {
        dojo_push(files, "run.sh", _llm_glue(slug, spec))
    }
    return files
}

// ── .hexa driver ─────────────────────────────────────────────────────

fn _llm_driver(slug: string, spec: DojoSpec) -> string {
    let host = spec_get_or(spec, "host", "ubu-1")
    let mut s = ""
    s = s + "// dojo job driver — generated by stdlib/dojo/llm\n"
    s = s + "// slug: " + slug + "\n"
    s = s + "//\n"
    s = s + "// Dispatches train.py to a cloud pool host in the background via\n"
    s = s + "// `hexa cloud nohup`, then prints the remote pid + the poll/tail\n"
    s = s + "// commands. Run from inside this job dir:  hexa run job.hexa\n"
    s = s + "\n"
    s = s + "fn main() {\n"
    s = s + "    let host = \"" + host + "\"\n"
    s = s + "    let log  = \"train." + slug + ".log\"\n"
    s = s + "    println(\"dojo: dispatching train.py → \" + host + \" (log \" + log + \")\")\n"
    s = s + "    let cmd = \"hexa cloud nohup \" + host + \" \" + log + \" -- python3 train.py\"\n"
    s = s + "    let out = exec(cmd + \" 2>&1\")\n"
    s = s + "    print(out)\n"
    s = s + "    println(\"\")\n"
    s = s + "    println(\"poll: hexa cloud poll \" + host + \" <pid>\")\n"
    s = s + "    println(\"tail: hexa cloud tail \" + host + \" \" + log)\n"
    s = s + "}\n"
    return s
}

// ── .py payload (emitted-string content only) ────────────────────────

fn _llm_payload(slug: string, spec: DojoSpec) -> string {
    let model    = spec_get_or(spec, "model", "gpt2")
    let dataset  = spec_get_or(spec, "dataset", "wikitext")
    let dscfg    = spec_get_or(spec, "dataset_config", "wikitext-2-raw-v1")
    let epochs   = spec_get_or(spec, "epochs", "1")
    let bs       = spec_get_or(spec, "batch_size", "4")
    let lr       = spec_get_or(spec, "lr", "5e-5")
    let maxsteps = spec_get_or(spec, "max_steps", "")
    let outdir   = spec_get_or(spec, "output_dir", "out")

    let mut s = ""
    s = s + "#!/usr/bin/env python3\n"
    s = s + "# dojo training payload — generated by stdlib/dojo/llm\n"
    s = s + "# slug: " + slug + "\n"
    s = s + "# HuggingFace Trainer causal-LM fine-tune. Edit the spec, re-emit;\n"
    s = s + "# do NOT hand-edit (provenance lives in the spec-json).\n"
    s = s + "import math\n"
    s = s + "from datasets import load_dataset\n"
    s = s + "from transformers import (\n"
    s = s + "    AutoModelForCausalLM, AutoTokenizer,\n"
    s = s + "    DataCollatorForLanguageModeling, Trainer, TrainingArguments,\n"
    s = s + ")\n"
    s = s + "\n"
    s = s + "MODEL = \"" + model + "\"\n"
    s = s + "DATASET = \"" + dataset + "\"\n"
    s = s + "DATASET_CONFIG = \"" + dscfg + "\"\n"
    s = s + "OUTPUT_DIR = \"" + outdir + "\"\n"
    s = s + "EPOCHS = " + epochs + "\n"
    s = s + "BATCH_SIZE = " + bs + "\n"
    s = s + "LR = " + lr + "\n"
    if len(maxsteps) > 0 {
        s = s + "MAX_STEPS = " + maxsteps + "\n"
    } else {
        s = s + "MAX_STEPS = -1  # full epochs (no hard step cap)\n"
    }
    s = s + "\n"
    s = s + "def main():\n"
    s = s + "    tok = AutoTokenizer.from_pretrained(MODEL)\n"
    s = s + "    if tok.pad_token is None:\n"
    s = s + "        tok.pad_token = tok.eos_token\n"
    s = s + "    ds = load_dataset(DATASET, DATASET_CONFIG)\n"
    s = s + "\n"
    s = s + "    def tokenize(batch):\n"
    s = s + "        return tok(batch[\"text\"], truncation=True, max_length=512)\n"
    s = s + "\n"
    s = s + "    ds = ds.map(tokenize, batched=True, remove_columns=ds[\"train\"].column_names)\n"
    s = s + "    collator = DataCollatorForLanguageModeling(tok, mlm=False)\n"
    s = s + "    model = AutoModelForCausalLM.from_pretrained(MODEL)\n"
    s = s + "\n"
    s = s + "    args = TrainingArguments(\n"
    s = s + "        output_dir=OUTPUT_DIR,\n"
    s = s + "        num_train_epochs=EPOCHS,\n"
    s = s + "        per_device_train_batch_size=BATCH_SIZE,\n"
    s = s + "        learning_rate=LR,\n"
    s = s + "        max_steps=MAX_STEPS,\n"
    s = s + "        logging_steps=10,\n"
    s = s + "        save_strategy=\"epoch\",\n"
    s = s + "        report_to=[],\n"
    s = s + "    )\n"
    s = s + "    trainer = Trainer(\n"
    s = s + "        model=model, args=args,\n"
    s = s + "        train_dataset=ds[\"train\"],\n"
    s = s + "        eval_dataset=ds.get(\"validation\"),\n"
    s = s + "        data_collator=collator,\n"
    s = s + "    )\n"
    s = s + "    trainer.train()\n"
    s = s + "    trainer.save_model(OUTPUT_DIR)\n"
    s = s + "    tok.save_pretrained(OUTPUT_DIR)\n"
    s = s + "    if ds.get(\"validation\") is not None:\n"
    s = s + "        metrics = trainer.evaluate()\n"
    s = s + "        ppl = math.exp(metrics[\"eval_loss\"]) if \"eval_loss\" in metrics else float(\"nan\")\n"
    s = s + "        print(f\"eval_loss={metrics.get('eval_loss')}  ppl={ppl}\")\n"
    s = s + "\n"
    s = s + "if __name__ == \"__main__\":\n"
    s = s + "    main()\n"
    return s
}

// ── run.sh glue (emitted-string content only) ────────────────────────

fn _llm_glue(slug: string, spec: DojoSpec) -> string {
    let host = spec_get_or(spec, "host", "ubu-1")
    let mut s = ""
    s = s + "#!/usr/bin/env bash\n"
    s = s + "# dojo run glue — generated by stdlib/dojo/llm\n"
    s = s + "# slug: " + slug + "\n"
    s = s + "set -euo pipefail\n"
    s = s + "cd \"$(dirname \"$0\")\"\n"
    s = s + "\n"
    s = s + "# d16 governance — run a FREE pool dry-run BEFORE any cost-bearing\n"
    s = s + "# remote launch (catches import/path errors without renting GPU time):\n"
    s = s + "#   pool on " + host + " 'python3 -c \"import transformers, datasets\"'\n"
    s = s + "\n"
    s = s + "# Background-dispatch train.py to the cloud pool host via the .hexa\n"
    s = s + "# driver (hexa cloud nohup → remote pid + poll/tail hints):\n"
    s = s + "exec hexa run job.hexa\n"
    return s
}
