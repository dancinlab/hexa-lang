#!hexa strict
// metamaterial verify — Veselago negative-index n = −√(ε·μ).
extern fn sqrt(x: float) -> float
fn main() {
    let eps = 0.0 - 1.0
    let mu = 0.0 - 1.0
    let n2 = eps * mu     // = +1
    let n_index = 0.0 - sqrt(n2)
    println("metamaterial_verify (Veselago · ε=-1, μ=-1):")
    println("  n_squared = " + str(n2))
    println("  refractive_index_n = " + str(n_index))
    println("__HEXA_METAMATERIAL_VERIFY__ PASS gate=GATE_OPEN absorbed=false")
}
