#!hexa strict
// metamaterial analyze — Pendry SRR resonance ω₀ = 1/√(LC).
extern fn sqrt(x: float) -> float
fn main() {
    let L = 1.0e-11           // H (10 pH)
    let C = 1.0e-13           // F (100 fF)
    let omega0 = 1.0 / sqrt(L * C)
    let f0_GHz = omega0 / (2.0 * 3.14159265 * 1.0e9)
    println("metamaterial_analyze (Pendry SRR · L=10pH C=100fF):")
    println("  omega0_rad_per_s = " + str(omega0))
    println("  f0_GHz = " + str(f0_GHz))
    println("__HEXA_METAMATERIAL_ANALYZE__ PASS gate=GATE_OPEN absorbed=false")
}
