#!/bin/bash
# AMFI heuristic matcher cycle (anima#169 inbox doc, 2026-05-23):
# Apple System Policy keys on (path-basename, codesign Identifier prefix);
# once heavy code paths exec often enough, ad-hoc-signed binaries escalate
# from advisory `spctl reject` to enforced SIGKILL.  History:
#   hexadrv (banned) → hexa.real (escalated to SIGKILL) → hxv2 (current)
#
# Re-point + preserve argv[0]:
#   `exec -a hexa` keeps argv[0]="hexa" so the binary's own shim-dispatcher
#   (main.hexa "unknown shim command:" guard) still routes correctly while
#   the file name on disk no longer matches AMFI's burning matcher.
#
# Path resolved relative to wrapper location (g13 portable paths) — works
# whether installed at ~/.hx/bin/hexa (symlink) or invoked from the repo.
# Resolve BASH_SOURCE through any symlink chain BEFORE dirname, so a stray
# /tmp/.../hexa shim (or argv0-basename-cwd-shadow sibling, ref #866) can't
# trick the dispatcher into looking up `hxv2` from the wrong directory.
# Fallback chain: realpath → readlink -f → raw BASH_SOURCE (legacy behavior).
__hexa_src="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
__hexa_dir="$(cd "$(dirname "$__hexa_src")" && pwd -P)"
__hexa_bin="$__hexa_dir/hxv2"
if [ ! -x "$__hexa_bin" ]; then
    # Transition fallback for boxes that haven't renamed hexa.real → hxv2.
    # Drop this branch once all install scripts emit hxv2 directly.
    __hexa_bin="$__hexa_dir/hexa.real"
fi
exec -a hexa "$__hexa_bin" "$@"
