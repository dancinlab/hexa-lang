#!/bin/bash
# AMFI heuristic matcher cycle (anima#169 inbox doc, 2026-05-23):
# Apple System Policy keys on (path-basename, codesign Identifier prefix);
# once heavy code paths exec often enough, ad-hoc-signed binaries escalate
# from advisory `spctl reject` to enforced SIGKILL.  History:
#   hexadrv (banned) → hexa.real (escalated to SIGKILL) → hxv2 (current)
#
# Re-point + preserve argv[0]:
#   `exec -a hexa` keeps argv[0]="hexa" so the binary's own shim-dispatcher
#   (main.hexa "unknown shim command:" guard) still routes correctly while
#   the file name on disk no longer matches AMFI's burning matcher.
#
# Path resolved relative to wrapper location (g13 portable paths) — works
# whether installed at ~/.hx/bin/hexa (symlink) or invoked from the repo.
# Resolve BASH_SOURCE through any symlink chain BEFORE dirname, so a stray
# /tmp/.../hexa shim (or argv0-basename-cwd-shadow sibling, ref #866) can't
# trick the dispatcher into looking up `hxv2` from the wrong directory.
# Fallback chain: realpath → readlink -f → raw BASH_SOURCE (legacy behavior).
__hexa_src="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
__hexa_dir="$(cd "$(dirname "$__hexa_src")" && pwd -P)"
__hexa_bin="$__hexa_dir/hxv2"
if [ ! -x "$__hexa_bin" ]; then
    # Transition fallback for boxes that haven't renamed hexa.real → hxv2.
    # Drop this branch once all install scripts emit hxv2 directly.
    __hexa_bin="$__hexa_dir/hexa.real"
fi

# Fork-exhaustion backstop (ref: fork EAGAIN, 2026-05-25/26).
#   A runaway hexa fork loop — e.g. an agent campaign shelling hexa → atlas →
#   verify without bound — can exhaust the per-uid process table.  Once that
#   happens every fork() EAGAINs, taking down unrelated sessions and the
#   SessionStart/PreToolUse hooks (which can no longer spawn /bin/sh).  Bound
#   the live hexa-family process count per real-uid at a hard ceiling and
#   refuse new front-door entry past it, so the loop breaks well before the
#   `ulimit -u` wall instead of after.
#   - No env / config opt-out by design: an escape hatch on a safety backstop
#     just gets flipped to silence it (sidecar governance s11).  Ceiling is a
#     literal; tune it here in-source if the legitimate parallel ceiling rises.
#   - macOS ships no flock(1); a ps headcount is the portable, crash-safe
#     primitive — dead procs leave the table on their own, so there is no
#     stale-counter to reap.  Fails OPEN: a ps glitch must never block work.
__hexa_cap=600
__hexa_live="$(ps -U "$(id -u)" -o comm= 2>/dev/null | grep -c '[h]exa')"
if [ "${__hexa_live:-0}" -ge "$__hexa_cap" ]; then
    printf 'hexa: fork-cap reached — %s hexa-family procs for uid %s (ceiling %s); refusing new entry.\n' "$__hexa_live" "$(id -u)" "$__hexa_cap" >&2
    printf 'hexa: this protects the process table from a runaway fork loop. Find + kill the runaway group:\n' >&2
    printf "hexa:   ps -axo pgid,comm | grep '[h]exa' | awk '{print \$1}' | sort | uniq -c | sort -rn | head\n" >&2
    printf 'hexa:   kill -- -<PGID>   # the big group; spares your shell + claude\n' >&2
    exit 1
fi

exec -a hexa "$__hexa_bin" "$@"
