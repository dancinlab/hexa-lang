#!/bin/bash
# AMFI heuristic matcher cycle (anima#169 inbox doc, 2026-05-23):
# Apple System Policy keys on (path-basename, codesign Identifier prefix);
# once heavy code paths exec often enough, ad-hoc-signed binaries escalate
# from advisory `spctl reject` to enforced SIGKILL.  History:
#   hexadrv (banned) → hexa.real (escalated to SIGKILL) → hxv2 (current)
#
# Re-point + preserve argv[0]:
#   `exec -a hexa` keeps argv[0]="hexa" so the binary's own shim-dispatcher
#   (main.hexa "unknown shim command:" guard) still routes correctly while
#   the file name on disk no longer matches AMFI's burning matcher.
#
# Path resolved relative to wrapper location (g13 portable paths) — works
# whether installed at ~/.hx/bin/hexa (symlink) or invoked from the repo.
# Resolve BASH_SOURCE through any symlink chain BEFORE dirname, so a stray
# /tmp/.../hexa shim (or argv0-basename-cwd-shadow sibling, ref #866) can't
# trick the dispatcher into looking up `hxv2` from the wrong directory.
# Fallback chain: realpath → readlink -f → raw BASH_SOURCE (legacy behavior).
__hexa_src="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
__hexa_dir="$(cd "$(dirname "$__hexa_src")" && pwd -P)"
__hexa_bin="$__hexa_dir/hxv2"
if [ ! -x "$__hexa_bin" ]; then
    # Transition fallback for boxes that haven't renamed hexa.real → hxv2.
    # Drop this branch once all install scripts emit hxv2 directly.
    __hexa_bin="$__hexa_dir/hexa.real"
fi

# Fork-exhaustion backstop — recursion-depth guard (ref: fork EAGAIN, 2026-05-25/26).
#   The runaway was a DEEP nested shell-out chain: hexa → sh → hexa-atlas → sh →
#   hexa → … , each bottom `hexa` re-entering this front-door via PATH lookup.
#   Bound that nesting structurally: every entry inherits HEXA_DEPTH from its
#   parent (the var rides through the intermediate sh / hexa-atlas / hexa-verify
#   untouched), increments it, and refuses past a hard ceiling — so an unbounded
#   hexa → … → hexa recursion is cut at depth N and can never reach the
#   process-table wall.  This targets the mechanism (recursion), not the symptom
#   (raw process count), so unlike an absolute headcount cap it does NOT penalise
#   legitimate WIDE parallelism (many shallow hexa fanned across agents).
#   - HEXA_DEPTH is mechanism state, not an opt-out knob (cf. make's MAKELEVEL).
#     There is no env switch that DISABLES the guard (sidecar governance s11);
#     resetting the counter mid-chain is the only bypass and no real code does it.
#   - Ceiling is an in-source literal.  Legit nested dispatch is single-digit
#     deep; 32 leaves vast headroom while still cutting an infinite loop early.
#     Non-numeric / unset HEXA_DEPTH sanitises to 0 (fails OPEN — never blocks).
__hexa_depth="${HEXA_DEPTH:-0}"
case "$__hexa_depth" in ''|*[!0-9]*) __hexa_depth=0 ;; esac
if [ "$__hexa_depth" -ge 32 ]; then
    printf 'hexa: recursion-depth cap reached — nested hexa shell-out depth %s ≥ 32; refusing.\n' "$__hexa_depth" >&2
    printf 'hexa: a hexa → … → hexa chain this deep is a runaway loop, not real work. Find + kill the group:\n' >&2
    printf "hexa:   ps -axo pgid,comm | grep '[h]exa' | awk '{print \$1}' | sort | uniq -c | sort -rn | head; kill -- -<PGID>\n" >&2
    exit 1
fi
export HEXA_DEPTH=$((__hexa_depth + 1))

exec -a hexa "$__hexa_bin" "$@"
