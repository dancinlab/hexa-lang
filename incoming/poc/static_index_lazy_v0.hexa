// PoC — Option A lazy-load surface for compiler/atlas/static_index.
//
// @version 0.0.1
// @capabilities [fs_read]
//
// Demonstrates the recommended migration for the 7,278-node rodata embed
// (compiler/atlas/embedded.gen.hexa, 4.6 MB / 7,331 LOC of nested
// AtlasNode struct literals) that currently hangs `hexa run` for >90 s at
// module-load time.
//
// The idea (Option A in the design note):
//   1. Ship the rodata as a *text* file (`.n6` payload) bundled next to
//      the compiler binary.
//   2. Keep the public API surface identical (atlas_list / atlas_lookup /
//      atlas_list_merged etc.).
//   3. On first call, read the text, parse it, cache the AtlasIndex.
//   4. Subsequent calls return the cached index in O(1).
//
// This PoC is *self-contained* — it does NOT touch compiler/atlas/
// static_index.hexa or compiler/atlas/embedded.gen.hexa. It uses a small
// fixture (50 nodes) to prove the lazy + cache behavior; the smoke test
// in test/static_index_lazy_poc_smoke.hexa drives it.
//
// Out of scope (intentional):
//   - rodata-during-AOT (AOT path already materializes constants in 0 ms;
//     this codepath is interp-only).
//   - overlay merging (would be added in step 3 of migration plan).
//   - structured grade/edge enrichment (covered by atlas_enrich today).

use "stdlib/io"

// ── tiny mirror of the public types ─────────────────────────────────────

// Mirror of compiler/atlas/parser::AtlasNode, lightened for the PoC.
// We deliberately keep the *field names* identical so a real port to
// compiler/atlas/ would be field-by-field compatible.
pub struct PocAtlasNode {
    kind: string,         // "P"|"C"|"L"|"E"|"F"|"R"|"S"|"X"|"Q"|""
    id: string,
    raw: string,
    source_file: string,
    source_line: i64
    // (grade + edges intentionally omitted — Wave-1 enrichment is lazy
    //  anyway; the migration plan keeps them as a post-load decoration.)
}

pub struct PocAtlasIndex {
    p_nodes: array,
    c_nodes: array,
    l_nodes: array,
    e_nodes: array,
    f_nodes: array,
    r_nodes: array,
    s_nodes: array,
    x_nodes: array,
    q_nodes: array,
    hash: string,
    source_count: i64
}

// ── lazy cache ─────────────────────────────────────────────────────────

// Stage0 hexa has no `static let mut` so the cache lives in a global
// 1-slot array. `[]` means "not yet loaded"; a single PocAtlasIndex means
// "cached". A real port would wire this onto the existing
// `overlay_load_cached` pattern in compiler/atlas/overlay.hexa.
let _POC_CACHE: array = []

// Default fixture path — used by the smoke test. A real port would point
// at `~/.hx/data/atlas.frozen.n6` or `compiler/atlas/embedded.gen.n6`.
pub let POC_FIXTURE_PATH: string = "incoming/poc/static_index_lazy_v0_fixture.n6"

// ── tiny parser (just enough for the fixture format) ───────────────────
//
// Fixture grammar is a *strict subset* of n6:
//   @<KIND> <id> :: <domain> [grade]
//     <- a, b              (continuation lines ignored by PoC parser)
// Header lines only — continuations are accumulated into `raw` but not
// structurally parsed. This keeps the PoC parser to ~30 LOC.

fn _ltrim(s: string) -> string {
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c != " " && c != "\t" { break }
        i = i + 1
    }
    return s.substring(i, n)
}

fn _kind_of(tok: string) -> string {
    if tok == "@P" { return "P" }
    if tok == "@C" { return "C" }
    if tok == "@L" { return "L" }
    if tok == "@E" { return "E" }
    if tok == "@F" { return "F" }
    if tok == "@R" { return "R" }
    if tok == "@S" { return "S" }
    if tok == "@X" { return "X" }
    if tok == "@?" { return "Q" }
    return ""
}

fn _split_first_ws(line: string) -> array {
    let n = len(line)
    let mut i = 0
    while i < n {
        let c = line.substring(i, i + 1)
        if c == " " || c == "\t" { break }
        i = i + 1
    }
    let head = line.substring(0, i)
    let rest = _ltrim(line.substring(i, n))
    return [head, rest]
}

fn _id_until_ws_or_eq(rest: string) -> string {
    let n = len(rest)
    let mut i = 0
    while i < n {
        let c = rest.substring(i, i + 1)
        if c == " " || c == "\t" || c == "=" { break }
        if c == ":" && i + 1 < n && rest.substring(i + 1, i + 2) == ":" { break }
        i = i + 1
    }
    return rest.substring(0, i)
}

// Parse one node-header into a PocAtlasNode (returns empty-kind sentinel
// on malformed). Continuation lines are appended into `raw` later.
fn _parse_header(line: string, source_file: string, source_line: i64) -> PocAtlasNode {
    let parts = _split_first_ws(line)
    let kind = _kind_of(to_string(parts[0]))
    if kind == "" {
        return PocAtlasNode { kind: "", id: "", raw: line, source_file: source_file, source_line: source_line }
    }
    let id = _id_until_ws_or_eq(to_string(parts[1]))
    return PocAtlasNode { kind: kind, id: id, raw: line, source_file: source_file, source_line: source_line }
}

// ── full file parser (Option A reference impl, tiny version) ───────────

fn _parse_n6_text(text: string, source_file: string) -> array {
    let lines = text.split("\n")
    let n = len(lines)
    let mut out: array = []
    let mut cur_kind: string = ""
    let mut cur_idx: i64 = -1
    let mut i: i64 = 0
    while i < n {
        let line = to_string(lines[i])
        let lstr = _ltrim(line)
        if len(lstr) == 0 || lstr.substring(0, 1) == "#" {
            i = i + 1
            continue
        }
        if lstr.substring(0, 1) == "@" {
            // Header line — emit a new node.
            let node = _parse_header(lstr, source_file, i + 1)
            if node.kind != "" {
                out.push(node)
                cur_kind = node.kind
                cur_idx = len(out) - 1
            } else {
                cur_kind = ""
                cur_idx = -1
            }
        } else if cur_idx >= 0 {
            // Continuation: append raw line into the previous node's `raw`.
            let prev = out[cur_idx]
            prev.raw = prev.raw + "\n" + line
        }
        i = i + 1
    }
    return out
}

fn _build_index(nodes: array, hash: string) -> PocAtlasIndex {
    let mut p: array = []
    let mut c: array = []
    let mut l: array = []
    let mut e: array = []
    let mut f: array = []
    let mut r: array = []
    let mut s: array = []
    let mut x: array = []
    let mut q: array = []
    let mut i = 0
    while i < len(nodes) {
        let nd = nodes[i]
        if nd.kind == "P" { p.push(nd) }
        else if nd.kind == "C" { c.push(nd) }
        else if nd.kind == "L" { l.push(nd) }
        else if nd.kind == "E" { e.push(nd) }
        else if nd.kind == "F" { f.push(nd) }
        else if nd.kind == "R" { r.push(nd) }
        else if nd.kind == "S" { s.push(nd) }
        else if nd.kind == "X" { x.push(nd) }
        else if nd.kind == "Q" { q.push(nd) }
        i = i + 1
    }
    return PocAtlasIndex {
        p_nodes: p, c_nodes: c, l_nodes: l, e_nodes: e,
        f_nodes: f, r_nodes: r, s_nodes: s, x_nodes: x, q_nodes: q,
        hash: hash, source_count: 1
    }
}

// ── public surface (mirrors compiler/atlas/static_index pub fns) ───────

// poc_static_atlas — lazy + cached. First call parses the fixture; later
// calls return the same cached PocAtlasIndex.
pub fn poc_static_atlas() -> PocAtlasIndex {
    return poc_static_atlas_from(POC_FIXTURE_PATH)
}

// poc_static_atlas_from — explicit path variant so the smoke test can
// drive a known fixture without env coupling.
pub fn poc_static_atlas_from(path: string) -> PocAtlasIndex {
    if len(_POC_CACHE) > 0 { return _POC_CACHE[0] }
    let text = read_text(path)
    let nodes = _parse_n6_text(text, "fixture.n6")
    // Hash placeholder — real port would feed bytes into stdlib/hash/sha256
    // as compiler/atlas/merger.hexa already does. PoC just records a stub
    // so smoke can assert "hash is non-empty after load".
    let hash = "poc-fixture-" + to_string(len(text))
    let idx = _build_index(nodes, hash)
    _POC_CACHE.push(idx)
    return idx
}

// poc_atlas_list — flat list of all nodes.
pub fn poc_atlas_list() -> array {
    let idx = poc_static_atlas()
    let mut out: array = []
    let mut i = 0
    while i < len(idx.p_nodes) { out.push(idx.p_nodes[i]); i = i + 1 }
    i = 0
    while i < len(idx.c_nodes) { out.push(idx.c_nodes[i]); i = i + 1 }
    i = 0
    while i < len(idx.l_nodes) { out.push(idx.l_nodes[i]); i = i + 1 }
    i = 0
    while i < len(idx.e_nodes) { out.push(idx.e_nodes[i]); i = i + 1 }
    return out
}

// poc_atlas_lookup — linear scan over all kinds, returns sentinel on miss.
pub fn poc_atlas_lookup(id: string) -> PocAtlasNode {
    let all = poc_atlas_list()
    let mut i = 0
    while i < len(all) {
        let n = all[i]
        if n.id == id { return n }
        i = i + 1
    }
    return PocAtlasNode { kind: "", id: "", raw: "", source_file: "", source_line: 0 }
}

// poc_reset_cache — smoke-test helper. Real port would NOT expose this.
pub fn poc_reset_cache() {
    while len(_POC_CACHE) > 0 { _POC_CACHE.pop() }
}
