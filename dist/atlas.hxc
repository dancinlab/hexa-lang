@atlas P|n|@P n = 6 :: foundation [11*]\\n  -> sigma, phi, tau, sopfr, J2, mu, M3\\n  => \\"모든 구조의 씨앗\\"\\n  => \\"meta-closure: 15 grade-10 derivations (sigma,phi,tau,sopfr,J2,mu,M3,sigma_n,perfect_number,sigma_decomp,J2_decomp,faction_phi,granville_smooth,...)\\"\\n  \|> verify_primitives.py|atlas.n6|25|-1|false|false
@atlas P|sigma|@P sigma = divisor_sum(6) = 12 :: foundation [11*]\\n  <- n\\n  -> sigma_sq, sigma_tau, sigma_n\\n  => \\"약수합 — 12파벌, 12모듈\\"\\n  => \\"meta-closure: 10 grade-10 derivations (sigma_sq,sigma_tau,sigma_n,sm_ampere,sm_blackwell,sm_amd,perfect_number,sigma_decomp,persistence_threshold,...)\\"\\n  == 1+2+3+6\\n  == phi * n|atlas.n6|30|-1|false|false
@atlas P|phi|@P phi = euler_totient(6) = 2 :: foundation [10*]\\n  -> phi_tau\\n  => \\"오일러 토션트 — 이진성의 근원\\"|atlas.n6|37|-1|false|false
@atlas P|tau|@P tau = divisor_count(6) = 4 :: foundation [11*]\\n  -> phi_tau, sigma_tau\\n  => \\"약수 개수 — 4차원, 4단계\\"\\n  => \\"meta-closure: 9 grade-10 derivations (sigma_tau,phi_tau,J2_tau,sm_blackwell,sm_amd,J2_decomp,sopfr_phi_tau,persistence_threshold,binding_tau)\\"|atlas.n6|40|-1|false|false
@atlas P|sopfr|@P sopfr = sum_prime_factors(6) = 5 :: foundation [10*]\\n  -> warp_size\\n  => \\"소인수합 2+3=5\\"\\n  == 2+3|atlas.n6|44|-1|false|false
