# clangd configuration — hexa-lang workspace
#
# The self/native/*.c files include "runtime.c" relative to self/, not
# relative to self/native/. Without this, clangd cannot resolve HexaVal
# and emits a wall of spurious "unknown type name" diagnostics. The
# regen-source self/native/hexa_cc.c + self/runtime.c left git in B9
# (#2065 — tracked `.c` = 0); the live transpiler now cold-builds from the
# self-contained seed (cc self/native/hexa_cc_seed.c — no -I, runtime inlined).
#
# Ref: tool/build_hexat_linux.hexa (src = self/native/hexa_cc_seed.c · cold-seed)
#      bootstrap.yml Stage 0       (cc hexa_cc_seed.c -o build/hexa_v2)
CompileFlags:
  Add:
    - -I.
    - -Iself
    - -Iself/native
    - -Iself/forge
    - -D_GNU_SOURCE
    - -std=gnu11

# Legacy parity files — suppress diagnostics (dead; slated for hard-delete
# per doc/plans/runtime_c_purge.md Phase C).
---
If:
  PathMatch: self/native/(codegen_c2_v2|lexer_v2|parser_v2|type_checker_v2)\.c
Diagnostics:
  Suppress: ["*"]
