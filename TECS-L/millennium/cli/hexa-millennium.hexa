#!hexa strict
// hexa-millennium/cli/hexa-millennium.hexa — standalone CLI router
//
// 7-pillar Clay Millennium Problems substrate (HEXA-Millennium family):
//   bsd            — Birch–Swinnerton-Dyer        (CANDIDATE spec, v1.0.0)
//   hodge          — Hodge Conjecture             (CANDIDATE spec, v1.0.0)
//   navier_stokes  — Navier–Stokes existence/smoothness  (CANDIDATE, v1.0.0)
//   p_vs_np        — P vs NP                      (CANDIDATE spec, v1.0.0)
//   poincare       — Poincaré (Perelman 2003)     (n=6 verification spec, v1.0.0)
//   riemann        — Riemann Hypothesis           (CANDIDATE spec, v1.0.0)
//   yang_mills     — Yang–Mills mass gap          (CANDIDATE spec, v1.0.0)
//
// Plus utility subcmds:
//   status      — verb status table (7/7 candidate-spec)
//   selftest    — verify all 7 verb directories present
//   help        — this help
//   --version   — print version
//
// Root resolution: $HEXA_MILLENNIUM_ROOT env, else inferred from $0 dirname.
// No nexus dependency — verb specs live alongside this script.
//
// Constraints:
//
// Cost: $0 (Mac local; pure spec dispatch).
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local CLI router; verbs are spec text.")

let VERSION = "1.0.0"

// ─── env / path resolve ───

let HOME = env("HOME")
let HEXA_MILLENNIUM_ROOT_ENV = env("HEXA_MILLENNIUM_ROOT")

fn hexa_millennium_root() -> str {
    if HEXA_MILLENNIUM_ROOT_ENV.len() > 0 { return HEXA_MILLENNIUM_ROOT_ENV }
    let inferred = exec("dirname \"$(dirname \"$0\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return HOME + "/.hexa-millennium"  // @allow-devpath
}

let HM = hexa_millennium_root()

// 7-pillar verb directory map (verb_slug → relative path under HM)
let VERB_BSD          = "bsd"
let VERB_HODGE        = "hodge"
let VERB_NAVIER       = "navier_stokes"
let VERB_PNP          = "p_vs_np"
let VERB_POINCARE     = "poincare"
let VERB_RIEMANN      = "riemann"
let VERB_YANG_MILLS   = "yang_mills"

// Spec filename map (each verb directory contains millennium-<slug>.md)
let SPEC_BSD          = HM + "/" + VERB_BSD          + "/millennium-bsd.md"
let SPEC_HODGE        = HM + "/" + VERB_HODGE        + "/millennium-hodge.md"
let SPEC_NAVIER       = HM + "/" + VERB_NAVIER       + "/millennium-navier-stokes.md"
let SPEC_PNP          = HM + "/" + VERB_PNP          + "/millennium-p-vs-np.md"
let SPEC_POINCARE     = HM + "/" + VERB_POINCARE     + "/millennium-poincare.md"
let SPEC_RIEMANN      = HM + "/" + VERB_RIEMANN      + "/millennium-riemann.md"
let SPEC_YANG_MILLS   = HM + "/" + VERB_YANG_MILLS   + "/millennium-yang-mills.md"

let LOG_PATH = HM + "/state/hexa_millennium_cli.log"

// ─── arg helpers ───

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn has_flag(a: [str], flag: str) -> bool {
    for x in a {
        if x == flag { return true }
    }
    return false
}

fn json_mode(a: [str]) -> bool {
    return has_flag(a, "--json")
}

// ─── audit log (jsonl) ───

fn _ts_now() -> str {
    return exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
}

fn _audit(subcmd: str, args_str: str, exit_code: int) {
    let line = "{\"ts\":\"" + _ts_now() + "\",\"caller\":\"hexa_millennium_standalone\",\"subcmd\":\"hexa-millennium " +
               subcmd + "\",\"args\":\"" + args_str.replace("\"", "\\\"") +
               "\",\"exit_code\":" + str(exit_code) + ",\"version\":\"" + VERSION + "\"}"
    exec("mkdir -p " + shq(HM + "/state") + " 2>/dev/null")
    exec("echo " + shq(line) + " >> " + shq(LOG_PATH) + " 2>/dev/null")
}

// ─── spec runner (placeholder: print spec head) ───

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _dir_exists(p: str) -> bool {
    let r = exec("[ -d " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _show_spec(verb_slug: str, spec_path: str) -> str {
    if _file_exists(spec_path) == false {
        return "ERROR: spec not found: " + spec_path + " (set HEXA_MILLENNIUM_ROOT or run from repo root)"
    }
    // Placeholder dispatcher: print spec head + n=6 candidate sentinel.
    let head = exec("head -n 30 " + shq(spec_path) + " 2>&1").trim()
    let sentinel = "__HEXA_MILLENNIUM_" + verb_slug.upper() + "__ PASS (candidate spec; not formal proof)"
    return head + "\n\n" + sentinel
}


fn _print_caveats() {
    println("")
    println("  1. Each verb directory ships an n=6 closed-form CANDIDATE spec +")
    println("     falsifier preregister. NOT a formal proof of any Clay problem.")
    println("  2. Poincaré is solved by Perelman (2003); the poincare verb is an")
    println("     n=6 closed-form verification-side spec, not a re-solution.")
    println("  3. n=6 perfect-number arithmetic (σ=12, τ=4, φ=2, sopfr=5) is the")
    println("     organizing backbone; per-problem mathematical justification is")
    println("     NOT supplied at v1.0.0.")
    println("  4. No lean4 / Coq mechanical verification layer is bundled in this")
    println("     standalone repo (defers to canon/lean4-n6/ if/when it")
    println("     materialises).")
}

// ─── subcommand: status ───

fn cmd_status(a: [str]) {
    if json_mode(a) {
        let mut js = "{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"status\","
        js = js + "\"verbs_total\":7,\"verbs_wired_as_candidate\":7,\"verbs_formally_proved\":0,"
        js = js + "\"verdict\":\"CANDIDATE_SPECS_ONLY\","
        js = js + "\"verbs\":[\"bsd:candidate\",\"hodge:candidate\",\"navier_stokes:candidate\",\"p_vs_np:candidate\",\"poincare:n6_verification_spec\",\"riemann:candidate\",\"yang_mills:candidate\"]"
        js = js + "}"
        println(js)
        return
    }

    println("hexa-millennium " + VERSION + " status — Clay 7 Millennium Problems (n=6 closed-form candidates)")
    println("")
    println("  verb            status              n=6 closed-form          formal proof")
    println("  --------------- ------------------- ------------------------ --------------------------")
    println("  bsd             CANDIDATE v1.0.0    σ-φ rank lemma           NOT a proof (open)")
    println("  hodge           CANDIDATE v1.0.0    σ=12 cohomology classes  NOT a proof (open)")
    println("  navier_stokes   CANDIDATE v1.0.0    τ=4 regime smoothness    NOT a proof (open)")
    println("  p_vs_np         CANDIDATE v1.0.0    σ²=144 separation        NOT a proof (open)")
    println("  poincare        VERIFICATION SPEC   n=6 geometrization       Perelman 2003 (solved)")
    println("  riemann         CANDIDATE v1.0.0    σ-φ critical-line        NOT a proof (open)")
    println("  yang_mills      CANDIDATE v1.0.0    β₀=σ-sopfr=7 mass gap    NOT a proof (open)")
    println("")
    println("  verdict: CANDIDATE_SPECS_ONLY (7/7 verbs ship spec + falsifier; 0/7 formally proved)")
    println("")
    println("  to drill into a verb:")
    println("    hexa-millennium bsd")
    println("    hexa-millennium hodge")
    println("    hexa-millennium navier_stokes")
    println("    hexa-millennium p_vs_np")
    println("    hexa-millennium poincare")
    println("    hexa-millennium riemann")
    println("    hexa-millennium yang_mills")
    println("    hexa-millennium selftest      (7-verb sentinel sweep)")
    _print_caveats()
}

// ─── per-verb subcommands ───

fn cmd_bsd(a: [str]) {
    let raw = _show_spec("BSD", SPEC_BSD)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_BSD__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"bsd\",\"pass\":" + pass + ",\"status\":\"candidate\"}")
    }
    _audit("bsd", "", 0)
}

fn cmd_hodge(a: [str]) {
    let raw = _show_spec("HODGE", SPEC_HODGE)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_HODGE__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"hodge\",\"pass\":" + pass + ",\"status\":\"candidate\"}")
    }
    _audit("hodge", "", 0)
}

