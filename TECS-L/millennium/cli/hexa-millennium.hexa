    let raw = _show_spec("YANG_MILLS", SPEC_YANG_MILLS)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_YANG_MILLS__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"yang_mills\",\"pass\":" + pass + ",\"status\":\"candidate\"}")
    }
