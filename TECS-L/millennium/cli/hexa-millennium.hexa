    let raw = _show_spec("P_VS_NP", SPEC_PNP)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_P_VS_NP__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"p_vs_np\",\"pass\":" + pass + ",\"status\":\"candidate\"}")
    }
    _audit("p_vs_np", "", 0)
}

fn cmd_poincare(a: [str]) {
    let raw = _show_spec("POINCARE", SPEC_POINCARE)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_POINCARE__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"poincare\",\"pass\":" + pass + ",\"status\":\"n6_verification_spec\",\"upstream_proof\":\"Perelman 2003\"}")
    }
    _audit("poincare", "", 0)
}

fn cmd_riemann(a: [str]) {
    let raw = _show_spec("RIEMANN", SPEC_RIEMANN)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_RIEMANN__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"riemann\",\"pass\":" + pass + ",\"status\":\"candidate\"}")
    }
