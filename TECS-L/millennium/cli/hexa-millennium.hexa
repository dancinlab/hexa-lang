// ─── subcommand: selftest ───

fn cmd_selftest(a: [str]) {
    let verbs = [VERB_BSD, VERB_HODGE, VERB_NAVIER, VERB_PNP, VERB_POINCARE, VERB_RIEMANN, VERB_YANG_MILLS]
    let mut found = 0
    for v in verbs {
        let p = HM + "/" + v
        if _dir_exists(p) {
            println("  verb " + v + " : present")
            found = found + 1
        } else {
            println("  verb " + v + " : MISSING (" + p + ")")
        }
    }
    let pass_overall = found == 7
    if pass_overall {
        println("__HEXA_MILLENNIUM_SELFTEST__ PASS (" + str(found) + "/7 verbs present)")
    } else {
        println("__HEXA_MILLENNIUM_SELFTEST__ FAIL (" + str(found) + "/7 verbs present)")
    }
    if json_mode(a) {
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"selftest\",\"verdict\":\"" + (if pass_overall { "PASS" } else { "FAIL" }) + "\",\"verbs_found\":" + str(found) + ",\"verbs_total\":7}")
    }
    _print_caveats()
    _audit("selftest", "", if pass_overall { 0 } else { 1 })
    if pass_overall == false { exit(1) }
}

// ─── version ───

fn cmd_version() {
    println("hexa-millennium " + VERSION)
    println("standalone Clay 7 Millennium Problems substrate (n=6 closed-form candidates)")
    println("license: MIT")
    println("repo:    https://github.com/dancinlab/hexa-millennium")
    println("note:    candidate specs only — NOT a formal proof of any Clay problem")
}

// ─── help ───

fn cmd_help() {
    println("hexa-millennium " + VERSION + " — Clay 7 Millennium Problems CLI")
    println("")
    println("usage: hexa-millennium <subcmd> [flags...]")
    println("")
    println("verb subcommands (7-pillar Clay set — n=6 invariant lattice):")
    println("  bsd             Birch–Swinnerton-Dyer                  [CANDIDATE]")
    println("  hodge           Hodge Conjecture                       [CANDIDATE]")
    println("  navier_stokes   Navier–Stokes existence/smoothness     [CANDIDATE]")
    println("  p_vs_np         P vs NP                                [CANDIDATE]")
    println("  poincare        Poincaré (Perelman 2003 — n=6 verif)   [VERIFICATION SPEC]")
    println("  riemann         Riemann Hypothesis                     [CANDIDATE]")
    println("  yang_mills      Yang–Mills mass gap                    [CANDIDATE]")
    println("")
    println("utility subcommands:")
    println("  status          7-verb status table + verdict + caveats")
    println("  selftest        7-verb sentinel sweep (directory presence)")
    println("")
    println("global flags:")
    println("  --version       show version")
    println("  --json          machine-parseable JSON tail")
    println("  --help, -h      this help")
    println("")
    println("env:")
    println("  HEXA_MILLENNIUM_ROOT   override repo root (default: inferred from $0)")
    println("")
    println("cost estimate (Mac local): $0 — all subcmds are spec dispatchers.")
    println("")
    println("note: each verb is a CANDIDATE spec. NOT a formal proof.")
    println("backend specs: " + HM)
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_millennium_cli", "hexa_millennium_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        cmd_help()
        return
    }

    if sub == "help" { cmd_help(); return }

    if sub == "status" {
        cmd_status(a)
    } else if sub == "bsd" {
        cmd_bsd(a)
    } else if sub == "hodge" {
        cmd_hodge(a)
    } else if sub == "navier_stokes" || sub == "navier-stokes" {
        cmd_navier_stokes(a)
    } else if sub == "p_vs_np" || sub == "p-vs-np" {
        cmd_p_vs_np(a)
    } else if sub == "poincare" {
        cmd_poincare(a)
    } else if sub == "riemann" {
        cmd_riemann(a)
    } else if sub == "yang_mills" || sub == "yang-mills" {
        cmd_yang_mills(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else {
        eprintln("hexa-millennium: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-millennium help' for usage")
        _audit(sub, "", 2)
        exit(2)
    }
}
