    let raw = _show_spec("NAVIER_STOKES", SPEC_NAVIER)
    println(raw)
    if json_mode(a) {
        let pass = if raw.contains("__HEXA_MILLENNIUM_NAVIER_STOKES__ PASS") { "true" } else { "false" }
        println("{\"hexa_millennium\":\"" + VERSION + "\",\"subcmd\":\"navier_stokes\",\"pass\":" + pass + ",\"status\":\"candidate\"}")
    }
    _audit("navier_stokes", "", 0)
