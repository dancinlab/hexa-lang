#!hexa strict
// hexa-millennium/verify/closure_consistency.hexa — scoreboard cross-check.
//
// Confirms three sources agree on the 7-verb count (Clay Millennium):
//   1. cli/hexa-millennium.hexa SPEC_* paths   (registry of record)
//   2. hexa.toml [closure] verbs_total / verbs_wired_as_candidate
//   3. README.md badge "verbs-7%2F7_candidate_spec"
//
// Per LATTICE_POLICY §1.3 rule 4: this is *internal* self-consistency
// (own substrate's own scoreboard), NOT a claim about external entities
// (Clay Mathematics Institute, Perelman, Fields medallists).
//
// CANDIDATE SPEC — it does NOT claim any Clay Millennium Problem has
// been solved by this repo. Acceptance requires formal Lean4/Coq +
// 2-yr Clay community review.

let HOME = env("HOME")
let HEXA_MILLENNIUM_ROOT_ENV = env("HEXA_MILLENNIUM_ROOT")

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_root() -> str {
    if HEXA_MILLENNIUM_ROOT_ENV.len() > 0 { return HEXA_MILLENNIUM_ROOT_ENV }
    let oldpwd = env("OLDPWD")
    if oldpwd.len() > 0 {
        let t = exec("[ -f " + shq(oldpwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return oldpwd }
    }
    let pwd = env("PWD")
    if pwd.len() > 0 {
        let t = exec("[ -f " + shq(pwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return pwd }
    }
    return HOME + "/core/hexa-millennium"
}

fn _count_spec_lines(root: str) -> int {
    let cli = root + "/cli/hexa-millennium.hexa"
    // Count SPEC_* let bindings (one per verb)
    let raw = exec("grep -cE '^let SPEC_[A-Z_]+ *=' " + shq(cli)).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

fn _toml_int(root: str, key: str) -> int {
    let toml = root + "/hexa.toml"
    let cmd = "awk -F'=' '/^" + key + " *=/ {gsub(/[^0-9]/,\"\",$2); print $2; exit}' " + shq(toml)
    let raw = exec(cmd).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

fn _readme_verbs_badge(root: str) -> int {
    let readme = root + "/README.md"
    // Match badge like "verbs-7%2F7_candidate_spec" — extract the 7.
    let cmd = "grep -oE 'verbs-[0-9]+%2F[0-9]+_candidate_spec' " + shq(readme) + " | head -1 | grep -oE '^verbs-[0-9]+' | grep -oE '[0-9]+'"
    let raw = exec(cmd).trim()
    if raw.len() == 0 { return -1 }
    return int(raw)
}

fn _file_contains(p: str, needle: str) -> bool {
    let cmd = "grep -F " + shq(needle) + " " + shq(p) + " >/dev/null 2>&1 && echo yes || echo no"
    return exec(cmd).trim() == "yes"
}

fn main() {
    let root = _resolve_root()
    println("hexa-millennium/verify/closure_consistency — scoreboard cross-check")
    println("  root: " + root)
    println("")

    let mut ok = 0
    let mut bad = 0

    let cli_n = _count_spec_lines(root)
    let toml_total = _toml_int(root, "verbs_total")
    let toml_cand = _toml_int(root, "verbs_wired_as_candidate")
    let toml_proved = _toml_int(root, "verbs_formally_proved")
    let readme_n = _readme_verbs_badge(root)

    println("  cli/hexa-millennium.hexa SPEC_* rows:    " + str(cli_n))
    println("  hexa.toml verbs_total:                    " + str(toml_total))
    println("  hexa.toml verbs_wired_as_candidate:       " + str(toml_cand))
    println("  hexa.toml verbs_formally_proved:          " + str(toml_proved))
    println("  README badge verbs-N%2F7_candidate_spec:  " + str(readme_n))
    println("")

    if cli_n == 7 {
        println("  [PASS] CLI registry has 7 SPEC_* paths")
        ok = ok + 1
    } else {
        println("  [FAIL] CLI registry has " + str(cli_n) + " SPEC_* paths (expected 7)")
        bad = bad + 1
    }
    if toml_total == 7 {
        println("  [PASS] hexa.toml verbs_total = 7")
        ok = ok + 1
    } else {
        println("  [FAIL] hexa.toml verbs_total = " + str(toml_total))
        bad = bad + 1
    }
    if toml_cand == 7 {
        println("  [PASS] hexa.toml verbs_wired_as_candidate = 7")
        ok = ok + 1
    } else {
        println("  [FAIL] hexa.toml verbs_wired_as_candidate = " + str(toml_cand))
        bad = bad + 1
    }
    if toml_proved == 0 {
        ok = ok + 1
    } else {
        println("  [FAIL] hexa.toml verbs_formally_proved = " + str(toml_proved) + " (must be 0 — no formal proofs claimed)")
        bad = bad + 1
    }
    if readme_n == 7 {
        println("  [PASS] README badge verbs-7/7_candidate_spec")
        ok = ok + 1
    } else {
        println("  [FAIL] README badge verbs-" + str(readme_n) + " (expected 7)")
        bad = bad + 1
    }

    // Standard policy artifacts must be present.
    let must = ["LATTICE_POLICY.md", "LIMIT_BREAKTHROUGH.md", "AGENTS.md", "hexa.toml", "README.md", "LICENSE", "CITATION.cff"]
    for f in must {
        let abs_f = root + "/" + f
        let cmd = "[ -f " + shq(abs_f) + " ] && echo y || echo n"
        if exec(cmd).trim() == "y" {
            println("  [PASS] standard artifact: " + f)
            ok = ok + 1
        } else {
            println("  [FAIL] standard artifact missing: " + f)
            bad = bad + 1
        }
    }

    // AGENTS.md must register LATTICE_POLICY + LIMIT_BREAKTHROUGH.
    let agents = root + "/AGENTS.md"
    if _file_contains(agents, "LATTICE_POLICY.md") {
        println("  [PASS] AGENTS.md registers LATTICE_POLICY.md")
        ok = ok + 1
    } else {
        println("  [FAIL] AGENTS.md does not register LATTICE_POLICY.md")
        bad = bad + 1
    }
    if _file_contains(agents, "LIMIT_BREAKTHROUGH.md") {
        println("  [PASS] AGENTS.md registers LIMIT_BREAKTHROUGH.md")
        ok = ok + 1
    } else {
        println("  [FAIL] AGENTS.md does not register LIMIT_BREAKTHROUGH.md")
        bad = bad + 1
    }

    // README must register Verify section.
    let readme = root + "/README.md"
    if _file_contains(readme, "## Verify") {
        println("  [PASS] README registers Verify section")
        ok = ok + 1
    } else {
        println("  [FAIL] README missing '## Verify' section")
        bad = bad + 1
    }

    println("")
    println("  passed: " + str(ok) + "  failed: " + str(bad))
    if bad > 0 {
        println("__HEXA_MILLENNIUM_CLOSURE_CONSISTENCY__ FAIL")
        exit(1)
    }
    println("__HEXA_MILLENNIUM_CLOSURE_CONSISTENCY__ PASS")
}
